from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from Clock import { * }
from ClockProvider import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/Clock.coo", [
        javascript_native_provider_bootstrap_resolves_backend().map(assertion => test("JavaScript native provider bootstrap resolves backend", () => assertion)),
        native_provider_can_be_injected_through_generated_interface().map(assertion => test("native provider can be injected through generated interface", () => assertion)),
    ])

fun javascript_native_provider_bootstrap_resolves_backend(): Effect[Assert] =
    let clock <- system_clock()
    assert_that(true).is_true()

fun native_provider_can_be_injected_through_generated_interface(): Effect[Assert] =
    let clock <- system_clock()
    assert_that(true).is_true()
