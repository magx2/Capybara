from /capy/lang/Option import { * }
from /capy/lang/Result import { * }

fun match_string(value: any): string =
    match value with
    case string s -> "s:" + s
    case int i -> "i:" + i
    case _ -> ""

fun match_int(value: any): int =
    match value with
    case int i -> i + 1
    case string s -> 0
    case _ -> 0

fun match_int_ignore_binding(value: any): int =
    match value with
    case int _ -> 1
    case _ -> 0

data Person { name: string }
type Entity = Person

fun is_data(value: any): bool =
    match value with
    case data d -> true
    case _ -> false

fun is_data_from_entity(value: Entity): bool =
    match value with
    case data d -> true
    case _ -> false

fun classify_json_char(first_char: string): string =
    match first_char with
    case '{' -> "object"
    case '"' -> "string"
    case '-', '1', '2', '3', '4', '5', '6', '7', '8', '9', '0' -> "number"
    case _ -> "other"

fun classify_json_char_with_named_wildcard(first_char: string): string =
    match first_char with
    case '-' -> "minus"
    case '1', '2', '3', '4', '5', '6', '7', '8', '9', '0' -> "number"
    case _ v -> "unknown: " + v

fun mood(b: bool): string =
    match b with
    case true -> "I'm happy"
    case false -> "I'm sad"

fun bare_generic_type_pattern(value: any): int =
    match value with
    case list -> 1
    case set s -> 2
    case dict d -> 3
    case Option o -> 4
    case _ -> 0

fun list_generic_type_pattern(l: list[any]): int =
    match l with
    case list[string] -> 1
    case list[Option] -> 2
    case list[int] -> 3
    case list -> 99

fun nested_generic_type_pattern(l: list[any]): int =
    match l with
    case list[Option[Result[int]]] -> 1
    case list[Option] -> 2
    case list -> 99
