open class GreeterBase {
    field prefix: string = "hello"

    open fun describe(name: string): string = prefix + " " + name
}

interface Printable {
    fun print(): string
}

trait BracketNaming {
    fun bracket(name: string): string = "[" + name + "]"
}

class Person(name: string): GreeterBase, Printable, BracketNaming {
    field name: string = name

    fun greet(): string = this.describe(this.name)

    override fun print(): string {
        let label: string = super[GreeterBase].describe(this.name)
        return label + "!"
    }

    fun display(formal: bool): string {
        if formal {
            return this.bracket(this.name)
        } else {
            return this.name
        }
    }
}
