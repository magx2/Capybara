open class GreeterBase {
    field prefix: string = "hello"

    open def describe(name: string): string = prefix + " " + name
}

interface Printable {
    def print(): string
}

trait BracketNaming {
    def bracket(name: string): string = "[" + name + "]"
}

class Person(name: string): GreeterBase, Printable, BracketNaming {
    field name: string = name

    def greet(): string = this.describe(this.name)

    def mutable(): string {
        def x = "a"
        x = "2"
        return x
    }

    def ping(): void = this.describe(this.name)

    override def print(): string {
        let label: string = GreeterBase.describe(this.name)
        return label + "!"
    }

    def display(formal: bool): string {
        if formal {
            return this.bracket(this.name)
        } else {
            return this.name
        }
    }

    def nested_label(): string {
        {
            let label: string = this.describe(this.name)
            return label
        }
    }

    def second_name(values: string[]): string = values[1]

    def first_id(values: int[]): int = values[0]

    def copy_people(values: Person[]): Person[] = values

    def names(): string[] = string[]{"zero", "one"}

    def slots(size: int): int[] = int[size]

    def first_positive(values: list[int]): int {
        for value in values {
            if value > 0 {
                return value
            }
        }
        return 0
    }

    def first_large(values: list[int]): int {
        foreach value: int in values {
            if value > 10 {
                return value
            }
        }
        return 0
    }

    def while_flag(flag: bool): int {
        while flag {
            return 1
        }
        return 0
    }

    def do_once(flag: bool): int {
        do {
            if flag {
                return 1
            }
            return 2
        } while false
    }

    def warmup(formal: bool): void {
        if formal {
            let label: string = this.bracket(this.name)
            {
                let copy: string = label
            }
        } else {
            let copy: string = this.name
        }
    }

    def foreach_warm(values: list[int]): void {
        foreach value in values {
            let label: string = this.bracket(this.name)
        }
    }

    def while_warm(flag: bool): void {
        while flag {
            let label: string = this.name
        }
    }

    def do_warm(): void {
        do {
            let label: string = this.describe(this.name)
        } while false
    }
}
