from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from NativeWiring import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/NativeWiring.coo", [
        native_wiring_app_is_constructible_with_host_provider_available().map(assertion => test("NativeWiringApp is constructible with host provider available", () => assertion)),
        native_provider_can_be_passed_to_domain_code().map(assertion => test("native provider can be passed to domain code", () => assertion)),
    ])

fun native_wiring_app_is_constructible_with_host_provider_available(): Effect[Assert] =
    let clock = system_clock()
    let app <- NativeWiringApp()
    assert_that(true).is_true()

fun native_provider_can_be_passed_to_domain_code(): Effect[Assert] =
    let clock = system_clock()
    let consumer <- NativeClockConsumer(clock)
    assert_that(true).is_true()
