from /capy/meta_prog/NativeProvider import { NativeProvider }

@NativeProvider(name: "system_clock", qualifier: "system")
interface NativeClock {
    def now_millis(): long
}

class NativeClockConsumer(clock: NativeClock) {
    field clock: NativeClock = clock

    def read(): long =
        this.clock.now_millis()
}

class NativeWiringApp {
    def read(): long =
        NativeClockConsumer(system_clock()).read()
}
