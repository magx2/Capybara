from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from ObjectConstructionInterop import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/ObjectConstructionInterop.cfun", [
        functional_object_construction_is_delayed_and_repeatable().map(assertion => test("functional object construction is delayed and repeatable", () => assertion)),
        parent_typed_construction_and_sequencing_work().map(assertion => test("parent typed construction and sequencing work", () => assertion)),
        zero_argument_construction_is_delayed_and_executable().map(assertion => test("zero argument construction is delayed and executable", () => assertion)),
        qualified_import_construction_works().map(assertion => test("qualified import construction works", () => assertion)),
    ])

fun functional_object_construction_is_delayed_and_repeatable(): Effect[Assert] =
    // The legacy host tests also assert exact stdout capture, generated class identity,
    // fresh object identity, CommonJS wiring, and label() results. Capybara .cfun tests
    // can sequence OO construction effects across backends, but cannot capture stdout,
    // compare backend object identity, or invoke OO instance methods portably.
    let person_runs <- runs_person_effect("Ada")
    let person_runs_twice <- runs_person_effect_twice("Ada")
    assert_all([
        assert_that(construct_lazily("Ada")).is_true(),
        assert_that(person_runs).is_true(),
        assert_that(person_runs_twice).is_true(),
    ])

fun parent_typed_construction_and_sequencing_work(): Effect[Assert] =
    let printable_runs <- runs_printable_effect("Bara")
    let sequence <- sequence_two("A", "B")
    assert_all([
        assert_that(printable_runs).is_true(),
        assert_that(sequence).is_equal_to("A:B"),
    ])

fun zero_argument_construction_is_delayed_and_executable(): Effect[Assert] =
    // Portable assertions cannot observe the absence of stdout at effect creation time.
    let empty_runs <- runs_empty_effect()
    assert_all([
        assert_that(creates_empty_effect_lazily()).is_true(),
        assert_that(empty_runs).is_true(),
    ])

fun qualified_import_construction_works(): Effect[Assert] =
    let qualified_person_runs <- runs_qualified_person_effect("Qual")
    let qualified_printable_runs <- runs_qualified_printable_effect("Iface")
    assert_all([
        assert_that(qualified_person_runs).is_true(),
        assert_that(qualified_printable_runs).is_true(),
    ])

private fun runs_person_effect(name: String): Effect[bool] =
    let person <- make_person(name)
    true

private fun runs_person_effect_twice(name: String): Effect[bool] =
    let effect = make_person(name)
    let first <- effect
    let second <- effect
    true

private fun runs_printable_effect(name: String): Effect[bool] =
    let printable <- make_printable(name)
    true

private fun creates_empty_effect_lazily(): bool =
    let effect = make_empty()
    true

private fun runs_empty_effect(): Effect[bool] =
    let empty <- make_empty()
    true

private fun runs_qualified_person_effect(name: String): Effect[bool] =
    let person <- make_qualified_person(name)
    true

private fun runs_qualified_printable_effect(name: String): Effect[bool] =
    let printable <- make_qualified_printable(name)
    true
