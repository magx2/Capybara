from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from E2eObjectTestSupport import { e2e_object_test_file }
from /dev/capylang/test/ObjectConstructionInterop import { sequence_two }

fun tests(): Effect[TestFile] =
    e2e_object_test_file("ObjectConstructionInterop.cfun", [
        test("should sequence object construction interop effects", () => should_construct_objects()),
    ])

fun should_construct_objects(): Assert =
    assert_that(sequence_two("Capy", "Bara").unsafe_run()).is_equal_to("Capy:Bara")
