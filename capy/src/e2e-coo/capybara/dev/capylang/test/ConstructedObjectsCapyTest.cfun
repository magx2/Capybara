from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
import ConstructedObjects
from ConstructedObjects import { EmptyTracked, TrackedPerson, TrackedPrintable }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/ConstructedObjects.coo", [
        effect_test("person construction is delayed and executable", () => person_construction_is_delayed_and_executable()),
        effect_test("parent typed construction and sequencing work", () => parent_typed_construction_and_sequencing_work()),
        effect_test("zero argument construction is delayed", () => zero_argument_construction_is_delayed()),
        effect_test("qualified import construction works", () => qualified_import_construction_works()),
    ])

fun person_construction_is_delayed_and_executable(): Effect[Assert] =
    // The legacy host tests also assert exact stdout capture, generated class identity,
    // fresh object identity, and label() results. Capybara .cfun tests can construct
    // OO values but cannot invoke OO instance methods or compare backend object identity,
    // so those host-facing observations remain there.
    let person_constructed <- constructs_person("Ada")
    assert_all([
        assert_that(construct_person_lazily("Ada")).is_true(),
        assert_that(person_constructed).is_true(),
    ])

fun parent_typed_construction_and_sequencing_work(): Effect[Assert] =
    let printable_constructed <- constructs_printable("Bara")
    let sequence <- construct_in_sequence("A", "B")
    assert_all([
        assert_that(printable_constructed).is_true(),
        assert_that(sequence).is_equal_to("A:B"),
    ])

fun zero_argument_construction_is_delayed(): Effect[Assert] =
    // Portable assertions cannot capture the absence or order of stdout writes or call label().
    let empty_constructed <- constructs_empty()
    assert_all([
        assert_that(construct_empty_lazily()).is_true(),
        assert_that(empty_constructed).is_true(),
    ])

fun qualified_import_construction_works(): Effect[Assert] =
    let qualified_person_constructed <- constructs_qualified_person("Qual")
    let qualified_printable_constructed <- constructs_qualified_printable("Iface")
    assert_all([
        assert_that(qualified_person_constructed).is_true(),
        assert_that(qualified_printable_constructed).is_true(),
    ])

private fun construct_person_lazily(name: String): bool =
    let effect = TrackedPerson(name)
    true

private fun constructs_person(name: String): Effect[bool] =
    let person <- TrackedPerson(name)
    true

private fun constructs_printable(name: String): Effect[bool] =
    let printable: TrackedPrintable <- TrackedPerson(name)
    true

private fun construct_in_sequence(left: String, right: String): Effect[String] =
    let first <- TrackedPerson(left)
    let second <- TrackedPerson(right)
    left + ":" + right

private fun construct_empty_lazily(): bool =
    let effect = EmptyTracked()
    true

private fun constructs_empty(): Effect[bool] =
    let empty <- EmptyTracked()
    true

private fun constructs_qualified_person(name: String): Effect[bool] =
    let person <- ConstructedObjects.TrackedPerson(name)
    true

private fun constructs_qualified_printable(name: String): Effect[bool] =
    let printable: ConstructedObjects.TrackedPrintable <- ConstructedObjects.TrackedPerson(name)
    true
