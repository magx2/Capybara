from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from /capy/collection/List import { * }
from ListCollection import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/collection/ListCollection.cfun", [
        test("static_list returns expected values", () => list_collection_static_list_returns_expected_values()),
        test("empty_static_list returns empty list", () => list_collection_empty_static_list_returns_empty_list()),
        test("static_list_with_trailing_comma returns expected values", () => list_collection_static_list_with_trailing_comma_returns_expected_values()),
        test("append adds value without mutating input", () => list_collection_append_adds_value_without_mutating_input()),
        test("append_list concatenates lists without mutating inputs", () => list_collection_append_list_concatenates_lists_without_mutating_inputs()),
        test("remove removes matching values without mutating input", () => list_collection_remove_removes_matching_values_without_mutating_input()),
        test("remove_list removes right-hand values without mutating inputs", () => list_collection_remove_list_removes_right_hand_values_without_mutating_inputs()),
        test("contains detects present and missing values", () => list_collection_contains_detects_present_and_missing_values()),
        test("any reports whether any value matches", () => list_collection_any_reports_whether_any_value_matches()),
        test("any_empty returns false for empty list", () => list_collection_any_empty_returns_false_for_empty_list()),
        test("all reports whether all values match", () => list_collection_all_reports_whether_all_values_match()),
        test("all_empty returns true for empty list", () => list_collection_all_empty_returns_true_for_empty_list()),
        test("is_empty reports empty state", () => list_collection_is_empty_reports_empty_state()),
        test("not_is_empty negates empty state", () => list_collection_not_is_empty_negates_empty_state()),
        test("not_nested_is_empty reads nested list field", () => list_collection_not_nested_is_empty_reads_nested_list_field()),
        test("size returns list size", () => list_collection_size_returns_list_size()),
        test("let_named_list returns local list size", () => list_collection_let_named_list_returns_local_list_size()),
    ])

private fun list_collection_static_list_returns_expected_values(): Assert =
    assert_that(static_list()).is_equal_to([1, 2, 3])

private fun list_collection_empty_static_list_returns_empty_list(): Assert =
    assert_that(empty_static_list()).is_empty()

private fun list_collection_static_list_with_trailing_comma_returns_expected_values(): Assert =
    assert_that(static_list_with_trailing_comma()).is_equal_to([1, 2, 3])

private fun list_collection_append_adds_value_without_mutating_input(): Assert =
    let input = [1, 2, 3]
    let result = append(input)
    assert_all([
        assert_that(result).is_equal_to([1, 2, 3, 5]),
        assert_that(input).is_equal_to([1, 2, 3]),
    ])

private fun list_collection_append_list_concatenates_lists_without_mutating_inputs(): Assert =
    let left = [1, 2]
    let right = [3, 4]
    let result = append_list(left, right)
    assert_all([
        assert_that(result).is_equal_to([1, 2, 3, 4]),
        assert_that(left).is_equal_to([1, 2]),
        assert_that(right).is_equal_to([3, 4]),
    ])

private fun list_collection_remove_removes_matching_values_without_mutating_input(): Assert =
    let input = [1, 2, 2, 3]
    let result = remove(input)
    assert_all([
        assert_that(result).is_equal_to([1, 3]),
        assert_that(input).is_equal_to([1, 2, 2, 3]),
    ])

private fun list_collection_remove_list_removes_right_hand_values_without_mutating_inputs(): Assert =
    let left = [1, 2, 2, 3, 4]
    let right = [2, 4]
    let result = remove_list(left, right)
    assert_all([
        assert_that(result).is_equal_to([1, 3]),
        assert_that(left).is_equal_to([1, 2, 2, 3, 4]),
        assert_that(right).is_equal_to([2, 4]),
    ])

private fun list_collection_contains_detects_present_and_missing_values(): Assert =
    assert_all([
        assert_that(contains([1, 2, 3], 2)).is_true(),
        assert_that(contains([1, 2, 3], 9)).is_false(),
    ])

private fun list_collection_any_reports_whether_any_value_matches(): Assert =
    assert_all([
        assert_that(any([1, 2, 3])).is_true(),
        assert_that(any([0, 1, 2])).is_false(),
    ])

private fun list_collection_any_empty_returns_false_for_empty_list(): Assert =
    let empty: List[int] = []
    assert_that(any_empty(empty)).is_false()

private fun list_collection_all_reports_whether_all_values_match(): Assert =
    assert_all([
        assert_that(all([1, 2, 3])).is_true(),
        assert_that(all([0, 1, 2])).is_false(),
    ])

private fun list_collection_all_empty_returns_true_for_empty_list(): Assert =
    let empty: List[int] = []
    assert_that(all_empty(empty)).is_true()

private fun list_collection_is_empty_reports_empty_state(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that(is_empty(empty)).is_true(),
        assert_that(is_empty([1, 2, 3])).is_false(),
    ])

private fun list_collection_not_is_empty_negates_empty_state(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that(not_is_empty(empty)).is_false(),
        assert_that(not_is_empty([1, 2, 3])).is_true(),
    ])

private fun list_collection_not_nested_is_empty_reads_nested_list_field(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that(not_nested_is_empty(ListHolder { values: empty })).is_false(),
        assert_that(not_nested_is_empty(ListHolder { values: [1, 2, 3] })).is_true(),
    ])

private fun list_collection_size_returns_list_size(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that(size([1, 2, 3])).is_equal_to(3),
        assert_that(size(empty)).is_zero(),
    ])

private fun list_collection_let_named_list_returns_local_list_size(): Assert =
    assert_that(let_named_list()).is_equal_to(4)
