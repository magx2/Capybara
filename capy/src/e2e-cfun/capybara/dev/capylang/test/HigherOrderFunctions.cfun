from /capy/collection/List import { * }
from /capy/collection/Set import { * }
from /capy/collection/Dict import { * }
from /capy/collection/Seq import { * }

fun map(l: List[int]) = l | :double

fun double(x: int) = x * x

fun hof(fun: int=>String) = fun(5)

fun invoke_hof(s: String) = hof(x => s + " " + x)

fun plus(a: int, b: int, c: int, d: int) = a+b-c*d

fun run(fun: (int, int, int, int ) => int) = fun(5,6,7,8)

fun run_lambda() = run((a, b, c, d) => a + b - c * d)

fun run_lambda2() = run(:plus)

fun invoke_hof_unused(s: String) = hof(_ => s)

fun run_lambda_unused_middle() = run((a, _, c, d) => a + c)

fun run0(fun: () => String) = fun()

fun run_lambda_no_args() = run0(() => "Hello, Wrold")

fun run_partial_function_call() =
    let increment = plus(_, 1, 0, 1)
    increment(41)

fun run_partial_function_call_multiple_arguments() =
    let combine = plus(10, _, _, 2)
    combine(7, 3)

fun run_partial_method_call() =
    let has_suffix = "capybara".end_with(_)
    has_suffix("bara")

fun run_partial_extension_method_call() =
    let contains_value: int => bool = [1, 2, 3].contains(_)
    contains_value(2) & !contains_value(4)
