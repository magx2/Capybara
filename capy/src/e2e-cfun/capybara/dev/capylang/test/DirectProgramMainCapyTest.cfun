from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Program import { * }
from DirectProgramMain import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/DirectProgramMain.cfun", [
        test("direct program main returns success", () => direct_program_main_returns_success()),
    ])

// The legacy Java host test also asserts generated Java has no main(String[]) entrypoint.
// That is backend-specific generated-shape behavior and has no portable Capybara test assertion.

fun direct_program_main_returns_success(): Assert =
    assert_that(main([])).is_equal_to(Success {})
