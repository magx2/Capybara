from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from E2eTestSupport import { e2e_test_file }
from /dev/capylang/test/SimpleFunction import { add }

fun tests(): Effect[TestFile] =
    e2e_test_file("SimpleFunction.cfun", [
        test("should add numbers", () => should_add_numbers()),
    ])

fun should_add_numbers(): Assert =
    assert_that(add(19, 23)).is_equal_to(42)
