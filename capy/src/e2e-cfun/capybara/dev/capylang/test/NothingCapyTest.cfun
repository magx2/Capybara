from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from Nothing import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/Nothing.cfun", [
        test("explicit return type placeholder can be deferred", () => explicit_return_type_placeholder_can_be_deferred()),
        test("inferred return type placeholder can be deferred", () => inferred_return_type_placeholder_can_be_deferred()),
    ])

fun explicit_return_type_placeholder_can_be_deferred(): Assert =
    // The legacy Java/JS host tests assert that invoking nothing1(1) throws:
    // line 1, column 28, file /dev/capylang/test/Nothing.cfun: the function `nothing1` is not yet implemented
    // The Capybara assertion framework does not currently expose a portable assert-throws primitive.
    let direct: Effect[int] = delay(() => nothing1(1))
    let forwarded: Effect[int] = delay(() => eval1(1))
    assert_all([
        assert_that(effect_is_constructed(direct)).is_true(),
        assert_that(effect_is_constructed(forwarded)).is_true(),
    ])

fun inferred_return_type_placeholder_can_be_deferred(): Assert =
    // The legacy Java/JS host tests assert that invoking nothing2(1) throws:
    // line 3, column 23, file /dev/capylang/test/Nothing.cfun: the function `nothing2` is not yet implemented
    // The Capybara assertion framework does not currently expose a portable assert-throws primitive.
    let direct = delay(() => nothing2(1))
    let forwarded = delay(() => eval2(1))
    assert_all([
        assert_that(effect_is_constructed(direct)).is_true(),
        assert_that(effect_is_constructed(forwarded)).is_true(),
    ])

private fun effect_is_constructed(effect: Effect[T]): bool =
    true
