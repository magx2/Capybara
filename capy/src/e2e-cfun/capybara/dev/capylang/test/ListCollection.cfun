from /capy/lang/Collections import { * }

fun static_list(): List[int] = [1,2,3]

fun empty_static_list(): List[int] = []

fun static_list_with_trailing_comma(): List[int] = [1,2,3,]

fun append(l: List[int]): List[int] = l + 5

fun append_list(left: List[int], right: List[int]): List[int] = left + right

fun remove(l: List[int]): List[int] = l - 2

fun remove_list(left: List[int], right: List[int]): List[int] = left - right

fun contains(l: List[int], value: int): bool = l ? value

fun any(l: List[int]): bool = l.any(value => value > 2)

fun any_empty(l: List[int]): bool = l.any(value => value > 2)

fun all(l: List[int]): bool = l.all(value => value > 0)

fun all_empty(l: List[int]): bool = l.all(value => value > 0)

fun is_empty(l: List[int]): bool = l.is_empty()

data ListHolder { values: List[int] }

fun not_is_empty(l: List[int]): bool = !l.is_empty()

fun not_nested_is_empty(holder: ListHolder): bool = !holder.values.is_empty()

fun size(l: List[int]): int = l.size()

fun let_named_list(): int =
    let list: List[int] = [1, 2, 3, 4]
    list.size()
