from /capy/collection/CollectionTypes import { * }
from /capy/lang/Option import { * }
from /capy/lang/Result import { * }
from /capy/lang/String import { * }

type user_id -> int with constructor {
    if value > 0
    then Success { value }
    else Error { message: "bad user id" }
}

type order_id -> int
type score -> int
type token -> String

const FIRST_USER_ID = user_id! { 1 }

fun new_user_id(value: int): Result[user_id] = user_id { value }
fun raw_user_id(value: int): user_id = user_id! { value }
fun unwrap_user_id(id: user_id): int = @id
fun unwrap_raw_user_id(value: int): int = unwrap_user_id(raw_user_id(value))
fun score_of(value: int): score = score { value }
fun unwrap_score(score: score): int = @score
fun raw_token(value: String): token = token { value }
fun unwrap_token(value: token): String = @value
fun append_token_suffix(value: String): String = value + "_suffix"
fun pass_token_to_string(value: token): String = append_token_suffix(value)

fun user_id.plus(other: user_id): user_id = user_id! { @this + @other }
fun user_id.`+`(other: user_id): user_id = user_id! { @this + @other }

fun plus_user_ids(left: user_id, right: user_id): user_id = left.plus(right)
fun add_user_ids(left: user_id, right: user_id): user_id = left + right

fun increment_int(value: int): int = value + 1
fun increment_user_id(id: user_id): int = increment_int(id)

fun string_at(input: String, idx: index): String =
    match input[idx] with
    case Some { value } -> value
    case None -> ""

fun string_get(input: String, idx: index): String =
    match input.get(idx) with
    case Some { value } -> value
    case None -> ""
