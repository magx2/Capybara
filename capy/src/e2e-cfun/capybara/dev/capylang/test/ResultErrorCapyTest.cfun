from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Result import { * }
from /capy/lang/String import { * }
from ResultError import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/ResultError.cfun", [
        test("success_result returns success value", () => success_result_returns_success_value()),
        test("fail_result returns error message", () => fail_result_returns_error_message()),
        test("parse_and_add_rest_size adds parsed value and rest size", () => parse_and_add_rest_size_adds_parsed_value_and_rest_size()),
        test("parse_and_add_rest_size propagates parse errors", () => parse_and_add_rest_size_propagates_parse_errors()),
        test("map_untyped_result maps success value", () => map_untyped_result_maps_success_value()),
        test("flatmap_untyped_result maps nested success value", () => flatmap_untyped_result_maps_nested_success_value()),
        test("dict_reduce_then_map keeps entries and final suffix", () => dict_reduce_then_map_keeps_entries_and_final_suffix()),
    ])

private fun success_result_returns_success_value(): Assert =
    assert_that(success_result()).succeeds(7)

private fun fail_result_returns_error_message(): Assert =
    assert_that(fail_result()).fails("boom")

private fun parse_and_add_rest_size_adds_parsed_value_and_rest_size(): Assert =
    assert_that(parse_and_add_rest_size("10")).succeeds(13L)

private fun parse_and_add_rest_size_propagates_parse_errors(): Assert =
    result_error_assert_failed_message_contains(parse_and_add_rest_size("abc"), "Cannot parse string to long")

private fun map_untyped_result_maps_success_value(): Assert =
    assert_that(map_untyped_result()).succeeds("mapped_success_value")

private fun flatmap_untyped_result_maps_nested_success_value(): Assert =
    assert_that(flatmap_untyped_result()).succeeds("mapped_success_value")

private fun dict_reduce_then_map_keeps_entries_and_final_suffix(): Assert =
    assert_that(dict_reduce_then_map({"a": 1, "b": 2})).succeeds(value => assert_all([
        assert_that(value).contains("a:1,"),
        assert_that(value).contains("b:2,"),
        result_error_assert_string_ends_with(value, "done"),
    ]))

private fun result_error_assert_failed_message_contains(result: Result[T], expected: String): Assert =
    assert_all([
        assert_that(result).fails(),
        assert_that(result_error_message(result)).contains(expected),
    ])

private fun result_error_message(result: Result[T]): String =
    match result with
    case Error e -> e.message
    case Success _ -> ""

private fun result_error_assert_string_ends_with(value: String, suffix: String): Assert =
    assert_that(result_error_string_ends_with(value, suffix)).is_true()

private fun result_error_string_ends_with(value: String, suffix: String): bool =
    let value_size = value.size().value
    let suffix_size = suffix.size().value
    if value_size < suffix_size
    then false
    else value[value_size - suffix_size, value_size] == suffix
