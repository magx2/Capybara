from /capy/io/ByteSize import { * }
from /capy/io/Path import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Result import { * }

fun read_text_file(path: Path): Effect[Result[String]] = path.read_text()

fun read_lines_file(path: Path): Effect[Result[List[String]]] = path.read_lines()

fun read_bytes_file(path: Path): Effect[Result[List[byte]]] = path.read_bytes()

fun write_text_file(path: Path, text: String): Effect[Result[String]] = path.write_text(text)

fun write_lines_file(path: Path, lines: List[String]): Effect[Result[List[String]]] = path.write_lines(lines)

fun write_bytes_file(path: Path, bytes: List[byte]): Effect[Result[List[byte]]] = path.write_bytes(bytes)

fun append_text_file(path: Path, text: String): Effect[Result[String]] = path.append_text(text)

fun append_lines_file(path: Path, lines: List[String]): Effect[Result[List[String]]] = path.append_lines(lines)

fun append_bytes_file(path: Path, bytes: List[byte]): Effect[Result[List[byte]]] = path.append_bytes(bytes)

fun exists_path(path: Path): Effect[bool] = path.exists()

fun is_file_path(path: Path): Effect[bool] = path.is_file()

fun is_directory_path(path: Path): Effect[bool] = path.is_directory()

fun file_size(path: Path): Effect[Result[byte_count]] = path.size()

fun create_file_at(path: Path): Effect[Result[Path]] = path.create_file()

fun create_directory_at(path: Path): Effect[Result[Path]] = path.create_directory()

fun create_directories_at(path: Path): Effect[Result[Path]] = path.create_directories()

fun list_directory(path: Path): Effect[Result[List[Path]]] = path.list_entries()

fun delete_path(path: Path): Effect[Result[bool]] = path.delete()

fun copy_path(source: Path, target: Path): Effect[Result[Path]] = source.copy(target)

fun copy_replace_path(source: Path, target: Path): Effect[Result[Path]] = source.copy_replace(target)

fun move_path(source: Path, target: Path): Effect[Result[Path]] = source.move(target)

fun move_replace_path(source: Path, target: Path): Effect[Result[Path]] = source.move_replace(target)
