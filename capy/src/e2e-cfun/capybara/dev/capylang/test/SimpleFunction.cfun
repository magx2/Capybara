fun classify(x: int): String =
    if (x > 0) then "positive" else "non-positive"

fun always_true(): bool = true

fun add(a: int, b: int): int = a + b

fun subtract(a: int, b: int): int = a - b

fun multiply(a: int, b: int): int = a * b

fun divide(a: int, b: int): int =
    a / {
        let x = if (b != 0) then b else 1
        x
    }

fun is_positive(x: int): bool = x > 0

fun greet(name: String): String = "Hello, " + name

fun double_then_classify(x: int): String =
    if (x * 2 > 0) then "positive" else "non-positive"

fun order_of_expression(a: int, b: int): int =
    {
        let x = (a-1) * b
        x + 1
    } * {
        let x = a + 1 * b
        x - 1
    }

fun power(x: int, y: int): int = x ^ y

fun static_list(): List[int] = [1,2,3]

fun foo(x: int): int = x + 1

private fun hidden_foo(x: int): int = x + 2

fun call_private_and_public(x: int): int = foo(x) + hidden_foo(x)

fun typed_let_string(): String =
    {
        let s: String = 'd'
        s
    }

fun typed_let_tuple_string(): String =
    {
        let pair: Tuple[String, int] = ("d", 1)
        pair[0]
    }

fun typed_let_tuple_int(): int =
    {
        let pair: Tuple[String, int] = ("d", 1)
        pair[1]
    }

fun typed_let_bool(): bool =
    {
        let v: bool = true
        v
    }

fun typed_let_int(): int =
    {
        let v: int = 7
        v
    }

fun typed_let_long(): long =
    {
        let v: long = 7L
        v
    }

fun typed_let_float(): float =
    {
        let v: float = 1.5f
        v
    }

fun typed_let_double(): double =
    {
        let v: double = 1.5d
        v
    }

fun typed_let_list(): List[int] =
    {
        let v: List[int] = [1, 2, 3]
        v
    }

fun typed_let_set(): Set[int] =
    {
        let v: Set[int] = {1, 2, 3}
        v
    }

fun typed_let_dict(): Dict[int] =
    {
        let v: Dict[int] = {"a": 1, "b": 2}
        v
    }

