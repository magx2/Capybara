from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from InfixOperators import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/InfixOperators.cfun", [
        test("plus promotes numeric operands and concatenates strings", () => plus_promotes_numeric_operands_and_concatenates_strings()),
        test("minus promotes numeric operands and supports string-left numeric operands", () => minus_promotes_numeric_operands_and_supports_string_left_numeric_operands()),
        test("multiplication promotes numeric operands and supports string-left numeric operands", () => multiplication_promotes_numeric_operands_and_supports_string_left_numeric_operands()),
        test("division promotes numeric operands and supports string-left numeric operands", () => division_promotes_numeric_operands_and_supports_string_left_numeric_operands()),
        test("power promotes numeric operands and supports string-left numeric operands", () => power_promotes_numeric_operands_and_supports_string_left_numeric_operands()),
    ])

private fun plus_promotes_numeric_operands_and_concatenates_strings(): Assert =
    assert_all([
        assert_byte(plus_byte_byte(0x06, 0x02), 0x08),
        assert_that(plus_byte_int(0x06, 2)).is_equal_to(8),
        assert_that(plus_byte_long(0x06, 2L)).is_equal_to(8L),
        assert_that(plus_byte_float(0x06, 2.0f)).is_equal_to(8.0f),
        assert_that(plus_byte_double(0x06, 2.0)).is_equal_to(8.0),
        assert_that(plus_byte_string(0x06, "x")).is_equal_to("6x"),
        assert_that(plus_int_byte(6, 0x02)).is_equal_to(8),
        assert_that(plus_int_int(6, 2)).is_equal_to(8),
        assert_that(plus_int_long(6, 2L)).is_equal_to(8L),
        assert_that(plus_int_float(6, 2.0f)).is_equal_to(8.0f),
        assert_that(plus_int_double(6, 2.0)).is_equal_to(8.0),
        assert_that(plus_int_string(6, "x")).is_equal_to("6x"),
        assert_that(plus_long_byte(6L, 0x02)).is_equal_to(8L),
        assert_that(plus_long_int(6L, 2)).is_equal_to(8L),
        assert_that(plus_long_long(6L, 2L)).is_equal_to(8L),
        assert_that(plus_long_float(6L, 2.0f)).is_equal_to(8.0f),
        assert_that(plus_long_double(6L, 2.0)).is_equal_to(8.0),
        assert_that(plus_long_string(6L, "x")).is_equal_to("6x"),
        assert_that(plus_float_byte(6.0f, 0x02)).is_equal_to(8.0f),
        assert_that(plus_float_int(6.0f, 2)).is_equal_to(8.0f),
        assert_that(plus_float_long(6.0f, 2L)).is_equal_to(8.0f),
        assert_that(plus_float_float(6.0f, 2.0f)).is_equal_to(8.0f),
        assert_that(plus_float_double(6.0f, 2.0)).is_equal_to(8.0),
        assert_that(plus_float_string(6.5f, "x")).is_equal_to("6.5x"),
        assert_that(plus_double_byte(6.0, 0x02)).is_equal_to(8.0),
        assert_that(plus_double_int(6.0, 2)).is_equal_to(8.0),
        assert_that(plus_double_long(6.0, 2L)).is_equal_to(8.0),
        assert_that(plus_double_float(6.0, 2.0f)).is_equal_to(8.0),
        assert_that(plus_double_double(6.0, 2.0)).is_equal_to(8.0),
        assert_that(plus_double_string(6.5, "x")).is_equal_to("6.5x"),
        assert_that(plus_string_byte("x", 0x06)).is_equal_to("x6"),
        assert_that(plus_string_int("x", 6)).is_equal_to("x6"),
        assert_that(plus_string_long("x", 6L)).is_equal_to("x6"),
        assert_that(plus_string_float("x", 6.5f)).is_equal_to("x6.5"),
        assert_that(plus_string_double("x", 6.5)).is_equal_to("x6.5"),
        assert_that(plus_string_string("x", "y")).is_equal_to("xy"),
    ])

private fun minus_promotes_numeric_operands_and_supports_string_left_numeric_operands(): Assert =
    assert_all([
        assert_byte(minus_byte_byte(0x06, 0x02), 0x04),
        assert_that(minus_byte_int(0x06, 2)).is_equal_to(4),
        assert_that(minus_byte_long(0x06, 2L)).is_equal_to(4L),
        assert_that(minus_byte_float(0x06, 2.0f)).is_equal_to(4.0f),
        assert_that(minus_byte_double(0x06, 2.0)).is_equal_to(4.0),
        assert_that(minus_int_byte(6, 0x02)).is_equal_to(4),
        assert_that(minus_int_int(6, 2)).is_equal_to(4),
        assert_that(minus_int_long(6, 2L)).is_equal_to(4L),
        assert_that(minus_int_float(6, 2.0f)).is_equal_to(4.0f),
        assert_that(minus_int_double(6, 2.0)).is_equal_to(4.0),
        assert_that(minus_long_byte(6L, 0x02)).is_equal_to(4L),
        assert_that(minus_long_int(6L, 2)).is_equal_to(4L),
        assert_that(minus_long_long(6L, 2L)).is_equal_to(4L),
        assert_that(minus_long_float(6L, 2.0f)).is_equal_to(4.0f),
        assert_that(minus_long_double(6L, 2.0)).is_equal_to(4.0),
        assert_that(minus_float_byte(6.0f, 0x02)).is_equal_to(4.0f),
        assert_that(minus_float_int(6.0f, 2)).is_equal_to(4.0f),
        assert_that(minus_float_long(6.0f, 2L)).is_equal_to(4.0f),
        assert_that(minus_float_float(6.0f, 2.0f)).is_equal_to(4.0f),
        assert_that(minus_float_double(6.0f, 2.0)).is_equal_to(4.0),
        assert_that(minus_double_byte(6.0, 0x02)).is_equal_to(4.0),
        assert_that(minus_double_int(6.0, 2)).is_equal_to(4.0),
        assert_that(minus_double_long(6.0, 2L)).is_equal_to(4.0),
        assert_that(minus_double_float(6.0, 2.0f)).is_equal_to(4.0),
        assert_that(minus_double_double(6.0, 2.0)).is_equal_to(4.0),
        assert_that(minus_string_byte("x", 0x06)).is_equal_to("x6"),
        assert_that(minus_string_int("x", 6)).is_equal_to("x6"),
        assert_that(minus_string_long("x", 6L)).is_equal_to("x6"),
        assert_that(minus_string_float("x", 6.5f)).is_equal_to("x6.5"),
        assert_that(minus_string_double("x", 6.5)).is_equal_to("x6.5"),
    ])

private fun multiplication_promotes_numeric_operands_and_supports_string_left_numeric_operands(): Assert =
    assert_all([
        assert_byte(mul_byte_byte(0x06, 0x02), 0x0C),
        assert_that(mul_byte_int(0x06, 2)).is_equal_to(12),
        assert_that(mul_byte_long(0x06, 2L)).is_equal_to(12L),
        assert_that(mul_byte_float(0x06, 2.0f)).is_equal_to(12.0f),
        assert_that(mul_byte_double(0x06, 2.0)).is_equal_to(12.0),
        assert_that(mul_int_byte(6, 0x02)).is_equal_to(12),
        assert_that(mul_int_int(6, 2)).is_equal_to(12),
        assert_that(mul_int_long(6, 2L)).is_equal_to(12L),
        assert_that(mul_int_float(6, 2.0f)).is_equal_to(12.0f),
        assert_that(mul_int_double(6, 2.0)).is_equal_to(12.0),
        assert_that(mul_long_byte(6L, 0x02)).is_equal_to(12L),
        assert_that(mul_long_int(6L, 2)).is_equal_to(12L),
        assert_that(mul_long_long(6L, 2L)).is_equal_to(12L),
        assert_that(mul_long_float(6L, 2.0f)).is_equal_to(12.0f),
        assert_that(mul_long_double(6L, 2.0)).is_equal_to(12.0),
        assert_that(mul_float_byte(6.0f, 0x02)).is_equal_to(12.0f),
        assert_that(mul_float_int(6.0f, 2)).is_equal_to(12.0f),
        assert_that(mul_float_long(6.0f, 2L)).is_equal_to(12.0f),
        assert_that(mul_float_float(6.0f, 2.0f)).is_equal_to(12.0f),
        assert_that(mul_float_double(6.0f, 2.0)).is_equal_to(12.0),
        assert_that(mul_double_byte(6.0, 0x02)).is_equal_to(12.0),
        assert_that(mul_double_int(6.0, 2)).is_equal_to(12.0),
        assert_that(mul_double_long(6.0, 2L)).is_equal_to(12.0),
        assert_that(mul_double_float(6.0, 2.0f)).is_equal_to(12.0),
        assert_that(mul_double_double(6.0, 2.0)).is_equal_to(12.0),
        assert_that(mul_string_byte("x", 0x06)).is_equal_to("x6"),
        assert_that(mul_string_int("x", 6)).is_equal_to("x6"),
        assert_that(mul_string_long("x", 6L)).is_equal_to("x6"),
        assert_that(mul_string_float("x", 6.5f)).is_equal_to("x6.5"),
        assert_that(mul_string_double("x", 6.5)).is_equal_to("x6.5"),
    ])

private fun division_promotes_numeric_operands_and_supports_string_left_numeric_operands(): Assert =
    assert_all([
        assert_byte(div_byte_byte(0x06, 0x02), 0x03),
        assert_that(div_byte_int(0x06, 2)).is_equal_to(3),
        assert_that(div_byte_long(0x06, 2L)).is_equal_to(3L),
        assert_that(div_byte_float(0x06, 2.0f)).is_equal_to(3.0f),
        assert_that(div_byte_double(0x06, 2.0)).is_equal_to(3.0),
        assert_that(div_int_byte(6, 0x02)).is_equal_to(3),
        assert_that(div_int_int(6, 2)).is_equal_to(3),
        assert_that(div_int_long(6, 2L)).is_equal_to(3L),
        assert_that(div_int_float(6, 2.0f)).is_equal_to(3.0f),
        assert_that(div_int_double(6, 2.0)).is_equal_to(3.0),
        assert_that(div_long_byte(6L, 0x02)).is_equal_to(3L),
        assert_that(div_long_int(6L, 2)).is_equal_to(3L),
        assert_that(div_long_long(6L, 2L)).is_equal_to(3L),
        assert_that(div_long_float(6L, 2.0f)).is_equal_to(3.0f),
        assert_that(div_long_double(6L, 2.0)).is_equal_to(3.0),
        assert_that(div_float_byte(6.0f, 0x02)).is_equal_to(3.0f),
        assert_that(div_float_int(6.0f, 2)).is_equal_to(3.0f),
        assert_that(div_float_long(6.0f, 2L)).is_equal_to(3.0f),
        assert_that(div_float_float(6.0f, 2.0f)).is_equal_to(3.0f),
        assert_that(div_float_double(6.0f, 2.0)).is_equal_to(3.0),
        assert_that(div_double_byte(6.0, 0x02)).is_equal_to(3.0),
        assert_that(div_double_int(6.0, 2)).is_equal_to(3.0),
        assert_that(div_double_long(6.0, 2L)).is_equal_to(3.0),
        assert_that(div_double_float(6.0, 2.0f)).is_equal_to(3.0),
        assert_that(div_double_double(6.0, 2.0)).is_equal_to(3.0),
        assert_that(div_string_byte("x", 0x06)).is_equal_to("x6"),
        assert_that(div_string_int("x", 6)).is_equal_to("x6"),
        assert_that(div_string_long("x", 6L)).is_equal_to("x6"),
        assert_that(div_string_float("x", 6.5f)).is_equal_to("x6.5"),
        assert_that(div_string_double("x", 6.5)).is_equal_to("x6.5"),
    ])

private fun power_promotes_numeric_operands_and_supports_string_left_numeric_operands(): Assert =
    assert_all([
        assert_byte(pow_byte_byte(0x06, 0x02), 0x24),
        assert_that(pow_byte_int(0x06, 2)).is_equal_to(36),
        assert_that(pow_byte_long(0x06, 2L)).is_equal_to(36L),
        assert_that(pow_byte_float(0x06, 2.0f)).is_equal_to(36.0f),
        assert_that(pow_byte_double(0x06, 2.0)).is_equal_to(36.0),
        assert_that(pow_int_byte(6, 0x02)).is_equal_to(36),
        assert_that(pow_int_int(6, 2)).is_equal_to(36),
        assert_that(pow_int_long(6, 2L)).is_equal_to(36L),
        assert_that(pow_int_float(6, 2.0f)).is_equal_to(36.0f),
        assert_that(pow_int_double(6, 2.0)).is_equal_to(36.0),
        assert_that(pow_long_byte(6L, 0x02)).is_equal_to(36L),
        assert_that(pow_long_int(6L, 2)).is_equal_to(36L),
        assert_that(pow_long_long(6L, 2L)).is_equal_to(36L),
        assert_that(pow_long_float(6L, 2.0f)).is_equal_to(36.0f),
        assert_that(pow_long_double(6L, 2.0)).is_equal_to(36.0),
        assert_that(pow_float_byte(6.0f, 0x02)).is_equal_to(36.0f),
        assert_that(pow_float_int(6.0f, 2)).is_equal_to(36.0f),
        assert_that(pow_float_long(6.0f, 2L)).is_equal_to(36.0f),
        assert_that(pow_float_float(6.0f, 2.0f)).is_equal_to(36.0f),
        assert_that(pow_float_double(6.0f, 2.0)).is_equal_to(36.0),
        assert_that(pow_double_byte(6.0, 0x02)).is_equal_to(36.0),
        assert_that(pow_double_int(6.0, 2)).is_equal_to(36.0),
        assert_that(pow_double_long(6.0, 2L)).is_equal_to(36.0),
        assert_that(pow_double_float(6.0, 2.0f)).is_equal_to(36.0),
        assert_that(pow_double_double(6.0, 2.0)).is_equal_to(36.0),
        assert_that(pow_string_byte("x", 0x06)).is_equal_to("x6"),
        assert_that(pow_string_int("x", 6)).is_equal_to("x6"),
        assert_that(pow_string_long("x", 6L)).is_equal_to("x6"),
        assert_that(pow_string_float("x", 6.5f)).is_equal_to("x6.5"),
        assert_that(pow_string_double("x", 6.5)).is_equal_to("x6.5"),
    ])

private fun assert_byte(actual: byte, expected: byte): Assert =
    assert_that([actual]).is_equal_to([expected])
