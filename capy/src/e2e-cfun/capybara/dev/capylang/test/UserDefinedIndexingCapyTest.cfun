from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from UserDefinedIndexing import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/UserDefinedIndexing.cfun", [
        test("int_index returns value for matching int key", () => int_index_returns_value_for_matching_int_key()),
        test("string_index returns value for matching string key", () => string_index_returns_value_for_matching_string_key()),
        test("matrix_index_name returns selected cell name", () => matrix_index_name_returns_selected_cell_name()),
        test("chained_index returns nested list value", () => chained_index_returns_nested_list_value()),
        test("list_variable_index returns value when present and empty option otherwise", () => list_variable_index_returns_value_when_present_and_empty_option_otherwise()),
    ])

private fun int_index_returns_value_for_matching_int_key(): Assert =
    assert_that(int_index()).is_equal_to("one")

private fun string_index_returns_value_for_matching_string_key(): Assert =
    assert_that(string_index()).is_equal_to(42.5)

private fun matrix_index_name_returns_selected_cell_name(): Assert =
    assert_that(matrix_index_name()).is_equal_to("second")

private fun chained_index_returns_nested_list_value(): Assert =
    assert_that(chained_index()).contains("e")

private fun list_variable_index_returns_value_when_present_and_empty_option_otherwise(): Assert =
    assert_all([
        assert_that(list_variable_index(["a", "b", "c"], 1)).contains("b"),
        assert_that(list_variable_index(["a"], 3)).is_empty(),
    ])
