from /capy/collection/List import { * }
from /capy/collection/Set import { * }
from /capy/collection/Dict import { * }
from /capy/lang/Collections import { * }
from /capy/lang/Option import { * }
from /capy/lang/String import { * }

fun static_dict(): Dict[int] = {
    "one": 1,
    "two": 2,
    "three": 3,
}

fun empty_static_dict(): Dict[int] = {:}

fun empty_static_dict_with_spaces(): Dict[int] = { : }

fun static_dict_with_trailing_comma(): Dict[int] = {
    "one": 1,
    "two": 2,
    "three": 3,
}

fun append(d: Dict[int]): Dict[int] = d + {
    "four": 4,
}

fun append_dict(left: Dict[int], right: Dict[int]): Dict[int] = left + right

fun append_tuple(d: Dict[int]): Dict[int] = d + ("leet", 1337)

fun append_tuple_override(d: Dict[int]): Dict[int] = d + ("two", 200)

fun remove(d: Dict[int]): Dict[int] = d - "two"

fun remove_dict(left: Dict[int], right: Dict[int]): Dict[int] = left - right

fun contains(d: Dict[int], key: String): bool = d ? key

fun any_value(d: Dict[int]): bool = d.any((_, value) => value > 2)

fun any_entry(d: Dict[int]): bool = d.any((key, value) => key.starts_with("t") & value == 2)

fun all_values(d: Dict[int]): bool = d.all((_, value) => value > 0)

fun all_entries(d: Dict[int]): bool = d.all((key, value) => key.length() > 0 & value > 0)

fun is_empty(d: Dict[int]): bool = d.is_empty()

data DictHolder { values: Dict[int] }

fun not_is_empty(d: Dict[int]): bool = !d.is_empty()

fun not_nested_is_empty(holder: DictHolder): bool = !holder.values.is_empty()

fun size(d: Dict[int]): int = d.size()

data Entry {k: String, v: int}
fun dict_to_list(d: Dict[int]): List[Entry] =
    let initial: List[Entry] = []
    d |> initial, (acc, k, v) => acc + Entry {k:k, v:v}

fun dict_to_string(d: Dict[int]): String =
    d
        |> "", (acc, k, v) =>
            if acc == ""
            then k + " " + v
            else acc + ", " + k + " " + v

fun let_named_dict(): int =
    let dict: Dict[int] = { "one": 1, "two": 2 }
    dict.size()

fun iterator_value_sum(d: Dict[int]): int =
    match d.iterator() with
    case None -> 0
    case Some { iterator } -> iterator.reduce(0, (acc, entry) => acc + entry[1])
