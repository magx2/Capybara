fun and_logic(a: bool, b: bool): bool = a & b

fun or_logic(a: bool, b: bool): bool = a | b

fun equal_logic(a: bool, b: bool): bool = a == b

fun not_equal_logic(a: bool, b: bool): bool = a != b

fun not_logic(a: bool): bool = !a

fun complex_logic(a: bool, b: bool): bool = (!a & b) | (a == b)

data BoolBox { failed: bool }

fun BoolBox.has_failed(): bool = this.failed

fun not_field_access(box: BoolBox): bool = !box.failed

fun not_method_call(box: BoolBox): bool = !box.has_failed()

fun byte_to_bool(v: byte): bool = if v then true else false

fun int_to_bool(v: int): bool = if v then true else false

fun long_to_bool(v: long): bool = if v then true else false

fun float_to_bool(v: float): bool = if v then true else false

fun double_to_bool(v: double): bool = if v then true else false

fun string_to_bool(v: String): bool = if v then true else false

fun list_to_bool(v: List[int]): bool = if v then true else false

fun set_to_bool(v: Set[int]): bool = if v then true else false

fun dict_to_bool(v: Dict[int]): bool = if v then true else false

fun and_int(a: int, b: int): bool = a & b

fun or_string(a: String, b: String): bool = a | b

fun not_int(v: int): bool = !v

fun not_list(v: List[int]): bool = !v
