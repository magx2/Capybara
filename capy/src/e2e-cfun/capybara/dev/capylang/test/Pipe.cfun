from /capy/lang/Seq import {*}
from /capy/lang/Option import { * }
from /capy/lang/String import { * }
from /capy/lang/Collections import { * }

fun map1(l: List[int]): List[int] =
    l | x => x * 2

fun map2(l: List[int]): List[int] =
    l
        .map(x => x * 2)
        .map(x => x - 1)

fun map3(l: List[int]): List[String] = l | x => "Hello " + x

fun filter1(l: List[int]): List[int] = l |- x => x > 0

fun filter2(l: List[int]): List[int] =
    l
        |- x => x > 2
        |- x => x == 1

fun reduce1(l: List[int]): int = l |> 0, (a,b) => a+b

/// returns if any of the ints in the list is positive
fun any_positive(l: List[int]): bool = l.any(x => x > 0)

/// returns if all of the ints in the list is positive
fun all_positive(l: List[int]): bool = l.all(x => x > 0)

private fun is_positive(x: int): bool = x > 0
fun any_positive_ref(l: List[int]): bool = l.any(:is_positive)
fun all_positive_ref(l: List[int]): bool = l.all(:is_positive)

fun reduce2(l: List[int]): int =
    l
        | (x => x * 2)
        |- (x => x < 0)
        |> 0, (a,b) => a+b

fun reduce_string1(l: List[String]): String = l |> "", (acc, v) => acc + v

fun reduce_string2(l: List[String]): String =
    l |> "start: ", (acc, v) => acc + (if acc == "start: " then "" else " ") + v

fun string_map(s: String): List[String] = s | ch => "[" + ch + "]"

fun string_filter(s: String): String = s |- ch => ch == "b"

fun string_reduce(s: String): String = s |> "", (acc, ch) => acc + ch

data Foo { value: String }
fun reduce_to_data(l: List[String]): Foo = l
    | v => Foo {value:v}
    |> Foo {value:""}, (acc, v) => Foo { value: acc.value + v.value }

fun flatMap1(l: List[int]): List[int] = l |* x => [x, x+1, x+2]

fun flatMap2(l: List[int]): List[int] =
    l
        | (x => x * 2)
        |- (x => x > 0)
        |* (x => [x, x+1, x+2])

fun setMap1(s: Set[int]): Set[int] = s | x => x * 2

fun setFilter1(s: Set[int]): Set[int] = s |- x => x > 0

fun setReduce1(s: Set[int]): int = s |> 0, (a,b) => a+b

fun set_reduce_string2(s: Set[String]): String =
    s |> "start: ", (acc, v) => acc + (if acc == "start: " then "" else " ") + v

fun setFlatMap1(s: Set[int]): Set[int] = s |* x => {x, x+10}

fun mapDict(d: Dict[int]): Dict[String] = d | (k,v) => v + ""

fun filterDict(d: Dict[int]): Dict[int] = d |- (k,v) => k != "" & v > 0

fun reduceDict(d: Dict[int]): String = d
    .map((k, v) => "(" + k + ":" + v + ")")
    .reduce("start: ", (acc, _, e) => acc + (if acc == "start: " then "" else ", ") + e)

data Entry { key: String, value: String }
fun reduce_to_data(l: Dict[String]): Set[Entry] =
    let initial: Set[Entry] = {}
    l |> initial, (acc, k, v) => acc + { Entry {key:k,value:v} }

fun dict_reduce_string2(d: Dict[String]): String =
    d |> "start: ", (acc, _, v) => acc + (if acc == "start: " then "" else " ") + v

fun dict_unused_key_to_sum(d: Dict[int]): int =
    d |> 0, (acc, _, v) => acc + v

fun dict_unused_reduce_key(d: Dict[int]): int =
    d |> 0, (acc, _, v) => acc + v

fun list_unused_lambda_arg(l: List[int]): List[int] = l | _ => 1

data Value { x: int }

fun add(v: Value, x: int): Value = Value { x: v.x + x }

fun data_pipe(a: int, b: int, c: int): /capy/lang/Option[Value] =
    let value = Value { x: a }
    if value.x > 0
    then None {}
    else Some { add(add(value, b), c) }

type Boxed = IntBox | LongBox
data IntBox { value: int }
data LongBox { value: long }

fun keep_boxed(boxed: Boxed): Boxed = boxed

fun add_to_boxed(boxed: Boxed): Boxed =
    match boxed with
    case IntBox { value } -> IntBox { value: value + 1 }
    case LongBox { value } -> LongBox { value: value + 1L }

fun type_pipe_lambda(x: int): Boxed =
    add_to_boxed(keep_boxed(IntBox { value: x }))

fun type_pipe_ref(x: int): Boxed =
    add_to_boxed(keep_boxed(IntBox { value: x }))

fun type_pipe_optional(x: int): /capy/lang/Option[Boxed] =
    if x > 0
    then None {}
    else Some { add_to_boxed(keep_boxed(IntBox { value: x })) }

fun pipe_then_chain_after_lambda(): int =
    match ([1, 2, 3]
        | (value => value + 1))[1] with
    case Some { value } -> value
    case None -> 0

fun pipe_then_chain_methods_after_lambda(): String =
    let ok: () => String = () => "ok"
    let failed: () => String = () => "failed"
    let later: () => String = () => "later"
    let suppliers: List[() => String] = [ok, failed, later]
    match to_seq(suppliers)
        | (supplier => supplier())
        .first() with
    case Some { value } -> value
    case None -> ""

fun pipe_lambda_body_multiline_without_parentheses(): List[String] =
    [" x ", " y "]
        | value =>
            value
                .trim()

fun pipe_filter_lambda_body_multiline_without_parentheses(): List[String] =
    [" a ", "bb", " c "]
        |- value =>
            value
                .trim()
                .starts_with("b")

fun pipe_any_lambda_body_multiline_without_parentheses(): bool =
    [" a ", "bb"]
        .any(value =>
            value
                .trim()
                .starts_with("a"))
