from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from PackageChild import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/local_visibility/child/PackageChild.cfun", [
        test("child package can use local members from parent package", () => child_package_can_use_local_members_from_parent_package()),
    ])

private fun child_package_can_use_local_members_from_parent_package(): Assert =
    assert_all([
        assert_that(child_can_use_local_members(1)).is_equal_to(6),
        assert_that(child_can_use_local_members(3)).is_equal_to(8),
    ])
