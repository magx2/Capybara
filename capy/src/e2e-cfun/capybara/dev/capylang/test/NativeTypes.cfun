from /capy/lang/String import { * }
from /capy/lang/Option import { * }
from /capy/lang/Collections import { * }

fun string_length(value: String): int = value.length()

fun string_trim(value: String): String = value.trim()

fun string_get(value: String, idx: int): Option[String] = value.get(idx)

fun string_get_range(value: String, from: int, to: int): String = value.get(from, to)

fun list_size(values: List[int]): int = values.size()

fun list_contains(values: List[int], value: int): bool = values.contains(value)

fun list_get(values: List[int], idx: int): Option[int] = values.get(idx)

fun list_get_range_method(values: List[int], from: int, to: int): List[int] = values.get(from, to)

fun list_get_range(values: List[int], from: int, to: int): List[int] = values[from, to]

fun set_is_empty(values: Set[int]): bool = values.is_empty()

fun set_contains(values: Set[int], value: int): bool = values.contains(value)

fun set_get(values: Set[int], value: int): Option[int] = values.get(value)

fun set_index(values: Set[int], value: int): Option[int] = values[value]

fun dict_size(values: Dict[int]): int = values.size()

fun dict_contains_key(values: Dict[int], key: String): bool = values.contains_key(key)

fun dict_get(values: Dict[int], key: String): Option[int] = values.get(key)

fun dict_index(values: Dict[int], key: String): Option[int] = values[key]

fun tuple_second(value: Tuple[int, String]): String = value[1]

fun tuple_get_second(value: Tuple[int, String]): String = value.get(1)
