from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Program import { * }
from EffectMainProgram import { * }

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/EffectMainProgram.cfun", [
        effect_main_returns_success().map(assertion => test("effect main returns success", () => assertion)),
    ])

// The legacy Java host test also asserts the generated main(String...) signature.
// The legacy Java/JavaScript host tests assert exact stdout/stderr capture through generated
// entry points and process wrappers; those are backend/tooling details, not portable
// Capybara assertions.
fun effect_main_returns_success(): Effect[Assert] =
    effect_main_assertions()

private fun effect_main_assertions(): Effect[Assert] =
    let program <- main(["one", "two"])
    assert_that(program).is_equal_to(Success {})
