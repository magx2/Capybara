from /capy/collection/List import { * }
from /capy/collection/Set import { * }
from /capy/collection/Dict import { * }

fun main(args: List[String]): /capy/lang/Program =
    if args ? "ok"
    then /capy/lang/Program.Success { results: args }
    else /capy/lang/Program.Failed { exitCode: 2, errors: ["missing ok"] }
