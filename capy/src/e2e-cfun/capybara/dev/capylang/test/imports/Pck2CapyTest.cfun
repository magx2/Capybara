from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }
import /dev/capylang/test/imports/Pck2

fun tests(): Effect[TestFile] =
    test_file("/dev/capylang/test/imports/Pck2.cfun", [
        test("add subtracts the second operand from the first", () => add_subtracts_the_second_operand_from_the_first()),
        test("empty returns sign classification for an integer", () => empty_returns_sign_classification_for_an_integer()),
    ])

private fun add_subtracts_the_second_operand_from_the_first(): Assert =
    assert_all([
        pck2_assert_int_equal(Pck2.add(2, 3), -1),
        pck2_assert_int_equal(Pck2.add(5, 2), 3),
        pck2_assert_int_equal(Pck2.add(-2, -3), 1),
    ])

private fun empty_returns_sign_classification_for_an_integer(): Assert =
    assert_all([
        pck2_assert_int_equal(Pck2.empty(-7), -1),
        pck2_assert_int_equal(Pck2.empty(0), 0),
        pck2_assert_int_equal(Pck2.empty(7), 1),
    ])

private fun pck2_assert_int_equal(value: int, expected: int): Assert =
    assert_that(value).is_equal_to(expected)
