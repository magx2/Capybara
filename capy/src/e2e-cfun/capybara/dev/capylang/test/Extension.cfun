// data extension

data Point { x: float, y: float }
data Point3D =  { z: float, ...Point }

data Label { label: String }
data Weighted { weight: float }
data LabeledPoint = { ...Point, ...Label }
data WeightedLabeledPoint3D = { tag: String, ...Point3D, ...Label, ...Weighted }

fun new_point3d(x: float, y: float, z: float): Point3D = Point3D { "x": x, "y": y, "z": z }

fun new_point3d(p: Point, z: float): Point3D = Point3D { ...p, "z": z }

fun new_point3d_ver2(x: float, y: float, z: float): Point3D = Point3D { x: x, y: y, z: z }

fun length2d(p: Point): float = sqrt(p.x * p.x + p.y * p.y)

fun length(p: Point): float = sqrt(p.x * p.x + p.y * p.y)

fun length(p: Point3D): float = sqrt(p.x * p.x + p.y * p.y + p.z * p.z)

fun x_and_y(p: Point) = p.x + p.y

fun only_point2d(): float =
    let p = Point3D { x: 1, y: 2, z: 3}
    x_and_y(p)

fun test_substitution(p3d: Point3D): float = length2d(p3d)

fun new_labeled_point(x: float, y: float, label: String): LabeledPoint =
    LabeledPoint { x: x, y: y, label: label }

fun weighted_labeled_point_score(point: WeightedLabeledPoint3D): float =
    point.x + point.y + point.z + point.weight

fun weighted_labeled_point_label(point: WeightedLabeledPoint3D): String = point.label + ":" + point.tag

fun overload_prefers_most_concrete(point: WeightedLabeledPoint3D): float = length(point)

fun overload_any_vs_parent(point: Point): String = "point"

fun overload_any_vs_parent(value: any): String = "any"

fun overload_any_prefers_parent(point: Point3D): String = overload_any_vs_parent(point)
