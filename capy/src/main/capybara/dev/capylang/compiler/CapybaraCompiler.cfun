from /capy/collection/Dict import { * }
from /capy/collection/List import { * }
from /capy/collection/Set import { Set }
from /capy/lang/Effect import { * }
from /capy/lang/Either import { Either, Left, Right }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledAnnotationDeclaration import { CompiledAnnotationDeclaration }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledFunctionReferenceExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression, CompiledWithExpression }
from /dev/capylang/compiler/CompiledDeriverDeclaration import { CompiledDeriverDeclaration }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledObjectOrientedClass import { CompiledObjectOrientedClass }
from /dev/capylang/compiler/CompiledObjectOrientedField import { CompiledObjectOrientedField }
from /dev/capylang/compiler/CompiledObjectOrientedInterface import { CompiledObjectOrientedInterface }
from /dev/capylang/compiler/CompiledObjectOrientedMethod import { CompiledObjectOrientedMethod }
from /dev/capylang/compiler/CompiledObjectOrientedUnit import { CompiledObjectOrientedUnit }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from /dev/capylang/compiler/CompilerError import { CompilerError }
from /dev/capylang/compiler/NativeProviderManifest import { NativeProviderManifest }
from /dev/capylang/compiler/parser/ConstantDeclaration import { ConstantDeclaration }
from /dev/capylang/compiler/parser/Definition import { AnnotationApplication, AnnotationArgument, AnnotationBoolValue, AnnotationDeclaration, AnnotationDoubleValue, AnnotationFieldDeclaration, AnnotationFloatValue, AnnotationIntValue, AnnotationLongValue, AnnotationNothingValue, AnnotationStringValue, AnnotationTypeNameValue, AnnotationValue, ConstantDefinition, DataDeclaration, DataFieldDeclaration, DataParentDeclaration, DeriveApplication, DeriverDeclaration, Definition, EnumDeclaration, EnumValueDeclaration, FunctionDefinition, TypeDeclaration }
from /dev/capylang/compiler/parser/Expression import { BinaryExpression, BlockExpression, BoolLiteral, DataField, DataLiteral, DictEntry, DictLiteral, DoubleLiteral, Expression, FieldAccessExpression, FloatLiteral, FunctionCallExpression, FunctionReferenceExpression, IfExpression, IndexExpression, IntLiteral, LambdaExpression, LetBinding, ListLiteral, LongLiteral, MatchCase, MatchExpression, MethodCallExpression, ReduceExpression, SetLiteral, StringLiteral, TupleLiteral, UnaryExpression, UnsupportedExpression, VariableExpression, WithExpression }
from /dev/capylang/compiler/parser/FunctionDeclaration import { FunctionDeclaration }
from /dev/capylang/compiler/parser/FunctionParameter import { FunctionParameter }
from /dev/capylang/compiler/parser/ImportDeclaration import { ImportDeclaration }
from /dev/capylang/compiler/parser/ObjectOriented import { ObjectOriented }
from /dev/capylang/compiler/parser/ObjectOrientedClass import { ObjectOrientedClass }
from /dev/capylang/compiler/parser/ObjectOrientedField import { ObjectOrientedField }
from /dev/capylang/compiler/parser/ObjectOrientedInterface import { ObjectOrientedInterface }
from /dev/capylang/compiler/parser/ObjectOrientedMethod import { ObjectOrientedMethod }
from /dev/capylang/compiler/parser/ParsedModule import { ParsedModule }
from /dev/capylang/compiler/parser/CapybaraParserProvider import { parser }
from /dev/capylang/compiler/parser/RawModule import { RawModule }
from /dev/capylang/compiler/parser/SourceLocation import { SourceLocation }
from /dev/capylang/compiler/parser/TypeReference import { TypeReference }

fun compile(
    rawModules: List[RawModule],
    libraries: Set[CompiledModule],
    nativeProviders: NativeProviderManifest,
    nativeImplementationProviders: NativeProviderManifest
): Effect[Either[CompiledProgram, List[CompilerError]]] =
    if rawModules.is_empty()
    then pure(Right { [CompilerError {
        message: "No Capybara source modules found.",
        moduleName: "",
        line: 0,
        column: 0
    }] })
    else
        let capybara_parser <- parser()
        capybara_parser.parse(rawModules).map(program => compiled_program(program, nativeProviders))

private fun compiled_program(
    program: /dev/capylang/compiler/parser/ParsedProgram,
    nativeProviders: NativeProviderManifest
): Either[CompiledProgram, List[CompilerError]] =
    Left { CompiledProgram {
        modules: compile_modules(program.modules),
        objectOrientedModules: compile_object_oriented_modules(program.modules),
        nativeProviders: nativeProviders,
        nativeProviderCatalog: empty_native_provider_catalog()
    }}

private fun compile_modules(modules: List[ParsedModule]): List[CompiledModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> merge_compiled_module(compile_module(module), compile_modules(modules[1:]))

private fun merge_compiled_module(module: CompiledModule, modules: List[CompiledModule]): List[CompiledModule] =
    match modules[0] with
    case None -> [module]
    case Some { existing } ->
        if same_compiled_module(module, existing)
        then [merge_compiled_modules(module, existing)] + modules[1:]
        else [existing] + merge_compiled_module(module, modules[1:])

private fun same_compiled_module(first: CompiledModule, second: CompiledModule): bool =
    first.name == second.name & first.path == second.path

private fun merge_compiled_modules(first: CompiledModule, second: CompiledModule): CompiledModule =
    CompiledModule {
        name: first.name,
        path: first.path,
        types: first.types + second.types,
        visiblePrimitiveBackedTypes: first.visiblePrimitiveBackedTypes + second.visiblePrimitiveBackedTypes,
        functions: first.functions + second.functions,
        imports: first.imports + second.imports,
        derivers: first.derivers + second.derivers,
        annotations: first.annotations + second.annotations,
        staticImports: first.staticImports + second.staticImports
    }

private fun compile_module(module: ParsedModule): CompiledModule =
    let derivers = compile_derivers(module.definitions)
    CompiledModule {
        name: module.name,
        path: normalize_module_path(module.path),
        types: {:},
        visiblePrimitiveBackedTypes: {:},
        functions: compile_functions(module.definitions, module.definitions)
            + compile_object_interface_functions(module.objectOriented.interfaces)
            + compile_object_class_functions(module.objectOriented.classes),
        imports: compile_imports(module.imports),
        derivers: derivers,
        annotations: compile_annotations(module.definitions),
        staticImports: []
    }

private fun compile_object_oriented_modules(modules: List[ParsedModule]): List[CompiledObjectOrientedUnit] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if module.objectOriented.interfaces.is_empty() & module.objectOriented.classes.is_empty()
        then compile_object_oriented_modules(modules[1:])
        else [CompiledObjectOrientedUnit {
            name: module.name,
            path: normalize_module_path(module.path),
            interfaces: compile_object_interfaces(module.objectOriented.interfaces),
            classes: compile_object_classes(module.objectOriented.classes)
        }] + compile_object_oriented_modules(modules[1:])

private fun compile_object_interfaces(interfaces: List[ObjectOrientedInterface]): List[CompiledObjectOrientedInterface] =
    match interfaces[0] with
    case None -> []
    case Some { interface } -> [compile_object_interface(interface)] + compile_object_interfaces(interfaces[1:])

private fun compile_object_interface(interface: ObjectOrientedInterface): CompiledObjectOrientedInterface =
    CompiledObjectOrientedInterface {
        name: interface.name,
        visibility: interface.visibility,
        parents: compile_types(interface.parents),
        methods: compile_object_methods(interface.name, interface.methods),
        location: compile_location(interface.location)
    }

private fun compile_object_classes(classes: List[ObjectOrientedClass]): List[CompiledObjectOrientedClass] =
    match classes[0] with
    case None -> []
    case Some { class } -> [compile_object_class(class)] + compile_object_classes(classes[1:])

private fun compile_object_class(class: ObjectOrientedClass): CompiledObjectOrientedClass =
    CompiledObjectOrientedClass {
        name: class.name,
        visibility: class.visibility,
        parameters: compile_parameters(class.parameters),
        parents: compile_types(class.parents),
        fields: compile_object_fields(class.name, class.fields),
        initBlocks: compile_object_init_blocks(class.name, class.initBlocks),
        methods: compile_object_methods(class.name, class.methods),
        location: compile_location(class.location)
    }

private fun compile_object_fields(className: String, fields: List[ObjectOrientedField]): List[CompiledObjectOrientedField] =
    match fields[0] with
    case None -> []
    case Some { field } -> [compile_object_field(className, field)] + compile_object_fields(className, fields[1:])

private fun compile_object_field(className: String, field: ObjectOrientedField): CompiledObjectOrientedField =
    CompiledObjectOrientedField {
        name: field.name,
        visibility: field.visibility,
        typeReference: compile_type(field.typeReference),
        value: compile_expression_in_function(field.value, className + "." + field.name),
        hasValue: field.hasValue,
        location: compile_location(field.location)
    }

private fun compile_object_init_blocks(className: String, initBlocks: List[Expression]): List[CompiledExpression] =
    match initBlocks[0] with
    case None -> []
    case Some { initBlock } -> [compile_expression_in_function(initBlock, className + ".init")] + compile_object_init_blocks(className, initBlocks[1:])

private fun compile_object_methods(className: String, methods: List[ObjectOrientedMethod]): List[CompiledObjectOrientedMethod] =
    match methods[0] with
    case None -> []
    case Some { method } -> [compile_object_method(className, method)] + compile_object_methods(className, methods[1:])

private fun compile_object_method(className: String, method: ObjectOrientedMethod): CompiledObjectOrientedMethod =
    let functionName = className + "." + method.name
    CompiledObjectOrientedMethod {
        name: method.name,
        visibility: method.visibility,
        parameters: compile_parameters(method.parameters),
        returnType: compile_type(method.returnType),
        body: compile_expression_in_function(method.body, functionName),
        location: compile_location(method.location)
    }

private fun compile_object_interface_functions(interfaces: List[ObjectOrientedInterface]): List[CompiledFunction] =
    match interfaces[0] with
    case None -> []
    case Some { interface } ->
        [compile_object_interface_schema_function(interface)]
            + compile_object_interface_parent_schema_functions(interface.name, interface.parents, 0)
            + compile_object_interface_method_functions(interface.name, interface.methods)
            + compile_object_interface_functions(interfaces[1:])

private fun compile_object_interface_schema_function(interface: ObjectOrientedInterface): CompiledFunction =
    compile_schema_constant(
        "__capy_oo_interface|" + interface.name,
        interface.visibility,
        interface.location
    )

private fun compile_object_interface_parent_schema_functions(interfaceName: String, parents: List[TypeReference], idx: int): List[CompiledFunction] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        [compile_schema_constant("__capy_oo_interface_parent|" + interfaceName + "|" + idx, type_reference_schema(parent), parent_location(parent))]
            + compile_object_interface_parent_schema_functions(interfaceName, parents[1:], idx + 1)

private fun parent_location(parent: TypeReference): SourceLocation =
    SourceLocation { line: 0, column: 0 }

private fun compile_object_interface_method_functions(interfaceName: String, methods: List[ObjectOrientedMethod]): List[CompiledFunction] =
    match methods[0] with
    case None -> []
    case Some { method } -> [compile_object_interface_method_function(interfaceName, method)] + compile_object_interface_method_functions(interfaceName, methods[1:])

private fun compile_object_interface_method_function(interfaceName: String, method: ObjectOrientedMethod): CompiledFunction =
    CompiledFunction {
        name: "__capy_oo_interface_method|" + interfaceName + "|" + method.name,
        visibility: "oo_interface_method:" + method.visibility,
        parameters: compile_parameters(method.parameters),
        returnType: compile_type(method.returnType),
        body: compile_expression_in_function(method.body, interfaceName + "." + method.name),
        location: compile_location(method.location)
    }

private fun compile_object_class_functions(classes: List[ObjectOrientedClass]): List[CompiledFunction] =
    match classes[0] with
    case None -> []
    case Some { class } ->
        [compile_object_class_schema_function(class)]
            + compile_object_class_parameter_schema_functions(class.name, class.parameters, 0)
            + compile_object_class_parent_schema_functions(class.name, class.parents, 0)
            + compile_object_field_schema_functions(class.name, class.fields, 0)
            + compile_object_field_init_functions(class.name, class.parameters, class.fields)
            + compile_object_init_functions(class.name, class.parameters, class.initBlocks, 0)
            + compile_object_method_functions(class.name, class.methods)
            + compile_object_class_functions(classes[1:])

private fun compile_object_class_schema_function(class: ObjectOrientedClass): CompiledFunction =
    compile_schema_constant(
        "__capy_oo_class|" + class.name,
        class.visibility,
        class.location
    )

private fun compile_object_class_parameter_schema_functions(className: String, parameters: List[FunctionParameter], idx: int): List[CompiledFunction] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [compile_schema_constant("__capy_oo_param|" + className + "|" + idx, parameter.name + "|" + type_reference_schema(parameter.typeReference), parameter.location)]
            + compile_object_class_parameter_schema_functions(className, parameters[1:], idx + 1)

private fun compile_object_class_parent_schema_functions(className: String, parents: List[TypeReference], idx: int): List[CompiledFunction] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        [compile_schema_constant("__capy_oo_parent|" + className + "|" + idx, type_reference_schema(parent), parent_location(parent))]
            + compile_object_class_parent_schema_functions(className, parents[1:], idx + 1)

private fun compile_object_field_schema_functions(className: String, fields: List[ObjectOrientedField], idx: int): List[CompiledFunction] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [compile_schema_constant("__capy_oo_field|" + className + "|" + idx, object_field_schema(field), field.location)]
            + compile_object_field_schema_functions(className, fields[1:], idx + 1)

private fun object_field_schema(field: ObjectOrientedField): String =
    field.name + "|" + field.visibility + "|" + type_reference_schema(field.typeReference) + "|" + object_field_has_value_schema(field)

private fun object_field_has_value_schema(field: ObjectOrientedField): String =
    if field.hasValue then "true" else "false"

private fun compile_object_field_init_functions(className: String, parameters: List[FunctionParameter], fields: List[ObjectOrientedField]): List[CompiledFunction] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        if field.hasValue
        then [compile_object_field_init_function(className, parameters, field)] + compile_object_field_init_functions(className, parameters, fields[1:])
        else compile_object_field_init_functions(className, parameters, fields[1:])

private fun compile_object_field_init_function(className: String, parameters: List[FunctionParameter], field: ObjectOrientedField): CompiledFunction =
    CompiledFunction {
        name: "__capy_oo_field_init|" + className + "|" + field.name,
        visibility: "oo_field_init",
        parameters: compile_parameters(parameters),
        returnType: compile_type(field.typeReference),
        body: compile_expression_in_function(field.value, className + "." + field.name),
        location: compile_location(field.location)
    }

private fun compile_object_init_functions(className: String, parameters: List[FunctionParameter], initBlocks: List[Expression], idx: int): List[CompiledFunction] =
    match initBlocks[0] with
    case None -> []
    case Some { initBlock } ->
        [compile_object_init_function(className, parameters, initBlock, idx)]
            + compile_object_init_functions(className, parameters, initBlocks[1:], idx + 1)

private fun compile_object_init_function(className: String, parameters: List[FunctionParameter], initBlock: Expression, idx: int): CompiledFunction =
    CompiledFunction {
        name: "__capy_oo_init|" + className + "|" + idx,
        visibility: "oo_init",
        parameters: compile_parameters(parameters),
        returnType: compile_type(compiler_any_type()),
        body: compile_expression_in_function(initBlock, className + ".init"),
        location: compile_location(expression_location(initBlock))
    }

private fun compile_object_method_functions(className: String, methods: List[ObjectOrientedMethod]): List[CompiledFunction] =
    match methods[0] with
    case None -> []
    case Some { method } -> [compile_object_method_function(className, method)] + compile_object_method_functions(className, methods[1:])

private fun compile_object_method_function(className: String, method: ObjectOrientedMethod): CompiledFunction =
    let functionName = className + "." + method.name
    CompiledFunction {
        name: "__capy_oo_method|" + className + "|" + method.name,
        visibility: "oo:" + method.visibility,
        parameters: compile_parameters(method.parameters),
        returnType: compile_type(method.returnType),
        body: compile_expression_in_function(method.body, functionName),
        location: compile_location(method.location)
    }

private fun compile_derivers(definitions: List[Definition]): Dict[CompiledDeriverDeclaration] =
    match definitions[0] with
    case None -> {:}
    case Some { definition } ->
        match definition with
        case DeriverDeclaration declaration ->
            compile_derivers(definitions[1:]) + (declaration.name, compile_deriver_declaration(declaration))
        case _ -> compile_derivers(definitions[1:])

private fun compile_deriver_declaration(declaration: DeriverDeclaration): CompiledDeriverDeclaration =
    CompiledDeriverDeclaration {
        name: declaration.name,
        visibility: declaration.visibility,
        methods: compile_deriver_methods(declaration.methods),
        location: compile_location(declaration.location)
    }

private fun compile_deriver_methods(methods: List[FunctionDeclaration]): List[CompiledFunction] =
    match methods[0] with
    case None -> []
    case Some { method } -> [compile_function(method)] + compile_deriver_methods(methods[1:])

private fun compile_derived_functions_for_type(typeName: String, derives: List[DeriveApplication], definitions: List[Definition]): List[CompiledFunction] =
    match derives[0] with
    case None -> []
    case Some { derive } ->
        match find_deriver(derive.name, definitions) with
        case Some { deriver } ->
            compile_derived_methods(typeName, deriver.methods)
                + compile_derived_functions_for_type(typeName, derives[1:], definitions)
        case None -> compile_derived_functions_for_type(typeName, derives[1:], definitions)

private fun find_deriver(name: String, definitions: List[Definition]): /capy/lang/Option[DeriverDeclaration] =
    match definitions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { definition } ->
        match definition with
        case DeriverDeclaration declaration ->
            if declaration.name == name
            then /capy/lang/Option.Some { declaration }
            else find_deriver(name, definitions[1:])
        case _ -> find_deriver(name, definitions[1:])

private fun compile_derived_methods(typeName: String, methods: List[FunctionDeclaration]): List[CompiledFunction] =
    match methods[0] with
    case None -> []
    case Some { method } -> [compile_derived_method(typeName, method)] + compile_derived_methods(typeName, methods[1:])

private fun compile_derived_method(typeName: String, method: FunctionDeclaration): CompiledFunction =
    let functionName = typeName + "." + method.name
    CompiledFunction {
        name: functionName,
        visibility: method.visibility,
        parameters: compile_parameters(method.parameters),
        returnType: compile_type(method.returnType),
        body: compile_expression_in_function(method.body, functionName),
        location: compile_location(method.location)
    }

private fun compile_annotations(definitions: List[Definition]): Dict[CompiledAnnotationDeclaration] =
    match definitions[0] with
    case None -> {:}
    case Some { definition } ->
        match definition with
        case AnnotationDeclaration declaration ->
            compile_annotations(definitions[1:]) + (declaration.name, compile_annotation_declaration(declaration))
        case _ -> compile_annotations(definitions[1:])

private fun compile_annotation_declaration(declaration: AnnotationDeclaration): CompiledAnnotationDeclaration =
    CompiledAnnotationDeclaration {
        name: declaration.name,
        visibility: declaration.visibility,
        repeatable: declaration.repeatable,
        targets: declaration.targets,
        fields: compile_annotation_fields(declaration.fields),
        location: compile_location(declaration.location)
    }

private fun compile_annotation_fields(fields: List[AnnotationFieldDeclaration]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } -> [compile_annotation_field(field)] + compile_annotation_fields(fields[1:])

private fun compile_annotation_field(field: AnnotationFieldDeclaration): String =
    field.name
        + "|" + type_reference_schema(field.typeReference)
        + "|" + annotation_default_present_schema(field.hasDefault)
        + "|" + annotation_value_schema(field.defaultValue)

private fun annotation_default_present_schema(hasDefault: bool): String =
    if hasDefault then "true" else "false"

private fun normalize_module_path(path: String): String =
    if compiler_string_has_prefix(path, "/")
    then normalize_module_path(path[1, path.size()])
    else path

private fun compiler_string_has_prefix(value: String, prefix: String): bool =
    compiler_string_has_prefix_at(value, prefix, 0)

private fun compiler_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then compiler_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun compile_constant(constant: ConstantDeclaration): CompiledFunction =
    CompiledFunction {
        name: constant.name,
        visibility: "const:" + constant.visibility,
        parameters: [],
        returnType: compile_type(constant.typeReference),
        body: compile_expression_in_function(constant.expression, constant.name),
        location: compile_location(constant.location)
    }

private fun compile_functions(definitions: List[Definition], allDefinitions: List[Definition]): List[CompiledFunction] =
    match definitions[0] with
    case None -> []
    case Some { definition } ->
        match definition with
        case ConstantDefinition { constant } -> [compile_constant(constant)] + compile_functions(definitions[1:], allDefinitions)
        case DataDeclaration declaration ->
            compile_data_declaration(declaration)
                + compile_derived_functions_for_type(declaration.name, declaration.derives, allDefinitions)
                + compile_functions(definitions[1:], allDefinitions)
        case TypeDeclaration declaration ->
            compile_derived_functions_for_type(declaration.name, declaration.derives, allDefinitions)
                + compile_functions(definitions[1:], allDefinitions)
        case EnumDeclaration declaration -> compile_enum_declaration(declaration) + compile_functions(definitions[1:], allDefinitions)
        case FunctionDefinition { function } -> [compile_function(function)] + compile_functions(definitions[1:], allDefinitions)
        case _ -> compile_functions(definitions[1:], allDefinitions)

private fun compile_data_declaration(declaration: DataDeclaration): List[CompiledFunction] =
    [compile_schema_constant("__capy_schema_type|" + declaration.name, declaration.name, declaration.location)]
        + compile_data_schema_parameters(declaration.name, declaration.parameters, 0, declaration.location)
        + compile_data_schema_fields(declaration.name, declaration.fields, 0)
        + compile_data_schema_parents(declaration.name, declaration.parents, 0)
        + compile_annotation_application_schema("__capy_schema_annotation|data|" + declaration.name + "|", declaration.annotations, 0)
        + compile_data_field_annotation_schema(declaration.name, declaration.fields, 0)

private fun compile_enum_declaration(declaration: EnumDeclaration): List[CompiledFunction] =
    [
        compile_schema_constant("__capy_schema_type|" + declaration.name, declaration.name, declaration.location),
        compile_schema_constant("__capy_schema_field|" + declaration.name + "|0", "name|String", declaration.location),
        compile_schema_constant("__capy_schema_field|" + declaration.name + "|1", "order|int", declaration.location),
    ] + compile_annotation_application_schema("__capy_schema_annotation|enum|" + declaration.name + "|", declaration.annotations, 0)
        + compile_enum_values(declaration.name, declaration.values, 0)

private fun compile_enum_values(enumName: String, values: List[EnumValueDeclaration], idx: int): List[CompiledFunction] =
    match values[0] with
    case None -> []
    case Some { value } ->
        [compile_schema_constant("__capy_schema_enum|" + enumName + "|" + idx, value.name, value.location),
            compile_enum_value_constant(enumName, value, idx)]
            + compile_enum_values(enumName, values[1:], idx + 1)

private fun compile_enum_value_constant(enumName: String, value: EnumValueDeclaration, idx: int): CompiledFunction =
    CompiledFunction {
        name: value.name,
        visibility: "const:public",
        parameters: [],
        returnType: CompiledTypeReference { name: enumName, arguments: [] },
        body: CompiledDataLiteral {
            typeName: "__capy_raw|" + value.name,
            fields: [
                CompiledDataField {
                    name: "name",
                    value: CompiledStringLiteral {
                        value: value.name,
                        source: "\"" + value.name + "\"",
                        location: compile_location(value.location)
                    },
                    spread: false,
                    location: compile_location(value.location)
                },
                CompiledDataField {
                    name: "order",
                    value: CompiledIntLiteral {
                        value: idx,
                        source: "" + idx,
                        location: compile_location(value.location)
                    },
                    spread: false,
                    location: compile_location(value.location)
                },
            ],
            location: compile_location(value.location)
        },
        location: compile_location(value.location)
    }

private fun compile_data_schema_parameters(dataName: String, parameters: List[String], idx: int, location: SourceLocation): List[CompiledFunction] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [compile_schema_constant("__capy_schema_param|" + dataName + "|" + idx, parameter, location)]
            + compile_data_schema_parameters(dataName, parameters[1:], idx + 1, location)

private fun compile_data_schema_fields(dataName: String, fields: List[DataFieldDeclaration], idx: int): List[CompiledFunction] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [compile_schema_constant("__capy_schema_field|" + dataName + "|" + idx, data_declaration_field_schema(field), field.location)]
            + compile_data_schema_fields(dataName, fields[1:], idx + 1)

private fun compile_data_field_annotation_schema(dataName: String, fields: List[DataFieldDeclaration], idx: int): List[CompiledFunction] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        compile_annotation_application_schema(
            "__capy_schema_annotation|field|" + dataName + "|" + idx + "|",
            field.annotations,
            0
        ) + compile_data_field_annotation_schema(dataName, fields[1:], idx + 1)

private fun compile_annotation_application_schema(prefix: String, annotations: List[AnnotationApplication], idx: int): List[CompiledFunction] =
    match annotations[0] with
    case None -> []
    case Some { annotation } ->
        [compile_schema_constant(prefix + idx, annotation_application_schema(annotation), annotation.location)]
            + compile_annotation_application_schema(prefix, annotations[1:], idx + 1)

private fun annotation_application_schema(annotation: AnnotationApplication): String =
    annotation.name + "|" + annotation_arguments_schema(annotation.arguments)

private fun annotation_arguments_schema(arguments: List[AnnotationArgument]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> annotation_argument_schema(argument) + annotation_argument_schema_tail(arguments[1:])

private fun annotation_argument_schema_tail(arguments: List[AnnotationArgument]): String =
    match arguments[0] with
    case None -> ""
    case Some _ -> ";" + annotation_arguments_schema(arguments)

private fun annotation_argument_schema(argument: AnnotationArgument): String =
    argument.name + "=" + annotation_value_schema(argument.value)

private fun annotation_value_schema(value: AnnotationValue): String =
    match value with
    case AnnotationStringValue literal -> "string:" + literal.value
    case AnnotationIntValue literal -> "int:" + literal.source
    case AnnotationLongValue literal -> "long:" + literal.source
    case AnnotationDoubleValue literal -> "double:" + literal.source
    case AnnotationFloatValue literal -> "float:" + literal.source
    case AnnotationBoolValue literal -> if literal.value then "bool:true" else "bool:false"
    case AnnotationTypeNameValue literal -> "type:" + literal.value
    case AnnotationNothingValue _ -> "nothing:"

private fun compile_data_schema_parents(dataName: String, parents: List[DataParentDeclaration], idx: int): List[CompiledFunction] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        [compile_schema_constant("__capy_schema_parent|" + dataName + "|" + idx, type_reference_schema(parent.typeReference), parent.location)]
            + compile_data_schema_parents(dataName, parents[1:], idx + 1)

private fun data_declaration_field_schema(field: DataFieldDeclaration): String =
    field.name + "|" + type_reference_schema(field.typeReference)

private fun type_reference_schema(type: TypeReference): String =
    type.name + type_reference_arguments_schema(type.arguments)

private fun type_reference_arguments_schema(arguments: List[TypeReference]): String =
    if arguments.is_empty()
    then ""
    else "[" + type_reference_list_schema(arguments) + "]"

private fun type_reference_list_schema(arguments: List[TypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> type_reference_schema(argument) + type_reference_list_tail_schema(arguments[1:])

private fun type_reference_list_tail_schema(arguments: List[TypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> ", " + type_reference_schema(argument) + type_reference_list_tail_schema(arguments[1:])

private fun compile_schema_constant(name: String, value: String, location: SourceLocation): CompiledFunction =
    CompiledFunction {
        name: name,
        visibility: "const:schema",
        parameters: [],
        returnType: compile_type(compiler_string_type()),
        body: CompiledStringLiteral {
            value: value,
            source: "\"" + value + "\"",
            location: compile_location(location)
        },
        location: compile_location(location)
    }

private fun compile_function(function: FunctionDeclaration): CompiledFunction =
    CompiledFunction {
        name: function.name,
        visibility: function.visibility,
        parameters: compile_parameters(function.parameters),
        returnType: compile_return_type(function.returnType, function.parameters, function.body),
        body: compile_expression_in_function(function.body, function.name),
        location: compile_location(function.location)
    }

private fun compile_return_type(type: TypeReference, parameters: List[FunctionParameter], body: Expression): CompiledTypeReference =
    if type.name.is_empty()
    then compile_type(infer_return_type(body, parameters, 0))
    else compile_type(type)

private fun infer_return_type(expression: Expression, env: List[FunctionParameter], depth: int): TypeReference =
    if depth > 16
    then missing_type()
    else match expression with
    case UnsupportedExpression unsupported -> if placeholder_source(unsupported.source) then nothing_type() else missing_type()
    case IntLiteral _ -> compiler_int_type()
    case LongLiteral _ -> compiler_long_type()
    case FloatLiteral _ -> compiler_float_type()
    case DoubleLiteral _ -> compiler_double_type()
    case BoolLiteral _ -> compiler_bool_type()
    case StringLiteral _ -> compiler_string_type()
    case VariableExpression variable -> lookup_inferred_type(variable.name, env)
    case IfExpression ifExpression -> infer_if_type(ifExpression, env, depth + 1)
    case BinaryExpression binary -> infer_binary_type(binary, env, depth + 1)
    case UnaryExpression unary -> infer_unary_type(unary, env, depth + 1)
    case FunctionCallExpression _ -> missing_type()
    case FunctionReferenceExpression _ -> missing_type()
    case MethodCallExpression call -> infer_method_call_type(call, env, depth + 1)
    case WithExpression withExpression -> infer_return_type(withExpression.receiver, env, depth + 1)
    case LambdaExpression _ -> missing_type()
    case ListLiteral literal -> compiler_list_type(compiler_first_expression_type(literal.values, env, depth + 1))
    case SetLiteral literal -> compiler_set_type(compiler_first_expression_type(literal.values, env, depth + 1))
    case DictLiteral literal -> compiler_dict_type(compiler_first_dict_value_type(literal.entries, env, depth + 1))
    case TupleLiteral literal -> compiler_tuple_type(compiler_expression_types(literal.values, env, depth + 1))
    case IndexExpression _ -> missing_type()
    case DataLiteral literal -> TypeReference { name: literal.typeName, arguments: [] }
    case FieldAccessExpression _ -> missing_type()
    case ReduceExpression reduce -> infer_return_type(reduce.initial, env, depth + 1)
    case MatchExpression matchExpression -> compiler_match_expression_type(matchExpression.cases, env, depth + 1)
    case BlockExpression block -> infer_return_type(block.result, block_type_env(block.bindings, env, depth + 1), depth + 1)

private fun block_type_env(bindings: List[LetBinding], env: List[FunctionParameter], depth: int): List[FunctionParameter] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        let bindingType = if binding.typeReference.name.is_empty() then infer_return_type(binding.value, env, depth + 1) else binding.typeReference
        block_type_env(bindings[1:], [FunctionParameter {
            name: binding.name,
            typeReference: bindingType,
            location: binding.location
        }] + env, depth + 1)

private fun lookup_inferred_type(name: String, env: List[FunctionParameter]): TypeReference =
    match env[0] with
    case None -> missing_type()
    case Some { binding } ->
        if binding.name == name
        then binding.typeReference
        else lookup_inferred_type(name, env[1:])

private fun infer_if_type(ifExpression: IfExpression, env: List[FunctionParameter], depth: int): TypeReference =
    let thenType = infer_return_type(ifExpression.thenBranch, env, depth + 1)
    let elseType = infer_return_type(ifExpression.elseBranch, env, depth + 1)
    if thenType.name.is_empty()
    then elseType
    else if elseType.name.is_empty() | compiler_same_type(thenType, elseType)
    then thenType
    else if compiler_data_object_type(thenType) & compiler_data_object_type(elseType)
    then compiler_preferred_data_object_type(thenType, elseType)
    else missing_type()

private fun compiler_data_object_type(type: TypeReference): bool =
    !type.name.is_empty()
        & !compiler_numeric_type(type)
        & type.name != "bool"
        & type.name != "String"
        & type.name != "List"
        & type.name != "Set"
        & type.name != "Dict"
        & type.name != "Tuple"
        & type.name != "Effect"
        & type.name != "Assert"
        & compiler_uppercase_type_name(type.name)

private fun compiler_uppercase_type_name(name: String): bool =
    let member = compiler_unqualified_type_name(name)
    match member[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

private fun compiler_unqualified_type_name(name: String): String =
    let dot = compiler_last_index_of(name, ".", 0, -1)
    let slash = compiler_last_index_of(name, "/", 0, -1)
    let idx = if dot > slash then dot else slash
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun compiler_last_index_of(value: String, needle: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { char } ->
            compiler_last_index_of(value, needle, idx + 1, if char == needle then idx else found)

private fun compiler_preferred_data_object_type(first: TypeReference, second: TypeReference): TypeReference =
    if first.arguments.is_empty() & !second.arguments.is_empty()
    then second
    else first

private fun infer_binary_type(binary: BinaryExpression, env: List[FunctionParameter], depth: int): TypeReference =
    let leftType = infer_return_type(binary.left, env, depth + 1)
    if compiler_collection_pipe_expression(binary, leftType)
    then missing_type()
    else compiler_binary_result_type(
        binary.operator,
        leftType,
        infer_return_type(binary.right, env, depth + 1)
    )

private fun compiler_collection_pipe_expression(binary: BinaryExpression, leftType: TypeReference): bool =
    compiler_collection_pipe_operator(binary.operator) & compiler_collection_receiver_type(leftType) & compiler_lambda_expression(binary.right)

private fun compiler_collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*"

private fun compiler_collection_receiver_type(type: TypeReference): bool =
    type.name == "List" | type.name == "Set" | type.name == "Dict" | type.name == "Seq" | type.name == "String"

private fun compiler_lambda_expression(expression: Expression): bool =
    match expression with
    case LambdaExpression _ -> true
    case FunctionReferenceExpression _ -> true
    case _ -> false

private fun infer_unary_type(unary: UnaryExpression, env: List[FunctionParameter], depth: int): TypeReference =
    if unary.operator == "!"
    then compiler_bool_type()
    else infer_return_type(unary.expression, env, depth + 1)

private fun infer_method_call_type(call: MethodCallExpression, env: List[FunctionParameter], depth: int): TypeReference =
    if call.name == "size"
    then compiler_int_type()
    else missing_type()

private fun compiler_first_expression_type(expressions: List[Expression], env: List[FunctionParameter], depth: int): TypeReference =
    match expressions[0] with
    case None -> compiler_any_type()
    case Some { expression } -> infer_return_type(expression, env, depth + 1)

private fun compiler_first_dict_value_type(entries: List[DictEntry], env: List[FunctionParameter], depth: int): TypeReference =
    match entries[0] with
    case None -> compiler_any_type()
    case Some { entry } -> infer_return_type(entry.value, env, depth + 1)

private fun compiler_expression_types(expressions: List[Expression], env: List[FunctionParameter], depth: int): List[TypeReference] =
    match expressions[0] with
    case None -> []
    case Some { expression } -> [infer_return_type(expression, env, depth + 1)] + compiler_expression_types(expressions[1:], env, depth + 1)

private fun compiler_match_expression_type(cases: List[MatchCase], env: List[FunctionParameter], depth: int): TypeReference =
    match cases[0] with
    case None -> missing_type()
    case Some { matchCase } -> infer_return_type(matchCase.body, env, depth + 1)

private fun compiler_binary_result_type(operator: String, leftType: TypeReference, rightType: TypeReference): TypeReference =
    if compiler_boolean_binary_operator(operator)
    then compiler_bool_type()
    else if compiler_comparison_operator(operator)
    then compiler_bool_type()
    else if operator == "+" & (leftType.name == "String" | rightType.name == "String")
    then compiler_string_type()
    else if compiler_string_left_numeric_operator(operator, leftType, rightType)
    then compiler_string_type()
    else if compiler_numeric_binary_operator(operator) & compiler_numeric_type(leftType) & compiler_numeric_type(rightType)
    then compiler_promoted_numeric_type(leftType, rightType)
    else missing_type()

private fun compiler_boolean_binary_operator(operator: String): bool =
    operator == "&" | operator == "|"

private fun compiler_comparison_operator(operator: String): bool =
    operator == ">" | operator == "<" | operator == ">=" | operator == "<=" | operator == "==" | operator == "!=" | operator == "?"

private fun compiler_numeric_binary_operator(operator: String): bool =
    operator == "+" | operator == "-" | operator == "*" | operator == "/" | operator == "%" | operator == "^"

private fun compiler_string_left_numeric_operator(operator: String, leftType: TypeReference, rightType: TypeReference): bool =
    (operator == "-" | operator == "*" | operator == "/" | operator == "^") & leftType.name == "String" & compiler_numeric_type(rightType)

private fun compiler_promoted_numeric_type(leftType: TypeReference, rightType: TypeReference): TypeReference =
    if leftType.name == "double" | rightType.name == "double"
    then compiler_double_type()
    else if leftType.name == "float" | rightType.name == "float"
    then compiler_float_type()
    else if leftType.name == "long" | rightType.name == "long"
    then compiler_long_type()
    else if leftType.name == "int" | rightType.name == "int"
    then compiler_int_type()
    else compiler_byte_type()

private fun compiler_numeric_type(type: TypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"

private fun compiler_same_type(first: TypeReference, second: TypeReference): bool =
    first.name == second.name & compiler_same_type_arguments(first.arguments, second.arguments)

private fun compiler_same_type_arguments(first: List[TypeReference], second: List[TypeReference]): bool =
    match first[0] with
    case None -> second.is_empty()
    case Some { firstType } ->
        match second[0] with
        case None -> false
        case Some { secondType } -> compiler_same_type(firstType, secondType) & compiler_same_type_arguments(first[1:], second[1:])

private fun missing_type(): TypeReference =
    TypeReference { name: "", arguments: [] }

private fun compiler_byte_type(): TypeReference =
    TypeReference { name: "byte", arguments: [] }

private fun compiler_int_type(): TypeReference =
    TypeReference { name: "int", arguments: [] }

private fun compiler_long_type(): TypeReference =
    TypeReference { name: "long", arguments: [] }

private fun compiler_float_type(): TypeReference =
    TypeReference { name: "float", arguments: [] }

private fun compiler_double_type(): TypeReference =
    TypeReference { name: "double", arguments: [] }

private fun compiler_bool_type(): TypeReference =
    TypeReference { name: "bool", arguments: [] }

private fun compiler_string_type(): TypeReference =
    TypeReference { name: "String", arguments: [] }

private fun compiler_any_type(): TypeReference =
    TypeReference { name: "any", arguments: [] }

private fun nothing_type(): TypeReference =
    TypeReference { name: "nothing", arguments: [] }

private fun compiler_list_type(argument: TypeReference): TypeReference =
    TypeReference { name: "List", arguments: [argument] }

private fun compiler_set_type(argument: TypeReference): TypeReference =
    TypeReference { name: "Set", arguments: [argument] }

private fun compiler_dict_type(argument: TypeReference): TypeReference =
    TypeReference { name: "Dict", arguments: [argument] }

private fun compiler_tuple_type(arguments: List[TypeReference]): TypeReference =
    TypeReference { name: "Tuple", arguments: arguments }

private fun placeholder_source(source: String): bool =
    source == "???" | source == "_"

private fun compile_imports(imports: List[ImportDeclaration]): List[CompiledImportDeclaration] =
    match imports[0] with
    case None -> []
    case Some { declaration } -> [CompiledImportDeclaration {
        modulePath: declaration.modulePath,
        importedNames: declaration.importedNames,
        excludedNames: declaration.excludedNames,
        wildcard: declaration.wildcard,
        qualified: declaration.qualified,
        location: compile_location(declaration.location)
    }] + compile_imports(imports[1:])

private fun compile_parameters(parameters: List[FunctionParameter]): List[CompiledFunctionParameter] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [CompiledFunctionParameter {
        name: parameter.name,
        typeReference: compile_type(parameter.typeReference),
        location: compile_location(parameter.location)
    }] + compile_parameters(parameters[1:])

private fun compile_type(type: TypeReference): CompiledTypeReference =
    CompiledTypeReference {
        name: type.name,
        arguments: compile_types(type.arguments)
    }

private fun compile_types(types: List[TypeReference]): List[CompiledTypeReference] =
    match types[0] with
    case None -> []
    case Some { type } -> [compile_type(type)] + compile_types(types[1:])

private fun compile_location(location: SourceLocation): CompiledSourceLocation =
    CompiledSourceLocation {
        line: location.line,
        column: location.column
    }

private fun expression_location(expression: Expression): SourceLocation =
    match expression with
    case UnsupportedExpression value -> value.location
    case IntLiteral value -> value.location
    case LongLiteral value -> value.location
    case FloatLiteral value -> value.location
    case DoubleLiteral value -> value.location
    case BoolLiteral value -> value.location
    case StringLiteral value -> value.location
    case VariableExpression value -> value.location
    case IfExpression value -> value.location
    case BinaryExpression value -> value.location
    case UnaryExpression value -> value.location
    case FunctionCallExpression value -> value.location
    case FunctionReferenceExpression value -> value.location
    case MethodCallExpression value -> value.location
    case WithExpression value -> value.location
    case LambdaExpression value -> value.location
    case ListLiteral value -> value.location
    case SetLiteral value -> value.location
    case DictLiteral value -> value.location
    case TupleLiteral value -> value.location
    case IndexExpression value -> value.location
    case DataLiteral value -> value.location
    case FieldAccessExpression value -> value.location
    case ReduceExpression value -> value.location
    case MatchExpression value -> value.location
    case BlockExpression value -> value.location

private fun compile_expression_in_function(expression: Expression, functionName: String): CompiledExpression =
    match expression with
    case UnsupportedExpression { source, location } -> CompiledUnsupportedExpression {
        source: compiled_unsupported_source(source, functionName),
        location: compile_location(location)
    }
    case IntLiteral { value, source, location } -> CompiledIntLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case LongLiteral { value, source, location } -> CompiledLongLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case FloatLiteral { value, source, location } -> CompiledFloatLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case DoubleLiteral { value, source, location } -> CompiledDoubleLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case BoolLiteral { value, source, location } -> CompiledBoolLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case StringLiteral { value, source, location } -> CompiledStringLiteral {
        value: value,
        source: source,
        location: compile_location(location)
    }
    case VariableExpression { name, location } -> CompiledVariableExpression {
        name: name,
        location: compile_location(location)
    }
    case IfExpression { condition, thenBranch, elseBranch, location } -> CompiledIfExpression {
        condition: compile_expression_in_function(condition, functionName),
        thenBranch: compile_expression_in_function(thenBranch, functionName),
        elseBranch: compile_expression_in_function(elseBranch, functionName),
        location: compile_location(location)
    }
    case BinaryExpression { operator, left, right, location } -> CompiledBinaryExpression {
        operator: operator,
        left: compile_expression_in_function(left, functionName),
        right: compile_expression_in_function(right, functionName),
        location: compile_location(location)
    }
    case UnaryExpression unary -> CompiledUnaryExpression {
        operator: unary.operator,
        expression: compile_expression_in_function(unary.expression, functionName),
        location: compile_location(unary.location)
    }
    case FunctionCallExpression { name, arguments, location } -> CompiledFunctionCallExpression {
        name: name,
        arguments: compile_expressions(arguments, functionName),
        location: compile_location(location)
    }
    case FunctionReferenceExpression { name, location } -> CompiledFunctionReferenceExpression {
        name: name,
        location: compile_location(location)
    }
    case MethodCallExpression call -> compile_method_call(call, functionName)
    case WithExpression { receiver, fields, location } -> CompiledWithExpression {
        receiver: compile_expression_in_function(receiver, functionName),
        fields: compile_expression_data_fields(fields, functionName),
        location: compile_location(location)
    }
    case LambdaExpression { parameters, body, location } -> CompiledLambdaExpression {
        parameters: parameters,
        body: compile_expression_in_function(body, functionName),
        location: compile_location(location)
    }
    case ListLiteral { values, location } -> CompiledListLiteral {
        values: compile_expressions(values, functionName),
        location: compile_location(location)
    }
    case SetLiteral { values, location } -> CompiledSetLiteral {
        values: compile_expressions(values, functionName),
        location: compile_location(location)
    }
    case DictLiteral { entries, location } -> CompiledDictLiteral {
        entries: compile_dict_entries(entries, functionName),
        location: compile_location(location)
    }
    case TupleLiteral { values, location } -> CompiledTupleLiteral {
        values: compile_expressions(values, functionName),
        location: compile_location(location)
    }
    case IndexExpression { receiver, index, endIndex, hasEndIndex, location } -> CompiledIndexExpression {
        receiver: compile_expression_in_function(receiver, functionName),
        index: compile_expression_in_function(index, functionName),
        endIndex: compile_expression_in_function(endIndex, functionName),
        hasEndIndex: hasEndIndex,
        location: compile_location(location)
    }
    case DataLiteral { typeName, fields, location } -> CompiledDataLiteral {
        typeName: typeName,
        fields: compile_expression_data_fields(fields, functionName),
        location: compile_location(location)
    }
    case FieldAccessExpression access -> compile_field_access(access, functionName)
    case ReduceExpression { receiver, initial, accumulatorName, keyName, valueName, body, location } -> CompiledReduceExpression {
        receiver: compile_expression_in_function(receiver, functionName),
        initial: compile_expression_in_function(initial, functionName),
        accumulatorName: accumulatorName,
        keyName: keyName,
        valueName: valueName,
        body: compile_expression_in_function(body, functionName),
        location: compile_location(location)
    }
    case MatchExpression { value, cases, location } -> CompiledMatchExpression {
        value: compile_expression_in_function(value, functionName),
        cases: compile_match_cases(cases, functionName),
        location: compile_location(location)
    }
    case BlockExpression { bindings, result, location } -> CompiledBlockExpression {
        bindings: compile_let_bindings(bindings, functionName),
        result: compile_expression_in_function(result, functionName),
        location: compile_location(location)
    }

private fun compile_method_call(call: MethodCallExpression, functionName: String): CompiledExpression =
    match call.receiver with
    case UnaryExpression { operator, expression, location } ->
        if operator == "!"
        then CompiledUnaryExpression {
            operator: operator,
            expression: CompiledMethodCallExpression {
                receiver: compile_expression_in_function(expression, functionName),
                name: call.name,
                arguments: compile_expressions(call.arguments, functionName),
                location: compile_location(call.location)
            },
            location: compile_location(location)
        }
        else compiled_method_call(call, functionName)
    case FieldAccessExpression access -> compile_method_call_on_field_access(call, access, functionName)
    case _ -> compiled_method_call(call, functionName)

private fun compile_method_call_on_field_access(call: MethodCallExpression, access: FieldAccessExpression, functionName: String): CompiledExpression =
    match access.receiver with
    case UnaryExpression { operator, expression, location } ->
        if operator == "!"
        then CompiledUnaryExpression {
            operator: operator,
            expression: CompiledMethodCallExpression {
                receiver: CompiledFieldAccessExpression {
                    receiver: compile_expression_in_function(expression, functionName),
                    name: access.name,
                    location: compile_location(access.location)
                },
                name: call.name,
                arguments: compile_expressions(call.arguments, functionName),
                location: compile_location(call.location)
            },
            location: compile_location(location)
        }
        else compiled_method_call(call, functionName)
    case _ -> compiled_method_call(call, functionName)

private fun compiled_method_call(call: MethodCallExpression, functionName: String): CompiledExpression =
    CompiledMethodCallExpression {
        receiver: compile_expression_in_function(call.receiver, functionName),
        name: call.name,
        arguments: compile_expressions(call.arguments, functionName),
        location: compile_location(call.location)
    }

private fun compile_field_access(access: FieldAccessExpression, functionName: String): CompiledExpression =
    match access.receiver with
    case UnaryExpression { operator, expression, location } ->
        if operator == "!"
        then CompiledUnaryExpression {
            operator: operator,
            expression: CompiledFieldAccessExpression {
                receiver: compile_expression_in_function(expression, functionName),
                name: access.name,
                location: compile_location(access.location)
            },
            location: compile_location(location)
        }
        else compiled_field_access(access, functionName)
    case _ -> compiled_field_access(access, functionName)

private fun compiled_field_access(access: FieldAccessExpression, functionName: String): CompiledExpression =
    CompiledFieldAccessExpression {
        receiver: compile_expression_in_function(access.receiver, functionName),
        name: access.name,
        location: compile_location(access.location)
    }

private fun compile_expressions(expressions: List[Expression], functionName: String): List[CompiledExpression] =
    match expressions[0] with
    case None -> []
    case Some { expression } -> [compile_expression_in_function(expression, functionName)] + compile_expressions(expressions[1:], functionName)

private fun compile_dict_entries(entries: List[DictEntry], functionName: String): List[CompiledDictEntry] =
    match entries[0] with
    case None -> []
    case Some { entry } -> [CompiledDictEntry {
        key: compile_expression_in_function(entry.key, functionName),
        value: compile_expression_in_function(entry.value, functionName),
        location: compile_location(entry.location)
    }] + compile_dict_entries(entries[1:], functionName)

private fun compile_expression_data_fields(fields: List[DataField], functionName: String): List[CompiledDataField] =
    match fields[0] with
    case None -> []
    case Some { field } -> [CompiledDataField {
        name: field.name,
        value: compile_expression_in_function(field.value, functionName),
        spread: field.spread,
        location: compile_location(field.location)
    }] + compile_expression_data_fields(fields[1:], functionName)

private fun compile_match_cases(cases: List[MatchCase], functionName: String): List[CompiledMatchCase] =
    match cases[0] with
    case None -> []
    case Some { matchCase } -> [CompiledMatchCase {
        typeName: matchCase.typeName,
        bindings: matchCase.bindings,
        bindsWholeValue: matchCase.bindsWholeValue,
        literal: compile_expression_in_function(matchCase.literal, functionName),
        hasLiteral: matchCase.hasLiteral,
        wildcard: matchCase.wildcard,
        guard: compile_expression_in_function(matchCase.guard, functionName),
        hasGuard: matchCase.hasGuard,
        body: compile_expression_in_function(matchCase.body, functionName),
        location: compile_location(matchCase.location)
    }] + compile_match_cases(cases[1:], functionName)

private fun compile_let_bindings(bindings: List[LetBinding], functionName: String): List[CompiledLetBinding] =
    match bindings[0] with
    case None -> []
    case Some { binding } -> [CompiledLetBinding {
        name: binding.name,
        typeReference: compile_type(binding.typeReference),
        operator: binding.operator,
        value: compile_expression_in_function(binding.value, functionName),
        location: compile_location(binding.location)
    }] + compile_let_bindings(bindings[1:], functionName)

private fun compiled_unsupported_source(source: String, functionName: String): String =
    if placeholder_source(source)
    then "__capy_placeholder__|" + functionName
    else source
