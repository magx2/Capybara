from /capy/collection/List import { List }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }

/// Annotation metadata available after compilation, including fields, documentation, visibility, and source location.
data CompiledAnnotationDeclaration {
    name: String,
    visibility: String,
    documentation: List[String],
    repeatable: bool,
    targets: List[String],
    fields: List[String],
    location: CompiledSourceLocation
}
