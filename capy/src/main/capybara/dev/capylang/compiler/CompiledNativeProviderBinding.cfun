from /capy/lang/Option import { Option }
from /dev/capylang/compiler/NativeProviderBackendBinding import { NativeProviderBackendBinding }

/// compiled native-provider binding for one backend implementation method and its Capybara signature.
data CompiledNativeProviderBinding {
    interfaceId: String,
    qualifier: String,
    javaBinding: Option[NativeProviderBackendBinding],
    javascriptBinding: Option[NativeProviderBackendBinding],
    pythonBinding: Option[NativeProviderBackendBinding]
}
