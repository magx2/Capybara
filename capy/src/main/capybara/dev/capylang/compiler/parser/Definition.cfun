from /capy/collection/List import { List }
from /dev/capylang/compiler/parser/ConstantDeclaration import { ConstantDeclaration }
from /dev/capylang/compiler/parser/FunctionDeclaration import { FunctionDeclaration }
from /dev/capylang/compiler/parser/SourceLocation import { SourceLocation }
from /dev/capylang/compiler/parser/TypeReference import { TypeReference }

/// Parsed annotation argument pairing a field name with a literal annotation value.
data AnnotationArgument { name: String, value: AnnotationValue, location: SourceLocation }
/// Parsed annotation use with name, argument list, and source position.
data AnnotationApplication { name: String, arguments: List[AnnotationArgument], location: SourceLocation }
/// Parsed annotation string literal, preserving source text and location.
data AnnotationStringValue { value: String, source: String, location: SourceLocation }
/// Parsed annotation int literal, preserving source text and location.
data AnnotationIntValue { value: int, source: String, location: SourceLocation }
/// Parsed annotation long literal, preserving source text and location.
data AnnotationLongValue { value: long, source: String, location: SourceLocation }
/// Parsed annotation double literal, preserving source text and location.
data AnnotationDoubleValue { value: double, source: String, location: SourceLocation }
/// Parsed annotation float literal, preserving source text and location.
data AnnotationFloatValue { value: float, source: String, location: SourceLocation }
/// Parsed annotation boolean literal, preserving source text and location.
data AnnotationBoolValue { value: bool, source: String, location: SourceLocation }
/// Parsed annotation type-name literal, preserving source text and location.
data AnnotationTypeNameValue { value: String, source: String, location: SourceLocation }
/// Parsed annotation nothing literal with source text and location.
data AnnotationNothingValue { source: String, location: SourceLocation }
/// Parsed annotation field declaration with declared type, optional default, documentation, and location.
data AnnotationFieldDeclaration {
    name: String,
    typeReference: TypeReference,
    defaultValue: AnnotationValue,
    hasDefault: bool,
    location: SourceLocation
}
/// Parsed annotation declaration with fields, documentation, visibility, and source location.
data AnnotationDeclaration {
    name: String,
    visibility: String,
    repeatable: bool,
    targets: List[String],
    fields: List[AnnotationFieldDeclaration],
    documentation: List[String],
    annotations: List[AnnotationApplication],
    location: SourceLocation
}
/// Parsed derive clause entry naming a deriver to apply at a source location.
data DeriveApplication { name: String, location: SourceLocation }
/// Parsed data field declaration with type, documentation, annotations, and source location.
data DataFieldDeclaration { name: String, typeReference: TypeReference, documentation: List[String], annotations: List[AnnotationApplication], location: SourceLocation }
/// Parsed parent type reference for a data declaration.
data DataParentDeclaration { typeReference: TypeReference, location: SourceLocation }
/// Parsed data type declaration with fields, parents, derives, documentation, annotations, and visibility.
data DataDeclaration {
    name: String,
    visibility: String,
    parameters: List[String],
    fields: List[DataFieldDeclaration],
    parents: List[DataParentDeclaration],
    documentation: List[String],
    annotations: List[AnnotationApplication],
    derives: List[DeriveApplication],
    location: SourceLocation
}
/// Parsed deriver declaration with type parameters, generated methods, documentation, and visibility.
data DeriverDeclaration {
    name: String,
    visibility: String,
    methods: List[FunctionDeclaration],
    documentation: List[String],
    annotations: List[AnnotationApplication],
    location: SourceLocation
}
/// Parsed enum value name with its source location.
data EnumValueDeclaration { name: String, location: SourceLocation }
/// Parsed enum declaration with values, documentation, annotations, and source location.
data EnumDeclaration { name: String, values: List[EnumValueDeclaration], documentation: List[String], annotations: List[AnnotationApplication], location: SourceLocation }
/// Parsed primitive-backed type declaration with backing type, documentation, annotations, and visibility.
data PrimitiveBackedTypeDeclaration {
    name: String,
    visibility: String,
    backingType: TypeReference,
    documentation: List[String],
    annotations: List[AnnotationApplication],
    location: SourceLocation
}
/// Parsed type alias declaration with aliased type, documentation, annotations, and visibility.
data TypeDeclaration {
    name: String,
    visibility: String,
    parameters: List[String],
    fields: List[DataFieldDeclaration],
    variants: List[TypeReference],
    documentation: List[String],
    annotations: List[AnnotationApplication],
    derives: List[DeriveApplication],
    location: SourceLocation
}
/// Sentinel for parser output that could not be classified as a supported top-level definition.
data UnsupportedDefinition {}
/// Top-level definition wrapper for a parsed constant declaration.
data ConstantDefinition { constant: ConstantDeclaration }
/// Top-level definition wrapper for a parsed function declaration.
data FunctionDefinition { function: FunctionDeclaration }

/// Union of supported top-level functional definitions produced by the parser.
union Definition = AnnotationDeclaration
                 | ConstantDefinition
                 | DataDeclaration
                 | DeriverDeclaration
                 | EnumDeclaration
                 | FunctionDefinition
                 | PrimitiveBackedTypeDeclaration
                 | TypeDeclaration
                 | UnsupportedDefinition

/// Union of literal value forms accepted in annotation arguments.
union AnnotationValue = AnnotationBoolValue
                      | AnnotationDoubleValue
                      | AnnotationFloatValue
                      | AnnotationIntValue
                      | AnnotationLongValue
                      | AnnotationNothingValue
                      | AnnotationStringValue
                      | AnnotationTypeNameValue
