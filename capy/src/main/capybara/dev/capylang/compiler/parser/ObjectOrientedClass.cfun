from /capy/collection/List import { List }
from /dev/capylang/compiler/parser/Expression import { Expression }
from /dev/capylang/compiler/parser/FunctionAnnotationApplication import { FunctionAnnotationApplication }
from /dev/capylang/compiler/parser/FunctionParameter import { FunctionParameter }
from /dev/capylang/compiler/parser/ObjectOrientedField import { ObjectOrientedField }
from /dev/capylang/compiler/parser/ObjectOrientedInitBlock import { ObjectOrientedInitBlock }
from /dev/capylang/compiler/parser/ObjectOrientedMethod import { ObjectOrientedMethod }
from /dev/capylang/compiler/parser/SourceLocation import { SourceLocation }
from /dev/capylang/compiler/parser/TypeReference import { TypeReference }

/// Parsed object class with parents, constructor parameters, fields, init blocks, methods, docs, annotations, and visibility.
data ObjectOrientedClass {
    name: String,
    visibility: String,
    open: bool,
    parameters: List[FunctionParameter],
    parents: List[TypeReference],
    fields: List[ObjectOrientedField],
    initBlocks: List[ObjectOrientedInitBlock],
    methods: List[ObjectOrientedMethod],
    documentation: List[String],
    annotations: List[FunctionAnnotationApplication],
    location: SourceLocation
}
