from /capy/collection/List import { List }
from /dev/capylang/compiler/parser/SourceLocation import { SourceLocation }
from /dev/capylang/compiler/parser/TypeReference import { TypeReference }

/// Union of expression variants used by the compiler pipeline.
union Expression =
    UnsupportedExpression
    | IntLiteral
    | LongLiteral
    | FloatLiteral
    | DoubleLiteral
    | BoolLiteral
    | StringLiteral
    | VariableExpression
    | IfExpression
    | BinaryExpression
    | UnaryExpression
    | FunctionCallExpression
    | FunctionReferenceExpression
    | MethodCallExpression
    | WithExpression
    | LambdaExpression
    | ListLiteral
    | SetLiteral
    | DictLiteral
    | TupleLiteral
    | IndexExpression
    | DataLiteral
    | FieldAccessExpression
    | ReduceExpression
    | MatchExpression
    | ThrowExpression
    | TryCatchExpression
    | BlockExpression

/// Parsed AST node for unsupported expression semantics.
data UnsupportedExpression { source: String, location: SourceLocation }
/// parsed AST node for an int literal, retaining source text and location.
data IntLiteral { value: int, source: String, location: SourceLocation }
/// Parsed AST node for a long literal, retaining source text and location.
data LongLiteral { value: long, source: String, location: SourceLocation }
/// Parsed AST node for a float literal, retaining source text and location.
data FloatLiteral { value: float, source: String, location: SourceLocation }
/// Parsed AST node for a double literal, retaining source text and location.
data DoubleLiteral { value: double, source: String, location: SourceLocation }
/// Parsed AST node for a boolean literal, retaining source text and location.
data BoolLiteral { value: bool, source: String, location: SourceLocation }
/// Parsed AST node for a string literal, retaining source text and location.
data StringLiteral { value: String, source: String, location: SourceLocation }
/// Parsed AST node for variable expression semantics.
data VariableExpression { name: String, location: SourceLocation }
/// Parsed AST node for if expression semantics.
data IfExpression { condition: Expression, thenBranch: Expression, elseBranch: Expression, location: SourceLocation }
/// Parsed AST node for binary expression semantics.
data BinaryExpression { operator: String, left: Expression, right: Expression, location: SourceLocation }
/// Parsed AST node for unary expression semantics.
data UnaryExpression { operator: String, expression: Expression, location: SourceLocation }
/// Parsed AST node for function call expression semantics.
data FunctionCallExpression { name: String, arguments: List[Expression], location: SourceLocation }
/// Parsed AST node for function reference expression semantics.
data FunctionReferenceExpression { name: String, location: SourceLocation }
/// Parsed AST node for method call expression semantics.
data MethodCallExpression { receiver: Expression, name: String, arguments: List[Expression], location: SourceLocation }
/// Parsed AST node for with expression semantics.
data WithExpression { receiver: Expression, fields: List[DataField], location: SourceLocation }
/// Parsed AST node for lambda expression semantics.
data LambdaExpression { parameters: List[String], body: Expression, location: SourceLocation }
/// Parsed AST node for a list literal, retaining source text and location.
data ListLiteral { values: List[Expression], location: SourceLocation }
/// Parsed AST node for a set literal, retaining source text and location.
data SetLiteral { values: List[Expression], location: SourceLocation }
/// Parsed AST helper node for one dict entry.
data DictEntry { key: Expression, value: Expression, location: SourceLocation }
/// Parsed AST node for a dict literal, retaining source text and location.
data DictLiteral { entries: List[DictEntry], location: SourceLocation }
/// Parsed AST node for a tuple literal, retaining source text and location.
data TupleLiteral { values: List[Expression], location: SourceLocation }
/// Parsed AST node for index expression semantics.
data IndexExpression { receiver: Expression, index: Expression, endIndex: Expression, hasEndIndex: bool, location: SourceLocation }
/// Parsed AST helper node for one data field.
data DataField { name: String, value: Expression, spread: bool, location: SourceLocation }
/// Parsed AST node for a data literal, retaining source text and location.
data DataLiteral { typeName: String, fields: List[DataField], location: SourceLocation }
/// Parsed AST node for field access expression semantics.
data FieldAccessExpression { receiver: Expression, name: String, location: SourceLocation }
/// Parsed AST node for reduce expression semantics.
data ReduceExpression { receiver: Expression, initial: Expression, accumulatorName: String, keyName: String, valueName: String, body: Expression, location: SourceLocation }
/// Parsed AST helper node for one match case.
data MatchCase { typeName: String, bindings: List[String], bindsWholeValue: bool, literal: Expression, hasLiteral: bool, wildcard: bool, guard: Expression, hasGuard: bool, body: Expression, location: SourceLocation }
/// Parsed AST node for match expression semantics.
data MatchExpression { value: Expression, cases: List[MatchCase], location: SourceLocation }
/// Parsed AST node for throw expression semantics.
data ThrowExpression { value: Expression, location: SourceLocation }
/// Parsed AST node for try/catch expression semantics.
data TryCatchExpression { body: Expression, catchName: String, catchBody: Expression, location: SourceLocation }
/// Parsed AST helper node for one let binding.
data LetBinding { name: String, typeReference: TypeReference, operator: String, value: Expression, documentation: List[String], location: SourceLocation }
/// Parsed AST node for block expression semantics.
data BlockExpression { bindings: List[LetBinding], result: Expression, location: SourceLocation }
