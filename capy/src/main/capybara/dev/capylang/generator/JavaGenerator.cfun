        + "    private static java.util.Set __capy_set_remove_all(java.util.Set left, java.util.Set right) {" + newline()
        + "        java.util.LinkedHashSet result = new java.util.LinkedHashSet(left);" + newline()
        + "        result.removeAll(right);" + newline()
        + "        return java.util.Collections.unmodifiableSet(result);" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings({\"unchecked\", \"rawtypes\"})" + newline()
        + "    private static java.util.Map __capy_dict_literal(java.util.Map.Entry... entries) {" + newline()
        + "        java.util.LinkedHashMap result = new java.util.LinkedHashMap();" + newline()
        + "        for (java.util.Map.Entry entry : entries) {" + newline()
        + "            result.put((java.lang.String) entry.getKey(), entry.getValue());" + newline()
        + "        }" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings({\"unchecked\", \"rawtypes\"})" + newline()
        + "    private static java.util.Map __capy_dict_append(java.util.Map values, java.util.List entry) {" + newline()
        + "        java.util.LinkedHashMap result = new java.util.LinkedHashMap(values);" + newline()
        + "        result.put((java.lang.String) entry.get(0), entry.get(1));" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings({\"unchecked\", \"rawtypes\"})" + newline()
        + "    private static java.util.Map __capy_dict_concat(java.util.Map left, java.util.Map right) {" + newline()
        + "        java.util.LinkedHashMap result = new java.util.LinkedHashMap(left);" + newline()
        + "        result.putAll(right);" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings({\"unchecked\", \"rawtypes\"})" + newline()
        + "    private static java.util.Map __capy_dict_remove(java.util.Map values, java.lang.String key) {" + newline()
        + "        java.util.LinkedHashMap result = new java.util.LinkedHashMap(values);" + newline()
        + "        result.remove(key);" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings({\"unchecked\", \"rawtypes\"})" + newline()
        + "    private static java.util.Map __capy_dict_remove_all(java.util.Map left, java.util.Map right) {" + newline()
        + "        java.util.LinkedHashMap result = new java.util.LinkedHashMap(left);" + newline()
        + "        result.keySet().removeAll(right.keySet());" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
