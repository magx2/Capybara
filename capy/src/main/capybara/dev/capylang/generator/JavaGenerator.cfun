from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from /dev/capylang/generator/GeneratedModule import { GeneratedModule }
from /dev/capylang/generator/GeneratedProgram import { GeneratedProgram }

data JavaBinding { name: String, typeReference: CompiledTypeReference }

const JAVA_IDENTIFIER_START = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_"
const JAVA_IDENTIFIER_PART = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
const JAVA_RESERVED_WORDS = "|abstract|assert|boolean|break|byte|case|catch|char|class|const|continue|default|do|double|else|enum|extends|final|finally|float|for|goto|if|implements|import|instanceof|int|interface|long|native|new|package|private|protected|public|return|short|static|strictfp|super|switch|synchronized|this|throw|throws|transient|try|void|volatile|while|true|false|null|var|record|yield|sealed|permits|_|"

fun java_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: java_modules(program.modules, program.modules) + test_runtime_modules(program.modules)
    }

private fun java_modules(modules: List[CompiledModule], allModules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: java_module_relative_path(module, ".java"),
        code: java_module_code(module, allModules)
    }] + java_modules(modules[1:], allModules)

private fun java_module_code(module: CompiledModule, allModules: List[CompiledModule]): String =
    java_package(module)
    + java_imports(module, allModules)
    + "public final class " + module.name + " {" + newline()
    + "    private " + module.name + "() " + "{" + "}" + newline() + newline()
    + java_constants(constant_functions(module.functions), [], module, allModules)
    + java_functions(module.functions, module, allModules)
    + java_helpers(module)
    + "}" + newline()

private fun java_imports(module: CompiledModule, allModules: List[CompiledModule]): String =
    "import java.util.*;" + newline()
    + "import java.util.function.*;" + newline()
    + static_imports(module.imports, module, allModules)
    + newline()

private fun static_imports(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        let className = imported_module_class(module, declaration.modulePath)
        if declaration.wildcard & !stdlib_import(declaration.modulePath) & module_class_exists(className, allModules)
        then "import static " + className + ".*;" + newline() + static_imports(imports[1:], module, allModules)
        else static_imports(imports[1:], module, allModules)

private fun stdlib_import(modulePath: String): bool =
    java_generator_string_has_prefix(modulePath, "/capy/") | java_generator_string_has_prefix(modulePath, "capy/")

private fun imported_module_class(module: CompiledModule, modulePath: String): String =
    if java_generator_string_has_prefix(modulePath, "/")
    then path_to_class(modulePath[1, modulePath.size()])
    else if modulePath ? "/"
    then path_to_class(modulePath)
    else if module.path.is_empty()
    then modulePath
    else module.path.replace("/", ".") + "." + modulePath

private fun path_to_class(path: String): String =
    path.replace("/", ".")

private fun java_generator_string_has_prefix(value: String, prefix: String): bool =
    java_generator_string_has_prefix_at(value, prefix, 0)

private fun java_generator_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then java_generator_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun module_class_exists(className: String, modules: List[CompiledModule]): bool =
    match modules[0] with
    case None -> false
    case Some { module } -> module_fqcn(module) == className | module_class_exists(className, modules[1:])

private fun java_constants(constants: List[CompiledFunction], previous: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match constants[0] with
    case None -> if previous.is_empty() then "" else newline()
    case Some { constant } ->
        java_constant(constant, constant_bindings(previous), module, allModules)
        + java_constants(constants[1:], [constant] + previous, module, allModules)

private fun java_constant(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = constant_type(constant, env, module, allModules)
    "    " + constant_java_visibility(constant) + " static final " + java_type(type) + " " + java_identifier(constant.name)
    + " = " + expression_code(constant.body, env, type, module, allModules) + ";" + newline()

private fun constant_type(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if constant.returnType.name.is_empty()
    then expression_type(constant.body, env, module, allModules)
    else constant.returnType

private fun constant_bindings(constants: List[CompiledFunction]): List[JavaBinding] =
    match constants[0] with
    case None -> []
    case Some { constant } -> [JavaBinding { name: constant.name, typeReference: constant_type_reference(constant) }] + constant_bindings(constants[1:])

private fun constant_type_reference(constant: CompiledFunction): CompiledTypeReference =
    if constant.returnType.name.is_empty()
    then object_type()
    else constant.returnType

private fun constant_functions(functions: List[CompiledFunction]): List[CompiledFunction] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_constant(function) & !compiled_schema(function)
        then [function] + constant_functions(functions[1:])
        else constant_functions(functions[1:])

private fun compiled_constant(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:")

private fun compiled_schema(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:schema")

private fun constant_java_visibility(function: CompiledFunction): String =
    java_visibility(function.visibility.replace("const:", ""))

private fun java_functions(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if compiled_constant(function)
        then java_functions(functions[1:], module, allModules)
        else java_function(function, module, allModules) + newline() + java_functions(functions[1:], module, allModules)

private fun java_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    let returnType = java_type(function.returnType)
    let env = java_function_bindings(function) + constant_bindings(constant_functions(module.functions))
    "    " + java_visibility(function.visibility) + " static " + returnType + " " + java_function_name(function) + "(" + java_function_parameters(function) + ") {" + newline()
    + java_function_body(function, env, module, allModules)
    + "    }" + newline()

private fun java_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else java_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

private fun java_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_function(name, module.functions) with
    case Some { function } -> java_function_name(function)
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> java_function_name(function)
        case None -> java_identifier(name)

private fun extension_method_function(function: CompiledFunction): bool =
    function.name ? "."

private fun method_receiver_type(function: CompiledFunction): CompiledTypeReference =
    CompiledTypeReference { name: method_owner_name(function.name), arguments: [] }

private fun method_owner_name(name: String): String =
    let idx = last_dot_index(name)
    if idx < 0 then "" else name[0, idx]

private fun method_member_name(name: String): String =
    let idx = last_dot_index(name)
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun last_dot_index(name: String): int =
    last_dot_index_from(name, 0, -1)

private fun last_dot_index_from(name: String, idx: int, found: int): int =
    if idx >= name.size().value
    then found
    else match name[idx] with
        case None -> found
        case Some { char } ->
            let next = if char == "." then idx else found
            last_dot_index_from(name, idx + 1, next)

private fun java_visibility(visibility: String): String =
    if visibility == "private" then "private" else "public"

private fun java_function_body(function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if !expression_emittable(function.body, env, module, allModules)
    then "        throw new UnsupportedOperationException(\"Unsupported CFUN expression at " + function.location.line + ":" + function.location.column + "\");" + newline()
    else
        match function.body with
        case CompiledBlockExpression block -> block_statements(block.bindings, env, module, allModules, "        ")
            + "        return " + expression_code(block.result, block_env(block.bindings, env, module, allModules), function.returnType, module, allModules) + ";" + newline()
        case _ -> "        return " + expression_code(function.body, env, function.returnType, module, allModules) + ";" + newline()

private fun java_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        java_type(parameter.typeReference) + " " + java_identifier(parameter.name) + java_parameter_tail(parameters[1:])

private fun java_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_type(parameter.typeReference) + " " + java_identifier(parameter.name) + java_parameter_tail(parameters[1:])

private fun java_function_parameters(function: CompiledFunction): String =
    if extension_method_function(function)
    then java_type(method_receiver_type(function)) + " " + java_identifier("this") + java_method_parameter_tail(function.parameters)
    else java_parameters(function.parameters)

private fun java_method_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else ", " + java_parameters(parameters)

private fun java_function_bindings(function: CompiledFunction): List[JavaBinding] =
    if extension_method_function(function)
    then [JavaBinding { name: "this", typeReference: method_receiver_type(function) }] + parameter_bindings(function.parameters)
    else parameter_bindings(function.parameters)

private fun parameter_bindings(parameters: List[CompiledFunctionParameter]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [JavaBinding { name: parameter.name, typeReference: parameter.typeReference }] + parameter_bindings(parameters[1:])

private fun expression_code(
    expression: CompiledExpression,
    env: List[JavaBinding],
    expectedType: CompiledTypeReference,
    module: CompiledModule,
    allModules: List[CompiledModule]
): String =
    match expression with
    case CompiledUnsupportedExpression unsupported ->
        if compiled_placeholder_source(unsupported.source)
        then placeholder_code(unsupported, module)
        else "unsupported(\"" + escape_java_string(unsupported.source) + "\")"
    case CompiledIntLiteral literal -> numeric_widening_code(int_literal_code(literal, expectedType), expression_type(expression, env, module, allModules), expectedType)
    case CompiledLongLiteral literal -> numeric_widening_code(literal.source, long_type(), expectedType)
    case CompiledFloatLiteral literal -> numeric_widening_code(literal.source, float_type(), expectedType)
    case CompiledDoubleLiteral literal -> literal.source
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> "\"" + escape_java_string(literal.value) + "\""
    case CompiledVariableExpression variable -> numeric_widening_code(java_identifier(variable.name), lookup_binding(variable.name, env), expectedType)
    case CompiledIfExpression ifExpression -> "("
        + truthy_expression_code(ifExpression.condition, env, module, allModules)
        + " ? " + expression_code(ifExpression.thenBranch, env, expectedType, module, allModules)
        + " : " + expression_code(ifExpression.elseBranch, env, expectedType, module, allModules)
        + ")"
    case CompiledBinaryExpression binary -> binary_expression_code(binary, env, expectedType, module, allModules)
    case CompiledUnaryExpression unary -> unary_expression_code(unary, env, expectedType, module, allModules)
    case CompiledFunctionCallExpression call -> numeric_widening_code(function_call_code(call, env, expectedType, module, allModules), function_call_type(call, env, module, allModules), expectedType)
    case CompiledMethodCallExpression call -> numeric_widening_code(method_call_code(call, env, expectedType, module, allModules), method_call_type(call, env, module, allModules), expectedType)
    case CompiledLambdaExpression lambda -> lambda_code(lambda, env, module, allModules)
    case CompiledListLiteral literal -> "java.util.List.of(" + expression_list_code(literal.values, env, module, allModules) + ")"
    case CompiledSetLiteral literal -> "java.util.Set.of(" + expression_list_code(literal.values, env, module, allModules) + ")"
    case CompiledDictLiteral literal -> dict_code(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> "java.util.List.of(" + expression_list_code(literal.values, env, module, allModules) + ")"
    case CompiledIndexExpression index -> index_code(index, env, expectedType, module, allModules)
    case CompiledDataLiteral literal -> data_literal_code(literal, env, expectedType, module, allModules)
    case CompiledFieldAccessExpression access -> field_access_code(access, env, expectedType, module, allModules)
    case CompiledReduceExpression reduce -> reduce_expression_code(reduce, env, expectedType, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_code(matchExpression, env, expectedType, module, allModules)
    case CompiledBlockExpression block -> block_expression_code(block, env, expectedType, module, allModules)

private fun placeholder_code(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    "__capy_not_implemented(\"" + escape_java_string(placeholder_message(placeholder, module)) + "\")"

private fun placeholder_message(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    let functionName = placeholder_function_name(placeholder.source)
    if functionName.is_empty()
    then "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": placeholder expression is not yet implemented"
    else "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": the function `" + functionName + "` is not yet implemented"

private fun compiled_placeholder_source(source: String): bool =
    java_generator_string_has_prefix(source, "__capy_placeholder__|")

private fun placeholder_function_name(source: String): String =
    if compiled_placeholder_source(source)
    then source["__capy_placeholder__|".size().value, source.size().value]
    else ""

private fun binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = expression_type(binary.left, env, module, allModules)
    let rightType = expression_type(binary.right, env, module, allModules)
    let naturalResultType = binary_result_type(binary.operator, leftType, rightType)
    let resultType = contextual_binary_result_type(naturalResultType, expectedType)
    if collection_pipe_expression(binary, leftType)
    then collection_pipe_code(binary, leftType, env, module, allModules)
    else if boolean_binary_operator(binary.operator)
    then "(" + truthy_expression_code(binary.left, env, module, allModules)
        + " " + java_boolean_operator(binary.operator) + " "
        + truthy_expression_code(binary.right, env, module, allModules)
        + ")"
    else if string_left_numeric_operator(binary.operator, leftType, rightType)
    then "(" + expression_code(binary.left, env, leftType, module, allModules)
        + " + "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    else if binary.operator == "^"
    then power_expression_code(binary, resultType, env, module, allModules)
    else if binary.operator == ".nand."
    then byte_result_code("(~(" + expression_code(binary.left, env, leftType, module, allModules)
        + " & "
        + expression_code(binary.right, env, rightType, module, allModules)
        + "))", expectedType)
    else if bitwise_binary_operator(binary.operator)
    then byte_result_code("(" + expression_code(binary.left, env, leftType, module, allModules)
        + " " + java_bitwise_operator(binary.operator) + " "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")", expectedType)
    else if binary.operator == "?"
    then expression_code(binary.left, env, leftType, module, allModules)
        + ".contains(" + expression_code(binary.right, env, rightType, module, allModules) + ")"
    else if binary.operator == "%" & resultType.name == "byte"
    then "((byte) (" + expression_code(binary.left, env, leftType, module, allModules)
        + " % "
        + expression_code(binary.right, env, rightType, module, allModules)
        + "))"
    else byte_result_code("(" + expression_code(binary.left, env, resultType, module, allModules)
        + " " + binary.operator + " "
        + expression_code(binary.right, env, resultType, module, allModules)
        + ")", resultType)

private fun contextual_binary_result_type(naturalResultType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if numeric_type(naturalResultType) & type_assignable(expectedType, naturalResultType)
    then expectedType
    else naturalResultType

private fun power_expression_code(binary: CompiledBinaryExpression, resultType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if resultType.name == "byte"
    then "((byte) __capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + "))"
    else if resultType.name == "int"
    then "__capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + ")"
    else if resultType.name == "long"
    then "__capy_pow_long("
        + expression_code(binary.left, env, long_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, long_type(), module, allModules)
        + ")"
    else if resultType.name == "float"
    then "((float) java.lang.Math.pow("
        + expression_code(binary.left, env, float_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, float_type(), module, allModules)
        + "))"
    else "java.lang.Math.pow("
        + expression_code(binary.left, env, double_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, double_type(), module, allModules)
        + ")"

private fun unary_expression_code(unary: CompiledUnaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(!" + truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then byte_result_code("(~" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else if unary.operator == "-"
    then byte_result_code("(-" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else "(" + unary.operator + expression_code(unary.expression, env, expectedType, module, allModules) + ")"

private fun byte_result_code(expression: String, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" then "((byte) " + expression + ")" else expression

private fun truthy_expression_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(expression, env, module, allModules)
    truthy_code(expression_code(expression, env, type, module, allModules), type)

private fun truthy_code(code: String, type: CompiledTypeReference): String =
    if type.name == "bool"
    then code
    else if integer_type(type)
    then "(" + code + " != 0)"
    else if type.name == "float"
    then "(" + code + " != 0.0f)"
    else if type.name == "double"
    then "(" + code + " != 0.0)"
    else if type.name == "String"
    then "(!" + code + ".isEmpty())"
    else if type.name == "List" | type.name == "Set" | type.name == "Dict"
    then "(!" + code + ".isEmpty())"
    else "__capy_truthy(" + code + ")"

private fun bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

private fun java_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

private fun boolean_binary_operator(operator: String): bool =
    operator == "&" | operator == "|"

private fun java_boolean_operator(operator: String): String =
    if operator == "&" then "&&" else "||"

private fun collection_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    collection_pipe_operator(binary.operator) & collection_receiver_type(leftType) & lambda_expression(binary.right)

private fun collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*"

private fun lambda_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case _ -> false

private fun collection_pipe_code(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = seq_receiver_code(binary.left, receiverType, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|-"
        then receiverCode + ".filter(" + lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules) + ")"
        else if binary.operator == "|*"
        then receiverCode + ".flatMap(" + flat_map_lambda_code(lambda, valueType, env, module, allModules) + ")"
        else receiverCode + ".map(" + lambda_code_for_value(lambda, valueType, expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules), env, module, allModules) + ")"
    case _ -> "unsupported(\"collection pipe\")"

private fun seq_receiver_code(expression: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = expression_code(expression, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then "capy.lang.String.chars(" + receiverCode + ")"
    else if receiverType.name == "Seq"
    then "((" + java_seq_type(receiverType) + ") " + receiverCode + ")"
    else "capy.lang.Seq.toSeq(" + receiverCode + ")"

private fun int_literal_code(literal: CompiledIntLiteral, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" & byte_literal_source(literal.source)
    then "((byte) " + literal.source + ")"
    else literal.source

private fun numeric_widening_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if primitive_numeric_widening_assignable(expectedType, sourceType)
    then "((" + java_type(expectedType) + ") " + code + ")"
    else code

private fun function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "delay"
    then "capy.lang.Effect.delay(" + expression_code(argument(call.arguments, 0), env, supplier_type(first_type_argument(delay_call_type(call.arguments, env, module, allModules))), module, allModules) + ")"
    else if call.name == "assert_all"
    then "capy.test.Assert.assertAll(" + expression_code(argument(call.arguments, 0), env, list_type(assert_type()), module, allModules) + ")"
    else if call.name == "assert_that"
    then assert_that_code(argument(call.arguments, 0), env, module, allModules)
    else if call.name == "test"
    then "new capy.test.CapyTest.TestCase("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + ", capy.test.CapyTest.Passed.INSTANCE, 0, 0.0, "
        + expression_code(argument(call.arguments, 1), env, supplier_type(assert_type()), module, allModules)
        + ")"
    else if call.name == "test_file"
    then "capy.lang.Effect.pure(new capy.test.CapyTest.TestFile("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + ", "
        + expression_code(argument(call.arguments, 1), env, list_type(test_case_type()), module, allModules)
        + ", java.lang.System.currentTimeMillis()))"
    else if stdlib_math_digits_call(call, module)
    then "java.lang.Integer.toString("
        + expression_code(argument(call.arguments, 0), env, int_type(), module, allModules)
        + ").replace(\"-\", \"\").length()"
    else ordinary_function_call_code(call, env, module, allModules)

private fun ordinary_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_function_in_scope(call.name, module, allModules) with
    case Some { function } ->
        java_function_name(function) + "(" + parameter_expression_list_code(function.parameters, call.arguments, env, module, allModules) + ")"
    case None -> java_function_call_name(call.name, module, allModules) + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun parameter_expression_list_code(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

private fun parameter_expression_list_tail(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        ", " + expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

private fun parameter_type_at(parameters: List[CompiledFunctionParameter], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match parameters[idx] with
    case Some { parameter } -> parameter.typeReference
    case None -> fallback

private fun argument(arguments: List[CompiledExpression], idx: int): CompiledExpression =
    match arguments[idx] with
    case Some { expression } -> expression
    case None -> missing_argument()

private fun missing_argument(): CompiledExpression =
    CompiledUnsupportedExpression {
        source: "missing argument",
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

private fun method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_code(call, env, module, allModules)
    else if seq_as_list_call(call, env, module, allModules)
    then seq_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".asList()"
    else if primitive_conversion_method(call.name)
    then primitive_conversion_code(call, env, module, allModules)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> extension_method_call_code(function, call, env, module, allModules)
        case None -> expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
            + "." + java_method_name(call.name)
            + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun collection_predicate_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if collection_predicate_method(call.name) & collection_receiver_type(receiverType)
    then match call.arguments[0] with
        case None -> false
        case Some { predicate } ->
            match call.arguments[1] with
            case None -> lambda_expression(predicate)
            case Some _ -> false
    else false

private fun collection_predicate_method(name: String): bool =
    name == "any" | name == "all"

private fun collection_predicate_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    let receiverCode =
        if receiverType.name == "Seq" | receiverType.name == "String"
        then seq_receiver_code(call.receiver, receiverType, env, module, allModules)
        else expression_code(call.receiver, env, receiverType, module, allModules)
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda ->
        let lambdaCode = lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules)
        if receiverType.name == "Seq" | receiverType.name == "String"
        then collection_seq_predicate_code(call.name, receiverCode, lambdaCode)
        else receiverCode + ".stream()." + java_stream_predicate_method(call.name) + "(" + lambdaCode + ")"
    case _ -> "unsupported(\"collection predicate\")"

private fun collection_seq_predicate_code(name: String, receiverCode: String, lambdaCode: String): String =
    if name == "any"
    then receiverCode + ".any(" + lambdaCode + ")"
    else receiverCode + ".asList().stream().allMatch(" + lambdaCode + ")"

private fun java_stream_predicate_method(name: String): String =
    if name == "any" then "anyMatch" else "allMatch"

private fun seq_as_list_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    call.name == "as_list" & receiverType.name == "Seq" & call.arguments.is_empty()

private fun extension_method_call_code(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_function_name(function)
        + "("
        + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
        + method_call_argument_tail(call.arguments, env, module, allModules)
        + ")"

private fun method_call_argument_tail(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + expression_list_code(arguments, env, module, allModules)

private fun primitive_conversion_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((" + java_type(method_call_type(call, env, module, allModules)) + ") "
    + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
    + ")"

private fun lambda_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let params = lambda_parameters(lambda.parameters)
    params + " -> " + expression_code(lambda.body, lambda_env(lambda.parameters, env), expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules), module, allModules)

private fun lambda_code_for_value(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyCode = expression_code(lambda.body, lambdaEnv, expectedType, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, bodyCode)

private fun flat_map_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyType = expression_type(lambda.body, lambdaEnv, module, allModules)
    let bodyCode = expression_code(lambda.body, lambdaEnv, bodyType, module, allModules)
    let resultCode =
        if collection_receiver_type(bodyType)
        then seq_receiver_code(lambda.body, bodyType, lambdaEnv, module, allModules)
        else bodyCode
    lambda_code_with_result(lambda.parameters, valueType, resultCode)

private fun lambda_code_with_result(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_code(parameters, valueType, resultCode)
    else lambda_parameters(parameters) + " -> " + resultCode

private fun tuple_lambda_code(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    let tupleName = "__capy_tuple"
    tupleName + " -> {" + newline()
    + tuple_lambda_binding_statements(parameters, valueType.arguments, tupleName, 0, "            ")
    + "            return " + resultCode + ";" + newline()
    + "        }"

private fun tuple_lambda_binding_statements(parameters: List[String], types: List[CompiledTypeReference], tupleName: String, idx: int, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        let type = tuple_argument(types, 0)
        let statement =
            if parameter == "_"
            then ""
            else indent + java_type(type) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(type) + ") ((java.util.List<?>) " + tupleName + ").get(" + idx + "));" + newline()
        statement + tuple_lambda_binding_statements(parameters[1:], types[1:], tupleName, idx + 1, indent)

private fun lambda_parameters(parameters: List[String]): String =
    if parameters.is_empty()
    then "()"
    else "(" + java_identifier_list(parameters) + ")"

private fun lambda_env(parameters: List[String], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [JavaBinding { name: parameter, typeReference: object_type() }] + lambda_env(parameters[1:], env)

private fun lambda_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_env(parameters, valueType.arguments, env)
    else lambda_single_value_env(parameters, valueType, env)

private fun lambda_single_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [JavaBinding { name: parameter, typeReference: valueType }] + env

private fun tuple_lambda_env(parameters: List[String], types: List[CompiledTypeReference], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } ->
        let rest = match types[0] with
            case None -> tuple_lambda_env(parameters[1:], [], env)
            case Some _ -> tuple_lambda_env(parameters[1:], types[1:], env)
        if parameter == "_"
        then rest
        else [JavaBinding { name: parameter, typeReference: tuple_argument(types, 0) }] + rest

private fun tuple_lambda_parameters(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ -> true

private fun index_code(index: CompiledIndexExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = expression_code(index.receiver, env, expression_type(index.receiver, env, module, allModules), module, allModules)
    let indexCode = expression_code(index.index, env, int_type(), module, allModules)
    let resultType = expression_type(index, env, module, allModules)
    "((" + boxed_java_type(resultType) + ") " + receiverCode + ".get(" + indexCode + "))"

private fun block_expression_code(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + block_statements(block.bindings, env, module, allModules, "            ")
    + "            return " + expression_code(block.result, block_env(block.bindings, env, module, allModules), expectedType, module, allModules) + ";" + newline()
    + "        }).get()"

private fun block_statements(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        indent + java_type(valueType) + " " + java_identifier(binding.name) + " = "
        + expression_code(binding.value, env, valueType, module, allModules) + ";" + newline()
        + block_statements(bindings[1:], [JavaBinding { name: binding.name, typeReference: valueType }] + env, module, allModules, indent)

private fun block_env(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        block_env(bindings[1:], [JavaBinding { name: binding.name, typeReference: valueType }] + env, module, allModules)

private fun binding_type(binding: CompiledLetBinding, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if binding.typeReference.name.is_empty()
    then expression_type(binding.value, env, module, allModules)
    else binding.typeReference

private fun assert_that_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let actualType = expression_type(expression, env, module, allModules)
    let actual = expression_code(expression, env, actualType, module, allModules)
    if actualType.name == "int"
    then "new capy.test.Assert.IntAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "long"
    then "new capy.test.Assert.LongAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "float"
    then "new capy.test.Assert.FloatAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "double"
    then "new capy.test.Assert.DoubleAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "bool"
    then "new capy.test.Assert.BoolAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "String"
    then "new capy.test.Assert.StringAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "Set"
    then "new capy.test.Assert.SetAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "Dict"
    then "new capy.test.Assert.DictAssert(java.util.List.of(), " + actual + ")"
    else "new capy.test.Assert.DataAssert(java.util.List.of(), " + actual + ")"

private fun expression_list_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
        + expression_list_tail(expressions[1:], env, module, allModules)

private fun expression_list_tail(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } -> ", " + expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules) + expression_list_tail(expressions[1:], env, module, allModules)

private fun dict_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if entries.is_empty()
    then "java.util.Map.of()"
    else "java.util.Map.ofEntries(" + dict_entries_code(entries, env, module, allModules) + ")"

private fun dict_entries_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        "java.util.Map.entry(" + expression_code(entry.key, env, string_type(), module, allModules) + ", " + expression_code(entry.value, env, expression_type(entry.value, env, module, allModules), module, allModules) + ")"
        + dict_entries_tail(entries[1:], env, module, allModules)

private fun dict_entries_tail(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some _ -> ", " + dict_entries_code(entries, env, module, allModules)

private fun data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let dataType = find_data_type(literal.typeName, module, allModules)
    let bindings = data_type_bindings(dataType, expectedType, module, allModules)
    "__capy_data(\"" + escape_java_string(literal.typeName) + "\", " + data_fields_code(literal.fields, env, dataType, bindings, module, allModules) + ")"

private fun data_fields_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if fields.is_empty()
    then "java.util.Map.of()"
    else "java.util.Map.ofEntries(" + data_field_entries_code(fields, env, dataType, bindings, module, allModules) + ")"

private fun data_field_entries_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        let fieldName = data_constructor_field_name(field.name, dataType, module, allModules)
        let fieldType = data_constructor_field_type(field.name, dataType, bindings, expression_type(field.value, env, module, allModules), module, allModules)
        "java.util.Map.entry(\"" + escape_java_string(fieldName) + "\", " + expression_code(field.value, env, fieldType, module, allModules) + ")"
        + data_field_entries_tail(fields[1:], env, dataType, bindings, module, allModules)

private fun data_field_entries_tail(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + data_field_entries_code(fields, env, dataType, bindings, module, allModules)

private fun data_constructor_field_name(name: String, dataType: /capy/lang/Option[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_generator_string_has_prefix(name, "$")
    then match dataType with
        case Some { value } -> declared_positional_field_name(name, data_type_fields(value, module, allModules), 0)
        case None -> name
    else name

private fun declared_positional_field_name(name: String, fields: List[String], idx: int): String =
    match fields[0] with
    case None -> name
    case Some { field } ->
        if name == "$" + idx
        then schema_field_name(field)
        else declared_positional_field_name(name, fields[1:], idx + 1)

private fun data_constructor_field_type(name: String, dataType: /capy/lang/Option[String], bindings: List[JavaBinding], fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match dataType with
    case Some { value } ->
        if java_generator_string_has_prefix(name, "$")
        then declared_positional_field_type(name, data_type_fields(value, module, allModules), bindings, 0, fallback)
        else declared_named_field_type(name, data_type_fields(value, module, allModules), bindings, fallback)
    case None -> fallback

private fun declared_named_field_type(name: String, fields: List[String], bindings: List[JavaBinding], fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if schema_field_name(field) == name
        then generic_data_field_type(field, bindings)
        else declared_named_field_type(name, fields[1:], bindings, fallback)

private fun declared_positional_field_type(name: String, fields: List[String], bindings: List[JavaBinding], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if name == "$" + idx
        then generic_data_field_type(field, bindings)
        else declared_positional_field_type(name, fields[1:], bindings, idx + 1, fallback)

private fun generic_data_field_type(field: String, bindings: List[JavaBinding]): CompiledTypeReference =
    let typeName = schema_field_type_name(field)
    match lookup_type_parameter(typeName, bindings) with
    case Some { value } -> value
    case None -> CompiledTypeReference { name: typeName, arguments: [] }

private fun field_access_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let sourceType = field_access_type(access, env, module, allModules)
    let castType = field_access_cast_type(sourceType, expectedType)
    numeric_widening_code(
        "((" + boxed_java_type(castType) + ") __capy_data_field("
        + expression_code(access.receiver, env, expression_type(access.receiver, env, module, allModules), module, allModules)
        + ", \"" + escape_java_string(access.name) + "\"))",
        castType,
        expectedType
    )

private fun field_access_cast_type(sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if sourceType.name == "any"
    then expectedType
    else sourceType

private fun reduce_expression_code(reduce: CompiledReduceExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = expression_type(reduce.initial, env, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    let reduceEnv = [JavaBinding { name: reduce.accumulatorName, typeReference: resultType }, JavaBinding { name: reduce.valueName, typeReference: valueType }] + env
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
    + "            for (" + java_type(valueType) + " " + java_identifier(reduce.valueName) + " : " + expression_code(reduce.receiver, env, receiverType, module, allModules) + ") {" + newline()
    + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
    + "            }" + newline()
    + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
    + "        }).get()"

private fun collection_value_type(type: CompiledTypeReference): CompiledTypeReference =
    if type.name == "List" | type.name == "Set" | type.name == "Seq"
    then first_type_argument(type)
    else if type.name == "String"
    then string_type()
    else object_type()

private fun collection_receiver_type(type: CompiledTypeReference): bool =
    type.name == "List" | type.name == "Set" | type.name == "Seq" | type.name == "String"

private fun match_expression_code(matchExpression: CompiledMatchExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = expression_type(matchExpression.value, env, module, allModules)
    let valueCode = expression_code(matchExpression.value, env, valueType, module, allModules)
    match_cases_code(matchExpression.cases, valueCode, env, expectedType, module, allModules)

private fun match_cases_code(cases: List[CompiledMatchCase], valueCode: String, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match cases[0] with
    case None -> "unsupported(\"match\")"
    case Some { matchCase } ->
        "(__capy_data_is(" + valueCode + ", \"" + escape_java_string(matchCase.typeName) + "\") ? "
        + match_case_body_code(matchCase, valueCode, env, expectedType, module, allModules)
        + " : " + match_cases_code(cases[1:], valueCode, env, expectedType, module, allModules) + ")"

private fun match_case_body_code(matchCase: CompiledMatchCase, valueCode: String, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if matchCase.bindings.is_empty()
    then expression_code(matchCase.body, env, expectedType, module, allModules)
    else "((java.util.function.Supplier<" + boxed_java_type(expectedType) + ">) () -> {" + newline()
        + match_binding_statements(matchCase.bindings, valueCode, "            ")
        + "            return " + expression_code(matchCase.body, match_env(matchCase.bindings, env), expectedType, module, allModules) + ";" + newline()
        + "        }).get()"

private fun match_binding_statements(bindings: List[String], valueCode: String, indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        indent + "java.lang.Object " + java_identifier(binding) + " = __capy_data_field(" + valueCode + ", \"" + escape_java_string(binding) + "\");" + newline()
        + match_binding_statements(bindings[1:], valueCode, indent)

private fun match_env(bindings: List[String], env: List[JavaBinding]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } -> [JavaBinding { name: binding, typeReference: object_type() }] + match_env(bindings[1:], env)

private fun expression_type(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledUnsupportedExpression unsupported -> if compiled_placeholder_source(unsupported.source) then nothing_type() else object_type()
    case CompiledIntLiteral literal -> if byte_literal_source(literal.source) then byte_type() else int_type()
    case CompiledLongLiteral _ -> long_type()
    case CompiledFloatLiteral _ -> float_type()
    case CompiledDoubleLiteral _ -> double_type()
    case CompiledBoolLiteral _ -> bool_type()
    case CompiledStringLiteral _ -> string_type()
    case CompiledVariableExpression variable -> lookup_binding(variable.name, env)
    case CompiledIfExpression ifExpression -> expression_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBinaryExpression binary ->
        let leftType = expression_type(binary.left, env, module, allModules)
        if collection_pipe_expression(binary, leftType)
        then collection_pipe_result_type(binary, leftType, env, module, allModules)
        else binary_result_type(
            binary.operator,
            leftType,
            expression_type(binary.right, env, module, allModules)
        )
    case CompiledUnaryExpression unary -> expression_type(unary.expression, env, module, allModules)
    case CompiledFunctionCallExpression call -> function_call_type(call, env, module, allModules)
    case CompiledMethodCallExpression call -> method_call_type(call, env, module, allModules)
    case CompiledLambdaExpression _ -> supplier_type(assert_type())
    case CompiledListLiteral literal -> list_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledSetLiteral literal -> set_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledDictLiteral literal -> dict_type(first_dict_value_type(literal.entries, env, module, allModules))
    case CompiledTupleLiteral literal -> tuple_type(expression_types(literal.values, env, module, allModules))
    case CompiledIndexExpression index -> indexed_type(expression_type(index.receiver, env, module, allModules), index.index)
    case CompiledDataLiteral literal -> CompiledTypeReference { name: literal.typeName, arguments: [] }
    case CompiledFieldAccessExpression access -> field_access_type(access, env, module, allModules)
    case CompiledReduceExpression reduce -> expression_type(reduce.initial, env, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_type(matchExpression.cases, env, module, allModules)
    case CompiledBlockExpression block -> expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)

private fun match_expression_type(cases: List[CompiledMatchCase], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match cases[0] with
    case None -> object_type()
    case Some { matchCase } -> expression_type(matchCase.body, match_env(matchCase.bindings, env), module, allModules)

private fun collection_pipe_result_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = collection_value_type(receiverType)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
        if binary.operator == "|-"
        then seq_type(valueType)
        else if binary.operator == "|*"
        then flat_map_result_type(expression_type(lambda.body, lambdaEnv, module, allModules))
        else seq_type(expression_type(lambda.body, lambdaEnv, module, allModules))
    case _ -> object_type()

private fun flat_map_result_type(bodyType: CompiledTypeReference): CompiledTypeReference =
    if collection_receiver_type(bodyType)
    then seq_type(collection_value_type(bodyType))
    else seq_type(object_type())

private fun field_access_type(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(access.receiver, env, module, allModules)
    match find_data_type(receiverType.name, module, allModules) with
    case Some { dataType } ->
        let bindings = data_type_bindings(/capy/lang/Option.Some { dataType }, receiverType, module, allModules)
        declared_named_field_type(access.name, data_type_fields(dataType, module, allModules), bindings, object_type())
    case None -> object_type()

private fun function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "delay"
    then delay_call_type(call.arguments, env, module, allModules)
    else if call.name == "assert_all" | call.name == "assert_that"
    then assert_type()
    else if call.name == "test"
    then test_case_type()
    else if call.name == "test_file"
    then effect_type(test_file_type())
    else if stdlib_math_digits_call(call, module)
    then int_type()
    else lookup_function_type_in_scope(call.name, module, allModules)

private fun delay_call_type(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match arguments[0] with
    case None -> effect_type(object_type())
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression lambda -> effect_type(expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules))
        case _ -> effect_type(object_type())

private fun method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "size"
    then int_type()
    else if collection_predicate_call(call, env, module, allModules)
    then bool_type()
    else if seq_as_list_call(call, env, module, allModules)
    then list_type(collection_value_type(expression_type(call.receiver, env, module, allModules)))
    else if call.name == "to_int"
    then int_type()
    else if call.name == "to_long"
    then long_type()
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> function.returnType
        case None -> assert_type()

private fun first_expression_type(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expressions[0] with
    case None -> object_type()
    case Some { expression } -> expression_type(expression, env, module, allModules)

private fun first_dict_value_type(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match entries[0] with
    case None -> object_type()
    case Some { entry } -> expression_type(entry.value, env, module, allModules)

private fun expression_types(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[CompiledTypeReference] =
    match expressions[0] with
    case None -> []
    case Some { expression } -> [expression_type(expression, env, module, allModules)] + expression_types(expressions[1:], env, module, allModules)

private fun indexed_type(receiverType: CompiledTypeReference, index: CompiledExpression): CompiledTypeReference =
    if receiverType.name == "Tuple" | receiverType.name == "List"
    then match index with
        case CompiledIntLiteral literal -> tuple_argument(receiverType.arguments, literal.value)
        case _ -> object_type()
    else object_type()

private fun tuple_argument(arguments: List[CompiledTypeReference], index: int): CompiledTypeReference =
    match arguments[index] with
    case None -> object_type()
    case Some { argument } -> argument

private fun lookup_binding(name: String, env: List[JavaBinding]): CompiledTypeReference =
    match env[0] with
    case None -> object_type()
    case Some { binding } -> if binding.name == name then binding.typeReference else lookup_binding(name, env[1:])

private fun lookup_function_type_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function(name, module.functions) with
    case Some { function } -> function.returnType
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> function.returnType
        case None -> object_type()

private fun find_function_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_function(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports(name, module.imports, module, allModules)

private fun find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name & !compiled_constant(function)
        then /capy/lang/Option.Some { function }
        else find_function(name, functions[1:])

private fun find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.wildcard & !stdlib_import(declaration.modulePath)
        then find_function_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_function_in_imports(name, imports[1:], module, allModules)

private fun find_extension_method(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    find_extension_method_in_scope(receiverType.name, call.name, module, allModules)

private fun find_extension_method_in_scope(ownerName: String, methodName: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_extension_method_in_imports(ownerName, methodName, module.imports, module, allModules)

private fun find_method_function(ownerName: String, methodName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if extension_method_function(function)
            & method_owner_name(function.name) == ownerName
            & method_member_name(function.name) == methodName
            & !compiled_constant(function)
        then /capy/lang/Option.Some { function }
        else find_method_function(ownerName, methodName, functions[1:])

private fun find_extension_method_in_imports(ownerName: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.wildcard & !stdlib_import(declaration.modulePath)
        then find_extension_method_in_import(ownerName, methodName, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_extension_method_in_imports(ownerName, methodName, imports[1:], module, allModules)

private fun find_extension_method_in_import(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_extension_method_in_imported_module(ownerName, methodName, rest, module, allModules, importedModule)
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

private fun find_extension_method_in_imported_module(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

private fun find_function_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function_in_imported_module(name, rest, module, allModules, importedModule)
    case _ -> find_function_in_imports(name, rest, module, allModules)

private fun find_function_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_function_in_imports(name, rest, module, allModules)

private fun find_module_by_class(className: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } -> if module_fqcn(module) == className then /capy/lang/Option.Some { module } else find_module_by_class(className, modules[1:])

private fun find_data_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if schema_type_exists(name, module.functions)
    then /capy/lang/Option.Some { name }
    else match find_data_type_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> /capy/lang/Option.Some { value }
        case None -> find_data_type_in_modules(name, allModules)

private fun find_data_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then find_data_type_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_data_type_in_imports(name, imports[1:], module, allModules)

private fun find_data_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_imports(name, rest, module, allModules)
    case _ -> find_data_type_in_imports(name, rest, module, allModules)

private fun find_data_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_modules(name, modules[1:])

private fun schema_type_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        schema_function(function, "__capy_schema_type|" + name)
            | schema_type_exists(name, functions[1:])

private fun schema_function(function: CompiledFunction, name: String): bool =
    compiled_schema(function) & function.name == name

private fun schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_schema(function) & java_generator_string_has_prefix(function.name, prefix)
        then [schema_value(function)] + schema_values(prefix, functions[1:])
        else schema_values(prefix, functions[1:])

private fun schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

private fun schema_field_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

private fun schema_field_type_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then "any"
    else value[separator + 1, value.size().value]

private fun first_index_of(value: String, needle: String, idx: int): int =
    if idx >= value.size().value
    then -1
    else match value[idx] with
        case None -> -1
        case Some { char } -> if char == needle then idx else first_index_of(value, needle, idx + 1)

private fun data_type_bindings(dataType: /capy/lang/Option[String], concreteType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match dataType with
    case Some { value } -> type_parameter_bindings(data_type_parameters(value, module, allModules), concreteType.arguments)
    case None -> []

private fun data_type_parameters(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if schema_type_exists(name, module.functions)
    then schema_values("__capy_schema_param|" + name + "|", module.functions)
    else match data_type_parameters_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_parameters_in_modules(name, allModules)

private fun data_type_parameters_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_parameters_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_parameters_in_imports(name, imports[1:], module, allModules)

private fun data_type_parameters_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { schema_values("__capy_schema_param|" + name + "|", importedModule.functions) }
        else data_type_parameters_in_imports(name, rest, module, allModules)
    case _ -> data_type_parameters_in_imports(name, rest, module, allModules)

private fun data_type_parameters_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then schema_values("__capy_schema_param|" + name + "|", module.functions)
        else data_type_parameters_in_modules(name, modules[1:])

private fun data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if schema_type_exists(name, module.functions)
    then schema_values("__capy_schema_field|" + name + "|", module.functions)
    else match data_type_fields_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_fields_in_modules(name, allModules)

private fun data_type_fields_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_fields_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_fields_in_imports(name, imports[1:], module, allModules)

private fun data_type_fields_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { schema_values("__capy_schema_field|" + name + "|", importedModule.functions) }
        else data_type_fields_in_imports(name, rest, module, allModules)
    case _ -> data_type_fields_in_imports(name, rest, module, allModules)

private fun data_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    !stdlib_import(declaration.modulePath) & (declaration.wildcard | string_list_contains(declaration.importedNames, name))

private fun string_list_contains(values: List[String], expected: String): bool =
    match values[0] with
    case None -> false
    case Some { value } -> value == expected | string_list_contains(values[1:], expected)

private fun data_type_fields_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then schema_values("__capy_schema_field|" + name + "|", module.functions)
        else data_type_fields_in_modules(name, modules[1:])

private fun type_parameter_bindings(parameters: List[String], arguments: List[CompiledTypeReference]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        match arguments[0] with
        case Some { argument } -> [JavaBinding { name: parameter, typeReference: argument }] + type_parameter_bindings(parameters[1:], arguments[1:])
        case None -> [JavaBinding { name: parameter, typeReference: object_type() }] + type_parameter_bindings(parameters[1:], [])

private fun lookup_type_parameter(name: String, bindings: List[JavaBinding]): /capy/lang/Option[CompiledTypeReference] =
    match bindings[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding.typeReference }
        else lookup_type_parameter(name, bindings[1:])

private fun binary_result_type(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if boolean_binary_operator(operator)
    then bool_type()
    else if comparison_operator(operator)
    then bool_type()
    else if operator == "+" & (leftType.name == "String" | rightType.name == "String")
    then string_type()
    else if string_left_numeric_operator(operator, leftType, rightType)
    then string_type()
    else if numeric_binary_operator(operator) & numeric_type(leftType) & numeric_type(rightType)
    then promoted_numeric_type(leftType, rightType)
    else leftType

private fun numeric_binary_operator(operator: String): bool =
    operator == "+" | operator == "-" | operator == "*" | operator == "/" | operator == "%" | operator == "^"

private fun string_left_numeric_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "-" | operator == "*" | operator == "/" | operator == "^") & leftType.name == "String" & numeric_type(rightType)

private fun promoted_numeric_type(leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if leftType.name == "double" | rightType.name == "double"
    then double_type()
    else if leftType.name == "float" | rightType.name == "float"
    then float_type()
    else if leftType.name == "long" | rightType.name == "long"
    then long_type()
    else if leftType.name == "int" | rightType.name == "int"
    then int_type()
    else byte_type()

private fun comparison_operator(operator: String): bool =
    operator == ">" | operator == "<" | operator == ">=" | operator == "<=" | operator == "==" | operator == "!=" | operator == "?"

private fun expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> compiled_placeholder_source(unsupported.source)
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression variable -> binding_exists(variable.name, env)
    case CompiledIfExpression e -> truthy_expression_emittable(e.condition, env, module, allModules) & expression_emittable(e.thenBranch, env, module, allModules) & expression_emittable(e.elseBranch, env, module, allModules)
    case CompiledBinaryExpression e ->
        if collection_pipe_expression(e, expression_type(e.left, env, module, allModules))
        then collection_pipe_emittable(e, env, module, allModules)
        else java_binary_operator_emittable(e, env, module, allModules) & expression_emittable(e.left, env, module, allModules) & expression_emittable(e.right, env, module, allModules)
    case CompiledUnaryExpression e -> java_unary_operator_emittable(e, env, module, allModules) & expression_emittable(e.expression, env, module, allModules)
    case CompiledFunctionCallExpression e -> function_call_emittable(e, env, module, allModules)
    case CompiledMethodCallExpression e -> java_method_emittable(e, env, module, allModules)
    case CompiledLambdaExpression _ -> false
    case CompiledListLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledSetLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledDictLiteral e -> dict_entries_emittable(e.entries, env, module, allModules)
    case CompiledTupleLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledIndexExpression e -> index_emittable(e, env, module, allModules)
    case CompiledDataLiteral e -> data_fields_emittable(e.fields, env, module, allModules)
    case CompiledFieldAccessExpression e -> expression_emittable(e.receiver, env, module, allModules)
    case CompiledReduceExpression e -> reduce_expression_emittable(e, env, module, allModules)
    case CompiledMatchExpression e -> constant_value_expression(e.value) & expression_emittable(e.value, env, module, allModules) & match_cases_emittable(e.cases, env, module, allModules)
    case CompiledBlockExpression e -> let_bindings_emittable(e.bindings, env, module, allModules) & expression_emittable(e.result, block_env(e.bindings, env, module, allModules), module, allModules)

private fun expressions_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> expression_emittable(expression, env, module, allModules) & expressions_emittable(expressions[1:], env, module, allModules)

private fun dict_entries_emittable(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } -> expression_emittable(entry.key, env, module, allModules) & expression_emittable(entry.value, env, module, allModules) & dict_entries_emittable(entries[1:], env, module, allModules)

private fun data_fields_emittable(fields: List[CompiledDataField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } -> expression_emittable(field.value, env, module, allModules) & data_fields_emittable(fields[1:], env, module, allModules)

private fun reduce_expression_emittable(reduce: CompiledReduceExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let resultType = expression_type(reduce.initial, env, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    let reduceEnv = [JavaBinding { name: reduce.accumulatorName, typeReference: resultType }, JavaBinding { name: reduce.valueName, typeReference: valueType }] + env
    let receiverReducible = receiverType.name == "List" | receiverType.name == "Set"
    receiverReducible
        & constant_value_expression(reduce.receiver)
        & expression_emittable(reduce.receiver, env, module, allModules)
        & expression_emittable(reduce.initial, env, module, allModules)
        & expression_emittable(reduce.body, reduceEnv, module, allModules)

private fun match_cases_emittable(cases: List[CompiledMatchCase], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } -> expression_emittable(matchCase.body, match_env(matchCase.bindings, env), module, allModules) & (cases[1:].is_empty() | match_cases_emittable(cases[1:], env, module, allModules))

private fun let_bindings_emittable(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        expression_emittable(binding.value, env, module, allModules) & let_bindings_emittable(bindings[1:], [JavaBinding { name: binding.name, typeReference: valueType }] + env, module, allModules)

private fun binding_exists(name: String, env: List[JavaBinding]): bool =
    match env[0] with
    case None -> false
    case Some { binding } -> binding.name == name | binding_exists(name, env[1:])

private fun lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some { parameter } -> parameter != "_" & lambda_parameters_supported(parameters[1:])

private fun collection_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(binary.left, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                if binary.operator == "|-"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules) & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                else if binary.operator == "|*"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules) & collection_receiver_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                else collection_lambda_emittable(lambda, valueType, env, module, allModules)
            case _ -> false

private fun collection_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if lambda_parameter_shape_supported(lambda.parameters, valueType)
    then expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    else false

private fun lambda_parameter_shape_supported(parameters: List[String], valueType: CompiledTypeReference): bool =
    if tuple_lambda_parameters(parameters)
    then valueType.name == "Tuple" & tuple_lambda_arity_supported(parameters, valueType.arguments)
    else single_value_lambda_parameters_supported(parameters)

private fun single_value_lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some _ -> parameters[1:].is_empty()

private fun tuple_lambda_arity_supported(parameters: List[String], types: List[CompiledTypeReference]): bool =
    match parameters[0] with
    case None -> types.is_empty()
    case Some _ ->
        match types[0] with
        case None -> false
        case Some _ -> tuple_lambda_arity_supported(parameters[1:], types[1:])

private fun java_binary_operator_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let rightType = expression_type(binary.right, env, module, allModules)
    if binary.operator == "+"
    then leftType.name == "String" | rightType.name == "String" | (numeric_type(leftType) & numeric_type(rightType))
    else if boolean_binary_operator(binary.operator)
    then truthy_type(leftType) & truthy_type(rightType)
    else if binary.operator == "^"
    then (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if binary.operator == ".nand." | bitwise_binary_operator(binary.operator)
    then integer_type(leftType) & integer_type(rightType)
    else if binary.operator == "%"
    then remainder_type(leftType) & remainder_type(rightType)
    else if binary.operator == "-" | binary.operator == "*" | binary.operator == "/"
    then (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if binary.operator == ">" | binary.operator == "<" | binary.operator == ">=" | binary.operator == "<="
    then numeric_type(leftType) & numeric_type(rightType)
    else if binary.operator == "?"
    then (leftType.name == "List" | leftType.name == "Set" | leftType.name == "String") & !rightType.name.is_empty()
    else binary.operator == "==" | binary.operator == "!="

private fun java_unary_operator_emittable(unary: CompiledUnaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let type = expression_type(unary.expression, env, module, allModules)
    if unary.operator == "!" then truthy_type(type)
    else if unary.operator == "-" then numeric_type(type)
    else if unary.operator == ".not." then integer_type(type)
    else false

private fun truthy_expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    truthy_type(expression_type(expression, env, module, allModules)) & expression_emittable(expression, env, module, allModules)

private fun truthy_type(type: CompiledTypeReference): bool =
    type.name == "bool"
        | integer_type(type)
        | type.name == "float"
        | type.name == "double"
        | type.name == "String"
        | type.name == "List"
        | type.name == "Set"
        | type.name == "Dict"
        | type.name == "any"

private fun integer_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long"

private fun numeric_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"

private fun remainder_type(type: CompiledTypeReference): bool =
    type.name == "byte" | numeric_type(type)

private fun byte_literal_source(source: String): bool =
    java_generator_string_has_prefix(source, "0x") | java_generator_string_has_prefix(source, "0X")

private fun java_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if call.name == "size"
    then (receiverType.name == "List" | receiverType.name == "Set" | receiverType.name == "Dict")
        & call.arguments.is_empty()
        & expression_emittable(call.receiver, env, module, allModules)
    else if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_emittable(call, receiverType, env, module, allModules)
    else if call.name == "as_list" & receiverType.name == "Seq"
    then call.arguments.is_empty() & expression_emittable(call.receiver, env, module, allModules)
    else if primitive_conversion_method(call.name)
    then primitive_conversion_method_emittable(call, receiverType, env, module, allModules)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> extension_method_call_emittable(function, call, env, module, allModules)
        case None -> java_method_supported(call.name)
            & expression_emittable(call.receiver, env, module, allModules)
            & expressions_emittable(call.arguments, env, module, allModules)

private fun extension_method_call_emittable(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    concrete_return_type(function.returnType)
        & expression_emittable(call.receiver, env, module, allModules)
        & parameters_assignable(function.parameters, call.arguments, env, module, allModules)
        & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

private fun primitive_conversion_method_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.arguments.is_empty()
        & primitive_conversion_receiver(call.name, receiverType)
        & expression_emittable(call.receiver, env, module, allModules)

private fun collection_predicate_call_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { predicate } ->
        match call.arguments[1] with
        case Some _ -> false
        case None ->
            expression_emittable(call.receiver, env, module, allModules)
            & match predicate with
                case CompiledLambdaExpression lambda ->
                    let valueType = collection_value_type(receiverType)
                    collection_lambda_emittable(lambda, valueType, env, module, allModules)
                        & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                case _ -> false

private fun primitive_conversion_method(name: String): bool =
    name == "to_int" | name == "to_long"

private fun primitive_conversion_receiver(name: String, receiverType: CompiledTypeReference): bool =
    if name == "to_int"
    then receiverType.name == "long" | receiverType.name == "float" | receiverType.name == "double"
    else if name == "to_long"
    then receiverType.name == "float" | receiverType.name == "double"
    else false

private fun constant_value_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledVariableExpression variable -> uppercase_constant_name(variable.name)
    case _ -> false

private fun uppercase_constant_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ_" ? char

private fun function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "delay"
    then delay_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "assert_all"
    then expressions_emittable(call.arguments, env, module, allModules)
    else if call.name == "assert_that"
    then assert_that_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test"
    then test_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test_file"
    then test_file_call_emittable(call.arguments, env, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then stdlib_math_digits_call_emittable(call.arguments, env, module, allModules)
    else java_callable_name(call.name) & !binding_exists(call.name, env) & function_call_target_emittable(call.name, call.arguments, env, module, allModules) & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

private fun stdlib_math_digits_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "digits" & !function_defined(call.name, module.functions) & stdlib_math_wildcard_import(module.imports)

private fun function_defined(name: String, functions: List[CompiledFunction]): bool =
    match find_function(name, functions) with
    case Some _ -> true
    case None -> false

private fun stdlib_math_wildcard_import(imports: List[CompiledImportDeclaration]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.wildcard & (declaration.modulePath == "/capy/lang/Math" | declaration.modulePath == "capy/lang/Math")
        then true
        else stdlib_math_wildcard_import(imports[1:])

private fun stdlib_math_digits_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
        & type_assignable(int_type(), expression_type(argument, env, module, allModules))
        & expression_emittable(argument, env, module, allModules)

private fun assert_that_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        assert_type_supported(expression_type(expression, env, module, allModules))
        & expression_emittable(expression, env, module, allModules)

private fun assert_type_supported(type: CompiledTypeReference): bool =
    type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"
        | type.name == "bool" | type.name == "String" | type.name == "List" | type.name == "Set" | type.name == "Dict"
        | data_assert_type_supported(type)

private fun data_assert_type_supported(type: CompiledTypeReference): bool =
    concrete_return_type(type)
        & !collection_assert_type(type.name)
        & type.name != "Assert"
        & type.name != "Effect"
        & type.name != "Supplier"
        & (type.name == "data" | type.name == "enum" | java_generator_string_has_prefix(type.name, "/") | uppercase_data_type_name(type.name))

private fun collection_assert_type(name: String): bool =
    name == "List" | name == "Set" | name == "Dict" | name == "Seq"

private fun uppercase_data_type_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

private fun delay_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        arguments[1:].is_empty() & lambda_argument_emittable(expression, env, module, allModules)

private fun test_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { assertionExpression } ->
            expression_emittable(nameExpression, env, module, allModules) & lambda_argument_emittable(assertionExpression, env, module, allModules)

private fun lambda_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda_parameters_supported(lambda.parameters) & expression_emittable(lambda.body, lambda_env(lambda.parameters, env), module, allModules)
    case _ -> false

private fun test_file_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { testsExpression } ->
            let testsType = expression_type(testsExpression, env, module, allModules)
            expression_emittable(nameExpression, env, module, allModules)
                & expression_emittable(testsExpression, env, module, allModules)
                & testsType.name == "List"
                & first_type_argument(testsType).name == "TestCase"

private fun index_emittable(index: CompiledIndexExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(index.receiver, env, module, allModules)
    if receiverType.name == "List" | receiverType.name == "Tuple"
    then index_literal_emittable(index.index) & expression_emittable(index.receiver, env, module, allModules) & expression_emittable(index.index, env, module, allModules)
    else false

private fun index_literal_emittable(index: CompiledExpression): bool =
    match index with
    case CompiledIntLiteral literal -> literal.value >= 0
    case _ -> false

private fun function_call_target_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function(name, module.functions) with
    case Some { function } -> concrete_return_type(function.returnType) & parameters_assignable(function.parameters, arguments, env, module, allModules)
    case None -> imported_function_target_emittable(name, arguments, env, module.imports, module, allModules)

private fun imported_function_target_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.wildcard & !stdlib_import(declaration.modulePath)
        then imported_module_function_emittable(name, arguments, env, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else imported_function_target_emittable(name, arguments, env, imports[1:], module, allModules)

private fun imported_module_function_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): bool =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> imported_module_function_body_emittable(name, arguments, env, rest, module, allModules, importedModule)
    case _ -> imported_function_target_emittable(name, arguments, env, rest, module, allModules)

private fun imported_module_function_body_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): bool =
    match find_function(name, importedModule.functions) with
    case Some { function } -> concrete_return_type(function.returnType) & parameters_assignable(function.parameters, arguments, env, module, allModules)
    case _ -> imported_function_target_emittable(name, arguments, env, rest, module, allModules)

private fun concrete_return_type(type: CompiledTypeReference): bool =
    !type.name.is_empty() & type.name != "any"

private fun parameters_assignable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            parameter_argument_assignable(parameter.typeReference, argument, env, module, allModules)
            & parameters_assignable(parameters[1:], arguments[1:], env, module, allModules)

private fun parameter_argument_assignable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if empty_collection_literal_assignable(target, argument)
    then true
    else type_assignable(target, expression_type(argument, env, module, allModules))

private fun empty_collection_literal_assignable(target: CompiledTypeReference, argument: CompiledExpression): bool =
    match argument with
    case CompiledListLiteral literal -> literal.values.is_empty() & target.name == "List"
    case CompiledSetLiteral literal -> literal.values.is_empty() & target.name == "Set"
    case CompiledDictLiteral literal -> literal.entries.is_empty() & target.name == "Dict"
    case _ -> false

private fun type_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    if type_parameter(target) | source.name == "nothing"
    then true
    else if target.name.is_empty() | source.name.is_empty() | target.name == "any" | source.name == "any"
    then false
    else if primitive_numeric_widening_assignable(target, source)
    then true
    else target.name == source.name & type_arguments_assignable(target.arguments, source.arguments)

private fun primitive_numeric_widening_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    source.arguments.is_empty() & target.arguments.is_empty() & (
        (source.name == "byte" & (target.name == "int" | target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "int" & (target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "long" & (target.name == "float" | target.name == "double"))
        | (source.name == "float" & target.name == "double")
    )

private fun type_arguments_assignable(target: List[CompiledTypeReference], source: List[CompiledTypeReference]): bool =
    match target[0] with
    case None -> source.is_empty()
    case Some { targetArgument } ->
        match source[0] with
        case None -> false
        case Some { sourceArgument } -> type_assignable(targetArgument, sourceArgument) & type_arguments_assignable(target[1:], source[1:])

private fun ordinary_call_arguments_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression _ -> false
        case _ -> expression_emittable(expression, env, module, allModules) & ordinary_call_arguments_emittable(expressions[1:], env, module, allModules)

private fun java_callable_name(name: String): bool =
    !(name ? "/") & !(name ? ".") & !(name ? "`")

private fun java_method_supported(name: String): bool =
    name == "is_equal_to" | name == "is_true" | name == "is_false"
        | name == "is_greater_than" | name == "is_less_than"
        | name == "is_greater_or_equals_than" | name == "is_less_or_equals_than"
        | name == "starts_with" | name == "does_not_start_with" | name == "contains"
        | name == "replace" | name == "size"

private fun java_type(type: CompiledTypeReference): String =
    if type.name == "byte" then "byte"
    else if type.name == "int" then "int"
    else if type.name == "long" then "long"
    else if type.name == "float" then "float"
    else if type.name == "double" then "double"
    else if type.name == "bool" then "boolean"
    else boxed_java_type(type)

private fun boxed_java_type(type: CompiledTypeReference): String =
    if type.name == "byte" then "java.lang.Byte"
    else if type.name == "int" then "java.lang.Integer"
    else if type.name == "long" then "java.lang.Long"
    else if type.name == "float" then "java.lang.Float"
    else if type.name == "double" then "java.lang.Double"
    else if type.name == "bool" then "java.lang.Boolean"
    else if type.name == "String" then "java.lang.String"
    else if type.name == "List" then "java.util.List<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Set" then "java.util.Set<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Dict" then "java.util.Map<java.lang.String, " + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Tuple" then "java.util.List<?>"
    else if type.name == "Effect" then "capy.lang.Effect<" + generic_argument_java_type(first_type_argument(type)) + ">"
    else if type.name == "Assert" then "capy.test.Assert"
    else if type.name == "TestFile" then "capy.test.CapyTest.TestFile"
    else if type.name == "TestCase" then "capy.test.CapyTest.TestCase"
    else if type.name == "Supplier" then "java.util.function.Supplier<" + boxed_java_type(first_type_argument(type)) + ">"
    else "java.lang.Object"

private fun java_seq_type(type: CompiledTypeReference): String =
    "capy.lang.Seq<" + boxed_java_type(first_type_argument(type)) + ">"

private fun first_type_argument(type: CompiledTypeReference): CompiledTypeReference =
    match type.arguments[0] with
    case None -> object_type()
    case Some { argument } -> argument

private fun generic_argument_java_type(type: CompiledTypeReference): String =
    if type_parameter(type) then "?" else boxed_java_type(type)

private fun type_parameter(type: CompiledTypeReference): bool =
    type.arguments.is_empty() & type.name.size().value == 1 & single_uppercase_name(type.name)

private fun single_uppercase_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

private fun int_type(): CompiledTypeReference = CompiledTypeReference { name: "int", arguments: [] }
private fun byte_type(): CompiledTypeReference = CompiledTypeReference { name: "byte", arguments: [] }
private fun long_type(): CompiledTypeReference = CompiledTypeReference { name: "long", arguments: [] }
private fun float_type(): CompiledTypeReference = CompiledTypeReference { name: "float", arguments: [] }
private fun double_type(): CompiledTypeReference = CompiledTypeReference { name: "double", arguments: [] }
private fun bool_type(): CompiledTypeReference = CompiledTypeReference { name: "bool", arguments: [] }
private fun string_type(): CompiledTypeReference = CompiledTypeReference { name: "String", arguments: [] }
private fun nothing_type(): CompiledTypeReference = CompiledTypeReference { name: "nothing", arguments: [] }
private fun object_type(): CompiledTypeReference = CompiledTypeReference { name: "any", arguments: [] }
private fun assert_type(): CompiledTypeReference = CompiledTypeReference { name: "Assert", arguments: [] }
private fun test_file_type(): CompiledTypeReference = CompiledTypeReference { name: "TestFile", arguments: [] }
private fun test_case_type(): CompiledTypeReference = CompiledTypeReference { name: "TestCase", arguments: [] }
private fun list_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "List", arguments: [arg] }
private fun set_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Set", arguments: [arg] }
private fun dict_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Dict", arguments: [arg] }
private fun tuple_type(args: List[CompiledTypeReference]): CompiledTypeReference = CompiledTypeReference { name: "Tuple", arguments: args }
private fun seq_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Seq", arguments: [arg] }
private fun effect_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Effect", arguments: [arg] }
private fun supplier_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Supplier", arguments: [arg] }

private fun test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    let gather = test_gather_calls(modules, modules)
    if gather.is_empty()
    then []
    else [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.java",
        code: "package capy.test;" + newline() + newline()
            + "public final class CapyTestRuntime {" + newline()
            + "    private CapyTestRuntime() " + "{" + "}" + newline() + newline()
            + "    public static java.util.List<CapyTest.TestFile> gatherTests() {" + newline()
            + "        return java.util.List.of(" + gather + ");" + newline()
            + "    }" + newline()
            + "}" + newline()
    }]

private fun test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        let calls = test_gather_calls_for_module(module.functions, module, allModules)
        let rest = test_gather_calls(modules[1:], allModules)
        join_non_empty(calls, rest)

private fun test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        let env = parameter_bindings(function.parameters) + constant_bindings(constant_functions(module.functions))
        let current =
            if function.name == "tests" & expression_emittable(function.body, env, module, allModules)
            then module_fqcn(module) + ".tests().unsafeRun()"
            else ""
        join_non_empty(current, test_gather_calls_for_module(functions[1:], module, allModules))

private fun join_non_empty(first: String, second: String): String =
    if first.is_empty() then second
    else if second.is_empty() then first
    else first + ", " + second

private fun module_fqcn(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path.replace("/", ".") + "." + module.name

private fun module_source_file(module: CompiledModule): String =
    if module.path.is_empty()
    then "/" + module.name + ".cfun"
    else "/" + module.path + "/" + module.name + ".cfun"

private fun java_helpers(module: CompiledModule): String =
    if module.functions.is_empty()
    then ""
    else "    private static int __capy_pow_int(int base, int exponent) {" + newline()
        + "        if (exponent <= 0) {" + newline()
        + "            return 1;" + newline()
        + "        }" + newline()
        + "        int result = 1;" + newline()
        + "        for (int i = 0; i < exponent; i++) {" + newline()
        + "            result *= base;" + newline()
        + "        }" + newline()
        + "        return result;" + newline()
        + "    }" + newline() + newline()
        + "    private static long __capy_pow_long(long base, long exponent) {" + newline()
        + "        if (exponent <= 0L) {" + newline()
        + "            return 1L;" + newline()
        + "        }" + newline()
        + "        long result = 1L;" + newline()
        + "        for (long i = 0L; i < exponent; i++) {" + newline()
        + "            result *= base;" + newline()
        + "        }" + newline()
        + "        return result;" + newline()
        + "    }" + newline() + newline()
        + "    private static <T> T unsupported(String source) {" + newline()
        + "        throw new UnsupportedOperationException(\"Unsupported CFUN expression: \" + source);" + newline()
        + "    }" + newline() + newline()
        + "    private static <T> T __capy_not_implemented(String message) {" + newline()
        + "        throw new UnsupportedOperationException(message);" + newline()
        + "    }" + newline() + newline()
        + "    private static java.util.Map<java.lang.String, java.lang.Object> __capy_data(java.lang.String type, java.util.Map<java.lang.String, ?> fields) {" + newline()
        + "        java.util.Map<java.lang.String, java.lang.Object> result = new java.util.LinkedHashMap<>();" + newline()
        + "        result.put(\"__type\", type);" + newline()
        + "        result.putAll(fields);" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    private static boolean __capy_data_is(java.lang.Object value, java.lang.String type) {" + newline()
        + "        return value instanceof java.util.Map<?, ?> map && type.equals(map.get(\"__type\"));" + newline()
        + "    }" + newline() + newline()
        + "    @SuppressWarnings(\"unchecked\")" + newline()
        + "    private static <T> T __capy_data_field(java.lang.Object value, java.lang.String field) {" + newline()
        + "        return (T) ((java.util.Map<java.lang.String, java.lang.Object>) value).get(field);" + newline()
        + "    }" + newline() + newline()
        + "    private static boolean __capy_truthy(java.lang.Object value) {" + newline()
        + "        if (value == null) {" + newline()
        + "            return false;" + newline()
        + "        }" + newline()
        + "        if (value instanceof java.lang.Boolean bool) {" + newline()
        + "            return bool;" + newline()
        + "        }" + newline()
        + "        if (value instanceof java.lang.Number number) {" + newline()
        + "            return number.doubleValue() != 0.0d;" + newline()
        + "        }" + newline()
        + "        if (value instanceof java.lang.CharSequence chars) {" + newline()
        + "            return !chars.isEmpty();" + newline()
        + "        }" + newline()
        + "        if (value instanceof java.util.Collection<?> collection) {" + newline()
        + "            return !collection.isEmpty();" + newline()
        + "        }" + newline()
        + "        if (value instanceof java.util.Map<?, ?> map) {" + newline()
        + "            return !map.isEmpty();" + newline()
        + "        }" + newline()
        + "        return true;" + newline()
        + "    }" + newline()

private fun java_package(module: CompiledModule): String =
    if module.path.is_empty()
    then ""
    else "package " + module.path.replace("/", ".") + ";" + newline() + newline()

private fun java_module_relative_path(module: CompiledModule, extension: String): String =
    if module.path.is_empty()
    then module.name + extension
    else module.path + "/" + module.name + extension

private fun java_identifier(name: String): String =
    let sanitized = java_identifier_chars(name, 0, "")
    let nonEmpty = if sanitized.is_empty() then "_" else sanitized
    let started = java_identifier_with_start(nonEmpty)
    if java_reserved_word(started) then "_" + started else started

private fun java_identifier_with_start(name: String): String =
    match name[0] with
    case None -> "_"
    case Some { char } -> if java_identifier_start_char(char) then name else "_" + name

private fun java_identifier_chars(name: String, idx: int, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            let next = if java_identifier_part_char(char) then char else "_"
            java_identifier_chars(name, idx + 1, acc + next)

private fun java_identifier_start_char(char: String): bool =
    JAVA_IDENTIFIER_START ? char

private fun java_identifier_part_char(char: String): bool =
    JAVA_IDENTIFIER_PART ? char

private fun java_reserved_word(name: String): bool =
    JAVA_RESERVED_WORDS ? ("|" + name + "|")

private fun java_method_name(name: String): String =
    if name == "is_equal_to" then "isEqualTo"
    else if name == "is_true" then "isTrue"
    else if name == "is_false" then "isFalse"
    else if name == "is_greater_than" then "isGreaterThan"
    else if name == "is_less_than" then "isLessThan"
    else if name == "is_greater_or_equals_than" then "isGreaterOrEqualsThan"
    else if name == "is_less_or_equals_than" then "isLessOrEqualsThan"
    else if name == "starts_with" then "startsWith"
    else if name == "does_not_start_with" then "doesNotStartWith"
    else if name == "as_list" then "asList"
    else java_identifier(name)

private fun java_identifier_list(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some { value } -> java_identifier(value) + java_identifier_list_tail(values[1:])

private fun java_identifier_list_tail(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some { value } -> ", " + java_identifier(value) + java_identifier_list_tail(values[1:])

private fun newline(): String = '\n'

private fun escape_java_string(value: String): String =
    value
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace('\n', '\\n')
        .replace('\r', '\\r')
        .replace('\t', '\\t')
