from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledProgram import { CompiledModule, CompiledProgram }
from /dev/capylang/generator/GeneratedProgram import { GeneratedModule, GeneratedProgram }

fun java_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: java_modules(program.modules)
    }

private fun java_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: module_relative_path(module, ".java"),
        code: java_module_code(module)
    }] + java_modules(modules[1:])

private fun java_module_code(module: CompiledModule): String =
    java_package(module)
    + "public final class " + module.name + " {\n"
    + "    private " + module.name + "() {}\n"
    + "}\n"

private fun java_package(module: CompiledModule): String =
    if module.path.is_empty()
    then ""
    else "package " + module.path.replace("/", ".") + ";\n\n"

private fun module_relative_path(module: CompiledModule, extension: String): String =
    if module.path.is_empty()
    then module.name + extension
    else module.path + "/" + module.name + extension
