/// Java generator name binding from a Capybara symbol to its resolved type and Java identifier.
data JavaBinding { name: String, typeReference: CompiledTypeReference, javaName: String }
/// Java generator binding that pairs a declaring module with a compiled object class.
data JavaObjectClassBinding { moduleClassName: String, module: CompiledModule, objectClass: CompiledObjectOrientedClass }
/// Java generator binding that pairs a declaring module with a compiled object interface.
data JavaObjectInterfaceBinding { moduleClassName: String, module: CompiledModule, objectInterface: CompiledObjectOrientedInterface }
/// Java generator binding for an object field and the generated module class that owns it.
data JavaObjectFieldBinding { moduleClassName: String, objectClass: CompiledObjectOrientedClass, field: CompiledObjectOrientedField }
/// Java generator binding for an object method and the generated module class that owns it.
data JavaObjectMethodBinding { moduleClassName: String, objectClass: CompiledObjectOrientedClass, method: CompiledObjectOrientedMethod }
/// Resolved Java object method lookup result with receiver type and compiled method metadata.
data JavaResolvedObjectMethod { receiverType: CompiledTypeReference, method: CompiledObjectOrientedMethod }
/// Java generator lookup entry for a data type and the compiled module that declares it.
data JavaDataTypeBinding { module: CompiledModule, name: String }
/// Java generator lookup entry for a qualified function and the compiled module that declares it.
data JavaQualifiedFunctionBinding { module: CompiledModule, function: CompiledFunction }
/// Precomputed Java function-name request metadata reused across function scans.
data JavaFunctionNameRequest { name: String, hasUppercase: bool }
/// Java generator mapping from a standard-library value to its Java name and resolved type.
data JavaStdlibValue { javaName: String, typeReference: CompiledTypeReference }
/// Java object metadata extracted from schema helper functions for one module.
data JavaCompiledObjects { interfaces: List[CompiledObjectOrientedInterface], classes: List[CompiledObjectOrientedClass] }
/// Java object-oriented metadata indexed by compiled module path.
data JavaObjectOrientedUnitIndex { units: Dict[CompiledObjectOrientedUnit] }
/// Native-provider declarations for a single Java generated module, indexed by provider function name.
data JavaNativeProviderDeclarations { declarations: Dict[CompiledNativeProviderDeclaration] }
/// Java native-provider declarations and bindings indexed for generator lookups.
data JavaNativeProviderIndex { declarationsByModule: Dict[JavaNativeProviderDeclarations], bindings: Dict[CompiledNativeProviderBinding] }
/// Java native-provider lookup scope for one generated module.
data JavaNativeProviderScope { declarations: Dict[CompiledNativeProviderDeclaration], bindings: Dict[CompiledNativeProviderBinding] }
/// Java generated modules split to preserve top-level interface files before module classes.
data JavaGeneratedModules { objectInterfaceModules: List[GeneratedModule], javaModules: List[GeneratedModule] }
/// Generator lookup entry for an annotation declaration and the compiled module that declares it.
data AnnotationBinding { declaration: CompiledAnnotationDeclaration, module: CompiledModule }
/// Decoded annotation schema argument with field name, value kind, and encoded source value.
data SchemaAnnotationArgument { name: String, kind: String, value: String }
/// Schema annotation values grouped under one object reflection metadata key.
data JavaObjectAnnotationValues { values: List[String] }
/// Object reflection annotation schema values collected in one pass for a class or interface.
data JavaObjectAnnotationSources { typeAnnotations: List[String], fieldAnnotations: Dict[JavaObjectAnnotationValues], methodAnnotations: Dict[JavaObjectAnnotationValues] }
/// Schema lookup result that distinguishes a type with no values from a missing type.
data JavaSchemaValues { typeExists: bool, values: List[String] }
/// Decoded object field schema metadata used while rebuilding object classes and reflection metadata.
data JavaObjectFieldSchema { name: String, visibility: String, typeName: String, hasValue: bool }
/// Object field schemas and initializer helpers collected in one class scan.
data JavaObjectFieldSources { schemas: List[CompiledFunction], initializers: List[CompiledFunction] }
/// Object class schema helpers collected in one class scan.
data JavaObjectClassSources {
    openValue: String,
    parameters: List[CompiledFunction],
    parents: List[String],
    fieldSchemas: List[CompiledFunction],
    fieldInitializers: List[CompiledFunction],
    initBlocks: List[CompiledFunction],
    methods: List[CompiledFunction]
}

const JAVA_IDENTIFIER_START = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_"
const JAVA_IDENTIFIER_PART = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
const JAVA_RESERVED_WORDS = "|abstract|assert|boolean|break|byte|case|catch|char|class|const|continue|default|do|double|else|enum|extends|final|finally|float|for|goto|if|implements|import|instanceof|int|interface|long|native|new|package|private|protected|public|return|short|static|strictfp|super|switch|synchronized|this|throw|throws|transient|try|void|volatile|while|true|false|null|var|record|yield|sealed|permits|_|"
const JAVA_OBJECT_TYPE_PREFIX = "__capy_oo|"
const OO_INTERFACE_SCHEMA_PREFIX = "__capy_oo_interface|"
const OO_INTERFACE_METHOD_FUNCTION_PREFIX = "__capy_oo_interface_method|"
const OO_CLASS_SCHEMA_PREFIX = "__capy_oo_class|"
const OO_CLASS_PARAMETER_SCHEMA_PREFIX = "__capy_oo_param|"
const OO_FIELD_SCHEMA_PREFIX = "__capy_oo_field|"
const OO_FIELD_INIT_FUNCTION_PREFIX = "__capy_oo_field_init|"
const OO_INIT_FUNCTION_PREFIX = "__capy_oo_init|"
const OO_METHOD_FUNCTION_PREFIX = "__capy_oo_method|"

/// Returns the length of the encoded Java object-type marker prefix.
private fun java_object_type_prefix_size(): int =
    "__capy_oo|".size().value

/// Checks whether a compiled type name can resolve to object-oriented metadata.
private fun java_object_receiver_type(typeName: String): bool =
    java_generator_string_has_prefix(typeName, JAVA_OBJECT_TYPE_PREFIX)

/// Returns the length of the encoded object-interface schema prefix.
private fun oo_interface_schema_prefix_size(): int =
    "__capy_oo_interface|".size().value

/// Returns the length of the encoded object-interface method schema prefix.
private fun oo_interface_method_function_prefix_size(): int =
    "__capy_oo_interface_method|".size().value

/// Returns the length of the encoded object-class schema prefix.
private fun oo_class_schema_prefix_size(): int =
    "__capy_oo_class|".size().value

/// Returns the length of the encoded object initializer function prefix.
private fun oo_init_function_prefix_size(): int =
    "__capy_oo_init|".size().value

/// Returns the length of the encoded object method function prefix.
private fun oo_method_function_prefix_size(): int =
    "__capy_oo_method|".size().value

/// Generates Java source modules, object interface files, and test runtime modules from a compiled program.
fun java_generator(program: CompiledProgram): GeneratedProgram =
    let objectOrientedUnitIndex = java_object_oriented_unit_index(program.objectOrientedModules)
    let nativeProviderIndex = java_native_provider_index(program.nativeProviderCatalog)
    let generated = java_generated_modules(program.modules, program.modules, objectOrientedUnitIndex, nativeProviderIndex)
    GeneratedProgram {
        modules: generated.objectInterfaceModules
            + generated.javaModules
            + test_runtime_modules(program.modules)
    }

/// Creates Java object interface and module source entries while decoding object schemas once per module.
private fun java_generated_modules(modules: List[CompiledModule], allModules: List[CompiledModule], objectOrientedUnitIndex: JavaObjectOrientedUnitIndex, nativeProviderIndex: JavaNativeProviderIndex): JavaGeneratedModules =
    match modules[0] with
    case None -> JavaGeneratedModules { objectInterfaceModules: [], javaModules: [] }
    case Some { module } ->
        let objects = java_compiled_objects_for_module(module, objectOrientedUnitIndex)
        let rest = java_generated_modules(modules[1:], allModules, objectOrientedUnitIndex, nativeProviderIndex)
        JavaGeneratedModules {
            objectInterfaceModules: java_object_interface_modules_for_module(objects.interfaces, module, allModules)
                + rest.objectInterfaceModules,
            javaModules: [GeneratedModule {
                relativePath: java_module_relative_path(module, ".java"),
                code: java_module_code_with_objects(module, allModules, nativeProviderIndex, objects)
            }] + rest.javaModules
        }

/// Returns object metadata carried by linked programs, falling back to schema decoding for legacy module-only linked input.
private fun java_compiled_objects_for_module(module: CompiledModule, objectOrientedUnitIndex: JavaObjectOrientedUnitIndex): JavaCompiledObjects =
    if objectOrientedUnitIndex.units.is_empty()
    then compiled_objects(module.functions)
    else match objectOrientedUnitIndex.units.get(java_compiled_module_key(module.name, module.path)) with
        case Some { unit } -> JavaCompiledObjects { interfaces: unit.interfaces, classes: unit.classes }
        case None -> JavaCompiledObjects { interfaces: [], classes: [] }

/// Builds object-oriented metadata lookup by compiled module path.
private fun java_object_oriented_unit_index(objectOrientedModules: List[CompiledObjectOrientedUnit]): JavaObjectOrientedUnitIndex =
    JavaObjectOrientedUnitIndex { units: java_object_oriented_unit_dict(objectOrientedModules) }

/// Builds object-oriented metadata dictionary while preserving first-match lookup semantics.
private fun java_object_oriented_unit_dict(objectOrientedModules: List[CompiledObjectOrientedUnit]): Dict[CompiledObjectOrientedUnit] =
    java_object_oriented_unit_dict_with_acc(objectOrientedModules, {:})

/// Builds object-oriented metadata dictionary using a forward accumulator.
private fun java_object_oriented_unit_dict_with_acc(objectOrientedModules: List[CompiledObjectOrientedUnit], units: Dict[CompiledObjectOrientedUnit]): Dict[CompiledObjectOrientedUnit] =
    match objectOrientedModules[0] with
    case None -> units
    case Some { unit } ->
        java_object_oriented_unit_dict_with_acc(objectOrientedModules[1:], java_object_oriented_unit_dict_add(units, unit))

/// Adds an object-oriented metadata unit unless an earlier unit already owns the key.
private fun java_object_oriented_unit_dict_add(units: Dict[CompiledObjectOrientedUnit], unit: CompiledObjectOrientedUnit): Dict[CompiledObjectOrientedUnit] =
    let key = java_compiled_module_key(unit.name, unit.path)
    match units.get(key) with
    case Some _ -> units
    case None -> units + (key, unit)

/// Builds the lookup key for compiled module metadata.
private fun java_compiled_module_key(name: String, path: String): String =
    if path.is_empty()
    then name
    else path + "/" + name

/// Emits the complete Java class source for one compiled module.
private fun java_module_code_with_objects(module: CompiledModule, allModules: List[CompiledModule], nativeProviderIndex: JavaNativeProviderIndex, objects: JavaCompiledObjects): String =
    if module.path == "capy/lang" & module.name == "Effect"
    then java_effect_module_code(module)
    else if module.path == "capy/lang" & module.name == "Async"
    then java_async_module_code(module)
    else if module.path == "capy/collection" & module.name == "Seq"
    then java_seq_module_code(module)
    else if module.path == "capy/lang" & module.name == "System"
    then java_system_module_code(module)
    else
    let constants = constant_functions(module.functions)
    let constantBindings = constant_bindings(constants, module, allModules)
    let nativeProviderScope = java_native_provider_scope_for_module(module, nativeProviderIndex)
    java_package(module)
    + java_imports(module, allModules)
    + "public final class " + module.name + " {" + newline()
    + "    private " + module.name + "() " + "{" + "}" + newline() + newline()
    + java_function_type_interfaces()
    + java_data_types(schema_values("__capy_schema_type|", module.functions), module, allModules)
    + java_object_interfaces(objects.interfaces, module, allModules)
    + java_object_classes(objects.classes, constantBindings, module, allModules)
    + java_constants(constants, module, allModules)
    + java_functions(module.functions, constantBindings, module, allModules, nativeProviderScope)
    + java_helpers(module)
    + "}" + newline()

private fun java_effect_module_code(module: CompiledModule): String =
    java_package(module)
    + "import java.util.function.*;" + newline() + newline()
    + "public final class Effect<T> {" + newline()
    + "    private final Supplier<T> unsafeThunk;" + newline() + newline()
    + "    private Effect(Supplier<T> unsafeThunk) {" + newline()
    + "        this.unsafeThunk = unsafeThunk;" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> Effect<T> pure(T value) {" + newline()
    + "        return new Effect<>(() -> value);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> Effect<T> delay(Supplier<T> thunk) {" + newline()
    + "        return new Effect<>(thunk);" + newline()
    + "    }" + newline() + newline()
    + "    public T unsafeRun() {" + newline()
    + "        return unsafeThunk.get();" + newline()
    + "    }" + newline() + newline()
    + "    public <Y> Effect<Y> map(Function<? super T, ? extends Y> map) {" + newline()
    + "        return delay(() -> map.apply(unsafeRun()));" + newline()
    + "    }" + newline() + newline()
    + "    public <Y> Effect<Y> flatMap(Function<? super T, Effect<Y>> flatmap) {" + newline()
    + "        return delay(() -> flatmap.apply(unsafeRun()).unsafeRun());" + newline()
    + "    }" + newline() + newline()
    + "    public capy.lang.Async<T> start() {" + newline()
    + "        return capy.lang.Async.start(this);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> Effect<T> pure__5_0(T value) {" + newline()
    + "        return pure(value);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> Effect<T> delay__8_0(Supplier<T> thunk) {" + newline()
    + "        return delay(thunk);" + newline()
    + "    }" + newline() + newline()
    + "    private static <T> T _run__11_0(Effect<T> effect) {" + newline()
    + "        return effect.unsafeRun();" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> T Effect_T__unsafe_run__15_0(Effect<T> effect) {" + newline()
    + "        return effect.unsafeRun();" + newline()
    + "    }" + newline() + newline()
    + "    public static <T, Y> Effect<Y> Effect_T__map__18_0(Effect<T> effect, Function<? super T, ? extends Y> map) {" + newline()
    + "        return effect.map(map);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T, Y> Effect<Y> Effect_T__flat_map__21_0(Effect<T> effect, Function<? super T, Effect<Y>> flatmap) {" + newline()
    + "        return effect.flatMap(flatmap);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T, Y> Effect<Y> Effect_T_______24_0(Effect<T> effect, Function<? super T, ? extends Y> map) {" + newline()
    + "        return effect.map(map);" + newline()
    + "    }" + newline() + newline()
    + "    public static <T, Y> Effect<Y> Effect_T________27_0(Effect<T> effect, Function<? super T, Effect<Y>> flatmap) {" + newline()
    + "        return effect.flatMap(flatmap);" + newline()
    + "    }" + newline()
    + "}" + newline()

private fun java_async_module_code(module: CompiledModule): String =
    java_package(module)
    + "import java.util.concurrent.*;" + newline()
    + "import java.util.function.*;" + newline() + newline()
    + "public final class Async<T> {" + newline()
    + "    private static final ExecutorService EXECUTOR = Executors.newCachedThreadPool(r -> {" + newline()
    + "        Thread thread = new Thread(r, \"capy-async\");" + newline()
    + "        thread.setDaemon(true);" + newline()
    + "        return thread;" + newline()
    + "    });" + newline() + newline()
    + "    private static final class ResultFailure extends RuntimeException {" + newline()
    + "        private final java.lang.Object error;" + newline() + newline()
    + "        private ResultFailure(java.lang.Object error) {" + newline()
    + "            super(\"Async.flat_map returned Error\");" + newline()
    + "            this.error = error;" + newline()
    + "        }" + newline()
    + "    }" + newline() + newline()
    + "    private final CompletableFuture<T> future;" + newline() + newline()
    + "    private Async(CompletableFuture<T> future) {" + newline()
    + "        this.future = future;" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> Async<T> start(capy.lang.Effect<T> effect) {" + newline()
    + "        return new Async<>(CompletableFuture.supplyAsync(effect::unsafeRun, EXECUTOR));" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> capy.lang.Effect<java.util.List<java.lang.Object>> all(java.util.List<Async<T>> tasks) {" + newline()
    + "        return capy.lang.Effect.delay(() -> tasks.stream().map(task -> task.joinedResult()).toList());" + newline()
    + "    }" + newline() + newline()
    + "    public static <T> capy.lang.Effect<java.lang.Object> any(java.util.List<Async<T>> tasks) {" + newline()
    + "        return capy.lang.Effect.delay(() -> {" + newline()
    + "            if (tasks.isEmpty()) {" + newline()
    + "                return error(\"capy.lang.async.empty\", \"Async.any requires at least one task\");" + newline()
    + "            }" + newline()
    + "            CompletableFuture<?>[] futures = tasks.stream().map(task -> task.future).toArray(CompletableFuture[]::new);" + newline()
    + "            try {" + newline()
    + "                CompletableFuture.anyOf(futures).handle((value, error) -> null).get();" + newline()
    + "            } catch (InterruptedException e) {" + newline()
    + "                Thread.currentThread().interrupt();" + newline()
    + "                return error(\"capy.lang.async.failed\", safeMessage(e), e);" + newline()
    + "            } catch (ExecutionException e) {" + newline()
    + "                return error(\"capy.lang.async.failed\", safeMessage(unwrap(e)), unwrap(e));" + newline()
    + "            }" + newline()
    + "            for (Async<T> task : tasks) {" + newline()
    + "                if (task.future.isDone()) {" + newline()
    + "                    return task.joinedResult();" + newline()
    + "                }" + newline()
    + "            }" + newline()
    + "            return tasks.get(0).joinedResult();" + newline()
    + "        });" + newline()
    + "    }" + newline() + newline()
    + "    public <Y> Async<Y> map(Function<? super T, ? extends Y> map) {" + newline()
    + "        return new Async<>(future.thenApplyAsync(map, EXECUTOR));" + newline()
    + "    }" + newline() + newline()
    + "    @SuppressWarnings(\"unchecked\")" + newline()
    + "    public <Y> Async<Y> flatMap(Function<? super T, ?> flatmap) {" + newline()
    + "        return new Async<>(future.thenApplyAsync(value -> {" + newline()
    + "            java.lang.Object result = flatmap.apply(value);" + newline()
    + "            if (isError(result)) {" + newline()
    + "                throw new ResultFailure(result);" + newline()
    + "            }" + newline()
    + "            if (isSuccess(result)) {" + newline()
    + "                return (Y) successValue(result);" + newline()
    + "            }" + newline()
    + "            throw new ResultFailure(error(\"capy.lang.argument.invalid\", \"Async.flat_map expected Result value\"));" + newline()
    + "        }, EXECUTOR));" + newline()
    + "    }" + newline() + newline()
    + "    public capy.lang.Effect<java.lang.Object> join() {" + newline()
    + "        return capy.lang.Effect.delay(this::joinedResult);" + newline()
    + "    }" + newline() + newline()
    + "    private java.lang.Object joinedResult() {" + newline()
    + "            try {" + newline()
    + "                return success(future.get());" + newline()
    + "            } catch (InterruptedException e) {" + newline()
    + "                Thread.currentThread().interrupt();" + newline()
    + "                return error(\"capy.lang.async.failed\", safeMessage(e), e);" + newline()
    + "            } catch (ExecutionException e) {" + newline()
    + "                Throwable cause = unwrap(e);" + newline()
    + "                if (cause instanceof ResultFailure resultFailure) {" + newline()
    + "                    return resultFailure.error;" + newline()
    + "                }" + newline()
    + "                return error(\"capy.lang.async.failed\", safeMessage(cause), cause);" + newline()
    + "            }" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object success(java.lang.Object value) {" + newline()
    + "        java.util.LinkedHashMap<java.lang.String, java.lang.Object> result = new java.util.LinkedHashMap<>();" + newline()
    + "        result.put(\"__type\", \"Success\");" + newline()
    + "        result.put(\"value\", value);" + newline()
    + "        return result;" + newline()
    + "    }" + newline() + newline()
    + "    private static boolean isSuccess(java.lang.Object value) {" + newline()
    + "        return resultType(value, \"Success\");" + newline()
    + "    }" + newline() + newline()
    + "    private static boolean isError(java.lang.Object value) {" + newline()
    + "        return resultType(value, \"Error\");" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object successValue(java.lang.Object value) {" + newline()
    + "        if (value instanceof java.util.Map<?, ?> map) {" + newline()
    + "            return map.get(\"value\");" + newline()
    + "        }" + newline()
    + "        return null;" + newline()
    + "    }" + newline() + newline()
    + "    private static boolean resultType(java.lang.Object value, java.lang.String typeName) {" + newline()
    + "        if (!(value instanceof java.util.Map<?, ?> map)) {" + newline()
    + "            return false;" + newline()
    + "        }" + newline()
    + "        java.lang.Object type = map.get(\"__type\");" + newline()
    + "        if (type == null) {" + newline()
    + "            return false;" + newline()
    + "        }" + newline()
    + "        java.lang.String actual = java.lang.String.valueOf(type);" + newline()
    + "        return actual.equals(typeName) || actual.endsWith(\".\" + typeName);" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object error(java.lang.String kind, java.lang.String message) {" + newline()
    + "        return errorFull(kind, message, java.util.Optional.empty(), java.util.Optional.empty(), java.util.List.of(), java.util.Optional.empty(), java.util.Optional.empty(), java.util.List.of());" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object error(java.lang.String kind, java.lang.String message, java.lang.Throwable throwable) {" + newline()
    + "        java.util.List<java.lang.Object> stackTrace = stackTrace(throwable);" + newline()
    + "        return errorFull(kind, message, java.util.Optional.empty(), sourceLocation(stackTrace), stackTrace, java.util.Optional.of(rawStack(throwable)), cause(throwable), suppressed(throwable));" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object errorFull(" + newline()
    + "            java.lang.String kind," + newline()
    + "            java.lang.String message," + newline()
    + "            java.util.Optional<java.lang.Object> details," + newline()
    + "            java.util.Optional<java.lang.Object> location," + newline()
    + "            java.util.List<java.lang.Object> stackTrace," + newline()
    + "            java.util.Optional<java.lang.String> rawStack," + newline()
    + "            java.util.Optional<java.lang.Object> cause," + newline()
    + "            java.util.List<java.lang.Object> suppressed" + newline()
    + "    ) {" + newline()
    + "        return java.util.Map.ofEntries(" + newline()
    + "                java.util.Map.entry(\"__type\", \"Error\")," + newline()
    + "                java.util.Map.entry(\"kind\", kind)," + newline()
    + "                java.util.Map.entry(\"message\", message)," + newline()
    + "                java.util.Map.entry(\"details\", details)," + newline()
    + "                java.util.Map.entry(\"location\", location)," + newline()
    + "                java.util.Map.entry(\"stack_trace\", stackTrace)," + newline()
    + "                java.util.Map.entry(\"raw_stack\", rawStack)," + newline()
    + "                java.util.Map.entry(\"cause\", cause)," + newline()
    + "                java.util.Map.entry(\"suppressed\", suppressed)" + newline()
    + "        );" + newline()
    + "    }" + newline() + newline()
    + "    private static java.util.List<java.lang.Object> stackTrace(java.lang.Throwable throwable) {" + newline()
    + "        java.util.ArrayList<java.lang.Object> frames = new java.util.ArrayList<>();" + newline()
    + "        for (java.lang.StackTraceElement element : throwable.getStackTrace()) {" + newline()
    + "            frames.add(stackFrame(element));" + newline()
    + "        }" + newline()
    + "        return java.util.List.copyOf(frames);" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.Object stackFrame(java.lang.StackTraceElement element) {" + newline()
    + "        return java.util.Map.ofEntries(" + newline()
    + "                java.util.Map.entry(\"__type\", \"StackFrame\")," + newline()
    + "                java.util.Map.entry(\"backend\", \"java\")," + newline()
    + "                java.util.Map.entry(\"module\", java.util.Optional.ofNullable(element.getModuleName()))," + newline()
    + "                java.util.Map.entry(\"type_name\", java.util.Optional.ofNullable(element.getClassName()))," + newline()
    + "                java.util.Map.entry(\"function\", java.util.Optional.ofNullable(element.getMethodName()))," + newline()
    + "                java.util.Map.entry(\"file\", java.util.Optional.ofNullable(element.getFileName()))," + newline()
    + "                java.util.Map.entry(\"line\", element.getLineNumber() >= 0 ? java.util.Optional.of(element.getLineNumber()) : java.util.Optional.empty())," + newline()
    + "                java.util.Map.entry(\"column\", java.util.Optional.empty())," + newline()
    + "                java.util.Map.entry(\"end_line\", java.util.Optional.empty())," + newline()
    + "                java.util.Map.entry(\"end_column\", java.util.Optional.empty())," + newline()
    + "                java.util.Map.entry(\"source_line\", java.util.Optional.empty())," + newline()
    + "                java.util.Map.entry(\"native\", element.isNativeMethod())," + newline()
    + "                java.util.Map.entry(\"raw\", element.toString())" + newline()
    + "        );" + newline()
    + "    }" + newline() + newline()
    + "    private static java.util.Optional<java.lang.Object> sourceLocation(java.util.List<java.lang.Object> stackTrace) {" + newline()
    + "        for (java.lang.Object frame : stackTrace) {" + newline()
    + "            if (frame instanceof java.util.Map<?, ?> map && map.get(\"file\") instanceof java.util.Optional<?> file && file.isPresent()) {" + newline()
    + "                int line = map.get(\"line\") instanceof java.util.Optional<?> lineOption && lineOption.isPresent() ? (java.lang.Integer) lineOption.get() : 0;" + newline()
    + "                return java.util.Optional.of(java.util.Map.ofEntries(" + newline()
    + "                        java.util.Map.entry(\"__type\", \"SourceLocation\")," + newline()
    + "                        java.util.Map.entry(\"file\", java.lang.String.valueOf(file.get()))," + newline()
    + "                        java.util.Map.entry(\"line\", line)," + newline()
    + "                        java.util.Map.entry(\"column\", java.util.Optional.empty())," + newline()
    + "                        java.util.Map.entry(\"end_line\", java.util.Optional.empty())," + newline()
    + "                        java.util.Map.entry(\"end_column\", java.util.Optional.empty())" + newline()
    + "                ));" + newline()
    + "            }" + newline()
    + "        }" + newline()
    + "        return java.util.Optional.empty();" + newline()
    + "    }" + newline() + newline()
    + "    private static java.util.Optional<java.lang.Object> cause(java.lang.Throwable throwable) {" + newline()
    + "        java.lang.Throwable cause = throwable.getCause();" + newline()
    + "        if (cause == null || cause == throwable) {" + newline()
    + "            return java.util.Optional.empty();" + newline()
    + "        }" + newline()
    + "        return java.util.Optional.of(error(cause.getClass().getName(), safeMessage(cause), cause));" + newline()
    + "    }" + newline() + newline()
    + "    private static java.util.List<java.lang.Object> suppressed(java.lang.Throwable throwable) {" + newline()
    + "        java.util.ArrayList<java.lang.Object> suppressed = new java.util.ArrayList<>();" + newline()
    + "        for (java.lang.Throwable item : throwable.getSuppressed()) {" + newline()
    + "            suppressed.add(error(item.getClass().getName(), safeMessage(item), item));" + newline()
    + "        }" + newline()
    + "        return java.util.List.copyOf(suppressed);" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.String rawStack(java.lang.Throwable throwable) {" + newline()
    + "        java.io.StringWriter writer = new java.io.StringWriter();" + newline()
    + "        throwable.printStackTrace(new java.io.PrintWriter(writer));" + newline()
    + "        return writer.toString();" + newline()
    + "    }" + newline() + newline()
    + "    private static java.lang.String safeMessage(java.lang.Throwable throwable) {" + newline()
    + "        java.lang.String message = throwable.getMessage();" + newline()
    + "        return message == null || message.isBlank() ? throwable.getClass().getSimpleName() : message;" + newline()
    + "    }" + newline() + newline()
    + "    private static Throwable unwrap(Throwable throwable) {" + newline()
    + "        Throwable current = throwable;" + newline()
    + "        while ((current instanceof ExecutionException || current instanceof CompletionException) && current.getCause() != null) {" + newline()
    + "            current = current.getCause();" + newline()
    + "        }" + newline()
    + "        return current;" + newline()
    + "    }" + newline()
    + "}" + newline()

private fun java_seq_module_code(module: CompiledModule): String =
    java_package(module)
    + "import java.util.*;" + newline()
    + "import java.util.function.*;" + newline() + newline()
    + "public final class Seq<T> {" + newline()
    + "    private final java.util.List<T> values;" + newline() + newline()
    + "    private Seq(java.util.List<T> values) {" + newline()
    + "        this.values = java.util.List.copyOf(values);" + newline()
    + "    }" + newline() + newline()
    + "    @SuppressWarnings(\"unchecked\")" + newline()
    + "    public static <T> Seq<T> toSeq(java.lang.Object value) {" + newline()
    + "        if (value instanceof Seq<?> seq) {" + newline()
    + "            return (Seq<T>) seq;" + newline()
    + "        }" + newline()
    + "        if (value instanceof java.util.Map<?, ?> map) {" + newline()
    + "            return new Seq<>((java.util.List<T>) map.entrySet().stream()" + newline()
    + "                    .map(entry -> java.util.List.of(java.lang.String.valueOf(entry.getKey()), entry.getValue()))" + newline()
    + "                    .toList());" + newline()
    + "        }" + newline()
    + "        if (value instanceof java.lang.Iterable<?> iterable) {" + newline()
    + "            java.util.ArrayList<T> list = new java.util.ArrayList<>();" + newline()
    + "            for (java.lang.Object item : iterable) {" + newline()
    + "                list.add((T) item);" + newline()
    + "            }" + newline()
    + "            return new Seq<>(list);" + newline()
    + "        }" + newline()
    + "        if (value == null) {" + newline()
    + "            return new Seq<>(java.util.List.of());" + newline()
    + "        }" + newline()
    + "        return new Seq<>(java.util.List.of((T) value));" + newline()
    + "    }" + newline() + newline()
    + java_seq_to_seq_aliases(module.functions)
    + "    public java.util.List<T> asList() {" + newline()
    + "        return values;" + newline()
    + "    }" + newline() + newline()
    + "    public java.util.Optional<T> first() {" + newline()
    + "        return values.isEmpty() ? java.util.Optional.empty() : java.util.Optional.ofNullable(values.getFirst());" + newline()
    + "    }" + newline() + newline()
    + "    public <Y> Seq<Y> map(Function<? super T, ? extends Y> map) {" + newline()
    + "        java.util.ArrayList<Y> mapped = new java.util.ArrayList<>();" + newline()
    + "        for (T value : values) {" + newline()
    + "            mapped.add(map.apply(value));" + newline()
    + "        }" + newline()
    + "        return new Seq<>(mapped);" + newline()
    + "    }" + newline() + newline()
    + "    public <Y> Seq<Y> flatMap(Function<? super T, Seq<Y>> flatmap) {" + newline()
    + "        java.util.ArrayList<Y> mapped = new java.util.ArrayList<>();" + newline()
    + "        for (T value : values) {" + newline()
    + "            mapped.addAll(flatmap.apply(value).asList());" + newline()
    + "        }" + newline()
    + "        return new Seq<>(mapped);" + newline()
    + "    }" + newline() + newline()
    + "    public Seq<T> filter(Predicate<? super T> pred) {" + newline()
    + "        return new Seq<>(values.stream().filter(pred).toList());" + newline()
    + "    }" + newline() + newline()
    + "    public boolean any(Predicate<? super T> pred) {" + newline()
    + "        return values.stream().anyMatch(pred);" + newline()
    + "    }" + newline() + newline()
    + "    public boolean all(Predicate<? super T> pred) {" + newline()
    + "        return values.stream().allMatch(pred);" + newline()
    + "    }" + newline()
    + "}" + newline()

private fun java_seq_to_seq_aliases(functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if function.name == "to_seq"
        then java_seq_to_seq_alias(function) + java_seq_to_seq_aliases(functions[1:])
        else java_seq_to_seq_aliases(functions[1:])

private fun java_seq_to_seq_alias(function: CompiledFunction): String =
    "    public static <T> Seq<T> " + java_function_name(function) + "(java.lang.Object value) {" + newline()
    + "        return toSeq(value);" + newline()
    + "    }" + newline() + newline()

private fun java_system_module_code(module: CompiledModule): String =
    java_package(module)
    + "public final class System {" + newline()
    + "    private System() " + "{" + "}" + newline() + newline()
    + "    public static capy.lang.Effect<java.lang.Long> currentMillis() {" + newline()
    + "        return capy.lang.Effect.delay(() -> java.lang.System.currentTimeMillis());" + newline()
    + "    }" + newline() + newline()
    + "    public static capy.lang.Effect<java.lang.Long> nanoTime() {" + newline()
    + "        return capy.lang.Effect.delay(() -> java.lang.System.nanoTime());" + newline()
    + "    }" + newline() + newline()
    + "    public static capy.lang.Effect<java.lang.Long> current_millis__3_0() {" + newline()
    + "        return currentMillis();" + newline()
    + "    }" + newline() + newline()
    + "    public static capy.lang.Effect<java.lang.Long> nano_time__8_0() {" + newline()
    + "        return nanoTime();" + newline()
    + "    }" + newline()
    + "}" + newline()

/// Emits private Java functional interfaces needed for higher-arity Capybara function values.
private fun java_function_type_interfaces(): String =
    "    @FunctionalInterface" + newline()
    + "    private interface __CapyFunction3<A, B, C, R> {" + newline()
    + "        R apply(A a, B b, C c);" + newline()
    + "    }" + newline() + newline()
    + "    @FunctionalInterface" + newline()
    + "    private interface __CapyFunction4<A, B, C, D, R> {" + newline()
    + "        R apply(A a, B b, C c, D d);" + newline()
    + "    }" + newline() + newline()

/// Formats Java source text for functional data and union declarations.
private fun java_data_types(typeNames: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match typeNames[0] with
    case None -> ""
    case Some { typeName } ->
        if java_data_type_emittable(typeName, module)
        then java_data_type(typeName, module, allModules) + newline()
            + java_data_types(typeNames[1:], module, allModules)
        else java_data_types(typeNames[1:], module, allModules)

/// Checks whether a data type should be emitted as a nested Java declaration.
private fun java_data_type_emittable(typeName: String, module: CompiledModule): bool =
    java_data_type_generated(typeName, module)
        & java_data_type_kind(typeName, module.functions) != "enum"
        & java_data_type_kind(typeName, module.functions) != "primitive"

/// Checks whether a data type can be generated without colliding with the enclosing module class.
private fun java_data_type_generated(typeName: String, module: CompiledModule): bool =
    typeName != module.name

/// Formats Java source text for one functional data or union declaration.
private fun java_data_type(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_data_type_kind(typeName, module.functions) == "union"
    then java_union_data_type(typeName, module, allModules)
    else java_record_data_type(typeName, module, allModules)

/// Resolves the schema kind for a functional data type.
private fun java_data_type_kind(typeName: String, functions: List[CompiledFunction]): String =
    match schema_value_named("__capy_schema_kind|" + typeName, functions) with
    case Some { value } -> value
    case None ->
        if primitive_backed_type_exists_in_functions(typeName, functions)
        then "primitive"
        else if enum_type_exists_in_functions(typeName, functions)
        then "enum"
        else "data"

/// Checks whether a schema type is primitive-backed in functions.
private fun primitive_backed_type_exists_in_functions(typeName: String, functions: List[CompiledFunction]): bool =
    match schema_value_named("__capy_schema_primitive|" + typeName, functions) with
    case Some _ -> true
    case None -> false

/// Resolves the schema kind for a data type visible from a module.
private fun java_data_type_kind_in_scope(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match data_type_owner_module(typeName, module, allModules) with
    case Some { owner } -> java_data_type_kind(typeName, owner.functions)
    case None -> "data"

/// Checks whether a data type visible from a module can be referenced as generated Java.
private fun java_data_type_generated_in_scope(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match data_type_owner_module(typeName, module, allModules) with
    case Some { owner } -> java_data_type_generated(typeName, owner)
    case None -> false

/// Formats Java source text for a functional union declaration.
private fun java_union_data_type(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let variants = java_data_type_variant_names(typeName, schema_values("__capy_schema_type|", module.functions), module)
    let externalVariants = java_data_type_has_external_variants(typeName, module, allModules)
    let parentClause = java_union_data_type_parent_clause(typeName, module, allModules)
    "    " + java_visibility_prefix(data_type_visibility(typeName, module.functions)) + java_union_modifier(variants, externalVariants)
        + "interface " + java_data_type_declaration_name(typeName, module, allModules) + parentClause + " {" + newline()
        + java_union_data_type_methods(data_type_direct_fields(typeName, module, allModules), module, allModules)
        + "    }" + newline()

/// Computes the Java union modifier.
private fun java_union_modifier(variants: List[String], externalVariants: bool): String =
    if variants.is_empty() | externalVariants
    then ""
    else "sealed "

/// Checks whether another module emits a generated subtype of the current union.
private fun java_data_type_has_external_variants(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match allModules[0] with
    case None -> false
    case Some { candidateModule } ->
        if java_same_module(candidateModule, module)
        then java_data_type_has_external_variants(typeName, module, allModules[1:])
        else if !java_data_type_variant_names(typeName, schema_values("__capy_schema_type|", candidateModule.functions), candidateModule).is_empty()
        then true
        else java_data_type_has_external_variants(typeName, module, allModules[1:])

/// Checks whether two compiled modules refer to the same generated module.
private fun java_same_module(first: CompiledModule, second: CompiledModule): bool =
    first.name == second.name & first.path == second.path

/// Formats the Java extends clause for union parents.
private fun java_union_data_type_parent_clause(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parents = java_data_record_union_parents(data_type_parent_types(typeName, module, allModules), module, allModules)
    if parents.is_empty()
    then ""
    else " extends " + java_data_record_parent_types(parents, module, allModules)

/// Formats Java source text for union field accessors.
private fun java_union_data_type_methods(fields: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        "        public " + java_data_type_java_type(schema_type_reference(schema_field_type_name(field)), module, allModules)
            + " " + java_identifier(schema_field_name(field)) + "();" + newline()
            + java_union_data_type_methods(fields[1:], module, allModules)

/// Formats Java source text for a functional data record declaration.
private fun java_record_data_type(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let declarationName = java_data_type_declaration_name(typeName, module, allModules)
    let components = java_data_record_components(java_data_record_fields(typeName, module, allModules), module, allModules)
    let parentClause = java_data_record_parent_clause(typeName, module, allModules)
    let declarationPrefix = "    " + java_visibility_prefix(data_type_visibility(typeName, module.functions)) + "record "
        + declarationName + "(" + components + ")"
    declarationPrefix + parentClause + " " + "{" + "}" + newline()

/// Formats Java record components for data fields.
private fun java_data_record_components(fields: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        java_data_record_component(field, module, allModules)
            + java_data_record_component_tail(fields[1:], module, allModules)

/// Formats the recursive tail segment for Java record components.
private fun java_data_record_component_tail(fields: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + java_data_record_components(fields, module, allModules)

/// Formats one Java record component.
private fun java_data_record_component(field: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_data_type_java_type(schema_type_reference(schema_field_type_name(field)), module, allModules)
        + " " + java_identifier(schema_field_name(field))

/// Collects record fields, preserving inherited and explicit union parent fields before own fields.
private fun java_data_record_fields(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let inheritedFields = java_data_record_parent_fields(data_type_parent_types(typeName, module, allModules), module, allModules)
    let parentFields = java_data_explicit_parent_fields(typeName, module.functions)
    if inheritedFields.is_empty() & parentFields.is_empty()
    then data_type_fields(typeName, module, allModules)
    else merge_schema_fields(
        inheritedFields,
        merge_schema_fields(parentFields, java_data_own_fields(typeName, module.functions))
    )

/// Collects generated Java record fields inherited from union parent types.
private fun java_data_record_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        let parentFields = match data_type_owner_module(parentName, module, allModules) with
            case Some { owner } -> java_data_record_fields(parentName, owner, allModules)
            case None -> java_data_record_fields(parentName, module, allModules)
        merge_schema_fields(
            parentFields,
            java_data_record_parent_fields(parents[1:], module, allModules)
        )

/// Collects parser-emitted union parent fields for a variant.
private fun java_data_explicit_parent_fields(typeName: String, functions: List[CompiledFunction]): List[String] =
    schema_values("__capy_schema_field|" + typeName + "|parent|", functions)

/// Collects directly declared fields for a data type, excluding parser-emitted union parent fields.
private fun java_data_own_fields(typeName: String, functions: List[CompiledFunction]): List[String] =
    schema_values_excluding_prefix(
        "__capy_schema_field|" + typeName + "|",
        "__capy_schema_field|" + typeName + "|parent|",
        functions
    )

/// Formats the Java implements clause for union parents.
private fun java_data_record_parent_clause(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parents = java_data_record_union_parents(data_type_parent_types(typeName, module, allModules), module, allModules)
    if parents.is_empty()
    then ""
    else " implements " + java_data_record_parent_types(parents, module, allModules)

/// Collects union parents that have generated Java declarations.
private fun java_data_record_union_parents(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentType = schema_type_reference(parent)
        if java_data_type_kind_in_scope(parentType.name, module, allModules) == "union"
            & java_data_type_generated_in_scope(parentType.name, module, allModules)
        then [parent] + java_data_record_union_parents(parents[1:], module, allModules)
        else java_data_record_union_parents(parents[1:], module, allModules)

/// Formats Java parent type references for record implements clauses.
private fun java_data_record_parent_types(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> ""
    case Some { parent } ->
        java_data_type_reference_java_type(schema_type_reference(parent), module, allModules)
            + java_data_record_parent_type_tail(parents[1:], module, allModules)

/// Formats the recursive tail segment for Java record parent types.
private fun java_data_record_parent_type_tail(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> ""
    case Some _ -> ", " + java_data_record_parent_types(parents, module, allModules)

/// Formats a Java data type declaration name with type parameters.
private fun java_data_type_declaration_name(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_identifier(typeName) + java_data_type_parameters(data_type_parameters(typeName, module, allModules))

/// Formats Java type parameters.
private fun java_data_type_parameters(parameters: List[String]): String =
    if parameters.is_empty()
    then ""
    else "<" + java_data_type_parameter_list(parameters) + ">"

/// Formats a Java type parameter list.
private fun java_data_type_parameter_list(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_identifier(parameter) + java_data_type_parameter_tail(parameters[1:])

/// Formats the recursive tail segment for Java type parameters.
private fun java_data_type_parameter_tail(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + java_data_type_parameter_list(parameters)

/// Collects data type variants from schema parent metadata.
private fun java_data_type_variant_names(typeName: String, candidates: List[String], module: CompiledModule): List[String] =
    match candidates[0] with
    case None -> []
    case Some { candidate } ->
        if java_data_type_has_parent(candidate, typeName, module.functions)
            & java_data_type_generated(candidate, module)
        then [candidate] + java_data_type_variant_names(typeName, candidates[1:], module)
        else java_data_type_variant_names(typeName, candidates[1:], module)

/// Checks whether a candidate data type has the expected parent.
private fun java_data_type_has_parent(candidate: String, parentName: String, functions: List[CompiledFunction]): bool =
    java_data_type_parent_values_contain(schema_values("__capy_schema_parent|" + candidate + "|", functions), parentName)

/// Checks whether parent schema values include the expected parent type name.
private fun java_data_type_parent_values_contain(parents: List[String], parentName: String): bool =
    match parents[0] with
    case None -> false
    case Some { parent } ->
        schema_type_reference(parent).name == parentName
            | java_data_type_parent_values_contain(parents[1:], parentName)

/// Resolves visibility for a functional data type.
private fun data_type_visibility(typeName: String, functions: List[CompiledFunction]): String =
    match schema_value_named("__capy_schema_visibility|" + typeName, functions) with
    case Some { value } -> value
    case None -> "public"

/// Formats a Java type in generated data declarations.
private fun java_data_type_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let primitiveType = primitive_java_type_name(type.name)
    if type.name == "array"
    then java_data_type_java_type(first_type_argument(type), module, allModules) + "[]"
    else if !primitiveType.is_empty()
    then primitiveType
    else match primitive_backed_backing_type(type.name, module, allModules) with
        case Some { backingType } -> java_data_type_java_type(backingType, module, allModules)
        case None -> java_data_type_boxed_java_type(type, module, allModules)

/// Formats a boxed Java type in generated data declarations.
private fun java_data_type_boxed_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let primitiveType = boxed_primitive_java_type_name(type.name)
    let simpleType = simple_java_type_name(type.name)
    let dataTypeName = type_unqualified_name(type.name)
    if type_parameter(type)
    then java_identifier(type.name)
    else if function_type(type)
    then top_level_java_functional_type(type, module, allModules)
    else if type.name == "array"
    then java_data_type_java_type(first_type_argument(type), module, allModules) + "[]"
    else if java_object_type(type)
    then java_object_type_java_name(type)
    else if !primitiveType.is_empty()
    then primitiveType
    else match primitive_backed_backing_type(type.name, module, allModules) with
        case Some { backingType } -> java_data_type_boxed_java_type(backingType, module, allModules)
        case None -> java_data_type_boxed_non_primitive_java_type(type, simpleType, dataTypeName, module, allModules)

/// Formats a boxed Java type in generated data declarations after primitive-backed type resolution.
private fun java_data_type_boxed_non_primitive_java_type(type: CompiledTypeReference, simpleType: String, dataTypeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if boxed_container_java_type_name(type.name)
    then boxed_container_java_type(type.name, java_data_type_boxed_java_type(first_type_argument(type), module, allModules))
    else if type.name == "Tuple"
    then "java.util.List<?>"
    else if type.name == "Effect"
    then "capy.lang.Effect<" + java_data_type_boxed_java_type(first_type_argument(type), module, allModules) + ">"
    else if type.name == "String"
    then "String"
    else if !simpleType.is_empty()
    then simpleType
    else match data_type_owner_module(dataTypeName, module, allModules) with
        case Some { owner } ->
            if java_data_type_emittable(dataTypeName, owner)
            then java_data_type_reference_java_type(type, module, allModules)
            else "java.lang.Object"
        case None -> "java.lang.Object"

/// Formats a Java data type reference.
private fun java_data_type_reference_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_data_type_reference_name(type, module, allModules)
        + java_data_type_reference_arguments(type.arguments, module, allModules)

/// Formats a Java data type reference name.
private fun java_data_type_reference_name(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let name = type_unqualified_name(type.name)
    match data_type_owner_module(name, module, allModules) with
    case Some { owner } ->
        if owner.name == module.name & owner.path == module.path
        then java_identifier(name)
        else top_level_owned_data_type_java_name(name, module, owner)
    case None -> java_identifier(name)

/// Formats Java data type reference arguments.
private fun java_data_type_reference_arguments(arguments: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else "<" + java_data_type_reference_argument_list(arguments, module, allModules) + ">"

/// Formats a Java data type reference argument list.
private fun java_data_type_reference_argument_list(arguments: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } ->
        java_data_type_boxed_java_type(argument, module, allModules)
            + java_data_type_reference_argument_tail(arguments[1:], module, allModules)

/// Formats the recursive tail segment for Java data type reference arguments.
private fun java_data_type_reference_argument_tail(arguments: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some _ -> ", " + java_data_type_reference_argument_list(arguments, module, allModules)

/// Creates top-level Java interface source modules for compiled object interfaces.
private fun java_object_interface_modules(modules: List[CompiledModule], allModules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        java_object_interface_modules_for_module(compiled_objects(module.functions).interfaces, module, allModules)
            + java_object_interface_modules(modules[1:], allModules)

/// Creates top-level Java interface modules declared inside one compiled module.
private fun java_object_interface_modules_for_module(interfaces: List[CompiledObjectOrientedInterface], module: CompiledModule, allModules: List[CompiledModule]): List[GeneratedModule] =
    match interfaces[0] with
    case None -> []
    case Some { objectInterface } -> [GeneratedModule {
        relativePath: java_object_interface_relative_path(objectInterface, module),
        code: java_object_top_level_interface_code(objectInterface, module, allModules)
    }] + java_object_interface_modules_for_module(interfaces[1:], module, allModules)

/// Computes the output or module path for object interface.
private fun java_object_interface_relative_path(objectInterface: CompiledObjectOrientedInterface, module: CompiledModule): String =
    if module.path.is_empty()
    then java_identifier(objectInterface.name) + ".java"
    else module.path + "/" + java_identifier(objectInterface.name) + ".java"

/// Emits top-level Java interface source for a compiled object interface.
private fun java_object_top_level_interface_code(objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_package(module)
    + "public interface " + java_identifier(objectInterface.name) + java_object_interface_parent_clause(objectInterface.parents, module, allModules) + " {" + newline()
    + java_object_top_level_interface_methods(objectInterface.methods, objectInterface, module, allModules)
    + "}" + newline()

/// Formats Java source text for object top-level interface methods.
private fun java_object_top_level_interface_methods(methods: List[CompiledObjectOrientedMethod], objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> ""
    case Some { method } ->
        java_object_top_level_interface_method(method, objectInterface, module, allModules)
            + java_object_top_level_interface_methods(methods[1:], objectInterface, module, allModules)

/// Formats Java source text for object top-level interface method.
private fun java_object_top_level_interface_method(method: CompiledObjectOrientedMethod, objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule]): String =
    if objectInterface.kind == "trait"
    then
        let env = java_object_interface_method_bindings(method.parameters, objectInterface, module)
        "    default " + top_level_java_type(method.returnType, module, allModules) + " " + java_method_name(method.name) + "(" + top_level_java_parameters(method.parameters, module, allModules) + ") {" + newline()
        + java_object_interface_method_body(method, env, module, allModules, "        ")
        + "    }" + newline()
    else "    " + top_level_java_type(method.returnType, module, allModules) + " " + java_method_name(method.name) + "(" + top_level_java_parameters(method.parameters, module, allModules) + ");" + newline()

/// Formats Java source text for object interfaces.
private fun java_object_interfaces(interfaces: List[CompiledObjectOrientedInterface], module: CompiledModule, allModules: List[CompiledModule]): String =
    match interfaces[0] with
    case None -> ""
    case Some { objectInterface } ->
        java_object_interface(objectInterface, module, allModules) + newline()
            + java_object_interfaces(interfaces[1:], module, allModules)

/// Formats Java source text for object interface.
private fun java_object_interface(objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule]): String =
    "    " + java_visibility_prefix(objectInterface.visibility) + "interface " + java_identifier(objectInterface.name) + java_object_interface_parent_clause(objectInterface.parents, module, allModules) + " {" + newline()
    + java_object_interface_methods(objectInterface.methods, objectInterface, module, allModules)
    + "    }" + newline()

/// Formats the Java clause for object interface parent.
private fun java_object_interface_parent_clause(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    if parents.is_empty()
    then ""
    else " extends " + java_object_parent_types(parents, module, allModules)

/// Formats Java source text for object interface methods.
private fun java_object_interface_methods(methods: List[CompiledObjectOrientedMethod], objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> ""
    case Some { method } ->
        java_object_interface_method(method, objectInterface, module, allModules, "        ")
            + java_object_interface_methods(methods[1:], objectInterface, module, allModules)

/// Formats Java source text for object interface method.
private fun java_object_interface_method(method: CompiledObjectOrientedMethod, objectInterface: CompiledObjectOrientedInterface, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if objectInterface.kind == "trait"
    then
        let env = java_object_interface_method_bindings(method.parameters, objectInterface, module)
        indent + "default " + java_type(method.returnType) + " " + java_method_name(method.name) + "(" + java_parameters(method.parameters) + ") {" + newline()
        + java_object_interface_method_body(method, env, module, allModules, indent + "    ")
        + indent + "}" + newline()
    else indent + java_type(method.returnType) + " " + java_method_name(method.name) + "(" + java_parameters(method.parameters) + ");" + newline()

/// Creates Java name/type bindings for object interface method.
private fun java_object_interface_method_bindings(parameters: List[CompiledFunctionParameter], objectInterface: CompiledObjectOrientedInterface, module: CompiledModule): List[JavaBinding] =
    [java_binding_with_java_name("this", java_object_interface_type_reference_for_module(module, objectInterface), "this")]
        + parameter_bindings(parameters)

/// Emits Java expression text for object interface method body.
private fun java_object_interface_method_body(method: CompiledObjectOrientedMethod, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if !expression_emittable(method.body, env, module, allModules)
    then indent + "throw new UnsupportedOperationException(\"Unsupported COO trait method body at " + method.location.line + ":" + method.location.column + "\");" + newline()
    else java_object_return_statements(method.body, method.returnType, env, module, allModules, indent)

/// Formats Java source text for object classes.
private fun java_object_classes(classes: List[CompiledObjectOrientedClass], constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match classes[0] with
    case None -> ""
    case Some { objectClass } ->
        java_object_class(objectClass, constantBindings, module, allModules) + newline()
            + java_object_constructor_function(objectClass, module, allModules) + newline()
            + java_object_classes(classes[1:], constantBindings, module, allModules)

/// Formats Java source text for object class.
private fun java_object_class(objectClass: CompiledObjectOrientedClass, constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "    " + java_visibility_prefix(objectClass.visibility) + "static " + java_object_class_final_modifier(objectClass) + "class " + java_identifier(objectClass.name) + java_object_class_parent_clause(objectClass.parents, module, allModules) + " {" + newline()
    + java_object_fields(objectClass.fields)
    + java_object_constructor(objectClass, module, allModules)
    + java_object_methods(objectClass.methods, objectClass, constantBindings, module, allModules)
    + "    }" + newline()

/// Formats Java source text for object class final modifier.
private fun java_object_class_final_modifier(objectClass: CompiledObjectOrientedClass): String =
    if objectClass.open then "" else "final "

/// Formats the Java clause for object class parent.
private fun java_object_class_parent_clause(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    let interfaceParents = java_object_class_interface_parents(parents, module, allModules)
    match java_object_class_parent(parents, module, allModules) with
    case Some { parent } -> " extends " + java_object_parent_type(parent, module, allModules) + java_object_class_implements_clause(interfaceParents, module, allModules)
    case None -> java_object_class_implements_clause(interfaceParents, module, allModules)

/// Resolves type metadata for object class parent.
private fun java_object_class_parent(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match parents[0] with
    case None -> /capy/lang/Option.None {}
    case Some { parent } ->
        if java_object_parent_is_class(parent, module, allModules)
        then /capy/lang/Option.Some { parent }
        else java_object_class_parent(parents[1:], module, allModules)

/// Collects object-oriented metadata for object class interface parents.
private fun java_object_class_interface_parents(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): List[CompiledTypeReference] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        if java_object_parent_is_class(parent, module, allModules)
        then java_object_class_interface_parents(parents[1:], module, allModules)
        else [parent] + java_object_class_interface_parents(parents[1:], module, allModules)

/// Checks whether the current value satisfies the object parent is class rule for Java processing.
private fun java_object_parent_is_class(parent: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_class_by_type(parent, allModules) with
    case Some _ -> true
    case None ->
        match find_object_class_in_scope(parent.name, module, allModules) with
        case Some _ -> true
        case None -> false

/// Formats the Java clause for object class implements.
private fun java_object_class_implements_clause(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    if parents.is_empty()
    then ""
    else " implements " + java_object_parent_types(parents, module, allModules)

/// Formats type metadata text for object parent types.
private fun java_object_parent_types(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> ""
    case Some { parent } -> java_object_parent_type(parent, module, allModules) + java_object_parent_type_tail(parents[1:], module, allModules)

/// Formats the recursive tail segment for object parent type.
private fun java_object_parent_type_tail(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> ""
    case Some _ -> ", " + java_object_parent_types(parents, module, allModules)

/// Computes the Java type for object parent.
private fun java_object_parent_type(parent: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_object_type(parent)
    then java_object_type_java_name(parent)
    else match find_object_interface_by_name(parent.name, module, allModules) with
    case Some { binding } -> binding.moduleClassName + "." + java_identifier(binding.objectInterface.name)
    case None -> java_identifier(type_unqualified_name(parent.name))

/// Formats Java source text for object fields.
private fun java_object_fields(fields: List[CompiledObjectOrientedField]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        "        " + java_visibility_prefix(field.visibility) + java_type(field.typeReference) + " " + java_identifier(field.name) + ";" + newline()
            + java_object_fields(fields[1:])

/// Formats Java source text for object constructor.
private fun java_object_constructor(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    let env = java_object_constructor_bindings(objectClass, module)
    "        public " + java_identifier(objectClass.name) + "(" + java_parameters(objectClass.parameters) + ") {" + newline()
    + java_object_field_assignments(objectClass.fields, env, module, allModules)
    + java_object_init_statements(objectClass.initBlocks, env, module, allModules)
    + "        }" + newline() + newline()

/// Creates Java name/type bindings for object constructor.
private fun java_object_constructor_bindings(objectClass: CompiledObjectOrientedClass, module: CompiledModule): List[JavaBinding] =
    [java_binding_with_java_name("this", java_object_type_reference(module, objectClass), "this")]
        + parameter_bindings(objectClass.parameters)

/// Formats Java source text for object field assignments.
private fun java_object_field_assignments(fields: List[CompiledObjectOrientedField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        (if field.hasValue
        then "            this." + java_identifier(field.name) + " = " + expression_code(field.value, env, field.typeReference, module, allModules) + ";" + newline()
        else "")
            + java_object_field_assignments(fields[1:], env, module, allModules)

/// Emits Java statements for object initializer.
private fun java_object_init_statements(initBlocks: List[CompiledObjectOrientedInitBlock], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match initBlocks[0] with
    case None -> ""
    case Some { initBlock } ->
        java_object_init_statement(initBlock, env, module, allModules)
            + java_object_init_statements(initBlocks[1:], env, module, allModules)

/// Emits one Java statement for object initializer.
private fun java_object_init_statement(initBlock: CompiledObjectOrientedInitBlock, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(initBlock.body, env, module, allModules)
    if type.name == "Effect"
    then "            " + expression_code(initBlock.body, env, type, module, allModules) + ".unsafeRun();" + newline()
    else "            " + expression_code(initBlock.body, env, type, module, allModules) + ";" + newline()

/// Formats Java source text for object methods.
private fun java_object_methods(methods: List[CompiledObjectOrientedMethod], objectClass: CompiledObjectOrientedClass, constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> ""
    case Some { method } -> java_object_method(method, objectClass, constantBindings, module, allModules) + newline() + java_object_methods(methods[1:], objectClass, constantBindings, module, allModules)

/// Formats Java source text for object method.
private fun java_object_method(method: CompiledObjectOrientedMethod, objectClass: CompiledObjectOrientedClass, constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let env = java_object_method_bindings(method.parameters, objectClass, module) + constantBindings
    "        " + java_visibility_prefix(method.visibility) + java_type(method.returnType) + " " + java_method_name(method.name) + "(" + java_parameters(method.parameters) + ") {" + newline()
    + java_object_method_body(method, env, module, allModules)
    + "        }" + newline()

/// Creates Java name/type bindings for object method.
private fun java_object_method_bindings(parameters: List[CompiledFunctionParameter], objectClass: CompiledObjectOrientedClass, module: CompiledModule): List[JavaBinding] =
    [java_binding_with_java_name("this", java_object_type_reference(module, objectClass), "this")]
        + parameter_bindings(parameters)

/// Emits Java expression text for object method body.
private fun java_object_method_body(method: CompiledObjectOrientedMethod, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if !expression_emittable(method.body, env, module, allModules)
    then "            throw new UnsupportedOperationException(\"Unsupported COO method body at " + method.location.line + ":" + method.location.column + "\");" + newline()
    else java_object_return_statements(method.body, method.returnType, env, module, allModules, "            ")

/// Emits Java statements for object return.
private fun java_object_return_statements(expression: CompiledExpression, returnType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledIfExpression ifExpression ->
        indent + "if (" + truthy_expression_code(ifExpression.condition, env, module, allModules) + ") {" + newline()
            + java_object_return_statements(ifExpression.thenBranch, returnType, env, module, allModules, indent + "    ")
            + indent + "} else {" + newline()
            + java_object_return_statements(ifExpression.elseBranch, returnType, env, module, allModules, indent + "    ")
            + indent + "}" + newline()
    case CompiledBlockExpression block ->
        block_statements(block.bindings, env, returnType, module, allModules, indent)
            + java_object_return_statements(block.result, returnType, block_env(block.bindings, env, module, allModules), module, allModules, indent)
    case _ ->
        let expressionType = expression_type(expression, env, module, allModules)
        if returnType.name == "void" & expressionType.name == "Effect"
        then indent + expression_code(expression, env, expressionType, module, allModules) + ".unsafeRun();" + newline()
        else if returnType.name == "void"
        then indent + expression_code(expression, env, object_type(), module, allModules) + ";" + newline()
        else indent + "return " + expression_code(expression, env, returnType, module, allModules) + ";" + newline()

/// Formats Java source text for object constructor function.
private fun java_object_constructor_function(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = java_object_type_reference(module, objectClass)
    "    public static capy.lang.Effect<" + boxed_java_type(type) + "> " + java_object_constructor_function_name(objectClass) + "(" + java_parameters(objectClass.parameters) + ") {" + newline()
    + "        return capy.lang.Effect.delay(() -> new " + boxed_java_type(type) + "(" + java_object_constructor_argument_names(objectClass.parameters) + "));" + newline()
    + "    }" + newline()

/// Computes the Java name for object constructor function.
private fun java_object_constructor_function_name(objectClass: CompiledObjectOrientedClass): String =
    java_identifier(objectClass.name) + "__" + objectClass.location.line + "_" + objectClass.location.column

/// Computes the Java name for object constructor argument names.
private fun java_object_constructor_argument_names(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_identifier(parameter.name) + java_object_constructor_argument_name_tail(parameters[1:])

/// Formats the recursive tail segment for object constructor argument name.
private fun java_object_constructor_argument_name_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_identifier(parameter.name) + java_object_constructor_argument_name_tail(parameters[1:])

/// Extracts object interface and class metadata in one top-level function pass.
private fun compiled_objects(functions: List[CompiledFunction]): JavaCompiledObjects =
    match functions[0] with
    case None -> JavaCompiledObjects { interfaces: [], classes: [] }
    case Some { function } ->
        let rest = compiled_objects(functions[1:])
        if compiled_object_interface_schema(function)
        then JavaCompiledObjects {
            interfaces: [compiled_object_interface(function, functions)] + rest.interfaces,
            classes: rest.classes
        }
        else if compiled_object_class_schema(function)
        then JavaCompiledObjects {
            interfaces: rest.interfaces,
            classes: [compiled_object_class(function, functions)] + rest.classes
        }
        else rest

/// Extracts compiled metadata for object interface schema.
private fun compiled_object_interface_schema(function: CompiledFunction): bool =
    if compiled_schema(function)
    then java_generator_string_has_prefix(function.name, OO_INTERFACE_SCHEMA_PREFIX)
    else false

/// Extracts compiled metadata for object interface.
private fun compiled_object_interface(function: CompiledFunction, functions: List[CompiledFunction]): CompiledObjectOrientedInterface =
    let interfaceName = function.name[oo_interface_schema_prefix_size(), function.name.size().value]
    CompiledObjectOrientedInterface {
        name: interfaceName,
        visibility: schema_value(function),
        documentation: function.documentation,
        kind: compiled_object_interface_kind(interfaceName, functions),
        parents: schema_type_references(schema_values("__capy_oo_interface_parent|" + interfaceName + "|", functions)),
        methods: compiled_object_interface_methods(interfaceName, functions),
        location: function.location
    }

/// Extracts compiled metadata for object interface kind.
private fun compiled_object_interface_kind(interfaceName: String, functions: List[CompiledFunction]): String =
    match schema_value_named("__capy_oo_interface_kind|" + interfaceName, functions) with
    case Some { value } -> value
    case None -> "interface"

/// Extracts compiled metadata for object interface methods.
private fun compiled_object_interface_methods(interfaceName: String, functions: List[CompiledFunction]): List[CompiledObjectOrientedMethod] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_interface_method_function_for_interface(function, interfaceName)
        then [compiled_object_interface_method(function)] + compiled_object_interface_methods(interfaceName, functions[1:])
        else compiled_object_interface_methods(interfaceName, functions[1:])

/// Extracts compiled metadata for object interface method function.
private fun compiled_object_interface_method_function(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.name, OO_INTERFACE_METHOD_FUNCTION_PREFIX)

/// Extracts compiled metadata for object interface method function for interface.
private fun compiled_object_interface_method_function_for_interface(function: CompiledFunction, interfaceName: String): bool =
    if compiled_object_interface_method_function(function)
    then compiled_object_interface_method_owner_name(function.name) == interfaceName
    else false

/// Extracts compiled metadata for object interface method.
private fun compiled_object_interface_method(function: CompiledFunction): CompiledObjectOrientedMethod =
    CompiledObjectOrientedMethod {
        name: compiled_object_interface_method_name(function.name),
        visibility: compiled_object_interface_method_visibility(function.visibility),
        documentation: function.documentation,
        parameters: function.parameters,
        returnType: function.returnType,
        body: function.body,
        location: function.location
    }

/// Extracts compiled metadata for object interface method owner name.
private fun compiled_object_interface_method_owner_name(name: String): String =
    let rest = name[oo_interface_method_function_prefix_size(), name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Extracts compiled metadata for object interface method name.
private fun compiled_object_interface_method_name(name: String): String =
    let rest = name[oo_interface_method_function_prefix_size(), name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then "" else rest[separator + 1, rest.size().value]

/// Extracts compiled metadata for object interface method visibility.
private fun compiled_object_interface_method_visibility(visibility: String): String =
    if java_generator_string_has_prefix(visibility, "oo_interface_method:")
    then visibility["oo_interface_method:".size().value, visibility.size().value]
    else visibility

/// Extracts compiled metadata for object classes.
private fun compiled_object_classes(functions: List[CompiledFunction]): List[CompiledObjectOrientedClass] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_class_schema(function)
        then [compiled_object_class(function, functions)] + compiled_object_classes(functions[1:])
        else compiled_object_classes(functions[1:])

/// Extracts compiled metadata for object class schema.
private fun compiled_object_class_schema(function: CompiledFunction): bool =
    if compiled_schema(function)
    then java_generator_string_has_prefix(function.name, OO_CLASS_SCHEMA_PREFIX)
    else false

/// Extracts compiled metadata for object class.
private fun compiled_object_class(function: CompiledFunction, functions: List[CompiledFunction]): CompiledObjectOrientedClass =
    let className = function.name[oo_class_schema_prefix_size(), function.name.size().value]
    let sources = compiled_object_class_sources(className, functions)
    CompiledObjectOrientedClass {
        name: className,
        visibility: schema_value(function),
        documentation: function.documentation,
        open: sources.openValue == "true",
        parameters: compiled_object_class_parameters_from_sources(sources.parameters),
        parents: schema_type_references(sources.parents),
        fields: compiled_object_fields(className, sources.fieldSchemas, sources.fieldInitializers),
        initBlocks: compiled_object_init_blocks_from_sources(sources.initBlocks),
        methods: compiled_object_methods_from_sources(sources.methods),
        location: function.location
    }

/// Extracts compiled object class schema and helper sources for one class once.
private fun compiled_object_class_sources(className: String, functions: List[CompiledFunction]): JavaObjectClassSources =
    match functions[0] with
    case None -> JavaObjectClassSources { openValue: "", parameters: [], parents: [], fieldSchemas: [], fieldInitializers: [], initBlocks: [], methods: [] }
    case Some { function } ->
        let rest = compiled_object_class_sources(className, functions[1:])
        if compiled_schema(function) & function.name == "__capy_oo_class_open|" + className
        then rest.with(openValue: schema_value(function))
        else if compiled_object_class_parameter_schema_for_class(function, className)
        then rest.with(parameters: [function] + rest.parameters)
        else if compiled_schema(function) & java_generator_string_has_prefix(function.name, "__capy_oo_parent|" + className + "|")
        then rest.with(parents: [schema_value(function)] + rest.parents)
        else if compiled_object_field_schema_for_class(function, className)
        then rest.with(fieldSchemas: [function] + rest.fieldSchemas)
        else if compiled_object_field_init_function_for_class(function, className)
        then rest.with(fieldInitializers: [function] + rest.fieldInitializers)
        else if compiled_object_init_function_for_class(function, className)
        then rest.with(initBlocks: [function] + rest.initBlocks)
        else if compiled_object_method_function_for_class(function, className)
        then rest.with(methods: [function] + rest.methods)
        else rest

/// Extracts compiled metadata for object class open.
private fun compiled_object_class_open(className: String, functions: List[CompiledFunction]): bool =
    match schema_value_named("__capy_oo_class_open|" + className, functions) with
    case Some { value } -> value == "true"
    case None -> false

/// Extracts compiled metadata for object class parameters.
private fun compiled_object_class_parameters(className: String, functions: List[CompiledFunction]): List[CompiledFunctionParameter] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_class_parameter_schema_for_class(function, className)
        then [compiled_object_class_parameter(function)] + compiled_object_class_parameters(className, functions[1:])
        else compiled_object_class_parameters(className, functions[1:])

/// Extracts compiled metadata for object class parameters from prefiltered schema functions.
private fun compiled_object_class_parameters_from_sources(functions: List[CompiledFunction]): List[CompiledFunctionParameter] =
    match functions[0] with
    case None -> []
    case Some { function } -> [compiled_object_class_parameter(function)] + compiled_object_class_parameters_from_sources(functions[1:])

/// Extracts compiled metadata for object class parameter schema for class.
private fun compiled_object_class_parameter_schema_for_class(function: CompiledFunction, className: String): bool =
    if compiled_schema(function)
    then java_generator_string_has_prefix(function.name, OO_CLASS_PARAMETER_SCHEMA_PREFIX + className + "|")
    else false

/// Extracts compiled metadata for object class parameter.
private fun compiled_object_class_parameter(function: CompiledFunction): CompiledFunctionParameter =
    let value = schema_value(function)
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then CompiledFunctionParameter { name: value, typeReference: object_type(), location: function.location }
    else CompiledFunctionParameter {
        name: value[0, separator],
        typeReference: schema_type_reference(value[separator + 1, value.size().value]),
        location: function.location
    }

/// Collects schema metadata entries for schema type references.
private fun schema_type_references(values: List[String]): List[CompiledTypeReference] =
    match values[0] with
    case None -> []
    case Some { value } -> [schema_type_reference(value)] + schema_type_references(values[1:])

/// Extracts compiled metadata for object fields.
private fun compiled_object_fields(className: String, fieldSchemas: List[CompiledFunction], fieldInitializers: List[CompiledFunction]): List[CompiledObjectOrientedField] =
    match fieldSchemas[0] with
    case None -> []
    case Some { function } ->
        [compiled_object_field(className, function, fieldInitializers)] + compiled_object_fields(className, fieldSchemas[1:], fieldInitializers)

/// Extracts compiled metadata for object field schema for class.
private fun compiled_object_field_schema_for_class(function: CompiledFunction, className: String): bool =
    if compiled_schema(function)
    then java_generator_string_has_prefix(function.name, OO_FIELD_SCHEMA_PREFIX + className + "|")
    else false

/// Extracts compiled metadata for object field.
private fun compiled_object_field(className: String, function: CompiledFunction, fieldInitializers: List[CompiledFunction]): CompiledObjectOrientedField =
    let value = schema_value(function)
    let schema = object_field_schema_metadata(value)
    CompiledObjectOrientedField {
        name: schema.name,
        visibility: schema.visibility,
        documentation: function.documentation,
        typeReference: schema_type_reference(schema.typeName),
        value: compiled_object_field_value(className, schema.name, fieldInitializers, function.location),
        hasValue: schema.hasValue,
        location: function.location
    }

/// Extracts compiled object field schema and initializer helpers for one class once.
private fun compiled_object_field_sources(className: String, functions: List[CompiledFunction]): JavaObjectFieldSources =
    match functions[0] with
    case None -> JavaObjectFieldSources { schemas: [], initializers: [] }
    case Some { function } ->
        let rest = compiled_object_field_sources(className, functions[1:])
        if compiled_object_field_schema_for_class(function, className)
        then JavaObjectFieldSources {
            schemas: [function] + rest.schemas,
            initializers: rest.initializers
        }
        else if compiled_object_field_init_function_for_class(function, className)
        then JavaObjectFieldSources {
            schemas: rest.schemas,
            initializers: [function] + rest.initializers
        }
        else rest

/// Extracts compiled metadata for object field value.
private fun compiled_object_field_value(className: String, fieldName: String, fieldInitializers: List[CompiledFunction], location: CompiledSourceLocation): CompiledExpression =
    match find_compiled_object_field_init(className, fieldName, fieldInitializers) with
    case Some { function } -> function.body
    case None -> missing_compiled_expression(location)

/// Finds a compiled object field initializer in available declarations, imports, or modules.
private fun find_compiled_object_field_init(className: String, fieldName: String, fieldInitializers: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    find_compiled_object_field_init_by_name(OO_FIELD_INIT_FUNCTION_PREFIX + className + "|" + fieldName, fieldInitializers)

/// Finds a compiled object field initializer by its encoded helper name.
private fun find_compiled_object_field_init_by_name(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name
        then /capy/lang/Option.Some { function }
        else find_compiled_object_field_init_by_name(name, functions[1:])

/// Computes the name for object field schema.
private fun object_field_schema_name(value: String): String =
    let first = first_index_of(value, "|", 0)
    if first < 0 then value else value[0, first]

/// Decodes object field schema separators once for generated object metadata.
private fun object_field_schema_metadata(value: String): JavaObjectFieldSchema =
    let first = first_index_of(value, "|", 0)
    let second = if first < 0 then -1 else first_index_of(value, "|", first + 1)
    let last = last_index_of(value, "|", 0, -1)
    JavaObjectFieldSchema {
        name: if first < 0 then value else value[0, first],
        visibility: if first < 0 | second < 0 then "public" else value[first + 1, second],
        typeName: if second < 0
            then "any"
            else if last <= second
            then value[second + 1, value.size().value]
            else value[second + 1, last],
        hasValue: last >= 0 & value[last + 1, value.size().value] == "true"
    }

/// Encodes schema metadata text for object field schema visibility.
private fun object_field_schema_visibility(value: String): String =
    let first = first_index_of(value, "|", 0)
    let second = if first < 0 then -1 else first_index_of(value, "|", first + 1)
    if first < 0 | second < 0 then "public" else value[first + 1, second]

/// Computes the compiled type for object field schema.
private fun object_field_schema_type(value: String): String =
    let second = object_field_schema_second_separator(value)
    let last = object_field_schema_last_separator(value)
    if second < 0
    then "any"
    else if last <= second
    then value[second + 1, value.size().value]
    else value[second + 1, last]

/// Checks whether schema metadata matches the object field schema has value rule.
private fun object_field_schema_has_value(value: String): bool =
    let last = object_field_schema_last_separator(value)
    last >= 0 & value[last + 1, value.size().value] == "true"

/// Computes a numeric value for object field schema second separator.
private fun object_field_schema_second_separator(value: String): int =
    let first = first_index_of(value, "|", 0)
    if first < 0 then -1 else first_index_of(value, "|", first + 1)

/// Computes a numeric value for object field schema last separator.
private fun object_field_schema_last_separator(value: String): int =
    last_index_of(value, "|", 0, -1)

/// Extracts compiled metadata for object initializer blocks.
private fun compiled_object_init_blocks(className: String, functions: List[CompiledFunction]): List[CompiledObjectOrientedInitBlock] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_init_function_for_class(function, className)
        then [CompiledObjectOrientedInitBlock {
            body: function.body,
            documentation: function.documentation,
            location: function.location
        }] + compiled_object_init_blocks(className, functions[1:])
        else compiled_object_init_blocks(className, functions[1:])

/// Extracts compiled metadata for object initializer blocks from prefiltered functions.
private fun compiled_object_init_blocks_from_sources(functions: List[CompiledFunction]): List[CompiledObjectOrientedInitBlock] =
    match functions[0] with
    case None -> []
    case Some { function } -> [CompiledObjectOrientedInitBlock {
        body: function.body,
        documentation: function.documentation,
        location: function.location
    }] + compiled_object_init_blocks_from_sources(functions[1:])

/// Extracts compiled metadata for object initializer function.
private fun compiled_object_init_function(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.name, OO_INIT_FUNCTION_PREFIX)

/// Extracts compiled metadata for object initializer function for class.
private fun compiled_object_init_function_for_class(function: CompiledFunction, className: String): bool =
    if compiled_object_init_function(function)
    then compiled_object_init_class_name(function.name) == className
    else false

/// Extracts compiled metadata for object initializer class name.
private fun compiled_object_init_class_name(name: String): String =
    let rest = name[oo_init_function_prefix_size(), name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Extracts compiled metadata for object field initializer function.
private fun compiled_object_field_init_function(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.name, OO_FIELD_INIT_FUNCTION_PREFIX)

/// Extracts compiled metadata for object field initializer function for class.
private fun compiled_object_field_init_function_for_class(function: CompiledFunction, className: String): bool =
    if compiled_object_field_init_function(function)
    then java_generator_string_has_prefix(function.name, OO_FIELD_INIT_FUNCTION_PREFIX + className + "|")
    else false

/// Resolves expression metadata for missing compiled expression.
private fun missing_compiled_expression(location: CompiledSourceLocation): CompiledExpression =
    CompiledUnsupportedExpression { source: "", location: location }

/// Extracts compiled metadata for object methods.
private fun compiled_object_methods(className: String, functions: List[CompiledFunction]): List[CompiledObjectOrientedMethod] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_method_function_for_class(function, className)
        then [compiled_object_method(function)] + compiled_object_methods(className, functions[1:])
        else compiled_object_methods(className, functions[1:])

/// Extracts compiled metadata for object methods from prefiltered functions.
private fun compiled_object_methods_from_sources(functions: List[CompiledFunction]): List[CompiledObjectOrientedMethod] =
    match functions[0] with
    case None -> []
    case Some { function } -> [compiled_object_method(function)] + compiled_object_methods_from_sources(functions[1:])

/// Extracts compiled metadata for object method function.
private fun compiled_object_method_function(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.name, OO_METHOD_FUNCTION_PREFIX)

/// Extracts compiled metadata for object method function for class.
private fun compiled_object_method_function_for_class(function: CompiledFunction, className: String): bool =
    if compiled_object_method_function(function)
    then compiled_object_method_class_name(function.name) == className
    else false

/// Extracts compiled metadata for object method.
private fun compiled_object_method(function: CompiledFunction): CompiledObjectOrientedMethod =
    CompiledObjectOrientedMethod {
        name: compiled_object_method_name(function.name),
        visibility: compiled_object_method_visibility(function.visibility),
        documentation: function.documentation,
        parameters: function.parameters,
        returnType: function.returnType,
        body: function.body,
        location: function.location
    }

/// Extracts compiled metadata for object method class name.
private fun compiled_object_method_class_name(name: String): String =
    let rest = name[oo_method_function_prefix_size(), name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Extracts compiled metadata for object method name.
private fun compiled_object_method_name(name: String): String =
    let rest = name[oo_method_function_prefix_size(), name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then "" else rest[separator + 1, rest.size().value]

/// Extracts compiled metadata for object method visibility.
private fun compiled_object_method_visibility(visibility: String): String =
    if java_generator_string_has_prefix(visibility, "oo:")
    then visibility[3, visibility.size().value]
    else visibility

/// Emits Java import source for imports.
private fun java_imports(module: CompiledModule, allModules: List[CompiledModule]): String =
    "import java.util.*;" + newline()
    + "import java.util.function.*;" + newline()
    + static_imports(module.imports, module, allModules)
    + compiled_static_imports(module.staticImports)
    + newline()

/// Extracts compiled metadata for static imports.
private fun compiled_static_imports(imports: List[StaticImport]): String =
    match imports[0] with
    case None -> ""
    case Some { staticImport } ->
        "import static " + staticImport.className + "." + staticImport.memberName + ";" + newline()
            + compiled_static_imports(imports[1:])

/// Emits import statements for static.
private fun static_imports(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        let className = imported_module_class(module, declaration.modulePath)
        if stdlib_import(declaration.modulePath) | declaration.qualified
        then static_imports(imports[1:], module, allModules)
        else match find_module_by_class(className, allModules) with
            case Some { importedModule } ->
                static_import_declaration(declaration, className, importedModule.functions)
                    + static_imports(imports[1:], module, allModules)
            case None -> static_imports(imports[1:], module, allModules)

/// Emits import source for static import declaration.
private fun static_import_declaration(declaration: CompiledImportDeclaration, className: String, functions: List[CompiledFunction]): String =
    if declaration.wildcard & declaration.excludedNames.is_empty()
    then "import static " + className + ".*;" + newline()
    else explicit_static_imports(functions, declaration, className)

/// Emits import statements for explicit static.
private fun explicit_static_imports(functions: List[CompiledFunction], declaration: CompiledImportDeclaration, className: String): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if static_import_function(function, declaration)
        then "import static " + className + "." + java_function_name(function) + ";" + newline()
            + explicit_static_imports(functions[1:], declaration, className)
        else explicit_static_imports(functions[1:], declaration, className)

/// Checks whether a function matches the static import function metadata.
private fun static_import_function(function: CompiledFunction, declaration: CompiledImportDeclaration): bool =
    if compiled_schema(function)
    then false
    else if compiled_object_helper_function(function)
    then false
    else if function.visibility == "private"
    then false
    else if function.visibility == "const:private"
    then false
    else import_includes_name(function.name, declaration)

/// Checks whether an import matches the standard-library import rule.
private fun stdlib_import(modulePath: String): bool =
    if java_generator_string_has_prefix(modulePath, "/capy/")
    then true
    else java_generator_string_has_prefix(modulePath, "capy/")

/// Collects imported module class visible to the current module.
private fun imported_module_class(module: CompiledModule, modulePath: String): String =
    if java_generator_string_has_prefix(modulePath, "/")
    then path_to_class(java_generator_normalize_import_module_path(modulePath))
    else if modulePath ? "/"
    then path_to_class(java_generator_normalize_import_module_path(modulePath))
    else if module.path.is_empty()
    then modulePath
    else module.path.replace("/", ".") + "." + modulePath

/// Normalizes import module path into the path or name form expected by later compiler stages.
private fun java_generator_normalize_import_module_path(path: String): String =
    let normalized = if java_generator_string_has_prefix(path, "/") then path[1, path.size()] else path
    if java_generator_string_has_prefix(normalized, "dev/capylang/capybara/")
    then java_generator_normalize_capybara_import_suffix(normalized["dev/capylang/capybara/".size(), normalized.size()], "dev/capylang/")
    else if java_generator_string_has_prefix(normalized, "capybara/")
    then java_generator_normalize_capybara_import_suffix(normalized["capybara/".size(), normalized.size()], "")
    else normalized

/// Normalizes Capybara import suffix into the path or name form expected by later compiler stages.
private fun java_generator_normalize_capybara_import_suffix(suffix: String, prefix: String): String =
    if java_generator_string_has_prefix(suffix, "test/")
    then prefix + suffix
    else prefix + "test/" + suffix

/// Computes the path for path to class.
private fun path_to_class(path: String): String =
    path.replace("/", ".")

/// Checks whether a string starts with the requested prefix.
private fun java_generator_string_has_prefix(value: String, prefix: String): bool =
    java_generator_string_has_prefix_at(value, prefix, 0)

/// Checks whether a string has the requested prefix at the given index.
private fun java_generator_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then java_generator_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun java_generator_string_has_suffix(value: String, suffix: String): bool =
    if suffix.size().value > value.size().value
    then false
    else value[value.size().value - suffix.size().value, value.size().value] == suffix

/// Formats Java source text for constants.
private fun java_constants(constants: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_constants_with_bindings(constants, [], module, allModules)

/// Formats Java source text for constants with already computed previous constant bindings.
private fun java_constants_with_bindings(constants: List[CompiledFunction], previousBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match constants[0] with
    case None -> if previousBindings.is_empty() then "" else newline()
    case Some { constant } ->
        let type = constant_type(constant, previousBindings, module, allModules)
        java_constant_with_type(constant, type, previousBindings, module, allModules)
        + java_constants_with_bindings(constants[1:], [java_binding(constant.name, type)] + previousBindings, module, allModules)

/// Formats Java source text for constant.
private fun java_constant(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = constant_type(constant, env, module, allModules)
    java_constant_with_type(constant, type, env, module, allModules)

/// Formats Java source text for a constant after its type has already been resolved.
private fun java_constant_with_type(constant: CompiledFunction, type: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "    " + constant_java_visibility(constant) + "static final " + java_type(type) + " " + java_identifier(constant.name)
    + " = " + expression_code(constant.body, env, type, module, allModules) + ";" + newline()

/// Computes constant metadata for type.
private fun constant_type(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if constant.returnType.name.is_empty()
    then expression_type(constant.body, env, module, allModules)
    else constant.returnType

/// Computes constant metadata for bindings.
private fun constant_bindings(constants: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match constants[0] with
    case None -> []
    case Some { constant } ->
        let rest = constant_bindings(constants[1:], module, allModules)
        [java_binding(constant.name, constant_type(constant, rest, module, allModules))] + rest

/// Resolves binding metadata for binding.
private fun java_binding(name: String, typeReference: CompiledTypeReference): JavaBinding =
    JavaBinding { name: name, typeReference: typeReference, javaName: java_identifier(name) }

/// Computes the Java name for binding with Java.
private fun java_binding_with_java_name(name: String, typeReference: CompiledTypeReference, javaName: String): JavaBinding =
    JavaBinding { name: name, typeReference: typeReference, javaName: javaName }

/// Computes constant metadata for functions.
private fun constant_functions(functions: List[CompiledFunction]): List[CompiledFunction] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_constant(function) & !compiled_schema(function)
        then [function] + constant_functions(functions[1:])
        else constant_functions(functions[1:])

/// Extracts compiled metadata for constant.
private fun compiled_constant(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:")

/// Extracts compiled metadata for schema.
private fun compiled_schema(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:schema")

/// Collects imported function visible to the current module.
private fun imported_function(function: CompiledFunction): bool =
    function.visibility == "imported"

/// Extracts compiled metadata for object helper function.
private fun compiled_object_helper_function(function: CompiledFunction): bool =
    if !java_generator_string_has_prefix(function.name, "__capy_oo_")
    then false
    else if compiled_object_method_function(function)
    then true
    else if compiled_object_interface_method_function(function)
    then true
    else if compiled_object_field_init_function(function)
    then true
    else compiled_object_init_function(function)

/// Checks whether a compiled function should be skipped by regular Java function emission.
private fun java_skip_function(function: CompiledFunction): bool =
    if compiled_constant(function)
    then true
    else if imported_function(function)
    then true
    else compiled_object_helper_function(function)

/// Computes constant metadata for Java visibility.
private fun constant_java_visibility(function: CompiledFunction): String =
    java_visibility_prefix(function.visibility.replace("const:", ""))

/// Formats Java source text for functions.
private fun java_functions(functions: List[CompiledFunction], constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaNativeProviderScope): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_skip_function(function)
        then java_functions(functions[1:], constantBindings, module, allModules, nativeProviderScope)
        else java_function(function, constantBindings, module, allModules, nativeProviderScope) + newline() + java_functions(functions[1:], constantBindings, module, allModules, nativeProviderScope)

/// Formats Java source text for function.
private fun java_function(function: CompiledFunction, constantBindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaNativeProviderScope): String =
    let returnTypeReference = effective_function_return_type_with_module_constants(function, module, allModules, constantBindings)
    let returnType = java_type(returnTypeReference)
    let env = java_function_bindings(function) + constantBindings
    "    " + java_visibility_prefix(function.visibility) + "static " + returnType + " " + java_function_name(function) + "(" + java_function_parameters(function) + ") {" + newline()
    + java_function_body(function, returnTypeReference, env, module, allModules, nativeProviderScope)
    + "    }" + newline()

/// Computes the Java name for function.
private fun java_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else java_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

/// Computes the Java name for function call.
private fun java_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_function(name, module.functions) with
    case Some { function } -> java_function_name(function)
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> java_function_name(function)
        case None -> java_identifier(name)

/// Builds precomputed metadata for matching a requested function name.
private fun java_function_name_request(name: String): JavaFunctionNameRequest =
    JavaFunctionNameRequest { name: name, hasUppercase: string_has_uppercase(name) }

/// Checks whether function name matches a precomputed request.
private fun function_name_request_matches(request: JavaFunctionNameRequest, declared: String): bool =
    if request.name == declared
    then true
    else if !(declared ? "_")
    then false
    else if !request.hasUppercase
    then false
    else request.name == exported_function_name(declared)

/// Checks whether a string contains an uppercase character.
private fun string_has_uppercase(value: String): bool =
    string_has_uppercase_from(value, 0)

/// Checks whether a string contains an uppercase character.
private fun string_has_uppercase_from(value: String, idx: int): bool =
    if idx >= value.size().value
    then false
    else match value[idx] with
        case None -> false
        case Some { char } ->
            if "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char
            then true
            else string_has_uppercase_from(value, idx + 1)

/// Computes the name for exported function.
private fun exported_function_name(name: String): String =
    exported_function_name_chars(name, 0, false, "")

/// Computes the name for exported function name chars.
private fun exported_function_name_chars(name: String, idx: int, capitalizeNext: bool, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            if char == "_"
            then exported_function_name_chars(name, idx + 1, true, acc)
            else exported_function_name_chars(name, idx + 1, false, acc + exported_function_char(char, capitalizeNext))

/// Formats source text for exported function char.
private fun exported_function_char(char: String, capitalize: bool): String =
    if capitalize then uppercase_ascii_char(char) else char

/// Formats source text for uppercase ASCII char.
private fun uppercase_ascii_char(char: String): String =
    if char == "a" then "A"
    else if char == "b" then "B"
    else if char == "c" then "C"
    else if char == "d" then "D"
    else if char == "e" then "E"
    else if char == "f" then "F"
    else if char == "g" then "G"
    else if char == "h" then "H"
    else if char == "i" then "I"
    else if char == "j" then "J"
    else if char == "k" then "K"
    else if char == "l" then "L"
    else if char == "m" then "M"
    else if char == "n" then "N"
    else if char == "o" then "O"
    else if char == "p" then "P"
    else if char == "q" then "Q"
    else if char == "r" then "R"
    else if char == "s" then "S"
    else if char == "t" then "T"
    else if char == "u" then "U"
    else if char == "v" then "V"
    else if char == "w" then "W"
    else if char == "x" then "X"
    else if char == "y" then "Y"
    else if char == "z" then "Z"
    else char

/// Checks whether a function matches the extension method function metadata.
private fun extension_method_function(function: CompiledFunction): bool =
    last_dot_index(function.name) >= 0

/// Computes the compiled type for method receiver.
private fun method_receiver_type(function: CompiledFunction): CompiledTypeReference =
    schema_type_reference(method_owner_name(function.name))

/// Computes the name for method owner.
private fun method_owner_name(name: String): String =
    let idx = last_dot_index(name)
    if idx < 0 then "" else name[0, idx]

/// Computes the index used to split or rank last dot index.
private fun last_dot_index(name: String): int =
    last_dot_index_from(name, 0, -1)

/// Computes the index used to split or rank last dot index from.
private fun last_dot_index_from(name: String, idx: int, found: int): int =
    if idx >= name.size().value
    then found
    else match name[idx] with
        case None -> found
        case Some { char } ->
            let next = if char == "." then idx else found
            last_dot_index_from(name, idx + 1, next)

/// Computes the Java prefix for visibility.
private fun java_visibility_prefix(visibility: String): String =
    if visibility == "private"
    then "private "
    else if visibility == "local"
    then "public "
    else "public "

/// Emits Java expression text for function body.
private fun java_function_body(function: CompiledFunction, returnType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaNativeProviderScope): String =
    match nativeProviderScope.declarations.get(function.name) with
    case Some { declaration } -> java_native_provider_function_body(declaration, returnType, nativeProviderScope)
    case None ->
    if tail_recursive_function(function, env, module, allModules)
    then tail_recursive_function_body(function, returnType, env, module, allModules)
    else match function.body with
    case CompiledBlockExpression block ->
        let effectBody = effect_block_body(block, env, returnType, module, allModules, "        ")
        if !effectBody.is_empty()
        then effectBody
        else if !expression_emittable_as(function.body, returnType, env, module, allModules)
        then "        throw new UnsupportedOperationException(\"Unsupported CFUN expression at " + function.location.line + ":" + function.location.column + "\");" + newline()
        else block_statements(block.bindings, env, returnType, module, allModules, "        ")
            + "        return " + block_result_code(block, env, returnType, module, allModules) + ";" + newline()
    case _ ->
        if !expression_emittable_as(function.body, returnType, env, module, allModules)
        then "        throw new UnsupportedOperationException(\"Unsupported CFUN expression at " + function.location.line + ":" + function.location.column + "\");" + newline()
        else "        return " + expression_code(function.body, env, returnType, module, allModules) + ";" + newline()

private fun java_native_provider_index(catalog: NativeProviderCatalog): JavaNativeProviderIndex =
    JavaNativeProviderIndex {
        declarationsByModule: java_native_provider_declarations_by_module(catalog.declarations),
        bindings: java_native_provider_binding_dict(catalog.bindings)
    }

private fun java_native_provider_scope_for_module(module: CompiledModule, index: JavaNativeProviderIndex): JavaNativeProviderScope =
    match index.declarationsByModule.get(java_native_provider_module_key(module.name, module.path)) with
    case Some { declarations } -> JavaNativeProviderScope {
        declarations: declarations.declarations,
        bindings: index.bindings
    }
    case None -> JavaNativeProviderScope {
        declarations: java_empty_native_provider_declaration_dict(),
        bindings: index.bindings
    }

private fun java_empty_native_provider_declaration_dict(): Dict[CompiledNativeProviderDeclaration] =
    {:}

private fun java_native_provider_declarations_by_module(declarations: List[CompiledNativeProviderDeclaration]): Dict[JavaNativeProviderDeclarations] =
    java_native_provider_declarations_by_module_with_acc(declarations, {:})

private fun java_native_provider_declarations_by_module_with_acc(declarations: List[CompiledNativeProviderDeclaration], declarationsByModule: Dict[JavaNativeProviderDeclarations]): Dict[JavaNativeProviderDeclarations] =
    match declarations[0] with
    case None -> declarationsByModule
    case Some { declaration } ->
        java_native_provider_declarations_by_module_with_acc(declarations[1:], java_native_provider_add_declaration(declarationsByModule, declaration))

private fun java_native_provider_add_declaration(declarationsByModule: Dict[JavaNativeProviderDeclarations], declaration: CompiledNativeProviderDeclaration): Dict[JavaNativeProviderDeclarations] =
    let moduleKey = java_native_provider_module_key(declaration.sourceModuleName, declaration.sourceModulePath)
    let declarations = match declarationsByModule.get(moduleKey) with
        case Some { moduleDeclarations } -> moduleDeclarations.declarations
        case None -> java_empty_native_provider_declaration_dict()
    match declarations.get(declaration.providerName) with
    case Some _ -> declarationsByModule
    case None -> declarationsByModule + (moduleKey, JavaNativeProviderDeclarations {
        declarations: declarations + (declaration.providerName, declaration)
    })

private fun java_native_provider_binding_dict(bindings: List[CompiledNativeProviderBinding]): Dict[CompiledNativeProviderBinding] =
    java_native_provider_binding_dict_with_acc(bindings, {:})

private fun java_native_provider_binding_dict_with_acc(bindings: List[CompiledNativeProviderBinding], bindingIndex: Dict[CompiledNativeProviderBinding]): Dict[CompiledNativeProviderBinding] =
    match bindings[0] with
    case None -> bindingIndex
    case Some { binding } ->
        java_native_provider_binding_dict_with_acc(bindings[1:], java_native_provider_binding_dict_add(bindingIndex, binding))

private fun java_native_provider_binding_dict_add(bindingIndex: Dict[CompiledNativeProviderBinding], binding: CompiledNativeProviderBinding): Dict[CompiledNativeProviderBinding] =
    let key = java_native_provider_binding_key(binding.interfaceId, binding.qualifier)
    match bindingIndex.get(key) with
    case Some _ -> bindingIndex
    case None -> bindingIndex + (key, binding)

private fun java_native_provider_module_key(name: String, path: String): String =
    if path.is_empty()
    then name
    else path + "/" + name

private fun java_native_provider_binding_key(interfaceId: String, qualifier: String): String =
    interfaceId.size().value + "|" + interfaceId + "|" + qualifier

/// Emits Java expression text for native provider function body.
private fun java_native_provider_function_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, nativeProviderScope: JavaNativeProviderScope): String =
    match nativeProviderScope.bindings.get(java_native_provider_binding_key(declaration.interfaceId, declaration.qualifier)) with
    case Some { binding } -> {
        match binding.javaBinding with
        case Some { backend } -> java_native_provider_bound_body(declaration, returnType, backend)
        case None -> java_native_provider_not_wired_body(declaration)
    }
    case None -> java_native_provider_not_wired_body(declaration)

/// Emits Java expression text for native provider bound body.
private fun java_native_provider_bound_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, backend: NativeProviderBackendBinding): String =
    match backend.className with
    case Some { className } ->
        let targetType = if returnType.name == "Effect" then first_type_argument(returnType) else CompiledTypeReference { name: declaration.targetTypeName, arguments: [] }
        "        return capy.lang.Effect.delay(() -> ((" + boxed_java_type(targetType) + ") new " + className + "()));" + newline()
    case None -> java_native_provider_not_wired_body(declaration)

/// Emits Java expression text for native provider not wired body.
private fun java_native_provider_not_wired_body(declaration: CompiledNativeProviderDeclaration): String =
    "        return capy.lang.Effect.delay(() -> { throw new dev.capylang.NativeProviderException(\"NotWired: No native provider registered for interface `"
        + escape_java_string(declaration.interfaceId)
        + "` with qualifier `"
        + escape_java_string(declaration.qualifier)
        + "`.\"); });" + newline()

/// Emits expression text for effect block body.
private fun effect_block_body(block: CompiledBlockExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if returnType.name == "Effect" & effect_block_emittable(block.bindings, block.result, env, returnType, module, allModules)
    then indent + "return " + effect_block_expression(block.bindings, block.result, env, returnType, module, allModules, indent) + ";" + newline()
    else ""

/// Emits expression text for effect block expression.
private fun effect_block_expression(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> effect_block_result_expression(result, env, returnType, module, allModules)
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        if binding.operator == "<-"
        then effect_bind_expression(binding, localBinding, bindings[1:], result, env, returnType, module, allModules, indent)
        else effect_local_expression(binding, localBinding, valueType, bindings[1:], result, env, returnType, module, allModules, indent)

/// Emits expression text for effect block result expression.
private fun effect_block_result_expression(result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = expression_type(result, env, module, allModules)
    if resultType.name == "Effect"
    then expression_code(result, env, returnType, module, allModules)
    else "capy.lang.Effect.pure(" + expression_code(result, env, first_type_argument(returnType), module, allModules) + ")"

/// Emits expression text for effect bind expression.
private fun effect_bind_expression(binding: CompiledLetBinding, localBinding: JavaBinding, rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let wrapperType = binding_value_type(binding, env, module, allModules)
    expression_code(binding.value, env, wrapperType, module, allModules)
        + ".flatMap(" + localBinding.javaName + " -> "
        + effect_block_expression(rest, result, [localBinding] + env, returnType, module, allModules, indent + "    ")
        + ")"

/// Emits expression text for effect local expression.
private fun effect_local_expression(binding: CompiledLetBinding, localBinding: JavaBinding, valueType: CompiledTypeReference, rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    "((java.util.function.Supplier<" + java_type(returnType) + ">) () -> {" + newline()
        + indent + "    " + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, valueType, module, allModules) + ";" + newline()
        + indent + "    return " + effect_block_expression(rest, result, [localBinding] + env, returnType, module, allModules, indent + "    ") + ";" + newline()
        + indent + "}).get()"

/// Checks whether effect block can be emitted by the target backend.
private fun effect_block_emittable(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> expression_emittable(result, env, module, allModules)
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        if binding.operator == "<-"
        then binding_value_type(binding, env, module, allModules).name == "Effect"
            & expression_emittable(binding.value, env, module, allModules)
            & effect_block_emittable(bindings[1:], result, [localBinding] + env, returnType, module, allModules)
        else expression_emittable(binding.value, env, module, allModules)
            & effect_block_emittable(bindings[1:], result, [localBinding] + env, returnType, module, allModules)

/// Checks whether a function matches the tail recursive function metadata.
private fun tail_recursive_function(function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !expression_references_function(function.body, function.name)
    then false
    else if !tail_recursive_expression(function.body, function)
    then false
    else tail_recursive_body_emittable(function.body, function, env, module, allModules)

/// Checks whether tail recursive body can be emitted by the target backend.
private fun tail_recursive_body_emittable(expression: CompiledExpression, function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then if tail_self_call_compatible(function.parameters, call.arguments)
            then expressions_emittable(call.arguments, env, module, allModules)
            else false
        else expression_emittable(expression, env, module, allModules)
    case CompiledIfExpression ifExpression ->
        if truthy_expression_emittable(ifExpression.condition, env, module, allModules)
        then if tail_recursive_body_emittable(ifExpression.thenBranch, function, env, module, allModules)
            then tail_recursive_body_emittable(ifExpression.elseBranch, function, env, module, allModules)
            else false
        else false
    case CompiledBlockExpression block ->
        if let_bindings_emittable(block.bindings, env, module, allModules)
        then tail_recursive_body_emittable(block.result, function, block_env(block.bindings, env, module, allModules), module, allModules)
        else false
    case CompiledMatchExpression matchExpression ->
        if expression_emittable(matchExpression.value, env, module, allModules)
        then tail_match_cases_emittable(matchExpression.cases, expression_type(matchExpression.value, env, module, allModules), function, env, module, allModules)
        else false
    case _ -> expression_emittable(expression, env, module, allModules)

/// Checks whether tail match cases can be emitted by the target backend.
private fun tail_match_cases_emittable(cases: List[CompiledMatchCase], valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
        if tail_recursive_body_emittable(matchCase.body, function, caseEnv, module, allModules)
        then if matchCase.hasGuard
            then if truthy_expression_emittable(matchCase.guard, caseEnv, module, allModules)
                then tail_match_case_literal_and_rest_emittable(matchCase, cases[1:], valueType, function, env, module, allModules)
                else false
            else tail_match_case_literal_and_rest_emittable(matchCase, cases[1:], valueType, function, env, module, allModules)
        else false

private fun tail_match_case_literal_and_rest_emittable(matchCase: CompiledMatchCase, rest: List[CompiledMatchCase], valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if matchCase.hasLiteral
    then if expression_emittable(matchCase.literal, env, module, allModules)
        then tail_match_case_rest_emittable(rest, valueType, function, env, module, allModules)
        else false
    else tail_match_case_rest_emittable(rest, valueType, function, env, module, allModules)

private fun tail_match_case_rest_emittable(rest: List[CompiledMatchCase], valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if rest.is_empty()
    then true
    else tail_match_cases_emittable(rest, valueType, function, env, module, allModules)

/// Checks whether an expression has the tail recursive expression shape.
private fun tail_recursive_expression(expression: CompiledExpression, function: CompiledFunction): bool =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then if tail_self_call_compatible(function.parameters, call.arguments)
            then !expressions_reference_function(call.arguments, function.name)
            else false
        else !expressions_reference_function(call.arguments, function.name)
    case CompiledIfExpression ifExpression ->
        if expression_references_function(ifExpression.condition, function.name)
        then false
        else if tail_recursive_expression(ifExpression.thenBranch, function)
        then tail_recursive_expression(ifExpression.elseBranch, function)
        else false
    case CompiledBlockExpression block ->
        if let_bindings_reference_function(block.bindings, function.name)
        then false
        else tail_recursive_expression(block.result, function)
    case CompiledMatchExpression matchExpression ->
        if expression_references_function(matchExpression.value, function.name)
        then false
        else tail_match_cases_recursive(matchExpression.cases, function)
    case _ -> !expression_references_function(expression, function.name)

/// Checks whether the current value satisfies the tail match cases recursive rule for compiler processing.
private fun tail_match_cases_recursive(cases: List[CompiledMatchCase], function: CompiledFunction): bool =
    match cases[0] with
    case None -> true
    case Some { matchCase } ->
        if matchCase.hasLiteral
        then if expression_references_function(matchCase.literal, function.name)
            then false
            else tail_match_case_guard_and_body_recursive(matchCase, cases[1:], function)
        else tail_match_case_guard_and_body_recursive(matchCase, cases[1:], function)

private fun tail_match_case_guard_and_body_recursive(matchCase: CompiledMatchCase, rest: List[CompiledMatchCase], function: CompiledFunction): bool =
    if matchCase.hasGuard
    then if expression_references_function(matchCase.guard, function.name)
        then false
        else tail_match_case_body_and_rest_recursive(matchCase, rest, function)
    else tail_match_case_body_and_rest_recursive(matchCase, rest, function)

private fun tail_match_case_body_and_rest_recursive(matchCase: CompiledMatchCase, rest: List[CompiledMatchCase], function: CompiledFunction): bool =
    if tail_recursive_expression(matchCase.body, function)
    then tail_match_cases_recursive(rest, function)
    else false

/// Checks whether a call has the tail self call compatible shape.
private fun tail_self_call_compatible(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some _ ->
        match arguments[0] with
        case None -> false
        case Some _ -> tail_self_call_compatible(parameters[1:], arguments[1:])

/// Formats the recursive tail segment for tail recursive function body.
private fun tail_recursive_function_body(function: CompiledFunction, returnType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "        while (true) {" + newline()
        + tail_expression_statements(function.body, function, env, returnType, module, allModules, "            ")
        + "        }" + newline()

/// Emits generated statements for tail expression.
private fun tail_expression_statements(expression: CompiledExpression, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then tail_self_call_statements(function.parameters, call.arguments, call.location, env, module, allModules, indent)
        else indent + "return " + expression_code(expression, env, expectedType, module, allModules) + ";" + newline()
    case CompiledIfExpression ifExpression ->
        indent + "if (" + truthy_expression_code(ifExpression.condition, env, module, allModules) + ") {" + newline()
            + tail_expression_statements(ifExpression.thenBranch, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "} else {" + newline()
            + tail_expression_statements(ifExpression.elseBranch, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "}" + newline()
    case CompiledBlockExpression block ->
        block_statements(block.bindings, env, expectedType, module, allModules, indent)
            + tail_expression_statements(block.result, function, block_env(block.bindings, env, module, allModules), expectedType, module, allModules, indent)
    case CompiledMatchExpression matchExpression ->
        tail_match_expression_statements(matchExpression, function, env, expectedType, module, allModules, indent)
    case _ -> indent + "return " + expression_code(expression, env, expectedType, module, allModules) + ";" + newline()

/// Emits generated statements for tail self call.
private fun tail_self_call_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], location: CompiledSourceLocation, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    tail_self_call_temp_statements(parameters, arguments, location, env, module, allModules, indent, 0)
        + tail_self_call_assign_statements(parameters, location, indent, 0)
        + indent + "continue;" + newline()

/// Emits generated statements for tail self call temp.
private fun tail_self_call_temp_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], location: CompiledSourceLocation, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String, idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        match arguments[0] with
        case None -> ""
        case Some { argument } ->
            let tempName = tail_argument_temp_name(parameter, location, idx)
            indent + java_type(parameter.typeReference) + " " + tempName + " = "
                + expression_code(argument, env, parameter.typeReference, module, allModules) + ";" + newline()
                + tail_self_call_temp_statements(parameters[1:], arguments[1:], location, env, module, allModules, indent, idx + 1)

/// Emits generated statements for tail self call assign.
private fun tail_self_call_assign_statements(parameters: List[CompiledFunctionParameter], location: CompiledSourceLocation, indent: String, idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        indent + java_identifier(parameter.name) + " = " + tail_argument_temp_name(parameter, location, idx) + ";" + newline()
            + tail_self_call_assign_statements(parameters[1:], location, indent, idx + 1)

/// Computes the name for tail argument temp.
private fun tail_argument_temp_name(parameter: CompiledFunctionParameter, location: CompiledSourceLocation, idx: int): String =
    "__capy_tail_" + java_identifier(parameter.name) + "_" + location.line + "_" + location.column + "_" + idx

/// Emits generated statements for tail match expression.
private fun tail_match_expression_statements(matchExpression: CompiledMatchExpression, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let valueType = expression_type(matchExpression.value, env, module, allModules)
    let valueCode = expression_code(matchExpression.value, env, valueType, module, allModules)
    let matchValueName = "__capy_match_value_" + matchExpression.location.line + "_" + matchExpression.location.column
    let cases = ordered_match_cases(matchExpression.cases)
    indent + java_type(valueType) + " " + matchValueName + " = " + valueCode + ";" + newline()
        + tail_match_case_statements(cases, matchValueName, valueType, function, env, expectedType, module, allModules, indent)
        + indent + "return unsupported(\"match\");" + newline()

/// Emits generated statements for tail match case.
private fun tail_match_case_statements(cases: List[CompiledMatchCase], valueCode: String, valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match cases[0] with
    case None -> ""
    case Some { matchCase } ->
        indent + "if (" + match_case_condition_code(matchCase, valueCode, valueType, env, module, allModules) + ") {" + newline()
            + match_binding_statements(matchCase.bindings, matchCase, valueCode, valueType, 0, module, allModules, indent + "    ")
            + tail_match_guarded_statement(matchCase, valueType, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "}" + newline()
            + tail_match_case_statements(cases[1:], valueCode, valueType, function, env, expectedType, module, allModules, indent)

/// Emits one generated statement for tail match guarded.
private fun tail_match_guarded_statement(matchCase: CompiledMatchCase, valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
    if matchCase.hasGuard
    then indent + "if (" + truthy_expression_code(matchCase.guard, caseEnv, module, allModules) + ") {" + newline()
        + tail_expression_statements(matchCase.body, function, caseEnv, expectedType, module, allModules, indent + "    ")
        + indent + "}" + newline()
    else tail_expression_statements(matchCase.body, function, caseEnv, expectedType, module, allModules, indent)

/// Formats Java source text for parameters.
private fun java_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        java_parameter(parameter) + java_parameter_tail(parameters[1:])

/// Formats the recursive tail segment for parameter.
private fun java_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_parameter(parameter) + java_parameter_tail(parameters[1:])

/// Formats Java source text for parameter.
private fun java_parameter(parameter: CompiledFunctionParameter): String =
    java_type(parameter.typeReference) + " " + java_identifier(parameter.name)

/// Formats top level Java parameters for generated emission.
private fun top_level_java_parameters(parameters: List[CompiledFunctionParameter], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        top_level_java_parameter(parameter, module, allModules) + top_level_java_parameter_tail(parameters[1:], module, allModules)

/// Formats the recursive tail segment for top-level Java parameter.
private fun top_level_java_parameter_tail(parameters: List[CompiledFunctionParameter], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", " + top_level_java_parameter(parameter, module, allModules) + top_level_java_parameter_tail(parameters[1:], module, allModules)

/// Formats one top level Java parameter for generated emission.
private fun top_level_java_parameter(parameter: CompiledFunctionParameter, module: CompiledModule, allModules: List[CompiledModule]): String =
    top_level_java_type(parameter.typeReference, module, allModules) + " " + java_identifier(parameter.name)

/// Formats function parameters for Java emission.
private fun java_function_parameters(function: CompiledFunction): String =
    if extension_method_function(function)
    then java_type(method_receiver_type(function)) + " " + java_identifier("this") + java_method_parameter_tail(function.parameters)
    else java_parameters(function.parameters)

/// Formats the recursive tail segment for method parameter.
private fun java_method_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else match parameters[0] with
        case Some { parameter } ->
            if parameter.name == "this"
            then java_method_parameter_tail(parameters[1:])
            else ", " + java_parameters(parameters)
        case None -> ""

/// Creates Java name/type bindings for function.
private fun java_function_bindings(function: CompiledFunction): List[JavaBinding] =
    if extension_method_function(function)
    then
        let receiverType = method_receiver_type(function)
        [java_binding("this", receiverType)]
            + parameter_bindings(function.parameters)
            + [java_binding_with_java_name("receiver", receiverType, java_identifier("this"))]
    else parameter_bindings(function.parameters)

/// Creates name/type bindings for parameter.
private fun parameter_bindings(parameters: List[CompiledFunctionParameter]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [java_binding(parameter.name, parameter.typeReference)] + parameter_bindings(parameters[1:])

/// Emits generated code for expression.
private fun expression_code(
    expression: CompiledExpression,
    env: List[JavaBinding],
    expectedType: CompiledTypeReference,
    module: CompiledModule,
    allModules: List[CompiledModule]
): String =
    match expression with
    case CompiledUnsupportedExpression unsupported ->
        if compiled_placeholder_source(unsupported.source)
        then placeholder_code(unsupported, module)
        else "unsupported(\"" + escape_java_string(unsupported.source) + "\")"
    case CompiledIntLiteral literal -> numeric_widening_code(int_literal_code(literal, expectedType), expression_type(expression, env, module, allModules), expectedType)
    case CompiledLongLiteral literal -> numeric_widening_code(literal.source, long_type(), expectedType)
    case CompiledFloatLiteral literal -> numeric_widening_code(literal.source, float_type(), expectedType)
    case CompiledDoubleLiteral literal -> literal.source
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> "\"" + escape_java_string(literal.value) + "\""
    case CompiledVariableExpression variable -> variable_expression_code(variable, env, expectedType, module, allModules)
    case CompiledIfExpression ifExpression -> "("
        + truthy_expression_code(ifExpression.condition, env, module, allModules)
        + " ? " + expression_code(ifExpression.thenBranch, env, expectedType, module, allModules)
        + " : " + expression_code(ifExpression.elseBranch, env, expectedType, module, allModules)
        + ")"
    case CompiledBinaryExpression binary -> binary_expression_code(binary, env, expectedType, module, allModules)
    case CompiledUnaryExpression unary -> unary_expression_code(unary, env, expectedType, module, allModules)
    case CompiledFunctionCallExpression call ->
        if partial_function_call(call)
        then partial_function_call_code(call, env, expectedType, module, allModules)
        else value_conversion_code(function_call_code(call, env, expectedType, module, allModules), function_call_type(call, env, module, allModules), expectedType, module, allModules)
    case CompiledFunctionReferenceExpression reference -> function_reference_code(reference, expectedType, module, allModules)
    case CompiledMethodCallExpression call ->
        if partial_method_call(call)
        then partial_method_call_code(call, env, expectedType, module, allModules)
        else value_conversion_code(method_call_code(call, env, expectedType, module, allModules), method_call_type(call, env, module, allModules), expectedType, module, allModules)
    case CompiledWithExpression withExpression -> value_conversion_code(with_expression_code(withExpression, env, module, allModules), with_expression_type(withExpression, env, module, allModules), expectedType, module, allModules)
    case CompiledLambdaExpression lambda -> lambda_expression_code(lambda, env, expectedType, module, allModules)
    case CompiledListLiteral literal -> list_literal_code(literal, env, expectedType, module, allModules)
    case CompiledSetLiteral literal -> "java.util.Set.of(" + expression_list_code(literal.values, env, module, allModules) + ")"
    case CompiledDictLiteral literal -> dict_code(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> tuple_literal_code(literal, env, expectedType, module, allModules)
    case CompiledIndexExpression index -> index_code(index, env, expectedType, module, allModules)
    case CompiledDataLiteral literal -> data_literal_code(literal, env, expectedType, module, allModules)
    case CompiledFieldAccessExpression access -> field_access_code(access, env, expectedType, module, allModules)
    case CompiledReduceExpression reduce -> reduce_expression_code(reduce, env, expectedType, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_code(matchExpression, env, expectedType, module, allModules)
    case CompiledThrowExpression throwExpression -> throw_expression_code(throwExpression, env, expectedType, module, allModules)
    case CompiledTryCatchExpression tryCatch -> try_catch_expression_code(tryCatch, env, expectedType, module, allModules)
    case CompiledBlockExpression block -> block_expression_code(block, env, expectedType, module, allModules)

/// Emits generated code for variable expression.
private fun variable_expression_code(variable: CompiledVariableExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding_exists(variable.name, env)
    then value_conversion_code(lookup_binding_java_name(variable.name, env), lookup_binding(variable.name, env), expectedType, module, allModules)
    else if qualified_enum_value_name(variable.name, module, allModules)
    then value_conversion_code(
        enum_qualified_value_code(variable.name, module, allModules),
        data_type_reference(enum_qualified_type_name(variable.name)),
        expectedType,
        module,
        allModules
    )
    else if variable.name == "DEFAULT_FAILED_EXIT_CODE" & program_member_imported(variable.name, module.imports)
    then numeric_widening_code("capy.lang.Program.DEFAULT_FAILED_EXIT_CODE", int_type(), expectedType)
    else match imported_stdlib_constant(variable.name, module.imports) with
        case Some { constant } -> value_conversion_code(constant.javaName, constant.typeReference, expectedType, module, allModules)
        case None ->
            match find_constant_in_scope(variable.name, module, allModules) with
            case Some { function } -> value_conversion_code(java_identifier(variable.name), effective_function_return_type(function, module, allModules), expectedType, module, allModules)
            case None -> numeric_widening_code(java_identifier(variable.name), object_type(), expectedType)

/// Emits generated code for placeholder.
private fun placeholder_code(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    "__capy_not_implemented(\"" + escape_java_string(placeholder_message(placeholder, module)) + "\")"

/// Formats source text for placeholder message.
private fun placeholder_message(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    let functionName = placeholder_function_name(placeholder.source)
    if functionName.is_empty()
    then "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": placeholder expression is not yet implemented"
    else "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": the function `" + functionName + "` is not yet implemented"

/// Extracts compiled metadata for placeholder source.
private fun compiled_placeholder_source(source: String): bool =
    java_generator_string_has_prefix(source, "__capy_placeholder__|")

/// Computes the name for placeholder function.
private fun placeholder_function_name(source: String): String =
    if compiled_placeholder_source(source)
    then source["__capy_placeholder__|".size().value, source.size().value]
    else ""

/// Emits generated code for binary expression.
private fun binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = expression_type(binary.left, env, module, allModules)
    if result_reduce_operator_expression(binary, leftType)
    then result_reduce_method_code(result_reduce_operator_call(binary), env, expectedType, module, allModules)
    else if async_pipe_expression(binary, leftType)
    then async_pipe_code(binary, leftType, expectedType, env, module, allModules)
    else if result_pipe_expression(binary, leftType)
    then result_pipe_code(binary, leftType, expectedType, env, module, allModules)
    else if option_pipe_expression(binary, leftType)
    then option_pipe_code(binary, leftType, env, module, allModules)
    else if collection_pipe_chained_method_expression(binary, leftType)
    then expression_code(collection_pipe_chained_method_call(binary), env, expectedType, module, allModules)
    else if collection_pipe_expression(binary, leftType)
    then collection_pipe_code(binary, leftType, env, module, allModules)
    else
        let rightType = expression_type(binary.right, env, module, allModules)
        let naturalResultType = binary_result_type(binary.operator, leftType, rightType)
        let resultType = contextual_binary_result_type(naturalResultType, expectedType)
        if collection_plus_expression(binary.operator, leftType, rightType)
        then collection_plus_code(binary, leftType, rightType, env, module, allModules)
        else if collection_minus_expression(binary.operator, leftType, rightType)
        then collection_minus_code(binary, leftType, rightType, env, module, allModules)
        else if binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
        then binary_extension_operator_code_with_left_type(binary, leftType, env, module, allModules)
        else if stdlib_path_slash_expression(binary, leftType, module)
        then stdlib_path_slash_code(binary, env, module, allModules)
        else if set_binary_expression(binary.operator, leftType, rightType)
        then set_binary_code(binary, leftType, rightType, env, module, allModules)
        else if regex_binary_expression(binary.operator, leftType)
        then regex_binary_code(binary, env, module, allModules)
        else if boolean_binary_operator(binary.operator)
        then "(" + truthy_expression_code(binary.left, env, module, allModules)
            + " " + java_boolean_operator(binary.operator) + " "
            + truthy_expression_code(binary.right, env, module, allModules)
            + ")"
        else if string_concat_expression(binary.operator, leftType, rightType)
        then "(" + expression_code(binary.left, env, string_concat_operand_type(leftType), module, allModules)
            + " + "
            + expression_code(binary.right, env, string_concat_operand_type(rightType), module, allModules)
            + ")"
        else if string_left_numeric_operator(binary.operator, leftType, rightType)
        then "(" + expression_code(binary.left, env, leftType, module, allModules)
            + " + "
            + expression_code(binary.right, env, rightType, module, allModules)
            + ")"
        else if binary.operator == "^"
        then power_expression_code(binary, resultType, env, module, allModules)
        else if binary.operator == ".nand."
        then byte_result_code("(~(" + expression_code(binary.left, env, leftType, module, allModules)
            + " & "
            + expression_code(binary.right, env, rightType, module, allModules)
            + "))", expectedType)
        else if bitwise_binary_operator(binary.operator)
        then byte_result_code("(" + expression_code(binary.left, env, leftType, module, allModules)
            + " " + java_bitwise_operator(binary.operator) + " "
            + expression_code(binary.right, env, rightType, module, allModules)
            + ")", expectedType)
        else if binary.operator == "?"
        then
            if leftType.name == "Dict"
            then expression_code(binary.left, env, leftType, module, allModules)
                + ".containsKey(" + expression_code(binary.right, env, string_type(), module, allModules) + ")"
            else expression_code(binary.left, env, leftType, module, allModules)
                + ".contains(" + expression_code(binary.right, env, rightType, module, allModules) + ")"
        else if string_equality_operator(binary.operator, leftType, rightType)
        then string_equality_code(binary, leftType, rightType, env, module, allModules)
        else if object_equality_operator(binary.operator, leftType, rightType)
        then object_equality_code(binary, leftType, rightType, env, module, allModules)
        else if binary.operator == "%" & resultType.name == "byte"
        then "((byte) (" + expression_code(binary.left, env, leftType, module, allModules)
            + " % "
            + expression_code(binary.right, env, rightType, module, allModules)
            + "))"
        else byte_result_code("(" + expression_code(binary.left, env, resultType, module, allModules)
            + " " + binary.operator + " "
            + expression_code(binary.right, env, resultType, module, allModules)
            + ")", resultType)

/// Computes the compiled type for contextual binary result.
private fun contextual_binary_result_type(naturalResultType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if numeric_type(naturalResultType)
    then if type_assignable(expectedType, naturalResultType) then expectedType else naturalResultType
    else naturalResultType

/// Checks whether an expression has the collection plus expression shape.
private fun collection_plus_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if operator == "+"
    then list_plus_expression(leftType, rightType) | set_plus_expression(leftType, rightType) | dict_plus_expression(leftType, rightType)
    else false

/// Checks whether an expression has the collection minus expression shape.
private fun collection_minus_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if operator == "-"
    then list_minus_expression(leftType, rightType) | set_minus_expression(leftType, rightType) | dict_minus_expression(leftType, rightType)
    else false

/// Checks whether an expression has the list plus expression shape.
private fun list_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "List" then !rightType.name.is_empty() else false

/// Checks whether an expression has the list minus expression shape.
private fun list_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "List" then !rightType.name.is_empty() else false

/// Checks whether an expression has the set plus expression shape.
private fun set_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "Set" then !rightType.name.is_empty() else false

/// Checks whether an expression has the set minus expression shape.
private fun set_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "Set" then !rightType.name.is_empty() else false

/// Checks whether an expression has the dict plus expression shape.
private fun dict_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "Dict" then rightType.name == "Dict" | rightType.name == "Tuple" else false

/// Checks whether an expression has the dict minus expression shape.
private fun dict_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    if leftType.name == "Dict" then rightType.name == "Dict" | rightType.name == "String" else false

/// Emits generated code for collection plus.
private fun collection_plus_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    if leftType.name == "List"
    then
        if rightType.name == "List"
        then "__capy_list_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_list_append(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if leftType.name == "Set"
    then
        if rightType.name == "Set"
        then "__capy_set_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_set_append(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if rightType.name == "Tuple"
    then "__capy_dict_append(" + leftCode + ", " + expression_code(binary.right, env, rightType, module, allModules) + ")"
    else "__capy_dict_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"

/// Emits generated code for collection minus.
private fun collection_minus_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    if leftType.name == "Dict"
    then
        if rightType.name == "Dict"
        then "__capy_dict_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_dict_remove(" + leftCode + ", " + expression_code(binary.right, env, string_type(), module, allModules) + ")"
    else if leftType.name == "Set"
    then
        if rightType.name == "Set"
        then "__capy_set_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_set_remove(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if rightType.name == "List"
    then "__capy_list_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
    else "__capy_list_remove(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"

/// Checks whether an expression has the set binary expression shape.
private fun set_binary_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Set" & rightType.name == "Set" & set_binary_operator(operator)

/// Checks whether an operator belongs to the set binary operator category.
private fun set_binary_operator(operator: String): bool =
    set_predicate_operator(operator) | set_algebra_operator(operator)

/// Checks whether an operator belongs to the set predicate operator category.
private fun set_predicate_operator(operator: String): bool =
    operator == "⊆" | operator == "⊂" | operator == "⊇" | operator == "⊃"

/// Checks whether an operator belongs to the set algebra operator category.
private fun set_algebra_operator(operator: String): bool =
    operator == "∪" | operator == "∩" | operator == "△" | operator == "×"

/// Emits generated code for set binary.
private fun set_binary_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    let rightCode = expression_code(binary.right, env, rightType, module, allModules)
    if binary.operator == "⊆"
    then "__capy_set_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊂"
    then "__capy_set_proper_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊇"
    then "__capy_set_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "⊃"
    then "__capy_set_proper_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "∪"
    then "__capy_set_concat(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "∩"
    then "__capy_set_intersection(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "△"
    then "__capy_set_symmetric_difference(" + leftCode + ", " + rightCode + ")"
    else "__capy_set_cartesian_product(" + leftCode + ", " + rightCode + ")"

/// Checks whether an operator belongs to the string equality operator category.
private fun string_equality_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "==" | operator == "!=") & (leftType.name == "String" | rightType.name == "String")

/// Emits generated code for string equality.
private fun string_equality_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = "java.util.Objects.equals("
        + expression_code(binary.left, env, leftType, module, allModules)
        + ", "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    if binary.operator == "!=" then "(!" + code + ")" else code

/// Checks whether an operator belongs to the object equality operator category.
private fun object_equality_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "==" | operator == "!=")
        & object_equality_type(leftType)
        & object_equality_type(rightType)

/// Checks whether a type reference matches the object equality type rule.
private fun object_equality_type(type: CompiledTypeReference): bool =
    type.name.is_empty()
        | type.name == "any"
        | (type.name != "bool" & !numeric_type(type))

/// Emits generated code for object equality.
private fun object_equality_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = "java.util.Objects.equals("
        + expression_code(binary.left, env, leftType, module, allModules)
        + ", "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    if binary.operator == "!=" then "(!" + code + ")" else code

/// Emits generated code for power expression.
private fun power_expression_code(binary: CompiledBinaryExpression, resultType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if resultType.name == "byte"
    then "((byte) __capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + "))"
    else if resultType.name == "int"
    then "__capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + ")"
    else if resultType.name == "long"
    then "__capy_pow_long("
        + expression_code(binary.left, env, long_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, long_type(), module, allModules)
        + ")"
    else if resultType.name == "float"
    then "((float) java.lang.Math.pow("
        + expression_code(binary.left, env, float_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, float_type(), module, allModules)
        + "))"
    else "java.lang.Math.pow("
        + expression_code(binary.left, env, double_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, double_type(), module, allModules)
        + ")"

/// Emits generated code for unary expression.
private fun unary_expression_code(unary: CompiledUnaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(!" + truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then byte_result_code("(~" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else if unary.operator == "-"
    then byte_result_code("(-" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else "(" + unary.operator + expression_code(unary.expression, env, expectedType, module, allModules) + ")"

/// Emits generated code for byte result.
private fun byte_result_code(expression: String, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" then "((byte) " + expression + ")" else expression

/// Emits generated code for truthy expression.
private fun truthy_expression_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(expression, env, module, allModules)
    truthy_code(expression_code(expression, env, type, module, allModules), type)

/// Emits generated code for truthy.
private fun truthy_code(code: String, type: CompiledTypeReference): String =
    if type.name == "bool"
    then code
    else if integer_type(type)
    then "(" + code + " != 0)"
    else if type.name == "float"
    then "(" + code + " != 0.0f)"
    else if type.name == "double"
    then "(" + code + " != 0.0)"
    else if type.name == "String"
    then "(!" + code + ".isEmpty())"
    else if type.name == "List" | type.name == "Set" | type.name == "Dict"
    then "(!" + code + ".isEmpty())"
    else "__capy_truthy(" + code + ")"

/// Checks whether an operator belongs to the binary operator category.
private fun bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

/// Maps bitwise to the Java operator category.
private fun java_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

/// Checks whether an operator belongs to the binary operator category.
private fun boolean_binary_operator(operator: String): bool =
    operator == "&" | operator == "|"

/// Maps boolean to the Java operator category.
private fun java_boolean_operator(operator: String): String =
    if operator == "&" then "&&" else "||"

/// Checks whether an operator belongs to the binary extension operator expression with left type category.
private fun binary_extension_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some _ -> true
    case None -> false

/// Computes the compiled type for binary extension operator code with left.
private fun binary_extension_operator_code_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } -> extension_method_call_code(function, binary_extension_method_call(binary), env, module, allModules)
    case None -> "unsupported(\"extension operator\")"

/// Computes the compiled type for binary extension operator type with left.
private fun binary_extension_operator_type_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } -> bound_extension_method_return_type(function, leftType)
    case None -> object_type()

/// Checks whether binary extension operator emittable with left type can be emitted by the target backend.
private fun binary_extension_operator_emittable_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } ->
        let parameters = bound_extension_method_parameters(function, leftType)
        concrete_return_type(bound_extension_method_return_type(function, leftType))
            & expression_emittable(binary.left, env, module, allModules)
            & extension_operator_arguments_emittable(parameters, [binary.right], env, module, allModules)
    case None -> false

/// Checks whether extension operator arguments can be emitted by the target backend.
private fun extension_operator_arguments_emittable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            extension_operator_argument_emittable(parameter.typeReference, argument, env, module, allModules)
                & extension_operator_arguments_emittable(parameters[1:], arguments[1:], env, module, allModules)

/// Checks whether extension operator argument can be emitted by the target backend.
private fun extension_operator_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentType = expression_type(argument, env, module, allModules)
    parameter_argument_emittable(target, argument, env, module, allModules)
        & (
            parameter_argument_assignable(target, argument, env, module, allModules)
            | (function_type(target) & function_type(argumentType))
        )

/// Resolves expression metadata for binary extension method call.
private fun binary_extension_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: binary.left,
        name: binary.operator,
        arguments: [binary.right],
        location: binary.location
    }

/// Checks whether an expression has the result pipe expression shape.
private fun result_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    (binary.operator == "|" | binary.operator == "|*")
        & lambda_expression(binary.right)
        & result_pipe_receiver(binary.left, leftType)

/// Checks whether a receiver type matches the result pipe receiver rule.
private fun result_pipe_receiver(left: CompiledExpression, leftType: CompiledTypeReference): bool =
    result_type_name(leftType.name)
        | result_constructor_type(leftType.name)
        | match left with
            case CompiledDataLiteral literal -> result_constructor_type(literal.typeName)
            case CompiledBinaryExpression binary -> result_pipe_expression(binary, leftType)
            case _ -> false

/// Checks whether an operator belongs to the result reduce operator expression category.
private fun result_reduce_operator_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    binary.operator == "|>"
        & result_type_name(leftType.name)
        & result_reduce_operator_arguments_shape(binary.right)

/// Checks whether an operator belongs to the result reduce operator arguments shape category.
private fun result_reduce_operator_arguments_shape(expression: CompiledExpression): bool =
    match expression with
    case CompiledTupleLiteral literal -> result_reduce_method_arguments(literal.values)
    case _ -> false

/// Resolves expression metadata for result reduce operator call.
private fun result_reduce_operator_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: binary.left,
        name: "reduce",
        arguments: result_reduce_operator_arguments(binary.right),
        location: binary.location
    }

/// Formats result reduce operator arguments for generated emission.
private fun result_reduce_operator_arguments(expression: CompiledExpression): List[CompiledExpression] =
    match expression with
    case CompiledTupleLiteral literal -> literal.values
    case _ -> []

/// Checks whether a type reference matches the result constructor type rule.
private fun result_constructor_type(typeName: String): bool =
    result_success_constructor(typeName) | result_error_constructor(typeName)

/// Checks whether constructor metadata matches the result success constructor rule.
private fun result_success_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Result", "Success")

/// Checks whether constructor metadata matches the result error constructor rule.
private fun result_error_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Result", "Error")

/// Checks whether an expression has the option pipe expression shape.
private fun option_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    (binary.operator == "|" | binary.operator == "|-" | binary.operator == "|*")
        & lambda_expression(binary.right)
        & option_pipe_receiver(binary.left, leftType)

/// Checks whether a receiver type matches the option pipe receiver rule.
private fun option_pipe_receiver(left: CompiledExpression, leftType: CompiledTypeReference): bool =
    option_type_name(leftType.name)
        | option_constructor_type(leftType.name)
        | match left with
            case CompiledDataLiteral literal -> option_constructor_type(literal.typeName)
            case CompiledBinaryExpression binary -> option_pipe_expression(binary, leftType)
            case _ -> false

/// Emits generated code for option pipe.
private fun option_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    let receiverCode = "((java.util.Optional<" + boxed_java_type(valueType) + ">) __capy_optional_value("
        + expression_code(binary.left, env, leftType, module, allModules)
        + "))"
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|"
        then receiverCode + ".map(" + lambda_code_for_value(lambda, valueType, expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules), env, module, allModules) + ")"
        else if binary.operator == "|*"
        then receiverCode + ".flatMap(" + option_flat_map_lambda_code(lambda, valueType, env, module, allModules) + ")"
        else receiverCode + ".filter(" + option_filter_lambda_code(lambda, valueType, env, module, allModules) + ")"
    case _ -> "unsupported(\"option pipe\")"

/// Emits generated code for option filter lambda.
private fun option_filter_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyCode = "!(" + truthy_expression_code(lambda.body, lambdaEnv, module, allModules) + ")"
    lambda_code_with_result(lambda.parameters, valueType, bodyCode)

/// Emits generated code for option flat map lambda.
private fun option_flat_map_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyType = expression_type(lambda.body, lambdaEnv, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, expression_code(lambda.body, lambdaEnv, bodyType, module, allModules))

/// Computes the compiled type for option pipe value.
private fun option_pipe_value_type(left: CompiledExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_type_name(leftType.name)
    then first_type_argument(leftType)
    else match left with
        case CompiledDataLiteral literal -> option_literal_value_type(literal, env, module, allModules)
        case CompiledBinaryExpression binary ->
            let resultType = option_pipe_result_type(binary, expression_type(binary.left, env, module, allModules), env, module, allModules)
            if option_type_name(resultType.name) then first_type_argument(resultType) else object_type()
        case _ -> object_type()

/// Computes the compiled type for option literal value.
private fun option_literal_value_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_some_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } -> expression_type(field.value, env, module, allModules)
        case None -> object_type()
    else object_type()

/// Computes the compiled type for option pipe result.
private fun option_pipe_result_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|-"
        then option_type(valueType)
        else
            let bodyType = expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
            if binary.operator == "|*" & option_type_name(bodyType.name)
            then bodyType
            else option_type(bodyType)
    case _ -> option_type(valueType)

/// Checks whether an expression has the async pipe expression shape.
private fun async_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    (binary.operator == "|" | binary.operator == "|*")
        & async_type_name(leftType.name)
        & lambda_expression(binary.right)

/// Emits generated code for async pipe.
private fun async_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = first_type_argument(leftType)
    let resultType = async_pipe_result_type(binary, leftType, env, module, allModules)
    let payloadType = if async_type_name(expectedType.name) then first_type_argument(expectedType) else first_type_argument(resultType)
    let receiverCode = async_receiver_code(binary.left, leftType, env, module, allModules)
    let methodName = if binary.operator == "|*" then "flatMap" else "map"
    let mapperExpectedType = if binary.operator == "|*" then result_type(payloadType) else payloadType
    receiverCode + "." + methodName + "(" + async_pipe_callable_code(binary.right, valueType, mapperExpectedType, env, module, allModules) + ")"

/// Emits generated code for async pipe callable.
private fun async_pipe_callable_code(mapper: CompiledExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match mapper with
    case CompiledLambdaExpression lambda -> lambda_code_for_value(lambda, valueType, expectedType, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> function_reference_lambda_code(reference, valueType, expectedType, module, allModules)
    case _ -> "ignored -> unsupported(\"async pipe\")"

/// Computes the compiled type for async pipe result.
private fun async_pipe_result_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = first_type_argument(leftType)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let bodyType = expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
        if binary.operator == "|*"
        then if result_type_name(bodyType.name) then async_type(first_type_argument(bodyType)) else async_type(object_type())
        else async_type(bodyType)
    case CompiledFunctionReferenceExpression reference ->
        let bodyType = function_reference_type(reference, module, allModules)
        if binary.operator == "|*"
        then if result_type_name(bodyType.name) then async_type(first_type_argument(bodyType)) else async_type(object_type())
        else async_type(bodyType)
    case _ -> async_type(object_type())

/// Emits generated code for result pipe.
private fun result_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binary.operator == "|*"
    then result_flat_pipe_code(binary, leftType, expectedType, env, module, allModules)
    else result_map_pipe_code(binary, leftType, expectedType, env, module, allModules)

/// Emits generated code for result map pipe.
private fun result_map_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    let resultType = if expectedType.name.is_empty() then result_pipe_result_type(binary, leftType, env, module, allModules) else expectedType
    let resultName = result_pipe_value_name(binary)
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + result_pipe_binding_statement(lambda.parameters, valueType, resultName, "                ")
        + "                return " + expression_code(lambda.body, lambda_value_env(lambda.parameters, valueType, env), resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case CompiledFunctionReferenceExpression reference ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + "                return " + result_function_reference_body_code(reference, valueType, resultName, resultType, env, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case _ -> "unsupported(\"result pipe\")"

/// Emits generated code for result flat pipe.
private fun result_flat_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    let resultType = if expectedType.name.is_empty() then result_pipe_result_type(binary, leftType, env, module, allModules) else expectedType
    let bodyExpectedType = result_flat_pipe_body_expected_type(resultType)
    let resultName = result_pipe_value_name(binary)
    let mappedName = resultName + "_mapped"
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + result_pipe_binding_statement(lambda.parameters, valueType, resultName, "                ")
        + "                java.lang.Object " + mappedName + " = " + expression_code(lambda.body, lambda_value_env(lambda.parameters, valueType, env), bodyExpectedType, module, allModules) + ";" + newline()
        + "                if (__capy_result_is_success(" + mappedName + ")) {" + newline()
        + "                    return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + mappedName + "));" + newline()
        + "                }" + newline()
        + "                return ((" + boxed_java_type(resultType) + ") " + mappedName + ");" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case CompiledFunctionReferenceExpression reference ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + "                java.lang.Object " + mappedName + " = " + result_function_reference_body_code(reference, valueType, resultName, bodyExpectedType, env, module, allModules) + ";" + newline()
        + "                if (__capy_result_is_success(" + mappedName + ")) {" + newline()
        + "                    return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + mappedName + "));" + newline()
        + "                }" + newline()
        + "                return ((" + boxed_java_type(resultType) + ") " + mappedName + ");" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case _ -> "unsupported(\"result pipe\")"

/// Emits generated code for result function reference body.
private fun result_function_reference_body_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, resultName: String, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueName = "__capy_result_value"
    let valueCode = "((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "))"
    expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: valueName,
            location: reference.location
        }],
        location: reference.location
    }, [java_binding_with_java_name(valueName, valueType, valueCode)] + env, expectedType, module, allModules)

/// Computes the compiled type for result flat pipe body expected.
private fun result_flat_pipe_body_expected_type(resultType: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(resultType.name)
    then result_type(resultType)
    else object_type()

/// Emits one generated statement for result pipe binding.
private fun result_pipe_binding_statement(parameters: List[String], valueType: CompiledTypeReference, resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "));" + newline()

/// Computes the name for result pipe value.
private fun result_pipe_value_name(binary: CompiledBinaryExpression): String =
    "__capy_result_" + binary.location.line + "_" + binary.location.column + "_" + result_pipe_left_depth(binary.left)

/// Computes a numeric value for result pipe left depth.
private fun result_pipe_left_depth(expression: CompiledExpression): int =
    match expression with
    case CompiledBinaryExpression binary -> 1 + result_pipe_left_depth(binary.left)
    case _ -> 0

/// Computes the compiled type for result pipe value.
private fun result_pipe_value_type(left: CompiledExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(leftType.name)
    then first_type_argument(leftType)
    else match left with
        case CompiledDataLiteral literal -> result_literal_value_type(literal, env, module, allModules)
        case CompiledBinaryExpression binary ->
            let resultType = result_pipe_result_type(binary, expression_type(binary.left, env, module, allModules), env, module, allModules)
            if result_type_name(resultType.name) then first_type_argument(resultType) else object_type()
        case _ -> object_type()

/// Computes the compiled type for result literal value.
private fun result_literal_value_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_success_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } -> result_expression_type(field.value, expression_type(field.value, env, module, allModules), env, module, allModules)
        case None -> object_type()
    else object_type()

/// Computes the compiled type for result pipe result.
private fun result_pipe_result_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
        let bodyType = result_expression_type(lambda.body, expression_type(lambda.body, lambdaEnv, module, allModules), lambdaEnv, module, allModules)
        if binary.operator == "|*" then result_flat_pipe_result_type(bodyType) else bodyType
    case CompiledFunctionReferenceExpression reference ->
        let bodyType = function_reference_type(reference, module, allModules)
        if binary.operator == "|*" then result_flat_pipe_result_type(bodyType) else bodyType
    case _ -> object_type()

/// Computes the compiled type for result flat pipe result.
private fun result_flat_pipe_result_type(bodyType: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(bodyType.name) & result_type_name(first_type_argument(bodyType).name)
    then first_type_argument(bodyType)
    else bodyType

/// Infers the expression type for result.
private fun result_expression_type(expression: CompiledExpression, expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(expressionType.name)
    then expressionType
    else non_result_expression_type(expression, expressionType, env, module, allModules)

/// Infers the expression type for non result.
private fun non_result_expression_type(expression: CompiledExpression, expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledDataLiteral literal ->
        if result_success_constructor(literal.typeName)
        then result_type(result_literal_value_type(literal, env, module, allModules))
        else if result_error_constructor(literal.typeName)
        then result_type(object_type())
        else expressionType
    case CompiledMatchExpression matchExpression -> result_match_expression_type(matchExpression.cases, expressionType, env, module, allModules)
    case _ -> expressionType

/// Infers the expression type for result match.
private fun result_match_expression_type(cases: List[CompiledMatchCase], expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let orderedCases = ordered_match_cases(cases)
    match orderedCases[0] with
    case Some { matchCase } -> result_expression_type(matchCase.body, expressionType, env, module, allModules)
    case None -> expressionType

/// Computes the compiled type for result.
private fun result_type(argument: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference { name: "Result", arguments: [argument] }

/// Computes the compiled type for date.
private fun date_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Date", arguments: [] }

/// Computes the compiled type for time.
private fun time_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Time", arguments: [] }

/// Computes the compiled type for date time.
private fun date_time_type(): CompiledTypeReference =
    CompiledTypeReference { name: "DateTime", arguments: [] }

/// Computes the compiled type for duration.
private fun duration_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Duration", arguments: [] }

/// Collects imported standard-library constant exists visible to the current module.
private fun imported_stdlib_constant_exists(name: String, imports: List[CompiledImportDeclaration]): bool =
    match imported_stdlib_constant(name, imports) with
    case Some _ -> true
    case None -> false

/// Collects imported standard-library constant visible to the current module.
private fun imported_stdlib_constant(name: String, imports: List[CompiledImportDeclaration]): /capy/lang/Option[JavaStdlibValue] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !declaration.qualified & import_includes_name(name, declaration)
        then match stdlib_constant(name, declaration.modulePath) with
            case Some { value } -> /capy/lang/Option.Some { value }
            case None -> imported_stdlib_constant(name, imports[1:])
        else imported_stdlib_constant(name, imports[1:])

/// Looks up optional metadata for standard-library constant.
private fun stdlib_constant(name: String, modulePath: String): /capy/lang/Option[JavaStdlibValue] =
    let path = normalized_stdlib_path(modulePath)
    if path == "capy/date_time/Date" & name == "UNIX_DATE"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.date_time.Date.UNIX_DATE", typeReference: date_type() } }
    else if path == "capy/date_time/Time" & name == "MIDNIGHT"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.date_time.Time.MIDNIGHT", typeReference: time_type() } }
    else if path == "capy/date_time/DateTime" & name == "UNIX_EPOCH"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.date_time.DateTime.UNIX_EPOCH", typeReference: date_time_type() } }
    else if path == "capy/date_time/Duration" & name == "ZERO"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.date_time.Duration.ZERO", typeReference: duration_type() } }
    else /capy/lang/Option.None {}

/// Computes the output or module path for normalized standard-library.
private fun normalized_stdlib_path(modulePath: String): String =
    if java_generator_string_has_prefix(modulePath, "/")
    then modulePath[1, modulePath.size()]
    else modulePath

/// Checks whether standard-library date time type is imported into the current module scope.
private fun stdlib_date_time_type_imported(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    let modulePath = stdlib_date_time_type_module_path(typeName)
    if modulePath.is_empty()
    then false
    else stdlib_module_imported(modulePath, type_unqualified_name(typeName), imports)

/// Checks whether standard-library module is imported into the current module scope.
private fun stdlib_module_imported(modulePath: String, memberName: String, imports: List[CompiledImportDeclaration]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if !declaration.qualified
            & normalized_stdlib_path(declaration.modulePath) == modulePath
            & import_includes_name(memberName, declaration)
        then true
        else stdlib_module_imported(modulePath, memberName, imports[1:])

/// Computes the output or module path for standard-library date time type module.
private fun stdlib_date_time_type_module_path(typeName: String): String =
    let name = type_unqualified_name(typeName)
    if name == "DateTime"
    then "capy/date_time/DateTime"
    else if name == "Date"
    then "capy/date_time/Date"
    else if name == "Time"
    then "capy/date_time/Time"
    else if name == "Duration" | name == "DateDuration" | name == "WeekDuration"
    then "capy/date_time/Duration"
    else ""

/// Checks whether an expression has the string concat expression shape.
private fun string_concat_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    operator == "+" & (leftType.name == "String" | rightType.name == "String")

/// Computes the compiled type for string concat operand.
private fun string_concat_operand_type(type: CompiledTypeReference): CompiledTypeReference =
    if type.name == "any"
    then object_type()
    else type

/// Checks whether a type reference matches the standard-library date/time type name rule.
private fun stdlib_date_time_type_name(typeName: String): bool =
    let name = type_unqualified_name(typeName)
    name == "DateTime"
        | name == "Date"
        | name == "Time"
        | name == "Duration"
        | name == "DateDuration"
        | name == "WeekDuration"

/// Computes the compiled type for standard-library date time Java.
private fun stdlib_date_time_java_type(typeName: String): String =
    "java.lang.Object"

/// Checks whether method metadata matches the standard-library date/time method call rule.
private fun stdlib_date_time_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if stdlib_date_time_method_name(call.name)
    then stdlib_date_time_method(expression_type(call.receiver, env, module, allModules).name, call.name)
    else false

private fun stdlib_date_time_method_name(methodName: String): bool =
    methodName == "add_days"
        | methodName == "add_years_months"
        | methodName == "leap_year"
        | methodName == "first_day_of_month"
        | methodName == "last_day_of_month"
        | methodName == "to_days_since_unix_epoch"
        | methodName == "to_iso_8601"
        | methodName == "add_seconds"
        | methodName == "add_minutes"
        | methodName == "add_hours"
        | methodName == "to_seconds"
        | methodName == "to_minutes"
        | methodName == "to_hours"
        | methodName == "round_to_minutes"
        | methodName == "round_to_hours"
        | methodName == "plus"
        | methodName == "minus"
        | methodName == "timestamp"
        | methodName == "greater_than"
        | methodName == "less_than"
        | methodName == "greater"
        | methodName == "less"
        | methodName == "negate"
        | methodName == "years"
        | methodName == "months"
        | methodName == "days"
        | methodName == "hours"
        | methodName == "minutes"
        | methodName == "seconds"

/// Checks whether method metadata matches the standard-library date/time method rule.
private fun stdlib_date_time_method(receiverTypeName: String, methodName: String): bool =
    let receiver = type_unqualified_name(receiverTypeName)
    if receiver == "Date"
    then methodName == "add_days" | methodName == "add_years_months" | methodName == "leap_year" | methodName == "first_day_of_month" | methodName == "last_day_of_month" | methodName == "to_days_since_unix_epoch" | methodName == "to_iso_8601"
    else if receiver == "Time"
    then methodName == "add_seconds" | methodName == "add_minutes" | methodName == "add_hours" | methodName == "to_seconds" | methodName == "to_minutes" | methodName == "to_hours" | methodName == "round_to_minutes" | methodName == "round_to_hours" | methodName == "to_iso_8601"
    else if receiver == "DateTime"
    then methodName == "plus" | methodName == "minus" | methodName == "to_iso_8601" | methodName == "timestamp" | methodName == "greater_than" | methodName == "less_than" | methodName == "greater" | methodName == "less"
    else if stdlib_duration_receiver(receiver)
    then methodName == "to_iso_8601" | methodName == "negate" | methodName == "years" | methodName == "months" | methodName == "days" | methodName == "hours" | methodName == "minutes" | methodName == "seconds"
    else false

private fun stdlib_duration_receiver(receiver: String): bool =
    receiver == "Duration" | receiver == "DateDuration" | receiver == "WeekDuration"

/// Computes the compiled type for standard-library date time method.
private fun stdlib_date_time_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    stdlib_date_time_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun stdlib_date_time_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiver = type_unqualified_name(receiverType.name)
    if receiver == "Date"
    then if call.name == "to_days_since_unix_epoch" then int_type() else if call.name == "to_iso_8601" then string_type() else if call.name == "leap_year" then bool_type() else date_type()
    else if receiver == "Time"
    then if call.name == "to_seconds" | call.name == "to_minutes" | call.name == "to_hours" then int_type() else if call.name == "to_iso_8601" then string_type() else time_type()
    else if receiver == "DateTime"
    then stdlib_date_time_method_date_time_type(call, env, module, allModules)
    else if stdlib_duration_receiver(receiver)
    then stdlib_date_time_method_duration_type(call.name)
    else object_type()

/// Computes the compiled type for standard-library date time method date time.
private fun stdlib_date_time_method_date_time_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "to_iso_8601"
    then string_type()
    else if call.name == "timestamp"
    then long_type()
    else if call.name == "greater_than" | call.name == "less_than" | call.name == "greater" | call.name == "less"
    then bool_type()
    else if call.name == "plus"
    then date_time_type()
    else if call.name == "minus"
    then
        let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
        if type_unqualified_name(argumentType.name) == "DateTime"
        then duration_type()
        else date_time_type()
    else date_time_type()

/// Computes the compiled type for standard-library date time method duration.
private fun stdlib_date_time_method_duration_type(methodName: String): CompiledTypeReference =
    if methodName == "to_iso_8601"
    then string_type()
    else if methodName == "negate"
    then duration_type()
    else int_type()

/// Checks whether standard-library date time method can be emitted by the target backend.
private fun stdlib_date_time_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiver = type_unqualified_name(expression_type(call.receiver, env, module, allModules).name)
    expression_emittable(call.receiver, env, module, allModules)
        & if receiver == "Date"
            then stdlib_date_method_arguments_emittable(call, env, module, allModules)
            else if receiver == "Time"
            then stdlib_time_method_arguments_emittable(call, env, module, allModules)
            else if receiver == "DateTime"
            then stdlib_date_time_method_arguments_emittable(call, env, module, allModules)
            else if stdlib_duration_receiver(receiver)
            then call.arguments.is_empty()
            else false

/// Checks whether standard-library date method arguments can be emitted by the target backend.
private fun stdlib_date_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "add_days"
    then stdlib_one_int_argument_emittable(call, env, module, allModules)
    else if call.name == "add_years_months"
    then stdlib_two_int_arguments_emittable(call, env, module, allModules)
    else call.arguments.is_empty()

/// Checks whether standard-library time method arguments can be emitted by the target backend.
private fun stdlib_time_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "add_seconds"
    then stdlib_one_int_argument_emittable(call, env, module, allModules)
    else if call.name == "add_minutes" | call.name == "add_hours"
    then stdlib_one_int_argument_emittable(call, env, module, allModules)
    else call.arguments.is_empty()

/// Checks whether standard-library date time method arguments can be emitted by the target backend.
private fun stdlib_date_time_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "plus"
    then stdlib_one_date_time_argument_emittable(call, "Duration", env, module, allModules)
    else if call.name == "minus"
    then stdlib_one_date_time_argument_emittable(call, "Duration", env, module, allModules)
        | stdlib_one_date_time_argument_emittable(call, "DateTime", env, module, allModules)
    else if call.name == "greater_than" | call.name == "less_than" | call.name == "greater" | call.name == "less"
    then stdlib_one_date_time_argument_emittable(call, "DateTime", env, module, allModules)
    else call.arguments.is_empty()

/// Checks whether standard-library one int argument can be emitted by the target backend.
private fun stdlib_one_int_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { actual } ->
        call.arguments[1:].is_empty()
            & expression_emittable(actual, env, module, allModules)
            & type_assignable(int_type(), expression_type(actual, env, module, allModules))

/// Checks whether standard-library two int arguments can be emitted by the target backend.
private fun stdlib_two_int_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { first } ->
        match call.arguments[1] with
        case None -> false
        case Some { second } ->
            call.arguments[2:].is_empty()
                & expression_emittable(first, env, module, allModules)
                & expression_emittable(second, env, module, allModules)
                & type_assignable(int_type(), expression_type(first, env, module, allModules))
                & type_assignable(int_type(), expression_type(second, env, module, allModules))

/// Checks whether standard-library one date time argument can be emitted by the target backend.
private fun stdlib_one_date_time_argument_emittable(call: CompiledMethodCallExpression, expectedTypeName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { actual } ->
        call.arguments[1:].is_empty()
            & expression_emittable(actual, env, module, allModules)
            & type_unqualified_name(expression_type(actual, env, module, allModules).name) == expectedTypeName

/// Checks whether an expression has the collection pipe expression shape.
private fun collection_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    collection_pipe_operator(binary.operator) & collection_pipe_receiver_type(leftType) & lambda_expression(binary.right)

/// Checks whether an expression has the collection pipe chained method expression shape.
private fun collection_pipe_chained_method_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    collection_pipe_operator(binary.operator)
        & collection_pipe_receiver_type(leftType)
        & match binary.right with
            case CompiledMethodCallExpression call -> lambda_expression(call.receiver)
            case _ -> false

/// Resolves expression metadata for collection pipe chained method call.
private fun collection_pipe_chained_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    match binary.right with
    case CompiledMethodCallExpression call ->
        CompiledMethodCallExpression {
            receiver: CompiledBinaryExpression {
                operator: binary.operator,
                left: binary.left,
                right: call.receiver,
                location: binary.location
            },
            name: call.name,
            arguments: call.arguments,
            location: call.location
        }
    case _ -> CompiledMethodCallExpression {
        receiver: binary,
        name: "",
        arguments: [],
        location: binary.location
    }

/// Checks whether an operator belongs to the collection pipe operator category.
private fun collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*" | operator == "|!"

/// Checks whether an expression has the lambda expression shape.
private fun lambda_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

/// Emits generated code for collection pipe.
private fun collection_pipe_code(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType.name == "Dict"
    then dict_pipe_code(binary, receiverType, env, module, allModules)
    else
        let receiverCode = seq_receiver_code(binary.left, receiverType, env, module, allModules)
        let valueType = collection_value_type(receiverType)
        match binary.right with
        case CompiledLambdaExpression lambda ->
            if binary.operator == "|!"
            then receiverCode + ".filter(" + reject_lambda_code(lambda, valueType, env, module, allModules) + ")"
            else if binary.operator == "|-"
            then receiverCode + ".filter(" + lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules) + ")"
            else if binary.operator == "|*"
            then receiverCode + ".flatMap(" + flat_map_lambda_code(lambda, valueType, env, module, allModules) + ")"
            else receiverCode + ".map(" + lambda_code_for_value(lambda, valueType, expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules), env, module, allModules) + ")"
        case CompiledFunctionReferenceExpression reference ->
            if binary.operator == "|!"
            then receiverCode + ".filter(" + predicate_function_reference_lambda_code(reference, valueType, true, module, allModules) + ")"
            else if binary.operator == "|-"
            then receiverCode + ".filter(" + predicate_function_reference_lambda_code(reference, valueType, false, module, allModules) + ")"
            else receiverCode + ".map(" + function_reference_lambda_code(reference, valueType, function_reference_type(reference, module, allModules), module, allModules) + ")"
        case _ -> "unsupported(\"collection pipe\")"

/// Emits generated code for reject lambda.
private fun reject_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    lambda_code_with_result(lambda.parameters, valueType, "!(" + truthy_expression_code(lambda.body, lambdaEnv, module, allModules) + ")")

/// Emits generated code for predicate function reference lambda.
private fun predicate_function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, negate: bool, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_value -> " + (if negate then "!(" + function_reference_predicate_call_code(reference, valueType, module, allModules) + ")" else function_reference_predicate_call_code(reference, valueType, module, allModules))

/// Emits generated code for function reference predicate call.
private fun function_reference_predicate_call_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: "__capy_value",
            location: reference.location
        }],
        location: reference.location
    }, [java_binding("__capy_value", valueType)], bool_type(), module, allModules)

/// Emits generated code for function reference lambda.
private fun function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_value -> " + expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: "__capy_value",
            location: reference.location
        }],
        location: reference.location
    }, [java_binding("__capy_value", valueType)], expectedType, module, allModules)

/// Emits generated code for dict pipe.
private fun dict_pipe_code(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = collection_value_type(receiverType)
    let receiverCode = expression_code(binary.left, env, receiverType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|!"
        then dict_filter_pipe_code(binary, receiverCode, valueType, lambda, false, env, module, allModules)
        else if binary.operator == "|-"
        then dict_filter_pipe_code(binary, receiverCode, valueType, lambda, true, env, module, allModules)
        else if binary.operator == "|"
        then dict_map_pipe_code(binary, receiverCode, valueType, lambda, env, module, allModules)
        else "unsupported(\"dict pipe\")"
    case _ -> "unsupported(\"dict pipe\")"

/// Emits generated code for dict map pipe.
private fun dict_map_pipe_code(binary: CompiledBinaryExpression, receiverCode: String, valueType: CompiledTypeReference, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
    let resultType = expression_type(lambda.body, lambdaEnv, module, allModules)
    let resultName = dict_pipe_result_name(binary)
    "((java.util.function.Supplier<java.util.Map<java.lang.String, " + boxed_java_type(resultType) + ">>) () -> {" + newline()
        + "            java.util.LinkedHashMap<java.lang.String, " + boxed_java_type(resultType) + "> " + resultName + " = new java.util.LinkedHashMap<>();" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + receiverCode + ".entrySet()) {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "                ")
        + "                " + resultName + ".put(__capy_entry.getKey(), " + expression_code(lambda.body, lambdaEnv, resultType, module, allModules) + ");" + newline()
        + "            }" + newline()
        + "            return java.util.Collections.unmodifiableMap(" + resultName + ");" + newline()
        + "        }).get()"

/// Emits generated code for dict filter pipe.
private fun dict_filter_pipe_code(binary: CompiledBinaryExpression, receiverCode: String, valueType: CompiledTypeReference, lambda: CompiledLambdaExpression, keepMatches: bool, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
    let resultName = dict_pipe_result_name(binary)
    let predicateCode = truthy_expression_code(lambda.body, lambdaEnv, module, allModules)
    let conditionCode = if keepMatches then predicateCode else "!(" + predicateCode + ")"
    "((java.util.function.Supplier<java.util.Map<java.lang.String, " + boxed_java_type(valueType) + ">>) () -> {" + newline()
        + "            java.util.LinkedHashMap<java.lang.String, " + boxed_java_type(valueType) + "> " + resultName + " = new java.util.LinkedHashMap<>();" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + receiverCode + ".entrySet()) {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "                ")
        + "                if (" + conditionCode + ") {" + newline()
        + "                    " + resultName + ".put(__capy_entry.getKey(), __capy_entry.getValue());" + newline()
        + "                }" + newline()
        + "            }" + newline()
        + "            return java.util.Collections.unmodifiableMap(" + resultName + ");" + newline()
        + "        }).get()"

/// Computes the name for dict pipe result.
private fun dict_pipe_result_name(binary: CompiledBinaryExpression): String =
    "__capy_dict_pipe_" + binary.location.line + "_" + binary.location.column

/// Emits generated code for seq receiver.
private fun seq_receiver_code(expression: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = expression_code(expression, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then "((capy.collection.Seq<java.lang.String>) (capy.collection.Seq<?>) capy.collection.Seq.toSeq(__capy_string_chars(" + receiverCode + ")))"
    else if receiverType.name == "List"
    then "((capy.collection.Seq<" + boxed_java_type(first_type_argument(receiverType)) + ">) (capy.collection.Seq<?>) capy.collection.Seq.toSeq(" + receiverCode + "))"
    else if seq_type_name(receiverType.name)
    then "((" + java_seq_type(receiverType) + ") (capy.collection.Seq<?>) " + receiverCode + ")"
    else "capy.collection.Seq.toSeq(" + receiverCode + ")"

private fun async_receiver_code(expression: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((capy.lang.Async<?>) " + expression_code(expression, env, receiverType, module, allModules) + ")"

/// Emits generated code for int literal.
private fun int_literal_code(literal: CompiledIntLiteral, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" & byte_literal_source(literal.source)
    then "((byte) " + literal.source + ")"
    else literal.source

/// Emits generated code for numeric widening.
private fun numeric_widening_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if primitive_numeric_widening_assignable(expectedType, sourceType)
    then "((" + java_type(expectedType) + ") " + code + ")"
    else code

/// Emits generated code for value conversion.
private fun value_conversion_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match primitive_backed_backing_type(sourceType.name, module, allModules) with
    case Some { backingType } ->
        if type_assignable(expectedType, backingType)
        then primitive_backed_value_conversion_code(code, backingType, expectedType)
        else ordinary_value_conversion_code(code, sourceType, expectedType)
    case None -> ordinary_value_conversion_code(code, sourceType, expectedType)

private fun primitive_backed_value_conversion_code(code: String, backingType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    let valueCode = "((" + boxed_java_type(backingType) + ") __capy_data_field(" + code + ", \"value\"))"
    if backingType.name == "long" & expectedType.name == "int"
    then valueCode + ".intValue()"
    else numeric_widening_code(valueCode, backingType, expectedType)

/// Emits generated code for ordinary value conversion.
private fun ordinary_value_conversion_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if (sourceType.name.is_empty() | sourceType.name == "any") & !expectedType.name.is_empty() & expectedType.name != "any"
    then "((" + boxed_java_type(expectedType) + ") " + code + ")"
    else numeric_widening_code(code, sourceType, expectedType)

/// Emits generated code for function call.
private fun function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "delay"
    then "capy.lang.Effect.delay(" + expression_code(argument(call.arguments, 0), env, supplier_type(first_type_argument(delay_call_type(call.arguments, env, module, allModules))), module, allModules) + ")"
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_value_call_code(call, env, module, allModules)
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then
        let valueType = if expectedType.name == "Effect" then first_type_argument(expectedType) else expression_type(argument(call.arguments, 0), env, module, allModules)
        "capy.lang.Effect.pure(" + expression_code(argument(call.arguments, 0), env, valueType, module, allModules) + ")"
    else if stdlib_effect_function_call(call, module)
    then stdlib_effect_function_call_code(call.name)
    else if async_function_call(call, module)
    then async_function_call_code(call, env, module, allModules)
    else if result_error_function_call(call, module)
    then result_error_function_call_code(call, env, module, allModules)
    else if stdlib_path_function_call(call, module)
    then stdlib_path_function_call_code(call, env, module, allModules)
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_code(call, env, module, allModules)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then console_print_call_code(call, env, module, allModules)
    else if console_read_line_call(call, module)
    then "capy.lang.Effect.delay(() -> dev.capylang.ConsoleUtil.readLine())"
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_code(call, env, module, allModules)
    else if reflection_function_call(call, module)
    then reflection_call_code(call, env, module, allModules)
    else if object_type_function_call(call, module, allModules)
    then object_type_function_call_code(call, module, allModules)
    else if call.name == "assert_all"
    then "capy.test.Assert.assert_all__48_0(" + expression_code(argument(call.arguments, 0), env, list_type(assert_type()), module, allModules) + ")"
    else if call.name == "assert_that"
    then assert_that_code(argument(call.arguments, 0), env, module, allModules)
    else if call.name == "test"
    then "__capy_data(\"TestCase\", java.util.Map.ofEntries(java.util.Map.entry(\"name\", "
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + "), java.util.Map.entry(\"result\", __capy_data(\"Passed\", java.util.Map.of())), java.util.Map.entry(\"assertions_count\", 0), java.util.Map.entry(\"execution_time\", 0.0), java.util.Map.entry(\"assert_supplier\", "
        + expression_code(argument(call.arguments, 1), env, supplier_type(assert_type()), module, allModules)
        + ")))"
    else if call.name == "test_file"
    then
        let testsExpression = argument(call.arguments, 1)
        let testsCode = test_file_tests_code(testsExpression, env, module, allModules)
        "capy.lang.Effect.delay(() -> __capy_data(\"TestFile\", java.util.Map.ofEntries(java.util.Map.entry(\"file_name\", "
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + "), java.util.Map.entry(\"test_cases\", "
        + testsCode
        + "), java.util.Map.entry(\"timestamp_millis\", java.lang.System.currentTimeMillis()))))"
    else if stdlib_math_sqrt_call(call, module)
    then sqrt_call_code(call, env, expectedType, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then "java.lang.Integer.toString("
        + expression_code(argument(call.arguments, 0), env, int_type(), module, allModules)
        + ").replace(\"-\", \"\").length()"
    else if enum_parse_call(call, module, allModules)
    then enum_parse_call_code(call, env, module, allModules)
    else if object_constructor_call(call, env, module, allModules)
    then object_constructor_call_code(call, env, expectedType, module, allModules)
    else ordinary_function_call_code(call, env, module, allModules)

/// Emits generated code for function value call.
private fun function_value_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = lookup_binding(call.name, env)
    let parameters = function_type_parameters(type)
    let target = lookup_binding_java_name(call.name, env)
    if parameters.is_empty()
    then target + ".get()"
    else target + ".apply(" + function_value_call_arguments(parameters, call.arguments, env, module, allModules) + ")"

private fun result_error_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "error"
    then "__capy_error(" + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules) + ")"
    else "__capy_error("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + ", "
        + expression_code(argument(call.arguments, 1), env, string_type(), module, allModules)
        + ")"

/// Formats function value call arguments for generated emission.
private fun function_value_call_arguments(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, function_type_parameter_at(parameters, 0), module, allModules)
        + function_value_call_argument_tail(parameters[1:], arguments[1:], env, module, allModules)

/// Formats the recursive tail segment for function value call argument.
private fun function_value_call_argument_tail(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, function_type_parameter_at(parameters, 0), module, allModules)
        + function_value_call_argument_tail(parameters[1:], arguments[1:], env, module, allModules)

/// Checks whether a function matches the partial function call metadata.
private fun partial_function_call(call: CompiledFunctionCallExpression): bool =
    arguments_contain_placeholder(call.arguments)

/// Checks whether method metadata matches the partial method call rule.
private fun partial_method_call(call: CompiledMethodCallExpression): bool =
    arguments_contain_placeholder(call.arguments)

/// Checks whether an expression uses the arguments contain placeholder placeholder form.
private fun arguments_contain_placeholder(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then true
        else arguments_contain_placeholder(arguments[1:])

/// Checks whether an expression has the partial placeholder expression shape.
private fun partial_placeholder_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> compiled_placeholder_source(unsupported.source)
    case _ -> false

/// Emits generated code for partial function call.
private fun partial_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let names = partial_placeholder_names(call.arguments, env)
    let type = partial_expected_type(expectedType, partial_function_call_type(call, env, module, allModules))
    "((" + boxed_java_type(type) + ") (" + partial_lambda_parameters(names)
        + " -> " + partial_function_call_body_code(call, names, env, module, allModules) + "))"

/// Emits generated code for partial method call.
private fun partial_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let names = partial_placeholder_names(call.arguments, env)
    let type = partial_expected_type(expectedType, partial_method_call_type(call, env, module, allModules))
    "((" + boxed_java_type(type) + ") (" + partial_lambda_parameters(names)
        + " -> " + partial_method_call_body_code(call, names, env, module, allModules) + "))"

/// Computes the compiled type for partial expected.
private fun partial_expected_type(expectedType: CompiledTypeReference, inferredType: CompiledTypeReference): CompiledTypeReference =
    if function_type(expectedType) then expectedType else inferredType

/// Emits generated code for partial function call body.
private fun partial_function_call_body_code(call: CompiledFunctionCallExpression, names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if qualified_call_name(call.name)
    then
        match find_qualified_function(call.name, module, allModules) with
        case Some { function } ->
            qualified_call_class_name(call.name, module) + "." + java_function_name(function)
                + "(" + partial_parameter_expression_list_code(function.parameters, call.arguments, names, env, module, allModules) + ")"
        case None ->
            qualified_call_class_name(call.name, module) + "." + java_identifier(qualified_call_member(call.name))
                + "(" + partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } ->
            java_function_name(function) + "(" + partial_parameter_expression_list_code(function.parameters, call.arguments, names, env, module, allModules) + ")"
        case None -> java_function_call_name(call.name, module, allModules) + "(" + partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"

/// Emits generated code for partial method call body.
private fun partial_method_call_body_code(call: CompiledMethodCallExpression, names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    match find_extension_method(call, env, module, allModules) with
    case Some { function } -> partial_extension_method_call_body_code(function, call, names, receiverType, env, module, allModules)
    case None -> expression_code(call.receiver, env, receiverType, module, allModules)
        + "." + java_method_name(call.name)
        + "(" + partial_method_expression_list_code(call.arguments, names, receiverType, call.name, env, module, allModules) + ")"

/// Emits generated code for partial extension method call body.
private fun partial_extension_method_call_body_code(function: CompiledFunction, call: CompiledMethodCallExpression, names: List[String], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = bound_extension_method_parameters(function, receiverType)
    java_function_name(function)
        + "("
        + expression_code(call.receiver, env, receiverType, module, allModules)
        + partial_extension_method_call_argument_tail(function.parameters, parameters, call.arguments, names, env, module, allModules)
        + ")"

/// Formats the recursive tail segment for partial extension method call argument.
private fun partial_extension_method_call_argument_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + partial_extension_parameter_expression_list_code(declaredParameters, boundParameters, arguments, names, env, module, allModules)

/// Computes the compiled type for partial function call.
private fun partial_function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if qualified_call_name(call.name)
    then
        match find_qualified_function_binding(call.name, module, allModules) with
        case Some { binding } -> partial_function_type(binding.function.parameters, call.arguments, effective_function_return_type(binding.function, binding.module, allModules))
        case None -> partial_unknown_function_type(call.arguments)
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } -> partial_function_type(function.parameters, call.arguments, effective_function_return_type(function, module, allModules))
        case None -> partial_unknown_function_type(call.arguments)

/// Computes the compiled type for partial method call.
private fun partial_method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    match find_extension_method(call, env, module, allModules) with
    case Some { function } ->
        CompiledTypeReference {
            name: function_type_reference_text(
                partial_extension_method_parameter_types(bound_extension_method_parameters(function, receiverType), call.arguments),
                bound_extension_method_return_type(function, receiverType)
            ),
            arguments: []
        }
    case None ->
        CompiledTypeReference {
            name: function_type_reference_text(
                partial_method_parameter_types(call.arguments, receiverType, call.name),
                partial_method_return_type(call, receiverType, env, module, allModules)
            ),
            arguments: []
        }

/// Computes the compiled type for partial function.
private fun partial_function_type(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], returnType: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference {
        name: function_type_reference_text(partial_function_parameter_types(parameters, arguments), returnType),
        arguments: []
    }

/// Computes the compiled type for partial unknown function.
private fun partial_unknown_function_type(arguments: List[CompiledExpression]): CompiledTypeReference =
    CompiledTypeReference {
        name: function_type_reference_text(partial_unknown_parameter_types(arguments), object_type()),
        arguments: []
    }

/// Collects partial function parameter types for compiler processing.
private fun partial_function_parameter_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, object_type())
        if partial_placeholder_expression(expression)
        then [parameterType] + partial_function_parameter_types(parameters[1:], arguments[1:])
        else partial_function_parameter_types(parameters[1:], arguments[1:])

/// Collects partial unknown parameter types for compiler processing.
private fun partial_unknown_parameter_types(arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then [object_type()] + partial_unknown_parameter_types(arguments[1:])
        else partial_unknown_parameter_types(arguments[1:])

/// Collects partial method parameter types for compiler processing.
private fun partial_method_parameter_types(arguments: List[CompiledExpression], receiverType: CompiledTypeReference, name: String): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then [partial_method_argument_type(receiverType, name)] + partial_method_parameter_types(arguments[1:], receiverType, name)
        else partial_method_parameter_types(arguments[1:], receiverType, name)

/// Collects partial extension method parameter types for compiler processing.
private fun partial_extension_method_parameter_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, object_type())
        if partial_placeholder_expression(expression)
        then [parameterType] + partial_extension_method_parameter_types(parameters[1:], arguments[1:])
        else partial_extension_method_parameter_types(parameters[1:], arguments[1:])

/// Computes the compiled type for partial method argument.
private fun partial_method_argument_type(receiverType: CompiledTypeReference, name: String): CompiledTypeReference =
    if receiverType.name == "String" & string_java_method(name)
    then string_type()
    else object_type()

/// Computes the compiled type for partial method return.
private fun partial_method_return_type(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if receiverType.name == "String" & string_java_method(call.name)
    then string_java_method_type(call.name)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> bound_extension_method_return_type(function, receiverType)
        case None -> object_type()

/// Checks whether partial function call can be emitted by the target backend.
private fun partial_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if partial_arguments_emittable(call.arguments, env, module, allModules)
    then if qualified_call_name(call.name)
        then match find_qualified_function(call.name, module, allModules) with
            case Some _ -> true
            case None -> false
        else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
            case Some _ -> true
            case None -> false
    else false

/// Checks whether partial method call can be emitted by the target backend.
private fun partial_method_call_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if expression_emittable(call.receiver, env, module, allModules)
    then if partial_arguments_emittable(call.arguments, env, module, allModules)
        then if string_java_method_call(call, env, module, allModules)
            then true
            else match find_extension_method(call, env, module, allModules) with
                case Some _ -> true
                case None -> java_method_supported(call.name)
        else false
    else false

/// Checks whether partial arguments can be emitted by the target backend.
private fun partial_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> true
    case Some { expression } ->
        let current = if partial_placeholder_expression(expression) then true else expression_emittable(expression, env, module, allModules)
        if current
        then partial_arguments_emittable(arguments[1:], env, module, allModules)
        else false

/// Collects partial placeholder names for compiler processing.
private fun partial_placeholder_names(arguments: List[CompiledExpression], env: List[JavaBinding]): List[String] =
    partial_placeholder_names_with_used(arguments, env, [])

/// Collects partial placeholder names with used names for compiler processing.
private fun partial_placeholder_names_with_used(arguments: List[CompiledExpression], env: List[JavaBinding], used: List[String]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then
            let name = available_partial_parameter_name(used, env, 1)
            [name] + partial_placeholder_names_with_used(arguments[1:], env, [name] + used)
        else partial_placeholder_names_with_used(arguments[1:], env, used)

/// Computes the name for available partial parameter.
private fun available_partial_parameter_name(used: List[String], env: List[JavaBinding], idx: int): String =
    let name = "capybaraPartial" + idx
    if binding_exists(name, env)
    then available_partial_parameter_name(used, env, idx + 1)
    else if string_list_contains(name, used)
    then available_partial_parameter_name(used, env, idx + 1)
    else name

/// Checks whether string list contains the requested value.
private fun string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> if item == value then true else string_list_contains(value, values[1:])

/// Formats partial lambda parameters for generated emission.
private fun partial_lambda_parameters(names: List[String]): String =
    match names[0] with
    case None -> "()"
    case Some { name } ->
        if names[1:].is_empty()
        then java_identifier(name)
        else "(" + partial_lambda_parameter_list(names) + ")"

/// Formats source text for partial lambda parameter list.
private fun partial_lambda_parameter_list(names: List[String]): String =
    match names[0] with
    case None -> ""
    case Some { name } -> java_identifier(name) + partial_lambda_parameter_tail(names[1:])

/// Formats the recursive tail segment for partial lambda parameter.
private fun partial_lambda_parameter_tail(names: List[String]): String =
    match names[0] with
    case None -> ""
    case Some { name } -> ", " + java_identifier(name) + partial_lambda_parameter_tail(names[1:])

/// Computes the name for partial argument.
private fun partial_argument_name(names: List[String]): String =
    match names[0] with
    case Some { name } -> java_identifier(name)
    case None -> "__capy_missing_partial"

/// Emits generated code for partial parameter expression list.
private fun partial_parameter_expression_list_code(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names[1:], env, module, allModules)
        else
            let parameterType = parameter_type_for_expression(parameters, expression, env, module, allModules)
            expression_code(expression, env, parameterType, module, allModules)
            + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names, env, module, allModules)

/// Formats the recursive tail segment for partial parameter expression list.
private fun partial_parameter_expression_list_tail(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names[1:], env, module, allModules)
        else
            let parameterType = parameter_type_for_expression(parameters, expression, env, module, allModules)
            ", " + expression_code(expression, env, parameterType, module, allModules)
            + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names, env, module, allModules)

/// Emits generated code for partial expression list.
private fun partial_expression_list_code(expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_expression_list_tail(expressions[1:], names[1:], env, module, allModules)
        else expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
            + partial_expression_list_tail(expressions[1:], names, env, module, allModules)

/// Formats the recursive tail segment for partial expression list.
private fun partial_expression_list_tail(expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_expression_list_tail(expressions[1:], names[1:], env, module, allModules)
        else ", " + expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
            + partial_expression_list_tail(expressions[1:], names, env, module, allModules)

/// Emits generated code for partial method expression list.
private fun partial_method_expression_list_code(expressions: List[CompiledExpression], names: List[String], receiverType: CompiledTypeReference, methodName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let argumentType = partial_method_argument_type(receiverType, methodName)
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_method_expression_list_tail(expressions[1:], names[1:], receiverType, methodName, env, module, allModules)
        else expression_code(expression, env, argumentType, module, allModules)
            + partial_method_expression_list_tail(expressions[1:], names, receiverType, methodName, env, module, allModules)

/// Formats the recursive tail segment for partial method expression list.
private fun partial_method_expression_list_tail(expressions: List[CompiledExpression], names: List[String], receiverType: CompiledTypeReference, methodName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let argumentType = partial_method_argument_type(receiverType, methodName)
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_method_expression_list_tail(expressions[1:], names[1:], receiverType, methodName, env, module, allModules)
        else ", " + expression_code(expression, env, argumentType, module, allModules)
            + partial_method_expression_list_tail(expressions[1:], names, receiverType, methodName, env, module, allModules)

/// Emits generated code for partial extension parameter expression list.
private fun partial_extension_parameter_expression_list_code(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        if partial_placeholder_expression(expression)
        then partial_extension_argument_code(partial_argument_name(names), declaredType, boundType)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names[1:], env, module, allModules)
        else extension_argument_code(expression, declaredType, boundType, env, module, allModules)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names, env, module, allModules)

/// Formats the recursive tail segment for partial extension parameter expression list.
private fun partial_extension_parameter_expression_list_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        if partial_placeholder_expression(expression)
        then ", " + partial_extension_argument_code(partial_argument_name(names), declaredType, boundType)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names[1:], env, module, allModules)
        else ", " + extension_argument_code(expression, declaredType, boundType, env, module, allModules)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names, env, module, allModules)

/// Emits generated code for partial extension argument.
private fun partial_extension_argument_code(code: String, declaredType: CompiledTypeReference, boundType: CompiledTypeReference): String =
    if extension_function_argument_needs_erased_cast(declaredType, boundType)
    then "((" + java_type(declaredType) + ") (" + raw_java_functional_type(declaredType) + ") " + code + ")"
    else code

/// Emits generated code for function reference.
private fun function_reference_code(reference: CompiledFunctionReferenceExpression, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function_type(expectedType)
    then "((" + boxed_java_type(expectedType) + ") (" + typed_function_reference_lambda_code(reference, expectedType, module, allModules) + "))"
    else function_reference_lambda_code(reference, function_reference_parameter_type(reference, module, allModules), function_reference_type(reference, module, allModules), module, allModules)

/// Emits generated code for typed function reference lambda.
private fun typed_function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = function_type_parameters(expectedType)
    function_lambda_parameters(parameters, 0)
        + " -> " + java_function_call_name(reference.name, module, allModules)
        + "(" + typed_function_reference_argument_list(reference, parameters, 0, module, allModules) + ")"

/// Formats type metadata text for typed function reference argument list.
private fun typed_function_reference_argument_list(reference: CompiledFunctionReferenceExpression, parameters: List[CompiledTypeReference], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ ->
        typed_function_reference_argument_code(reference, idx, module, allModules)
            + typed_function_reference_argument_tail(reference, parameters[1:], idx + 1, module, allModules)

/// Formats the recursive tail segment for typed function reference argument.
private fun typed_function_reference_argument_tail(reference: CompiledFunctionReferenceExpression, parameters: List[CompiledTypeReference], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + typed_function_reference_argument_code(reference, idx, module, allModules)
        + typed_function_reference_argument_tail(reference, parameters[1:], idx + 1, module, allModules)

/// Emits generated code for typed function reference argument.
private fun typed_function_reference_argument_code(reference: CompiledFunctionReferenceExpression, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let argument = "__capy_arg" + idx
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        let parameterType = parameter_type_at(function.parameters, idx, object_type())
        if parameterType.name == "any" | type_parameter(parameterType)
        then argument
        else "((" + boxed_java_type(parameterType) + ") " + argument + ")"
    case None -> argument

/// Formats function lambda parameters for generated emission.
private fun function_lambda_parameters(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> "()"
    case Some _ ->
        if parameters[1:].is_empty()
        then "__capy_arg" + idx
        else "(" + function_lambda_parameter_list(parameters, idx) + ")"

/// Formats source text for function lambda parameter list.
private fun function_lambda_parameter_list(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> "__capy_arg" + idx + function_lambda_parameter_tail(parameters[1:], idx + 1)

/// Formats the recursive tail segment for function lambda parameter.
private fun function_lambda_parameter_tail(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", __capy_arg" + idx + function_lambda_parameter_tail(parameters[1:], idx + 1)

/// Emits generated code for ordinary function call.
private fun ordinary_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if qualified_call_name(call.name)
    then
        match find_qualified_function(call.name, module, allModules) with
        case Some { function } ->
            qualified_call_class_name(call.name, module) + "." + java_function_name(function)
                + "(" + parameter_expression_list_code(function.parameters, call.arguments, env, module, allModules) + ")"
        case None ->
            qualified_call_class_name(call.name, module) + "." + java_identifier(qualified_call_member(call.name))
                + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } ->
            java_function_name(function) + "(" + parameter_expression_list_code(function.parameters, call.arguments, env, module, allModules) + ")"
        case None -> java_function_call_name(call.name, module, allModules) + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

/// Checks whether a call has the object constructor call shape.
private fun object_constructor_call(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_class_in_scope(call.name, module, allModules) with
    case Some { binding } -> parameters_emittable_and_assignable(binding.objectClass.parameters, call.arguments, env, module, allModules)
    case None -> false

/// Checks whether object constructor call can be emitted by the target backend.
private fun object_constructor_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    object_constructor_call(call, env, module, allModules)

/// Computes the compiled type for object constructor call.
private fun object_constructor_call_type(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_object_class_in_scope(call.name, module, allModules) with
    case Some { binding } -> effect_type(java_object_type_reference_for_class(binding.moduleClassName, binding.objectClass))
    case None -> effect_type(object_type())

/// Emits generated code for object constructor call.
private fun object_constructor_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_object_class_in_scope(call.name, module, allModules) with
    case Some { binding } ->
        let objectType = java_object_type_reference_for_class(binding.moduleClassName, binding.objectClass)
        let valueType = if expectedType.name == "Effect" then first_type_argument(expectedType) else objectType
        let rawCode = "new " + boxed_java_type(objectType) + "(" + parameter_expression_list_code(binding.objectClass.parameters, call.arguments, env, module, allModules) + ")"
        "capy.lang.Effect.delay(() -> " + java_object_value_code(rawCode, objectType, valueType) + ")"
    case None -> ordinary_function_call_code(call, env, module, allModules)

/// Emits Java code for object value.
private fun java_object_value_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if expectedType.name == sourceType.name | expectedType.name.is_empty()
    then code
    else "((" + boxed_java_type(expectedType) + ") " + code + ")"

/// Checks whether a type reference matches the object type method call rule.
private fun object_type_method_call(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name != "type"
    then false
    else if !call.arguments.is_empty()
    then false
    else object_type_method_receiver(call.receiver, module, allModules)

/// Checks whether a type reference matches the object type function call rule.
private fun object_type_function_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !qualified_call_name(call.name)
    then false
    else if qualified_call_member(call.name) != "type"
    then false
    else if !call.arguments.is_empty()
    then false
    else object_type_method_receiver_name(object_type_function_receiver_name(call.name), module, allModules)

/// Computes the name for object type function receiver.
private fun object_type_function_receiver_name(name: String): String =
    name[0, last_dot_index(name)]

/// Checks whether a type reference matches the object type method receiver rule.
private fun object_type_method_receiver(receiver: CompiledExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match receiver with
    case CompiledVariableExpression variable -> object_type_method_receiver_name(variable.name, module, allModules)
    case _ -> false

/// Checks whether a type reference matches the object type method receiver name rule.
private fun object_type_method_receiver_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_class_in_scope(name, module, allModules) with
    case Some _ -> true
    case None ->
        match find_object_interface_by_name(name, module, allModules) with
        case Some _ -> true
        case None -> false

/// Computes the compiled type for object type method call.
private fun object_type_method_call_type(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match call.receiver with
    case CompiledVariableExpression variable -> object_info_type_for_name(variable.name, module, allModules)
    case _ -> data_type_reference("ObjectInfo")

/// Computes the compiled type for object type function call.
private fun object_type_function_call_type(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    object_info_type_for_name(object_type_function_receiver_name(call.name), module, allModules)

/// Computes the name for object info type for.
private fun object_info_type_for_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_object_class_in_scope(name, module, allModules) with
    case Some _ -> data_type_reference("ObjectInfo")
    case None ->
        match find_object_interface_by_name(name, module, allModules) with
        case Some { binding } ->
            if binding.objectInterface.kind == "trait"
            then data_type_reference("TraitInfo")
            else data_type_reference("InterfaceInfo")
        case None -> data_type_reference("ObjectInfo")

/// Emits generated code for object type method call.
private fun object_type_method_call_code(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledVariableExpression variable -> object_type_method_call_code_for_name(variable.name, module, allModules)
    case _ -> "unsupported(\"COO type\")"

/// Emits generated code for object type function call.
private fun object_type_function_call_code(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    object_type_method_call_code_for_name(object_type_function_receiver_name(call.name), module, allModules)

/// Computes the name for object type method call code for.
private fun object_type_method_call_code_for_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_object_class_in_scope(name, module, allModules) with
    case Some { binding } -> reflection_object_info_code(binding.objectClass.name, binding.module, allModules)
    case None ->
        match find_object_interface_by_name(name, module, allModules) with
        case Some { binding } -> reflection_object_interface_info_code(binding.objectInterface, binding.module, allModules)
        case None -> "unsupported(\"COO type\")"

/// Emits generated code for reflection object info.
private fun reflection_object_info_code(className: String, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let annotationSources = java_object_annotation_sources(className, owner.functions)
    "__capy_data(\"ObjectInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(className) + "\"")
        + ", " + java_map_entry("pkg", package_info_code(owner))
        + ", " + java_map_entry("open", reflection_object_open_code(className, owner.functions))
        + ", " + java_map_entry("fields", reflection_object_field_infos_code(className, schema_values("__capy_oo_field|" + className + "|", owner.functions), annotationSources, owner, allModules))
        + ", " + java_map_entry("methods", reflection_object_method_infos_code(className, owner.functions, annotationSources, owner, allModules))
        + ", " + java_map_entry("parents", reflection_parent_infos_code(schema_values("__capy_oo_parent|" + className + "|", owner.functions), owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(annotationSources.typeAnnotations, owner, allModules))
        + "))"

/// Emits generated code for reflection object open.
private fun reflection_object_open_code(className: String, functions: List[CompiledFunction]): String =
    if compiled_object_class_open(className, functions) then "true" else "false"

/// Emits generated code for reflection object interface info.
private fun reflection_object_interface_info_code(objectInterface: CompiledObjectOrientedInterface, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let annotationSources = java_object_annotation_sources(objectInterface.name, owner.functions)
    "__capy_data(\"" + reflection_object_interface_info_type(objectInterface) + "\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(objectInterface.name) + "\"")
        + ", " + java_map_entry("pkg", package_info_code(owner))
        + ", " + java_map_entry("methods", reflection_object_interface_method_infos_code(objectInterface.name, owner.functions, annotationSources, owner, allModules))
        + ", " + java_map_entry("parents", reflection_parent_infos_code(schema_values("__capy_oo_interface_parent|" + objectInterface.name + "|", owner.functions), owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(annotationSources.typeAnnotations, owner, allModules))
        + "))"

/// Computes the compiled type for reflection object interface info.
private fun reflection_object_interface_info_type(objectInterface: CompiledObjectOrientedInterface): String =
    if objectInterface.kind == "trait" then "TraitInfo" else "InterfaceInfo"

/// Emits generated code for reflection object field infos.
private fun reflection_object_field_infos_code(className: String, fields: List[String], annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_object_field_info_codes(className, fields, 0, annotationSources, owner, allModules))

/// Collects reflection metadata entries for reflection object field info codes.
private fun reflection_object_field_info_codes(className: String, fields: List[String], idx: int, annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [reflection_object_field_info_code(className, field, idx, annotationSources, owner, allModules)]
            + reflection_object_field_info_codes(className, fields[1:], idx + 1, annotationSources, owner, allModules)

/// Emits generated code for reflection object field info.
private fun reflection_object_field_info_code(className: String, field: String, idx: int, annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let schema = object_field_schema_metadata(field)
    "__capy_data(\"FieldInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(schema.name) + "\"")
        + ", " + java_map_entry("type", reflection_any_info_code(schema_type_reference(schema.typeName), owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            java_object_annotation_values("" + idx, annotationSources.fieldAnnotations),
            owner,
            allModules
        ))
        + "))"

/// Emits generated code for reflection object method infos.
private fun reflection_object_method_infos_code(className: String, functions: List[CompiledFunction], annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_object_method_info_codes(className, functions, annotationSources, owner, allModules))

/// Collects reflection metadata entries for reflection object method info codes.
private fun reflection_object_method_info_codes(className: String, functions: List[CompiledFunction], annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_method_function_for_class(function, className)
        then [reflection_object_method_info_code(function, annotationSources, owner, allModules)]
            + reflection_object_method_info_codes(className, functions[1:], annotationSources, owner, allModules)
        else reflection_object_method_info_codes(className, functions[1:], annotationSources, owner, allModules)

/// Emits generated code for reflection object method info.
private fun reflection_object_method_info_code(function: CompiledFunction, annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let className = compiled_object_method_class_name(function.name)
    let methodName = compiled_object_method_name(function.name)
    "__capy_data(\"MethodInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(methodName) + "\"")
        + ", " + java_map_entry("pkg", package_info_code(owner))
        + ", " + java_map_entry("params", reflection_method_param_infos_code(function.parameters, owner, allModules))
        + ", " + java_map_entry("return_type", reflection_any_info_code(function.returnType, owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            java_object_annotation_values(methodName, annotationSources.methodAnnotations),
            owner,
            allModules
        ))
        + "))"

/// Emits generated code for reflection object interface method infos.
private fun reflection_object_interface_method_infos_code(interfaceName: String, functions: List[CompiledFunction], annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_object_interface_method_info_codes(interfaceName, functions, annotationSources, owner, allModules))

/// Collects reflection metadata entries for reflection object interface method info codes.
private fun reflection_object_interface_method_info_codes(interfaceName: String, functions: List[CompiledFunction], annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_object_interface_method_function_for_interface(function, interfaceName)
        then [reflection_object_interface_method_info_code(function, annotationSources, owner, allModules)]
            + reflection_object_interface_method_info_codes(interfaceName, functions[1:], annotationSources, owner, allModules)
        else reflection_object_interface_method_info_codes(interfaceName, functions[1:], annotationSources, owner, allModules)

/// Emits generated code for reflection object interface method info.
private fun reflection_object_interface_method_info_code(function: CompiledFunction, annotationSources: JavaObjectAnnotationSources, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let interfaceName = compiled_object_interface_method_owner_name(function.name)
    let methodName = compiled_object_interface_method_name(function.name)
    "__capy_data(\"MethodInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(methodName) + "\"")
        + ", " + java_map_entry("pkg", package_info_code(owner))
        + ", " + java_map_entry("params", reflection_method_param_infos_code(function.parameters, owner, allModules))
        + ", " + java_map_entry("return_type", reflection_any_info_code(function.returnType, owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            java_object_annotation_values(methodName, annotationSources.methodAnnotations),
            owner,
            allModules
        ))
        + "))"

/// Collects object reflection annotation schema values for one object owner.
private fun java_object_annotation_sources(ownerName: String, functions: List[CompiledFunction]): JavaObjectAnnotationSources =
    match functions[0] with
    case None -> JavaObjectAnnotationSources { typeAnnotations: [], fieldAnnotations: {:}, methodAnnotations: {:} }
    case Some { function } ->
        let rest = java_object_annotation_sources(ownerName, functions[1:])
        if compiled_schema(function) & java_generator_string_has_prefix(function.name, "__capy_oo_annotation|type|" + ownerName + "|")
        then rest.with(typeAnnotations: [schema_value(function)] + rest.typeAnnotations)
        else if compiled_schema(function) & java_generator_string_has_prefix(function.name, "__capy_oo_annotation|field|" + ownerName + "|")
        then rest.with(fieldAnnotations: java_object_annotation_values_add(rest.fieldAnnotations, java_object_annotation_member_key(function.name, "__capy_oo_annotation|field|" + ownerName + "|"), schema_value(function)))
        else if compiled_schema(function) & java_generator_string_has_prefix(function.name, "__capy_oo_annotation|method|" + ownerName + "|")
        then rest.with(methodAnnotations: java_object_annotation_values_add(rest.methodAnnotations, java_object_annotation_member_key(function.name, "__capy_oo_annotation|method|" + ownerName + "|"), schema_value(function)))
        else rest

/// Adds one object annotation schema value while preserving source order.
private fun java_object_annotation_values_add(index: Dict[JavaObjectAnnotationValues], key: String, value: String): Dict[JavaObjectAnnotationValues] =
    match index.get(key) with
    case Some { existing } -> index + (key, JavaObjectAnnotationValues { values: [value] + existing.values })
    case None -> index + (key, JavaObjectAnnotationValues { values: [value] })

/// Returns object annotation schema values for a member key.
private fun java_object_annotation_values(key: String, index: Dict[JavaObjectAnnotationValues]): List[String] =
    match index.get(key) with
    case Some { values } -> values.values
    case None -> []

/// Extracts the first path segment after an object annotation prefix.
private fun java_object_annotation_member_key(name: String, prefix: String): String =
    let rest = name[prefix.size().value, name.size().value]
    let separator = first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Emits generated code for reflection method param infos.
private fun reflection_method_param_infos_code(parameters: List[CompiledFunctionParameter], owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_method_param_info_codes(parameters, owner, allModules))

/// Collects reflection metadata entries for reflection method parameter info codes.
private fun reflection_method_param_info_codes(parameters: List[CompiledFunctionParameter], owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [reflection_method_param_info_code(parameter, owner, allModules)]
            + reflection_method_param_info_codes(parameters[1:], owner, allModules)

/// Emits generated code for reflection method param info.
private fun reflection_method_param_info_code(parameter: CompiledFunctionParameter, owner: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"FieldInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(parameter.name) + "\"")
        + ", " + java_map_entry("type", reflection_any_info_code(parameter.typeReference, owner, allModules))
        + ", " + java_map_entry("annotations", "java.util.List.of()")
        + "))"

/// Emits generated code for reflection parent infos.
private fun reflection_parent_infos_code(parents: List[String], owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_set_code(reflection_parent_info_codes(parents, owner, allModules))

/// Collects reflection metadata entries for reflection parent info codes.
private fun reflection_parent_info_codes(parents: List[String], owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        [reflection_any_info_code(schema_type_reference(parent), owner, allModules)]
            + reflection_parent_info_codes(parents[1:], owner, allModules)

/// Checks whether method metadata matches the object method call rule.
private fun object_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_method(call, env, module, allModules) with
    case Some _ -> true
    case None -> false

/// Computes the compiled type for object method call.
private fun object_method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_object_method(call, env, module, allModules) with
    case Some { binding } -> effect_type(binding.method.returnType)
    case None -> effect_type(object_type())

/// Emits generated code for object method call.
private fun object_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_object_method(call, env, module, allModules) with
    case Some { binding } -> object_method_call_code_with_binding(binding, call, env, expectedType, module, allModules)
    case None -> expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
        + "." + java_method_name(call.name)
        + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun object_method_call_code_with_binding(binding: JavaResolvedObjectMethod, call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = if expectedType.name == "Effect" then first_type_argument(expectedType) else binding.method.returnType
    let rawCode = expression_code(call.receiver, env, binding.receiverType, module, allModules)
        + "." + java_method_name(call.name)
        + "(" + parameter_expression_list_code(binding.method.parameters, call.arguments, env, module, allModules) + ")"
    if expectedType.name == "Effect"
    then "capy.lang.Effect.delay(() -> " + java_object_value_code(rawCode, binding.method.returnType, valueType) + ")"
    else java_object_value_code(rawCode, binding.method.returnType, valueType)

/// Checks whether object method call can be emitted by the target backend.
private fun object_method_call_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_method(call, env, module, allModules) with
    case Some { binding } ->
        expression_emittable(call.receiver, env, module, allModules)
            & parameters_emittable_and_assignable(binding.method.parameters, call.arguments, env, module, allModules)
    case None -> false

/// Finds an object method in available declarations, imports, or modules.
private fun find_object_method(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaResolvedObjectMethod] =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    find_object_method_with_receiver_type(call, receiverType, module, allModules)

private fun find_object_method_with_receiver_type(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaResolvedObjectMethod] =
    match find_object_class_by_type(receiverType, allModules) with
    case Some { binding } ->
        {
            match find_object_method_in_methods(call.name, binding.objectClass.methods) with
            case Some { method } -> /capy/lang/Option.Some { JavaResolvedObjectMethod { receiverType: java_object_type_reference_for_class(binding.moduleClassName, binding.objectClass), method: method } }
            case None -> find_object_interface_method(call.name, receiverType, module, allModules)
        }
    case _ -> find_object_interface_method(call.name, receiverType, module, allModules)

/// Finds an object interface method in available declarations, imports, or modules.
private fun find_object_interface_method(name: String, receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaResolvedObjectMethod] =
    match find_object_interface_by_type(receiverType, allModules) with
    case Some { binding } -> {
        match find_object_method_in_methods(name, binding.objectInterface.methods) with
        case Some { method } -> /capy/lang/Option.Some { JavaResolvedObjectMethod { receiverType: java_object_interface_type_reference(binding), method: method } }
        case None -> /capy/lang/Option.None {}
    }
    case None -> /capy/lang/Option.None {}

/// Checks whether the current value satisfies the object field access rule for compiler processing.
private fun object_field_access(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_field(access, env, module, allModules) with
    case Some _ -> true
    case None -> false

/// Finds an object field in available declarations, imports, or modules.
private fun find_object_field(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectFieldBinding] =
    let receiverType = expression_type(access.receiver, env, module, allModules)
    match find_object_class_by_type(receiverType, allModules) with
    case Some { binding } ->
        {
            match find_object_field_in_class(access.name, binding.objectClass.fields) with
            case Some { field } -> /capy/lang/Option.Some { JavaObjectFieldBinding { moduleClassName: binding.moduleClassName, objectClass: binding.objectClass, field: field } }
            case None -> /capy/lang/Option.None {}
        }
    case _ -> /capy/lang/Option.None {}

/// Finds an object field in class in available declarations, imports, or modules.
private fun find_object_field_in_class(name: String, fields: List[CompiledObjectOrientedField]): /capy/lang/Option[CompiledObjectOrientedField] =
    match fields[0] with
    case None -> /capy/lang/Option.None {}
    case Some { field } ->
        if field.name == name
        then /capy/lang/Option.Some { field }
        else find_object_field_in_class(name, fields[1:])

/// Finds an object method in methods in available declarations, imports, or modules.
private fun find_object_method_in_methods(name: String, methods: List[CompiledObjectOrientedMethod]): /capy/lang/Option[CompiledObjectOrientedMethod] =
    match methods[0] with
    case None -> /capy/lang/Option.None {}
    case Some { method } ->
        if method.name == name
        then /capy/lang/Option.Some { method }
        else find_object_method_in_methods(name, methods[1:])

/// Finds an object class in scope in available declarations, imports, or modules.
private fun find_object_class_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    if qualified_call_name(name)
    then find_qualified_object_class(name, module, allModules)
    else match find_object_class(name, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_object_class_in_imports(name, module.imports, module, allModules)

/// Finds an object class in available declarations, imports, or modules.
private fun find_object_class(name: String, module: CompiledModule): /capy/lang/Option[JavaObjectClassBinding] =
    find_object_class_in_functions(name, module.functions, module)

/// Finds an object class in schema helper functions without materializing unrelated classes.
private fun find_object_class_in_functions(name: String, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[JavaObjectClassBinding] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if compiled_object_class_schema(function)
        then
            let className = function.name[oo_class_schema_prefix_size(), function.name.size().value]
            if className == name
            then /capy/lang/Option.Some { JavaObjectClassBinding { moduleClassName: module_fqcn(module), module: module, objectClass: compiled_object_class(function, functions) } }
            else find_object_class_in_functions(name, functions[1:], module)
        else find_object_class_in_functions(name, functions[1:], module)

/// Finds a qualified object class in available declarations, imports, or modules.
private fun find_qualified_object_class(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    let className = qualified_call_class_name(name, module)
    let member = qualified_call_member(name)
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_object_class(member, importedModule)
    case None -> /capy/lang/Option.None {}

/// Finds an object class in classes in available declarations, imports, or modules.
private fun find_object_class_in_classes(name: String, classes: List[CompiledObjectOrientedClass], module: CompiledModule): /capy/lang/Option[JavaObjectClassBinding] =
    match classes[0] with
    case None -> /capy/lang/Option.None {}
    case Some { objectClass } ->
        if objectClass.name == name
        then /capy/lang/Option.Some { JavaObjectClassBinding { moduleClassName: module_fqcn(module), module: module, objectClass: objectClass } }
        else find_object_class_in_classes(name, classes[1:], module)

/// Finds an object class in imports in available declarations, imports, or modules.
private fun find_object_class_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !stdlib_import(declaration.modulePath) & !declaration.qualified & import_includes_name(name, declaration)
        then find_object_class_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_object_class_in_imports(name, imports[1:], module, allModules)

/// Finds an object class in import in available declarations, imports, or modules.
private fun find_object_class_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[JavaObjectClassBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        {
            match find_object_class(name, importedModule) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> find_object_class_in_imports(name, rest, module, allModules)
        }
    case _ -> find_object_class_in_imports(name, rest, module, allModules)

/// Finds an object class by type in available declarations, imports, or modules.
private fun find_object_class_by_type(type: CompiledTypeReference, modules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    if !java_object_receiver_type(type.name)
    then /capy/lang/Option.None {}
    else find_object_class_by_type_name(type.name, modules)

/// Finds an object class by encoded type name in available declarations, imports, or modules.
private fun find_object_class_by_type_name(typeName: String, modules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    let moduleClassName = java_object_type_owner_class_name(typeName)
    let className = java_object_type_member_name(typeName)
    if moduleClassName.is_empty()
    then find_object_class_by_type_name_in_modules(typeName, modules)
    else match find_module_by_class(moduleClassName, modules) with
        case Some { module } -> {
            match find_object_class_by_encoded_name(className, module.functions, module) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> find_object_class_by_type_name_in_modules(typeName, modules)
        }
        case None -> find_object_class_by_type_name_in_modules(typeName, modules)

/// Finds an object class by encoded type name with the historical module scan.
private fun find_object_class_by_type_name_in_modules(typeName: String, modules: List[CompiledModule]): /capy/lang/Option[JavaObjectClassBinding] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match find_object_class_by_type_in_module(typeName, module.functions, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_object_class_by_type_name_in_modules(typeName, modules[1:])

/// Finds an object class by the encoded Java identifier segment.
private fun find_object_class_by_encoded_name(encodedName: String, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[JavaObjectClassBinding] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if compiled_object_class_schema(function)
        then
            let className = function.name[oo_class_schema_prefix_size(), function.name.size().value]
            if java_identifier(className) == encodedName
            then /capy/lang/Option.Some { JavaObjectClassBinding { moduleClassName: module_fqcn(module), module: module, objectClass: compiled_object_class(function, functions) } }
            else find_object_class_by_encoded_name(encodedName, functions[1:], module)
        else find_object_class_by_encoded_name(encodedName, functions[1:], module)

/// Extracts the owner module class from an encoded object type name.
private fun java_object_type_owner_class_name(typeName: String): String =
    let rawName = typeName[java_object_type_prefix_size(), typeName.size().value]
    let idx = last_dot_index(rawName)
    if idx < 0 then "" else rawName[0, idx]

/// Extracts the encoded member identifier from an encoded object type name.
private fun java_object_type_member_name(typeName: String): String =
    let rawName = typeName[java_object_type_prefix_size(), typeName.size().value]
    let idx = last_dot_index(rawName)
    if idx < 0 then rawName else rawName[idx + 1, rawName.size().value]

/// Finds an object class by type in a module without materializing unrelated classes.
private fun find_object_class_by_type_in_module(typeName: String, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[JavaObjectClassBinding] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if compiled_object_class_schema(function)
        then
            let className = function.name[oo_class_schema_prefix_size(), function.name.size().value]
            if typeName == java_object_type_name(module, className)
            then /capy/lang/Option.Some { JavaObjectClassBinding { moduleClassName: module_fqcn(module), module: module, objectClass: compiled_object_class(function, functions) } }
            else find_object_class_by_type_in_module(typeName, functions[1:], module)
        else find_object_class_by_type_in_module(typeName, functions[1:], module)

/// Finds an object interface by type in available declarations, imports, or modules.
private fun find_object_interface_by_type(type: CompiledTypeReference, modules: List[CompiledModule]): /capy/lang/Option[JavaObjectInterfaceBinding] =
    if !java_object_receiver_type(type.name)
    then /capy/lang/Option.None {}
    else find_object_interface_by_type_name(type.name, modules)

/// Finds an object interface by encoded type name in available declarations, imports, or modules.
private fun find_object_interface_by_type_name(typeName: String, modules: List[CompiledModule]): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match find_object_interface_by_type_in_module(typeName, module.functions, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_object_interface_by_type_name(typeName, modules[1:])

/// Finds an object interface by type in a module without materializing unrelated interfaces.
private fun find_object_interface_by_type_in_module(typeName: String, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if compiled_object_interface_schema(function)
        then
            let interfaceName = function.name[oo_interface_schema_prefix_size(), function.name.size().value]
            if typeName == java_object_interface_type_name(module, interfaceName)
            then /capy/lang/Option.Some { JavaObjectInterfaceBinding { moduleClassName: module_fqcn(module), module: module, objectInterface: compiled_object_interface(function, functions) } }
            else find_object_interface_by_type_in_module(typeName, functions[1:], module)
        else find_object_interface_by_type_in_module(typeName, functions[1:], module)

/// Finds an object interface by name in available declarations, imports, or modules.
private fun find_object_interface_by_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectInterfaceBinding] =
    if qualified_call_name(name)
    then find_qualified_object_interface(name, module, allModules)
    else match find_object_interface(name, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_object_interface_in_imports(name, module.imports, module, allModules)

/// Finds a qualified object interface in available declarations, imports, or modules.
private fun find_qualified_object_interface(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectInterfaceBinding] =
    let className = qualified_call_class_name(name, module)
    let member = qualified_call_member(name)
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_object_interface(member, importedModule)
    case None -> /capy/lang/Option.None {}

/// Finds an object interface in available declarations, imports, or modules.
private fun find_object_interface(name: String, module: CompiledModule): /capy/lang/Option[JavaObjectInterfaceBinding] =
    find_object_interface_in_functions(name, module.functions, module)

/// Finds an object interface in schema helper functions without materializing unrelated interfaces.
private fun find_object_interface_in_functions(name: String, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if compiled_object_interface_schema(function)
        then
            let interfaceName = function.name[oo_interface_schema_prefix_size(), function.name.size().value]
            if interfaceName == name
            then /capy/lang/Option.Some { JavaObjectInterfaceBinding { moduleClassName: module_fqcn(module), module: module, objectInterface: compiled_object_interface(function, functions) } }
            else find_object_interface_in_functions(name, functions[1:], module)
        else find_object_interface_in_functions(name, functions[1:], module)

/// Finds an object interface in interfaces in available declarations, imports, or modules.
private fun find_object_interface_in_interfaces(name: String, interfaces: List[CompiledObjectOrientedInterface], module: CompiledModule): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match interfaces[0] with
    case None -> /capy/lang/Option.None {}
    case Some { objectInterface } ->
        if objectInterface.name == name
        then /capy/lang/Option.Some { JavaObjectInterfaceBinding { moduleClassName: module_fqcn(module), module: module, objectInterface: objectInterface } }
        else find_object_interface_in_interfaces(name, interfaces[1:], module)

/// Finds an object interface in imports in available declarations, imports, or modules.
private fun find_object_interface_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !stdlib_import(declaration.modulePath) & !declaration.qualified & import_includes_name(name, declaration)
        then find_object_interface_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_object_interface_in_imports(name, imports[1:], module, allModules)

/// Finds an object interface in import in available declarations, imports, or modules.
private fun find_object_interface_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[JavaObjectInterfaceBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        {
            match find_object_interface(name, importedModule) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> find_object_interface_in_imports(name, rest, module, allModules)
        }
    case _ -> find_object_interface_in_imports(name, rest, module, allModules)

/// Resolves type metadata for object type reference.
private fun java_object_type_reference(module: CompiledModule, objectClass: CompiledObjectOrientedClass): CompiledTypeReference =
    java_object_type_reference_for_class(module_fqcn(module), objectClass)

/// Resolves type metadata for object type reference for class.
private fun java_object_type_reference_for_class(moduleClassName: String, objectClass: CompiledObjectOrientedClass): CompiledTypeReference =
    CompiledTypeReference { name: java_object_type_name_for_class(moduleClassName, objectClass.name), arguments: [] }

/// Resolves type metadata for object interface type reference.
private fun java_object_interface_type_reference(binding: JavaObjectInterfaceBinding): CompiledTypeReference =
    CompiledTypeReference { name: java_object_interface_type_name_for_class(binding.moduleClassName, binding.objectInterface.name), arguments: [] }

/// Resolves type metadata for object interface type reference for a module.
private fun java_object_interface_type_reference_for_module(module: CompiledModule, objectInterface: CompiledObjectOrientedInterface): CompiledTypeReference =
    CompiledTypeReference { name: java_object_interface_type_name(module, objectInterface.name), arguments: [] }

/// Computes the Java type name for object.
private fun java_object_type_name(module: CompiledModule, className: String): String =
    java_object_type_name_for_class(module_fqcn(module), className)

/// Computes the Java name for object type name for class.
private fun java_object_type_name_for_class(moduleClassName: String, className: String): String =
    JAVA_OBJECT_TYPE_PREFIX + moduleClassName + "." + java_identifier(className)

/// Computes the Java type name for object interface.
private fun java_object_interface_type_name(module: CompiledModule, interfaceName: String): String =
    java_object_interface_type_name_for_class(module_fqcn(module), interfaceName)

/// Computes the Java name for object interface type name for class.
private fun java_object_interface_type_name_for_class(moduleClassName: String, interfaceName: String): String =
    JAVA_OBJECT_TYPE_PREFIX + java_object_interface_java_name(moduleClassName, interfaceName)

/// Computes the Java name for object interface Java.
private fun java_object_interface_java_name(moduleClassName: String, interfaceName: String): String =
    let packageName = java_object_interface_package_name(moduleClassName)
    if packageName.is_empty()
    then java_identifier(interfaceName)
    else packageName + "." + java_identifier(interfaceName)

/// Computes the Java name for object interface package.
private fun java_object_interface_package_name(moduleClassName: String): String =
    let idx = last_dot_index(moduleClassName)
    if idx < 0 then "" else moduleClassName[0, idx]

/// Checks whether a type reference matches the object type rule.
private fun java_object_type(type: CompiledTypeReference): bool =
    java_generator_string_has_prefix(type.name, JAVA_OBJECT_TYPE_PREFIX)

/// Computes the Java name for object type Java.
private fun java_object_type_java_name(type: CompiledTypeReference): String =
    type.name[java_object_type_prefix_size(), type.name.size().value]

/// Checks whether a call has the standard-library to seq call shape.
private fun stdlib_to_seq_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "to_seq" & seq_member_imported("to_seq", module.imports) & one_method_argument(call.arguments)

/// Emits generated code for standard-library to seq.
private fun stdlib_to_seq_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    "capy.collection.Seq.toSeq(" + expression_code(argumentExpression, env, argumentType, module, allModules) + ")"

/// Emits generated code for enum parse call.
private fun enum_parse_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = enum_qualified_type_name(call.name)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    let parseByName = type_assignable(string_type(), argumentType)
    let inputName = "__capy_enum_parse_value_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<java.lang.Object>) () -> {" + newline()
        + "            java.lang.Object " + inputName + " = " + expression_code(argumentExpression, env, enum_parse_argument_type(argumentType), module, allModules) + ";" + newline()
        + enum_parse_cases_code(typeName, enum_values(typeName, module, allModules), 0, inputName, parseByName, module, allModules)
        + "            return __capy_error(\"capy.lang.parse.invalid_enum\", \"Cannot parse "
        + escape_java_string(typeName)
        + " from \" + "
        + inputName
        + ");" + newline()
        + "        }).get()"

/// Computes the compiled type for enum parse argument.
private fun enum_parse_argument_type(argumentType: CompiledTypeReference): CompiledTypeReference =
    if type_assignable(string_type(), argumentType)
    then string_type()
    else int_type()

/// Emits generated code for enum parse cases.
private fun enum_parse_cases_code(typeName: String, values: List[String], idx: int, inputName: String, parseByName: bool, module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        "            if (java.util.Objects.equals(" + inputName + ", " + enum_parse_expected_value_code(value, idx, parseByName) + ")) {" + newline()
            + "                return __capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", "
            + enum_value_reference_code(typeName, value, module, allModules)
            + ")));" + newline()
            + "            }" + newline()
            + enum_parse_cases_code(typeName, values[1:], idx + 1, inputName, parseByName, module, allModules)

/// Emits generated code for enum parse expected value.
private fun enum_parse_expected_value_code(value: String, idx: int, parseByName: bool): String =
    if parseByName
    then "\"" + escape_java_string(value) + "\""
    else "" + idx

/// Emits generated code for parameter expression list.
private fun parameter_expression_list_code(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_for_expression(parameters, expression, env, module, allModules)
        expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

/// Formats the recursive tail segment for parameter expression list.
private fun parameter_expression_list_tail(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_for_expression(parameters, expression, env, module, allModules)
        ", " + expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

/// Resolves a parameter type without inferring the expression type when a declaration is available.
private fun parameter_type_for_expression(parameters: List[CompiledFunctionParameter], expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match parameters[0] with
    case Some { parameter } -> parameter.typeReference
    case None -> expression_type(expression, env, module, allModules)

/// Resolves type metadata for parameter type at.
private fun parameter_type_at(parameters: List[CompiledFunctionParameter], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match parameters[idx] with
    case Some { parameter } -> parameter.typeReference
    case None -> fallback

/// Resolves expression metadata for argument.
private fun argument(arguments: List[CompiledExpression], idx: int): CompiledExpression =
    match arguments[idx] with
    case Some { expression } -> expression
    case None -> missing_argument()

/// Formats one missing argument for generated emission.
private fun missing_argument(): CompiledExpression =
    CompiledUnsupportedExpression {
        source: "missing argument",
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

/// Emits generated code for method call.
private fun method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "size" & call.arguments.is_empty()
    then size_method_code(call, env, module, allModules)
    else if char_to_string_call(call, env, module, allModules)
    then char_to_string_code(call, env, module, allModules)
    else if enum_name_method_call(call, env, module, allModules)
    then "__capy_enum_name(" + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules) + ")"
    else if assert_is_empty_call(call)
    then assert_is_empty_code(call, env, module, allModules)
    else if option_assert_is_equal_to_call(call, env, module, allModules)
    then option_assert_is_equal_to_code(call, env, module, allModules)
    else if result_assert_is_equal_to_call(call, env, module, allModules)
    then result_assert_is_equal_to_code(call, env, module, allModules)
    else if result_assert_succeeds_lambda_call(call, env, module, allModules)
    then result_assert_succeeds_lambda_code(call, env, module, allModules)
    else if assert_method_call(call, env, module, allModules)
    then assert_method_call_code(call, env, module, allModules)
    else if negated_collection_is_empty_call(call, env, module, allModules)
    then negated_collection_is_empty_code(call, env, module, allModules)
    else if collection_is_empty_call(call, env, module, allModules)
    then collection_is_empty_code(call, env, module, allModules)
    else if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_code(call, env, module, allModules)
    else if collection_reduce_method_call(call, env, module, allModules)
    then reduce_expression_code(collection_reduce_method_expression(call, expression_type(call.receiver, env, module, allModules)), env, expectedType, module, allModules)
    else if option_method_call(call, env, module, allModules)
    then option_pipe_code(option_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if collection_method_call(call, env, module, allModules)
    then collection_pipe_code(collection_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if set_method_call(call, env, module, allModules)
    then set_method_call_code(call, env, module, allModules)
    else if stdlib_date_time_method_call(call, env, module, allModules)
    then stdlib_date_time_method_call_code(call, env, module, allModules)
    else if native_stdlib_method_call(call, env, module, allModules)
    then native_stdlib_method_code(call, env, expectedType, module, allModules)
    else if seq_as_list_call(call, env, module, allModules)
    then seq_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".asList()"
    else if seq_first_call(call, env, module, allModules)
    then seq_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".first()"
    else if effect_start_method_call(call, env, module, allModules)
    then "capy.lang.Async.start((capy.lang.Effect) " + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules) + ")"
    else if async_join_method_call(call, env, module, allModules)
    then async_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".join()"
    else if async_map_method_call(call, env, module, allModules)
    then async_pipe_code(async_map_method_binary(call), expression_type(call.receiver, env, module, allModules), expectedType, env, module, allModules)
    else if function_value_method_call(call, env, module, allModules)
    then function_value_method_code(call, env, module, allModules)
    else if result_reduce_method_call(call, env, module, allModules)
    then result_reduce_method_code(call, env, expectedType, module, allModules)
    else if result_map_method_call(call, env, module, allModules)
    then result_map_method_code(call, env, expectedType, module, allModules)
    else if result_or_else_method_call(call, env, module, allModules)
    then result_or_else_method_code(call, env, module, allModules)
    else if result_or_method_call(call, env, module, allModules)
    then result_or_method_code(call, env, module, allModules)
    else if effect_map_method_call(call, env, module, allModules)
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        let valueType = first_type_argument(receiverType)
        let bodyExpectedType = if expectedType.name == "Effect" then first_type_argument(expectedType) else object_type()
        match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda ->
            expression_code(call.receiver, env, receiverType, module, allModules)
                + ".map(" + lambda_code_for_value(lambda, valueType, bodyExpectedType, env, module, allModules) + ")"
        case _ -> "unsupported(\"effect map\")"
    else if string_parse_method_call(call, env, module, allModules)
    then string_parse_method_code(call, env, module, allModules)
    else if regex_method_call(call, env, module, allModules)
    then regex_method_code(call, env, module, allModules)
    else if primitive_conversion_method(call.name)
    then primitive_conversion_code(call, env, module, allModules)
    else if object_type_method_call(call, module, allModules)
    then object_type_method_call_code(call, module, allModules)
    else match find_object_method(call, env, module, allModules) with
        case Some { binding } -> object_method_call_code_with_binding(binding, call, env, expectedType, module, allModules)
        case None ->
            match find_extension_method(call, env, module, allModules) with
            case Some { function } -> extension_method_call_code(function, call, env, module, allModules)
            case None -> expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
                + "." + java_method_name(call.name)
                + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

/// Checks whether a function matches the function value method call metadata.
private fun function_value_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "__capy_call"
    then function_type(expression_type(call.receiver, env, module, allModules))
    else false

private fun effect_map_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "map"
    then expression_type(call.receiver, env, module, allModules).name == "Effect"
    else false

private fun effect_start_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "start"
    then call.arguments.is_empty()
        & expression_type(call.receiver, env, module, allModules).name == "Effect"
    else false

private fun async_join_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "join"
    then call.arguments.is_empty()
        & async_type_name(expression_type(call.receiver, env, module, allModules).name)
    else false

private fun async_map_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if async_map_method_name(call.name)
    then result_map_method_argument(call.arguments)
        & async_type_name(expression_type(call.receiver, env, module, allModules).name)
    else false

private fun async_map_method_name(name: String): bool =
    name == "map" | name == "flat_map" | name == "`|`" | name == "`|*`"

private fun async_map_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: if call.name == "flat_map" | call.name == "`|*`" then "|*" else "|",
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

/// Emits generated code for function value method.
private fun function_value_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let parameters = function_type_parameters(receiverType)
    let target = expression_code(call.receiver, env, receiverType, module, allModules)
    if parameters.is_empty()
    then target + ".get()"
    else target + ".apply(" + function_value_call_arguments(parameters, call.arguments, env, module, allModules) + ")"

/// Checks whether method metadata matches the result map method call rule.
private fun result_map_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "map" | call.name == "flat_map"
    then
        if result_map_method_argument(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

/// Checks whether method metadata matches the result reduce method call rule.
private fun result_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "reduce" | call.name == "reduce_left"
    then
        if result_reduce_method_arguments(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

/// Checks whether method metadata matches the result or else method call rule.
private fun result_or_else_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or_else"
    then
        if one_method_argument(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

/// Checks whether method metadata matches the result or method call rule.
private fun result_or_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or"
    then
        if one_method_argument(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

/// Checks whether method metadata matches the result reduce method arguments rule.
private fun result_reduce_method_arguments(arguments: List[CompiledExpression]): bool =
    result_reduce_method_argument_at(arguments, 0)
        & result_reduce_method_argument_at(arguments, 1)
        & no_third_expression(arguments)

/// Checks whether method metadata matches the result reduce method argument at rule.
private fun result_reduce_method_argument_at(arguments: List[CompiledExpression], idx: int): bool =
    match arguments[0] with
    case Some { expression } ->
        if idx == 0
        then result_reduce_method_lambda_argument(expression)
        else result_reduce_method_argument_at(arguments[1:], idx - 1)
    case None -> false

/// Checks whether method metadata matches the result reduce method lambda argument rule.
private fun result_reduce_method_lambda_argument(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case _ -> false

/// Checks whether method metadata matches the result map method argument rule.
private fun result_map_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case Some { expression } -> result_map_method_lambda_argument(expression) & no_second_expression(arguments)
    case None -> false

/// Checks whether method metadata matches the result map method lambda argument rule.
private fun result_map_method_lambda_argument(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

/// Emits generated code for result map method.
private fun result_map_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    result_pipe_code(result_map_method_binary(call), receiverType, expectedType, env, module, allModules)

/// Emits generated code for result reduce method.
private fun result_reduce_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let resultType = if expectedType.name.is_empty() | expectedType.name == "any" then result_reduce_method_type_with_receiver(call, receiverType, env, module, allModules) else expectedType
    let resultName = "__capy_result_reduce_" + call.location.line + "_" + call.location.column
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let successLambda = result_reduce_lambda_argument(argument(call.arguments, 0))
    let errorLambda = result_reduce_lambda_argument(argument(call.arguments, 1))
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + receiverCode + ";" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + result_reduce_success_binding_statement(successLambda.parameters, valueType, resultName, "                ")
    + "                return " + expression_code(successLambda.body, lambda_value_env(successLambda.parameters, valueType, env), resultType, module, allModules) + ";" + newline()
    + "            }" + newline()
    + result_reduce_error_binding_statement(errorLambda.parameters, resultName, "            ")
    + "            return " + expression_code(errorLambda.body, lambda_value_env(errorLambda.parameters, error_type(), env), resultType, module, allModules) + ";" + newline()
    + "        }).get()"

/// Emits generated code for result or else method.
private fun result_or_else_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let resultType = result_or_else_method_type_with_receiver(call, receiverType, env, module, allModules)
    let resultName = "__capy_result_or_else_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + expression_code(call.receiver, env, receiverType, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + "                return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + resultName + "));" + newline()
    + "            }" + newline()
    + "            return " + expression_code(argument(call.arguments, 0), env, resultType, module, allModules) + ";" + newline()
    + "        }).get()"

/// Emits generated code for result or method.
private fun result_or_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let resultType = result_or_method_type_with_receiver(call, receiverType, env, module, allModules)
    let resultName = "__capy_result_or_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + expression_code(call.receiver, env, receiverType, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_error(" + resultName + ")) {" + newline()
    + "                return " + expression_code(argument(call.arguments, 0), env, resultType, module, allModules) + ";" + newline()
    + "            }" + newline()
    + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
    + "        }).get()"

/// Formats one result reduce lambda argument for generated emission.
private fun result_reduce_lambda_argument(expression: CompiledExpression): CompiledLambdaExpression =
    match expression with
    case CompiledLambdaExpression lambda -> lambda
    case _ -> CompiledLambdaExpression {
        parameters: [],
        body: missing_argument(),
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

/// Emits one generated statement for result reduce success binding.
private fun result_reduce_success_binding_statement(parameters: List[String], valueType: CompiledTypeReference, resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "));" + newline()

/// Emits one generated statement for result reduce error binding.
private fun result_reduce_error_binding_statement(parameters: List[String], resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + java_type(error_type()) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(error_type()) + ") __capy_result_error_value(" + resultName + "));" + newline()

/// Resolves expression metadata for result map method binary.
private fun result_map_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: if call.name == "flat_map" then "|*" else "|",
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

/// Checks whether method metadata matches the option method call rule.
private fun option_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if option_method_name(call.name) & one_method_argument(call.arguments)
    then option_type_name(expression_type(call.receiver, env, module, allModules).name)
        & match argument(call.arguments, 0) with
            case CompiledLambdaExpression _ -> true
            case _ -> false
    else false

/// Checks whether method metadata matches the option method name rule.
private fun option_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "flat_map"

/// Resolves expression metadata for option method binary.
private fun option_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: option_method_operator(call.name),
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

/// Maps option method to the compiler operator category.
private fun option_method_operator(name: String): String =
    if name == "filter" then "|-"
    else if name == "flat_map" then "|*"
    else "|"

/// Checks whether method metadata matches the collection method call rule.
private fun collection_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if collection_method_name(call.name)
        & one_method_argument(call.arguments)
        & lambda_expression(argument(call.arguments, 0))
    then collection_pipe_receiver_type(expression_type(call.receiver, env, module, allModules))
    else false

/// Checks whether method metadata matches the collection method name rule.
private fun collection_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "`|-`" | name == "reject" | name == "flat_map"

/// Resolves expression metadata for collection method binary.
private fun collection_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: collection_method_operator(call.name),
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

/// Maps collection method to the compiler operator category.
private fun collection_method_operator(name: String): String =
    if name == "filter" | name == "`|-`" then "|-"
    else if name == "reject" then "|!"
    else if name == "flat_map" then "|*"
    else "|"

/// Checks whether method metadata matches the collection reduce method call rule.
private fun collection_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "reduce" | call.name == "reduce_left"
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        collection_pipe_receiver_type(receiverType)
            & collection_reduce_method_arguments(call.arguments, receiverType)
    else false

/// Checks whether method metadata matches the collection reduce method arguments rule.
private fun collection_reduce_method_arguments(arguments: List[CompiledExpression], receiverType: CompiledTypeReference): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some { reducer } ->
            no_third_expression(arguments)
                & match reducer with
                    case CompiledLambdaExpression lambda -> collection_reduce_lambda_parameters_supported(lambda.parameters, receiverType)
                    case CompiledFunctionReferenceExpression _ -> true
                    case _ -> false

/// Checks whether collection reduce lambda parameters is supported by the current backend.
private fun collection_reduce_lambda_parameters_supported(parameters: List[String], receiverType: CompiledTypeReference): bool =
    if receiverType.name == "Dict"
    then reduce_lambda_arity_supported(parameters, 3)
    else reduce_lambda_arity_supported(parameters, 2)

/// Checks whether reduce lambda arity is supported by the current backend.
private fun reduce_lambda_arity_supported(parameters: List[String], arity: int): bool =
    if arity == 0
    then parameters.is_empty()
    else match parameters[0] with
        case None -> false
        case Some _ -> reduce_lambda_arity_supported(parameters[1:], arity - 1)

/// Resolves expression metadata for collection reduce method expression.
private fun collection_reduce_method_expression(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference): CompiledReduceExpression =
    match argument(call.arguments, 1) with
    case CompiledLambdaExpression lambda ->
        CompiledReduceExpression {
            receiver: call.receiver,
            initial: argument(call.arguments, 0),
            accumulatorName: reduce_lambda_parameter(lambda.parameters, 0),
            keyName: reduce_lambda_key_parameter(lambda.parameters),
            valueName: reduce_lambda_value_parameter(lambda.parameters),
            body: lambda.body,
            location: call.location
        }
    case CompiledFunctionReferenceExpression reference ->
        let dictReceiver = receiverType.name == "Dict"
        let accumulatorName = "__capy_acc"
        let valueName = "__capy_value"
        let keyName = if dictReceiver then "__capy_key" else ""
        CompiledReduceExpression {
            receiver: call.receiver,
            initial: argument(call.arguments, 0),
            accumulatorName: accumulatorName,
            keyName: keyName,
            valueName: valueName,
            body: CompiledFunctionCallExpression {
                name: reference.name,
                arguments: collection_reduce_reference_arguments(accumulatorName, keyName, valueName, reference.location),
                location: reference.location
            },
            location: call.location
        }
    case _ -> CompiledReduceExpression {
        receiver: call.receiver,
        initial: argument(call.arguments, 0),
        accumulatorName: "",
        keyName: "",
        valueName: "",
        body: missing_argument(),
        location: call.location
    }

/// Formats collection reduce reference arguments for generated emission.
private fun collection_reduce_reference_arguments(accumulatorName: String, keyName: String, valueName: String, location: CompiledSourceLocation): List[CompiledExpression] =
    if keyName.is_empty()
    then [
        CompiledVariableExpression { name: accumulatorName, location: location },
        CompiledVariableExpression { name: valueName, location: location }
    ]
    else [
        CompiledVariableExpression { name: accumulatorName, location: location },
        CompiledVariableExpression { name: keyName, location: location },
        CompiledVariableExpression { name: valueName, location: location }
    ]

/// Formats one reduce lambda key parameter for generated emission.
private fun reduce_lambda_key_parameter(parameters: List[String]): String =
    if reduce_lambda_arity_supported(parameters, 3)
    then reduce_lambda_parameter(parameters, 1)
    else ""

/// Formats one reduce lambda value parameter for generated emission.
private fun reduce_lambda_value_parameter(parameters: List[String]): String =
    if reduce_lambda_arity_supported(parameters, 3)
    then reduce_lambda_parameter(parameters, 2)
    else reduce_lambda_parameter(parameters, 1)

/// Formats one reduce lambda parameter for generated emission.
private fun reduce_lambda_parameter(parameters: List[String], idx: int): String =
    match parameters[idx] with
    case Some { parameter } -> parameter
    case None -> ""

/// Computes the compiled type for collection reduce method.
private fun collection_reduce_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(argument(call.arguments, 0), env, module, allModules)

/// Checks whether a call has the seq first call shape.
private fun seq_first_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "first" & call.arguments.is_empty()
    then seq_type_name(expression_type(call.receiver, env, module, allModules).name)
    else false

/// Checks whether method metadata matches the regex method call rule.
private fun regex_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if regex_method_name(call.name)
    then
        if one_method_argument(call.arguments)
        then
            let receiverType = expression_type(call.receiver, env, module, allModules)
            regex_type_name(receiverType.name)
        else false
    else false

/// Checks whether method metadata matches the regex method name rule.
private fun regex_method_name(name: String): bool =
    name == "matches" | name == "find" | name == "find_all" | name == "replace" | name == "split"

/// Emits generated code for regex method.
private fun regex_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let argumentCode = expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
    if call.name == "matches"
    then "__capy_regex_matches(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find"
    then "__capy_regex_find(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find_all"
    then "__capy_regex_find_all_seq(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "replace"
    then "__capy_regex_replacer(" + receiverCode + ", " + argumentCode + ")"
    else "__capy_regex_split(" + receiverCode + ", " + argumentCode + ")"

/// Emits generated code for regex binary.
private fun regex_binary_code(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = expression_type(binary.left, env, module, allModules)
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    let rightCode = expression_code(binary.right, env, string_type(), module, allModules)
    if binary.operator == "?"
    then "__capy_regex_matches(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~"
    then "__capy_regex_find(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~~"
    then "__capy_regex_find_all_seq(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~>"
    then "__capy_regex_replacer(" + leftCode + ", " + rightCode + ")"
    else "__capy_regex_split(" + leftCode + ", " + rightCode + ")"

/// Checks whether a call has the collection predicate call shape.
private fun collection_predicate_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if collection_predicate_method(call.name)
        & one_method_argument(call.arguments)
        & lambda_expression(argument(call.arguments, 0))
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        collection_predicate_receiver_type(receiverType)
    else false

/// Checks whether method metadata matches the collection predicate method rule.
private fun collection_predicate_method(name: String): bool =
    name == "any" | name == "all"

/// Checks whether a type reference matches the collection predicate receiver type rule.
private fun collection_predicate_receiver_type(type: CompiledTypeReference): bool =
    collection_receiver_type(type) | type.name == "Dict"

/// Emits generated code for collection predicate call.
private fun collection_predicate_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    let rawReceiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let receiverCode =
        if seq_type_name(receiverType.name) | receiverType.name == "String"
        then seq_receiver_code(call.receiver, receiverType, env, module, allModules)
        else rawReceiverCode
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda ->
        if receiverType.name == "Dict"
        then dict_predicate_call_code(call.name, rawReceiverCode, lambda, valueType, env, module, allModules)
        else if receiverType.name == "String" & string_indexed_lambda(lambda.parameters)
        then string_indexed_predicate_code(call.name, rawReceiverCode, lambda, env, module, allModules)
        else if seq_type_name(receiverType.name) | receiverType.name == "String"
        then collection_seq_predicate_code(call.name, receiverCode, lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules))
        else receiverCode + ".stream()." + java_stream_predicate_method(call.name) + "(" + lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules) + ")"
    case CompiledFunctionReferenceExpression reference ->
        if receiverType.name == "Dict"
        then "unsupported(\"dict predicate reference\")"
        else if seq_type_name(receiverType.name) | receiverType.name == "String"
        then collection_seq_predicate_code(call.name, receiverCode, function_reference_lambda_code(reference, valueType, bool_type(), module, allModules))
        else receiverCode + ".stream()." + java_stream_predicate_method(call.name) + "(" + function_reference_lambda_code(reference, valueType, bool_type(), module, allModules) + ")"
    case _ -> "unsupported(\"collection predicate\")"

/// Emits generated code for dict predicate call.
private fun dict_predicate_call_code(name: String, receiverCode: String, lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    receiverCode + ".entrySet().stream()." + java_stream_predicate_method(name) + "(__capy_entry -> {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "            ")
        + "            return " + expression_code(lambda.body, dict_predicate_lambda_env(lambda.parameters, valueType, env), bool_type(), module, allModules) + ";" + newline()
        + "        })"

/// Creates name/type bindings for dict predicate lambda.
private fun dict_predicate_lambda_bindings(parameters: List[String], valueType: CompiledTypeReference, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { keyParameter } ->
        match parameters[1] with
        case None -> ""
        case Some { valueParameter } ->
            dict_predicate_key_binding(keyParameter, indent)
                + dict_predicate_value_binding(valueParameter, valueType, indent)

/// Creates one name/type binding for dict predicate key.
private fun dict_predicate_key_binding(parameter: String, indent: String): String =
    if parameter == "_"
    then ""
    else indent + "java.lang.String " + java_identifier(parameter) + " = (java.lang.String) __capy_entry.getKey();" + newline()

/// Creates one name/type binding for dict predicate value.
private fun dict_predicate_value_binding(parameter: String, valueType: CompiledTypeReference, indent: String): String =
    if parameter == "_"
    then ""
    else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_entry.getValue());" + newline()

/// Collects dict predicate lambda environmentironment for compiler processing.
private fun dict_predicate_lambda_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { keyParameter } ->
        match parameters[1] with
        case None -> env
        case Some { valueParameter } ->
            dict_predicate_key_env(keyParameter) + dict_predicate_value_env(valueParameter, valueType) + env

/// Collects dict predicate key environmentironment for compiler processing.
private fun dict_predicate_key_env(parameter: String): List[JavaBinding] =
    if parameter == "_" then [] else [java_binding(parameter, string_type())]

/// Collects dict predicate value environmentironment for compiler processing.
private fun dict_predicate_value_env(parameter: String, valueType: CompiledTypeReference): List[JavaBinding] =
    if parameter == "_" then [] else [java_binding(parameter, valueType)]

/// Emits generated code for string indexed predicate.
private fun string_indexed_predicate_code(name: String, receiverCode: String, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "java.util.stream.IntStream.range(0, " + receiverCode + ".length())."
        + java_stream_predicate_method(name)
        + "(__capy_idx -> "
        + expression_code(lambda.body, string_indexed_lambda_env(lambda.parameters, receiverCode, env), bool_type(), module, allModules)
        + ")"

/// Collects string indexed lambda environmentironment for compiler processing.
private fun string_indexed_lambda_env(parameters: List[String], receiverCode: String, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { charParameter } ->
        match parameters[1] with
        case None -> env
        case Some { indexParameter } ->
            string_indexed_lambda_binding(charParameter, string_type(), "java.lang.String.valueOf(" + receiverCode + ".charAt(__capy_idx))")
                + string_indexed_lambda_binding(indexParameter, int_type(), "__capy_idx")
                + env

/// Creates one name/type binding for string indexed lambda.
private fun string_indexed_lambda_binding(name: String, type: CompiledTypeReference, javaName: String): List[JavaBinding] =
    if name == "_"
    then []
    else [java_binding_with_java_name(name, type, javaName)]

/// Checks whether the current value satisfies the string indexed lambda rule for compiler processing.
private fun string_indexed_lambda(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ ->
            match parameters[2] with
            case None -> true
            case Some _ -> false

/// Emits generated code for collection seq predicate.
private fun collection_seq_predicate_code(name: String, receiverCode: String, lambdaCode: String): String =
    if name == "any"
    then receiverCode + ".any(" + lambdaCode + ")"
    else receiverCode + ".asList().stream().allMatch(" + lambdaCode + ")"

/// Formats Java source text for stream predicate method.
private fun java_stream_predicate_method(name: String): String =
    if name == "any" then "anyMatch" else "allMatch"

/// Checks whether method metadata matches the set method call rule.
private fun set_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if set_method_arity(call)
    then expression_type(call.receiver, env, module, allModules).name == "Set"
    else false

/// Checks whether method metadata matches the set method arity rule.
private fun set_method_arity(call: CompiledMethodCallExpression): bool =
    if set_no_argument_method(call.name)
    then call.arguments.is_empty()
    else if set_one_argument_method(call.name)
    then one_method_argument(call.arguments)
    else false

/// Checks whether method metadata matches the set no argument method rule.
private fun set_no_argument_method(name: String): bool =
    name == "power_set" | name == "℘"

/// Checks whether method metadata matches the set one argument method rule.
private fun set_one_argument_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"
        | name == "union" | name == "intersection" | name == "difference"
        | name == "symmetric_difference" | name == "cartesian_product"

/// Emits generated code for set method call.
private fun set_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if call.name == "power_set" | call.name == "℘"
    then "__capy_set_power_set(" + receiverCode + ")"
    else
        let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
        let argumentCode = expression_code(argument(call.arguments, 0), env, argumentType, module, allModules)
        if call.name == "contains"
        then receiverCode + ".contains(" + argumentCode + ")"
        else if call.name == "is_subset_of"
        then "__capy_set_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_proper_subset_of"
        then "__capy_set_proper_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_superset_of"
        then "__capy_set_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "is_proper_superset_of"
        then "__capy_set_proper_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "union"
        then "__capy_set_concat(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "intersection"
        then "__capy_set_intersection(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "difference"
        then "__capy_set_remove_all(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "symmetric_difference"
        then "__capy_set_symmetric_difference(" + receiverCode + ", " + argumentCode + ")"
        else "__capy_set_cartesian_product(" + receiverCode + ", " + argumentCode + ")"

private fun stdlib_date_time_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let ownerName = stdlib_date_time_method_owner_name(receiverType.name)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    match find_stdlib_date_time_method_function(ownerName, call, receiverType, env, module, allModules) with
    case Some { function } ->
        stdlib_date_time_method_class_name(ownerName)
            + "." + java_function_name(function)
            + "(" + receiverCode
            + extension_method_call_argument_tail(function.parameters, bound_extension_method_parameters(function, receiverType), call.arguments, env, module, allModules)
            + ")"
    case None -> "unsupported(\"date/time method\")"

private fun stdlib_date_time_method_owner_name(typeName: String): String =
    let receiver = type_unqualified_name(typeName)
    if stdlib_duration_receiver(receiver) then "Duration" else receiver

private fun stdlib_date_time_method_class_name(ownerName: String): String =
    "capy.date_time." + ownerName

private fun find_stdlib_date_time_method_function(ownerName: String, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(stdlib_date_time_method_class_name(ownerName), allModules) with
    case Some { dateTimeModule } -> find_stdlib_date_time_method_function_in_functions(ownerName, call, receiverType, env, dateTimeModule.functions, module, allModules)
    case None -> /capy/lang/Option.None {}

private fun find_stdlib_date_time_method_function_in_functions(ownerName: String, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if stdlib_date_time_method_function_matches(ownerName, call, receiverType, env, function, module, allModules)
        then /capy/lang/Option.Some { function }
        else find_stdlib_date_time_method_function_in_functions(ownerName, call, receiverType, env, functions[1:], module, allModules)

private fun stdlib_date_time_method_function_matches(ownerName: String, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    method_function_matches(ownerName, call.name, function)
        & parameters_assignable(bound_extension_method_parameters(function, receiverType), call.arguments, env, module, allModules)

/// Checks whether method metadata matches the native standard-library method call rule.
private fun native_stdlib_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if native_stdlib_method_name(call.name)
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        native_stdlib_receiver_method(receiverType, call)
    else false

private fun native_stdlib_method_name(name: String): bool =
    name == "get" | name == "contains_key"

private fun native_stdlib_receiver_method(receiverType: CompiledTypeReference, call: CompiledMethodCallExpression): bool =
    if receiverType.name == "String"
    then call.name == "get" & (one_method_argument(call.arguments) | two_method_arguments(call.arguments))
    else if receiverType.name == "List"
    then call.name == "get" & (one_method_argument(call.arguments) | two_method_arguments(call.arguments))
    else if receiverType.name == "Dict"
    then (call.name == "contains_key" | call.name == "get") & one_method_argument(call.arguments)
    else if receiverType.name == "Tuple"
    then call.name == "get" & one_method_argument(call.arguments)
    else false

/// Emits generated code for native standard-library method.
private fun native_stdlib_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then string_get_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "List"
    then list_get_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "Dict"
    then dict_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "Tuple"
    then tuple_get_method_code(call, receiverCode, expectedType, env, module, allModules)
    else "unsupported(\"native stdlib method\")"

/// Emits generated code for string get method.
private fun string_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if one_method_argument(call.arguments)
    then string_optional_index_code(receiverCode, index_argument_code(argument(call.arguments, 0), env, module, allModules))
    else "__capy_string_slice("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + index_argument_code(argument(call.arguments, 1), env, module, allModules)
        + ")"

/// Emits generated code for list get method.
private fun list_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if one_method_argument(call.arguments)
    then list_optional_index_code(receiverCode, index_argument_code(argument(call.arguments, 0), env, module, allModules))
    else "__capy_list_slice("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + index_argument_code(argument(call.arguments, 1), env, module, allModules)
        + ")"

/// Emits generated code for dict method.
private fun dict_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let keyCode = expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
    if call.name == "contains_key"
    then receiverCode + ".containsKey(" + keyCode + ")"
    else dict_optional_index_code(receiverCode, keyCode)

/// Emits generated code for tuple get method.
private fun tuple_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let methodType = method_call_type(call, env, module, allModules)
    let resultType = if expectedType.name.is_empty() | expectedType.name == "any" then methodType else expectedType
    "((" + boxed_java_type(resultType) + ") "
        + receiverCode
        + ".get(__capy_normalized_index("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ")))"

/// Checks whether method metadata matches the one method argument rule.
private fun one_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ -> arguments[1:].is_empty()

/// Checks whether method metadata matches the two method arguments rule.
private fun two_method_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some _ -> arguments[2:].is_empty()

/// Checks whether a call has the seq as list call shape.
private fun seq_as_list_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "as_list" & call.arguments.is_empty()
    then seq_type_name(expression_type(call.receiver, env, module, allModules).name)
    else false

/// Checks whether a call has the collection is empty call shape.
private fun collection_is_empty_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_empty" & call.arguments.is_empty()
    then collection_empty_receiver_type(expression_type(call.receiver, env, module, allModules))
    else false

/// Checks whether a type reference matches the collection empty receiver type rule.
private fun collection_empty_receiver_type(type: CompiledTypeReference): bool =
    type.name == "List" | type.name == "Set" | type.name == "Dict" | type.name == "String" | seq_type_name(type.name)

/// Emits generated code for collection is empty.
private fun collection_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if seq_type_name(receiverType.name)
    then seq_receiver_code(call.receiver, receiverType, env, module, allModules) + ".asList().isEmpty()"
    else expression_code(call.receiver, env, receiverType, module, allModules) + ".isEmpty()"

/// Checks whether a call has the negated collection is empty call shape.
private fun negated_collection_is_empty_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_empty" & call.arguments.is_empty()
    then match call.receiver with
            case CompiledUnaryExpression unary ->
                unary.operator == "!"
                    & collection_empty_receiver_type(expression_type(unary.expression, env, module, allModules))
            case _ -> false
    else false

/// Emits generated code for negated collection is empty.
private fun negated_collection_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledUnaryExpression unary ->
        let receiverType = expression_type(unary.expression, env, module, allModules)
        if seq_type_name(receiverType.name)
        then "!(" + seq_receiver_code(unary.expression, receiverType, env, module, allModules) + ".asList().isEmpty())"
        else "!(" + expression_code(unary.expression, env, receiverType, module, allModules) + ".isEmpty())"
    case _ -> "unsupported(\"negated collection is_empty\")"

/// Emits generated code for size method.
private fun size_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then receiverCode + ".length()"
    else if receiverType.name == "char"
    then "((java.lang.String) " + receiverCode + ").length()"
    else receiverCode + ".size()"

/// Checks whether a call has the assert is empty call shape.
private fun assert_is_empty_call(call: CompiledMethodCallExpression): bool =
    call.name == "is_empty"
        & call.arguments.is_empty()
        & match call.receiver with
            case CompiledFunctionCallExpression receiver -> receiver.name == "assert_that"
            case _ -> false

/// Checks whether a call has the assert status call shape.
private fun assert_status_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if (call.name == "succeeded" | call.name == "failed") & call.arguments.is_empty()
    then assert_expression(call.receiver, env, module, allModules)
    else false

/// Emits generated code for assert is empty.
private fun assert_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        assert_that_code(actual, env, module, allModules) + ".isEmpty()"
    case _ -> "unsupported(\"assert is_empty\")"

/// Checks whether a call has the option assert is equal to call shape.
private fun option_assert_is_equal_to_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_equal_to" & !call.arguments.is_empty()
    then match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & option_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
            case _ -> false
    else false

/// Emits generated code for option assert is equal to.
private fun option_assert_is_equal_to_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let expected = argument(call.arguments, 0)
        assert_that_code(actual, env, module, allModules)
            + ".isEqualTo(__capy_optional_value("
            + expression_code(expected, env, expression_type(expected, env, module, allModules), module, allModules)
            + "))"
    case _ -> "unsupported(\"option assert is_equal_to\")"

/// Checks whether a call has the result assert is equal to call shape.
private fun result_assert_is_equal_to_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_equal_to" & !call.arguments.is_empty()
    then match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & result_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
            case _ -> false
    else false

/// Emits generated code for result assert is equal to.
private fun result_assert_is_equal_to_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let expected = argument(call.arguments, 0)
        assert_that_code(actual, env, module, allModules)
            + ".isEqualTo(__capy_result_value("
            + expression_code(expected, env, expression_type(expected, env, module, allModules), module, allModules)
            + "))"
    case _ -> "unsupported(\"result assert is_equal_to\")"

/// Checks whether a call has the result assert succeeds lambda call shape.
private fun result_assert_succeeds_lambda_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "succeeds"
    then match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & result_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
                    & result_assert_succeeds_lambda_argument(call.arguments)
            case _ -> false
    else false

/// Checks whether the current value satisfies the result assert succeeds lambda argument rule for compiler processing.
private fun result_assert_succeeds_lambda_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case Some { expression } -> result_assert_succeeds_lambda_expression(expression) & no_second_expression(arguments)
    case None -> false

/// Checks whether an expression has the no second expression shape.
private fun no_second_expression(arguments: List[CompiledExpression]): bool =
    match arguments[1] with
    case None -> true
    case Some _ -> false

/// Checks whether an expression has the no third expression shape.
private fun no_third_expression(arguments: List[CompiledExpression]): bool =
    match arguments[2] with
    case None -> true
    case Some _ -> false

/// Checks whether an expression has the result assert succeeds lambda expression shape.
private fun result_assert_succeeds_lambda_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case _ -> false

/// Emits generated code for result assert succeeds lambda.
private fun result_assert_succeeds_lambda_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let resultType = expression_type(actual, env, module, allModules)
        result_assert_succeeds_lambda_argument_code(actual, resultType, argument(call.arguments, 0), env, module, allModules)
    case _ -> "unsupported(\"result assert succeeds\")"

/// Emits generated code for result assert succeeds lambda argument.
private fun result_assert_succeeds_lambda_argument_code(actual: CompiledExpression, resultType: CompiledTypeReference, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledLambdaExpression lambda ->
        assert_that_code(actual, env, module, allModules)
            + ".succeeds(" + lambda_code_for_value(lambda, first_type_argument(resultType), assert_type(), env, module, allModules) + ")"
    case _ -> "unsupported(\"result assert succeeds\")"

/// Checks whether method metadata matches the assert method call rule.
private fun assert_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if assert_method_supported(call.name)
    then assert_expression(call.receiver, env, module, allModules)
    else false

/// Checks whether an expression has the assert expression shape.
private fun assert_expression(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "assert_that" | call.name == "assert_all"
    case CompiledMethodCallExpression call -> assert_method_call(call, env, module, allModules) | assert_status_call(call, env, module, allModules)
    case CompiledVariableExpression variable -> lookup_binding(variable.name, env).name == "Assert"
    case _ -> expression_type(expression, env, module, allModules).name == "Assert"

/// Checks whether assert method is supported by the current backend.
private fun assert_method_supported(name: String): bool =
    name == "is_equal_to" | name == "is_true" | name == "is_false"
        | name == "is_greater_than" | name == "is_less_than"
        | name == "is_greater_or_equals_than" | name == "is_less_or_equals_than"
        | name == "is_zero" | name == "is_one" | name == "is_between"
        | name == "starts_with" | name == "does_not_start_with" | name == "contains"
        | name == "has_size" | name == "is_empty" | name == "succeeds" | name == "fails"
        | name == "has_day" | name == "has_month" | name == "has_year"
        | name == "has_hour" | name == "has_minute" | name == "has_second" | name == "has_offset_minutes"
        | name == "has_date" | name == "has_time"
        | name == "has_years" | name == "has_months" | name == "has_days" | name == "has_hours"
        | name == "has_minutes" | name == "has_seconds" | name == "has_weeks"
        | name == "has_start" | name == "has_end" | name == "has_duration"
        | name == "does_not_contain" | name == "contains_key" | name == "does_not_contain_key" | name == "contains_value"

/// Emits generated code for assert method call.
private fun assert_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(call.receiver, env, assert_type(), module, allModules)
        + "." + java_method_name(call.name)
        + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

/// Emits generated code for extension method call.
private fun extension_method_call_code(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    extension_method_call_code_with_receiver_type(function, call, receiverType, env, module, allModules)

/// Computes the compiled type for extension method call code with receiver.
private fun extension_method_call_code_with_receiver_type(function: CompiledFunction, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = bound_extension_method_parameters(function, receiverType)
    java_function_name(function)
        + "("
        + expression_code(call.receiver, env, receiverType, module, allModules)
        + extension_method_call_argument_tail(function.parameters, parameters, call.arguments, env, module, allModules)
        + ")"

/// Formats the recursive tail segment for extension method call argument.
private fun extension_method_call_argument_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + extension_parameter_expression_list_code(declaredParameters, boundParameters, arguments, env, module, allModules)

/// Emits generated code for extension parameter expression list.
private fun extension_parameter_expression_list_code(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        extension_argument_code(expression, declaredType, boundType, env, module, allModules)
        + extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], env, module, allModules)

/// Formats the recursive tail segment for extension parameter expression list.
private fun extension_parameter_expression_list_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        ", " + extension_argument_code(expression, declaredType, boundType, env, module, allModules)
        + extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], env, module, allModules)

/// Emits generated code for extension argument.
private fun extension_argument_code(expression: CompiledExpression, declaredType: CompiledTypeReference, boundType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = expression_code(expression, env, boundType, module, allModules)
    if extension_function_argument_needs_erased_cast(declaredType, boundType)
    then "((" + java_type(declaredType) + ") (" + raw_java_functional_type(declaredType) + ") " + code + ")"
    else code

/// Checks whether a function matches the extension function argument needs erased cast metadata.
private fun extension_function_argument_needs_erased_cast(declaredType: CompiledTypeReference, boundType: CompiledTypeReference): bool =
    function_type(declaredType) & function_type(boundType) & java_type(declaredType) != java_type(boundType)

/// Computes the compiled type for raw Java functional.
private fun raw_java_functional_type(type: CompiledTypeReference): String =
    let parameters = function_type_parameters(type)
    if parameters.is_empty()
    then "java.util.function.Supplier"
    else if parameters.size().value == 1
    then "java.util.function.Function"
    else if parameters.size().value == 2
    then "java.util.function.BiFunction"
    else if parameters.size().value == 3
    then "__CapyFunction3"
    else if parameters.size().value == 4
    then "__CapyFunction4"
    else "java.lang.Object"

/// Formats bound extension method parameters for generated emission.
private fun bound_extension_method_parameters(function: CompiledFunction, receiverType: CompiledTypeReference): List[CompiledFunctionParameter] =
    bound_extension_parameters(function.parameters, extension_method_type_bindings(function, receiverType))

/// Formats bound extension parameters for generated emission.
private fun bound_extension_parameters(parameters: List[CompiledFunctionParameter], bindings: List[JavaBinding]): List[CompiledFunctionParameter] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [CompiledFunctionParameter {
        name: parameter.name,
        typeReference: bound_extension_type(parameter.typeReference, bindings),
        location: parameter.location
    }] + bound_extension_parameters(parameters[1:], bindings)

/// Computes the compiled type for bound extension method return.
private fun bound_extension_method_return_type(function: CompiledFunction, receiverType: CompiledTypeReference): CompiledTypeReference =
    bound_extension_type(function.returnType, extension_method_type_bindings(function, receiverType))

/// Creates name/type bindings for extension method type.
private fun extension_method_type_bindings(function: CompiledFunction, receiverType: CompiledTypeReference): List[JavaBinding] =
    inferred_type_bindings(schema_type_reference(method_owner_name(function.name)), receiverType)

/// Computes the compiled type for bound extension.
private fun bound_extension_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    if function_type(type)
    then bound_function_type(type, bindings)
    else bound_schema_type(type, bindings)

/// Computes the compiled type for bound function.
private fun bound_function_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    let parameters = bound_schema_types(function_type_parameters(type), bindings)
    let returnType = bound_schema_type(function_type_return_type_with_arguments(type), bindings)
    CompiledTypeReference {
        name: function_type_reference_text(parameters, returnType),
        arguments: []
    }

/// Formats function type return type with arguments for generated emission.
private fun function_type_return_type_with_arguments(type: CompiledTypeReference): CompiledTypeReference =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0
    then object_type()
    else function_type_return_type_with_arguments_text(type.name[arrow + 2, type.name.size().value], type.arguments)

/// Resolves type metadata for function type return type with arguments text.
private fun function_type_return_type_with_arguments_text(returnText: String, arguments: List[CompiledTypeReference]): CompiledTypeReference =
    let parsed = schema_type_reference(returnText)
    if parsed.arguments.is_empty()
    then CompiledTypeReference {
        name: parsed.name,
        arguments: arguments
    }
    else parsed

/// Formats type metadata text for function type reference text.
private fun function_type_reference_text(parameters: List[CompiledTypeReference], returnType: CompiledTypeReference): String =
    function_type_parameter_reference_text(parameters) + "=>" + type_reference_text(returnType)

/// Formats type metadata text for function type parameter reference text.
private fun function_type_parameter_reference_text(parameters: List[CompiledTypeReference]): String =
    if parameters.is_empty()
    then "()"
    else if parameters[1:].is_empty()
    then type_reference_text(function_type_parameter_at(parameters, 0))
    else "(" + type_reference_list_text(parameters) + ")"

/// Formats type metadata text for type reference text.
private fun type_reference_text(type: CompiledTypeReference): String =
    type.name + type_reference_arguments_text(type.arguments)

/// Formats type metadata text for type reference arguments text.
private fun type_reference_arguments_text(arguments: List[CompiledTypeReference]): String =
    if arguments.is_empty()
    then ""
    else "[" + type_reference_list_text(arguments) + "]"

/// Formats type metadata text for type reference list text.
private fun type_reference_list_text(types: List[CompiledTypeReference]): String =
    match types[0] with
    case None -> ""
    case Some { type } -> type_reference_text(type) + type_reference_list_tail(types[1:])

/// Formats the recursive tail segment for type reference list.
private fun type_reference_list_tail(types: List[CompiledTypeReference]): String =
    match types[0] with
    case None -> ""
    case Some { type } -> ", " + type_reference_text(type) + type_reference_list_tail(types[1:])

/// Emits generated code for primitive conversion.
private fun primitive_conversion_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if call.name == "to_int"
    then primitive_to_int_code(receiverCode, receiverType)
    else primitive_to_long_code(receiverCode, receiverType)

private fun primitive_to_int_code(receiverCode: String, receiverType: CompiledTypeReference): String =
    if receiverType.name == "long"
    then "java.lang.Long.valueOf(" + receiverCode + ").intValue()"
    else if receiverType.name == "float"
    then "java.lang.Float.valueOf(" + receiverCode + ").intValue()"
    else "java.lang.Double.valueOf(" + receiverCode + ").intValue()"

private fun primitive_to_long_code(receiverCode: String, receiverType: CompiledTypeReference): String =
    if receiverType.name == "float"
    then "java.lang.Float.valueOf(" + receiverCode + ").longValue()"
    else "java.lang.Double.valueOf(" + receiverCode + ").longValue()"

/// Checks whether method metadata matches the string parse method call rule.
private fun string_parse_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if string_parse_method(call.name) & call.arguments.is_empty()
    then expression_type(call.receiver, env, module, allModules).name == "String"
    else false

/// Checks whether method metadata matches the string parse method rule.
private fun string_parse_method(name: String): bool =
    name == "to_int" | name == "to_long" | name == "to_double" | name == "to_float" | name == "to_bool"

/// Emits generated code for string parse method.
private fun string_parse_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_parse_" + string_parse_method_suffix(call.name)
        + "(" + expression_code(call.receiver, env, string_type(), module, allModules) + ")"

/// Formats source text for string parse method suffix.
private fun string_parse_method_suffix(name: String): String =
    if name == "to_int"
    then "int"
    else if name == "to_long"
    then "long"
    else if name == "to_double"
    then "double"
    else if name == "to_float"
    then "float"
    else "bool"

/// Checks whether a call has the character to string call shape.
private fun char_to_string_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "to_string" & call.arguments.is_empty()
    then expression_type(call.receiver, env, module, allModules).name == "char"
    else false

/// Emits generated code for character to string.
private fun char_to_string_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.String) " + expression_code(call.receiver, env, object_type(), module, allModules) + ")"

/// Checks whether method metadata matches the enum name method call rule.
private fun enum_name_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "name" & call.arguments.is_empty()
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        receiverType.name == "enum" | enum_type_exists(receiverType.name, module, allModules)
    else false

/// Emits generated code for lambda.
private fun lambda_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let params = lambda_parameters(lambda.parameters)
    params + " -> " + expression_code(lambda.body, lambda_env(lambda.parameters, env), expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules), module, allModules)

/// Emits generated code for lambda expression.
private fun lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function_type(expectedType)
    then typed_lambda_expression_code(lambda, env, expectedType, module, allModules)
    else if expectedType.name == "Supplier"
    then supplier_lambda_expression_code(lambda, env, first_type_argument(expectedType), module, allModules)
    else
        let code = lambda_code(lambda, env, module, allModules)
        if lambda.parameters.is_empty() & expectedType.name != "Supplier"
        then "((java.util.function.Supplier<java.lang.Object>) (" + code + "))"
        else code

/// Emits generated code for supplier lambda expression.
private fun supplier_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    lambda_parameters(lambda.parameters)
        + " -> "
        + expression_code(lambda.body, lambda_env(lambda.parameters, env), expectedType, module, allModules)

/// Emits generated code for typed lambda expression.
private fun typed_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = function_type_parameters(expectedType)
    let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
    "((" + boxed_java_type(expectedType) + ") ("
        + lambda_parameters(lambda.parameters)
        + " -> "
        + expression_code(lambda.body, lambdaEnv, function_type_return_type(expectedType), module, allModules)
        + "))"

/// Collects typed lambda environmentironment for compiler processing.
private fun typed_lambda_env(parameters: List[String], types: List[CompiledTypeReference], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } ->
        if parameter == "_"
        then typed_lambda_env(parameters[1:], type_reference_tail(types), env)
        else [java_binding(parameter, function_type_parameter_at(types, 0))]
            + typed_lambda_env(parameters[1:], type_reference_tail(types), env)

/// Computes value metadata for lambda code for value.
private fun lambda_code_for_value(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyCode = expression_code(lambda.body, lambdaEnv, expectedType, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, bodyCode)

/// Emits generated code for flat map lambda.
private fun flat_map_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyType = expression_type(lambda.body, lambdaEnv, module, allModules)
    let bodyCode = expression_code(lambda.body, lambdaEnv, bodyType, module, allModules)
    let resultCode =
        if collection_receiver_type(bodyType)
        then seq_receiver_code(lambda.body, bodyType, lambdaEnv, module, allModules)
        else bodyCode
    lambda_code_with_result(lambda.parameters, valueType, resultCode)

/// Emits source code for lambda code with result.
private fun lambda_code_with_result(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_code(parameters, valueType, resultCode)
    else lambda_parameters(parameters) + " -> " + resultCode

/// Emits generated code for tuple lambda.
private fun tuple_lambda_code(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    let tupleName = "__capy_tuple"
    tupleName + " -> {" + newline()
    + tuple_lambda_binding_statements(parameters, valueType.arguments, tupleName, 0, "            ")
    + "            return " + resultCode + ";" + newline()
    + "        }"

/// Emits generated statements for tuple lambda binding.
private fun tuple_lambda_binding_statements(parameters: List[String], types: List[CompiledTypeReference], tupleName: String, idx: int, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        let type = tuple_argument(types, 0)
        let statement =
            if parameter == "_"
            then ""
            else indent + java_type(type) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(type) + ") ((java.util.List<?>) " + tupleName + ").get(" + idx + "));" + newline()
        statement + tuple_lambda_binding_statements(parameters[1:], types[1:], tupleName, idx + 1, indent)

/// Formats lambda parameters for generated emission.
private fun lambda_parameters(parameters: List[String]): String =
    if parameters.is_empty()
    then "()"
    else "(" + java_identifier_list(parameters) + ")"

/// Collects lambda environmentironment for compiler processing.
private fun lambda_env(parameters: List[String], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [java_binding(parameter, object_type())] + lambda_env(parameters[1:], env)

/// Collects lambda value environmentironment for compiler processing.
private fun lambda_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_env(parameters, valueType.arguments, env)
    else lambda_single_value_env(parameters, valueType, env)

/// Collects lambda single value environmentironment for compiler processing.
private fun lambda_single_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [java_binding(parameter, valueType)] + env

/// Collects tuple lambda environmentironment for compiler processing.
private fun tuple_lambda_env(parameters: List[String], types: List[CompiledTypeReference], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } ->
        let rest = match types[0] with
            case None -> tuple_lambda_env(parameters[1:], [], env)
            case Some _ -> tuple_lambda_env(parameters[1:], types[1:], env)
        if parameter == "_"
        then rest
        else [java_binding(parameter, tuple_argument(types, 0))] + rest

/// Checks whether the current value satisfies the tuple lambda parameters rule for compiler processing.
private fun tuple_lambda_parameters(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ -> true

/// Emits generated code for index.
private fun index_code(index: CompiledIndexExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(index.receiver, env, module, allModules)
    let receiverCode = expression_code(index.receiver, env, receiverType, module, allModules)
    let indexCode = index_argument_code(index.index, env, module, allModules)
    let resultType = expression_type(index, env, module, allModules)
    if !built_in_index_expression(index, receiverType)
    then user_defined_index_code(index, receiverType, env, expectedType, module, allModules)
    else if receiverType.name == "String" & index.hasEndIndex
    then "__capy_string_slice("
        + receiverCode
        + ", "
        + indexCode
        + ", "
        + index_argument_code(index.endIndex, env, module, allModules)
        + ")"
    else if receiverType.name == "String"
    then string_optional_index_code(receiverCode, indexCode)
    else if receiverType.name == "Tuple" & !index.hasEndIndex
    then "((" + boxed_java_type(resultType) + ") " + receiverCode + ".get(__capy_normalized_index(" + receiverCode + ", " + indexCode + ")))"
    else if receiverType.name == "Dict" & !index.hasEndIndex
    then dict_optional_index_code(receiverCode, expression_code(index.index, env, string_type(), module, allModules))
    else if index.hasEndIndex
    then "__capy_list_slice("
        + receiverCode
        + ", "
        + list_slice_start_index_code(index.index, env, module, allModules)
        + ", "
        + list_slice_end_index_code(receiverCode, index.endIndex, env, module, allModules)
        + ")"
    else list_optional_index_code(receiverCode, indexCode)

/// Checks whether an expression has the built in index expression shape.
private fun built_in_index_expression(index: CompiledIndexExpression, receiverType: CompiledTypeReference): bool =
    if index.hasEndIndex
    then receiverType.name == "String" | receiverType.name == "Tuple" | receiverType.name == "List"
    else receiverType.name == "String" | receiverType.name == "Tuple" | receiverType.name == "List" | receiverType.name == "Dict"

/// Emits generated code for user defined index.
private fun user_defined_index_code(index: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let call = index_get_call(index)
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } ->
        let callType = bound_extension_method_return_type(function, receiverType)
        value_conversion_code(extension_method_call_code_with_receiver_type(function, call, receiverType, env, module, allModules), callType, expectedType, module, allModules)
    case None -> value_conversion_code("unsupported(\"index get\")", object_type(), expectedType, module, allModules)

/// Resolves expression metadata for index get call.
private fun index_get_call(index: CompiledIndexExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: index.receiver,
        name: "get",
        arguments: index_get_arguments(index),
        location: index.location
    }

/// Formats index get arguments for generated emission.
private fun index_get_arguments(index: CompiledIndexExpression): List[CompiledExpression] =
    if index.hasEndIndex
    then [index.index, index.endIndex]
    else [index.index]

/// Emits generated code for list slice start index.
private fun list_slice_start_index_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_start(literal)
        then "0"
        else index_argument_code(expression, env, module, allModules)
    case _ -> index_argument_code(expression, env, module, allModules)

/// Emits generated code for list slice end index.
private fun list_slice_end_index_code(receiverCode: String, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_end(literal)
        then receiverCode + ".size()"
        else index_argument_code(expression, env, module, allModules)
    case _ -> index_argument_code(expression, env, module, allModules)

/// Checks whether the current value satisfies the omitted slice end rule for compiler processing.
private fun omitted_slice_end(literal: CompiledIntLiteral): bool =
    literal.source == "__capy_slice_end__"

/// Checks whether the current value satisfies the omitted slice start rule for compiler processing.
private fun omitted_slice_start(literal: CompiledIntLiteral): bool =
    literal.source == "__capy_slice_start__"

/// Emits generated code for index argument.
private fun index_argument_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(expression, env, int_type(), module, allModules)

/// Checks whether index argument can be emitted by the target backend.
private fun index_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & value_assignable(int_type(), expression_type(expression, env, module, allModules), module, allModules)

/// Emits generated code for string optional index.
private fun string_optional_index_code(receiverCode: String, indexCode: String): String =
    "__capy_string_get_optional(" + receiverCode + ", " + indexCode + ")"

/// Emits generated code for list optional index.
private fun list_optional_index_code(receiverCode: String, indexCode: String): String =
    "__capy_list_get_optional(" + receiverCode + ", " + indexCode + ")"

/// Emits generated code for dict optional index.
private fun dict_optional_index_code(receiverCode: String, keyCode: String): String =
    "__capy_dict_get_optional(" + receiverCode + ", " + keyCode + ")"

/// Emits generated code for block expression.
private fun block_expression_code(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = block_expression_result_type(block, env, expectedType, module, allModules)
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + block_statements(block.bindings, env, resultType, module, allModules, "            ")
    + "            return " + block_result_code(block, env, expectedType, module, allModules) + ";" + newline()
    + "        }).get()"

/// Computes the compiled type for block expression result.
private fun block_expression_result_type(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let resultEnv = block_env(block.bindings, env, module, allModules)
    let rawResultType = expression_type(block.result, resultEnv, module, allModules)
    if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules)
    then expectedType
    else rawResultType

/// Emits generated code for block result.
private fun block_result_code(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultEnv = block_env(block.bindings, env, module, allModules)
    let rawResultType = expression_type(block.result, resultEnv, module, allModules)
    let resultExpectedType = if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules) then first_type_argument(expectedType) else expectedType
    let resultCode = expression_code(block.result, resultEnv, resultExpectedType, module, allModules)
    if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules)
    then "__capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", " + resultCode + ")))"
    else resultCode

private fun throw_expression_code(throwExpression: CompiledThrowExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.util.function.Supplier<" + boxed_java_type(expectedType) + ">) () -> {" + newline()
    + "            throw new __CapyThrownError(" + expression_code(throwExpression.value, env, error_type(), module, allModules) + ");" + newline()
    + "        }).get()"

private fun try_catch_expression_code(tryCatch: CompiledTryCatchExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let catchJavaName = "__capy_caught_error_" + tryCatch.location.line + "_" + tryCatch.location.column
    "((java.util.function.Supplier<" + boxed_java_type(expectedType) + ">) () -> {" + newline()
    + "            try {" + newline()
    + "                return " + expression_code(tryCatch.body, env, expectedType, module, allModules) + ";" + newline()
    + "            } catch (__CapyThrownError __capy_error) {" + newline()
    + "                java.lang.Object " + catchJavaName + " = __capy_error.error();" + newline()
    + try_catch_branch_code(tryCatch.branches, catchJavaName, env, expectedType, module, allModules)
    + "            } catch (java.lang.RuntimeException __capy_host_exception) {" + newline()
    + "                java.lang.Object " + catchJavaName + " = __capy_error(\"capy.runtime.host_exception\", __capy_safe_message(__capy_host_exception), __capy_host_exception);" + newline()
    + try_catch_branch_code(tryCatch.branches, catchJavaName, env, expectedType, module, allModules)
    + "            }" + newline()
    + "        }).get()"

private fun try_catch_branch_code(branches: List[CompiledTryCatchBranch], catchJavaName: String, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match branches[0] with
    case None -> "                throw new __CapyThrownError(" + catchJavaName + ");" + newline()
    case Some { branch } ->
        let catchEnv = [java_binding_with_java_name(branch.catchName, error_type(), catchJavaName)] + env
        let branchBody = "                    return " + expression_code(branch.catchBody, catchEnv, expectedType, module, allModules) + ";" + newline()
        if branch.hasKind
        then "                if (__capy_error_kind_equals(" + catchJavaName + ", \"" + escape_java_string(branch.kind) + "\")) {" + newline()
            + branchBody
            + "                }" + newline()
            + try_catch_branch_code(branches[1:], catchJavaName, env, expectedType, module, allModules)
        else "                return " + expression_code(branch.catchBody, catchEnv, expectedType, module, allModules) + ";" + newline()

/// Checks whether the current value satisfies the result block wraps success rule for compiler processing.
private fun result_block_wraps_success(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, rawResultType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    result_type_name(expectedType.name)
        & !result_type_name(rawResultType.name)
        & result_bindings(block.bindings, env, module, allModules)

/// Checks whether the current value satisfies the result bindings rule for compiler processing.
private fun result_bindings(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        let valueType = binding_value_type(binding, env, module, allModules)
        let localType =
            if binding.typeReference.name.is_empty()
            then if binding.operator == "<-" then first_type_argument(valueType) else valueType
            else binding.typeReference
        if binding.operator == "<-" & result_type_name(valueType.name)
        then true
        else result_bindings(bindings[1:], [local_java_binding(binding.name, localType, binding.location, env)] + env, module, allModules)

/// Emits generated statements for block.
private fun block_statements(bindings: List[CompiledLetBinding], env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        binding_statement(binding, localBinding, env, valueType, expectedType, module, allModules, indent)
        + block_statements(bindings[1:], [localBinding] + env, expectedType, module, allModules, indent)

/// Emits one generated statement for binding.
private fun binding_statement(binding: CompiledLetBinding, localBinding: JavaBinding, env: List[JavaBinding], valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if binding.operator == "<-"
    then monadic_binding_statement(binding, localBinding, env, valueType, expectedType, module, allModules, indent)
    else indent + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, valueType, module, allModules) + ";" + newline()

/// Emits one generated statement for monadic binding.
private fun monadic_binding_statement(binding: CompiledLetBinding, localBinding: JavaBinding, env: List[JavaBinding], valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let wrapperType = binding_value_type(binding, env, module, allModules)
    let bindName = "__capy_bind_" + localBinding.javaName
    if wrapperType.name == "Effect"
    then indent + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, wrapperType, module, allModules) + ".unsafeRun();" + newline()
    else if result_type_name(wrapperType.name)
    then indent + "java.lang.Object " + bindName + " = " + expression_code(binding.value, env, wrapperType, module, allModules) + ";" + newline()
        + indent + "if (!__capy_result_is_success(" + bindName + ")) {" + newline()
        + indent + "    return ((" + boxed_java_type(expectedType) + ") " + bindName + ");" + newline()
        + indent + "}" + newline()
        + indent + java_type(valueType) + " " + localBinding.javaName + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + bindName + "));" + newline()
    else if option_type_name(wrapperType.name)
    then indent + java_type(wrapperType) + " " + bindName + " = " + expression_code(binding.value, env, wrapperType, module, allModules) + ";" + newline()
        + indent + "if (" + bindName + ".isEmpty()) {" + newline()
        + indent + "    return ((" + boxed_java_type(expectedType) + ") " + bindName + ");" + newline()
        + indent + "}" + newline()
        + indent + java_type(valueType) + " " + localBinding.javaName + " = ((" + boxed_java_type(valueType) + ") " + bindName + ".get());" + newline()
    else indent + "java.lang.Object " + bindName + " = " + expression_code(binding.value, env, wrapperType, module, allModules) + ";" + newline()
        + indent + java_type(valueType) + " " + localBinding.javaName + " = ((" + boxed_java_type(valueType) + ") __capy_data_value_field(" + bindName + "));" + newline()

/// Collects block environmentironment for compiler processing.
private fun block_env(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        block_env(bindings[1:], [local_java_binding(binding.name, valueType, binding.location, env)] + env, module, allModules)

/// Creates one name/type binding for local Java.
private fun local_java_binding(name: String, typeReference: CompiledTypeReference, location: CompiledSourceLocation, env: List[JavaBinding]): JavaBinding =
    if binding_exists(name, env)
    then java_binding_with_java_name(name, typeReference, java_identifier(name) + "__" + location.line + "_" + location.column)
    else java_binding(name, typeReference)

/// Computes the compiled type for binding.
private fun binding_type(binding: CompiledLetBinding, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if binding.typeReference.name.is_empty()
    then
        let valueType = inferred_binding_value_type(binding.value, binding_value_type(binding, env, module, allModules), env, module, allModules)
        if binding.operator == "<-"
        then first_type_argument(valueType)
        else valueType
    else binding.typeReference

/// Computes the compiled type for binding value.
private fun binding_value_type(binding: CompiledLetBinding, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(binding.value, env, module, allModules)

/// Computes the compiled type for inferred binding value.
private fun inferred_binding_value_type(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledDataLiteral literal ->
        if valueType.arguments.is_empty()
        then inferred_data_literal_reference(valueType.name, literal, env, module, allModules)
        else valueType
    case CompiledLambdaExpression lambda -> inferred_lambda_function_type(lambda, env, module, allModules)
    case _ -> valueType

/// Computes the compiled type for inferred lambda function.
private fun inferred_lambda_function_type(lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let parameters = lambda_object_parameter_types(lambda.parameters)
    let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
    CompiledTypeReference {
        name: function_type_reference_text(parameters, expression_type(lambda.body, lambdaEnv, module, allModules)),
        arguments: []
    }

/// Collects object-oriented metadata for lambda object parameter types.
private fun lambda_object_parameter_types(parameters: List[String]): List[CompiledTypeReference] =
    match parameters[0] with
    case None -> []
    case Some _ -> [object_type()] + lambda_object_parameter_types(parameters[1:])

/// Emits generated code for assert that.
private fun assert_that_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let actualType = expression_type(expression, env, module, allModules)
    let actual = expression_code(expression, env, actualType, module, allModules)
    if actualType.name == "int"
    then java_assert_data("IntAssert", actual)
    else if actualType.name == "long"
    then java_assert_data("LongAssert", actual)
    else if actualType.name == "float"
    then java_assert_data("FloatAssert", actual)
    else if actualType.name == "double"
    then java_assert_data("DoubleAssert", actual)
    else if actualType.name == "bool"
    then java_assert_data("BoolAssert", actual)
    else if actualType.name == "String"
    then java_assert_data("StringAssert", actual)
    else if actualType.name == "List"
    then java_assert_data("ListAssert", actual)
    else if seq_type_name(actualType.name)
    then java_assert_data("ListAssert", seq_receiver_code(expression, actualType, env, module, allModules) + ".asList()")
    else if actualType.name == "Set"
    then java_assert_data("SetAssert", actual)
    else if actualType.name == "Dict"
    then java_assert_data("DictAssert", actual)
    else if option_type_name(actualType.name)
    then java_assert_data("OptionAssert", "__capy_optional_value(" + actual + ")")
    else if result_type_name(actualType.name)
    then java_assert_data("ResultAssert", "__capy_result_value(" + actual + ")")
    else java_assert_data("DataAssert", actual)

private fun java_assert_data(typeName: String, valueCode: String): String =
    "__capy_data(\"" + typeName + "\", java.util.Map.ofEntries(java.util.Map.entry(\"assertions\", java.util.List.of()), java.util.Map.entry(\"value\", " + valueCode + ")))"

/// Emits generated code for expression list.
private fun expression_list_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
        + expression_list_tail(expressions[1:], env, module, allModules)

/// Formats the recursive tail segment for expression list.
private fun expression_list_tail(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } -> ", " + expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules) + expression_list_tail(expressions[1:], env, module, allModules)

/// Emits generated code for list literal.
private fun list_literal_code(literal: CompiledListLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let elementType = if expectedType.name == "List" then first_type_argument(expectedType) else object_type()
    "java.util.List.of(" + list_expression_list_code(literal.values, elementType, env, module, allModules) + ")"

/// Emits generated code for list expression list.
private fun list_expression_list_code(expressions: List[CompiledExpression], elementType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, list_element_expected_type(elementType, expression, env, module, allModules), module, allModules)
        + list_expression_list_tail(expressions[1:], elementType, env, module, allModules)

/// Formats the recursive tail segment for list expression list.
private fun list_expression_list_tail(expressions: List[CompiledExpression], elementType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, list_element_expected_type(elementType, expression, env, module, allModules), module, allModules)
        + list_expression_list_tail(expressions[1:], elementType, env, module, allModules)

/// Computes the compiled type for list element expected.
private fun list_element_expected_type(elementType: CompiledTypeReference, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if elementType.name.is_empty() | elementType.name == "any" | elementType.name == "Object"
    then expression_type(expression, env, module, allModules)
    else elementType

/// Emits generated code for tuple literal.
private fun tuple_literal_code(literal: CompiledTupleLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "java.util.List.of(" + tuple_expression_list_code(literal.values, expectedType.arguments, env, module, allModules) + ")"

/// Emits generated code for tuple expression list.
private fun tuple_expression_list_code(expressions: List[CompiledExpression], expectedTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, tuple_expression_expected_type(expectedTypes, 0, expression, env, module, allModules), module, allModules)
        + tuple_expression_list_tail(expressions[1:], type_reference_tail(expectedTypes), env, module, allModules)

/// Formats the recursive tail segment for tuple expression list.
private fun tuple_expression_list_tail(expressions: List[CompiledExpression], expectedTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, tuple_expression_expected_type(expectedTypes, 0, expression, env, module, allModules), module, allModules)
        + tuple_expression_list_tail(expressions[1:], type_reference_tail(expectedTypes), env, module, allModules)

/// Computes the compiled type for tuple expression expected.
private fun tuple_expression_expected_type(expectedTypes: List[CompiledTypeReference], idx: int, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expectedTypes[idx] with
    case Some { type } -> type
    case None -> expression_type(expression, env, module, allModules)

/// Collects type reference tail for compiler processing.
private fun type_reference_tail(types: List[CompiledTypeReference]): List[CompiledTypeReference] =
    if types.is_empty() then [] else types[1:]

/// Emits generated code for dict.
private fun dict_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if entries.is_empty()
    then "java.util.Map.of()"
    else "__capy_dict_literal(" + dict_entries_code(entries, env, module, allModules) + ")"

/// Emits generated code for dict entries.
private fun dict_entries_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        "java.util.Map.entry(" + expression_code(entry.key, env, string_type(), module, allModules) + ", " + expression_code(entry.value, env, expression_type(entry.value, env, module, allModules), module, allModules) + ")"
        + dict_entries_tail(entries[1:], env, module, allModules)

/// Formats the recursive tail segment for dict entries.
private fun dict_entries_tail(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some _ -> ", " + dict_entries_code(entries, env, module, allModules)

/// Emits generated code for data literal.
private fun data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if primitive_char_constructor(literal, expectedType)
    then primitive_char_constructor_code(literal, env, module, allModules)
    else if stdlib_date_time_data_literal(literal.typeName, module.imports)
    then stdlib_date_time_data_literal_code(literal, env, module, allModules)
    else if option_constructor_type(literal.typeName)
    then option_data_literal_code(literal, env, expectedType, module, allModules)
    else if result_error_constructor(literal.typeName)
    then result_error_data_literal_code(literal, env, expectedType, module, allModules)
    else if program_success_literal(literal.typeName, module.imports)
    then "capy.lang.Program.Success.INSTANCE"
    else if program_failed_literal(literal.typeName, module.imports)
    then match literal.fields[0] with
        case Some { field } -> "new capy.lang.Program.Failed(" + expression_code(field.value, env, int_type(), module, allModules) + ")"
        case None -> "new capy.lang.Program.Failed(0)"
    else if raw_data_literal(literal.typeName)
    then raw_data_literal_code(literal, env, expectedType, module, allModules)
    else
        let declaredType = data_literal_declared_type(literal.typeName)
        let parentConstructors = data_parent_constructor_type_names(declaredType.name, module, allModules)
        if parentConstructors.is_empty()
        then match data_constructor_function(literal.typeName, module) with
            case Some { function } -> data_constructor_call_code(function, literal, env, module, allModules)
            case None -> raw_data_literal_code(literal, env, expectedType, module, allModules)
        else data_constructor_pipeline_code(parentConstructors + data_own_constructor_type_names(declaredType.name, module), literal, env, expectedType, module, allModules)

/// Emits generated code for raw data literal.
private fun raw_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredType = data_literal_declared_type(literal.typeName)
    let typeName = declaredType.name
    let rawLiteral = CompiledDataLiteral {
        typeName: typeName,
        fields: literal.fields,
        location: literal.location
    }
    let dataType = find_data_type(typeName, module, allModules)
    let bindings = data_type_bindings(dataType, data_literal_context_type(declaredType, expectedType), module, allModules)
    "__capy_data(\"" + escape_java_string(data_literal_type_name(typeName, dataType)) + "\", " + data_fields_code(rawLiteral.fields, env, dataType, bindings, module, allModules) + ")"

/// Checks whether the current value satisfies the raw data literal rule for compiler processing.
private fun raw_data_literal(typeName: String): bool =
    java_generator_string_has_prefix(typeName, "__capy_raw|")

/// Computes the type name for raw data literal.
private fun raw_data_literal_type_name(typeName: String): String =
    if raw_data_literal(typeName)
    then typeName["__capy_raw|".size().value, typeName.size().value]
    else typeName

/// Computes the compiled type for data literal declared.
private fun data_literal_declared_type(typeName: String): CompiledTypeReference =
    schema_type_reference(raw_data_literal_type_name(typeName))

/// Computes the compiled type for data literal context.
private fun data_literal_context_type(declaredType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if declaredType.arguments.is_empty()
    then expectedType
    else declaredType

/// Looks up optional metadata for data constructor function.
private fun data_constructor_function(typeName: String, module: CompiledModule): /capy/lang/Option[CompiledFunction] =
    if raw_data_literal(typeName)
    then /capy/lang/Option.None {}
    else find_function(data_constructor_function_name(data_literal_declared_type(typeName).name), module.functions)

/// Computes the name for data constructor function.
private fun data_constructor_function_name(typeName: String): String =
    "__capy_constructor|" + typeName

/// Collects data own constructor type names for compiler processing.
private fun data_own_constructor_type_names(typeName: String, module: CompiledModule): List[String] =
    match data_constructor_function(typeName, module) with
    case Some _ -> [typeName]
    case None -> []

/// Collects data parent constructor type names for compiler processing.
private fun data_parent_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    data_parent_constructor_type_names_from(data_type_parent_types(typeName, module, allModules), module)

/// Collects data parent constructor type names from for compiler processing.
private fun data_parent_constructor_type_names_from(typeNames: List[String], module: CompiledModule): List[String] =
    match typeNames[0] with
    case None -> []
    case Some { typeName } ->
        match data_constructor_function(typeName, module) with
        case Some _ -> [typeName] + data_parent_constructor_type_names_from(typeNames[1:], module)
        case None -> data_parent_constructor_type_names_from(typeNames[1:], module)

/// Emits generated code for data constructor pipeline.
private fun data_constructor_pipeline_code(constructorTypes: List[String], literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredType = data_literal_declared_type(literal.typeName)
    let resultType = data_constructor_pipeline_type(declaredType.name, constructorTypes, module, allModules)
    let dataName = "__capy_constructor_data_" + literal.location.line + "_" + literal.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + dataName + " = " + raw_data_literal_code(literal, env, expectedType, module, allModules) + ";" + newline()
    + data_constructor_pipeline_steps(constructorTypes, declaredType.name, dataName, 0, module, allModules)
    + data_constructor_pipeline_return(dataName, resultType)
    + "        }).get()"

/// Formats source text for data constructor pipeline steps.
private fun data_constructor_pipeline_steps(constructorTypes: List[String], literalTypeName: String, dataName: String, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match constructorTypes[0] with
    case None -> ""
    case Some { constructorType } ->
        match data_constructor_function(constructorType, module) with
        case Some { function } ->
            data_constructor_pipeline_step(function, constructorType, constructorType != literalTypeName, dataName, idx, module, allModules)
                + data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, dataName, idx + 1, module, allModules)
        case None -> data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, dataName, idx, module, allModules)

/// Formats source text for data constructor pipeline step.
private fun data_constructor_pipeline_step(function: CompiledFunction, constructorType: String, parentConstructor: bool, dataName: String, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultName = dataName + "_result_" + idx
    "            java.lang.Object " + resultName + " = " + data_constructor_data_call_code(function, dataName, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_error(" + resultName + ")) {" + newline()
    + "                return " + resultName + ";" + newline()
    + "            }" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + data_constructor_pipeline_assignment(dataName, "__capy_result_success_value(" + resultName + ")", constructorType, parentConstructor, "                ")
    + "            } else {" + newline()
    + data_constructor_pipeline_assignment(dataName, resultName, constructorType, parentConstructor, "                ")
    + "            }" + newline()

/// Formats source text for data constructor pipeline assignment.
private fun data_constructor_pipeline_assignment(dataName: String, valueCode: String, constructorType: String, parentConstructor: bool, indent: String): String =
    let constructorValue = "__capy_constructor_value(\"" + escape_java_string(constructorType) + "\", " + valueCode + ")"
    if parentConstructor
    then indent + dataName + " = __capy_merge_data(" + dataName + ", " + constructorValue + ");" + newline()
    else indent + dataName + " = " + constructorValue + ";" + newline()

/// Formats source text for data constructor pipeline return.
private fun data_constructor_pipeline_return(dataName: String, resultType: CompiledTypeReference): String =
    if result_type_name(resultType.name)
    then "            return __capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", " + dataName + ")));" + newline()
    else "            return " + dataName + ";" + newline()

/// Computes the compiled type for data constructor pipeline.
private fun data_constructor_pipeline_type(typeName: String, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then result_type(data_type_reference(typeName))
    else data_type_reference(typeName)

/// Checks whether constructor metadata matches the data constructor pipeline returns result rule.
private fun data_constructor_pipeline_returns_result(constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match constructorTypes[0] with
    case None -> false
    case Some { constructorType } ->
        if data_constructor_type_returns_result(constructorType, module, allModules)
        then true
        else data_constructor_pipeline_returns_result(constructorTypes[1:], module, allModules)

/// Checks whether a type reference matches the data constructor type returns result rule.
private fun data_constructor_type_returns_result(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match data_constructor_function(typeName, module) with
    case Some { function } -> data_constructor_function_returns_result(function, module, allModules)
    case None -> false

/// Checks whether a function matches the data constructor function returns result metadata.
private fun data_constructor_function_returns_result(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if result_type_name(function.returnType.name)
    then true
    else result_type_name(data_constructor_inferred_return_type(function, module, allModules).name)

/// Emits generated code for data constructor data call.
private fun data_constructor_data_call_code(function: CompiledFunction, dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_function_name(function) + "(" + data_constructor_data_call_arguments(function.parameters, dataName, module, allModules) + ")"

/// Formats data constructor data call arguments for generated emission.
private fun data_constructor_data_call_arguments(parameters: List[CompiledFunctionParameter], dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        data_constructor_data_call_argument(parameter, dataName, module, allModules)
            + data_constructor_data_call_argument_tail(parameters[1:], dataName, module, allModules)

/// Formats the recursive tail segment for data constructor data call argument.
private fun data_constructor_data_call_argument_tail(parameters: List[CompiledFunctionParameter], dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + data_constructor_data_call_arguments(parameters, dataName, module, allModules)

/// Formats one data constructor data call argument for generated emission.
private fun data_constructor_data_call_argument(parameter: CompiledFunctionParameter, dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    "((" + boxed_java_type(parameter.typeReference) + ") __capy_data_field(" + dataName + ", \"" + escape_java_string(parameter.name) + "\"))"

/// Emits generated code for data constructor call.
private fun data_constructor_call_code(function: CompiledFunction, literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = data_literal_declared_type(literal.typeName).name
    let callCode = java_function_name(function) + "(" + data_constructor_call_arguments(function.parameters, literal.fields, 0, env, module, allModules) + ")"
    if data_constructor_function_returns_result(function, module, allModules)
    then "__capy_constructor_result(\"" + escape_java_string(typeName) + "\", " + callCode + ")"
    else "__capy_constructor_value(\"" + escape_java_string(typeName) + "\", " + callCode + ")"

/// Formats data constructor call arguments for generated emission.
private fun data_constructor_call_arguments(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        expression_code(data_constructor_argument_value(fields, parameter.name, "$" + idx), env, parameter.typeReference, module, allModules)
            + data_constructor_call_argument_tail(parameters[1:], fields, idx + 1, env, module, allModules)

/// Formats the recursive tail segment for data constructor call argument.
private fun data_constructor_call_argument_tail(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + data_constructor_call_arguments(parameters, fields, idx, env, module, allModules)

/// Computes value metadata for data constructor argument value.
private fun data_constructor_argument_value(fields: List[CompiledDataField], name: String, positionalName: String): CompiledExpression =
    match fields[0] with
    case None -> missing_argument()
    case Some { field } ->
        if field.name == name | field.name == positionalName
        then field.value
        else data_constructor_argument_value(fields[1:], name, positionalName)

/// Checks whether the current value satisfies the standard-library date/time data literal rule for compiler processing.
private fun stdlib_date_time_data_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    type_unqualified_name(typeName) == "DateTime" & stdlib_date_time_type_imported("DateTime", imports)

/// Emits generated code for standard-library date time data literal.
private fun stdlib_date_time_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"DateTime\", java.util.Map.ofEntries(java.util.Map.entry(\"date\", "
        + expression_code(data_field_value(literal.fields, "date"), env, date_type(), module, allModules)
        + "), java.util.Map.entry(\"time\", "
        + expression_code(data_field_value(literal.fields, "time"), env, time_type(), module, allModules)
        + ")))"

/// Computes value metadata for data field value.
private fun data_field_value(fields: List[CompiledDataField], name: String): CompiledExpression =
    match fields[0] with
    case None -> missing_argument()
    case Some { field } -> if field.name == name then field.value else data_field_value(fields[1:], name)

/// Checks whether constructor metadata matches the primitive character constructor rule.
private fun primitive_char_constructor(literal: CompiledDataLiteral, expectedType: CompiledTypeReference): bool =
    literal.typeName == "char" & result_type_name(expectedType.name)

/// Emits generated code for primitive character constructor.
private fun primitive_char_constructor_code(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_char(" + expression_code(first_data_field_value(literal.fields), env, string_type(), module, allModules) + ")"

private fun result_error_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if data_fields_have_all_structured_error_fields(literal.fields)
    then raw_data_literal_code(literal, env, expectedType, module, allModules)
    else if data_fields_have_name(literal.fields, "kind") & data_fields_have_name(literal.fields, "message")
    then "__capy_error(" + expression_code(data_field_value(literal.fields, "kind"), env, string_type(), module, allModules) + ", " + expression_code(data_field_value(literal.fields, "message"), env, string_type(), module, allModules) + ")"
    else if data_fields_have_name(literal.fields, "message")
    then "__capy_error(" + expression_code(data_field_value(literal.fields, "message"), env, string_type(), module, allModules) + ")"
    else "__capy_error(" + expression_code(first_data_field_value(literal.fields), env, string_type(), module, allModules) + ")"

private fun data_fields_have_all_structured_error_fields(fields: List[CompiledDataField]): bool =
    data_fields_have_name(fields, "kind")
        & data_fields_have_name(fields, "message")
        & data_fields_have_name(fields, "details")
        & data_fields_have_name(fields, "location")
        & data_fields_have_name(fields, "stack_trace")
        & data_fields_have_name(fields, "raw_stack")
        & data_fields_have_name(fields, "cause")
        & data_fields_have_name(fields, "suppressed")

private fun data_fields_have_name(fields: List[CompiledDataField], name: String): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> field.name == name | data_fields_have_name(fields[1:], name)

/// Computes value metadata for first data field value.
private fun first_data_field_value(fields: List[CompiledDataField]): CompiledExpression =
    match fields[0] with
    case Some { field } -> field.value
    case None -> missing_argument()

/// Computes the type name for data literal.
private fun data_literal_type_name(typeName: String, dataType: /capy/lang/Option[String]): String =
    match dataType with
    case Some { value } -> value
    case None -> typeName

/// Emits generated code for data fields.
private fun data_fields_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if fields.is_empty()
    then "java.util.Map.of()"
    else if data_fields_have_spread(fields)
    then "__capy_data_fields(" + data_field_entries_code(fields, env, dataType, bindings, module, allModules) + ")"
    else "java.util.Map.ofEntries(" + data_field_entries_code(fields, env, dataType, bindings, module, allModules) + ")"

/// Checks whether the current value satisfies the data fields have spread rule for compiler processing.
private fun data_fields_have_spread(fields: List[CompiledDataField]): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> field.spread | data_fields_have_spread(fields[1:])

/// Emits generated code for data field entries.
private fun data_field_entries_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        data_field_entry_code(field, env, dataType, bindings, module, allModules)
        + data_field_entries_tail(fields[1:], env, dataType, bindings, module, allModules)

/// Emits generated code for data field entry.
private fun data_field_entry_code(field: CompiledDataField, env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if field.spread
    then expression_code(field.value, env, expression_type(field.value, env, module, allModules), module, allModules)
    else
        let fieldName = data_constructor_field_name(field.name, dataType, module, allModules)
        let fieldType = data_constructor_field_type(field.name, dataType, bindings, expression_type(field.value, env, module, allModules), module, allModules)
        "java.util.Map.entry(\"" + escape_java_string(fieldName) + "\", " + expression_code(field.value, env, fieldType, module, allModules) + ")"

/// Formats the recursive tail segment for data field entries.
private fun data_field_entries_tail(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + data_field_entries_code(fields, env, dataType, bindings, module, allModules)

/// Emits generated code for with expression.
private fun with_expression_code(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let rawReceiverType = with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = with_constructor_type_names(rawReceiverType.name, module, allModules)
    let rawWithCode = raw_with_expression_code(withExpression, rawReceiverType, env, module, allModules)
    if constructorTypes.is_empty()
    then rawWithCode
    else
        let resultType = with_constructor_result_type(rawReceiverType, constructorTypes, module, allModules)
        let dataName = "__capy_constructor_data_" + withExpression.location.line + "_" + withExpression.location.column + "_" + with_expression_receiver_depth(withExpression.receiver)
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + dataName + " = " + rawWithCode + ";" + newline()
        + data_constructor_pipeline_steps(constructorTypes, rawReceiverType.name, dataName, 0, module, allModules)
        + data_constructor_pipeline_return(dataName, resultType)
        + "        }).get()"

/// Emits generated code for raw with expression.
private fun raw_with_expression_code(withExpression: CompiledWithExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_merge_data("
        + expression_code(withExpression.receiver, env, receiverType, module, allModules)
        + ", __capy_data(\"\", " + with_fields_code(withExpression.fields, receiverType, env, module, allModules) + "))"

/// Computes the compiled type for with expression receiver.
private fun with_expression_receiver_type(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(withExpression.receiver, env, module, allModules)

/// Computes a numeric value for with expression receiver depth.
private fun with_expression_receiver_depth(expression: CompiledExpression): int =
    match expression with
    case CompiledWithExpression withExpression -> 1 + with_expression_receiver_depth(withExpression.receiver)
    case _ -> 0

/// Collects with constructor type names for compiler processing.
private fun with_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    data_parent_constructor_type_names(typeName, module, allModules) + data_own_constructor_type_names(typeName, module)

/// Computes the compiled type for with constructor result.
private fun with_constructor_result_type(receiverType: CompiledTypeReference, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then result_type(receiverType)
    else receiverType

/// Emits generated code for with fields.
private fun with_fields_code(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if fields.is_empty()
    then "java.util.Map.of()"
    else "java.util.Map.ofEntries(" + with_field_entries_code(fields, receiverType, env, module, allModules) + ")"

/// Emits generated code for with field entries.
private fun with_field_entries_code(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        let fieldType = with_field_type(field.name, receiverType, expression_type(field.value, env, module, allModules), module, allModules)
        "java.util.Map.entry(\"" + escape_java_string(field.name) + "\", " + expression_code(field.value, env, fieldType, module, allModules) + ")"
        + with_field_entries_tail(fields[1:], receiverType, env, module, allModules)

/// Formats the recursive tail segment for with field entries.
private fun with_field_entries_tail(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + with_field_entries_code(fields, receiverType, env, module, allModules)

/// Computes the compiled type for with field.
private fun with_field_type(name: String, receiverType: CompiledTypeReference, fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    data_field_type(name, receiverType, fallback, module, allModules)

/// Computes the name for data constructor field.
private fun data_constructor_field_name(name: String, dataType: /capy/lang/Option[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_generator_string_has_prefix(name, "$")
    then match dataType with
        case Some { value } -> declared_positional_field_name(name, data_type_fields(value, module, allModules), 0)
        case None -> name
    else name

/// Computes the name for declared positional field.
private fun declared_positional_field_name(name: String, fields: List[String], idx: int): String =
    match fields[0] with
    case None -> name
    case Some { field } ->
        if name == "$" + idx
        then schema_field_name(field)
        else declared_positional_field_name(name, fields[1:], idx + 1)

/// Computes the compiled type for data constructor field.
private fun data_constructor_field_type(name: String, dataType: /capy/lang/Option[String], bindings: List[JavaBinding], fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match dataType with
    case Some { value } ->
        if java_generator_string_has_prefix(name, "$")
        then declared_positional_field_type(name, data_type_fields(value, module, allModules), bindings, 0, fallback)
        else declared_named_field_type(name, data_type_fields(value, module, allModules), bindings, fallback)
    case None -> fallback

/// Computes the compiled type for declared named field.
private fun declared_named_field_type(name: String, fields: List[String], bindings: List[JavaBinding], fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if schema_field_name(field) == name
        then generic_data_field_type(field, bindings)
        else declared_named_field_type(name, fields[1:], bindings, fallback)

/// Computes the compiled type for declared positional field.
private fun declared_positional_field_type(name: String, fields: List[String], bindings: List[JavaBinding], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if name == "$" + idx
        then generic_data_field_type(field, bindings)
        else declared_positional_field_type(name, fields[1:], bindings, idx + 1, fallback)

/// Computes the compiled type for generic data field.
private fun generic_data_field_type(field: String, bindings: List[JavaBinding]): CompiledTypeReference =
    bound_schema_type(schema_type_reference(schema_field_type_name(field)), bindings)

/// Computes the compiled type for bound schema.
private fun bound_schema_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    match lookup_type_parameter(type.name, bindings) with
    case Some { value } -> value
    case None -> CompiledTypeReference {
        name: type.name,
        arguments: bound_schema_types(type.arguments, bindings)
    }

/// Collects schema metadata entries for bound schema types.
private fun bound_schema_types(types: List[CompiledTypeReference], bindings: List[JavaBinding]): List[CompiledTypeReference] =
    match types[0] with
    case None -> []
    case Some { type } -> [bound_schema_type(type, bindings)] + bound_schema_types(types[1:], bindings)

/// Emits generated code for field access.
private fun field_access_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if enum_static_field_access(access, env, module, allModules)
    then enum_static_field_access_code(access, module, allModules)
    else if object_field_access(access, env, module, allModules)
    then object_field_access_code(access, env, expectedType, module, allModules)
    else if access.name == "value" & numeric_type(expression_type(access.receiver, env, module, allModules))
    then expression_code(access.receiver, env, expectedType, module, allModules)
    else if access.name == "value" & stdlib_byte_count_type(expression_type(access.receiver, env, module, allModules))
    then stdlib_byte_count_value_code(access, env, expectedType, module, allModules)
    else
        let sourceType = field_access_type(access, env, module, allModules)
        let castType = field_access_cast_type(sourceType, expectedType)
        numeric_widening_code(
            "((" + boxed_java_type(castType) + ") __capy_data_field("
            + expression_code(access.receiver, env, expression_type(access.receiver, env, module, allModules), module, allModules)
            + ", \"" + escape_java_string(access.name) + "\"))",
            castType,
            expectedType
        )

/// Emits generated code for object field access.
private fun object_field_access_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_object_field(access, env, module, allModules) with
    case Some { binding } ->
        let receiverType = java_object_type_reference_for_class(binding.moduleClassName, binding.objectClass)
        value_conversion_code(
            expression_code(access.receiver, env, receiverType, module, allModules) + "." + java_identifier(binding.field.name),
            binding.field.typeReference,
            expectedType,
            module,
            allModules
        )
    case None -> "__capy_data_field(" + expression_code(access.receiver, env, object_type(), module, allModules) + ", \"" + escape_java_string(access.name) + "\")"

/// Computes the compiled type for field access cast.
private fun field_access_cast_type(sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if sourceType.name == "any"
    then expectedType
    else sourceType

/// Checks whether the current value satisfies the enum static field access rule for compiler processing.
private fun enum_static_field_access(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match access.receiver with
    case CompiledVariableExpression variable ->
        !binding_exists(variable.name, env)
            & enum_type_exists(variable.name, module, allModules)
            & (access.name == "values" | enum_value_exists(variable.name, access.name, module, allModules))
    case _ -> false

/// Emits generated code for enum static field access.
private fun enum_static_field_access_code(access: CompiledFieldAccessExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = enum_static_field_access_type_name(access)
    if access.name == "values"
    then "java.util.Set.of(" + enum_value_references_code(typeName, enum_values(typeName, module, allModules), module, allModules) + ")"
    else enum_value_reference_code(typeName, access.name, module, allModules)

/// Computes the compiled type for enum static field access.
private fun enum_static_field_access_type(access: CompiledFieldAccessExpression): CompiledTypeReference =
    let typeName = enum_static_field_access_type_name(access)
    if access.name == "values"
    then set_type(data_type_reference(typeName))
    else data_type_reference(typeName)

/// Computes the type name for enum static field access.
private fun enum_static_field_access_type_name(access: CompiledFieldAccessExpression): String =
    match access.receiver with
    case CompiledVariableExpression variable -> variable.name
    case _ -> ""

/// Emits generated code for reduce expression.
private fun reduce_expression_code(reduce: CompiledReduceExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = reduce_result_type(reduce.initial, env, expectedType, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = reduce_value_type(receiverType)
    let accumulatorSnapshot = "__capy_" + java_identifier(reduce.accumulatorName) + "_snapshot"
    let reduceEnv = reduce_env(reduce, resultType, valueType, accumulatorSnapshot, env)
    let receiverIterableCode = reduce_receiver_iterable_code(reduce.receiver, receiverType, env, module, allModules)
    if option_type_name(receiverType.name)
    then option_reduce_expression_code(reduce, receiverType, valueType, resultType, accumulatorSnapshot, reduceEnv, env, module, allModules)
    else if receiverType.name == "Dict"
    then "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + expression_code(reduce.receiver, env, receiverType, module, allModules) + ".entrySet()) {" + newline()
        + reduce_key_statement(reduce.keyName, "                ")
        + "                " + java_type(valueType) + " " + java_identifier(reduce.valueName) + " = __capy_entry.getValue();" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"
    else "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            for (" + java_type(valueType) + " " + java_identifier(reduce.valueName) + " : " + receiverIterableCode + ") {" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"

/// Emits generated code for option reduce expression.
private fun option_reduce_expression_code(reduce: CompiledReduceExpression, receiverType: CompiledTypeReference, valueType: CompiledTypeReference, resultType: CompiledTypeReference, accumulatorSnapshot: String, reduceEnv: List[JavaBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let optionName = "__capy_option_reduce_" + reduce.location.line + "_" + reduce.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            java.util.Optional<" + boxed_java_type(valueType) + "> " + optionName + " = ((java.util.Optional<" + boxed_java_type(valueType) + ">) __capy_optional_value(" + expression_code(reduce.receiver, env, receiverType, module, allModules) + "));" + newline()
        + "            if (" + optionName + ".isPresent()) {" + newline()
        + "                " + java_type(valueType) + " " + java_identifier(reduce.valueName) + " = ((" + boxed_java_type(valueType) + ") " + optionName + ".get());" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"

/// Emits generated code for reduce receiver iterable.
private fun reduce_receiver_iterable_code(receiver: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType.name == "String" | seq_type_name(receiverType.name)
    then seq_receiver_code(receiver, receiverType, env, module, allModules) + ".asList()"
    else expression_code(receiver, env, receiverType, module, allModules)

/// Computes the compiled type for reduce result.
private fun reduce_result_type(initial: CompiledExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if empty_collection_literal_assignable(expectedType, initial)
    then expectedType
    else expression_type(initial, env, module, allModules)

/// Computes the compiled type for reduce value.
private fun reduce_value_type(receiverType: CompiledTypeReference): CompiledTypeReference =
    if option_type_name(receiverType.name)
    then first_type_argument(receiverType)
    else collection_value_type(receiverType)

/// Collects reduce environmentironment for compiler processing.
private fun reduce_env(reduce: CompiledReduceExpression, resultType: CompiledTypeReference, valueType: CompiledTypeReference, accumulatorJavaName: String, env: List[JavaBinding]): List[JavaBinding] =
    [java_binding_with_java_name(reduce.accumulatorName, resultType, accumulatorJavaName)]
        + reduce_key_env(reduce.keyName)
        + [java_binding(reduce.valueName, valueType)]
        + env

/// Collects reduce key environmentironment for compiler processing.
private fun reduce_key_env(keyName: String): List[JavaBinding] =
    if keyName.is_empty()
    then []
    else [java_binding(keyName, string_type())]

/// Emits one generated statement for reduce key.
private fun reduce_key_statement(keyName: String, indent: String): String =
    if keyName.is_empty()
    then ""
    else indent + "java.lang.String " + java_identifier(keyName) + " = __capy_entry.getKey();" + newline()

/// Computes the compiled type for collection value.
private fun collection_value_type(type: CompiledTypeReference): CompiledTypeReference =
    if type.name == "List" | type.name == "Set" | seq_type_name(type.name) | type.name == "Dict"
    then first_type_argument(type)
    else if type.name == "String"
    then string_type()
    else object_type()

/// Checks whether a type reference matches the collection receiver type rule.
private fun collection_receiver_type(type: CompiledTypeReference): bool =
    type.name == "List" | type.name == "Set" | seq_type_name(type.name) | type.name == "String"

/// Checks whether a type reference matches the collection pipe receiver type rule.
private fun collection_pipe_receiver_type(type: CompiledTypeReference): bool =
    collection_receiver_type(type) | type.name == "Dict"

/// Checks whether a type reference matches the option type name rule.
private fun option_type_name(name: String): bool =
    stdlib_type_name(name, "Option")

/// Checks whether a type reference matches the result type name rule.
private fun result_type_name(name: String): bool =
    stdlib_type_name(name, "Result")

private fun error_type_name(name: String): bool =
    name == "Error" | name == "Result.Error" | name == "/capy/lang/Result.Error" | name == "capy/lang/Result.Error"

/// Checks whether a type reference matches the seq type name rule.
private fun seq_type_name(name: String): bool =
    stdlib_type_name(name, "Seq")

/// Checks whether a type reference matches the async type name rule.
private fun async_type_name(name: String): bool =
    stdlib_type_name(name, "Async")

/// Checks whether a type reference matches the standard-library type name rule.
private fun stdlib_type_name(name: String, member: String): bool =
    name == member | name == "/capy/lang/" + member | name == "capy/lang/" + member

/// Checks whether standard-library type reference is assignable under the generator type rules.
private fun stdlib_type_reference_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    stdlib_type_reference_assignable_as(target, source, "Option")
        | stdlib_type_reference_assignable_as(target, source, "Result")
        | stdlib_type_reference_assignable_as(target, source, "Seq")
        | stdlib_type_reference_assignable_as(target, source, "Async")

/// Checks whether standard-library type reference assignable as is assignable under the generator type rules.
private fun stdlib_type_reference_assignable_as(target: CompiledTypeReference, source: CompiledTypeReference, member: String): bool =
    stdlib_type_name_equivalent(target.name, source.name, member)
        & type_arguments_assignable(target.arguments, source.arguments)

/// Checks whether a type reference matches the standard-library type name equivalent rule.
private fun stdlib_type_name_equivalent(target: String, source: String, member: String): bool =
    stdlib_type_name(target, member) & stdlib_type_name(source, member)

/// Checks whether constructor metadata matches the standard-library data constructor name rule.
private fun stdlib_data_constructor_name(typeName: String, owner: String, member: String): bool =
    typeName == member
        | typeName == "/capy/lang/" + owner + "." + member
        | typeName == owner + "." + member

/// Emits generated code for match expression.
private fun match_expression_code(matchExpression: CompiledMatchExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = expression_type(matchExpression.value, env, module, allModules)
    let valueCode = expression_code(matchExpression.value, env, valueType, module, allModules)
    let matchValueName = "__capy_match_value_" + matchExpression.location.line + "_" + matchExpression.location.column
    let cases = ordered_match_cases(matchExpression.cases)
    "((java.util.function.Supplier<" + boxed_java_type(expectedType) + ">) () -> {" + newline()
    + "            " + java_type(valueType) + " " + matchValueName + " = " + valueCode + ";" + newline()
    + match_case_statements(cases, matchValueName, valueType, env, expectedType, module, allModules, "            ")
    + "            return unsupported(\"match\");" + newline()
    + "        }).get()"

/// Collects ordered match cases for compiler processing.
private fun ordered_match_cases(cases: List[CompiledMatchCase]): List[CompiledMatchCase] =
    match_cases_with_guard(cases, true) + match_cases_with_guard(cases, false)

/// Collects match cases with guard for compiler processing.
private fun match_cases_with_guard(cases: List[CompiledMatchCase], guarded: bool): List[CompiledMatchCase] =
    match cases[0] with
    case None -> []
    case Some { matchCase } ->
        if matchCase.hasGuard == guarded
        then [matchCase] + match_cases_with_guard(cases[1:], guarded)
        else match_cases_with_guard(cases[1:], guarded)

/// Emits generated statements for match case.
private fun match_case_statements(cases: List[CompiledMatchCase], valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match cases[0] with
    case None -> ""
    case Some { matchCase } ->
        indent + "if (" + match_case_condition_code(matchCase, valueCode, valueType, env, module, allModules) + ") {" + newline()
        + match_binding_statements(matchCase.bindings, matchCase, valueCode, valueType, 0, module, allModules, indent + "    ")
        + match_guarded_return_statement(matchCase, valueCode, valueType, env, expectedType, module, allModules, indent + "    ")
        + indent + "}" + newline()
        + match_case_statements(cases[1:], valueCode, valueType, env, expectedType, module, allModules, indent)

/// Emits one generated statement for match guarded return.
private fun match_guarded_return_statement(matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
    if matchCase.hasGuard
    then indent + "if (" + truthy_expression_code(matchCase.guard, caseEnv, module, allModules) + ") {" + newline()
        + indent + "    return " + expression_code(matchCase.body, caseEnv, expectedType, module, allModules) + ";" + newline()
        + indent + "}" + newline()
    else indent + "return " + expression_code(matchCase.body, caseEnv, expectedType, module, allModules) + ";" + newline()

/// Emits generated code for match case condition.
private fun match_case_condition_code(matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if matchCase.wildcard
    then "true"
    else if matchCase.hasLiteral
    then "java.util.Objects.equals(" + valueCode + ", " + expression_code(matchCase.literal, env, valueType, module, allModules) + ")"
    else if option_match_case(matchCase, valueType)
    then option_match_condition_code(matchCase, valueCode)
    else if result_match_case(matchCase, valueType)
    then result_match_condition_code(matchCase, valueCode)
    else if matchCase.typeName == "data"
    then "__capy_data_is_any(" + valueCode + ")"
    else if matchCase.typeName == "enum"
    then "__capy_enum_is(" + valueCode + ")"
    else if collection_match_type(matchCase.typeName)
    then collection_match_condition_code(matchCase.typeName, valueCode)
    else if primitive_match_type(matchCase.typeName)
    then primitive_match_condition_code(matchCase.typeName, valueCode, valueType)
    else "__capy_data_is(" + valueCode + ", \"" + escape_java_string(matchCase.typeName) + "\")"

/// Checks whether the current value satisfies the option match case rule for compiler processing.
private fun option_match_case(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): bool =
    option_type_name(valueType.name) & option_constructor_type(matchCase.typeName)

/// Checks whether a type reference matches the option constructor type rule.
private fun option_constructor_type(typeName: String): bool =
    option_some_constructor(typeName) | option_none_constructor(typeName)

/// Checks whether constructor metadata matches the option some constructor rule.
private fun option_some_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Option", "Some")

/// Checks whether constructor metadata matches the option none constructor rule.
private fun option_none_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Option", "None")

/// Emits generated code for option match condition.
private fun option_match_condition_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if option_some_constructor(matchCase.typeName)
    then option_value_code(valueCode) + ".isPresent()"
    else option_value_code(valueCode) + ".isEmpty()"

/// Emits generated code for option value.
private fun option_value_code(valueCode: String): String =
    "((java.util.Optional<?>) __capy_optional_value(" + valueCode + "))"

/// Checks whether the current value satisfies the result match case rule for compiler processing.
private fun result_match_case(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): bool =
    result_type_name(valueType.name) & result_constructor_type(matchCase.typeName)

/// Emits generated code for result match condition.
private fun result_match_condition_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_result_is_success(" + valueCode + ")"
    else "__capy_result_is_error(" + valueCode + ")"

/// Emits generated code for primitive match condition.
private fun primitive_match_condition_code(typeName: String, valueCode: String, valueType: CompiledTypeReference): String =
    if valueType.name == typeName
    then "true"
    else valueCode + " instanceof " + boxed_java_type(CompiledTypeReference { name: typeName, arguments: [] })

/// Checks whether a type reference matches the collection match type rule.
private fun collection_match_type(typeName: String): bool =
    typeName == "List" | typeName == "Set" | typeName == "Dict" | option_type_name(typeName)

/// Emits generated code for collection match condition.
private fun collection_match_condition_code(typeName: String, valueCode: String): String =
    if typeName == "List"
    then valueCode + " instanceof java.util.List<?>"
    else if typeName == "Set"
    then valueCode + " instanceof java.util.Set<?>"
    else if typeName == "Dict"
    then valueCode + " instanceof java.util.Map<?, ?> __capy_match_map && !__capy_match_map.containsKey(\"__type\")"
    else valueCode + " instanceof java.util.Optional<?>"

/// Emits generated statements for match binding.
private fun match_binding_statements(bindings: List[String], matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let bindingType = match_binding_type(binding, matchCase, valueType, idx, module, allModules)
        indent + java_type(bindingType) + " " + match_binding_java_name(binding, matchCase, idx) + " = ((" + boxed_java_type(bindingType) + ") " + match_binding_value_code(binding, matchCase, valueCode, valueType, idx, module, allModules) + ");" + newline()
        + match_binding_statements(bindings[1:], matchCase, valueCode, valueType, idx + 1, module, allModules, indent)

/// Collects match environmentironment for compiler processing.
private fun match_env(bindings: List[String], matchCase: CompiledMatchCase, valueType: CompiledTypeReference, idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        [java_binding_with_java_name(binding, match_binding_type(binding, matchCase, valueType, idx, module, allModules), match_binding_java_name(binding, matchCase, idx))]
            + match_env(bindings[1:], matchCase, valueType, idx + 1, env, module, allModules)

/// Computes the name for match binding Java.
private fun match_binding_java_name(binding: String, matchCase: CompiledMatchCase, idx: int): String =
    java_identifier(binding) + "__match_" + matchCase.location.line + "_" + matchCase.location.column + "_" + idx

/// Computes the name for match binding field.
private fun match_binding_field_name(matchCase: CompiledMatchCase, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let fields = data_type_fields(matchCase.typeName, module, allModules)
    if fields.is_empty() & idx == 0
    then "value"
    else declared_positional_field_name("$" + idx, fields, 0)

/// Computes the compiled type for match binding.
private fun match_binding_type(binding: String, matchCase: CompiledMatchCase, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if match_binding_whole_value(matchCase)
    then match_binding_whole_value_type(matchCase, valueType)
    else if option_match_case(matchCase, valueType)
    then first_type_argument(valueType)
    else if result_match_case(matchCase, valueType)
    then if result_success_constructor(matchCase.typeName) then first_type_argument(valueType) else result_error_field_type(binding, idx)
    else
        let dataType = find_data_type(matchCase.typeName, module, allModules)
        let bindings = data_type_bindings(dataType, valueType, module, allModules)
        declared_positional_field_type("$" + idx, data_type_fields(matchCase.typeName, module, allModules), bindings, 0, object_type())

/// Emits generated code for match binding value.
private fun match_binding_value_code(binding: String, matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    if result_match_case(matchCase, valueType) & match_binding_whole_value(matchCase)
    then result_match_whole_value_code(matchCase, valueCode)
    else if match_binding_whole_value(matchCase)
    then valueCode
    else if option_match_case(matchCase, valueType)
    then option_value_code(valueCode) + ".orElse(null)"
    else if result_match_case(matchCase, valueType)
    then result_match_binding_value_code(binding, matchCase, valueCode, idx)
    else "__capy_data_field(" + valueCode + ", \"" + escape_java_string(match_binding_field_name(matchCase, idx, module, allModules)) + "\")"

/// Emits generated code for result match whole value.
private fun result_match_whole_value_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", __capy_result_success_value(" + valueCode + "))))"
    else "__capy_result_error_value(" + valueCode + ")"

/// Emits generated code for result match binding value.
private fun result_match_binding_value_code(binding: String, matchCase: CompiledMatchCase, valueCode: String, idx: int): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_result_success_value(" + valueCode + ")"
    else "__capy_data_field(__capy_result_error_value(" + valueCode + "), \"" + escape_java_string(result_error_field_name(binding, idx)) + "\")"

private fun result_error_field_name(binding: String, idx: int): String =
    if result_error_field_exists(binding)
    then binding
    else result_error_field_name_at(idx)

private fun result_error_field_name_at(idx: int): String =
    if idx == 0 then "kind"
    else if idx == 1 then "message"
    else if idx == 2 then "details"
    else if idx == 3 then "location"
    else if idx == 4 then "stack_trace"
    else if idx == 5 then "raw_stack"
    else if idx == 6 then "cause"
    else if idx == 7 then "suppressed"
    else "$" + idx

private fun result_error_field_exists(name: String): bool =
    name == "kind"
        | name == "message"
        | name == "details"
        | name == "location"
        | name == "stack_trace"
        | name == "raw_stack"
        | name == "cause"
        | name == "suppressed"

private fun result_error_field_type(binding: String, idx: int): CompiledTypeReference =
    let field = result_error_field_name(binding, idx)
    if field == "kind" | field == "message" then string_type()
    else if field == "details" then data_type_reference("data")
    else if field == "location" then option_type(data_type_reference("/capy/lang/Result.SourceLocation"))
    else if field == "stack_trace" then list_type(data_type_reference("/capy/lang/Result.StackFrame"))
    else if field == "raw_stack" then option_type(string_type())
    else if field == "cause" then option_type(data_type_reference("/capy/lang/Result.Error"))
    else if field == "suppressed" then list_type(data_type_reference("/capy/lang/Result.Error"))
    else object_type()

/// Checks whether the current value satisfies the match binding whole value rule for compiler processing.
private fun match_binding_whole_value(matchCase: CompiledMatchCase): bool =
    matchCase.bindsWholeValue | matchCase.wildcard | primitive_match_type(matchCase.typeName)

/// Computes the compiled type for match binding whole value.
private fun match_binding_whole_value_type(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): CompiledTypeReference =
    if matchCase.typeName.is_empty()
    then valueType
    else if result_match_case(matchCase, valueType)
    then result_match_whole_value_type(matchCase, valueType)
    else CompiledTypeReference { name: matchCase.typeName, arguments: [] }

/// Computes the compiled type for result match whole value.
private fun result_match_whole_value_type(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): CompiledTypeReference =
    if result_success_constructor(matchCase.typeName)
    then CompiledTypeReference { name: "/capy/lang/Result.Success", arguments: [first_type_argument(valueType)] }
    else CompiledTypeReference { name: "/capy/lang/Result.Error", arguments: [] }

/// Checks whether a type reference matches the primitive match type rule.
private fun primitive_match_type(typeName: String): bool =
    typeName == "byte" | typeName == "int" | typeName == "long" | typeName == "float" | typeName == "double" | typeName == "bool" | typeName == "String"

/// Emits generated code for option data literal.
private fun option_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if option_some_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } ->
            let valueType = option_data_literal_value_expected_type(field.value, expectedType, env, module, allModules)
            "java.util.Optional.ofNullable(" + expression_code(field.value, env, valueType, module, allModules) + ")"
        case None -> "java.util.Optional.ofNullable(null)"
    else "java.util.Optional.empty()"

/// Computes the compiled type for option data literal value expected.
private fun option_data_literal_value_expected_type(value: CompiledExpression, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_type_name(expectedType.name)
    then first_type_argument(expectedType)
    else expression_type(value, env, module, allModules)

/// Computes the compiled type for expression.
private fun expression_type(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledUnsupportedExpression unsupported -> if compiled_placeholder_source(unsupported.source) then nothing_type() else object_type()
    case CompiledIntLiteral literal -> if byte_literal_source(literal.source) then byte_type() else int_type()
    case CompiledLongLiteral _ -> long_type()
    case CompiledFloatLiteral _ -> float_type()
    case CompiledDoubleLiteral _ -> double_type()
    case CompiledBoolLiteral _ -> bool_type()
    case CompiledStringLiteral _ -> string_type()
    case CompiledVariableExpression variable -> variable_expression_type(variable, env, module, allModules)
    case CompiledIfExpression ifExpression -> expression_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBinaryExpression binary ->
        let leftType = expression_type(binary.left, env, module, allModules)
        if result_reduce_operator_expression(binary, leftType)
        then result_reduce_method_type(result_reduce_operator_call(binary), env, module, allModules)
        else if async_pipe_expression(binary, leftType)
        then async_pipe_result_type(binary, leftType, env, module, allModules)
        else if result_pipe_expression(binary, leftType)
        then result_pipe_result_type(binary, leftType, env, module, allModules)
        else if option_pipe_expression(binary, leftType)
        then option_pipe_result_type(binary, leftType, env, module, allModules)
        else if collection_pipe_chained_method_expression(binary, leftType)
        then method_call_type(collection_pipe_chained_method_call(binary), env, module, allModules)
        else if collection_pipe_expression(binary, leftType)
        then collection_pipe_result_type(binary, leftType, env, module, allModules)
        else if binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
        then binary_extension_operator_type_with_left_type(binary, leftType, module, allModules)
        else if stdlib_path_slash_expression(binary, leftType, module)
        then stdlib_path_type()
        else binary_result_type(
            binary.operator,
            leftType,
            expression_type(binary.right, env, module, allModules)
        )
    case CompiledUnaryExpression unary -> if unary.operator == "!" then bool_type() else expression_type(unary.expression, env, module, allModules)
    case CompiledFunctionCallExpression call ->
        if partial_function_call(call)
        then partial_function_call_type(call, env, module, allModules)
        else function_call_type(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> function_reference_type(reference, module, allModules)
    case CompiledMethodCallExpression call ->
        if partial_method_call(call)
        then partial_method_call_type(call, env, module, allModules)
        else method_call_type(call, env, module, allModules)
    case CompiledWithExpression withExpression -> with_expression_type(withExpression, env, module, allModules)
    case CompiledLambdaExpression _ -> supplier_type(assert_type())
    case CompiledListLiteral literal -> list_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledSetLiteral literal -> set_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledDictLiteral literal -> dict_type(first_dict_value_type(literal.entries, env, module, allModules))
    case CompiledTupleLiteral literal -> tuple_type(expression_types(literal.values, env, module, allModules))
    case CompiledIndexExpression index -> indexed_type(index, expression_type(index.receiver, env, module, allModules), env, module, allModules)
    case CompiledDataLiteral literal -> data_literal_expression_type(literal, env, module, allModules)
    case CompiledFieldAccessExpression access -> field_access_type(access, env, module, allModules)
    case CompiledReduceExpression reduce -> expression_type(reduce.initial, env, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_type(matchExpression.cases, env, module, allModules)
    case CompiledThrowExpression _ -> nothing_type()
    case CompiledTryCatchExpression tryCatch -> try_catch_expression_type(tryCatch, env, module, allModules)
    case CompiledBlockExpression block -> expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)

private fun try_catch_expression_type(tryCatch: CompiledTryCatchExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let bodyType = expression_type(tryCatch.body, env, module, allModules)
    if bodyType.name == "nothing"
    then try_catch_branch_type(tryCatch.branches, env, module, allModules)
    else bodyType

private fun try_catch_branch_type(branches: List[CompiledTryCatchBranch], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match branches[0] with
    case None -> nothing_type()
    case Some { branch } -> expression_type(branch.catchBody, [java_binding_with_java_name(branch.catchName, error_type(), "__capy_caught_error")] + env, module, allModules)

/// Infers the expression type for data literal.
private fun data_literal_expression_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if program_success_literal(literal.typeName, module.imports) | program_failed_literal(literal.typeName, module.imports)
    then CompiledTypeReference { name: "/capy/lang/Program", arguments: [] }
    else if option_some_constructor(literal.typeName)
    then option_type(option_literal_value_type(literal, env, module, allModules))
    else if option_none_constructor(literal.typeName)
    then option_type(nothing_type())
    else if result_success_literal(literal.typeName, module.imports)
    then result_type(result_literal_value_type(literal, env, module, allModules))
    else if result_error_literal(literal.typeName, module.imports)
    then result_type(object_type())
    else if raw_data_literal(literal.typeName)
    then data_literal_declared_type(literal.typeName)
    else
        let declaredType = data_literal_declared_type(literal.typeName)
        let parentConstructors = data_parent_constructor_type_names(declaredType.name, module, allModules)
        if parentConstructors.is_empty()
        then match data_constructor_function(literal.typeName, module) with
            case Some { function } -> data_constructor_literal_type(declaredType.name, function, module, allModules)
            case None ->
                if declaredType.arguments.is_empty()
                then inferred_data_literal_reference(declaredType.name, literal, env, module, allModules)
                else declaredType
        else data_constructor_pipeline_type(declaredType.name, parentConstructors + data_own_constructor_type_names(declaredType.name, module), module, allModules)

/// Infers the expression type for with.
private fun with_expression_type(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = with_constructor_type_names(receiverType.name, module, allModules)
    if constructorTypes.is_empty()
    then receiverType
    else with_constructor_result_type(receiverType, constructorTypes, module, allModules)

/// Computes the compiled type for data constructor literal.
private fun data_constructor_literal_type(typeName: String, function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(function.returnType.name)
    then function.returnType
    else if concrete_return_type(function.returnType)
    then function.returnType
    else
        let inferred = data_constructor_inferred_return_type(function, module, allModules)
        if result_type_name(inferred.name)
        then inferred
        else data_type_reference(typeName)

/// Computes the compiled type for data constructor inferred return.
private fun data_constructor_inferred_return_type(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let constructorEnv = java_function_bindings(function) + constant_bindings(constant_functions(module.functions), module, allModules)
    data_constructor_inferred_expression_type(function.body, constructorEnv, module, allModules)

/// Infers the expression type for data constructor inferred.
private fun data_constructor_inferred_expression_type(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledIfExpression ifExpression -> preferred_result_type(
        data_constructor_inferred_expression_type(ifExpression.thenBranch, env, module, allModules),
        data_constructor_inferred_expression_type(ifExpression.elseBranch, env, module, allModules)
    )
    case CompiledBlockExpression block ->
        data_constructor_inferred_expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> result_expression_type(expression, expression_type(expression, env, module, allModules), env, module, allModules)

/// Computes the compiled type for preferred result.
private fun preferred_result_type(first: CompiledTypeReference, second: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(first.name) & result_type_name(second.name)
    then if result_value_type_needs_context(first_type_argument(first)) then second else first
    else if result_type_name(first.name)
    then first
    else if result_type_name(second.name)
    then second
    else first

/// Resolves type metadata for data type reference.
private fun data_type_reference(typeName: String): CompiledTypeReference =
    CompiledTypeReference { name: typeName, arguments: [] }

/// Resolves type metadata for inferred data literal reference.
private fun inferred_data_literal_reference(typeName: String, literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_data_type(typeName, module, allModules) with
    case Some { dataType } ->
        let parameters = data_type_parameters(dataType, module, allModules)
        if parameters.is_empty()
        then data_type_reference(typeName)
        else CompiledTypeReference {
            name: typeName,
            arguments: data_literal_type_arguments(parameters, data_literal_type_parameter_bindings(dataType, literal.fields, env, module, allModules))
        }
    case None -> data_type_reference(typeName)

/// Creates name/type bindings for data literal type parameter.
private fun data_literal_type_parameter_bindings(dataType: String, fields: List[CompiledDataField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    data_literal_schema_bindings(data_type_fields(dataType, module, allModules), fields, 0, env, module, allModules)

/// Creates name/type bindings for data literal schema.
private fun data_literal_schema_bindings(schemaFields: List[String], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match schemaFields[0] with
    case None -> []
    case Some { schemaField } ->
        let fieldValue = data_constructor_argument_value(fields, schema_field_name(schemaField), "$" + idx)
        let fieldType = schema_type_reference(schema_field_type_name(schemaField))
        inferred_type_bindings(fieldType, expression_type(fieldValue, env, module, allModules))
            + data_literal_schema_bindings(schemaFields[1:], fields, idx + 1, env, module, allModules)

/// Formats data literal type arguments for generated emission.
private fun data_literal_type_arguments(parameters: List[String], bindings: List[JavaBinding]): List[CompiledTypeReference] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [data_literal_type_argument(parameter, bindings)] + data_literal_type_arguments(parameters[1:], bindings)

/// Formats one data literal type argument for generated emission.
private fun data_literal_type_argument(parameter: String, bindings: List[JavaBinding]): CompiledTypeReference =
    match lookup_type_parameter(parameter, bindings) with
    case Some { value } -> value
    case None -> object_type()

/// Creates name/type bindings for inferred type.
private fun inferred_type_bindings(expected: CompiledTypeReference, actual: CompiledTypeReference): List[JavaBinding] =
    if type_parameter(expected)
    then [java_binding(expected.name, actual)]
    else inferred_type_argument_bindings(expected.arguments, actual.arguments)

/// Creates name/type bindings for inferred type argument.
private fun inferred_type_argument_bindings(expected: List[CompiledTypeReference], actual: List[CompiledTypeReference]): List[JavaBinding] =
    match expected[0] with
    case None -> []
    case Some { expectedType } ->
        match actual[0] with
        case Some { actualType } ->
            inferred_type_bindings(expectedType, actualType) + inferred_type_argument_bindings(expected[1:], actual[1:])
        case None -> inferred_type_argument_bindings(expected[1:], [])

/// Infers the expression type for variable.
private fun variable_expression_type(variable: CompiledVariableExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if binding_exists(variable.name, env)
    then lookup_binding(variable.name, env)
    else if qualified_enum_value_name(variable.name, module, allModules)
    then data_type_reference(enum_qualified_type_name(variable.name))
    else if variable.name == "DEFAULT_FAILED_EXIT_CODE" & program_member_imported(variable.name, module.imports)
    then int_type()
    else match imported_stdlib_constant(variable.name, module.imports) with
        case Some { constant } -> constant.typeReference
        case None ->
            match find_constant_in_scope(variable.name, module, allModules) with
            case Some { function } -> effective_function_return_type(function, module, allModules)
            case None -> object_type()

/// Infers the expression type for match.
private fun match_expression_type(cases: List[CompiledMatchCase], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let orderedCases = ordered_match_cases(cases)
    match orderedCases[0] with
    case None -> object_type()
    case Some { matchCase } -> expression_type(matchCase.body, match_env(matchCase.bindings, matchCase, object_type(), 0, env, module, allModules), module, allModules)

/// Computes the compiled type for collection pipe result.
private fun collection_pipe_result_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if receiverType.name == "Dict"
    then dict_pipe_result_type(binary, receiverType, env, module, allModules)
    else
        let valueType = collection_value_type(receiverType)
        match binary.right with
        case CompiledLambdaExpression lambda ->
            let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
            if binary.operator == "|-" | binary.operator == "|!"
            then seq_type(valueType)
            else if binary.operator == "|*"
            then flat_map_result_type(expression_type(lambda.body, lambdaEnv, module, allModules))
            else seq_type(expression_type(lambda.body, lambdaEnv, module, allModules))
        case CompiledFunctionReferenceExpression reference ->
            if binary.operator == "|-" | binary.operator == "|!"
            then seq_type(valueType)
            else if binary.operator == "|*"
            then flat_map_result_type(function_reference_type(reference, module, allModules))
            else seq_type(function_reference_type(reference, module, allModules))
        case _ -> object_type()

/// Computes the compiled type for dict pipe result.
private fun dict_pipe_result_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = collection_value_type(receiverType)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|-" | binary.operator == "|!"
        then receiverType
        else if binary.operator == "|"
        then dict_type(expression_type(lambda.body, dict_predicate_lambda_env(lambda.parameters, valueType, env), module, allModules))
        else object_type()
    case _ -> object_type()

/// Computes the compiled type for flat map result.
private fun flat_map_result_type(bodyType: CompiledTypeReference): CompiledTypeReference =
    if collection_receiver_type(bodyType)
    then seq_type(collection_value_type(bodyType))
    else seq_type(object_type())

/// Computes the compiled type for option.
private fun option_type(argument: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference { name: "Option", arguments: [argument] }

/// Computes the compiled type for field access.
private fun field_access_type(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if enum_static_field_access(access, env, module, allModules)
    then enum_static_field_access_type(access)
    else if object_field_access(access, env, module, allModules)
    then object_field_access_type(access, env, module, allModules)
    else
        let receiverType = expression_type(access.receiver, env, module, allModules)
        if access.name == "value" & numeric_type(receiverType)
        then receiverType
        else if access.name == "value" & stdlib_byte_count_type(receiverType)
        then long_type()
        else if result_match_whole_value_field(access.name, receiverType)
        then result_match_whole_value_field_type(access.name, receiverType)
        else data_field_type(access.name, receiverType, object_type(), module, allModules)

/// Computes the compiled type for object field access.
private fun object_field_access_type(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_object_field(access, env, module, allModules) with
    case Some { binding } -> binding.field.typeReference
    case None -> object_type()

/// Computes the compiled type for data field.
private fun data_field_type(name: String, receiverType: CompiledTypeReference, fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if qualified_call_name(receiverType.name)
    then match find_qualified_data_type_binding(receiverType.name, module, allModules) with
        case Some { binding } -> data_field_type_in_module(name, receiverType, binding.name, fallback, binding.module, allModules)
        case None -> data_field_type_in_scope(name, receiverType, fallback, module, allModules)
    else data_field_type_in_scope(name, receiverType, fallback, module, allModules)

/// Resolves type metadata for data field type in scope.
private fun data_field_type_in_scope(name: String, receiverType: CompiledTypeReference, fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_data_type(receiverType.name, module, allModules) with
    case Some { dataType } -> data_field_type_in_module(name, receiverType, dataType, fallback, module, allModules)
    case None -> fallback

/// Resolves type metadata for data field type in a module.
private fun data_field_type_in_module(name: String, receiverType: CompiledTypeReference, dataType: String, fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let bindings = data_type_bindings(/capy/lang/Option.Some { dataType }, receiverType, module, allModules)
    declared_named_field_type(name, data_type_fields(dataType, module, allModules), bindings, fallback)

/// Checks whether the current value satisfies the result match whole value field rule for compiler processing.
private fun result_match_whole_value_field(name: String, receiverType: CompiledTypeReference): bool =
    (receiverType.name == "/capy/lang/Result.Error" & name == "message")
        | (receiverType.name == "/capy/lang/Result.Success" & name == "value")

/// Computes the compiled type for result match whole value field.
private fun result_match_whole_value_field_type(name: String, receiverType: CompiledTypeReference): CompiledTypeReference =
    if receiverType.name == "/capy/lang/Result.Success" & name == "value"
    then first_type_argument(receiverType)
    else string_type()

/// Computes the compiled type for function call.
private fun function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "delay"
    then delay_call_type(call.arguments, env, module, allModules)
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_type_return_type(lookup_binding(call.name, env))
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then effect_type(expression_type(argument(call.arguments, 0), env, module, allModules))
    else if async_function_call(call, module)
    then async_function_call_type(call, env, module, allModules)
    else if stdlib_effect_function_call(call, module)
    then stdlib_effect_function_call_type(call.name)
    else if result_error_function_call(call, module)
    then error_type()
    else if stdlib_path_function_call(call, module)
    then stdlib_path_type()
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_type(call.name)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then console_print_call_type(call, env, module, allModules)
    else if console_read_line_call(call, module)
    then effect_type(option_type(string_type()))
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_type(call, env, module, allModules)
    else if reflection_function_call(call, module)
    then data_type_reference("DataValueInfo")
    else if object_type_function_call(call, module, allModules)
    then object_type_function_call_type(call, module, allModules)
    else if call.name == "assert_all" | call.name == "assert_that"
    then assert_type()
    else if call.name == "test"
    then test_case_type()
    else if call.name == "test_file"
    then effect_type(test_file_type())
    else if stdlib_math_sqrt_call(call, module)
    then sqrt_call_type(call, env, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then int_type()
    else if enum_parse_call(call, module, allModules)
    then result_type(data_type_reference(enum_qualified_type_name(call.name)))
    else if object_constructor_call(call, env, module, allModules)
    then object_constructor_call_type(call, module, allModules)
    else if qualified_call_name(call.name)
    then qualified_function_call_type(call.name, module, allModules)
    else function_call_type_in_scope(call, env, module, allModules)

/// Resolves type metadata for function call type in scope.
private fun function_call_type_in_scope(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
    case Some { function } -> effective_function_return_type(function, module, allModules)
    case None -> lookup_function_type_in_scope(call.name, module, allModules)

/// Computes the compiled type for standard-library to seq.
private fun stdlib_to_seq_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if argumentType.name == "Dict"
    then seq_type(tuple_type([string_type(), first_type_argument(argumentType)]))
    else seq_type(collection_value_type(argumentType))

/// Checks whether a function matches the reflection function call metadata.
private fun reflection_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "reflection"
    then !function_defined("reflection", module.functions) & reflection_member_imported("reflection", module.imports)
    else false

/// Checks whether reflection call can be emitted by the target backend.
private fun reflection_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { value } ->
        let valueType = expression_type(value, env, module, allModules)
        call.arguments[1:].is_empty()
            & expression_emittable(value, env, module, allModules)
            & (generated_data_object_type(valueType) | valueType.name == "data")

/// Emits generated code for reflection call.
private fun reflection_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let value = argument(call.arguments, 0)
    let valueType = expression_type(value, env, module, allModules)
    let valueName = "__capy_reflection_value_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<java.util.Map<java.lang.String, java.lang.Object>>) () -> {" + newline()
        + "            java.lang.Object " + valueName + " = " + expression_code(value, env, valueType, module, allModules) + ";" + newline()
        + "            return " + reflection_value_info_for_type_code(valueType, valueName, module, allModules) + ";" + newline()
        + "        }).get()"

/// Emits generated code for reflection value info for a type.
private fun reflection_value_info_for_type_code(valueType: CompiledTypeReference, valueCode: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if valueType.name == "data"
    then reflection_dynamic_value_info_code(valueCode, module, allModules)
    else
        let dataName = type_unqualified_name(valueType.name)
        let owner = reflection_owner_module(dataName, module, allModules)
        reflection_value_info_code(dataName, valueCode, owner, allModules)

/// Emits generated code for reflection value info.
private fun reflection_value_info_code(dataName: String, valueCode: String, owner: CompiledModule, allModules: List[CompiledModule]): String =
    if enum_type_exists(dataName, owner, allModules)
    then reflection_enum_value_info_code(dataName, valueCode, owner, allModules)
    else reflection_data_value_info_code(dataName, valueCode, owner, allModules)

/// Emits generated code for reflection dynamic value info.
private fun reflection_dynamic_value_info_code(valueCode: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let runtimeTypeName = "__capy_reflection_runtime_type"
    let modules = reflection_dispatch_modules(module, allModules)
    "((java.util.function.Supplier<java.util.Map<java.lang.String, java.lang.Object>>) () -> {" + newline()
        + "                java.lang.String " + runtimeTypeName + " = __capy_data_type(" + valueCode + ");" + newline()
        + reflection_dynamic_enum_value_cases_code(modules, runtimeTypeName, valueCode, allModules)
        + reflection_dynamic_data_type_cases_code(modules, runtimeTypeName, valueCode, allModules)
        + "                return " + reflection_unknown_data_value_info_code(runtimeTypeName) + ";" + newline()
        + "            }).get()"

/// Creates generated-module entries for reflection dispatch.
private fun reflection_dispatch_modules(module: CompiledModule, allModules: List[CompiledModule]): List[CompiledModule] =
    [module] + reflection_imported_modules(module.imports, module, allModules)

/// Creates generated-module entries for reflection imported.
private fun reflection_imported_modules(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): List[CompiledModule] =
    match imports[0] with
    case None -> []
    case Some { declaration } ->
        if stdlib_import(declaration.modulePath)
        then reflection_imported_modules(imports[1:], module, allModules)
        else match find_module_by_class(imported_module_class(module, declaration.modulePath), allModules) with
            case Some { importedModule } -> [importedModule] + reflection_imported_modules(imports[1:], module, allModules)
            case None -> reflection_imported_modules(imports[1:], module, allModules)

/// Emits generated code for reflection dynamic enum value cases.
private fun reflection_dynamic_enum_value_cases_code(modules: List[CompiledModule], runtimeTypeName: String, valueCode: String, allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        reflection_dynamic_enum_value_cases_in_module_code(schema_values("__capy_schema_type|", module.functions), module, runtimeTypeName, valueCode, allModules)
            + reflection_dynamic_enum_value_cases_code(modules[1:], runtimeTypeName, valueCode, allModules)

/// Emits complete source for reflection dynamic enum value cases in a module.
private fun reflection_dynamic_enum_value_cases_in_module_code(typeNames: List[String], owner: CompiledModule, runtimeTypeName: String, valueCode: String, allModules: List[CompiledModule]): String =
    match typeNames[0] with
    case None -> ""
    case Some { typeName } ->
        let enumValues = enum_values_in_functions(typeName, owner.functions)
        if !enumValues.is_empty()
        then reflection_dynamic_enum_value_cases_for_type_code(typeName, enumValues, owner, runtimeTypeName, valueCode, allModules)
            + reflection_dynamic_enum_value_cases_in_module_code(typeNames[1:], owner, runtimeTypeName, valueCode, allModules)
        else reflection_dynamic_enum_value_cases_in_module_code(typeNames[1:], owner, runtimeTypeName, valueCode, allModules)

/// Emits generated code for reflection dynamic enum value cases for a type.
private fun reflection_dynamic_enum_value_cases_for_type_code(enumName: String, values: List[String], owner: CompiledModule, runtimeTypeName: String, valueCode: String, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        "                if (__capy_enum_is(" + valueCode + ") && java.util.Objects.equals(" + runtimeTypeName + ", \"" + escape_java_string(value) + "\")) {" + newline()
            + "                    return " + reflection_enum_value_info_code(enumName, valueCode, owner, allModules) + ";" + newline()
            + "                }" + newline()
            + reflection_dynamic_enum_value_cases_for_type_code(enumName, values[1:], owner, runtimeTypeName, valueCode, allModules)

/// Emits generated code for reflection dynamic data type cases.
private fun reflection_dynamic_data_type_cases_code(modules: List[CompiledModule], runtimeTypeName: String, valueCode: String, allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        reflection_dynamic_data_type_cases_in_module_code(schema_values("__capy_schema_type|", module.functions), module, runtimeTypeName, valueCode, allModules)
            + reflection_dynamic_data_type_cases_code(modules[1:], runtimeTypeName, valueCode, allModules)

/// Emits complete source for reflection dynamic data type cases in a module.
private fun reflection_dynamic_data_type_cases_in_module_code(typeNames: List[String], owner: CompiledModule, runtimeTypeName: String, valueCode: String, allModules: List[CompiledModule]): String =
    match typeNames[0] with
    case None -> ""
    case Some { typeName } ->
        let enumValues = enum_values_in_functions(typeName, owner.functions)
        if !enumValues.is_empty()
        then reflection_dynamic_data_type_cases_in_module_code(typeNames[1:], owner, runtimeTypeName, valueCode, allModules)
        else "                if (java.util.Objects.equals(" + runtimeTypeName + ", \"" + escape_java_string(typeName) + "\")) {" + newline()
            + "                    return " + reflection_data_value_info_code(typeName, valueCode, owner, allModules) + ";" + newline()
            + "                }" + newline()
            + reflection_dynamic_data_type_cases_in_module_code(typeNames[1:], owner, runtimeTypeName, valueCode, allModules)

/// Emits generated code for reflection unknown data value info.
private fun reflection_unknown_data_value_info_code(nameCode: String): String =
    "__capy_data(\"DataValueInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", nameCode)
        + ", " + java_map_entry("pkg", package_info_literal_code("", ""))
        + ", " + java_map_entry("fields", "java.util.List.of()")
        + ", " + java_map_entry("annotations", "java.util.List.of()")
        + "))"

/// Resolves metadata for reflection owner module during compiler processing.
private fun reflection_owner_module(dataName: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledModule =
    match data_type_owner_module(dataName, module, allModules) with
    case Some { owner } -> owner
    case None -> module

/// Emits generated code for reflection data value info.
private fun reflection_data_value_info_code(dataName: String, valueCode: String, owner: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"DataValueInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(dataName) + "\"")
        + ", " + java_map_entry("pkg", data_value_package_info_code(owner))
        + ", " + java_map_entry("fields", reflection_field_value_infos_code(dataName, valueCode, reflection_data_type_fields(dataName, owner, allModules), 0, owner, allModules))
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            schema_values("__capy_schema_annotation|data|" + dataName + "|", owner.functions),
            owner,
            allModules
        ))
        + "))"

/// Emits generated code for reflection enum value info.
private fun reflection_enum_value_info_code(dataName: String, valueCode: String, owner: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"DataValueInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "(java.lang.String) __capy_data_field(" + valueCode + ", \"name\")")
        + ", " + java_map_entry("pkg", data_value_package_info_code(owner))
        + ", " + java_map_entry("fields", "java.util.List.of()")
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            schema_values("__capy_schema_annotation|enum|" + dataName + "|", owner.functions),
            owner,
            allModules
        ))
        + "))"

/// Emits generated code for reflection field value infos.
private fun reflection_field_value_infos_code(dataName: String, valueCode: String, fields: List[String], idx: int, owner: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_field_value_info_codes(dataName, valueCode, fields, idx, owner, allModules))

/// Collects reflection metadata entries for reflection field value info codes.
private fun reflection_field_value_info_codes(dataName: String, valueCode: String, fields: List[String], idx: int, owner: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [reflection_field_value_info_code(dataName, valueCode, field, idx, owner, allModules)]
            + reflection_field_value_info_codes(dataName, valueCode, fields[1:], idx + 1, owner, allModules)

/// Emits generated code for reflection field value info.
private fun reflection_field_value_info_code(dataName: String, valueCode: String, field: String, idx: int, owner: CompiledModule, allModules: List[CompiledModule]): String =
    let fieldName = schema_field_name(field)
    let fieldType = schema_type_reference(schema_field_type_name(field))
    "__capy_data(\"FieldValueInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(fieldName) + "\"")
        + ", " + java_map_entry("type", reflection_any_info_code(fieldType, owner, allModules))
        + ", " + java_map_entry("value", "__capy_data_field(" + valueCode + ", \"" + escape_java_string(fieldName) + "\")")
        + ", " + java_map_entry("annotations", reflection_annotation_infos_code(
            schema_values("__capy_schema_annotation|field|" + dataName + "|" + idx + "|", owner.functions),
            owner,
            allModules
        ))
        + "))"

/// Emits generated code for reflection any info.
private fun reflection_any_info_code(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"DataInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(type_unqualified_name(type.name)) + "\"")
        + ", " + java_map_entry("pkg", reflection_type_package_info_code(type.name, module, allModules))
        + ", " + java_map_entry("annotations", "java.util.List.of()")
        + "))"

/// Emits generated code for reflection type package info.
private fun reflection_type_package_info_code(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match data_type_owner_module(type_unqualified_name(typeName), module, allModules) with
    case Some { owner } -> package_info_code(owner)
    case None -> package_info_literal_code("", "")

/// Emits generated code for package info.
private fun package_info_code(module: CompiledModule): String =
    package_info_literal_code(module.name, module.path)

/// Emits generated code for data value package info.
private fun data_value_package_info_code(module: CompiledModule): String =
    package_info_literal_code(module.name, module_reflection_path(module))

/// Computes the output or module path for module reflection.
private fun module_reflection_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

/// Emits generated code for package info literal.
private fun package_info_literal_code(name: String, path: String): String =
    "__capy_data(\"PackageInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(name) + "\"")
        + ", " + java_map_entry("path", "\"" + escape_java_string(path) + "\"")
        + "))"

/// Emits generated code for reflection annotation infos.
private fun reflection_annotation_infos_code(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    java_list_code(reflection_annotation_info_codes(values, usageModule, allModules))

/// Collects reflection metadata entries for reflection annotation info codes.
private fun reflection_annotation_info_codes(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match values[0] with
    case None -> []
    case Some { value } ->
        [reflection_annotation_info_code(value, usageModule, allModules)]
            + reflection_annotation_info_codes(values[1:], usageModule, allModules)

/// Emits generated code for reflection annotation info.
private fun reflection_annotation_info_code(value: String, usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    let name = annotation_schema_name(value)
    let explicitArguments = annotation_schema_arguments(annotation_schema_arguments_source(value))
    match find_annotation_binding(name, usageModule, allModules) with
    case Some { binding } ->
        "__capy_data(\"AnnotationInfo\", java.util.Map.ofEntries("
            + java_map_entry("name", "\"" + escape_java_string(binding.declaration.name) + "\"")
            + ", " + java_map_entry("pkg", package_info_code(binding.module))
            + ", " + java_map_entry("arguments", java_list_code(annotation_argument_info_codes(explicitArguments, binding.declaration.fields)))
            + "))"
    case None ->
        "__capy_data(\"AnnotationInfo\", java.util.Map.ofEntries("
            + java_map_entry("name", "\"" + escape_java_string(annotation_display_name(name)) + "\"")
            + ", " + java_map_entry("pkg", package_info_code(usageModule))
            + ", " + java_map_entry("arguments", java_list_code(explicit_annotation_argument_info_codes(explicitArguments)))
            + "))"

/// Computes the name for annotation display.
private fun annotation_display_name(name: String): String =
    if qualified_call_name(name) then qualified_call_member(name) else name

/// Collects annotation argument info codes for compiler processing.
private fun annotation_argument_info_codes(arguments: List[SchemaAnnotationArgument], fields: List[String]): List[String] =
    explicit_annotation_argument_info_codes(arguments) + default_annotation_argument_info_codes(fields, arguments)

/// Collects explicit annotation argument info codes for compiler processing.
private fun explicit_annotation_argument_info_codes(arguments: List[SchemaAnnotationArgument]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { argument } ->
        [annotation_argument_info_code(argument.name, schema_annotation_value_code(argument))]
            + explicit_annotation_argument_info_codes(arguments[1:])

/// Collects default annotation argument info codes for compiler processing.
private fun default_annotation_argument_info_codes(fields: List[String], explicitArguments: List[SchemaAnnotationArgument]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        let fieldName = annotation_field_schema_name(field)
        if annotation_field_schema_has_default(field) & !schema_annotation_argument_exists(fieldName, explicitArguments)
        then [annotation_argument_info_code(fieldName, annotation_field_schema_default_value_code(field))]
            + default_annotation_argument_info_codes(fields[1:], explicitArguments)
        else default_annotation_argument_info_codes(fields[1:], explicitArguments)

/// Checks whether schema annotation argument exists in the relevant declarations or imports.
private fun schema_annotation_argument_exists(name: String, arguments: List[SchemaAnnotationArgument]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } -> argument.name == name | schema_annotation_argument_exists(name, arguments[1:])

/// Emits generated code for annotation argument info.
private fun annotation_argument_info_code(name: String, valueCode: String): String =
    "__capy_data(\"AnnotationArgumentInfo\", java.util.Map.ofEntries("
        + java_map_entry("name", "\"" + escape_java_string(name) + "\"")
        + ", " + java_map_entry("value", valueCode)
        + "))"

/// Emits generated code for schema annotation value.
private fun schema_annotation_value_code(argument: SchemaAnnotationArgument): String =
    annotation_value_code(argument.kind, argument.value)

/// Emits generated code for annotation value.
private fun annotation_value_code(kind: String, value: String): String =
    if kind == "string"
    then "__capy_data(\"AnnotationString\", java.util.Map.ofEntries(" + java_map_entry("value", "\"" + escape_java_string(value) + "\"") + "))"
    else if kind == "int"
    then "__capy_data(\"AnnotationInt\", java.util.Map.ofEntries(" + java_map_entry("value", value) + "))"
    else if kind == "long"
    then "__capy_data(\"AnnotationLong\", java.util.Map.ofEntries(" + java_map_entry("value", value) + "))"
    else if kind == "double"
    then "__capy_data(\"AnnotationDouble\", java.util.Map.ofEntries(" + java_map_entry("value", value) + "))"
    else if kind == "float"
    then "__capy_data(\"AnnotationFloat\", java.util.Map.ofEntries(" + java_map_entry("value", value) + "))"
    else if kind == "bool"
    then "__capy_data(\"AnnotationBool\", java.util.Map.ofEntries(" + java_map_entry("value", value) + "))"
    else if kind == "type"
    then "__capy_data(\"AnnotationTypeName\", java.util.Map.ofEntries(" + java_map_entry("value", "\"" + escape_java_string(value) + "\"") + "))"
    else "__capy_data(\"AnnotationNothing\", java.util.Map.ofEntries())"

/// Computes the name for annotation schema.
private fun annotation_schema_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

/// Encodes schema metadata text for annotation schema arguments source.
private fun annotation_schema_arguments_source(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then ""
    else value[separator + 1, value.size().value]

/// Formats annotation schema arguments for generated emission.
private fun annotation_schema_arguments(value: String): List[SchemaAnnotationArgument] =
    if value.is_empty()
    then []
    else
        let separator = first_index_of(value, ";", 0)
        if separator < 0
        then [annotation_schema_argument(value)]
        else [annotation_schema_argument(value[0, separator])] + annotation_schema_arguments(value[separator + 1, value.size().value])

/// Formats one annotation schema argument for generated emission.
private fun annotation_schema_argument(value: String): SchemaAnnotationArgument =
    let equals = first_index_of(value, "=", 0)
    if equals < 0
    then SchemaAnnotationArgument { name: value, kind: "nothing", value: "" }
    else
        let payload = value[equals + 1, value.size().value]
        let colon = first_index_of(payload, ":", 0)
        if colon < 0
        then SchemaAnnotationArgument { name: value[0, equals], kind: "nothing", value: "" }
        else SchemaAnnotationArgument {
            name: value[0, equals],
            kind: payload[0, colon],
            value: payload[colon + 1, payload.size().value]
        }

/// Computes the name for annotation field schema.
private fun annotation_field_schema_name(value: String): String =
    schema_field_name(value)

/// Checks whether annotation metadata matches the annotation field schema has default rule.
private fun annotation_field_schema_has_default(value: String): bool =
    let second = annotation_field_schema_second_separator(value)
    let third = annotation_field_schema_third_separator(value)
    if second < 0 | third < 0
    then false
    else value[second + 1, third] == "true"

/// Emits generated code for annotation field schema default value.
private fun annotation_field_schema_default_value_code(value: String): String =
    let third = annotation_field_schema_third_separator(value)
    if third < 0
    then annotation_value_code("nothing", "")
    else
        let payload = value[third + 1, value.size().value]
        let colon = first_index_of(payload, ":", 0)
        if colon < 0
        then annotation_value_code("nothing", "")
        else annotation_value_code(payload[0, colon], payload[colon + 1, payload.size().value])

/// Computes a numeric value for annotation field schema second separator.
private fun annotation_field_schema_second_separator(value: String): int =
    let first = first_index_of(value, "|", 0)
    if first < 0 then -1 else first_index_of(value, "|", first + 1)

/// Computes a numeric value for annotation field schema third separator.
private fun annotation_field_schema_third_separator(value: String): int =
    let second = annotation_field_schema_second_separator(value)
    if second < 0 then -1 else first_index_of(value, "|", second + 1)

/// Formats Java source text for map entry.
private fun java_map_entry(name: String, valueCode: String): String =
    "java.util.Map.entry(\"" + escape_java_string(name) + "\", " + valueCode + ")"

/// Emits Java code for list.
private fun java_list_code(values: List[String]): String =
    "java.util.List.of(" + java_code_list(values) + ")"

/// Emits Java code for set.
private fun java_set_code(values: List[String]): String =
    "java.util.Set.of(" + java_code_list(values) + ")"

/// Emits Java source code for code list.
private fun java_code_list(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some { value } -> value + java_code_list_tail(values[1:])

/// Emits Java source code for code list tail.
private fun java_code_list_tail(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + java_code_list(values)

/// Finds an annotation binding in available declarations, imports, or modules.
private fun find_annotation_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    if qualified_call_name(name)
    then find_qualified_annotation_binding(name, module, allModules)
    else
        match module.annotations.get(name) with
        case Some { declaration } -> /capy/lang/Option.Some { AnnotationBinding { declaration: declaration, module: module } }
        case None ->
            match find_annotation_binding_in_imports(name, module.imports, module, allModules) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> find_annotation_binding_in_modules(name, allModules)

/// Finds a qualified annotation binding in available declarations, imports, or modules.
private fun find_qualified_annotation_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    let qualifier = qualified_call_qualifier(name)
    let className = qualified_call_class_name(name, module)
    let member = qualified_call_member(name)
    if absolute_qualified_call_name(name)
    then find_qualified_annotation_binding_in_class(className, member, allModules)
    else match find_qualified_annotation_binding_in_imports(
            qualifier,
            className,
            member,
            module.imports,
            module,
            allModules
        ) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_qualified_annotation_binding_in_class(className, member, allModules)

/// Finds a qualified annotation binding in class in available declarations, imports, or modules.
private fun find_qualified_annotation_binding_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    if stdlib_annotations_class(className)
    then stdlib_annotation_binding(member)
    else match find_module_by_class(className, allModules) with
    case Some { module } ->
        {
            match module.annotations.get(member) with
            case Some { declaration } -> /capy/lang/Option.Some { AnnotationBinding { declaration: declaration, module: module } }
            case None -> /capy/lang/Option.None {}
        }
    case None -> /capy/lang/Option.None {}

/// Finds a qualified annotation binding in imports in available declarations, imports, or modules.
private fun find_qualified_annotation_binding_in_imports(qualifier: String, className: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & qualified_annotation_import_matches(qualifier, className, declaration, module)
        then find_qualified_annotation_binding_in_import(qualifier, className, declaration, member, imports[1:], module, allModules)
        else find_qualified_annotation_binding_in_imports(qualifier, className, member, imports[1:], module, allModules)

/// Finds a qualified annotation binding in import in available declarations, imports, or modules.
private fun find_qualified_annotation_binding_in_import(qualifier: String, className: String, declaration: CompiledImportDeclaration, member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    if stdlib_annotations_module_path(declaration.modulePath)
    then {
        match stdlib_annotation_binding(member) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_qualified_annotation_binding_in_imports(qualifier, className, member, rest, module, allModules)
    }
    else {
        match find_module_by_class(imported_module_class(module, declaration.modulePath), allModules) with
        case Some { importedModule } -> find_qualified_annotation_binding_in_module(member, rest, module, allModules, importedModule)
        case None -> find_qualified_annotation_binding_in_imports(qualifier, className, member, rest, module, allModules)
    }

/// Finds a qualified annotation binding in a module in available declarations, imports, or modules.
private fun find_qualified_annotation_binding_in_module(member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[AnnotationBinding] =
    match importedModule.annotations.get(member) with
    case Some { declaration } -> /capy/lang/Option.Some { AnnotationBinding { declaration: declaration, module: importedModule } }
    case None -> find_qualified_annotation_binding_in_imports(module_fqcn(importedModule), module_fqcn(importedModule), member, rest, module, allModules)

/// Checks whether qualified annotation import matches the requested declaration, type, or name.
private fun qualified_annotation_import_matches(qualifier: String, className: String, declaration: CompiledImportDeclaration, module: CompiledModule): bool =
    let importedClass = imported_module_class(module, declaration.modulePath)
    qualifier == declaration.modulePath
        | qualifier == importedClass
        | qualifier == module_class_leaf_name(importedClass)
        | className == importedClass

/// Finds an annotation binding in imports in available declarations, imports, or modules.
private fun find_annotation_binding_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        match stdlib_annotation_binding_in_import(name, declaration) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None ->
            if annotation_import_matches(name, declaration)
            then find_annotation_binding_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
            else find_annotation_binding_in_imports(name, imports[1:], module, allModules)

/// Finds an annotation binding in import in available declarations, imports, or modules.
private fun find_annotation_binding_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[AnnotationBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        {
            match importedModule.annotations.get(name) with
            case Some { declaration } -> /capy/lang/Option.Some { AnnotationBinding { declaration: declaration, module: importedModule } }
            case None -> find_annotation_binding_in_imports(name, rest, module, allModules)
        }
    case _ -> find_annotation_binding_in_imports(name, rest, module, allModules)

/// Finds an annotation binding in a modules in available declarations, imports, or modules.
private fun find_annotation_binding_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[AnnotationBinding] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        {
            match module.annotations.get(name) with
            case Some { declaration } -> /capy/lang/Option.Some { AnnotationBinding { declaration: declaration, module: module } }
            case None -> find_annotation_binding_in_modules(name, modules[1:])
        }

/// Checks whether annotation import matches the requested declaration, type, or name.
private fun annotation_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else import_includes_name(name, declaration)

/// Emits one import statement for standard-library annotation binding in.
private fun stdlib_annotation_binding_in_import(name: String, declaration: CompiledImportDeclaration): /capy/lang/Option[AnnotationBinding] =
    if !declaration.qualified
        & stdlib_annotations_module_path(declaration.modulePath)
        & import_includes_name(name, declaration)
    then stdlib_annotation_binding(name)
    else /capy/lang/Option.None {}

/// Creates one name/type binding for standard-library annotation.
private fun stdlib_annotation_binding(name: String): /capy/lang/Option[AnnotationBinding] =
    if name == "Deprecated"
    then /capy/lang/Option.Some { AnnotationBinding {
        declaration: CompiledAnnotationDeclaration {
            name: "Deprecated",
            visibility: "public",
            documentation: [],
            repeatable: false,
            targets: ["fun", "method", "const", "data", "union", "enum", "type", "deriver", "class", "interface", "trait", "field", "init"],
            fields: ["message|String|false|nothing:", "since|String|true|string:"],
            location: CompiledSourceLocation { line: 2, column: 0 }
        },
        module: stdlib_annotations_module()
    }}
    else /capy/lang/Option.None {}

/// Resolves metadata for standard-library annotations module during compiler processing.
private fun stdlib_annotations_module(): CompiledModule =
    CompiledModule {
        name: "Annotations",
        path: "capy/meta_prog",
        types: {:},
        visiblePrimitiveBackedTypes: {:},
        functions: [],
        imports: [],
        derivers: {:},
        annotations: {:},
        staticImports: []
    }

/// Checks whether annotation metadata matches the standard-library annotations class rule.
private fun stdlib_annotations_class(className: String): bool =
    className == "capy.meta_prog.Annotations"

/// Checks whether annotation metadata matches the standard-library annotations module path rule.
private fun stdlib_annotations_module_path(path: String): bool =
    path == "/capy/meta_prog/Annotations" | path == "capy/meta_prog/Annotations"

/// Resolves type metadata for data type owner module.
private fun data_type_owner_module(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    if schema_type_exists(name, module.functions)
    then /capy/lang/Option.Some { module }
    else match data_type_owner_module_in_imports(name, module.imports, module, allModules) with
        case Some { owner } -> /capy/lang/Option.Some { owner }
        case None -> data_type_owner_module_in_modules(name, allModules)

/// Emits import statements for data type owner module in.
private fun data_type_owner_module_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_owner_module_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_owner_module_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for data type owner module in.
private fun data_type_owner_module_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledModule] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { importedModule }
        else data_type_owner_module_in_imports(name, rest, module, allModules)
    case None -> data_type_owner_module_in_imports(name, rest, module, allModules)

/// Creates generated-module entries for data type owner module in a.
private fun data_type_owner_module_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then /capy/lang/Option.Some { module }
        else data_type_owner_module_in_modules(name, modules[1:])

/// Computes the compiled type for qualified function call.
private fun qualified_function_call_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_qualified_function_binding(name, module, allModules) with
    case Some { binding } ->
        qualified_function_return_type(effective_function_return_type(binding.function, binding.module, allModules), binding.module, module)
    case None ->
        if qualified_call_member(name) == "main"
        then effect_type(CompiledTypeReference { name: "/capy/lang/Program", arguments: [] })
        else object_type()

/// Computes the compiled type for qualified function return.
private fun qualified_function_return_type(type: CompiledTypeReference, owner: CompiledModule, current: CompiledModule): CompiledTypeReference =
    if type.name.is_empty() | type.name == "any" | qualified_call_name(type.name) | type.name ? "/"
    then type
    else if module_fqcn(owner) == module_fqcn(current)
    then type
    else if schema_type_exists(type.name, owner.functions)
    then CompiledTypeReference { name: module_absolute_type_name(owner, type.name), arguments: type.arguments }
    else type

/// Computes the type name for module absolute.
private fun module_absolute_type_name(module: CompiledModule, typeName: String): String =
    if module.path.is_empty()
    then "/" + module.name + "." + typeName
    else "/" + module.path + "/" + module.name + "." + typeName

/// Computes the compiled type for function reference.
private fun function_reference_type(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    lookup_function_type_in_scope(reference.name, module, allModules)

/// Computes the compiled type for function reference parameter.
private fun function_reference_parameter_type(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } -> first_parameter_type(function.parameters)
    case None -> object_type()

/// Computes the compiled type for first parameter.
private fun first_parameter_type(parameters: List[CompiledFunctionParameter]): CompiledTypeReference =
    match parameters[0] with
    case Some { parameter } -> parameter.typeReference
    case None -> object_type()

/// Computes the compiled type for delay call.
private fun delay_call_type(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match arguments[0] with
    case None -> effect_type(object_type())
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression lambda -> effect_type(expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules))
        case _ -> effect_type(object_type())

/// Checks whether a function matches the standard-library effect function call metadata.
private fun stdlib_effect_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.arguments.is_empty()
    then stdlib_effect_function_call_by_name(call.name, module)
    else false

/// Checks whether a function name matches the standard-library effect function call metadata.
private fun stdlib_effect_function_call_by_name(name: String, module: CompiledModule): bool =
    if name == "current_millis"
    then !function_defined(name, module.functions) & system_member_imported("current_millis", module.imports)
    else if name == "nano_time"
    then !function_defined(name, module.functions) & system_member_imported("nano_time", module.imports)
    else if name == "now"
    then !function_defined(name, module.functions) & clock_member_imported("now", module.imports)
    else false

/// Emits generated code for standard-library effect function call.
private fun stdlib_effect_function_call_code(name: String): String =
    if name == "current_millis"
    then "capy.lang.System.currentMillis()"
    else if name == "nano_time"
    then "capy.lang.System.nanoTime()"
    else "capy.date_time.Clock.now__4_0()"

/// Checks whether a function call targets the Async standard-library functions.
private fun async_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    one_method_argument(call.arguments)
        & (call.name == "all" | call.name == "any")
        & async_member_imported(call.name, module.imports)

/// Emits generated code for Async standard-library functions.
private fun async_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let tasks = argument(call.arguments, 0)
    "capy.lang.Async." + call.name + "(" + expression_code(tasks, env, expression_type(tasks, env, module, allModules), module, allModules) + ")"

/// Computes the type for Async standard-library functions.
private fun async_function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let tasksType = expression_type(argument(call.arguments, 0), env, module, allModules)
    let valueType = async_tasks_value_type(tasksType)
    if call.name == "all"
    then effect_type(list_type(result_type(valueType)))
    else effect_type(result_type(valueType))

/// Computes the Async value type from a List[Async[T]].
private fun async_tasks_value_type(tasksType: CompiledTypeReference): CompiledTypeReference =
    if tasksType.name == "List"
    then first_type_argument(first_type_argument(tasksType))
    else object_type()

/// Checks whether Async standard-library function call can be emitted.
private fun async_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { argument } -> expression_emittable(argument, env, module, allModules)

/// Computes the compiled type for standard-library effect function call.
private fun stdlib_effect_function_call_type(name: String): CompiledTypeReference =
    if name == "now"
    then effect_type(date_time_type())
    else effect_type(long_type())

/// Checks whether a function matches the standard-library path function call metadata.
private fun stdlib_path_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "from_string"
    then one_method_argument(call.arguments)
        & !function_defined(call.name, module.functions)
        & stdlib_path_member_imported("from_string", module.imports)
    else false

/// Emits generated code for standard-library path function call.
private fun stdlib_path_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.Object) dev.capylang.PathUtil.fromString("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + "))"

/// Checks whether standard-library path function call can be emitted by the target backend.
private fun stdlib_path_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { value } -> call.arguments[1:].is_empty()
        & type_assignable(string_type(), expression_type(value, env, module, allModules))
        & expression_emittable(value, env, module, allModules)

/// Checks whether a function matches the standard-library I/O function call metadata.
private fun stdlib_io_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if stdlib_io_function_name(call.name)
    then !function_defined(call.name, module.functions) & stdlib_io_member_imported(call.name, module.imports)
    else false

/// Checks whether a function matches the standard-library I/O function name metadata.
private fun stdlib_io_function_name(name: String): bool =
    stdlib_io_one_path_function(name)
        | stdlib_io_text_payload_function(name)
        | stdlib_io_lines_payload_function(name)
        | stdlib_io_bytes_payload_function(name)
        | stdlib_io_two_path_function(name)

/// Checks whether a function matches the standard-library I/O one path function metadata.
private fun stdlib_io_one_path_function(name: String): bool =
    name == "read_text"
        | name == "read_lines"
        | name == "read_bytes"
        | name == "exists"
        | name == "is_file"
        | name == "is_directory"
        | name == "size"
        | name == "create_file"
        | name == "create_directory"
        | name == "create_directories"
        | name == "list_entries"
        | name == "delete"

/// Checks whether a function matches the standard-library I/O text payload function metadata.
private fun stdlib_io_text_payload_function(name: String): bool =
    name == "write_text" | name == "append_text"

/// Checks whether a function matches the standard-library I/O lines payload function metadata.
private fun stdlib_io_lines_payload_function(name: String): bool =
    name == "write_lines" | name == "append_lines"

/// Checks whether a function matches the standard-library I/O bytes payload function metadata.
private fun stdlib_io_bytes_payload_function(name: String): bool =
    name == "write_bytes" | name == "append_bytes"

/// Checks whether a function matches the standard-library I/O two path function metadata.
private fun stdlib_io_two_path_function(name: String): bool =
    name == "copy" | name == "copy_replace" | name == "move" | name == "move_replace"

/// Emits generated code for standard-library I/O function call.
private fun stdlib_io_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let callCode = "capy.io.IO." + stdlib_io_java_method(call.name) + "(" + stdlib_io_arguments_code(call, env, module, allModules) + ")"
    if stdlib_io_bool_effect_function(call.name)
    then callCode
    else stdlib_effect_object_cast(callCode)

/// Emits generated code for standard-library I/O arguments.
private fun stdlib_io_arguments_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if stdlib_io_one_path_function(call.name)
    then stdlib_path_argument_code(argument(call.arguments, 0), env, module, allModules)
    else stdlib_path_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + stdlib_io_second_argument_code(call.name, argument(call.arguments, 1), env, module, allModules)

/// Emits generated code for standard-library I/O second argument.
private fun stdlib_io_second_argument_code(name: String, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if stdlib_io_text_payload_function(name)
    then expression_code(expression, env, string_type(), module, allModules)
    else if stdlib_io_lines_payload_function(name)
    then expression_code(expression, env, list_type(string_type()), module, allModules)
    else if stdlib_io_bytes_payload_function(name)
    then expression_code(expression, env, list_type(byte_type()), module, allModules)
    else stdlib_path_argument_code(expression, env, module, allModules)

/// Emits generated code for standard-library path argument.
private fun stdlib_path_argument_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((capy.io.Path) " + expression_code(expression, env, object_type(), module, allModules) + ")"

/// Formats source text for standard-library effect object cast.
private fun stdlib_effect_object_cast(code: String): String =
    "((capy.lang.Effect<java.lang.Object>) (capy.lang.Effect<?>) " + code + ")"

/// Formats source text for standard-library I/O Java method.
private fun stdlib_io_java_method(name: String): String =
    if name == "read_text"
    then "readText"
    else if name == "read_lines"
    then "readLines"
    else if name == "read_bytes"
    then "readBytes"
    else if name == "write_text"
    then "writeText"
    else if name == "write_lines"
    then "writeLines"
    else if name == "write_bytes"
    then "writeBytes"
    else if name == "append_text"
    then "appendText"
    else if name == "append_lines"
    then "appendLines"
    else if name == "append_bytes"
    then "appendBytes"
    else if name == "is_file"
    then "isFile"
    else if name == "is_directory"
    then "isDirectory"
    else if name == "create_file"
    then "createFile"
    else if name == "create_directory"
    then "createDirectory"
    else if name == "create_directories"
    then "createDirectories"
    else if name == "list_entries"
    then "listEntries"
    else if name == "copy_replace"
    then "copyReplace"
    else if name == "move_replace"
    then "moveReplace"
    else name

/// Checks whether a function matches the standard-library I/O boolean effect function metadata.
private fun stdlib_io_bool_effect_function(name: String): bool =
    name == "exists" | name == "is_file" | name == "is_directory"

/// Computes the compiled type for standard-library I/O function call.
private fun stdlib_io_function_call_type(name: String): CompiledTypeReference =
    if stdlib_io_bool_effect_function(name)
    then effect_type(bool_type())
    else effect_type(result_type(stdlib_io_result_value_type(name)))

/// Computes the compiled type for standard-library I/O result value.
private fun stdlib_io_result_value_type(name: String): CompiledTypeReference =
    if name == "read_text" | stdlib_io_text_payload_function(name)
    then string_type()
    else if name == "read_lines" | stdlib_io_lines_payload_function(name)
    then list_type(string_type())
    else if name == "read_bytes" | stdlib_io_bytes_payload_function(name)
    then list_type(byte_type())
    else if name == "size"
    then stdlib_byte_count_type_reference()
    else if name == "list_entries"
    then list_type(stdlib_path_type())
    else if name == "delete"
    then bool_type()
    else stdlib_path_type()

/// Checks whether standard-library I/O function call can be emitted by the target backend.
private fun stdlib_io_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if stdlib_io_one_path_function(call.name)
    then one_method_argument(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
    else if stdlib_io_text_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), string_type(), env, module, allModules)
    else if stdlib_io_lines_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), list_type(string_type()), env, module, allModules)
    else if stdlib_io_bytes_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), list_type(byte_type()), env, module, allModules)
    else two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & stdlib_path_argument_emittable(argument(call.arguments, 1), env, module, allModules)

/// Checks whether typed argument can be emitted by the target backend.
private fun typed_argument_emittable(expression: CompiledExpression, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & type_assignable(expectedType, expression_type(expression, env, module, allModules))

/// Checks whether standard-library path argument can be emitted by the target backend.
private fun stdlib_path_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & stdlib_path_type_reference(expression_type(expression, env, module, allModules), module)

/// Checks whether an expression has the standard-library path slash expression shape.
private fun stdlib_path_slash_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule): bool =
    binary.operator == "/"
        & stdlib_path_type_reference(leftType, module)
        & stdlib_path_member_imported("/", module.imports)

/// Emits generated code for standard-library path slash.
private fun stdlib_path_slash_code(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.Object) "
        + stdlib_path_argument_code(binary.left, env, module, allModules)
        + ".slash("
        + stdlib_path_slash_right_code(binary.right, env, module, allModules)
        + "))"

/// Emits generated code for standard-library path slash right.
private fun stdlib_path_slash_right_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let rightType = expression_type(expression, env, module, allModules)
    if type_assignable(string_type(), rightType)
    then expression_code(expression, env, string_type(), module, allModules)
    else stdlib_path_argument_code(expression, env, module, allModules)

/// Checks whether standard-library path slash can be emitted by the target backend.
private fun stdlib_path_slash_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let rightType = expression_type(binary.right, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & expression_emittable(binary.right, env, module, allModules)
        & (type_assignable(string_type(), rightType) | stdlib_path_type_reference(rightType, module))

/// Checks whether a type reference matches the standard-library path type reference rule.
private fun stdlib_path_type_reference(type: CompiledTypeReference, module: CompiledModule): bool =
    type.name == "/capy/io/Path"
        | (type_unqualified_name(type.name) == "Path" & stdlib_path_member_imported("Path", module.imports))

/// Computes the compiled type for standard-library path.
private fun stdlib_path_type(): CompiledTypeReference =
    data_type_reference("Path")

/// Resolves type metadata for standard-library byte count type reference.
private fun stdlib_byte_count_type_reference(): CompiledTypeReference =
    data_type_reference("byte_count")

/// Checks whether a type reference matches the standard-library byte count type rule.
private fun stdlib_byte_count_type(type: CompiledTypeReference): bool =
    type.name == "/capy/io/ByteSize.byte_count" | type_unqualified_name(type.name) == "byte_count"

/// Emits generated code for standard-library byte count value.
private fun stdlib_byte_count_value_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    numeric_widening_code(
        "((java.lang.Long) " + expression_code(access.receiver, env, object_type(), module, allModules) + ")",
        long_type(),
        expectedType
    )

/// Computes the compiled type for method call.
private fun method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "size"
    then int_type()
    else
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if call.name == "__capy_call" & function_type(receiverType)
    then function_type_return_type(receiverType)
    else if call.name == "to_string" & call.arguments.is_empty() & receiverType.name == "char"
    then string_type()
    else if call.name == "name" & call.arguments.is_empty() & (receiverType.name == "enum" | enum_type_exists(receiverType.name, module, allModules))
    then string_type()
    else if assert_status_call(call, env, module, allModules)
    then bool_type()
    else if assert_method_call(call, env, module, allModules)
    then assert_type()
    else if assert_is_empty_call(call) | negated_collection_is_empty_call(call, env, module, allModules) | (call.name == "is_empty" & call.arguments.is_empty() & collection_empty_receiver_type(receiverType))
    then bool_type()
    else if collection_predicate_method(call.name) & one_method_argument(call.arguments) & lambda_expression(argument(call.arguments, 0)) & collection_predicate_receiver_type(receiverType)
    then bool_type()
    else if (call.name == "reduce" | call.name == "reduce_left") & collection_pipe_receiver_type(receiverType) & collection_reduce_method_arguments(call.arguments, receiverType)
    then collection_reduce_method_type(call, env, module, allModules)
    else if option_method_name(call.name) & one_method_argument(call.arguments) & option_type_name(receiverType.name)
        & match argument(call.arguments, 0) with
            case CompiledLambdaExpression _ -> true
            case _ -> false
    then option_pipe_result_type(option_method_binary(call), receiverType, env, module, allModules)
    else if collection_method_name(call.name) & one_method_argument(call.arguments) & lambda_expression(argument(call.arguments, 0)) & collection_pipe_receiver_type(receiverType)
    then collection_pipe_result_type(collection_method_binary(call), receiverType, env, module, allModules)
    else if set_method_arity(call) & receiverType.name == "Set"
    then set_method_call_type_with_receiver(call, receiverType, env, module, allModules)
    else if call.name == "as_list" & call.arguments.is_empty() & seq_type_name(receiverType.name)
    then list_type(collection_value_type(receiverType))
    else if call.name == "first" & call.arguments.is_empty() & seq_type_name(receiverType.name)
    then option_type(collection_value_type(receiverType))
    else if (call.name == "reduce" | call.name == "reduce_left") & result_reduce_method_arguments(call.arguments) & result_type_name(receiverType.name)
    then result_reduce_method_type_with_receiver(call, receiverType, env, module, allModules)
    else if (call.name == "map" | call.name == "flat_map") & result_map_method_argument(call.arguments) & result_type_name(receiverType.name)
    then result_map_method_type_with_receiver(call, receiverType, env, module, allModules)
    else if call.name == "or_else" & one_method_argument(call.arguments) & result_type_name(receiverType.name)
    then result_or_else_method_type_with_receiver(call, receiverType, env, module, allModules)
    else if call.name == "or" & one_method_argument(call.arguments) & result_type_name(receiverType.name)
    then result_or_method_type_with_receiver(call, receiverType, env, module, allModules)
    else if call.name == "start" & call.arguments.is_empty() & receiverType.name == "Effect"
    then async_type(first_type_argument(receiverType))
    else if call.name == "join" & call.arguments.is_empty() & async_type_name(receiverType.name)
    then effect_type(result_type(first_type_argument(receiverType)))
    else if async_map_method_name(call.name) & result_map_method_argument(call.arguments) & async_type_name(receiverType.name)
    then async_pipe_result_type(async_map_method_binary(call), receiverType, env, module, allModules)
    else if call.name == "map" & receiverType.name == "Effect"
    then
        let valueType = first_type_argument(receiverType)
        match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda -> effect_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
        case _ -> effect_type(object_type())
    else if string_parse_method(call.name) & call.arguments.is_empty() & receiverType.name == "String"
    then string_parse_result_type(call.name)
    else if native_stdlib_method_name(call.name) & native_stdlib_receiver_method(receiverType, call)
    then native_stdlib_method_type_with_receiver(call, receiverType)
    else if regex_method_name(call.name) & one_method_argument(call.arguments) & regex_type_name(receiverType.name)
    then regex_method_type(call.name)
    else if stdlib_date_time_method_name(call.name) & stdlib_date_time_method(receiverType.name, call.name)
    then stdlib_date_time_method_type_with_receiver(call, receiverType, env, module, allModules)
    else if string_java_method(call.name) & receiverType.name == "String"
    then string_java_method_type(call.name)
    else if call.name == "to_int"
    then int_type()
    else if call.name == "to_long"
    then long_type()
    else if object_type_method_call(call, module, allModules)
    then object_type_method_call_type(call, module, allModules)
    else match find_object_method_with_receiver_type(call, receiverType, module, allModules) with
        case Some { binding } -> effect_type(binding.method.returnType)
        case None ->
            match find_extension_method_in_scope(receiverType.name, call.name, module, allModules) with
            case Some { function } -> bound_extension_method_return_type(function, receiverType)
            case None -> assert_type()

/// Computes the compiled type for result map method.
private fun result_map_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_map_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun result_map_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_pipe_result_type(
        result_map_method_binary(call),
        receiverType,
        env,
        module,
        allModules
    )

/// Computes the compiled type for result reduce method.
private fun result_reduce_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_reduce_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun result_reduce_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = first_type_argument(receiverType)
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda -> expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    case _ -> object_type()

/// Computes the compiled type for result or else method.
private fun result_or_else_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_or_else_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun result_or_else_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = first_type_argument(receiverType)
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if result_value_type_needs_context(valueType) then argumentType else valueType

/// Computes the compiled type for result or method.
private fun result_or_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_or_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun result_or_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = first_type_argument(receiverType)
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if result_value_type_needs_context(valueType) & result_type_name(argumentType.name) then argumentType else receiverType

/// Checks whether a type reference matches the result value type needs context rule.
private fun result_value_type_needs_context(type: CompiledTypeReference): bool =
    type.name == "any" | type.name.is_empty() | type_parameter(type)

/// Computes the compiled type for regex method.
private fun regex_method_type(name: String): CompiledTypeReference =
    if name == "matches"
    then bool_type()
    else if name == "find"
    then option_type(regex_match_type())
    else if name == "find_all"
    then seq_type(regex_match_type())
    else if name == "replace"
    then string_to_string_function_type()
    else list_type(string_type())

/// Computes the compiled type for string parse result.
private fun string_parse_result_type(name: String): CompiledTypeReference =
    if name == "to_int"
    then result_type(int_type())
    else if name == "to_long"
    then result_type(long_type())
    else if name == "to_double"
    then result_type(double_type())
    else if name == "to_float"
    then result_type(float_type())
    else result_type(bool_type())

/// Checks whether method metadata matches the string Java method call rule.
private fun string_java_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if string_java_method(call.name)
    then expression_type(call.receiver, env, module, allModules).name == "String"
    else false

/// Checks whether method metadata matches the string Java method rule.
private fun string_java_method(name: String): bool =
    name == "trim" | name == "replace" | name == "contains" | name == "starts_with" | name == "end_with"

/// Computes the compiled type for string Java method.
private fun string_java_method_type(name: String): CompiledTypeReference =
    if name == "trim" | name == "replace"
    then string_type()
    else bool_type()

/// Computes the compiled type for native standard-library method.
private fun native_stdlib_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    native_stdlib_method_type_with_receiver(call, expression_type(call.receiver, env, module, allModules))

private fun native_stdlib_method_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference): CompiledTypeReference =
    if receiverType.name == "String"
    then if one_method_argument(call.arguments) then option_type(string_type()) else string_type()
    else if receiverType.name == "List"
    then if one_method_argument(call.arguments) then option_type(first_type_argument(receiverType)) else receiverType
    else if receiverType.name == "Dict"
    then if call.name == "contains_key" then bool_type() else option_type(first_type_argument(receiverType))
    else if receiverType.name == "Tuple"
    then tuple_get_method_type(call, receiverType)
    else object_type()

/// Computes the compiled type for set method call.
private fun set_method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    set_method_call_type_with_receiver(call, expression_type(call.receiver, env, module, allModules), env, module, allModules)

private fun set_method_call_type_with_receiver(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if set_predicate_method(call.name)
    then bool_type()
    else if call.name == "cartesian_product"
    then set_type(tuple_type([first_type_argument(receiverType), first_type_argument(expression_type(argument(call.arguments, 0), env, module, allModules))]))
    else if call.name == "power_set" | call.name == "℘"
    then set_type(receiverType)
    else receiverType

/// Checks whether method metadata matches the set predicate method rule.
private fun set_predicate_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"

/// Computes the compiled type for tuple get method.
private fun tuple_get_method_type(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference): CompiledTypeReference =
    tuple_argument(receiverType.arguments, normalized_tuple_type_index(receiverType.arguments, argument(call.arguments, 0), 0))

/// Infers the expression type for first.
private fun first_expression_type(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expressions[0] with
    case None -> object_type()
    case Some { expression } -> expression_type(expression, env, module, allModules)

/// Computes the compiled type for first dict value.
private fun first_dict_value_type(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match entries[0] with
    case None -> object_type()
    case Some { entry } -> expression_type(entry.value, env, module, allModules)

/// Collects expression types for compiler processing.
private fun expression_types(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[CompiledTypeReference] =
    match expressions[0] with
    case None -> []
    case Some { expression } -> [expression_type(expression, env, module, allModules)] + expression_types(expressions[1:], env, module, allModules)

/// Computes the compiled type for indexed.
private fun indexed_type(indexExpression: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if !built_in_index_expression(indexExpression, receiverType)
    then user_defined_index_type(receiverType, module, allModules)
    else if receiverType.name == "Tuple"
    then
        if indexExpression.hasEndIndex
        then tuple_type(tuple_slice_arguments(
            receiverType.arguments,
            normalized_tuple_type_index(receiverType.arguments, indexExpression.index, 0),
            normalized_tuple_slice_end_index(receiverType.arguments, indexExpression.endIndex)
        ))
        else tuple_argument(receiverType.arguments, normalized_tuple_type_index(receiverType.arguments, indexExpression.index, 0))
    else if receiverType.name == "List"
    then
        if indexExpression.hasEndIndex
        then receiverType
        else option_type(first_type_argument(receiverType))
    else if receiverType.name == "String"
    then if indexExpression.hasEndIndex then string_type() else option_type(string_type())
    else if receiverType.name == "Dict"
    then if indexExpression.hasEndIndex then object_type() else option_type(first_type_argument(receiverType))
    else object_type()

/// Computes the compiled type for user defined index.
private fun user_defined_index_type(receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } -> bound_extension_method_return_type(function, receiverType)
    case None -> object_type()

/// Computes the index used to split or rank normalized tuple slice end index.
private fun normalized_tuple_slice_end_index(arguments: List[CompiledTypeReference], expression: CompiledExpression): int =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_end(literal)
        then arguments.size().value
        else normalized_tuple_type_index(arguments, expression, arguments.size().value)
    case _ -> arguments.size().value

/// Computes the index used to split or rank normalized tuple type index.
private fun normalized_tuple_type_index(arguments: List[CompiledTypeReference], expression: CompiledExpression, fallback: int): int =
    match expression with
    case CompiledIntLiteral literal -> normalize_tuple_index(arguments, literal.value)
    case CompiledUnaryExpression unary ->
        if unary.operator == "-"
        then match unary.expression with
            case CompiledIntLiteral literal -> normalize_tuple_index(arguments, 0 - literal.value)
            case _ -> fallback
        else fallback
    case _ -> fallback

/// Normalizes tuple index into the path or name form expected by later compiler stages.
private fun normalize_tuple_index(arguments: List[CompiledTypeReference], index: int): int =
    if index < 0 then arguments.size().value + index else index

/// Formats tuple slice arguments for generated emission.
private fun tuple_slice_arguments(arguments: List[CompiledTypeReference], start: int, end: int): List[CompiledTypeReference] =
    tuple_slice_arguments_from(arguments, start, end, 0)

/// Collects tuple slice arguments from for compiler processing.
private fun tuple_slice_arguments_from(arguments: List[CompiledTypeReference], start: int, end: int, idx: int): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { argument } ->
        let rest = tuple_slice_arguments_from(arguments[1:], start, end, idx + 1)
        if idx >= start & idx < end
        then [argument] + rest
        else rest

/// Formats one tuple argument for generated emission.
private fun tuple_argument(arguments: List[CompiledTypeReference], index: int): CompiledTypeReference =
    match arguments[index] with
    case None -> object_type()
    case Some { argument } -> argument

/// Creates one name/type binding for lookup.
private fun lookup_binding(name: String, env: List[JavaBinding]): CompiledTypeReference =
    match env[0] with
    case None -> object_type()
    case Some { binding } -> if binding.name == name then binding.typeReference else lookup_binding(name, env[1:])

/// Computes the name for lookup binding Java.
private fun lookup_binding_java_name(name: String, env: List[JavaBinding]): String =
    match env[0] with
    case None -> java_identifier(name)
    case Some { binding } -> if binding.name == name then binding.javaName else lookup_binding_java_name(name, env[1:])

/// Resolves type metadata for lookup function type in scope.
private fun lookup_function_type_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function(name, module.functions) with
    case Some { function } -> effective_function_return_type(function, module, allModules)
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> effective_function_return_type(function, module, allModules)
        case None -> object_type()

/// Computes the compiled type for effective function return.
private fun effective_function_return_type(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if concrete_return_type(function.returnType) | function.returnType.name == "any"
    then function.returnType
    else if expression_references_function(function.body, function.name)
    then function.returnType
    else
        let owner = function_owner_module(function, module, allModules)
        effective_function_return_type_with_constants(
            function,
            owner,
            allModules,
            constant_bindings(constant_functions(owner.functions), owner, allModules)
        )

/// Computes effective return type while reusing constants already collected for the generated module.
private fun effective_function_return_type_with_module_constants(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], constantBindings: List[JavaBinding]): CompiledTypeReference =
    if concrete_return_type(function.returnType) | function.returnType.name == "any"
    then function.returnType
    else if expression_references_function(function.body, function.name)
    then function.returnType
    else
        let owner = function_owner_module(function, module, allModules)
        if same_java_module(owner, module)
        then effective_function_return_type_with_constants(function, owner, allModules, constantBindings)
        else effective_function_return_type_with_constants(
            function,
            owner,
            allModules,
            constant_bindings(constant_functions(owner.functions), owner, allModules)
        )

/// Computes effective return type with precomputed constant bindings for the owning module.
private fun effective_function_return_type_with_constants(function: CompiledFunction, owner: CompiledModule, allModules: List[CompiledModule], constantBindings: List[JavaBinding]): CompiledTypeReference =
    expression_type(function.body, java_function_bindings(function) + constantBindings, owner, allModules)

/// Checks whether two compiled modules identify the same generated Java module.
private fun same_java_module(first: CompiledModule, second: CompiledModule): bool =
    first.name == second.name & first.path == second.path

/// Resolves metadata for function owner module during compiler processing.
private fun function_owner_module(function: CompiledFunction, fallback: CompiledModule, modules: List[CompiledModule]): CompiledModule =
    match modules[0] with
    case None -> fallback
    case Some { module } ->
        if module_contains_function(function, module.functions)
        then module
        else function_owner_module(function, fallback, modules[1:])

/// Checks whether module contains function contains the requested value.
private fun module_contains_function(expected: CompiledFunction, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if same_function(expected, function)
        then true
        else module_contains_function(expected, functions[1:])

/// Checks whether two function values identify the same entity.
private fun same_function(first: CompiledFunction, second: CompiledFunction): bool =
    first.name == second.name
        & first.location.line == second.location.line
        & first.location.column == second.location.column

/// Checks whether an expression has the expression references function shape.
private fun expression_references_function(expression: CompiledExpression, name: String): bool =
    match expression with
    case CompiledUnsupportedExpression _ -> false
    case CompiledIntLiteral _ -> false
    case CompiledLongLiteral _ -> false
    case CompiledFloatLiteral _ -> false
    case CompiledDoubleLiteral _ -> false
    case CompiledBoolLiteral _ -> false
    case CompiledStringLiteral _ -> false
    case CompiledVariableExpression _ -> false
    case CompiledIfExpression ifExpression ->
        if expression_references_function(ifExpression.condition, name)
        then true
        else if expression_references_function(ifExpression.thenBranch, name)
        then true
        else expression_references_function(ifExpression.elseBranch, name)
    case CompiledBinaryExpression binary ->
        if expression_references_function(binary.left, name)
        then true
        else expression_references_function(binary.right, name)
    case CompiledUnaryExpression unary -> expression_references_function(unary.expression, name)
    case CompiledFunctionCallExpression call ->
        if call.name == name
        then true
        else expressions_reference_function(call.arguments, name)
    case CompiledFunctionReferenceExpression reference -> reference.name == name
    case CompiledMethodCallExpression call ->
        if expression_references_function(call.receiver, name)
        then true
        else expressions_reference_function(call.arguments, name)
    case CompiledWithExpression withExpression ->
        if expression_references_function(withExpression.receiver, name)
        then true
        else data_fields_reference_function(withExpression.fields, name)
    case CompiledLambdaExpression lambda -> expression_references_function(lambda.body, name)
    case CompiledListLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledSetLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledDictLiteral literal -> dict_entries_reference_function(literal.entries, name)
    case CompiledTupleLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledIndexExpression index ->
        if expression_references_function(index.receiver, name)
        then true
        else if expression_references_function(index.index, name)
        then true
        else if index.hasEndIndex
        then expression_references_function(index.endIndex, name)
        else false
    case CompiledDataLiteral literal -> data_fields_reference_function(literal.fields, name)
    case CompiledFieldAccessExpression access -> expression_references_function(access.receiver, name)
    case CompiledReduceExpression reduce ->
        if expression_references_function(reduce.receiver, name)
        then true
        else if expression_references_function(reduce.initial, name)
        then true
        else expression_references_function(reduce.body, name)
    case CompiledMatchExpression matchExpression ->
        if expression_references_function(matchExpression.value, name)
        then true
        else match_cases_reference_function(matchExpression.cases, name)
    case CompiledThrowExpression throwExpression -> expression_references_function(throwExpression.value, name)
    case CompiledTryCatchExpression tryCatch ->
        if expression_references_function(tryCatch.body, name)
        then true
        else try_catch_branches_reference_function(tryCatch.branches, name)
    case CompiledBlockExpression block ->
        if let_bindings_reference_function(block.bindings, name)
        then true
        else expression_references_function(block.result, name)

private fun try_catch_branches_reference_function(branches: List[CompiledTryCatchBranch], name: String): bool =
    match branches[0] with
    case None -> false
    case Some { branch } ->
        if expression_references_function(branch.catchBody, name)
        then true
        else try_catch_branches_reference_function(branches[1:], name)

/// Checks whether an expression has the expressions reference function shape.
private fun expressions_reference_function(expressions: List[CompiledExpression], name: String): bool =
    match expressions[0] with
    case None -> false
    case Some { expression } ->
        if expression_references_function(expression, name)
        then true
        else expressions_reference_function(expressions[1:], name)

/// Checks whether a function matches the dict entries reference function metadata.
private fun dict_entries_reference_function(entries: List[CompiledDictEntry], name: String): bool =
    match entries[0] with
    case None -> false
    case Some { entry } ->
        if expression_references_function(entry.key, name)
        then true
        else if expression_references_function(entry.value, name)
        then true
        else dict_entries_reference_function(entries[1:], name)

/// Checks whether a function matches the data fields reference function metadata.
private fun data_fields_reference_function(fields: List[CompiledDataField], name: String): bool =
    match fields[0] with
    case None -> false
    case Some { field } ->
        if expression_references_function(field.value, name)
        then true
        else data_fields_reference_function(fields[1:], name)

/// Checks whether a function matches the match cases reference function metadata.
private fun match_cases_reference_function(cases: List[CompiledMatchCase], name: String): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        if matchCase.hasLiteral
        then if expression_references_function(matchCase.literal, name)
            then true
            else match_case_guard_body_or_rest_references_function(matchCase, cases[1:], name)
        else match_case_guard_body_or_rest_references_function(matchCase, cases[1:], name)

private fun match_case_guard_body_or_rest_references_function(matchCase: CompiledMatchCase, rest: List[CompiledMatchCase], name: String): bool =
    if matchCase.hasGuard
    then if expression_references_function(matchCase.guard, name)
        then true
        else match_case_body_or_rest_references_function(matchCase, rest, name)
    else match_case_body_or_rest_references_function(matchCase, rest, name)

private fun match_case_body_or_rest_references_function(matchCase: CompiledMatchCase, rest: List[CompiledMatchCase], name: String): bool =
    if expression_references_function(matchCase.body, name)
    then true
    else match_cases_reference_function(rest, name)

/// Checks whether a function matches the let bindings reference function metadata.
private fun let_bindings_reference_function(bindings: List[CompiledLetBinding], name: String): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        if expression_references_function(binding.value, name)
        then true
        else let_bindings_reference_function(bindings[1:], name)

/// Finds a function in scope in available declarations, imports, or modules.
private fun find_function_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_function(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports(name, module.imports, module, allModules)

/// Computes constant metadata for exists in scope.
private fun constant_exists_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_constant_in_scope(name, module, allModules) with
    case Some _ -> true
    case None -> false

/// Finds a constant in scope in available declarations, imports, or modules.
private fun find_constant_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_constant(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_constant_in_imports(name, module.imports, module, allModules)

/// Finds a constant in available declarations, imports, or modules.
private fun find_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name & compiled_constant(function) & !compiled_schema(function)
        then /capy/lang/Option.Some { function }
        else find_constant(name, functions[1:])

/// Finds a constant in imports in available declarations, imports, or modules.
private fun find_constant_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if constant_import_matches(name, declaration)
        then find_constant_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_constant_in_imports(name, imports[1:], module, allModules)

/// Finds a constant in import in available declarations, imports, or modules.
private fun find_constant_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_constant_in_imported_module(name, rest, module, allModules, importedModule)
    case None -> find_constant_in_imports(name, rest, module, allModules)

/// Finds a constant in imported module in available declarations, imports, or modules.
private fun find_constant_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_constant(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_constant_in_imports(name, rest, module, allModules)

/// Computes constant metadata for import matches.
private fun constant_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else import_includes_name(name, declaration)

/// Finds a function for arguments in available declarations, imports, or modules.
private fun find_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let argumentTypes = expression_types(arguments, env, module, allModules)
    match find_function_for_argument_types_in_functions(name, arguments, argumentTypes, env, module.functions, module, allModules) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports_for_argument_types(name, arguments, argumentTypes, env, module.imports, module, allModules)

/// Finds a function for arguments in functions in available declarations, imports, or modules.
private fun find_function_for_arguments_in_functions(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    find_function_for_argument_types_in_functions(name, arguments, expression_types(arguments, env, module, allModules), env, functions, module, allModules)

/// Finds a function for precomputed argument types in functions in available declarations, imports, or modules.
private fun find_function_for_argument_types_in_functions(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    best_function_for_argument_types(name, arguments, argumentTypes, env, functions, module, allModules, /capy/lang/Option.None {}, 1000000)

/// Formats best function for arguments for generated emission.
private fun best_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int): /capy/lang/Option[CompiledFunction] =
    best_function_for_argument_types(name, arguments, expression_types(arguments, env, module, allModules), env, functions, module, allModules, best, bestScore)

/// Formats best function for precomputed argument types for generated emission.
private fun best_function_for_argument_types(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int): /capy/lang/Option[CompiledFunction] =
    best_function_for_argument_request_types(java_function_name_request(name), arguments, argumentTypes, env, functions, module, allModules, best, bestScore)

/// Formats best function for precomputed argument types with precomputed name request metadata.
private fun best_function_for_argument_request_types(request: JavaFunctionNameRequest, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> best
    case Some { function } ->
        if function_name_request_matches(request, function.name)
        then best_matching_function_for_argument_request_types(request, arguments, argumentTypes, env, functions, module, allModules, best, bestScore, function)
        else best_function_for_argument_request_types(request, arguments, argumentTypes, env, functions[1:], module, allModules, best, bestScore)

/// Formats best matching function for arguments for generated emission.
private fun best_matching_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int, function: CompiledFunction): /capy/lang/Option[CompiledFunction] =
    best_matching_function_for_argument_types(name, arguments, expression_types(arguments, env, module, allModules), env, functions, module, allModules, best, bestScore, function)

/// Formats best matching function for precomputed argument types for generated emission.
private fun best_matching_function_for_argument_types(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int, function: CompiledFunction): /capy/lang/Option[CompiledFunction] =
    best_matching_function_for_argument_request_types(java_function_name_request(name), arguments, argumentTypes, env, functions, module, allModules, best, bestScore, function)

/// Formats best matching function for precomputed argument types with precomputed name request metadata.
private fun best_matching_function_for_argument_request_types(request: JavaFunctionNameRequest, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int, function: CompiledFunction): /capy/lang/Option[CompiledFunction] =
    if compiled_constant(function)
    then best_function_for_argument_request_types(request, arguments, argumentTypes, env, functions[1:], module, allModules, best, bestScore)
    else if parameters_assignable_with_types(function.parameters, arguments, argumentTypes, env, module, allModules)
    then
        let score = function_argument_score_with_types(function.parameters, arguments, argumentTypes, env, module, allModules)
        if score < bestScore
        then best_function_for_argument_request_types(request, arguments, argumentTypes, env, functions[1:], module, allModules, /capy/lang/Option.Some { function }, score)
        else best_function_for_argument_request_types(request, arguments, argumentTypes, env, functions[1:], module, allModules, best, bestScore)
    else best_function_for_argument_request_types(request, arguments, argumentTypes, env, functions[1:], module, allModules, best, bestScore)

/// Finds a function in imports for arguments in available declarations, imports, or modules.
private fun find_function_in_imports_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    find_function_in_imports_for_argument_types(name, arguments, expression_types(arguments, env, module, allModules), env, imports, module, allModules)

/// Finds a function in imports for precomputed argument types in available declarations, imports, or modules.
private fun find_function_in_imports_for_argument_types(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then find_function_in_import_for_argument_types(name, arguments, argumentTypes, env, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_function_in_imports_for_argument_types(name, arguments, argumentTypes, env, imports[1:], module, allModules)

/// Finds a function in import for arguments in available declarations, imports, or modules.
private fun find_function_in_import_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    find_function_in_import_for_argument_types(name, arguments, expression_types(arguments, env, module, allModules), env, rest, module, allModules, className)

/// Finds a function in import for precomputed argument types in available declarations, imports, or modules.
private fun find_function_in_import_for_argument_types(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function_in_imported_module_for_argument_types(name, arguments, argumentTypes, env, rest, module, allModules, importedModule)
    case None -> find_function_in_imports_for_argument_types(name, arguments, argumentTypes, env, rest, module, allModules)

/// Finds a function in imported module for arguments in available declarations, imports, or modules.
private fun find_function_in_imported_module_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    find_function_in_imported_module_for_argument_types(name, arguments, expression_types(arguments, env, module, allModules), env, rest, module, allModules, importedModule)

/// Finds a function in imported module for precomputed argument types in available declarations, imports, or modules.
private fun find_function_in_imported_module_for_argument_types(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function_for_argument_types_in_functions(name, arguments, argumentTypes, env, importedModule.functions, module, allModules) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports_for_argument_types(name, arguments, argumentTypes, env, rest, module, allModules)

/// Computes the match score for function argument score.
private fun function_argument_score(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    function_argument_score_with_types(parameters, arguments, expression_types(arguments, env, module, allModules), env, module, allModules)

/// Computes the match score for function argument score with precomputed argument types.
private fun function_argument_score_with_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    match parameters[0] with
    case None -> 0
    case Some { parameter } ->
        match arguments[0] with
        case None -> 1000000
        case Some { argument } ->
            match argumentTypes[0] with
            case None -> 1000000
            case Some { argumentType } ->
                parameter_argument_score_with_type(parameter.typeReference, argument, argumentType, env, module, allModules)
                    + function_argument_score_with_types(parameters[1:], arguments[1:], argumentTypes[1:], env, module, allModules)

/// Computes the match score for parameter argument score.
private fun parameter_argument_score(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    parameter_argument_score_with_type(target, argument, expression_type(argument, env, module, allModules), env, module, allModules)

/// Computes the match score for parameter argument score with a precomputed argument type.
private fun parameter_argument_score_with_type(target: CompiledTypeReference, argument: CompiledExpression, argumentType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    if empty_collection_literal_assignable(target, argument) | function_reference_assignable(target, argument, module, allModules) | function_lambda_assignable(target, argument, env, module, allModules)
    then 0
    else type_match_score(target, argumentType, module, allModules)

/// Computes the match score for type match score.
private fun type_match_score(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): int =
    if target.name == source.name & type_arguments_assignable(target.arguments, source.arguments)
    then 0
    else if target.name == "any"
    then 1000
    else if primitive_numeric_widening_assignable(target, source)
    then 10
    else if runtime_supertype_assignable(target, source, module, allModules)
    then 100
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then data_type_match_score(target.name, source.name, module, allModules)
    else if type_assignable(target, source)
    then 100
    else primitive_backed_type_match_score(target, source, module, allModules)

/// Computes the match score for primitive backed type match score.
private fun primitive_backed_type_match_score(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): int =
    match primitive_backed_backing_type(source.name, module, allModules) with
    case Some { backingType } -> if type_assignable(target, backingType) then 100 else 1000000
    case None -> 1000000

/// Computes the match score for data type match score.
private fun data_type_match_score(targetName: String, sourceName: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    let distance = data_type_distance(targetName, sourceName, module, allModules)
    if distance >= 0 then distance else 500

/// Finds a function in available declarations, imports, or modules.
private fun find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    find_function_by_request(java_function_name_request(name), functions)

/// Finds a function using precomputed name request metadata.
private fun find_function_by_request(request: JavaFunctionNameRequest, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function_name_request_matches(request, function.name) & !compiled_constant(function)
        then /capy/lang/Option.Some { function }
        else find_function_by_request(request, functions[1:])

/// Finds a function in imports in available declarations, imports, or modules.
private fun find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then find_function_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_function_in_imports(name, imports[1:], module, allModules)

/// Checks whether function import matches the requested declaration, type, or name.
private fun function_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else import_includes_name(name, declaration)

/// Finds an extension method in available declarations, imports, or modules.
private fun find_extension_method(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    find_extension_method_in_scope(receiverType.name, call.name, module, allModules)

/// Finds a binary extension operator in available declarations, imports, or modules.
private fun find_binary_extension_operator(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = expression_type(binary.left, env, module, allModules)
    find_binary_extension_operator_with_left_type(binary, receiverType, module, allModules)

/// Finds a binary extension operator with left type in available declarations, imports, or modules.
private fun find_binary_extension_operator_with_left_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    find_extension_method_in_scope(receiverType.name, binary.operator, module, allModules)

/// Finds an extension method in scope in available declarations, imports, or modules.
private fun find_extension_method_in_scope(ownerName: String, methodName: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_extension_method_in_imports(ownerName, methodName, module.imports, module, allModules)

/// Finds a method function in available declarations, imports, or modules.
private fun find_method_function(ownerName: String, methodName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    let normalizedMethodName = method_member_name_normalized(methodName)
    find_method_function_with_suffixes(method_owner_base_name(ownerName), methodName, "." + normalizedMethodName, ".`" + normalizedMethodName + "`", functions)

private fun find_method_function_with_suffixes(ownerBaseName: String, methodName: String, directSuffix: String, quotedSuffix: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if method_member_candidate(directSuffix, quotedSuffix, function.name)
            & method_function_matches(ownerBaseName, methodName, function)
        then /capy/lang/Option.Some { function }
        else find_method_function_with_suffixes(ownerBaseName, methodName, directSuffix, quotedSuffix, functions[1:])

private fun method_member_candidate(directSuffix: String, quotedSuffix: String, functionName: String): bool =
    if java_generator_string_has_suffix(functionName, directSuffix)
    then true
    else java_generator_string_has_suffix(functionName, quotedSuffix)

/// Checks whether method function matches the requested declaration, type, or name.
private fun method_function_matches(ownerBaseName: String, methodName: String, function: CompiledFunction): bool =
    if compiled_constant(function)
    then false
    else if function.name ? "__local__"
    then false
    else
        let idx = last_dot_index(function.name)
        if idx < 0
        then false
        else method_owner_base_name(function.name[0, idx]) == ownerBaseName
            & method_member_matches(function.name[idx + 1, function.name.size().value], methodName)

/// Checks whether method owner matches the requested declaration, type, or name.
private fun method_owner_matches(declaredOwner: String, actualOwner: String): bool =
    method_owner_base_name(declaredOwner) == method_owner_base_name(actualOwner)

/// Computes the name for method owner base.
private fun method_owner_base_name(name: String): String =
    let bracket = first_index_of(name, "[", 0)
    if bracket < 0 then name else name[0, bracket]

/// Checks whether method member matches the requested declaration, type, or name.
private fun method_member_matches(declaredMember: String, actualMember: String): bool =
    method_member_name_normalized(declaredMember) == method_member_name_normalized(actualMember)

/// Computes the name for method member name normalized.
private fun method_member_name_normalized(name: String): String =
    if name.size().value >= 2 & java_generator_string_has_prefix(name, "`")
    then name[1, name.size().value - 1]
    else name

/// Finds an extension method in imports in available declarations, imports, or modules.
private fun find_extension_method_in_imports(ownerName: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.wildcard
            & !stdlib_import(declaration.modulePath)
            & !declaration.qualified
            & !string_list_contains(declaration.excludedNames, methodName)
        then find_extension_method_in_import(ownerName, methodName, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_extension_method_in_imports(ownerName, methodName, imports[1:], module, allModules)

/// Finds an extension method in import in available declarations, imports, or modules.
private fun find_extension_method_in_import(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_extension_method_in_imported_module(ownerName, methodName, rest, module, allModules, importedModule)
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

/// Finds an extension method in imported module in available declarations, imports, or modules.
private fun find_extension_method_in_imported_module(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

/// Finds a function in import in available declarations, imports, or modules.
private fun find_function_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function_in_imported_module(name, rest, module, allModules, importedModule)
    case _ -> find_function_in_imports(name, rest, module, allModules)

/// Finds a function in imported module in available declarations, imports, or modules.
private fun find_function_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_function_in_imports(name, rest, module, allModules)

/// Finds a module by class in available declarations, imports, or modules.
private fun find_module_by_class(className: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if module_matches_class(module, className)
        then /capy/lang/Option.Some { module }
        else find_module_by_class(className, modules[1:])

/// Checks whether a compiled module matches a generated class name without building the full class name.
private fun module_matches_class(module: CompiledModule, className: String): bool =
    let nameSize = module.name.size().value
    if className.size().value < nameSize
    then false
    else if className[className.size().value - nameSize, className.size().value] != module.name
    then false
    else if module.path.is_empty()
    then module.name == className
    else
        let pathSize = module.path.size().value
        if className.size().value != pathSize + 1 + nameSize
        then false
        else if !java_generator_module_path_matches_class_prefix(module.path, className, 0)
        then false
        else className[pathSize, pathSize + 1] == "."

/// Checks whether a slash-separated module path matches a dot-separated generated class prefix.
private fun java_generator_module_path_matches_class_prefix(path: String, className: String, idx: int): bool =
    if idx >= path.size().value
    then true
    else match path[idx] with
        case None -> true
        case Some { char } ->
            match className[idx] with
            case None -> false
            case Some { actual } ->
                let expected = if char == "/" then "." else char
                if actual == expected
                then java_generator_module_path_matches_class_prefix(path, className, idx + 1)
                else false

/// Finds a data type in available declarations, imports, or modules.
private fun find_data_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if qualified_call_name(name)
    then find_qualified_data_type(name, module, allModules)
    else if schema_type_exists(name, module.functions)
    then /capy/lang/Option.Some { name }
    else if stdlib_reflection_type(name)
    then /capy/lang/Option.Some { name }
    else match find_data_type_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> /capy/lang/Option.Some { value }
        case None -> find_data_type_in_modules(name, allModules)

/// Finds a qualified data type in available declarations, imports, or modules.
private fun find_qualified_data_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match find_qualified_data_type_binding(name, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding.name }
    case None -> /capy/lang/Option.None {}

/// Finds a qualified data type binding in available declarations, imports, or modules.
private fun find_qualified_data_type_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaDataTypeBinding] =
    find_qualified_data_type_binding_in_class(
        qualified_call_class_name(name, module),
        qualified_call_member(name),
        allModules
    )

/// Finds a qualified data type binding in class in available declarations, imports, or modules.
private fun find_qualified_data_type_binding_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[JavaDataTypeBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(member, importedModule.functions)
        then /capy/lang/Option.Some { JavaDataTypeBinding { module: importedModule, name: member } }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

/// Finds a data type in imports in available declarations, imports, or modules.
private fun find_data_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then find_data_type_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_data_type_in_imports(name, imports[1:], module, allModules)

/// Finds a data type in import in available declarations, imports, or modules.
private fun find_data_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_imports(name, rest, module, allModules)
    case _ -> find_data_type_in_imports(name, rest, module, allModules)

/// Finds a data type in a modules in available declarations, imports, or modules.
private fun find_data_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_modules(name, modules[1:])

/// Checks whether schema type exists in the relevant declarations or imports.
private fun schema_type_exists(name: String, functions: List[CompiledFunction]): bool =
    schema_type_exists_named("__capy_schema_type|" + name, functions)

/// Checks whether schema type exists using a precomputed schema key.
private fun schema_type_exists_named(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if schema_function(function, name)
        then true
        else schema_type_exists_named(name, functions[1:])

/// Collects schema values while also checking whether the owning data type exists.
private fun schema_values_for_type(name: String, valuePrefix: String, functions: List[CompiledFunction]): JavaSchemaValues =
    schema_values_for_type_named("__capy_schema_type|" + name, valuePrefix + name + "|", functions)

private fun schema_values_for_type_named(typeSchemaName: String, valuePrefix: String, functions: List[CompiledFunction]): JavaSchemaValues =
    match functions[0] with
    case None -> JavaSchemaValues { typeExists: false, values: [] }
    case Some { function } ->
        let rest = schema_values_for_type_named(typeSchemaName, valuePrefix, functions[1:])
        if compiled_schema(function)
        then JavaSchemaValues {
            typeExists: if rest.typeExists then true else function.name == typeSchemaName,
            values: if java_generator_string_has_prefix(function.name, valuePrefix) then [schema_value(function)] + rest.values else rest.values
        }
        else rest

/// Checks whether a function matches the schema function metadata.
private fun schema_function(function: CompiledFunction, name: String): bool =
    if function.name == name
    then compiled_schema(function)
    else false

/// Computes value metadata for schema values.
private fun schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_schema(function)
        then if java_generator_string_has_prefix(function.name, prefix)
            then [schema_value(function)] + schema_values(prefix, functions[1:])
            else schema_values(prefix, functions[1:])
        else schema_values(prefix, functions[1:])

/// Checks whether any schema helper has the requested key prefix without materializing values.
private fun schema_value_with_prefix_exists(prefix: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if compiled_schema(function)
        then if java_generator_string_has_prefix(function.name, prefix)
            then true
            else schema_value_with_prefix_exists(prefix, functions[1:])
        else schema_value_with_prefix_exists(prefix, functions[1:])

/// Computes value metadata for schema values while excluding a more specific prefix.
private fun schema_values_excluding_prefix(prefix: String, excludedPrefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_schema(function)
            & java_generator_string_has_prefix(function.name, prefix)
            & !java_generator_string_has_prefix(function.name, excludedPrefix)
        then [schema_value(function)] + schema_values_excluding_prefix(prefix, excludedPrefix, functions[1:])
        else schema_values_excluding_prefix(prefix, excludedPrefix, functions[1:])

/// Computes value metadata for schema value.
private fun schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

/// Looks up optional metadata for schema value named.
private fun schema_value_named(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if schema_function(function, name)
        then /capy/lang/Option.Some { schema_value(function) }
        else schema_value_named(name, functions[1:])

/// Checks whether enum type exists in the relevant declarations or imports.
private fun enum_type_exists(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if enum_type_exists_in_functions(name, module.functions)
    then true
    else match enum_type_imported_class(name, module.imports, module, allModules) with
        case Some _ -> true
        case None -> false

/// Checks whether enum value exists in the relevant declarations or imports.
private fun enum_value_exists(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    string_list_contains(enum_values(typeName, module, allModules), valueName)

/// Computes value metadata for enum values.
private fun enum_values(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localValues = enum_values_in_functions(name, module.functions)
    if !localValues.is_empty()
    then localValues
    else match enum_values_in_imports(name, module.imports, module, allModules) with
        case Some { values } -> values
        case None -> []

/// Checks whether enum type exists in functions exists in the relevant declarations or imports.
private fun enum_type_exists_in_functions(name: String, functions: List[CompiledFunction]): bool =
    schema_value_with_prefix_exists("__capy_schema_enum|" + name + "|", functions)

/// Collects enum metadata for enum values in functions.
private fun enum_values_in_functions(name: String, functions: List[CompiledFunction]): List[String] =
    schema_values("__capy_schema_enum|" + name + "|", functions)

/// Emits import statements for enum values in.
private fun enum_values_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then enum_values_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else enum_values_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for enum values in.
private fun enum_values_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        let values = enum_values_in_functions(name, importedModule.functions)
        if !values.is_empty()
        then /capy/lang/Option.Some { values }
        else enum_values_in_imports(name, rest, module, allModules)
    case _ -> enum_values_in_imports(name, rest, module, allModules)

/// Checks whether the current value satisfies the qualified enum value name rule for compiler processing.
private fun qualified_enum_value_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    qualified_call_name(name)
        & enum_value_exists(enum_qualified_type_name(name), enum_qualified_member_name(name), module, allModules)

/// Computes the type name for enum qualified.
private fun enum_qualified_type_name(name: String): String =
    name[0, last_dot_index(name)]

/// Computes the name for enum qualified member.
private fun enum_qualified_member_name(name: String): String =
    name[last_dot_index(name) + 1, name.size().value]

/// Emits generated code for enum qualified value.
private fun enum_qualified_value_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    enum_value_reference_code(enum_qualified_type_name(name), enum_qualified_member_name(name), module, allModules)

/// Emits generated code for enum value references.
private fun enum_value_references_code(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        enum_value_reference_code(typeName, value, module, allModules)
            + enum_value_reference_tail(typeName, values[1:], module, allModules)

/// Formats the recursive tail segment for enum value reference.
private fun enum_value_reference_tail(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + enum_value_references_code(typeName, values, module, allModules)

/// Emits generated code for enum value reference.
private fun enum_value_reference_code(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if enum_type_exists_in_functions(typeName, module.functions)
    then java_identifier(valueName)
    else match enum_type_imported_class(typeName, module.imports, module, allModules) with
        case Some { className } -> className + "." + java_identifier(valueName)
        case None -> java_identifier(valueName)

/// Resolves type metadata for enum type imported class.
private fun enum_type_imported_class(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then enum_type_imported_class_from(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else enum_type_imported_class(name, imports[1:], module, allModules)

/// Resolves type metadata for enum type imported class from.
private fun enum_type_imported_class_from(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if enum_type_exists_in_functions(name, importedModule.functions)
        then /capy/lang/Option.Some { className }
        else enum_type_imported_class(name, rest, module, allModules)
    case _ -> enum_type_imported_class(name, rest, module, allModules)

/// Computes the name for schema field.
private fun schema_field_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

/// Computes the type name for schema field.
private fun schema_field_type_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then "any"
    else value[separator + 1, value.size().value]

/// Resolves type metadata for schema type reference.
private fun schema_type_reference(value: String): CompiledTypeReference =
    let trimmed = value.trim()
    let bracket = first_index_of(trimmed, "[", 0)
    if bracket < 0
    then CompiledTypeReference { name: trimmed, arguments: [] }
    else CompiledTypeReference {
        name: trimmed[0, bracket],
        arguments: schema_type_arguments(trimmed[bracket + 1, trimmed.size().value - 1])
    }

/// Formats schema type arguments for generated emission.
private fun schema_type_arguments(value: String): List[CompiledTypeReference] =
    if value.trim().is_empty()
    then []
    else schema_type_arguments_from(value, 0, 0, 0)

/// Collects schema metadata entries for schema type arguments from.
private fun schema_type_arguments_from(value: String, idx: int, depth: int, start: int): List[CompiledTypeReference] =
    if idx >= value.size().value
    then [schema_type_reference(value[start, value.size().value])]
    else match value[idx] with
    case None -> [schema_type_reference(value[start, value.size().value])]
    case Some { char } ->
        if char == "," & depth == 0
        then [schema_type_reference(value[start, idx])] + schema_type_arguments_from(value, idx + 1, depth, idx + 1)
        else schema_type_arguments_from(value, idx + 1, schema_type_argument_depth(depth, char), start)

/// Computes a numeric value for schema type argument depth.
private fun schema_type_argument_depth(depth: int, char: String): int =
    if char == "["
    then depth + 1
    else if char == "]"
    then depth - 1
    else depth

/// Computes the index used to split or rank first index of.
private fun first_index_of(value: String, needle: String, idx: int): int =
    if idx >= value.size().value
    then -1
    else match value[idx] with
        case None -> -1
        case Some { char } -> if char == needle then idx else first_index_of(value, needle, idx + 1)

/// Creates name/type bindings for data type.
private fun data_type_bindings(dataType: /capy/lang/Option[String], concreteType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match dataType with
    case Some { value } -> type_parameter_bindings(data_type_parameters(value, module, allModules), concreteType.arguments)
    case None -> []

/// Formats data type parameters for generated emission.
private fun data_type_parameters(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localParameters = schema_values_for_type(name, "__capy_schema_param|", module.functions)
    if localParameters.typeExists
    then localParameters.values
    else match data_type_parameters_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_parameters_in_modules(name, allModules)

/// Emits import statements for data type parameters in.
private fun data_type_parameters_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_parameters_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_parameters_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for data type parameters in.
private fun data_type_parameters_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        let importedParameters = schema_values_for_type(name, "__capy_schema_param|", importedModule.functions)
        if importedParameters.typeExists
        then /capy/lang/Option.Some { importedParameters.values }
        else data_type_parameters_in_imports(name, rest, module, allModules)
    case _ -> data_type_parameters_in_imports(name, rest, module, allModules)

/// Creates generated-module entries for data type parameters in a.
private fun data_type_parameters_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        let moduleParameters = schema_values_for_type(name, "__capy_schema_param|", module.functions)
        if moduleParameters.typeExists
        then moduleParameters.values
        else data_type_parameters_in_modules(name, modules[1:])

/// Computes the compiled type for primitive backed backing.
private fun primitive_backed_backing_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    if qualified_call_name(name)
    then primitive_backed_backing_type_in_class(qualified_call_class_name(name, module), qualified_call_member(name), allModules)
    else match primitive_backed_backing_type_in_functions(name, module.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> match primitive_backed_backing_type_in_imports(name, module.imports, module, allModules) with
            case Some { backingType } -> /capy/lang/Option.Some { backingType }
            case None -> primitive_backed_backing_type_in_modules(name, allModules)

/// Resolves type metadata for primitive backed backing type in functions.
private fun primitive_backed_backing_type_in_functions(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledTypeReference] =
    match schema_value_named("__capy_schema_primitive|" + name, functions) with
    case Some { value } -> /capy/lang/Option.Some { schema_type_reference(value) }
    case None -> /capy/lang/Option.None {}

/// Resolves type metadata for primitive backed backing type in class.
private fun primitive_backed_backing_type_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> primitive_backed_backing_type_in_functions(member, importedModule.functions)
    case None -> /capy/lang/Option.None {}

/// Emits import statements for primitive backed backing type in.
private fun primitive_backed_backing_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then primitive_backed_backing_type_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else primitive_backed_backing_type_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for primitive backed backing type in.
private fun primitive_backed_backing_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledTypeReference] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> primitive_backed_backing_type_in_imported_module(name, rest, module, allModules, importedModule)
    case _ -> primitive_backed_backing_type_in_imports(name, rest, module, allModules)

/// Resolves type metadata for primitive backed backing type in imported module.
private fun primitive_backed_backing_type_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledTypeReference] =
    match primitive_backed_backing_type_in_functions(name, importedModule.functions) with
    case Some { backingType } -> /capy/lang/Option.Some { backingType }
    case None -> primitive_backed_backing_type_in_imports(name, rest, module, allModules)

/// Creates generated-module entries for primitive backed backing type in a.
private fun primitive_backed_backing_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match primitive_backed_backing_type_in_functions(name, module.functions) with
            case Some { backingType } -> /capy/lang/Option.Some { backingType }
            case None -> primitive_backed_backing_type_in_modules(name, modules[1:])

/// Collects data type parent types for compiler processing.
private fun data_type_parent_types(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localParents = schema_values_for_type(name, "__capy_schema_parent|", module.functions)
    if localParents.typeExists
    then localParents.values
    else if stdlib_reflection_type(name)
    then stdlib_reflection_type_parents(name)
    else match data_type_parent_types_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_parent_types_in_modules(name, allModules)

/// Emits import statements for data type parent types in.
private fun data_type_parent_types_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_parent_types_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_parent_types_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for data type parent types in.
private fun data_type_parent_types_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        let importedParents = schema_values_for_type(name, "__capy_schema_parent|", importedModule.functions)
        if importedParents.typeExists
        then /capy/lang/Option.Some { importedParents.values }
        else data_type_parent_types_in_imports(name, rest, module, allModules)
    case _ -> data_type_parent_types_in_imports(name, rest, module, allModules)

/// Creates generated-module entries for data type parent types in a.
private fun data_type_parent_types_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        let moduleParents = schema_values_for_type(name, "__capy_schema_parent|", module.functions)
        if moduleParents.typeExists
        then moduleParents.values
        else data_type_parent_types_in_modules(name, modules[1:])

/// Computes a numeric value for data type distance.
private fun data_type_distance(targetName: String, sourceName: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    if targetName == sourceName
    then 0
    else data_type_parent_distance(targetName, data_type_parent_types(sourceName, module, allModules), 1, -1, module, allModules)

/// Computes a numeric value for data type parent distance.
private fun data_type_parent_distance(targetName: String, parents: List[String], distance: int, best: int, module: CompiledModule, allModules: List[CompiledModule]): int =
    match parents[0] with
    case None -> best
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        let direct = if parentName == targetName then distance else data_type_parent_distance(targetName, data_type_parent_types(parentName, module, allModules), distance + 1, -1, module, allModules)
        let nextBest = if direct >= 0 & (best < 0 | direct < best) then direct else best
        data_type_parent_distance(targetName, parents[1:], distance, nextBest, module, allModules)

/// Collects data type fields for compiler processing.
private fun data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    merge_schema_fields(
        data_type_direct_fields(name, module, allModules),
        data_type_parent_fields(data_type_parent_types(name, module, allModules), module, allModules)
    )

/// Collects reflection metadata entries for reflection data type fields.
private fun reflection_data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    merge_schema_fields(
        reflection_data_type_parent_fields(data_type_parent_types(name, module, allModules), module, allModules),
        data_type_direct_fields(name, module, allModules)
    )

/// Collects data type direct fields for compiler processing.
private fun data_type_direct_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localFields = schema_values_for_type(name, "__capy_schema_field|", module.functions)
    if localFields.typeExists
    then localFields.values
    else if stdlib_reflection_type(name)
    then stdlib_reflection_type_fields(name)
    else match data_type_fields_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_fields_in_modules(name, allModules)

/// Checks whether a type reference matches the standard-library reflection type rule.
private fun stdlib_reflection_type(name: String): bool =
    name == "PackageInfo"
        | name == "AnyInfo"
        | name == "CFunInfo"
        | name == "CooInfo"
        | name == "AnnotationValue"
        | name == "AnnotationInfo"
        | name == "AnnotationArgumentInfo"
        | name == "DataValueInfo"
        | name == "FieldValueInfo"
        | name == "DataInfo"
        | name == "FunctionTypeInfo"
        | name == "FieldInfo"
        | name == "ListInfo"
        | name == "SetInfo"
        | name == "DictInfo"
        | name == "TupleInfo"
        | name == "InterfaceInfo"
        | name == "ObjectInfo"
        | name == "TraitInfo"
        | name == "MethodInfo"
        | name == "AnnotationString"
        | name == "AnnotationInt"
        | name == "AnnotationLong"
        | name == "AnnotationDouble"
        | name == "AnnotationFloat"
        | name == "AnnotationBool"
        | name == "AnnotationTypeName"
        | name == "AnnotationNothing"

/// Collects reflection metadata entries for standard-library reflection type parents.
private fun stdlib_reflection_type_parents(name: String): List[String] =
    if name == "CFunInfo" | name == "CooInfo"
    then ["AnyInfo"]
    else if name == "DataInfo" | name == "ListInfo" | name == "SetInfo" | name == "DictInfo" | name == "TupleInfo" | name == "FunctionTypeInfo"
    then ["CFunInfo"]
    else if name == "InterfaceInfo" | name == "ObjectInfo" | name == "TraitInfo" | name == "MethodInfo"
    then ["CooInfo"]
    else if name == "AnnotationString" | name == "AnnotationInt" | name == "AnnotationLong" | name == "AnnotationDouble" | name == "AnnotationFloat" | name == "AnnotationBool" | name == "AnnotationTypeName" | name == "AnnotationNothing"
    then ["AnnotationValue"]
    else []

/// Collects reflection metadata entries for standard-library reflection type fields.
private fun stdlib_reflection_type_fields(name: String): List[String] =
    if name == "PackageInfo"
    then ["name|String", "path|String"]
    else if name == "AnyInfo"
    then ["name|String", "pkg|PackageInfo"]
    else if name == "AnnotationInfo"
    then ["name|String", "pkg|PackageInfo", "arguments|List[AnnotationArgumentInfo]"]
    else if name == "AnnotationArgumentInfo"
    then ["name|String", "value|AnnotationValue"]
    else if name == "DataValueInfo"
    then ["name|String", "pkg|PackageInfo", "fields|List[FieldValueInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "FieldValueInfo"
    then ["name|String", "type|AnyInfo", "value|any", "annotations|List[AnnotationInfo]"]
    else if name == "DataInfo"
    then ["name|String", "pkg|PackageInfo", "annotations|List[AnnotationInfo]"]
    else if name == "FunctionTypeInfo"
    then ["name|String", "pkg|PackageInfo", "params|List[AnyInfo]", "return_type|AnyInfo"]
    else if name == "FieldInfo"
    then ["name|String", "type|AnyInfo", "annotations|List[AnnotationInfo]"]
    else if name == "ListInfo" | name == "SetInfo"
    then ["name|String", "pkg|PackageInfo", "element_type|AnyInfo"]
    else if name == "DictInfo"
    then ["name|String", "pkg|PackageInfo", "value_type|AnyInfo"]
    else if name == "TupleInfo"
    then ["name|String", "pkg|PackageInfo", "elements|List[AnyInfo]"]
    else if name == "InterfaceInfo" | name == "TraitInfo"
    then ["name|String", "pkg|PackageInfo", "methods|List[MethodInfo]", "parents|Set[AnyInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "ObjectInfo"
    then ["name|String", "pkg|PackageInfo", "open|bool", "fields|List[FieldInfo]", "methods|List[MethodInfo]", "parents|Set[AnyInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "MethodInfo"
    then ["name|String", "pkg|PackageInfo", "params|List[FieldInfo]", "return_type|AnyInfo", "annotations|List[AnnotationInfo]"]
    else if name == "AnnotationString" | name == "AnnotationTypeName"
    then ["value|String"]
    else if name == "AnnotationInt"
    then ["value|int"]
    else if name == "AnnotationLong"
    then ["value|long"]
    else if name == "AnnotationDouble"
    then ["value|double"]
    else if name == "AnnotationFloat"
    then ["value|float"]
    else if name == "AnnotationBool"
    then ["value|bool"]
    else []

/// Collects data type parent fields for compiler processing.
private fun data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        merge_schema_fields(
            data_type_fields(parentName, module, allModules),
            data_type_parent_fields(parents[1:], module, allModules)
        )

/// Collects reflection metadata entries for reflection data type parent fields.
private fun reflection_data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        merge_schema_fields(
            reflection_data_type_fields(parentName, module, allModules),
            reflection_data_type_parent_fields(parents[1:], module, allModules)
        )

/// Merges schema fields while preserving compiler-visible metadata.
private fun merge_schema_fields(first: List[String], second: List[String]): List[String] =
    first + schema_fields_not_named(second, schema_field_name_index(first))

/// Collects schema metadata entries for schema fields not named.
private fun schema_fields_not_named(fields: List[String], existingNames: Dict[bool]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        let name = schema_field_name(field)
        if schema_field_name_exists(name, existingNames)
        then schema_fields_not_named(fields[1:], existingNames)
        else [field] + schema_fields_not_named(fields[1:], existingNames + (name, true))

/// Indexes schema field names already emitted by earlier fields.
private fun schema_field_name_index(fields: List[String]): Dict[bool] =
    schema_field_name_index_acc(fields, {:})

/// Accumulates schema field names already emitted by earlier fields.
private fun schema_field_name_index_acc(fields: List[String], names: Dict[bool]): Dict[bool] =
    match fields[0] with
    case None -> names
    case Some { field } -> schema_field_name_index_acc(fields[1:], names + (schema_field_name(field), true))

/// Checks whether schema field name exists in the relevant declarations or imports.
private fun schema_field_name_exists(name: String, fields: Dict[bool]): bool =
    match fields.get(name) with
    case Some _ -> true
    case None -> false

/// Emits import statements for data type fields in.
private fun data_type_fields_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_fields_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_fields_in_imports(name, imports[1:], module, allModules)

/// Emits one import statement for data type fields in.
private fun data_type_fields_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        let importedFields = schema_values_for_type(name, "__capy_schema_field|", importedModule.functions)
        if importedFields.typeExists
        then /capy/lang/Option.Some { importedFields.values }
        else data_type_fields_in_imports(name, rest, module, allModules)
    case _ -> data_type_fields_in_imports(name, rest, module, allModules)

/// Checks whether data import matches the requested declaration, type, or name.
private fun data_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else import_includes_name(name, declaration)

/// Checks whether an import matches the import includes name rule.
private fun import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !string_list_contains(declaration.excludedNames, name)
    else string_list_contains(declaration.importedNames, name)

/// Checks whether string list contains the requested value.
private fun string_list_contains(values: List[String], expected: String): bool =
    match values[0] with
    case None -> false
    case Some { value } -> if value == expected then true else string_list_contains(values[1:], expected)

/// Creates generated-module entries for data type fields in a.
private fun data_type_fields_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        let moduleFields = schema_values_for_type(name, "__capy_schema_field|", module.functions)
        if moduleFields.typeExists
        then moduleFields.values
        else data_type_fields_in_modules(name, modules[1:])

/// Creates name/type bindings for type parameter.
private fun type_parameter_bindings(parameters: List[String], arguments: List[CompiledTypeReference]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        match arguments[0] with
        case Some { argument } -> [java_binding(parameter, argument)] + type_parameter_bindings(parameters[1:], arguments[1:])
        case None -> [java_binding(parameter, object_type())] + type_parameter_bindings(parameters[1:], [])

/// Formats one lookup type parameter for generated emission.
private fun lookup_type_parameter(name: String, bindings: List[JavaBinding]): /capy/lang/Option[CompiledTypeReference] =
    match bindings[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding.typeReference }
        else lookup_type_parameter(name, bindings[1:])

/// Computes the compiled type for binary result.
private fun binary_result_type(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if boolean_binary_operator(operator)
    then bool_type()
    else if set_binary_expression(operator, leftType, rightType) & set_predicate_operator(operator)
    then bool_type()
    else if set_binary_expression(operator, leftType, rightType) & operator == "×"
    then set_type(tuple_type([first_type_argument(leftType), first_type_argument(rightType)]))
    else if set_binary_expression(operator, leftType, rightType)
    then leftType
    else if regex_binary_expression(operator, leftType)
    then regex_binary_result_type(operator)
    else if comparison_operator(operator)
    then bool_type()
    else if operator == "+" & (leftType.name == "String" | rightType.name == "String")
    then string_type()
    else if string_left_numeric_operator(operator, leftType, rightType)
    then string_type()
    else if numeric_binary_operator(operator) & numeric_type(leftType) & numeric_type(rightType)
    then promoted_numeric_type(leftType, rightType)
    else leftType

/// Checks whether an operator belongs to the binary operator category.
private fun numeric_binary_operator(operator: String): bool =
    operator == "+" | operator == "-" | operator == "*" | operator == "/" | operator == "%" | operator == "^"

/// Checks whether an operator belongs to the string left numeric operator category.
private fun string_left_numeric_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "-" | operator == "*" | operator == "/" | operator == "^") & leftType.name == "String" & numeric_type(rightType)

/// Computes the compiled type for promoted numeric.
private fun promoted_numeric_type(leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if leftType.name == "double" | rightType.name == "double"
    then double_type()
    else if leftType.name == "float" | rightType.name == "float"
    then float_type()
    else if leftType.name == "long" | rightType.name == "long"
    then long_type()
    else if leftType.name == "int" | rightType.name == "int"
    then int_type()
    else byte_type()

/// Checks whether an operator belongs to the operator category.
private fun comparison_operator(operator: String): bool =
    operator == ">" | operator == "<" | operator == ">=" | operator == "<=" | operator == "==" | operator == "!=" | operator == "?"

/// Checks whether an expression has the regex binary expression shape.
private fun regex_binary_expression(operator: String, leftType: CompiledTypeReference): bool =
    regex_type_name(leftType.name) & regex_binary_operator(operator)

/// Checks whether an operator belongs to the regex binary operator category.
private fun regex_binary_operator(operator: String): bool =
    operator == "?" | operator == "~" | operator == "~~" | operator == "~>" | operator == "/>"

/// Computes the compiled type for regex binary result.
private fun regex_binary_result_type(operator: String): CompiledTypeReference =
    if operator == "?"
    then bool_type()
    else if operator == "~"
    then option_type(regex_match_type())
    else if operator == "~~"
    then seq_type(regex_match_type())
    else if operator == "~>"
    then string_to_string_function_type()
    else list_type(string_type())

/// Checks whether expression can be emitted by the target backend.
private fun expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> compiled_placeholder_source(unsupported.source)
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression variable ->
        binding_exists(variable.name, env)
            | program_member_imported(variable.name, module.imports)
            | imported_stdlib_constant_exists(variable.name, module.imports)
            | constant_exists_in_scope(variable.name, module, allModules)
            | qualified_enum_value_name(variable.name, module, allModules)
    case CompiledIfExpression e -> truthy_expression_emittable(e.condition, env, module, allModules) & expression_emittable(e.thenBranch, env, module, allModules) & expression_emittable(e.elseBranch, env, module, allModules)
    case CompiledBinaryExpression e ->
        let leftType = expression_type(e.left, env, module, allModules)
        if result_reduce_operator_expression(e, leftType)
        then result_reduce_method_emittable(result_reduce_operator_call(e), env, module, allModules)
        else if async_pipe_expression(e, leftType)
        then async_pipe_emittable(e, env, module, allModules)
        else if result_pipe_expression(e, leftType)
        then result_pipe_emittable(e, env, module, allModules)
        else if option_pipe_expression(e, leftType)
        then option_pipe_emittable(e, env, module, allModules)
        else if collection_pipe_chained_method_expression(e, leftType)
        then expression_emittable(collection_pipe_chained_method_call(e), env, module, allModules)
        else if collection_pipe_expression(e, leftType)
        then collection_pipe_emittable(e, env, module, allModules)
        else if binary_extension_operator_expression_with_left_type(e, leftType, module, allModules)
        then binary_extension_operator_emittable_with_left_type(e, leftType, env, module, allModules)
        else if stdlib_path_slash_expression(e, leftType, module)
        then stdlib_path_slash_emittable(e, env, module, allModules)
        else java_binary_operator_emittable(e, env, module, allModules) & expression_emittable(e.left, env, module, allModules) & expression_emittable(e.right, env, module, allModules)
    case CompiledUnaryExpression e -> java_unary_operator_emittable(e, env, module, allModules) & expression_emittable(e.expression, env, module, allModules)
    case CompiledFunctionCallExpression e -> function_call_emittable(e, env, module, allModules)
    case CompiledFunctionReferenceExpression e -> function_reference_emittable(e, module, allModules)
    case CompiledMethodCallExpression e -> java_method_emittable(e, env, module, allModules)
    case CompiledWithExpression e -> expression_emittable(e.receiver, env, module, allModules) & data_fields_emittable(e.fields, env, module, allModules)
    case CompiledLambdaExpression lambda -> lambda_parameters_supported(lambda.parameters) & expression_emittable(lambda.body, lambda_env(lambda.parameters, env), module, allModules)
    case CompiledListLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledSetLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledDictLiteral e -> dict_entries_emittable(e.entries, env, module, allModules)
    case CompiledTupleLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledIndexExpression e -> index_emittable(e, env, module, allModules)
    case CompiledDataLiteral e -> data_fields_emittable(e.fields, env, module, allModules)
    case CompiledFieldAccessExpression e -> enum_static_field_access(e, env, module, allModules) | expression_emittable(e.receiver, env, module, allModules)
    case CompiledReduceExpression e -> reduce_expression_emittable(e, env, module, allModules)
    case CompiledMatchExpression e -> expression_emittable(e.value, env, module, allModules) & match_cases_emittable(e.cases, expression_type(e.value, env, module, allModules), env, module, allModules)
    case CompiledThrowExpression e -> throw_expression_emittable(e, env, module, allModules)
    case CompiledTryCatchExpression e -> try_catch_expression_emittable(e, env, module, allModules)
    case CompiledBlockExpression e -> let_bindings_emittable(e.bindings, env, module, allModules) & expression_emittable(e.result, block_env(e.bindings, env, module, allModules), module, allModules)

/// Checks whether expression emittable as can be emitted by the target backend.
private fun expression_emittable_as(expression: CompiledExpression, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression _ ->
        if function_type(expectedType)
        then function_lambda_assignable(expectedType, expression, env, module, allModules)
        else expression_emittable(expression, env, module, allModules)
    case CompiledBlockExpression block ->
        let_bindings_emittable(block.bindings, env, module, allModules)
            & expression_emittable_as(block.result, expectedType, block_env(block.bindings, env, module, allModules), module, allModules)
    case CompiledTryCatchExpression tryCatch ->
        expression_emittable_as(tryCatch.body, expectedType, env, module, allModules)
            & try_catch_branches_emittable_as(tryCatch.branches, expectedType, env, module, allModules)
    case _ -> expression_emittable(expression, env, module, allModules)

/// Checks whether expressions can be emitted by the target backend.
private fun expressions_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> expression_emittable(expression, env, module, allModules) & expressions_emittable(expressions[1:], env, module, allModules)

/// Checks whether dict entries can be emitted by the target backend.
private fun dict_entries_emittable(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } -> expression_emittable(entry.key, env, module, allModules) & expression_emittable(entry.value, env, module, allModules) & dict_entries_emittable(entries[1:], env, module, allModules)

/// Checks whether data fields can be emitted by the target backend.
private fun data_fields_emittable(fields: List[CompiledDataField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } -> expression_emittable(field.value, env, module, allModules) & data_fields_emittable(fields[1:], env, module, allModules)

/// Checks whether reduce expression can be emitted by the target backend.
private fun reduce_expression_emittable(reduce: CompiledReduceExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let resultType = expression_type(reduce.initial, env, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = reduce_value_type(receiverType)
    let reduceEnv = reduce_env(reduce, resultType, valueType, java_identifier(reduce.accumulatorName), env)
    let receiverReducible = receiverType.name == "List" | receiverType.name == "Set" | receiverType.name == "Dict" | receiverType.name == "String" | seq_type_name(receiverType.name) | option_type_name(receiverType.name)
    receiverReducible
        & expression_emittable(reduce.receiver, env, module, allModules)
        & expression_emittable(reduce.initial, env, module, allModules)
        & expression_emittable(reduce.body, reduceEnv, module, allModules)

private fun throw_expression_emittable(throwExpression: CompiledThrowExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(throwExpression.value, env, module, allModules)
        & error_type_name(expression_type(throwExpression.value, env, module, allModules).name)

private fun try_catch_expression_emittable(tryCatch: CompiledTryCatchExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(tryCatch.body, env, module, allModules)
        & try_catch_branches_emittable(tryCatch.branches, env, module, allModules)

private fun try_catch_branches_emittable(branches: List[CompiledTryCatchBranch], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match branches[0] with
    case None -> true
    case Some { branch } ->
        expression_emittable(branch.catchBody, [java_binding_with_java_name(branch.catchName, error_type(), "__capy_caught_error")] + env, module, allModules)
            & (if branch.hasKind then try_catch_branches_emittable(branches[1:], env, module, allModules) else true)

private fun try_catch_branches_emittable_as(branches: List[CompiledTryCatchBranch], expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match branches[0] with
    case None -> true
    case Some { branch } ->
        expression_emittable_as(branch.catchBody, expectedType, [java_binding_with_java_name(branch.catchName, error_type(), "__capy_caught_error")] + env, module, allModules)
            & (if branch.hasKind then try_catch_branches_emittable_as(branches[1:], expectedType, env, module, allModules) else true)

/// Checks whether match cases can be emitted by the target backend.
private fun match_cases_emittable(cases: List[CompiledMatchCase], valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
        expression_emittable(matchCase.body, caseEnv, module, allModules)
            & (!matchCase.hasGuard | truthy_expression_emittable(matchCase.guard, caseEnv, module, allModules))
            & (!matchCase.hasLiteral | expression_emittable(matchCase.literal, env, module, allModules))
            & (cases[1:].is_empty() | match_cases_emittable(cases[1:], valueType, env, module, allModules))

/// Checks whether let bindings can be emitted by the target backend.
private fun let_bindings_emittable(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let bindingValueType = binding_value_type(binding, env, module, allModules)
        let effectBindNeedsSpecialCode = binding.operator == "<-" & bindingValueType.name == "Effect"
        !effectBindNeedsSpecialCode
            & expression_emittable_as(binding.value, valueType, env, module, allModules)
            & let_bindings_emittable(bindings[1:], [local_java_binding(binding.name, valueType, binding.location, env)] + env, module, allModules)

/// Checks whether binding exists in the relevant declarations or imports.
private fun binding_exists(name: String, env: List[JavaBinding]): bool =
    match env[0] with
    case None -> false
    case Some { binding } -> binding.name == name | binding_exists(name, env[1:])

/// Checks whether lambda parameters is supported by the current backend.
private fun lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some { parameter } -> parameter != "_" & lambda_parameters_supported(parameters[1:])

/// Checks whether async pipe can be emitted by the target backend.
private fun async_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let valueType = first_type_argument(leftType)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
                collection_lambda_emittable(lambda, valueType, env, module, allModules)
                    & (binary.operator != "|*" | result_type_name(expression_type(lambda.body, lambdaEnv, module, allModules).name))
            case CompiledFunctionReferenceExpression reference -> async_function_reference_emittable(reference, valueType, binary.operator == "|*", module, allModules)
            case _ -> false

/// Checks whether async function reference can be emitted by the target backend.
private fun async_function_reference_emittable(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, flatMap: bool, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        let returnType = effective_function_return_type(function, module, allModules)
        concrete_return_type(returnType)
            & single_parameter_assignable(function.parameters, valueType)
            & (!flatMap | result_type_name(returnType.name))
    case None -> false

/// Checks whether result pipe can be emitted by the target backend.
private fun result_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                lambda_parameter_shape_supported(lambda.parameters, valueType)
                    & expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
            case CompiledFunctionReferenceExpression reference -> result_function_reference_emittable(reference, valueType, module, allModules)
            case _ -> false

/// Checks whether result function reference can be emitted by the target backend.
private fun result_function_reference_emittable(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        let returnType = effective_function_return_type(function, module, allModules)
        concrete_return_type(returnType)
            & result_type_name(returnType.name)
            & single_parameter_assignable(function.parameters, valueType)
    case None -> false

/// Checks whether option pipe can be emitted by the target backend.
private fun option_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
                if binary.operator == "|-"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules)
                    & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
                else if binary.operator == "|*"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules)
                    & option_type_name(expression_type(lambda.body, lambdaEnv, module, allModules).name)
                else collection_lambda_emittable(lambda, valueType, env, module, allModules)
            case _ -> false

/// Checks whether collection pipe can be emitted by the target backend.
private fun collection_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(binary.left, env, module, allModules)
    if receiverType.name == "Dict"
    then dict_pipe_emittable(binary, receiverType, env, module, allModules)
    else
        let valueType = collection_value_type(receiverType)
        expression_emittable(binary.left, env, module, allModules)
            & match binary.right with
                case CompiledLambdaExpression lambda ->
                    if binary.operator == "|-" | binary.operator == "|!"
                    then collection_lambda_emittable(lambda, valueType, env, module, allModules) & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                    else if binary.operator == "|*"
                    then collection_lambda_emittable(lambda, valueType, env, module, allModules) & collection_receiver_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                    else collection_lambda_emittable(lambda, valueType, env, module, allModules)
                case CompiledFunctionReferenceExpression reference ->
                    collection_function_reference_emittable(reference, valueType, module, allModules)
                        & ((binary.operator != "|-" & binary.operator != "|!") | type_assignable(bool_type(), function_reference_type(reference, module, allModules)))
                case _ -> false

/// Checks whether dict pipe can be emitted by the target backend.
private fun dict_pipe_emittable(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let valueType = collection_value_type(receiverType)
    expression_emittable(binary.left, env, module, allModules)
        & (binary.operator == "|" | binary.operator == "|-" | binary.operator == "|!")
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                if dict_predicate_lambda_parameters_supported(lambda.parameters)
                then
                    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
                    expression_emittable(lambda.body, lambdaEnv, module, allModules)
                        & ((binary.operator != "|-" & binary.operator != "|!") | truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules)))
                else false
            case _ -> false

/// Checks whether collection lambda can be emitted by the target backend.
private fun collection_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if lambda_parameter_shape_supported(lambda.parameters, valueType)
    then expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    else false

/// Checks whether collection function reference can be emitted by the target backend.
private fun collection_function_reference_emittable(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        concrete_return_type(function.returnType)
            & single_parameter_assignable(function.parameters, valueType)
    case None -> false

/// Checks whether single parameter is assignable under the generator type rules.
private fun single_parameter_assignable(parameters: List[CompiledFunctionParameter], valueType: CompiledTypeReference): bool =
    match parameters[0] with
    case None -> false
    case Some { parameter } -> parameters[1:].is_empty() & type_assignable(parameter.typeReference, valueType)

/// Checks whether lambda parameter shape is supported by the current backend.
private fun lambda_parameter_shape_supported(parameters: List[String], valueType: CompiledTypeReference): bool =
    if tuple_lambda_parameters(parameters)
    then valueType.name == "Tuple" & tuple_lambda_arity_supported(parameters, valueType.arguments)
    else single_value_lambda_parameters_supported(parameters)

/// Checks whether single value lambda parameters is supported by the current backend.
private fun single_value_lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some _ -> parameters[1:].is_empty()

/// Checks whether tuple lambda arity is supported by the current backend.
private fun tuple_lambda_arity_supported(parameters: List[String], types: List[CompiledTypeReference]): bool =
    match parameters[0] with
    case None -> types.is_empty()
    case Some _ ->
        match types[0] with
        case None -> false
        case Some _ -> tuple_lambda_arity_supported(parameters[1:], types[1:])

/// Checks whether binary operator can be emitted by the Java backend.
private fun java_binary_operator_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let rightType = expression_type(binary.right, env, module, allModules)
    if binary.operator == "+"
    then collection_plus_expression(binary.operator, leftType, rightType) | leftType.name == "String" | rightType.name == "String" | (numeric_type(leftType) & numeric_type(rightType))
    else if boolean_binary_operator(binary.operator)
    then truthy_type(leftType) & truthy_type(rightType)
    else if binary.operator == "^"
    then (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if binary.operator == ".nand." | bitwise_binary_operator(binary.operator)
    then integer_type(leftType) & integer_type(rightType)
    else if binary.operator == "%"
    then remainder_type(leftType) & remainder_type(rightType)
    else if binary.operator == "-" | binary.operator == "*" | binary.operator == "/"
    then collection_minus_expression(binary.operator, leftType, rightType) | (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if set_binary_expression(binary.operator, leftType, rightType)
    then true
    else if regex_binary_expression(binary.operator, leftType)
    then regex_binary_emittable(binary, env, module, allModules)
    else if binary.operator == ">" | binary.operator == "<" | binary.operator == ">=" | binary.operator == "<="
    then numeric_type(leftType) & numeric_type(rightType)
    else if binary.operator == "?"
    then
        if leftType.name == "Dict"
        then type_assignable(string_type(), rightType)
        else (leftType.name == "List" | leftType.name == "Set" | leftType.name == "String") & !rightType.name.is_empty()
    else binary.operator == "==" | binary.operator == "!="

/// Checks whether regex binary can be emitted by the target backend.
private fun regex_binary_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(binary.left, env, module, allModules)
        & expression_emittable(binary.right, env, module, allModules)
        & type_assignable(string_type(), expression_type(binary.right, env, module, allModules))

/// Checks whether unary operator can be emitted by the Java backend.
private fun java_unary_operator_emittable(unary: CompiledUnaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let type = expression_type(unary.expression, env, module, allModules)
    if unary.operator == "!" then truthy_type(type)
    else if unary.operator == "-" then numeric_type(type)
    else if unary.operator == ".not." then integer_type(type)
    else false

/// Checks whether truthy expression can be emitted by the target backend.
private fun truthy_expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    truthy_type(expression_type(expression, env, module, allModules)) & expression_emittable(expression, env, module, allModules)

/// Checks whether a type reference matches the truthy type rule.
private fun truthy_type(type: CompiledTypeReference): bool =
    type.name == "bool"
        | integer_type(type)
        | type.name == "float"
        | type.name == "double"
        | type.name == "String"
        | type.name == "List"
        | type.name == "Set"
        | type.name == "Dict"
        | type.name == "any"

/// Checks whether a type reference matches the integer type rule.
private fun integer_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long"

/// Checks whether a type reference matches the numeric type rule.
private fun numeric_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"

/// Checks whether a type reference matches the remainder type rule.
private fun remainder_type(type: CompiledTypeReference): bool =
    numeric_type(type)

/// Checks whether the current value satisfies the byte literal source rule for compiler processing.
private fun byte_literal_source(source: String): bool =
    java_generator_string_has_prefix(source, "0x") | java_generator_string_has_prefix(source, "0X")

/// Checks whether method can be emitted by the Java backend.
private fun java_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if partial_method_call(call)
    then partial_method_call_emittable(call, env, module, allModules)
    else if call.name == "size"
    then (receiverType.name == "List" | receiverType.name == "Set" | receiverType.name == "Dict" | receiverType.name == "String" | receiverType.name == "char")
        & call.arguments.is_empty()
        & expression_emittable(call.receiver, env, module, allModules)
    else if char_to_string_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if enum_name_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if assert_status_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if assert_is_empty_call(call)
    then assert_is_empty_emittable(call, env, module, allModules)
    else if result_assert_succeeds_lambda_call(call, env, module, allModules)
    then result_assert_succeeds_lambda_emittable(call, env, module, allModules)
    else if assert_method_call(call, env, module, allModules)
    then assert_method_call_emittable(call, env, module, allModules)
    else if negated_collection_is_empty_call(call, env, module, allModules)
    then negated_collection_is_empty_emittable(call, env, module, allModules)
    else if collection_is_empty_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_emittable(call, receiverType, env, module, allModules)
    else if collection_reduce_method_call(call, env, module, allModules)
    then reduce_expression_emittable(collection_reduce_method_expression(call, receiverType), env, module, allModules)
    else if option_method_call(call, env, module, allModules)
    then option_pipe_emittable(option_method_binary(call), env, module, allModules)
    else if collection_method_call(call, env, module, allModules)
    then collection_pipe_emittable(collection_method_binary(call), env, module, allModules)
    else if set_method_call(call, env, module, allModules)
    then set_method_call_emittable(call, receiverType, env, module, allModules)
    else if native_stdlib_method_call(call, env, module, allModules)
    then native_stdlib_method_emittable(call, receiverType, env, module, allModules)
    else if call.name == "as_list" & seq_type_name(receiverType.name)
    then call.arguments.is_empty() & expression_emittable(call.receiver, env, module, allModules)
    else if seq_first_call(call, env, module, allModules)
    then call.arguments.is_empty() & expression_emittable(call.receiver, env, module, allModules)
    else if effect_start_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if async_join_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if async_map_method_call(call, env, module, allModules)
    then async_pipe_emittable(async_map_method_binary(call), env, module, allModules)
    else if function_value_method_call(call, env, module, allModules)
    then function_value_method_emittable(call, env, module, allModules)
    else if result_reduce_method_call(call, env, module, allModules)
    then result_reduce_method_emittable(call, env, module, allModules)
    else if result_map_method_call(call, env, module, allModules)
    then result_map_method_emittable(call, env, module, allModules)
    else if result_or_else_method_call(call, env, module, allModules)
    then result_or_else_method_emittable(call, env, module, allModules)
    else if result_or_method_call(call, env, module, allModules)
    then result_or_method_emittable(call, env, module, allModules)
    else if call.name == "map" & receiverType.name == "Effect"
    then match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda ->
            expression_emittable(call.receiver, env, module, allModules)
                & collection_lambda_emittable(lambda, first_type_argument(receiverType), env, module, allModules)
        case _ -> false
    else if string_parse_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if regex_method_call(call, env, module, allModules)
    then regex_method_emittable(call, env, module, allModules)
    else if stdlib_date_time_method_call(call, env, module, allModules)
    then stdlib_date_time_method_emittable(call, env, module, allModules)
    else if primitive_conversion_method(call.name)
    then primitive_conversion_method_emittable(call, receiverType, env, module, allModules)
    else if object_type_method_call(call, module, allModules)
    then true
    else if object_method_call(call, env, module, allModules)
    then object_method_call_emittable(call, env, module, allModules)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> extension_method_call_emittable(function, call, env, module, allModules)
        case None -> java_method_supported(call.name)
            & expression_emittable(call.receiver, env, module, allModules)
            & expressions_emittable(call.arguments, env, module, allModules)

/// Checks whether function value method can be emitted by the target backend.
private fun function_value_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & function_type_call_arguments_emittable(function_type_parameters(receiverType), call.arguments, env, module, allModules)

/// Checks whether result map method can be emitted by the target backend.
private fun result_map_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    result_pipe_emittable(result_map_method_binary(call), env, module, allModules)

/// Checks whether result reduce method can be emitted by the target backend.
private fun result_reduce_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    expression_emittable(call.receiver, env, module, allModules)
        & result_reduce_argument_emittable(argument(call.arguments, 0), valueType, env, module, allModules)
        & result_reduce_argument_emittable(argument(call.arguments, 1), error_type(), env, module, allModules)

/// Checks whether result or else method can be emitted by the target backend.
private fun result_or_else_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & (result_value_type_needs_context(valueType) | type_assignable(valueType, argumentType))

/// Checks whether result or method can be emitted by the target backend.
private fun result_or_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & result_type_name(argumentType.name)
        & (result_value_type_needs_context(valueType) | type_assignable(receiverType, argumentType))

/// Checks whether result reduce argument can be emitted by the target backend.
private fun result_reduce_argument_emittable(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> result_reduce_lambda_emittable(lambda, valueType, env, module, allModules)
    case _ -> false

/// Checks whether result reduce lambda can be emitted by the target backend.
private fun result_reduce_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if lambda_parameter_shape_supported(lambda.parameters, valueType)
    then expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    else false

/// Checks whether regex method can be emitted by the target backend.
private fun regex_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentExpression = argument(call.arguments, 0)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & type_assignable(string_type(), expression_type(argumentExpression, env, module, allModules))

/// Checks whether extension method call can be emitted by the target backend.
private fun extension_method_call_emittable(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    extension_method_call_emittable_with_receiver_type(function, call, receiverType, env, module, allModules)

/// Checks whether extension method call emittable with receiver type can be emitted by the target backend.
private fun extension_method_call_emittable_with_receiver_type(function: CompiledFunction, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let parameters = bound_extension_method_parameters(function, receiverType)
    concrete_return_type(bound_extension_method_return_type(function, receiverType))
        & expression_emittable(call.receiver, env, module, allModules)
        & parameters_assignable(parameters, call.arguments, env, module, allModules)
        & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

/// Checks whether native standard-library method can be emitted by the target backend.
private fun native_stdlib_method_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & if receiverType.name == "String" | receiverType.name == "List"
            then index_method_arguments_emittable(call.arguments, env, module, allModules)
            else if receiverType.name == "Dict"
            then dict_method_arguments_emittable(call, env, module, allModules)
            else if receiverType.name == "Tuple"
            then tuple_get_method_arguments_emittable(call, env, module, allModules)
            else expressions_emittable(call.arguments, env, module, allModules)

/// Checks whether set method call can be emitted by the target backend.
private fun set_method_call_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & if set_no_argument_method(call.name)
            then call.arguments.is_empty()
            else if call.name == "contains"
            then set_contains_argument_emittable(call, env, module, allModules)
            else set_set_argument_emittable(call, env, module, allModules)

/// Checks whether set contains argument can be emitted by the target backend.
private fun set_contains_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    one_method_argument(call.arguments) & expression_emittable(argument(call.arguments, 0), env, module, allModules)

/// Checks whether set set argument can be emitted by the target backend.
private fun set_set_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    one_method_argument(call.arguments)
        & expression_type(argument(call.arguments, 0), env, module, allModules).name == "Set"
        & expression_emittable(argument(call.arguments, 0), env, module, allModules)

/// Checks whether dict method arguments can be emitted by the target backend.
private fun dict_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let key = argument(call.arguments, 0)
    expression_emittable(key, env, module, allModules)
        & type_assignable(string_type(), expression_type(key, env, module, allModules))

/// Checks whether tuple get method arguments can be emitted by the target backend.
private fun tuple_get_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let index = argument(call.arguments, 0)
    index_literal_emittable(index)
        & index_argument_emittable(index, env, module, allModules)

/// Checks whether index method arguments can be emitted by the target backend.
private fun index_method_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { first } ->
        index_argument_emittable(first, env, module, allModules)
            & match arguments[1] with
                case None -> true
                case Some { second } -> arguments[2:].is_empty() & index_argument_emittable(second, env, module, allModules)

/// Checks whether primitive conversion method can be emitted by the target backend.
private fun primitive_conversion_method_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.arguments.is_empty()
        & primitive_conversion_receiver(call.name, receiverType)
        & expression_emittable(call.receiver, env, module, allModules)

/// Checks whether result assert succeeds lambda can be emitted by the target backend.
private fun result_assert_succeeds_lambda_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let valueType = first_type_argument(expression_type(actual, env, module, allModules))
        expression_emittable(actual, env, module, allModules)
            & result_assert_succeeds_lambda_argument_emittable(argument(call.arguments, 0), valueType, env, module, allModules)
    case _ -> false

/// Checks whether result assert succeeds lambda argument can be emitted by the target backend.
private fun result_assert_succeeds_lambda_argument_emittable(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> collection_lambda_emittable(lambda, valueType, env, module, allModules)
    case _ -> false

/// Checks whether assert method call can be emitted by the target backend.
private fun assert_method_call_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

/// Checks whether negated collection is empty can be emitted by the target backend.
private fun negated_collection_is_empty_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledUnaryExpression unary -> expression_emittable(unary.expression, env, module, allModules)
    case _ -> false

/// Checks whether collection predicate call can be emitted by the target backend.
private fun collection_predicate_call_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { predicate } ->
        match call.arguments[1] with
        case Some _ -> false
        case None ->
            expression_emittable(call.receiver, env, module, allModules)
            & match predicate with
                case CompiledLambdaExpression lambda ->
                    let valueType = collection_value_type(receiverType)
                    if receiverType.name == "Dict"
                    then dict_predicate_lambda_emittable(lambda, valueType, env, module, allModules)
                    else if receiverType.name == "String" & string_indexed_lambda(lambda.parameters)
                    then
                        let lambdaEnv = string_indexed_lambda_env(lambda.parameters, expression_code(call.receiver, env, receiverType, module, allModules), env)
                        expression_emittable(lambda.body, lambdaEnv, module, allModules)
                            & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
                    else collection_lambda_emittable(lambda, valueType, env, module, allModules)
                            & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                case CompiledFunctionReferenceExpression reference ->
                    let valueType = collection_value_type(receiverType)
                    receiverType.name != "Dict"
                        & collection_function_reference_emittable(reference, valueType, module, allModules)
                        & type_assignable(bool_type(), function_reference_type(reference, module, allModules))
                case _ -> false

/// Checks whether dict predicate lambda can be emitted by the target backend.
private fun dict_predicate_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if dict_predicate_lambda_parameters_supported(lambda.parameters)
    then
        let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
        expression_emittable(lambda.body, lambdaEnv, module, allModules)
            & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
    else false

/// Checks whether dict predicate lambda parameters is supported by the current backend.
private fun dict_predicate_lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ -> parameters[2:].is_empty()

/// Checks whether assert is empty can be emitted by the target backend.
private fun assert_is_empty_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledFunctionCallExpression receiver -> assert_is_empty_arguments_emittable(receiver.arguments, env, module, allModules)
    case _ -> false

/// Checks whether assert is empty arguments can be emitted by the target backend.
private fun assert_is_empty_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { actual } ->
        let actualType = expression_type(actual, env, module, allModules)
        if collection_empty_receiver_type(actualType) | option_type_name(actualType.name)
        then expression_emittable(actual, env, module, allModules)
        else false

/// Checks whether method metadata matches the primitive conversion method rule.
private fun primitive_conversion_method(name: String): bool =
    name == "to_int" | name == "to_long"

/// Checks whether a receiver type matches the primitive conversion receiver rule.
private fun primitive_conversion_receiver(name: String, receiverType: CompiledTypeReference): bool =
    if name == "to_int"
    then receiverType.name == "long" | receiverType.name == "float" | receiverType.name == "double"
    else if name == "to_long"
    then receiverType.name == "float" | receiverType.name == "double"
    else false

/// Checks whether function call can be emitted by the target backend.
private fun function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if partial_function_call(call)
    then partial_function_call_emittable(call, env, module, allModules)
    else if call.name == "delay"
    then delay_call_emittable(call.arguments, env, module, allModules)
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_value_call_emittable(call, env, module, allModules)
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then match call.arguments[0] with
        case None -> false
        case Some { argument } ->
            if call.arguments[1:].is_empty()
            then expression_emittable(argument, env, module, allModules)
            else false
    else if async_function_call(call, module)
    then async_function_call_emittable(call, env, module, allModules)
    else if stdlib_effect_function_call(call, module)
    then true
    else if result_error_function_call(call, module)
    then result_error_function_call_emittable(call, env, module, allModules)
    else if stdlib_path_function_call(call, module)
    then stdlib_path_function_call_emittable(call, env, module, allModules)
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_emittable(call, env, module, allModules)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then match call.arguments[0] with
        case None -> false
        case Some { argument } ->
            if call.arguments[1:].is_empty()
            then expression_emittable(argument, env, module, allModules)
            else false
    else if console_read_line_call(call, module)
    then true
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_call_emittable(call, env, module, allModules)
    else if reflection_function_call(call, module)
    then reflection_call_emittable(call, env, module, allModules)
    else if object_type_function_call(call, module, allModules)
    then true
    else if call.name == "assert_all"
    then expressions_emittable(call.arguments, env, module, allModules)
    else if call.name == "assert_that"
    then assert_that_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test"
    then test_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test_file"
    then test_file_call_emittable(call.arguments, env, module, allModules)
    else if stdlib_math_sqrt_call(call, module)
    then stdlib_math_sqrt_call_emittable(call.arguments, env, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then stdlib_math_digits_call_emittable(call.arguments, env, module, allModules)
    else if enum_parse_call(call, module, allModules)
    then enum_parse_call_emittable(call, env, module, allModules)
    else if object_constructor_call(call, env, module, allModules)
    then object_constructor_call_emittable(call, env, module, allModules)
    else if qualified_call_name(call.name)
    then qualified_function_call_emittable(call, env, module, allModules)
    else java_callable_name(call.name) & !binding_exists(call.name, env) & function_call_target_emittable(call.name, call.arguments, env, module, allModules)

/// Checks whether standard-library to seq call can be emitted by the target backend.
private fun stdlib_to_seq_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    if argumentType.name == "List" | argumentType.name == "Set" | argumentType.name == "Dict"
    then expression_emittable(argumentExpression, env, module, allModules)
    else false

/// Checks whether qualified function call can be emitted by the target backend.
private fun qualified_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if binding_exists(call.name, env)
    then false
    else match find_qualified_function_binding(call.name, module, allModules) with
        case Some { binding } ->
            if callable_return_type(effective_function_return_type(binding.function, binding.module, allModules))
            then parameters_emittable_and_assignable(binding.function.parameters, call.arguments, env, module, allModules)
            else false
        case None -> qualified_call_member(call.name) == "main"

/// Checks whether function value call can be emitted by the target backend.
private fun function_value_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let type = lookup_binding(call.name, env)
    function_type_call_arguments_emittable(function_type_parameters(type), call.arguments, env, module, allModules)

/// Checks whether function type call arguments can be emitted by the target backend.
private fun function_type_call_arguments_emittable(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            if expression_emittable(argument, env, module, allModules)
            then if value_assignable(parameter, expression_type(argument, env, module, allModules), module, allModules)
                then function_type_call_arguments_emittable(parameters[1:], arguments[1:], env, module, allModules)
                else false
            else false

/// Checks whether function reference can be emitted by the target backend.
private fun function_reference_emittable(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } -> concrete_return_type(function.returnType)
    case None -> false

/// Checks whether a call has the standard-library math sqrt call shape.
private fun stdlib_math_sqrt_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "sqrt"
    then !function_defined(call.name, module.functions)
    else false

/// Computes the compiled type for sqrt call.
private fun sqrt_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if argumentType.name == "double" then double_type() else float_type()

/// Emits generated code for sqrt call.
private fun sqrt_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = if expectedType.name == "double" then double_type() else sqrt_call_type(call, env, module, allModules)
    let code = "java.lang.Math.sqrt(" + expression_code(argument(call.arguments, 0), env, double_type(), module, allModules) + ")"
    if resultType.name == "double" then code else "((float) " + code + ")"

/// Checks whether standard-library math sqrt call can be emitted by the target backend.
private fun stdlib_math_sqrt_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & numeric_type(expression_type(argument, env, module, allModules))
            & expression_emittable(argument, env, module, allModules)

/// Checks whether a call has the standard-library math digits call shape.
private fun stdlib_math_digits_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "digits"
    then !function_defined(call.name, module.functions) & stdlib_math_wildcard_import(module.imports)
    else false

/// Checks whether a function matches the function defined metadata.
private fun function_defined(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if function.name == name & !compiled_constant(function)
        then true
        else function_defined(name, functions[1:])

/// Checks whether an import matches the standard-library math wildcard import rule.
private fun stdlib_math_wildcard_import(imports: List[CompiledImportDeclaration]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.wildcard
            & (declaration.modulePath == "/capy/lang/Math" | declaration.modulePath == "capy/lang/Math")
            & !string_list_contains(declaration.excludedNames, "digits")
        then true
        else stdlib_math_wildcard_import(imports[1:])

/// Checks whether standard-library math digits call can be emitted by the target backend.
private fun stdlib_math_digits_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
        & type_assignable(int_type(), expression_type(argument, env, module, allModules))
        & expression_emittable(argument, env, module, allModules)

/// Checks whether a call has the enum parse call shape.
private fun enum_parse_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    qualified_call_name(call.name)
        & enum_qualified_member_name(call.name) == "parse"
        & enum_type_exists(enum_qualified_type_name(call.name), module, allModules)

/// Checks whether enum parse call can be emitted by the target backend.
private fun enum_parse_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { argument } ->
        call.arguments[1:].is_empty()
            & expression_emittable(argument, env, module, allModules)
            & enum_parse_argument_supported(expression_type(argument, env, module, allModules))

/// Checks whether enum parse argument is supported by the current backend.
private fun enum_parse_argument_supported(argumentType: CompiledTypeReference): bool =
    type_assignable(string_type(), argumentType) | type_assignable(int_type(), argumentType)

/// Checks whether assert that call can be emitted by the target backend.
private fun assert_that_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        assert_type_supported(expression_type(expression, env, module, allModules))
        & expression_emittable(expression, env, module, allModules)

/// Checks whether assert type is supported by the current backend.
private fun assert_type_supported(type: CompiledTypeReference): bool =
    type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"
        | type.name == "bool" | type.name == "String" | type.name == "List" | type.name == "Set" | type.name == "Dict"
        | data_assert_type_supported(type)

/// Checks whether data assert type is supported by the current backend.
private fun data_assert_type_supported(type: CompiledTypeReference): bool =
    concrete_return_type(type)
        & !collection_assert_type(type.name)
        & type.name != "Assert"
        & type.name != "Effect"
        & type.name != "Supplier"
        & (type.name == "data" | type.name == "enum" | java_generator_string_has_prefix(type.name, "/") | uppercase_data_type_name(type.name))

/// Checks whether a type reference matches the collection assert type rule.
private fun collection_assert_type(name: String): bool =
    name == "List" | name == "Set" | name == "Dict" | seq_type_name(name)

/// Checks whether a type reference matches the uppercase data type name rule.
private fun uppercase_data_type_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

/// Checks whether delay call can be emitted by the target backend.
private fun delay_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        arguments[1:].is_empty() & lambda_argument_emittable(expression, env, module, allModules)

/// Checks whether test call can be emitted by the target backend.
private fun test_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { assertionExpression } ->
            expression_emittable(nameExpression, env, module, allModules) & test_supplier_emittable(assertionExpression)

/// Checks whether test supplier can be emitted by the target backend.
private fun test_supplier_emittable(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

/// Checks whether lambda argument can be emitted by the target backend.
private fun lambda_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda_parameters_supported(lambda.parameters) & expression_emittable(lambda.body, lambda_env(lambda.parameters, env), module, allModules)
    case _ -> false

/// Checks whether test file call can be emitted by the target backend.
private fun test_file_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { testsExpression } ->
            let testsType = expression_type(testsExpression, env, module, allModules)
            expression_emittable(nameExpression, env, module, allModules)
                & expression_emittable(testsExpression, env, module, allModules)
                & testsType.name == "List"
                & test_file_test_case_list_type(first_type_argument(testsType))

/// Checks whether index can be emitted by the target backend.
private fun index_emittable(index: CompiledIndexExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(index.receiver, env, module, allModules)
    if !built_in_index_expression(index, receiverType)
    then user_defined_index_emittable(index, receiverType, env, module, allModules)
    else if receiverType.name == "List"
    then expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "Tuple"
    then index_literal_emittable(index.index)
        & (!index.hasEndIndex | index_literal_emittable(index.endIndex))
        & expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "String"
    then expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "Dict"
    then !index.hasEndIndex
        & expression_emittable(index.receiver, env, module, allModules)
        & expression_emittable(index.index, env, module, allModules)
        & type_assignable(string_type(), expression_type(index.index, env, module, allModules))
    else false

/// Checks whether user defined index can be emitted by the target backend.
private fun user_defined_index_emittable(index: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } -> extension_method_call_emittable_with_receiver_type(function, index_get_call(index), receiverType, env, module, allModules)
    case None -> false

/// Checks whether index literal can be emitted by the target backend.
private fun index_literal_emittable(index: CompiledExpression): bool =
    match index with
    case CompiledIntLiteral _ -> true
    case CompiledUnaryExpression unary -> unary.operator == "-" & index_literal_emittable(unary.expression)
    case _ -> false

/// Checks whether function call target can be emitted by the target backend.
private fun function_call_target_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentTypes = expression_types(arguments, env, module, allModules)
    match find_function_for_argument_types_in_functions(name, arguments, argumentTypes, env, module.functions, module, allModules) with
    case Some { function } ->
        callable_return_type(effective_function_return_type(function, module, allModules))
            & parameters_emittable_and_assignable_with_types(function.parameters, arguments, argumentTypes, env, module, allModules)
    case None -> imported_function_target_emittable(name, arguments, argumentTypes, env, module.imports, module, allModules)

/// Collects imported function target emittable visible to the current module.
private fun imported_function_target_emittable(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then imported_module_function_emittable(name, arguments, argumentTypes, env, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else imported_function_target_emittable(name, arguments, argumentTypes, env, imports[1:], module, allModules)

/// Collects imported module function emittable visible to the current module.
private fun imported_module_function_emittable(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): bool =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> imported_module_function_body_emittable(name, arguments, argumentTypes, env, rest, module, allModules, importedModule)
    case _ -> imported_function_target_emittable(name, arguments, argumentTypes, env, rest, module, allModules)

/// Collects imported module function body emittable visible to the current module.
private fun imported_module_function_body_emittable(name: String, arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): bool =
    match find_function_for_argument_types_in_functions(name, arguments, argumentTypes, env, importedModule.functions, module, allModules) with
    case Some { function } ->
        callable_return_type(effective_function_return_type(function, importedModule, allModules))
            & parameters_emittable_and_assignable_with_types(function.parameters, arguments, argumentTypes, env, module, allModules)
    case _ -> imported_function_target_emittable(name, arguments, argumentTypes, env, rest, module, allModules)

/// Checks whether a type reference matches the concrete return type rule.
private fun concrete_return_type(type: CompiledTypeReference): bool =
    !type.name.is_empty() & type.name != "any"

/// Checks whether a type reference matches the callable return type rule.
private fun callable_return_type(type: CompiledTypeReference): bool =
    concrete_return_type(type) | type.name.is_empty() | type.name == "any"

/// Checks whether parameters is assignable under the generator type rules.
private fun parameters_assignable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    parameters_assignable_with_types(parameters, arguments, expression_types(arguments, env, module, allModules), env, module, allModules)

/// Checks whether parameters is assignable under the generator type rules with precomputed argument types.
private fun parameters_assignable_with_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            match argumentTypes[0] with
            case None -> false
            case Some { argumentType } ->
                parameter_argument_assignable_with_type(parameter.typeReference, argument, argumentType, env, module, allModules)
                    & parameters_assignable_with_types(parameters[1:], arguments[1:], argumentTypes[1:], env, module, allModules)

/// Checks whether parameters emittable and assignable can be emitted by the target backend.
private fun parameters_emittable_and_assignable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            parameter_argument_assignable(parameter.typeReference, argument, env, module, allModules)
                & parameter_argument_emittable(parameter.typeReference, argument, env, module, allModules)
                & parameters_emittable_and_assignable(parameters[1:], arguments[1:], env, module, allModules)

/// Checks whether parameters emittable and assignable can be emitted by the target backend with precomputed argument types.
private fun parameters_emittable_and_assignable_with_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], argumentTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            match argumentTypes[0] with
            case None -> false
            case Some { argumentType } ->
                parameter_argument_assignable_with_type(parameter.typeReference, argument, argumentType, env, module, allModules)
                    & parameter_argument_emittable(parameter.typeReference, argument, env, module, allModules)
                    & parameters_emittable_and_assignable_with_types(parameters[1:], arguments[1:], argumentTypes[1:], env, module, allModules)

/// Checks whether parameter argument can be emitted by the target backend.
private fun parameter_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if function_type(target)
    then function_argument_emittable(target, argument, env, module, allModules)
    else expression_emittable(argument, env, module, allModules)

/// Checks whether function argument can be emitted by the target backend.
private fun function_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match argument with
    case CompiledLambdaExpression _ -> function_lambda_assignable(target, argument, env, module, allModules)
    case CompiledFunctionReferenceExpression _ -> function_reference_assignable(target, argument, module, allModules)
    case _ -> expression_emittable(argument, env, module, allModules)

/// Checks whether parameter argument is assignable under the generator type rules.
private fun parameter_argument_assignable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    parameter_argument_assignable_with_type(target, argument, expression_type(argument, env, module, allModules), env, module, allModules)

/// Checks whether parameter argument is assignable under the generator type rules with a precomputed argument type.
private fun parameter_argument_assignable_with_type(target: CompiledTypeReference, argument: CompiledExpression, argumentType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if empty_collection_literal_assignable(target, argument)
    then true
    else if function_reference_assignable(target, argument, module, allModules)
    then true
    else if function_lambda_assignable(target, argument, env, module, allModules)
    then true
    else value_assignable(target, argumentType, module, allModules)

/// Checks whether function lambda is assignable under the generator type rules.
private fun function_lambda_assignable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !function_type(target)
    then false
    else match argument with
        case CompiledLambdaExpression lambda ->
            let parameters = function_type_parameters(target)
            let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
            lambda_function_parameters_assignable(parameters, lambda.parameters)
                & expression_emittable(lambda.body, lambdaEnv, module, allModules)
                & type_assignable(function_type_return_type(target), expression_type(lambda.body, lambdaEnv, module, allModules))
        case _ -> false

/// Checks whether lambda function parameters is assignable under the generator type rules.
private fun lambda_function_parameters_assignable(parameters: List[CompiledTypeReference], names: List[String]): bool =
    match parameters[0] with
    case None -> names.is_empty()
    case Some _ ->
        match names[0] with
        case None -> false
        case Some _ -> lambda_function_parameters_assignable(parameters[1:], names[1:])

/// Checks whether function reference is assignable under the generator type rules.
private fun function_reference_assignable(target: CompiledTypeReference, argument: CompiledExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !function_type(target)
    then false
    else match argument with
        case CompiledFunctionReferenceExpression reference -> function_reference_type_assignable(target, reference, module, allModules)
        case _ -> false

/// Checks whether function reference type is assignable under the generator type rules.
private fun function_reference_type_assignable(target: CompiledTypeReference, reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        type_assignable(function_type_return_type(target), effective_function_return_type(function, module, allModules))
            & function_parameters_assignable(function_type_parameters(target), function.parameters)
    case None -> false

/// Checks whether function parameters is assignable under the generator type rules.
private fun function_parameters_assignable(targetParameters: List[CompiledTypeReference], sourceParameters: List[CompiledFunctionParameter]): bool =
    match targetParameters[0] with
    case None -> sourceParameters.is_empty()
    case Some { targetParameter } ->
        match sourceParameters[0] with
        case None -> false
        case Some { sourceParameter } ->
            type_assignable(targetParameter, sourceParameter.typeReference)
                & function_parameters_assignable(targetParameters[1:], sourceParameters[1:])

/// Checks whether empty collection literal is assignable under the generator type rules.
private fun empty_collection_literal_assignable(target: CompiledTypeReference, argument: CompiledExpression): bool =
    match argument with
    case CompiledListLiteral literal -> literal.values.is_empty() & target.name == "List"
    case CompiledSetLiteral literal -> literal.values.is_empty() & target.name == "Set"
    case CompiledDictLiteral literal -> literal.entries.is_empty() & target.name == "Dict"
    case _ -> false

/// Checks whether type is assignable under the generator type rules.
private fun type_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    if type_parameter(target) | type_parameter(source) | source.name == "nothing"
    then true
    else if target.name == "any"
    then true
    else if target.name.is_empty() | source.name.is_empty() | source.name == "any"
    then false
    else if function_type(target) & function_type(source)
    then function_type_assignable(target, source)
    else if primitive_numeric_widening_assignable(target, source)
    then true
    else if stdlib_type_reference_assignable(target, source)
    then true
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then true
    else if target.name == "data" & generated_data_object_type(source)
    then true
    else target.name == source.name & type_arguments_assignable(target.arguments, source.arguments)

/// Checks whether function type is assignable under the generator type rules.
private fun function_type_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    type_arguments_assignable(function_type_parameters(target), function_type_parameters(source))
        & type_assignable(function_type_return_type_with_arguments(target), function_type_return_type_with_arguments(source))

/// Checks whether value is assignable under the generator type rules.
private fun value_assignable(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if stdlib_type_reference_assignable(target, source)
    then true
    else if object_type_assignable(target, source, module, allModules)
    then true
    else if runtime_supertype_assignable(target, source, module, allModules)
    then true
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then data_type_distance(target.name, source.name, module, allModules) >= 0
    else if type_assignable(target, source)
    then true
    else match primitive_backed_backing_type(source.name, module, allModules) with
        case Some { backingType } -> type_assignable(target, backingType)
        case None -> false

/// Checks whether object type is assignable under the generator type rules.
private fun object_type_assignable(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_object_class_by_type(source, allModules) with
    case Some { binding } ->
        if object_type_name_matches(target.name, binding.objectClass.name)
        then true
        else object_parent_assignable(target.name, binding.objectClass.parents, module, allModules)
    case None -> false

/// Checks whether object parent is assignable under the generator type rules.
private fun object_parent_assignable(targetName: String, parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parents[0] with
    case None -> false
    case Some { parent } ->
        if object_type_name_matches(targetName, parent.name)
        then true
        else if object_parent_assignable(targetName, object_interface_parent_types(parent.name, module, allModules), module, allModules)
        then true
        else object_parent_assignable(targetName, parents[1:], module, allModules)

/// Collects object-oriented metadata for object interface parent types.
private fun object_interface_parent_types(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[CompiledTypeReference] =
    match find_object_interface_by_name(name, module, allModules) with
    case Some { binding } -> binding.objectInterface.parents
    case None -> []

/// Checks whether object type name matches the requested declaration, type, or name.
private fun object_type_name_matches(first: String, second: String): bool =
    first == second | type_unqualified_name(first) == type_unqualified_name(second)

/// Checks whether runtime supertype is assignable under the generator type rules.
private fun runtime_supertype_assignable(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if target.name == "enum"
    then source.name == "any" | enum_type_exists(source.name, module, allModules)
    else if target.name == "data"
    then source.name == "any" | generated_data_object_type(source)
    else false

/// Checks whether a type reference matches the generated data object type rule.
private fun generated_data_object_type(type: CompiledTypeReference): bool =
    !type.name.is_empty()
        & !numeric_type(type)
        & type.name != "bool"
        & type.name != "String"
        & type.name != "List"
        & type.name != "Set"
        & type.name != "Dict"
        & type.name != "Tuple"
        & type.name != "Effect"
        & type.name != "Async"
        & type.name != "Assert"
        & type.name != "TestFile"
        & type.name != "TestCase"
        & type.name != "Supplier"
        & uppercase_data_type_name(type_unqualified_name(type.name))

/// Computes the name for type unqualified.
private fun type_unqualified_name(name: String): String =
    let idx = last_type_separator_index(name)
    if idx < 0 then name else name[idx + 1, name.size().value]

/// Computes the last separator for a qualified or path-qualified type name.
private fun last_type_separator_index(name: String): int =
    last_type_separator_index_from(name, 0, -1)

/// Computes the last separator for a qualified or path-qualified type name from an offset.
private fun last_type_separator_index_from(name: String, idx: int, found: int): int =
    if idx >= name.size().value
    then found
    else match name[idx] with
        case None -> found
        case Some { char } ->
            last_type_separator_index_from(name, idx + 1, if char == "." | char == "/" then idx else found)

/// Computes the index used to split or rank last index of.
private fun last_index_of(value: String, needle: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { char } -> last_index_of(value, needle, idx + 1, if char == needle then idx else found)

/// Checks whether primitive numeric widening is assignable under the generator type rules.
private fun primitive_numeric_widening_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    source.arguments.is_empty() & target.arguments.is_empty() & (
        (source.name == "byte" & (target.name == "int" | target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "int" & (target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "long" & (target.name == "float" | target.name == "double"))
        | (source.name == "float" & target.name == "double")
    )

/// Checks whether type arguments is assignable under the generator type rules.
private fun type_arguments_assignable(target: List[CompiledTypeReference], source: List[CompiledTypeReference]): bool =
    match target[0] with
    case None -> source.is_empty()
    case Some { targetArgument } ->
        match source[0] with
        case None -> false
        case Some { sourceArgument } -> type_assignable(targetArgument, sourceArgument) & type_arguments_assignable(target[1:], source[1:])

/// Checks whether ordinary call arguments can be emitted by the target backend.
private fun ordinary_call_arguments_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression _ -> false
        case _ -> expression_emittable(expression, env, module, allModules) & ordinary_call_arguments_emittable(expressions[1:], env, module, allModules)

/// Checks whether a call has the callable name shape.
private fun java_callable_name(name: String): bool =
    !(name ? "/") & !(name ? ".") & !(name ? "`")

/// Checks whether method is supported by the current backend.
private fun java_method_supported(name: String): bool =
    name == "is_equal_to" | name == "is_true" | name == "is_false"
        | name == "is_greater_than" | name == "is_less_than"
        | name == "is_greater_or_equals_than" | name == "is_less_or_equals_than"
        | name == "is_zero" | name == "is_one"
        | name == "starts_with" | name == "does_not_start_with" | name == "end_with" | name == "contains"
        | name == "has_size" | name == "succeeds" | name == "fails"
        | name == "succeeded" | name == "failed"
        | name == "replace" | name == "trim" | name == "size"

/// Formats type metadata text for type.
private fun java_type(type: CompiledTypeReference): String =
    let primitive_type = primitive_java_type_name(type.name)
    if type.name == "array" then java_type(first_type_argument(type)) + "[]"
    else if !primitive_type.is_empty() then primitive_type
    else boxed_java_type(type)

/// Computes the compiled type for boxed Java.
private fun boxed_java_type(type: CompiledTypeReference): String =
    let primitive_type = boxed_primitive_java_type_name(type.name)
    let simple_type = simple_java_type_name(type.name)
    if function_type(type) then java_functional_type(type)
    else if type.name == "array" then java_type(first_type_argument(type)) + "[]"
    else if java_object_type(type) then java_object_type_java_name(type)
    else if !primitive_type.is_empty() then primitive_type
    else if boxed_container_java_type_name(type.name) then boxed_container_java_type(type.name, boxed_java_type(first_type_argument(type)))
    else if type.name == "Tuple" then "java.util.List<?>"
    else if type.name == "Effect" then "capy.lang.Effect<" + generic_argument_java_type(first_type_argument(type)) + ">"
    else if type.name == "Async" then "capy.lang.Async<" + generic_argument_java_type(first_type_argument(type)) + ">"
    else if !simple_type.is_empty() then simple_type
    else "java.lang.Object"

/// Computes the compiled type for top level Java.
private fun top_level_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let primitive_type = primitive_java_type_name(type.name)
    if type.name == "array" then top_level_java_type(first_type_argument(type), module, allModules) + "[]"
    else if !primitive_type.is_empty() then primitive_type
    else top_level_boxed_java_type(type, module, allModules)

/// Computes the compiled type for top level boxed Java.
private fun top_level_boxed_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let primitive_type = boxed_primitive_java_type_name(type.name)
    let simple_type = simple_java_type_name(type.name)
    if function_type(type) then top_level_java_functional_type(type, module, allModules)
    else if type.name == "array" then top_level_java_type(first_type_argument(type), module, allModules) + "[]"
    else if java_object_type(type) then java_object_type_java_name(type)
    else if !primitive_type.is_empty() then primitive_type
    else if boxed_container_java_type_name(type.name) then boxed_container_java_type(type.name, top_level_boxed_java_type(first_type_argument(type), module, allModules))
    else if type.name == "Tuple" then "java.util.List<?>"
    else if type.name == "Effect" then "capy.lang.Effect<" + top_level_generic_argument_java_type(first_type_argument(type), module, allModules) + ">"
    else if type.name == "Async" then "capy.lang.Async<" + top_level_generic_argument_java_type(first_type_argument(type), module, allModules) + ">"
    else if !simple_type.is_empty() then simple_type
    else match top_level_data_type_java_name(type, module, allModules) with
        case Some { name } -> name
        case None -> "java.lang.Object"

/// Computes the type name for primitive Java.
private fun primitive_java_type_name(name: String): String =
    if name == "void" then "void"
    else if name == "byte" then "byte"
    else if name == "int" then "int"
    else if name == "long" then "long"
    else if name == "float" then "float"
    else if name == "double" then "double"
    else if name == "bool" then "boolean"
    else ""

/// Computes the type name for boxed primitive Java.
private fun boxed_primitive_java_type_name(name: String): String =
    if name == "byte" then "java.lang.Byte"
    else if name == "int" then "java.lang.Integer"
    else if name == "long" then "java.lang.Long"
    else if name == "float" then "java.lang.Float"
    else if name == "double" then "java.lang.Double"
    else if name == "bool" then "java.lang.Boolean"
    else ""

/// Computes the compiled type for boxed container Java.
private fun boxed_container_java_type(name: String, argument: String): String =
    if name == "List" then "java.util.List<" + argument + ">"
    else if name == "Set" then "java.util.Set<" + argument + ">"
    else if name == "Dict" then "java.util.Map<java.lang.String, " + argument + ">"
    else if option_type_name(name) then "java.util.Optional<" + argument + ">"
    else if name == "Supplier" then "java.util.function.Supplier<" + argument + ">"
    else ""

/// Checks whether a type reference matches the boxed container Java type name rule.
private fun boxed_container_java_type_name(name: String): bool =
    name == "List" | name == "Set" | name == "Dict" | option_type_name(name) | name == "Supplier"

/// Computes the type name for simple Java.
private fun simple_java_type_name(name: String): String =
    if name == "String" then "java.lang.String"
    else if name == "Assert" then "java.lang.Object"
    else if name == "TestFile" then "java.lang.Object"
    else if name == "TestCase" then "java.lang.Object"
    else if name == "/capy/lang/Program" then "capy.lang.Program"
    else if stdlib_date_time_type_name(name) then stdlib_date_time_java_type(name)
    else ""

/// Computes the compiled type for top level Java functional.
private fun top_level_java_functional_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = function_type_parameters(type)
    let returnType = function_type_return_type(type)
    if parameters.is_empty()
    then "java.util.function.Supplier<" + top_level_boxed_java_type(returnType, module, allModules) + ">"
    else if parameters.size().value == 1
    then "java.util.function.Function<" + top_level_boxed_java_type(function_type_parameter_at(parameters, 0), module, allModules) + ", " + top_level_boxed_java_type(returnType, module, allModules) + ">"
    else if parameters.size().value == 2
    then "java.util.function.BiFunction<" + top_level_boxed_java_type(function_type_parameter_at(parameters, 0), module, allModules) + ", " + top_level_boxed_java_type(function_type_parameter_at(parameters, 1), module, allModules) + ", " + top_level_boxed_java_type(returnType, module, allModules) + ">"
    else "java.lang.Object"

/// Computes the compiled type for top level generic argument Java.
private fun top_level_generic_argument_java_type(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if type_parameter(type) then "?" else top_level_boxed_java_type(type, module, allModules)

/// Computes the name for top level data type Java.
private fun top_level_data_type_java_name(type: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    /capy/lang/Option.None {}

/// Computes the name for top level qualified data type Java.
private fun top_level_qualified_data_type_java_name(typeName: String, memberName: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let className = if qualified_call_name(typeName) then qualified_call_class_name(typeName, module) else path_to_class(java_generator_normalize_import_module_path(typeName))
    match find_module_by_class(className, allModules) with
    case Some { owner } -> /capy/lang/Option.Some { top_level_owned_data_type_java_name(memberName, module, owner) }
    case None -> /capy/lang/Option.Some { if type_unqualified_name(className) == memberName then className else className + "." + java_identifier(memberName) }

/// Computes the name for top level owned data type Java.
private fun top_level_owned_data_type_java_name(name: String, current: CompiledModule, owner: CompiledModule): String =
    let ownerPackage = module_package_fqcn(owner)
    let currentPackage = module_package_fqcn(current)
    let ownerClass = if ownerPackage.is_empty() then java_identifier(owner.name) else ownerPackage + "." + java_identifier(owner.name)
    let ownedName = if owner.name == name then ownerClass else ownerClass + "." + java_identifier(name)
    if ownerPackage == currentPackage
    then if owner.name == name then java_identifier(name) else java_identifier(owner.name) + "." + java_identifier(name)
    else ownedName

/// Formats source text for module package fully qualified class name.
private fun module_package_fqcn(module: CompiledModule): String =
    if module.path.is_empty() then "" else module.path.replace("/", ".")

/// Checks whether a type reference matches the function type rule.
private fun function_type(type: CompiledTypeReference): bool =
    type.name ? "=>"

/// Computes the Java type for functional.
private fun java_functional_type(type: CompiledTypeReference): String =
    let parameters = function_type_parameters(type)
    let returnType = function_type_return_type(type)
    if parameters.is_empty()
    then "java.util.function.Supplier<" + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 1
    then "java.util.function.Function<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 2
    then "java.util.function.BiFunction<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 3
    then "__CapyFunction3<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 2)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 4
    then "__CapyFunction4<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 2)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 3)) + ", " + boxed_java_type(returnType) + ">"
    else "java.lang.Object"

/// Formats function type parameters for generated emission.
private fun function_type_parameters(type: CompiledTypeReference): List[CompiledTypeReference] =
    let text = function_type_parameter_text(type)
    if text == "()"
    then []
    else function_type_parameter_list(function_type_parameter_inner_text(text))

/// Formats type metadata text for function type parameter text.
private fun function_type_parameter_text(type: CompiledTypeReference): String =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0 then "" else type.name[0, arrow]

/// Formats type metadata text for function type parameter inner text.
private fun function_type_parameter_inner_text(text: String): String =
    if java_generator_string_has_prefix(text, "(")
    then text[1, text.size().value - 1]
    else text

/// Collects function type parameter list for compiler processing.
private fun function_type_parameter_list(text: String): List[CompiledTypeReference] =
    if text.trim().is_empty()
    then []
    else schema_type_arguments(text)

/// Computes the compiled type for function type return.
private fun function_type_return_type(type: CompiledTypeReference): CompiledTypeReference =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0
    then object_type()
    else schema_type_reference(type.name[arrow + 2, type.name.size().value])

/// Resolves type metadata for function type parameter at.
private fun function_type_parameter_at(parameters: List[CompiledTypeReference], idx: int): CompiledTypeReference =
    match parameters[idx] with
    case Some { parameter } -> parameter
    case None -> object_type()

/// Computes the Java type for seq.
private fun java_seq_type(type: CompiledTypeReference): String =
    "capy.collection.Seq<" + boxed_java_type(first_type_argument(type)) + ">"

/// Formats one first type argument for generated emission.
private fun first_type_argument(type: CompiledTypeReference): CompiledTypeReference =
    match type.arguments[0] with
    case None -> object_type()
    case Some { argument } -> argument

/// Computes the compiled type for generic argument Java.
private fun generic_argument_java_type(type: CompiledTypeReference): String =
    if type_parameter(type) then "?" else boxed_java_type(type)

/// Checks whether a type reference matches the type parameter rule.
private fun type_parameter(type: CompiledTypeReference): bool =
    type.arguments.is_empty() & type.name.size().value == 1 & single_uppercase_name(type.name)

/// Checks whether the current value satisfies the single uppercase name rule for compiler processing.
private fun single_uppercase_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

/// Checks whether the current value satisfies the result success literal rule for compiler processing.
private fun result_success_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Result.Success"
        | typeName == "Result.Success"
        | (typeName == "Success" & result_member_imported("Success", imports))

/// Checks whether the current value satisfies the result error literal rule for compiler processing.
private fun result_error_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Result.Error"
        | typeName == "Result.Error"
        | (typeName == "Error" & result_member_imported("Error", imports))

private fun result_error_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "error" | call.name == "error_kind"
    then !function_defined(call.name, module.functions) & result_member_imported(call.name, module.imports)
    else false

private fun result_error_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "error"
    then one_string_argument(call.arguments, env, module, allModules)
    else two_string_arguments(call.arguments, env, module, allModules)

private fun one_string_argument(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & type_assignable(string_type(), expression_type(argument, env, module, allModules))
            & expression_emittable(argument, env, module, allModules)

private fun two_string_arguments(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { first } ->
        match arguments[1] with
        case None -> false
        case Some { second } ->
            arguments[2:].is_empty()
                & type_assignable(string_type(), expression_type(first, env, module, allModules))
                & type_assignable(string_type(), expression_type(second, env, module, allModules))
                & expression_emittable(first, env, module, allModules)
                & expression_emittable(second, env, module, allModules)

/// Checks whether the current value satisfies the program success literal rule for compiler processing.
private fun program_success_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Success"
        | typeName == "Program.Success"
        | (typeName == "Success" & program_member_imported("Success", imports))

/// Checks whether the current value satisfies the program failed literal rule for compiler processing.
private fun program_failed_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Failed"
        | typeName == "Program.Failed"
        | (typeName == "Failed" & program_member_imported("Failed", imports))

/// Checks whether program member is imported into the current module scope.
private fun program_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Program", "capy/lang/Program")

/// Checks whether effect member is imported into the current module scope.
private fun effect_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Effect", "capy/lang/Effect")

/// Checks whether async member is imported into the current module scope.
private fun async_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Async", "capy/lang/Async")

/// Checks whether system member is imported into the current module scope.
private fun system_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/System", "capy/lang/System")

/// Checks whether clock member is imported into the current module scope.
private fun clock_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/date_time/Clock", "capy/date_time/Clock")

/// Checks whether result member is imported into the current module scope.
private fun result_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Result", "capy/lang/Result")

/// Checks whether seq member is imported into the current module scope.
private fun seq_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/collection/Seq", "capy/collection/Seq")

/// Checks whether reflection member is imported into the current module scope.
private fun reflection_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/meta_prog/Reflection", "capy/meta_prog/Reflection")

/// Checks whether the current value satisfies the console print name rule for compiler processing.
private fun console_print_name(name: String): bool =
    name == "print" | name == "println" | name == "print_error" | name == "println_error"

/// Emits generated code for console print call.
private fun console_print_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    if argumentType.name == "Effect"
    then expression_code(argumentExpression, env, argumentType, module, allModules)
        + ".map(__capy_console_value -> dev.capylang.ConsoleUtil." + console_util_method(call.name) + "(__capy_console_value))"
    else
        let valueCode = expression_code(argumentExpression, env, argumentType, module, allModules)
        "capy.lang.Effect.delay(() -> { var __capy_console_value = " + valueCode + "; "
            + "return dev.capylang.ConsoleUtil." + console_util_method(call.name) + "(__capy_console_value); })"

/// Computes the compiled type for console print call.
private fun console_print_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if argumentType.name == "Effect"
    then argumentType
    else effect_type(argumentType)

/// Checks whether a call has the console read line call shape.
private fun console_read_line_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "read_line" & call.arguments.is_empty() & console_member_imported("read_line", module.imports)

/// Checks whether console member is imported into the current module scope.
private fun console_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/Console", "capy/io/Console")
        | module_member_imported(member, imports, "/capy/io/Stdout", "capy/io/Stdout")

/// Checks whether standard-library I/O member is imported into the current module scope.
private fun stdlib_io_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/IO", "capy/io/IO")

/// Checks whether standard-library path member is imported into the current module scope.
private fun stdlib_path_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/Path", "capy/io/Path")

/// Checks whether module member is imported into the current module scope.
private fun module_member_imported(member: String, imports: List[CompiledImportDeclaration], absoluteModulePath: String, relativeModulePath: String): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.modulePath == absoluteModulePath | declaration.modulePath == relativeModulePath
        then if import_includes_name(member, declaration) then true else module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)
        else module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)

/// Formats source text for console util method.
private fun console_util_method(name: String): String =
    if name == "print_error"
    then "printError"
    else if name == "println_error"
    then "printlnError"
    else name

/// Checks whether a type reference matches the test file test case list type rule.
private fun test_file_test_case_list_type(type: CompiledTypeReference): bool =
    type.name == "TestCase" | (type.name == "Effect" & first_type_argument(type).name == "TestCase")

/// Emits generated code for test file tests.
private fun test_file_tests_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledListLiteral literal -> "java.util.List.of(" + test_file_test_elements_code(literal.values, env, module, allModules) + ")"
    case _ ->
        let testsType = expression_type(expression, env, module, allModules)
        if testsType.name == "List" & first_type_argument(testsType).name == "Effect" & first_type_argument(first_type_argument(testsType)).name == "TestCase"
        then expression_code(expression, env, list_type(effect_type(test_case_type())), module, allModules)
            + ".stream().map((capy.lang.Effect<java.lang.Object> __capy_effect_test_case) -> __capy_effect_test_case.unsafeRun()).toList()"
        else expression_code(expression, env, list_type(test_case_type()), module, allModules)

/// Emits generated code for test file test elements.
private fun test_file_test_elements_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        test_file_test_element_code(expression, env, module, allModules)
        + test_file_test_elements_tail_code(expressions[1:], env, module, allModules)

/// Emits generated code for test file test elements tail.
private fun test_file_test_elements_tail_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + test_file_test_element_code(expression, env, module, allModules)
        + test_file_test_elements_tail_code(expressions[1:], env, module, allModules)

/// Emits generated code for test file test element.
private fun test_file_test_element_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(expression, env, module, allModules)
    if type.name == "Effect" & first_type_argument(type).name == "TestCase"
    then lazy_effect_test_case_code(expression, env, module, allModules)
    else expression_code(expression, env, test_case_type(), module, allModules)

/// Emits generated code for lazy effect test case.
private fun lazy_effect_test_case_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledMethodCallExpression call ->
        if call.name == "map"
        then lazy_effect_map_test_case_code(expression, call, env, module, allModules)
        else eager_effect_test_case_code(expression, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

/// Emits generated code for lazy effect map test case.
private fun lazy_effect_map_test_case_code(expression: CompiledExpression, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda -> lazy_effect_test_case_lambda_code(expression, lambda, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

/// Emits generated code for lazy effect test case lambda.
private fun lazy_effect_test_case_lambda_code(expression: CompiledExpression, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match lambda.body with
    case CompiledFunctionCallExpression testCall ->
        if testCall.name == "test"
        then "__capy_data(\"TestCase\", java.util.Map.ofEntries(java.util.Map.entry(\"name\", "
            + expression_code(argument(testCall.arguments, 0), env, string_type(), module, allModules)
            + "), java.util.Map.entry(\"result\", __capy_data(\"Passed\", java.util.Map.of())), java.util.Map.entry(\"assertions_count\", 0), java.util.Map.entry(\"execution_time\", 0.0), java.util.Map.entry(\"assert_supplier\", (java.util.function.Supplier<java.lang.Object>) (() -> ((java.util.function.Supplier<java.lang.Object>) __capy_data_field("
            + expression_code(expression, env, effect_type(test_case_type()), module, allModules)
            + ".unsafeRun(), \"assert_supplier\")).get()))))"
        else eager_effect_test_case_code(expression, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

/// Emits generated code for eager effect test case.
private fun eager_effect_test_case_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(expression, env, effect_type(test_case_type()), module, allModules) + ".unsafeRun()"

/// Checks whether a call has the qualified call name shape.
private fun qualified_call_name(name: String): bool =
    let idx = last_dot_index(name)
    idx > 0 & idx < name.size().value - 1

/// Emits expression text for qualified call member.
private fun qualified_call_member(name: String): String =
    name[last_dot_index(name) + 1, name.size().value]

/// Emits expression text for qualified call qualifier.
private fun qualified_call_qualifier(name: String): String =
    name[0, last_dot_index(name)]

/// Computes the name for qualified call class.
private fun qualified_call_class_name(name: String, module: CompiledModule): String =
    let qualifier = qualified_call_qualifier(name)
    if java_generator_string_has_prefix(qualifier, "/")
    then path_to_class(java_generator_normalize_import_module_path(qualifier))
    else if qualifier ? "/"
    then path_to_class(java_generator_normalize_import_module_path(qualifier))
    else imported_module_class(module, qualifier)

/// Computes the name for module class leaf.
private fun module_class_leaf_name(className: String): String =
    let idx = last_dot_index(className)
    if idx < 0 then className else className[idx + 1, className.size().value]

/// Finds a qualified function in available declarations, imports, or modules.
private fun find_qualified_function(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_qualified_function_binding(name, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding.function }
    case None -> /capy/lang/Option.None {}

/// Finds a qualified function binding in available declarations, imports, or modules.
private fun find_qualified_function_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaQualifiedFunctionBinding] =
    let className = qualified_call_class_name(name, module)
    let member = qualified_call_member(name)
    if absolute_qualified_call_name(name)
    then find_qualified_function_binding_in_class(className, member, allModules)
    else match find_qualified_function_binding_in_imports(
            className,
            member,
            module.imports,
            module,
            allModules
        ) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> find_qualified_function_binding_in_class(className, member, allModules)

/// Checks whether a call has the absolute qualified call name shape.
private fun absolute_qualified_call_name(name: String): bool =
    java_generator_string_has_prefix(name, "/")

/// Finds a qualified function binding in class in available declarations, imports, or modules.
private fun find_qualified_function_binding_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[JavaQualifiedFunctionBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> {
        match find_function(member, importedModule.functions) with
        case Some { function } -> /capy/lang/Option.Some { JavaQualifiedFunctionBinding { module: importedModule, function: function } }
        case None -> /capy/lang/Option.None {}
    }
    case _ -> /capy/lang/Option.None {}

/// Finds a qualified function binding in imports in available declarations, imports, or modules.
private fun find_qualified_function_binding_in_imports(className: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaQualifiedFunctionBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !stdlib_import(declaration.modulePath) & imported_module_class(module, declaration.modulePath) == className
        then find_qualified_function_binding_in_import(className, member, imports[1:], module, allModules)
        else find_qualified_function_binding_in_imports(className, member, imports[1:], module, allModules)

/// Finds a qualified function binding in import in available declarations, imports, or modules.
private fun find_qualified_function_binding_in_import(className: String, member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaQualifiedFunctionBinding] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_qualified_function_binding_in_module(member, rest, module, allModules, importedModule)
    case _ -> find_qualified_function_binding_in_imports(className, member, rest, module, allModules)

/// Finds a qualified function binding in a module in available declarations, imports, or modules.
private fun find_qualified_function_binding_in_module(member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[JavaQualifiedFunctionBinding] =
    match find_function(member, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { JavaQualifiedFunctionBinding { module: importedModule, function: function } }
    case _ -> find_qualified_function_binding_in_imports(module_fqcn(importedModule), member, rest, module, allModules)

/// Computes the compiled type for int.
private fun int_type(): CompiledTypeReference = CompiledTypeReference { name: "int", arguments: [] }
/// Computes the compiled type for byte.
private fun byte_type(): CompiledTypeReference = CompiledTypeReference { name: "byte", arguments: [] }
/// Computes the compiled type for long.
private fun long_type(): CompiledTypeReference = CompiledTypeReference { name: "long", arguments: [] }
/// Computes the compiled type for float.
private fun float_type(): CompiledTypeReference = CompiledTypeReference { name: "float", arguments: [] }
/// Computes the compiled type for double.
private fun double_type(): CompiledTypeReference = CompiledTypeReference { name: "double", arguments: [] }
/// Computes the compiled type for boolean.
private fun bool_type(): CompiledTypeReference = CompiledTypeReference { name: "bool", arguments: [] }
/// Computes the compiled type for string.
private fun string_type(): CompiledTypeReference = CompiledTypeReference { name: "String", arguments: [] }
/// Returns the canonical compiler type reference for `Nothing`.
private fun nothing_type(): CompiledTypeReference = CompiledTypeReference { name: "nothing", arguments: [] }
/// Computes the compiled type for object.
private fun object_type(): CompiledTypeReference = CompiledTypeReference { name: "any", arguments: [] }
/// Computes the compiled type for error.
private fun error_type(): CompiledTypeReference = CompiledTypeReference { name: "/capy/lang/Result.Error", arguments: [] }
/// Computes the compiled type for assert.
private fun assert_type(): CompiledTypeReference = CompiledTypeReference { name: "Assert", arguments: [] }
/// Computes the compiled type for test file.
private fun test_file_type(): CompiledTypeReference = CompiledTypeReference { name: "TestFile", arguments: [] }
/// Computes the compiled type for test case.
private fun test_case_type(): CompiledTypeReference = CompiledTypeReference { name: "TestCase", arguments: [] }
/// Computes the compiled type for list.
private fun list_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "List", arguments: [arg] }
/// Computes the compiled type for set.
private fun set_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Set", arguments: [arg] }
/// Computes the compiled type for dict.
private fun dict_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Dict", arguments: [arg] }
/// Computes the compiled type for tuple.
private fun tuple_type(args: List[CompiledTypeReference]): CompiledTypeReference = CompiledTypeReference { name: "Tuple", arguments: args }
/// Computes the compiled type for seq.
private fun seq_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Seq", arguments: [arg] }
/// Computes the compiled type for async.
private fun async_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Async", arguments: [arg] }
/// Computes the compiled type for effect.
private fun effect_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Effect", arguments: [arg] }
/// Computes the compiled type for supplier.
private fun supplier_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Supplier", arguments: [arg] }
/// Computes the compiled type for regex match.
private fun regex_match_type(): CompiledTypeReference = CompiledTypeReference { name: "Match", arguments: [] }
/// Computes the compiled type for string to string function.
private fun string_to_string_function_type(): CompiledTypeReference = CompiledTypeReference { name: "String=>String", arguments: [] }

/// Checks whether a type reference matches the regex type name rule.
private fun regex_type_name(name: String): bool =
    name == "Regex" | name == "/capy/lang/Regex" | name == "capy/lang/Regex" | name == "capy.lang.Regex"

/// Creates generated-module entries for test runtime.
private fun test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    let gather = test_gather_calls(modules, modules)
    if gather.is_empty()
    then []
    else [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.java",
        code: "package capy.test;" + newline() + newline()
            + "public final class CapyTestRuntime {" + newline()
            + "    private CapyTestRuntime() " + "{" + "}" + newline() + newline()
            + "    public static java.util.List<java.lang.Object> gatherTests() {" + newline()
            + "        return java.util.List.of(" + gather + ");" + newline()
            + "    }" + newline()
            + "}" + newline()
    }]

/// Emits expression text for test gather calls.
private fun test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        let calls = test_gather_calls_for_module(module.functions, module, allModules)
        let rest = test_gather_calls(modules[1:], allModules)
        join_non_empty(calls, rest)

/// Emits expression text for test gather calls for a module.
private fun test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if function.name == "tests"
        then
            let current = module_fqcn(module) + ".tests().unsafeRun()"
            join_non_empty(current, test_gather_calls_for_module(functions[1:], module, allModules))
        else test_gather_calls_for_module(functions[1:], module, allModules)

/// Checks whether test function can be emitted by the target backend.
private fun test_function_emittable(function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match function.body with
    case CompiledBlockExpression block ->
        let returnType = effective_function_return_type(function, module, allModules)
        if effect_block_emittable(block.bindings, block.result, env, returnType, module, allModules)
        then true
        else expression_emittable(function.body, env, module, allModules)
    case _ -> expression_emittable(function.body, env, module, allModules)

/// Formats source text for join non empty.
private fun join_non_empty(first: String, second: String): String =
    if first.is_empty() then second
    else if second.is_empty() then first
    else first + ", " + second

/// Formats source text for module fully qualified class name.
private fun module_fqcn(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path.replace("/", ".") + "." + module.name

/// Formats source text for module source file.
private fun module_source_file(module: CompiledModule): String =
    if module.path.is_empty()
    then "/" + module.name + ".cfun"
    else "/" + module.path + "/" + module.name + ".cfun"

/// Emits Java runtime helper source for helpers.
private fun java_helpers(module: CompiledModule): String =
    if module.functions.is_empty()
    then ""
    else java_base_helpers() + java_collection_helpers() + java_truthy_helper()

/// Emits Java runtime helper source for base helpers.
private fun java_base_helpers(): String =
    java_pow_helpers()
        + java_data_helpers()
        + java_option_result_helpers()
        + java_regex_helpers()
        + java_parse_helpers()

/// Emits Java runtime helper source for pow helpers.
private fun java_pow_helpers(): String =
    "    private static int __capy_pow_int(int base, int exponent) {" + newline()
        + "        if (exponent <= 0) {" + newline()
        + "            return 1;" + newline()
        + "        }" + newline()
        + "        int result = 1;" + newline()
        + "        for (int i = 0; i < exponent; i++) {" + newline()
        + "            result *= base;" + newline()
        + "        }" + newline()
        + "        return result;" + newline()
        + "    }" + newline() + newline()
        + "    private static long __capy_pow_long(long base, long exponent) {" + newline()
        + "        if (exponent <= 0L) {" + newline()
        + "            return 1L;" + newline()
        + "        }" + newline()
        + "        long result = 1L;" + newline()
        + "        for (long i = 0L; i < exponent; i++) {" + newline()
        + "            result *= base;" + newline()
        + "        }" + newline()
        + "        return result;" + newline()
        + "    }" + newline() + newline()
        + "    private static <T> T unsupported(java.lang.String source) {" + newline()
        + "        throw new UnsupportedOperationException(\"Unsupported CFUN expression: \" + source);" + newline()
        + "    }" + newline() + newline()
        + "    private static <T> T __capy_not_implemented(java.lang.String message) {" + newline()
        + "        throw new UnsupportedOperationException(message);" + newline()
        + "    }" + newline() + newline()

/// Emits Java runtime helper source for data helpers.
private fun java_data_helpers(): String =
    "    private static java.util.Map<java.lang.String, java.lang.Object> __capy_data(java.lang.String type, java.util.Map<java.lang.String, ?> fields) {" + newline()
        + "        java.util.Map<java.lang.String, java.lang.Object> result = new java.util.LinkedHashMap<>() {" + newline()
        + "            @Override" + newline()
        + "            public java.lang.String toString() {" + newline()
        + "                return __capy_data_to_string(this);" + newline()
        + "            }" + newline()
        + "        };" + newline()
        + "        result.put(\"__type\", type);" + newline()
        + "        result.putAll(fields);" + newline()
        + "        return java.util.Collections.unmodifiableMap(result);" + newline()
        + "    }" + newline() + newline()
        + "    private static java.lang.String __capy_data_to_string(java.util.Map<java.lang.String, ?> data) {" + newline()
        + "        java.lang.String type = java.lang.String.valueOf(data.get(\"__type\"));" + newline()
        + "        java.lang.StringBuilder builder = new java.lang.StringBuilder(type).append(\" {\");" + newline()
        + "        java.util.List<java.lang.String> keys = new java.util.ArrayList<>(data.keySet());" + newline()
        + "        keys.remove(\"__type\");" + newline()
        + "        java.util.Collections.sort(keys);" + newline()
        + "        boolean first = true;" + newline()
        + "        for (java.lang.String key : keys) {" + newline()
        + "            if (!first) {" + newline()
        + "                builder.append(\", \");" + newline()
        + "            }" + newline()
        + "            builder.append(key).append(\"=\").append(__capy_render_value(data.get(key)));" + newline()
        + "            first = false;" + newline()
        + "        }" + newline()
        + "        return builder.append(\"}\").toString();" + newline()
        + "    }" + newline() + newline()
        + "    private static java.lang.String __capy_render_value(java.lang.Object value) {" + newline()
        + "        return java.lang.String.valueOf(value);" + newline()
        + "    }" + newline() + newline()
        + "    private static boolean __capy_data_is(java.lang.Object value, java.lang.String type) {" + newline()
        + "        return value instanceof java.util.Map<?, ?> map && type.equals(map.get(\"__type\"));" + newline()
        + "    }" + newline() + newline()
        + "    private static boolean __capy_data_is_any(java.lang.Object value) {" + newline()
        + "        return value instanceof java.util.Map<?, ?> map && map.containsKey(\"__type\");" + newline()
        + "    }" + newline() + newline()
        + "    private static java.lang.String __capy_data_type(java.lang.Object value) {" + newline()
        + "        if (value instanceof java.util.Map<?, ?> map && map.get(\"__type\") instanceof java.lang.String type) {" + newline()
        + "            return type;" + newline()
        + "        }" + newline()
        + "        return \"\";" + newline()
        + "    }" + newline() + newline()
        + "    private static boolean __capy_enum_is(java.lang.Object value) {" + newline()
