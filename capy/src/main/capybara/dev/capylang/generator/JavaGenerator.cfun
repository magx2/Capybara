from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledFunctionReferenceExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression, CompiledWithExpression }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from /dev/capylang/generator/GeneratedModule import { GeneratedModule }
from /dev/capylang/generator/GeneratedProgram import { GeneratedProgram }

data JavaBinding { name: String, typeReference: CompiledTypeReference, javaName: String }
data JavaStdlibValue { javaName: String, typeReference: CompiledTypeReference }

const JAVA_IDENTIFIER_START = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_"
const JAVA_IDENTIFIER_PART = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
const JAVA_RESERVED_WORDS = "|abstract|assert|boolean|break|byte|case|catch|char|class|const|continue|default|do|double|else|enum|extends|final|finally|float|for|goto|if|implements|import|instanceof|int|interface|long|native|new|package|private|protected|public|return|short|static|strictfp|super|switch|synchronized|this|throw|throws|transient|try|void|volatile|while|true|false|null|var|record|yield|sealed|permits|_|"

fun java_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: java_modules(program.modules, program.modules) + test_runtime_modules(program.modules)
    }

private fun java_modules(modules: List[CompiledModule], allModules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: java_module_relative_path(module, ".java"),
        code: java_module_code(module, allModules)
    }] + java_modules(modules[1:], allModules)

private fun java_module_code(module: CompiledModule, allModules: List[CompiledModule]): String =
    java_package(module)
    + java_imports(module, allModules)
    + "public final class " + module.name + " {" + newline()
    + "    private " + module.name + "() " + "{" + "}" + newline() + newline()
    + java_function_type_interfaces()
    + java_constants(constant_functions(module.functions), [], module, allModules)
    + java_functions(module.functions, module, allModules)
    + java_helpers(module)
    + "}" + newline()

private fun java_function_type_interfaces(): String =
    "    @FunctionalInterface" + newline()
    + "    private interface __CapyFunction3<A, B, C, R> {" + newline()
    + "        R apply(A a, B b, C c);" + newline()
    + "    }" + newline() + newline()
    + "    @FunctionalInterface" + newline()
    + "    private interface __CapyFunction4<A, B, C, D, R> {" + newline()
    + "        R apply(A a, B b, C c, D d);" + newline()
    + "    }" + newline() + newline()

private fun java_imports(module: CompiledModule, allModules: List[CompiledModule]): String =
    "import java.util.*;" + newline()
    + "import java.util.function.*;" + newline()
    + static_imports(module.imports, module, allModules)
    + newline()

private fun static_imports(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        let className = imported_module_class(module, declaration.modulePath)
        if stdlib_import(declaration.modulePath) | declaration.qualified
        then static_imports(imports[1:], module, allModules)
        else match find_module_by_class(className, allModules) with
            case Some { importedModule } ->
                static_import_declaration(declaration, className, importedModule.functions)
                    + static_imports(imports[1:], module, allModules)
            case None -> static_imports(imports[1:], module, allModules)

private fun static_import_declaration(declaration: CompiledImportDeclaration, className: String, functions: List[CompiledFunction]): String =
    if declaration.wildcard & declaration.excludedNames.is_empty()
    then "import static " + className + ".*;" + newline()
    else explicit_static_imports(functions, declaration, className)

private fun explicit_static_imports(functions: List[CompiledFunction], declaration: CompiledImportDeclaration, className: String): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if static_import_function(function, declaration)
        then "import static " + className + "." + java_function_name(function) + ";" + newline()
            + explicit_static_imports(functions[1:], declaration, className)
        else explicit_static_imports(functions[1:], declaration, className)

private fun static_import_function(function: CompiledFunction, declaration: CompiledImportDeclaration): bool =
    !compiled_schema(function)
        & function.visibility != "private"
        & function.visibility != "const:private"
        & import_includes_name(function.name, declaration)

private fun stdlib_import(modulePath: String): bool =
    java_generator_string_has_prefix(modulePath, "/capy/") | java_generator_string_has_prefix(modulePath, "capy/")

private fun imported_module_class(module: CompiledModule, modulePath: String): String =
    if java_generator_string_has_prefix(modulePath, "/")
    then path_to_class(modulePath[1, modulePath.size()])
    else if modulePath ? "/"
    then path_to_class(modulePath)
    else if module.path.is_empty()
    then modulePath
    else module.path.replace("/", ".") + "." + modulePath

private fun path_to_class(path: String): String =
    path.replace("/", ".")

private fun java_generator_string_has_prefix(value: String, prefix: String): bool =
    java_generator_string_has_prefix_at(value, prefix, 0)

private fun java_generator_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then java_generator_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun java_constants(constants: List[CompiledFunction], previous: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match constants[0] with
    case None -> if previous.is_empty() then "" else newline()
    case Some { constant } ->
        java_constant(constant, constant_bindings(previous, module, allModules), module, allModules)
        + java_constants(constants[1:], [constant] + previous, module, allModules)

private fun java_constant(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = constant_type(constant, env, module, allModules)
    "    " + constant_java_visibility(constant) + "static final " + java_type(type) + " " + java_identifier(constant.name)
    + " = " + expression_code(constant.body, env, type, module, allModules) + ";" + newline()

private fun constant_type(constant: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if constant.returnType.name.is_empty()
    then expression_type(constant.body, env, module, allModules)
    else constant.returnType

private fun constant_bindings(constants: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match constants[0] with
    case None -> []
    case Some { constant } ->
        let rest = constant_bindings(constants[1:], module, allModules)
        [java_binding(constant.name, constant_type(constant, rest, module, allModules))] + rest

private fun java_binding(name: String, typeReference: CompiledTypeReference): JavaBinding =
    JavaBinding { name: name, typeReference: typeReference, javaName: java_identifier(name) }

private fun java_binding_with_java_name(name: String, typeReference: CompiledTypeReference, javaName: String): JavaBinding =
    JavaBinding { name: name, typeReference: typeReference, javaName: javaName }

private fun constant_functions(functions: List[CompiledFunction]): List[CompiledFunction] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_constant(function) & !compiled_schema(function)
        then [function] + constant_functions(functions[1:])
        else constant_functions(functions[1:])

private fun compiled_constant(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:")

private fun compiled_schema(function: CompiledFunction): bool =
    java_generator_string_has_prefix(function.visibility, "const:schema")

private fun constant_java_visibility(function: CompiledFunction): String =
    java_visibility_prefix(function.visibility.replace("const:", ""))

private fun java_functions(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if compiled_constant(function)
        then java_functions(functions[1:], module, allModules)
        else java_function(function, module, allModules) + newline() + java_functions(functions[1:], module, allModules)

private fun java_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    let returnTypeReference = effective_function_return_type(function, module, allModules)
    let returnType = java_type(returnTypeReference)
    let env = java_function_bindings(function) + constant_bindings(constant_functions(module.functions), module, allModules)
    "    " + java_visibility_prefix(function.visibility) + "static " + returnType + " " + java_function_name(function) + "(" + java_function_parameters(function) + ") {" + newline()
    + java_function_body(function, returnTypeReference, env, module, allModules)
    + "    }" + newline()

private fun java_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else java_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

private fun java_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_function(name, module.functions) with
    case Some { function } -> java_function_name(function)
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> java_function_name(function)
        case None -> java_identifier(name)

private fun extension_method_function(function: CompiledFunction): bool =
    last_dot_index(function.name) >= 0

private fun method_receiver_type(function: CompiledFunction): CompiledTypeReference =
    schema_type_reference(method_owner_name(function.name))

private fun method_owner_name(name: String): String =
    let idx = last_dot_index(name)
    if idx < 0 then "" else name[0, idx]

private fun method_member_name(name: String): String =
    let idx = last_dot_index(name)
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun last_dot_index(name: String): int =
    last_dot_index_from(name, 0, -1)

private fun last_dot_index_from(name: String, idx: int, found: int): int =
    if idx >= name.size().value
    then found
    else match name[idx] with
        case None -> found
        case Some { char } ->
            let next = if char == "." then idx else found
            last_dot_index_from(name, idx + 1, next)

private fun java_visibility_prefix(visibility: String): String =
    if visibility == "private"
    then "private "
    else if visibility == "local"
    then "public "
    else "public "

private fun java_function_body(function: CompiledFunction, returnType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if tail_recursive_function(function, env, module, allModules)
    then tail_recursive_function_body(function, returnType, env, module, allModules)
    else match function.body with
    case CompiledBlockExpression block ->
        let effectBody = effect_block_body(block, env, returnType, module, allModules, "        ")
        if !effectBody.is_empty()
        then effectBody
        else if !expression_emittable(function.body, env, module, allModules)
        then "        throw new UnsupportedOperationException(\"Unsupported CFUN expression at " + function.location.line + ":" + function.location.column + "\");" + newline()
        else block_statements(block.bindings, env, returnType, module, allModules, "        ")
            + "        return " + block_result_code(block, env, returnType, module, allModules) + ";" + newline()
    case _ ->
        if !expression_emittable(function.body, env, module, allModules)
        then "        throw new UnsupportedOperationException(\"Unsupported CFUN expression at " + function.location.line + ":" + function.location.column + "\");" + newline()
        else "        return " + expression_code(function.body, env, returnType, module, allModules) + ";" + newline()

private fun effect_block_body(block: CompiledBlockExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if returnType.name == "Effect" & effect_block_emittable(block.bindings, block.result, env, returnType, module, allModules)
    then indent + "return " + effect_block_expression(block.bindings, block.result, env, returnType, module, allModules, indent) + ";" + newline()
    else ""

private fun effect_block_expression(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> effect_block_result_expression(result, env, returnType, module, allModules)
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        if binding.operator == "<-"
        then effect_bind_expression(binding, localBinding, bindings[1:], result, env, returnType, module, allModules, indent)
        else effect_local_expression(binding, localBinding, valueType, bindings[1:], result, env, returnType, module, allModules, indent)

private fun effect_block_result_expression(result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = expression_type(result, env, module, allModules)
    if resultType.name == "Effect"
    then expression_code(result, env, returnType, module, allModules)
    else "capy.lang.Effect.pure(" + expression_code(result, env, first_type_argument(returnType), module, allModules) + ")"

private fun effect_bind_expression(binding: CompiledLetBinding, localBinding: JavaBinding, rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let wrapperType = binding_value_type(binding, env, module, allModules)
    expression_code(binding.value, env, wrapperType, module, allModules)
        + ".flatMap(" + localBinding.javaName + " -> "
        + effect_block_expression(rest, result, [localBinding] + env, returnType, module, allModules, indent + "    ")
        + ")"

private fun effect_local_expression(binding: CompiledLetBinding, localBinding: JavaBinding, valueType: CompiledTypeReference, rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    "((java.util.function.Supplier<" + java_type(returnType) + ">) () -> {" + newline()
        + indent + "    " + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, valueType, module, allModules) + ";" + newline()
        + indent + "    return " + effect_block_expression(rest, result, [localBinding] + env, returnType, module, allModules, indent + "    ") + ";" + newline()
        + indent + "}).get()"

private fun effect_block_emittable(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaBinding], returnType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> expression_emittable(result, env, module, allModules)
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        if binding.operator == "<-"
        then binding_value_type(binding, env, module, allModules).name == "Effect"
            & expression_emittable(binding.value, env, module, allModules)
            & effect_block_emittable(bindings[1:], result, [localBinding] + env, returnType, module, allModules)
        else expression_emittable(binding.value, env, module, allModules)
            & effect_block_emittable(bindings[1:], result, [localBinding] + env, returnType, module, allModules)

private fun tail_recursive_function(function: CompiledFunction, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_references_function(function.body, function.name)
        & tail_recursive_expression(function.body, function)
        & expression_emittable(function.body, env, module, allModules)

private fun tail_recursive_expression(expression: CompiledExpression, function: CompiledFunction): bool =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then tail_self_call_compatible(function.parameters, call.arguments) & !expressions_reference_function(call.arguments, function.name)
        else !expressions_reference_function(call.arguments, function.name)
    case CompiledIfExpression ifExpression ->
        !expression_references_function(ifExpression.condition, function.name)
            & tail_recursive_expression(ifExpression.thenBranch, function)
            & tail_recursive_expression(ifExpression.elseBranch, function)
    case CompiledBlockExpression block ->
        !let_bindings_reference_function(block.bindings, function.name)
            & tail_recursive_expression(block.result, function)
    case CompiledMatchExpression matchExpression ->
        !expression_references_function(matchExpression.value, function.name)
            & tail_match_cases_recursive(matchExpression.cases, function)
    case _ -> !expression_references_function(expression, function.name)

private fun tail_match_cases_recursive(cases: List[CompiledMatchCase], function: CompiledFunction): bool =
    match cases[0] with
    case None -> true
    case Some { matchCase } ->
        (!matchCase.hasLiteral | !expression_references_function(matchCase.literal, function.name))
            & (!matchCase.hasGuard | !expression_references_function(matchCase.guard, function.name))
            & tail_recursive_expression(matchCase.body, function)
            & tail_match_cases_recursive(cases[1:], function)

private fun tail_self_call_compatible(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some _ ->
        match arguments[0] with
        case None -> false
        case Some _ -> tail_self_call_compatible(parameters[1:], arguments[1:])

private fun tail_recursive_function_body(function: CompiledFunction, returnType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "        while (true) {" + newline()
        + tail_expression_statements(function.body, function, env, returnType, module, allModules, "            ")
        + "        }" + newline()

private fun tail_expression_statements(expression: CompiledExpression, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then tail_self_call_statements(function.parameters, call.arguments, call.location, env, module, allModules, indent)
        else indent + "return " + expression_code(expression, env, expectedType, module, allModules) + ";" + newline()
    case CompiledIfExpression ifExpression ->
        indent + "if (" + truthy_expression_code(ifExpression.condition, env, module, allModules) + ") {" + newline()
            + tail_expression_statements(ifExpression.thenBranch, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "} else {" + newline()
            + tail_expression_statements(ifExpression.elseBranch, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "}" + newline()
    case CompiledBlockExpression block ->
        block_statements(block.bindings, env, expectedType, module, allModules, indent)
            + tail_expression_statements(block.result, function, block_env(block.bindings, env, module, allModules), expectedType, module, allModules, indent)
    case CompiledMatchExpression matchExpression ->
        tail_match_expression_statements(matchExpression, function, env, expectedType, module, allModules, indent)
    case _ -> indent + "return " + expression_code(expression, env, expectedType, module, allModules) + ";" + newline()

private fun tail_self_call_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], location: CompiledSourceLocation, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    tail_self_call_temp_statements(parameters, arguments, location, env, module, allModules, indent, 0)
        + tail_self_call_assign_statements(parameters, location, indent, 0)
        + indent + "continue;" + newline()

private fun tail_self_call_temp_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], location: CompiledSourceLocation, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String, idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        match arguments[0] with
        case None -> ""
        case Some { argument } ->
            let tempName = tail_argument_temp_name(parameter, location, idx)
            indent + java_type(parameter.typeReference) + " " + tempName + " = "
                + expression_code(argument, env, parameter.typeReference, module, allModules) + ";" + newline()
                + tail_self_call_temp_statements(parameters[1:], arguments[1:], location, env, module, allModules, indent, idx + 1)

private fun tail_self_call_assign_statements(parameters: List[CompiledFunctionParameter], location: CompiledSourceLocation, indent: String, idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        indent + java_identifier(parameter.name) + " = " + tail_argument_temp_name(parameter, location, idx) + ";" + newline()
            + tail_self_call_assign_statements(parameters[1:], location, indent, idx + 1)

private fun tail_argument_temp_name(parameter: CompiledFunctionParameter, location: CompiledSourceLocation, idx: int): String =
    "__capy_tail_" + java_identifier(parameter.name) + "_" + location.line + "_" + location.column + "_" + idx

private fun tail_match_expression_statements(matchExpression: CompiledMatchExpression, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let valueType = expression_type(matchExpression.value, env, module, allModules)
    let valueCode = expression_code(matchExpression.value, env, valueType, module, allModules)
    let matchValueName = "__capy_match_value_" + matchExpression.location.line + "_" + matchExpression.location.column
    let cases = ordered_match_cases(matchExpression.cases)
    indent + java_type(valueType) + " " + matchValueName + " = " + valueCode + ";" + newline()
        + tail_match_case_statements(cases, matchValueName, valueType, function, env, expectedType, module, allModules, indent)
        + indent + "return unsupported(\"match\");" + newline()

private fun tail_match_case_statements(cases: List[CompiledMatchCase], valueCode: String, valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match cases[0] with
    case None -> ""
    case Some { matchCase } ->
        indent + "if (" + match_case_condition_code(matchCase, valueCode, valueType, env, module, allModules) + ") {" + newline()
            + match_binding_statements(matchCase.bindings, matchCase, valueCode, valueType, 0, module, allModules, indent + "    ")
            + tail_match_guarded_statement(matchCase, valueType, function, env, expectedType, module, allModules, indent + "    ")
            + indent + "}" + newline()
            + tail_match_case_statements(cases[1:], valueCode, valueType, function, env, expectedType, module, allModules, indent)

private fun tail_match_guarded_statement(matchCase: CompiledMatchCase, valueType: CompiledTypeReference, function: CompiledFunction, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
    if matchCase.hasGuard
    then indent + "if (" + truthy_expression_code(matchCase.guard, caseEnv, module, allModules) + ") {" + newline()
        + tail_expression_statements(matchCase.body, function, caseEnv, expectedType, module, allModules, indent + "    ")
        + indent + "}" + newline()
    else tail_expression_statements(matchCase.body, function, caseEnv, expectedType, module, allModules, indent)

private fun java_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        java_type(parameter.typeReference) + " " + java_identifier(parameter.name) + java_parameter_tail(parameters[1:])

private fun java_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_type(parameter.typeReference) + " " + java_identifier(parameter.name) + java_parameter_tail(parameters[1:])

private fun java_function_parameters(function: CompiledFunction): String =
    if extension_method_function(function)
    then java_type(method_receiver_type(function)) + " " + java_identifier("this") + java_method_parameter_tail(function.parameters)
    else java_parameters(function.parameters)

private fun java_method_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else ", " + java_parameters(parameters)

private fun java_function_bindings(function: CompiledFunction): List[JavaBinding] =
    if extension_method_function(function)
    then [java_binding("this", method_receiver_type(function))] + parameter_bindings(function.parameters)
    else parameter_bindings(function.parameters)

private fun parameter_bindings(parameters: List[CompiledFunctionParameter]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [java_binding(parameter.name, parameter.typeReference)] + parameter_bindings(parameters[1:])

private fun expression_code(
    expression: CompiledExpression,
    env: List[JavaBinding],
    expectedType: CompiledTypeReference,
    module: CompiledModule,
    allModules: List[CompiledModule]
): String =
    match expression with
    case CompiledUnsupportedExpression unsupported ->
        if compiled_placeholder_source(unsupported.source)
        then placeholder_code(unsupported, module)
        else "unsupported(\"" + escape_java_string(unsupported.source) + "\")"
    case CompiledIntLiteral literal -> numeric_widening_code(int_literal_code(literal, expectedType), expression_type(expression, env, module, allModules), expectedType)
    case CompiledLongLiteral literal -> numeric_widening_code(literal.source, long_type(), expectedType)
    case CompiledFloatLiteral literal -> numeric_widening_code(literal.source, float_type(), expectedType)
    case CompiledDoubleLiteral literal -> literal.source
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> "\"" + escape_java_string(literal.value) + "\""
    case CompiledVariableExpression variable -> variable_expression_code(variable, env, expectedType, module, allModules)
    case CompiledIfExpression ifExpression -> "("
        + truthy_expression_code(ifExpression.condition, env, module, allModules)
        + " ? " + expression_code(ifExpression.thenBranch, env, expectedType, module, allModules)
        + " : " + expression_code(ifExpression.elseBranch, env, expectedType, module, allModules)
        + ")"
    case CompiledBinaryExpression binary -> binary_expression_code(binary, env, expectedType, module, allModules)
    case CompiledUnaryExpression unary -> unary_expression_code(unary, env, expectedType, module, allModules)
    case CompiledFunctionCallExpression call ->
        if partial_function_call(call)
        then partial_function_call_code(call, env, expectedType, module, allModules)
        else value_conversion_code(function_call_code(call, env, expectedType, module, allModules), function_call_type(call, env, module, allModules), expectedType, module, allModules)
    case CompiledFunctionReferenceExpression reference -> function_reference_code(reference, expectedType, module, allModules)
    case CompiledMethodCallExpression call ->
        if partial_method_call(call)
        then partial_method_call_code(call, env, expectedType, module, allModules)
        else value_conversion_code(method_call_code(call, env, expectedType, module, allModules), method_call_type(call, env, module, allModules), expectedType, module, allModules)
    case CompiledWithExpression withExpression -> value_conversion_code(with_expression_code(withExpression, env, module, allModules), with_expression_type(withExpression, env, module, allModules), expectedType, module, allModules)
    case CompiledLambdaExpression lambda -> lambda_expression_code(lambda, env, expectedType, module, allModules)
    case CompiledListLiteral literal -> list_literal_code(literal, env, expectedType, module, allModules)
    case CompiledSetLiteral literal -> "java.util.Set.of(" + expression_list_code(literal.values, env, module, allModules) + ")"
    case CompiledDictLiteral literal -> dict_code(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> tuple_literal_code(literal, env, expectedType, module, allModules)
    case CompiledIndexExpression index -> index_code(index, env, expectedType, module, allModules)
    case CompiledDataLiteral literal -> data_literal_code(literal, env, expectedType, module, allModules)
    case CompiledFieldAccessExpression access -> field_access_code(access, env, expectedType, module, allModules)
    case CompiledReduceExpression reduce -> reduce_expression_code(reduce, env, expectedType, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_code(matchExpression, env, expectedType, module, allModules)
    case CompiledBlockExpression block -> block_expression_code(block, env, expectedType, module, allModules)

private fun variable_expression_code(variable: CompiledVariableExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding_exists(variable.name, env)
    then value_conversion_code(lookup_binding_java_name(variable.name, env), lookup_binding(variable.name, env), expectedType, module, allModules)
    else if qualified_enum_value_name(variable.name, module, allModules)
    then value_conversion_code(
        enum_qualified_value_code(variable.name, module, allModules),
        data_type_reference(enum_qualified_type_name(variable.name)),
        expectedType,
        module,
        allModules
    )
    else if variable.name == "DEFAULT_FAILED_EXIT_CODE" & program_member_imported(variable.name, module.imports)
    then numeric_widening_code("capy.lang.Program.DEFAULT_FAILED_EXIT_CODE", int_type(), expectedType)
    else match imported_stdlib_constant(variable.name, module.imports) with
        case Some { constant } -> value_conversion_code(constant.javaName, constant.typeReference, expectedType, module, allModules)
        case None ->
            match find_constant_in_scope(variable.name, module, allModules) with
            case Some { function } -> value_conversion_code(java_identifier(variable.name), effective_function_return_type(function, module, allModules), expectedType, module, allModules)
            case None -> numeric_widening_code(java_identifier(variable.name), object_type(), expectedType)

private fun placeholder_code(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    "__capy_not_implemented(\"" + escape_java_string(placeholder_message(placeholder, module)) + "\")"

private fun placeholder_message(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    let functionName = placeholder_function_name(placeholder.source)
    if functionName.is_empty()
    then "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": placeholder expression is not yet implemented"
    else "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + module_source_file(module) + ": the function `" + functionName + "` is not yet implemented"

private fun compiled_placeholder_source(source: String): bool =
    java_generator_string_has_prefix(source, "__capy_placeholder__|")

private fun placeholder_function_name(source: String): String =
    if compiled_placeholder_source(source)
    then source["__capy_placeholder__|".size().value, source.size().value]
    else ""

private fun binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = expression_type(binary.left, env, module, allModules)
    let rightType = expression_type(binary.right, env, module, allModules)
    let naturalResultType = binary_result_type(binary.operator, leftType, rightType)
    let resultType = contextual_binary_result_type(naturalResultType, expectedType)
    if result_reduce_operator_expression(binary, leftType)
    then result_reduce_method_code(result_reduce_operator_call(binary), env, expectedType, module, allModules)
    else if result_pipe_expression(binary, leftType)
    then result_pipe_code(binary, leftType, expectedType, env, module, allModules)
    else if option_pipe_expression(binary, leftType)
    then option_pipe_code(binary, leftType, env, module, allModules)
    else if collection_pipe_chained_method_expression(binary, leftType)
    then expression_code(collection_pipe_chained_method_call(binary), env, expectedType, module, allModules)
    else if collection_pipe_expression(binary, leftType)
    then collection_pipe_code(binary, leftType, env, module, allModules)
    else if binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
    then binary_extension_operator_code_with_left_type(binary, leftType, env, module, allModules)
    else if stdlib_path_slash_expression(binary, leftType, module)
    then stdlib_path_slash_code(binary, env, module, allModules)
    else if collection_plus_expression(binary.operator, leftType, rightType)
    then collection_plus_code(binary, leftType, rightType, env, module, allModules)
    else if collection_minus_expression(binary.operator, leftType, rightType)
    then collection_minus_code(binary, leftType, rightType, env, module, allModules)
    else if set_binary_expression(binary.operator, leftType, rightType)
    then set_binary_code(binary, leftType, rightType, env, module, allModules)
    else if regex_binary_expression(binary.operator, leftType)
    then regex_binary_code(binary, env, module, allModules)
    else if boolean_binary_operator(binary.operator)
    then "(" + truthy_expression_code(binary.left, env, module, allModules)
        + " " + java_boolean_operator(binary.operator) + " "
        + truthy_expression_code(binary.right, env, module, allModules)
        + ")"
    else if string_left_numeric_operator(binary.operator, leftType, rightType)
    then "(" + expression_code(binary.left, env, leftType, module, allModules)
        + " + "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    else if binary.operator == "^"
    then power_expression_code(binary, resultType, env, module, allModules)
    else if binary.operator == ".nand."
    then byte_result_code("(~(" + expression_code(binary.left, env, leftType, module, allModules)
        + " & "
        + expression_code(binary.right, env, rightType, module, allModules)
        + "))", expectedType)
    else if bitwise_binary_operator(binary.operator)
    then byte_result_code("(" + expression_code(binary.left, env, leftType, module, allModules)
        + " " + java_bitwise_operator(binary.operator) + " "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")", expectedType)
    else if binary.operator == "?"
    then
        if leftType.name == "Dict"
        then expression_code(binary.left, env, leftType, module, allModules)
            + ".containsKey(" + expression_code(binary.right, env, string_type(), module, allModules) + ")"
        else expression_code(binary.left, env, leftType, module, allModules)
            + ".contains(" + expression_code(binary.right, env, rightType, module, allModules) + ")"
    else if string_equality_operator(binary.operator, leftType, rightType)
    then string_equality_code(binary, leftType, rightType, env, module, allModules)
    else if object_equality_operator(binary.operator, leftType, rightType)
    then object_equality_code(binary, leftType, rightType, env, module, allModules)
    else if binary.operator == "%" & resultType.name == "byte"
    then "((byte) (" + expression_code(binary.left, env, leftType, module, allModules)
        + " % "
        + expression_code(binary.right, env, rightType, module, allModules)
        + "))"
    else byte_result_code("(" + expression_code(binary.left, env, resultType, module, allModules)
        + " " + binary.operator + " "
        + expression_code(binary.right, env, resultType, module, allModules)
        + ")", resultType)

private fun contextual_binary_result_type(naturalResultType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if numeric_type(naturalResultType) & type_assignable(expectedType, naturalResultType)
    then expectedType
    else naturalResultType

private fun collection_plus_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    operator == "+"
        & (list_plus_expression(leftType, rightType) | set_plus_expression(leftType, rightType) | dict_plus_expression(leftType, rightType))

private fun collection_minus_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    operator == "-" & (list_minus_expression(leftType, rightType) | set_minus_expression(leftType, rightType) | dict_minus_expression(leftType, rightType))

private fun list_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "List" & !rightType.name.is_empty()

private fun list_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "List" & !rightType.name.is_empty()

private fun set_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Set" & !rightType.name.is_empty()

private fun set_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Set" & !rightType.name.is_empty()

private fun dict_plus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Dict" & (rightType.name == "Dict" | rightType.name == "Tuple")

private fun dict_minus_expression(leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Dict" & (rightType.name == "Dict" | rightType.name == "String")

private fun collection_plus_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    if leftType.name == "List"
    then
        if rightType.name == "List"
        then "__capy_list_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_list_append(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if leftType.name == "Set"
    then
        if rightType.name == "Set"
        then "__capy_set_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_set_append(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if rightType.name == "Tuple"
    then "__capy_dict_append(" + leftCode + ", " + expression_code(binary.right, env, rightType, module, allModules) + ")"
    else "__capy_dict_concat(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"

private fun collection_minus_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    if leftType.name == "Dict"
    then
        if rightType.name == "Dict"
        then "__capy_dict_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_dict_remove(" + leftCode + ", " + expression_code(binary.right, env, string_type(), module, allModules) + ")"
    else if leftType.name == "Set"
    then
        if rightType.name == "Set"
        then "__capy_set_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
        else "__capy_set_remove(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"
    else if rightType.name == "List"
    then "__capy_list_remove_all(" + leftCode + ", " + expression_code(binary.right, env, leftType, module, allModules) + ")"
    else "__capy_list_remove(" + leftCode + ", " + expression_code(binary.right, env, first_type_argument(leftType), module, allModules) + ")"

private fun set_binary_expression(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    leftType.name == "Set" & rightType.name == "Set" & set_binary_operator(operator)

private fun set_binary_operator(operator: String): bool =
    set_predicate_operator(operator) | set_algebra_operator(operator)

private fun set_predicate_operator(operator: String): bool =
    operator == "⊆" | operator == "⊂" | operator == "⊇" | operator == "⊃"

private fun set_algebra_operator(operator: String): bool =
    operator == "∪" | operator == "∩" | operator == "△" | operator == "×"

private fun set_binary_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    let rightCode = expression_code(binary.right, env, rightType, module, allModules)
    if binary.operator == "⊆"
    then "__capy_set_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊂"
    then "__capy_set_proper_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊇"
    then "__capy_set_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "⊃"
    then "__capy_set_proper_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "∪"
    then "__capy_set_concat(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "∩"
    then "__capy_set_intersection(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "△"
    then "__capy_set_symmetric_difference(" + leftCode + ", " + rightCode + ")"
    else "__capy_set_cartesian_product(" + leftCode + ", " + rightCode + ")"

private fun string_equality_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "==" | operator == "!=") & (leftType.name == "String" | rightType.name == "String")

private fun string_equality_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = "java.util.Objects.equals("
        + expression_code(binary.left, env, leftType, module, allModules)
        + ", "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    if binary.operator == "!=" then "(!" + code + ")" else code

private fun object_equality_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "==" | operator == "!=")
        & object_equality_type(leftType)
        & object_equality_type(rightType)

private fun object_equality_type(type: CompiledTypeReference): bool =
    type.name.is_empty()
        | type.name == "any"
        | (type.name != "bool" & !numeric_type(type))

private fun object_equality_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, rightType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = "java.util.Objects.equals("
        + expression_code(binary.left, env, leftType, module, allModules)
        + ", "
        + expression_code(binary.right, env, rightType, module, allModules)
        + ")"
    if binary.operator == "!=" then "(!" + code + ")" else code

private fun power_expression_code(binary: CompiledBinaryExpression, resultType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if resultType.name == "byte"
    then "((byte) __capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + "))"
    else if resultType.name == "int"
    then "__capy_pow_int("
        + expression_code(binary.left, env, int_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, int_type(), module, allModules)
        + ")"
    else if resultType.name == "long"
    then "__capy_pow_long("
        + expression_code(binary.left, env, long_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, long_type(), module, allModules)
        + ")"
    else if resultType.name == "float"
    then "((float) java.lang.Math.pow("
        + expression_code(binary.left, env, float_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, float_type(), module, allModules)
        + "))"
    else "java.lang.Math.pow("
        + expression_code(binary.left, env, double_type(), module, allModules)
        + ", "
        + expression_code(binary.right, env, double_type(), module, allModules)
        + ")"

private fun unary_expression_code(unary: CompiledUnaryExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(!" + truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then byte_result_code("(~" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else if unary.operator == "-"
    then byte_result_code("(-" + expression_code(unary.expression, env, expression_type(unary.expression, env, module, allModules), module, allModules) + ")", expectedType)
    else "(" + unary.operator + expression_code(unary.expression, env, expectedType, module, allModules) + ")"

private fun byte_result_code(expression: String, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" then "((byte) " + expression + ")" else expression

private fun truthy_expression_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(expression, env, module, allModules)
    truthy_code(expression_code(expression, env, type, module, allModules), type)

private fun truthy_code(code: String, type: CompiledTypeReference): String =
    if type.name == "bool"
    then code
    else if integer_type(type)
    then "(" + code + " != 0)"
    else if type.name == "float"
    then "(" + code + " != 0.0f)"
    else if type.name == "double"
    then "(" + code + " != 0.0)"
    else if type.name == "String"
    then "(!" + code + ".isEmpty())"
    else if type.name == "List" | type.name == "Set" | type.name == "Dict"
    then "(!" + code + ".isEmpty())"
    else "__capy_truthy(" + code + ")"

private fun bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

private fun java_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

private fun boolean_binary_operator(operator: String): bool =
    operator == "&" | operator == "|"

private fun java_boolean_operator(operator: String): String =
    if operator == "&" then "&&" else "||"

private fun binary_extension_operator_expression(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator(binary, env, module, allModules) with
    case Some _ -> true
    case None -> false

private fun binary_extension_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some _ -> true
    case None -> false

private fun binary_extension_operator_code(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_binary_extension_operator(binary, env, module, allModules) with
    case Some { function } -> extension_method_call_code(function, binary_extension_method_call(binary), env, module, allModules)
    case None -> "unsupported(\"extension operator\")"

private fun binary_extension_operator_code_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } -> extension_method_call_code(function, binary_extension_method_call(binary), env, module, allModules)
    case None -> "unsupported(\"extension operator\")"

private fun binary_extension_operator_type(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_binary_extension_operator(binary, env, module, allModules) with
    case Some { function } -> bound_extension_method_return_type(function, expression_type(binary.left, env, module, allModules))
    case None -> object_type()

private fun binary_extension_operator_type_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } -> bound_extension_method_return_type(function, leftType)
    case None -> object_type()

private fun binary_extension_operator_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator(binary, env, module, allModules) with
    case Some { function } ->
        let receiverType = expression_type(binary.left, env, module, allModules)
        let parameters = bound_extension_method_parameters(function, receiverType)
        concrete_return_type(bound_extension_method_return_type(function, receiverType))
            & expression_emittable(binary.left, env, module, allModules)
            & extension_operator_arguments_emittable(parameters, [binary.right], env, module, allModules)
    case None -> false

private fun binary_extension_operator_emittable_with_left_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } ->
        let parameters = bound_extension_method_parameters(function, leftType)
        concrete_return_type(bound_extension_method_return_type(function, leftType))
            & expression_emittable(binary.left, env, module, allModules)
            & extension_operator_arguments_emittable(parameters, [binary.right], env, module, allModules)
    case None -> false

private fun extension_operator_arguments_emittable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            extension_operator_argument_emittable(parameter.typeReference, argument, env, module, allModules)
                & extension_operator_arguments_emittable(parameters[1:], arguments[1:], env, module, allModules)

private fun extension_operator_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentType = expression_type(argument, env, module, allModules)
    expression_emittable(argument, env, module, allModules)
        & (
            parameter_argument_assignable(target, argument, env, module, allModules)
            | (function_type(target) & function_type(argumentType))
        )

private fun binary_extension_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: binary.left,
        name: binary.operator,
        arguments: [binary.right],
        location: binary.location
    }

private fun result_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    (binary.operator == "|" | binary.operator == "|*")
        & lambda_expression(binary.right)
        & result_pipe_receiver(binary.left, leftType)

private fun result_pipe_receiver(left: CompiledExpression, leftType: CompiledTypeReference): bool =
    result_type_name(leftType.name)
        | result_constructor_type(leftType.name)
        | match left with
            case CompiledDataLiteral literal -> result_constructor_type(literal.typeName)
            case CompiledBinaryExpression binary -> result_pipe_expression(binary, leftType)
            case _ -> false

private fun result_reduce_operator_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    binary.operator == "|>"
        & result_type_name(leftType.name)
        & result_reduce_operator_arguments_shape(binary.right)

private fun result_reduce_operator_arguments_shape(expression: CompiledExpression): bool =
    match expression with
    case CompiledTupleLiteral literal -> result_reduce_method_arguments(literal.values)
    case _ -> false

private fun result_reduce_operator_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: binary.left,
        name: "reduce",
        arguments: result_reduce_operator_arguments(binary.right),
        location: binary.location
    }

private fun result_reduce_operator_arguments(expression: CompiledExpression): List[CompiledExpression] =
    match expression with
    case CompiledTupleLiteral literal -> literal.values
    case _ -> []

private fun result_constructor_type(typeName: String): bool =
    result_success_constructor(typeName) | result_error_constructor(typeName)

private fun result_success_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Result", "Success")

private fun result_error_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Result", "Error")

private fun option_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    (binary.operator == "|" | binary.operator == "|-" | binary.operator == "|*")
        & lambda_expression(binary.right)
        & option_pipe_receiver(binary.left, leftType)

private fun option_pipe_receiver(left: CompiledExpression, leftType: CompiledTypeReference): bool =
    option_type_name(leftType.name)
        | option_constructor_type(leftType.name)
        | match left with
            case CompiledDataLiteral literal -> option_constructor_type(literal.typeName)
            case CompiledBinaryExpression binary -> option_pipe_expression(binary, leftType)
            case _ -> false

private fun option_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    let receiverCode = "((java.util.Optional<" + boxed_java_type(valueType) + ">) __capy_optional_value("
        + expression_code(binary.left, env, leftType, module, allModules)
        + "))"
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|"
        then receiverCode + ".map(" + lambda_code_for_value(lambda, valueType, expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules), env, module, allModules) + ")"
        else if binary.operator == "|*"
        then receiverCode + ".flatMap(" + option_flat_map_lambda_code(lambda, valueType, env, module, allModules) + ")"
        else receiverCode + ".filter(" + option_filter_lambda_code(lambda, valueType, env, module, allModules) + ")"
    case _ -> "unsupported(\"option pipe\")"

private fun option_filter_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyCode = truthy_expression_code(lambda.body, lambdaEnv, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, bodyCode)

private fun option_flat_map_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyType = expression_type(lambda.body, lambdaEnv, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, expression_code(lambda.body, lambdaEnv, bodyType, module, allModules))

private fun option_pipe_value_type(left: CompiledExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_type_name(leftType.name)
    then first_type_argument(leftType)
    else match left with
        case CompiledDataLiteral literal -> option_literal_value_type(literal, env, module, allModules)
        case CompiledBinaryExpression binary ->
            let resultType = option_pipe_result_type(binary, expression_type(binary.left, env, module, allModules), env, module, allModules)
            if option_type_name(resultType.name) then first_type_argument(resultType) else object_type()
        case _ -> object_type()

private fun option_literal_value_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_some_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } -> expression_type(field.value, env, module, allModules)
        case None -> object_type()
    else object_type()

private fun option_pipe_result_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|-"
        then option_type(valueType)
        else
            let bodyType = expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
            if binary.operator == "|*" & option_type_name(bodyType.name)
            then bodyType
            else option_type(bodyType)
    case _ -> option_type(valueType)

private fun result_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binary.operator == "|*"
    then result_flat_pipe_code(binary, leftType, expectedType, env, module, allModules)
    else result_map_pipe_code(binary, leftType, expectedType, env, module, allModules)

private fun result_map_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    let resultType = if expectedType.name.is_empty() then result_pipe_result_type(binary, leftType, env, module, allModules) else expectedType
    let resultName = result_pipe_value_name(binary)
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + result_pipe_binding_statement(lambda.parameters, valueType, resultName, "                ")
        + "                return " + expression_code(lambda.body, lambda_value_env(lambda.parameters, valueType, env), resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case CompiledFunctionReferenceExpression reference ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + "                return " + result_function_reference_body_code(reference, valueType, resultName, resultType, env, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case _ -> "unsupported(\"result pipe\")"

private fun result_flat_pipe_code(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    let resultType = if expectedType.name.is_empty() then result_pipe_result_type(binary, leftType, env, module, allModules) else expectedType
    let bodyExpectedType = result_flat_pipe_body_expected_type(resultType)
    let resultName = result_pipe_value_name(binary)
    let mappedName = resultName + "_mapped"
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + result_pipe_binding_statement(lambda.parameters, valueType, resultName, "                ")
        + "                java.lang.Object " + mappedName + " = " + expression_code(lambda.body, lambda_value_env(lambda.parameters, valueType, env), bodyExpectedType, module, allModules) + ";" + newline()
        + "                if (__capy_result_is_success(" + mappedName + ")) {" + newline()
        + "                    return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + mappedName + "));" + newline()
        + "                }" + newline()
        + "                return ((" + boxed_java_type(resultType) + ") " + mappedName + ");" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case CompiledFunctionReferenceExpression reference ->
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + resultName + " = " + leftCode + ";" + newline()
        + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
        + "                java.lang.Object " + mappedName + " = " + result_function_reference_body_code(reference, valueType, resultName, bodyExpectedType, env, module, allModules) + ";" + newline()
        + "                if (__capy_result_is_success(" + mappedName + ")) {" + newline()
        + "                    return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + mappedName + "));" + newline()
        + "                }" + newline()
        + "                return ((" + boxed_java_type(resultType) + ") " + mappedName + ");" + newline()
        + "            }" + newline()
        + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
        + "        }).get()"
    case _ -> "unsupported(\"result pipe\")"

private fun result_function_reference_body_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, resultName: String, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueName = "__capy_result_value"
    let valueCode = "((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "))"
    expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: valueName,
            location: reference.location
        }],
        location: reference.location
    }, [java_binding_with_java_name(valueName, valueType, valueCode)] + env, expectedType, module, allModules)

private fun result_flat_pipe_body_expected_type(resultType: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(resultType.name)
    then result_type(resultType)
    else object_type()

private fun result_pipe_binding_statement(parameters: List[String], valueType: CompiledTypeReference, resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "));" + newline()

private fun result_pipe_value_name(binary: CompiledBinaryExpression): String =
    "__capy_result_" + binary.location.line + "_" + binary.location.column + "_" + result_pipe_left_depth(binary.left)

private fun result_pipe_left_depth(expression: CompiledExpression): int =
    match expression with
    case CompiledBinaryExpression binary -> 1 + result_pipe_left_depth(binary.left)
    case _ -> 0

private fun result_pipe_value_type(left: CompiledExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(leftType.name)
    then first_type_argument(leftType)
    else match left with
        case CompiledDataLiteral literal -> result_literal_value_type(literal, env, module, allModules)
        case CompiledBinaryExpression binary ->
            let resultType = result_pipe_result_type(binary, expression_type(binary.left, env, module, allModules), env, module, allModules)
            if result_type_name(resultType.name) then first_type_argument(resultType) else object_type()
        case _ -> object_type()

private fun result_literal_value_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_success_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } -> result_expression_type(field.value, expression_type(field.value, env, module, allModules), env, module, allModules)
        case None -> object_type()
    else object_type()

private fun result_pipe_result_type(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
        let bodyType = result_expression_type(lambda.body, expression_type(lambda.body, lambdaEnv, module, allModules), lambdaEnv, module, allModules)
        if binary.operator == "|*" then result_flat_pipe_result_type(bodyType) else bodyType
    case CompiledFunctionReferenceExpression reference ->
        let bodyType = function_reference_type(reference, module, allModules)
        if binary.operator == "|*" then result_flat_pipe_result_type(bodyType) else bodyType
    case _ -> object_type()

private fun result_flat_pipe_result_type(bodyType: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(bodyType.name) & result_type_name(first_type_argument(bodyType).name)
    then first_type_argument(bodyType)
    else bodyType

private fun result_expression_type(expression: CompiledExpression, expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(expressionType.name)
    then expressionType
    else non_result_expression_type(expression, expressionType, env, module, allModules)

private fun non_result_expression_type(expression: CompiledExpression, expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledDataLiteral literal ->
        if result_success_constructor(literal.typeName)
        then result_type(result_literal_value_type(literal, env, module, allModules))
        else if result_error_constructor(literal.typeName)
        then result_type(object_type())
        else expressionType
    case CompiledMatchExpression matchExpression -> result_match_expression_type(matchExpression.cases, expressionType, env, module, allModules)
    case _ -> expressionType

private fun result_match_expression_type(cases: List[CompiledMatchCase], expressionType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let orderedCases = ordered_match_cases(cases)
    match orderedCases[0] with
    case Some { matchCase } -> result_expression_type(matchCase.body, expressionType, env, module, allModules)
    case None -> expressionType

private fun result_type(argument: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference { name: "Result", arguments: [argument] }

private fun date_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Date", arguments: [] }

private fun time_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Time", arguments: [] }

private fun date_time_type(): CompiledTypeReference =
    CompiledTypeReference { name: "DateTime", arguments: [] }

private fun duration_type(): CompiledTypeReference =
    CompiledTypeReference { name: "Duration", arguments: [] }

private fun imported_stdlib_constant_exists(name: String, imports: List[CompiledImportDeclaration]): bool =
    match imported_stdlib_constant(name, imports) with
    case Some _ -> true
    case None -> false

private fun imported_stdlib_constant(name: String, imports: List[CompiledImportDeclaration]): /capy/lang/Option[JavaStdlibValue] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !declaration.qualified & import_includes_name(name, declaration)
        then match stdlib_constant(name, declaration.modulePath) with
            case Some { value } -> /capy/lang/Option.Some { value }
            case None -> imported_stdlib_constant(name, imports[1:])
        else imported_stdlib_constant(name, imports[1:])

private fun stdlib_constant(name: String, modulePath: String): /capy/lang/Option[JavaStdlibValue] =
    let path = normalized_stdlib_path(modulePath)
    if path == "capy/date_time/Date" & name == "UNIX_DATE"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.dateTime.DateModule.UNIX_DATE", typeReference: date_type() } }
    else if path == "capy/date_time/Time" & name == "MIDNIGHT"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.dateTime.TimeModule.MIDNIGHT", typeReference: time_type() } }
    else if path == "capy/date_time/DateTime" & name == "UNIX_EPOCH"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.dateTime.DateTimeModule.UNIX_EPOCH", typeReference: date_time_type() } }
    else if path == "capy/date_time/Duration" & name == "ZERO"
    then /capy/lang/Option.Some { JavaStdlibValue { javaName: "capy.dateTime.Duration.ZERO", typeReference: duration_type() } }
    else /capy/lang/Option.None {}

private fun normalized_stdlib_path(modulePath: String): String =
    if java_generator_string_has_prefix(modulePath, "/")
    then modulePath[1, modulePath.size()]
    else modulePath

private fun stdlib_date_time_type_imported(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    let modulePath = stdlib_date_time_type_module_path(typeName)
    if modulePath.is_empty()
    then false
    else stdlib_module_imported(modulePath, type_unqualified_name(typeName), imports)

private fun stdlib_module_imported(modulePath: String, memberName: String, imports: List[CompiledImportDeclaration]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if !declaration.qualified
            & normalized_stdlib_path(declaration.modulePath) == modulePath
            & import_includes_name(memberName, declaration)
        then true
        else stdlib_module_imported(modulePath, memberName, imports[1:])

private fun stdlib_date_time_type_module_path(typeName: String): String =
    let name = type_unqualified_name(typeName)
    if name == "DateTime"
    then "capy/date_time/DateTime"
    else if name == "Date"
    then "capy/date_time/Date"
    else if name == "Time"
    then "capy/date_time/Time"
    else if name == "Duration" | name == "DateDuration" | name == "WeekDuration"
    then "capy/date_time/Duration"
    else ""

private fun stdlib_date_time_type_name(typeName: String): bool =
    let name = type_unqualified_name(typeName)
    name == "DateTime"
        | name == "Date"
        | name == "Time"
        | name == "Duration"
        | name == "DateDuration"
        | name == "WeekDuration"

private fun stdlib_date_time_java_type(typeName: String): String =
    let name = type_unqualified_name(typeName)
    if name == "DateTime"
    then "capy.dateTime.DateTime"
    else if name == "Date"
    then "capy.dateTime.Date"
    else if name == "Time"
    then "capy.dateTime.Time"
    else if name == "DateDuration"
    then "capy.dateTime.Duration.DateDuration"
    else if name == "WeekDuration"
    then "capy.dateTime.Duration.WeekDuration"
    else "capy.dateTime.Duration"

private fun stdlib_date_time_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    stdlib_date_time_method(expression_type(call.receiver, env, module, allModules).name, call.name)

private fun stdlib_date_time_method(receiverTypeName: String, methodName: String): bool =
    let receiver = type_unqualified_name(receiverTypeName)
    if receiver == "Date"
    then methodName == "add_days" | methodName == "add_years_months" | methodName == "to_days_since_unix_epoch" | methodName == "to_iso_8601"
    else if receiver == "Time"
    then methodName == "add_seconds" | methodName == "to_seconds" | methodName == "to_iso_8601"
    else if receiver == "DateTime"
    then methodName == "plus" | methodName == "minus" | methodName == "to_iso_8601" | methodName == "timestamp"
    else if receiver == "Duration"
    then methodName == "to_iso_8601" | methodName == "negate" | methodName == "years" | methodName == "months" | methodName == "days" | methodName == "hours" | methodName == "minutes" | methodName == "seconds"
    else false

private fun stdlib_date_time_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiver = type_unqualified_name(expression_type(call.receiver, env, module, allModules).name)
    if receiver == "Date"
    then if call.name == "to_days_since_unix_epoch" then int_type() else if call.name == "to_iso_8601" then string_type() else date_type()
    else if receiver == "Time"
    then if call.name == "to_seconds" then int_type() else if call.name == "to_iso_8601" then string_type() else time_type()
    else if receiver == "DateTime"
    then stdlib_date_time_method_date_time_type(call, env, module, allModules)
    else if receiver == "Duration"
    then stdlib_date_time_method_duration_type(call.name)
    else object_type()

private fun stdlib_date_time_method_date_time_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "to_iso_8601"
    then string_type()
    else if call.name == "timestamp"
    then long_type()
    else if call.name == "plus"
    then date_time_type()
    else if call.name == "minus"
    then
        let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
        if type_unqualified_name(argumentType.name) == "DateTime"
        then duration_type()
        else date_time_type()
    else date_time_type()

private fun stdlib_date_time_method_duration_type(methodName: String): CompiledTypeReference =
    if methodName == "to_iso_8601"
    then string_type()
    else if methodName == "negate"
    then duration_type()
    else int_type()

private fun stdlib_date_time_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiver = type_unqualified_name(expression_type(call.receiver, env, module, allModules).name)
    expression_emittable(call.receiver, env, module, allModules)
        & if receiver == "Date"
            then stdlib_date_method_arguments_emittable(call, env, module, allModules)
            else if receiver == "Time"
            then stdlib_time_method_arguments_emittable(call, env, module, allModules)
            else if receiver == "DateTime"
            then stdlib_date_time_method_arguments_emittable(call, env, module, allModules)
            else if receiver == "Duration"
            then call.arguments.is_empty()
            else false

private fun stdlib_date_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "add_days"
    then stdlib_one_int_argument_emittable(call, env, module, allModules)
    else if call.name == "add_years_months"
    then stdlib_two_int_arguments_emittable(call, env, module, allModules)
    else call.arguments.is_empty()

private fun stdlib_time_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "add_seconds"
    then stdlib_one_int_argument_emittable(call, env, module, allModules)
    else call.arguments.is_empty()

private fun stdlib_date_time_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "plus"
    then stdlib_one_date_time_argument_emittable(call, "Duration", env, module, allModules)
    else if call.name == "minus"
    then stdlib_one_date_time_argument_emittable(call, "Duration", env, module, allModules)
        | stdlib_one_date_time_argument_emittable(call, "DateTime", env, module, allModules)
    else call.arguments.is_empty()

private fun stdlib_one_int_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { actual } ->
        call.arguments[1:].is_empty()
            & expression_emittable(actual, env, module, allModules)
            & type_assignable(int_type(), expression_type(actual, env, module, allModules))

private fun stdlib_two_int_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { first } ->
        match call.arguments[1] with
        case None -> false
        case Some { second } ->
            call.arguments[2:].is_empty()
                & expression_emittable(first, env, module, allModules)
                & expression_emittable(second, env, module, allModules)
                & type_assignable(int_type(), expression_type(first, env, module, allModules))
                & type_assignable(int_type(), expression_type(second, env, module, allModules))

private fun stdlib_one_date_time_argument_emittable(call: CompiledMethodCallExpression, expectedTypeName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { actual } ->
        call.arguments[1:].is_empty()
            & expression_emittable(actual, env, module, allModules)
            & type_unqualified_name(expression_type(actual, env, module, allModules).name) == expectedTypeName

private fun collection_pipe_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    collection_pipe_operator(binary.operator) & collection_pipe_receiver_type(leftType) & lambda_expression(binary.right)

private fun collection_pipe_chained_method_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference): bool =
    collection_pipe_operator(binary.operator)
        & collection_pipe_receiver_type(leftType)
        & match binary.right with
            case CompiledMethodCallExpression call -> lambda_expression(call.receiver)
            case _ -> false

private fun collection_pipe_chained_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    match binary.right with
    case CompiledMethodCallExpression call ->
        CompiledMethodCallExpression {
            receiver: CompiledBinaryExpression {
                operator: binary.operator,
                left: binary.left,
                right: call.receiver,
                location: binary.location
            },
            name: call.name,
            arguments: call.arguments,
            location: call.location
        }
    case _ -> CompiledMethodCallExpression {
        receiver: binary,
        name: "",
        arguments: [],
        location: binary.location
    }

private fun collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*" | operator == "|!"

private fun lambda_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

private fun collection_pipe_code(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType.name == "Dict"
    then dict_pipe_code(binary, receiverType, env, module, allModules)
    else
        let receiverCode = seq_receiver_code(binary.left, receiverType, env, module, allModules)
        let valueType = collection_value_type(receiverType)
        match binary.right with
        case CompiledLambdaExpression lambda ->
            if binary.operator == "|!"
            then receiverCode + ".filter(" + reject_lambda_code(lambda, valueType, env, module, allModules) + ")"
            else if binary.operator == "|-"
            then receiverCode + ".filter(" + lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules) + ")"
            else if binary.operator == "|*"
            then receiverCode + ".flatMap(" + flat_map_lambda_code(lambda, valueType, env, module, allModules) + ")"
            else receiverCode + ".map(" + lambda_code_for_value(lambda, valueType, expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules), env, module, allModules) + ")"
        case CompiledFunctionReferenceExpression reference ->
            if binary.operator == "|!"
            then receiverCode + ".filter(" + predicate_function_reference_lambda_code(reference, valueType, true, module, allModules) + ")"
            else if binary.operator == "|-"
            then receiverCode + ".filter(" + predicate_function_reference_lambda_code(reference, valueType, false, module, allModules) + ")"
            else receiverCode + ".map(" + function_reference_lambda_code(reference, valueType, function_reference_type(reference, module, allModules), module, allModules) + ")"
        case _ -> "unsupported(\"collection pipe\")"

private fun reject_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    lambda_code_with_result(lambda.parameters, valueType, "!(" + truthy_expression_code(lambda.body, lambdaEnv, module, allModules) + ")")

private fun predicate_function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, negate: bool, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_value -> " + (if negate then "!(" + function_reference_predicate_call_code(reference, valueType, module, allModules) + ")" else function_reference_predicate_call_code(reference, valueType, module, allModules))

private fun function_reference_predicate_call_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: "__capy_value",
            location: reference.location
        }],
        location: reference.location
    }, [java_binding("__capy_value", valueType)], bool_type(), module, allModules)

private fun function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_value -> " + expression_code(CompiledFunctionCallExpression {
        name: reference.name,
        arguments: [CompiledVariableExpression {
            name: "__capy_value",
            location: reference.location
        }],
        location: reference.location
    }, [java_binding("__capy_value", valueType)], expectedType, module, allModules)

private fun dict_pipe_code(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = collection_value_type(receiverType)
    let receiverCode = expression_code(binary.left, env, receiverType, module, allModules)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|!"
        then dict_filter_pipe_code(binary, receiverCode, valueType, lambda, false, env, module, allModules)
        else if binary.operator == "|-"
        then dict_filter_pipe_code(binary, receiverCode, valueType, lambda, true, env, module, allModules)
        else if binary.operator == "|"
        then dict_map_pipe_code(binary, receiverCode, valueType, lambda, env, module, allModules)
        else "unsupported(\"dict pipe\")"
    case _ -> "unsupported(\"dict pipe\")"

private fun dict_map_pipe_code(binary: CompiledBinaryExpression, receiverCode: String, valueType: CompiledTypeReference, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
    let resultType = expression_type(lambda.body, lambdaEnv, module, allModules)
    let resultName = dict_pipe_result_name(binary)
    "((java.util.function.Supplier<java.util.Map<java.lang.String, " + boxed_java_type(resultType) + ">>) () -> {" + newline()
        + "            java.util.LinkedHashMap<java.lang.String, " + boxed_java_type(resultType) + "> " + resultName + " = new java.util.LinkedHashMap<>();" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + receiverCode + ".entrySet()) {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "                ")
        + "                " + resultName + ".put(__capy_entry.getKey(), " + expression_code(lambda.body, lambdaEnv, resultType, module, allModules) + ");" + newline()
        + "            }" + newline()
        + "            return java.util.Collections.unmodifiableMap(" + resultName + ");" + newline()
        + "        }).get()"

private fun dict_filter_pipe_code(binary: CompiledBinaryExpression, receiverCode: String, valueType: CompiledTypeReference, lambda: CompiledLambdaExpression, keepMatches: bool, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
    let resultName = dict_pipe_result_name(binary)
    let predicateCode = truthy_expression_code(lambda.body, lambdaEnv, module, allModules)
    let conditionCode = if keepMatches then predicateCode else "!(" + predicateCode + ")"
    "((java.util.function.Supplier<java.util.Map<java.lang.String, " + boxed_java_type(valueType) + ">>) () -> {" + newline()
        + "            java.util.LinkedHashMap<java.lang.String, " + boxed_java_type(valueType) + "> " + resultName + " = new java.util.LinkedHashMap<>();" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + receiverCode + ".entrySet()) {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "                ")
        + "                if (" + conditionCode + ") {" + newline()
        + "                    " + resultName + ".put(__capy_entry.getKey(), __capy_entry.getValue());" + newline()
        + "                }" + newline()
        + "            }" + newline()
        + "            return java.util.Collections.unmodifiableMap(" + resultName + ");" + newline()
        + "        }).get()"

private fun dict_pipe_result_name(binary: CompiledBinaryExpression): String =
    "__capy_dict_pipe_" + binary.location.line + "_" + binary.location.column

private fun seq_receiver_code(expression: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = expression_code(expression, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then "capy.lang.String.chars(" + receiverCode + ")"
    else if seq_type_name(receiverType.name)
    then "((" + java_seq_type(receiverType) + ") (capy.lang.Seq<?>) " + receiverCode + ")"
    else "capy.lang.Seq.toSeq(" + receiverCode + ")"

private fun int_literal_code(literal: CompiledIntLiteral, expectedType: CompiledTypeReference): String =
    if expectedType.name == "byte" & byte_literal_source(literal.source)
    then "((byte) " + literal.source + ")"
    else literal.source

private fun numeric_widening_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if primitive_numeric_widening_assignable(expectedType, sourceType)
    then "((" + java_type(expectedType) + ") " + code + ")"
    else code

private fun value_conversion_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    match primitive_backed_backing_type(sourceType.name, module, allModules) with
    case Some { backingType } ->
        if type_assignable(expectedType, backingType)
        then numeric_widening_code("((" + boxed_java_type(backingType) + ") __capy_data_field(" + code + ", \"value\"))", backingType, expectedType)
        else ordinary_value_conversion_code(code, sourceType, expectedType)
    case None -> ordinary_value_conversion_code(code, sourceType, expectedType)

private fun ordinary_value_conversion_code(code: String, sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): String =
    if (sourceType.name.is_empty() | sourceType.name == "any") & !expectedType.name.is_empty() & expectedType.name != "any"
    then "((" + boxed_java_type(expectedType) + ") " + code + ")"
    else numeric_widening_code(code, sourceType, expectedType)

private fun function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "delay"
    then "capy.lang.Effect.delay(" + expression_code(argument(call.arguments, 0), env, supplier_type(first_type_argument(delay_call_type(call.arguments, env, module, allModules))), module, allModules) + ")"
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_value_call_code(call, env, module, allModules)
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then
        let valueType = if expectedType.name == "Effect" then first_type_argument(expectedType) else expression_type(argument(call.arguments, 0), env, module, allModules)
        "capy.lang.Effect.pure(" + expression_code(argument(call.arguments, 0), env, valueType, module, allModules) + ")"
    else if stdlib_effect_function_call(call, module)
    then stdlib_effect_function_call_code(call.name)
    else if stdlib_path_function_call(call, module)
    then stdlib_path_function_call_code(call, env, module, allModules)
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_code(call, env, module, allModules)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then console_print_call_code(call, env, module, allModules)
    else if console_read_line_call(call, module)
    then "capy.lang.Effect.delay(() -> dev.capylang.ConsoleUtil.readLine())"
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_code(call, env, module, allModules)
    else if call.name == "assert_all"
    then "capy.test.Assert.assertAll(" + expression_code(argument(call.arguments, 0), env, list_type(assert_type()), module, allModules) + ")"
    else if call.name == "assert_that"
    then assert_that_code(argument(call.arguments, 0), env, module, allModules)
    else if call.name == "test"
    then "new capy.test.CapyTest.TestCase("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + ", capy.test.CapyTest.Passed.INSTANCE, 0, 0.0, "
        + expression_code(argument(call.arguments, 1), env, supplier_type(assert_type()), module, allModules)
        + ")"
    else if call.name == "test_file"
    then
        let testsExpression = argument(call.arguments, 1)
        let testsCode = test_file_tests_code(testsExpression, env, module, allModules)
        "capy.lang.Effect.delay(() -> new capy.test.CapyTest.TestFile("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + ", "
        + testsCode
        + ", java.lang.System.currentTimeMillis()))"
    else if stdlib_math_sqrt_call(call, module)
    then sqrt_call_code(call, env, expectedType, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then "java.lang.Integer.toString("
        + expression_code(argument(call.arguments, 0), env, int_type(), module, allModules)
        + ").replace(\"-\", \"\").length()"
    else if enum_parse_call(call, module, allModules)
    then enum_parse_call_code(call, env, module, allModules)
    else ordinary_function_call_code(call, env, module, allModules)

private fun function_value_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = lookup_binding(call.name, env)
    let parameters = function_type_parameters(type)
    let target = lookup_binding_java_name(call.name, env)
    if parameters.is_empty()
    then target + ".get()"
    else target + ".apply(" + function_value_call_arguments(parameters, call.arguments, env, module, allModules) + ")"

private fun function_value_call_arguments(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, function_type_parameter_at(parameters, 0), module, allModules)
        + function_value_call_argument_tail(parameters[1:], arguments[1:], env, module, allModules)

private fun function_value_call_argument_tail(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, function_type_parameter_at(parameters, 0), module, allModules)
        + function_value_call_argument_tail(parameters[1:], arguments[1:], env, module, allModules)

private fun partial_function_call(call: CompiledFunctionCallExpression): bool =
    arguments_contain_placeholder(call.arguments)

private fun partial_method_call(call: CompiledMethodCallExpression): bool =
    arguments_contain_placeholder(call.arguments)

private fun arguments_contain_placeholder(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } -> partial_placeholder_expression(expression) | arguments_contain_placeholder(arguments[1:])

private fun partial_placeholder_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> compiled_placeholder_source(unsupported.source)
    case _ -> false

private fun partial_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let names = partial_placeholder_names(call.arguments, env)
    let type = partial_expected_type(expectedType, partial_function_call_type(call, env, module, allModules))
    "((" + boxed_java_type(type) + ") (" + partial_lambda_parameters(names)
        + " -> " + partial_function_call_body_code(call, names, env, module, allModules) + "))"

private fun partial_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let names = partial_placeholder_names(call.arguments, env)
    let type = partial_expected_type(expectedType, partial_method_call_type(call, env, module, allModules))
    "((" + boxed_java_type(type) + ") (" + partial_lambda_parameters(names)
        + " -> " + partial_method_call_body_code(call, names, env, module, allModules) + "))"

private fun partial_expected_type(expectedType: CompiledTypeReference, inferredType: CompiledTypeReference): CompiledTypeReference =
    if function_type(expectedType) then expectedType else inferredType

private fun partial_function_call_body_code(call: CompiledFunctionCallExpression, names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if qualified_call_name(call.name)
    then
        match find_qualified_function(call.name, module, allModules) with
        case Some { function } ->
            qualified_call_class_name(call.name, module) + "." + java_function_name(function)
                + "(" + partial_parameter_expression_list_code(function.parameters, call.arguments, names, env, module, allModules) + ")"
        case None ->
            qualified_call_class_name(call.name, module) + "." + java_identifier(qualified_call_member(call.name))
                + "(" + partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } ->
            java_function_name(function) + "(" + partial_parameter_expression_list_code(function.parameters, call.arguments, names, env, module, allModules) + ")"
        case None -> java_function_call_name(call.name, module, allModules) + "(" + partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"

private fun partial_method_call_body_code(call: CompiledMethodCallExpression, names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    match find_extension_method(call, env, module, allModules) with
    case Some { function } -> partial_extension_method_call_body_code(function, call, names, receiverType, env, module, allModules)
    case None -> expression_code(call.receiver, env, receiverType, module, allModules)
        + "." + java_method_name(call.name)
        + "(" + partial_method_expression_list_code(call.arguments, names, receiverType, call.name, env, module, allModules) + ")"

private fun partial_extension_method_call_body_code(function: CompiledFunction, call: CompiledMethodCallExpression, names: List[String], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = bound_extension_method_parameters(function, receiverType)
    java_function_name(function)
        + "("
        + expression_code(call.receiver, env, receiverType, module, allModules)
        + partial_extension_method_call_argument_tail(function.parameters, parameters, call.arguments, names, env, module, allModules)
        + ")"

private fun partial_extension_method_call_argument_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + partial_extension_parameter_expression_list_code(declaredParameters, boundParameters, arguments, names, env, module, allModules)

private fun partial_function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if qualified_call_name(call.name)
    then
        match find_qualified_function(call.name, module, allModules) with
        case Some { function } -> partial_function_type(function.parameters, call.arguments, effective_function_return_type(function, module, allModules))
        case None -> partial_unknown_function_type(call.arguments)
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } -> partial_function_type(function.parameters, call.arguments, effective_function_return_type(function, module, allModules))
        case None -> partial_unknown_function_type(call.arguments)

private fun partial_method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    match find_extension_method(call, env, module, allModules) with
    case Some { function } ->
        CompiledTypeReference {
            name: function_type_reference_text(
                partial_extension_method_parameter_types(bound_extension_method_parameters(function, receiverType), call.arguments),
                bound_extension_method_return_type(function, receiverType)
            ),
            arguments: []
        }
    case None ->
        CompiledTypeReference {
            name: function_type_reference_text(
                partial_method_parameter_types(call.arguments, receiverType, call.name),
                partial_method_return_type(call, receiverType, env, module, allModules)
            ),
            arguments: []
        }

private fun partial_function_type(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], returnType: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference {
        name: function_type_reference_text(partial_function_parameter_types(parameters, arguments), returnType),
        arguments: []
    }

private fun partial_unknown_function_type(arguments: List[CompiledExpression]): CompiledTypeReference =
    CompiledTypeReference {
        name: function_type_reference_text(partial_unknown_parameter_types(arguments), object_type()),
        arguments: []
    }

private fun partial_function_parameter_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, object_type())
        if partial_placeholder_expression(expression)
        then [parameterType] + partial_function_parameter_types(parameters[1:], arguments[1:])
        else partial_function_parameter_types(parameters[1:], arguments[1:])

private fun partial_unknown_parameter_types(arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then [object_type()] + partial_unknown_parameter_types(arguments[1:])
        else partial_unknown_parameter_types(arguments[1:])

private fun partial_method_parameter_types(arguments: List[CompiledExpression], receiverType: CompiledTypeReference, name: String): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then [partial_method_argument_type(receiverType, name)] + partial_method_parameter_types(arguments[1:], receiverType, name)
        else partial_method_parameter_types(arguments[1:], receiverType, name)

private fun partial_extension_method_parameter_types(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression]): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, object_type())
        if partial_placeholder_expression(expression)
        then [parameterType] + partial_extension_method_parameter_types(parameters[1:], arguments[1:])
        else partial_extension_method_parameter_types(parameters[1:], arguments[1:])

private fun partial_method_argument_type(receiverType: CompiledTypeReference, name: String): CompiledTypeReference =
    if receiverType.name == "String" & string_java_method(name)
    then string_type()
    else object_type()

private fun partial_method_return_type(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if receiverType.name == "String" & string_java_method(call.name)
    then string_java_method_type(call.name)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> bound_extension_method_return_type(function, receiverType)
        case None -> object_type()

private fun partial_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    partial_arguments_emittable(call.arguments, env, module, allModules)
        & if qualified_call_name(call.name)
            then match find_qualified_function(call.name, module, allModules) with
                case Some _ -> true
                case None -> false
            else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
                case Some _ -> true
                case None -> false

private fun partial_method_call_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & partial_arguments_emittable(call.arguments, env, module, allModules)
        & (string_java_method_call(call, env, module, allModules)
            | match find_extension_method(call, env, module, allModules) with
                case Some _ -> true
                case None -> java_method_supported(call.name))

private fun partial_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> true
    case Some { expression } ->
        (partial_placeholder_expression(expression) | expression_emittable(expression, env, module, allModules))
            & partial_arguments_emittable(arguments[1:], env, module, allModules)

private fun partial_placeholder_names(arguments: List[CompiledExpression], env: List[JavaBinding]): List[String] =
    partial_placeholder_names_with_used(arguments, env, [])

private fun partial_placeholder_names_with_used(arguments: List[CompiledExpression], env: List[JavaBinding], used: List[String]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then
            let name = available_partial_parameter_name(used, env, 1)
            [name] + partial_placeholder_names_with_used(arguments[1:], env, [name] + used)
        else partial_placeholder_names_with_used(arguments[1:], env, used)

private fun available_partial_parameter_name(used: List[String], env: List[JavaBinding], idx: int): String =
    let name = "capybaraPartial" + idx
    if binding_exists(name, env) | string_list_contains(name, used)
    then available_partial_parameter_name(used, env, idx + 1)
    else name

private fun string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> item == value | string_list_contains(value, values[1:])

private fun partial_lambda_parameters(names: List[String]): String =
    match names[0] with
    case None -> "()"
    case Some { name } ->
        if names[1:].is_empty()
        then java_identifier(name)
        else "(" + partial_lambda_parameter_list(names) + ")"

private fun partial_lambda_parameter_list(names: List[String]): String =
    match names[0] with
    case None -> ""
    case Some { name } -> java_identifier(name) + partial_lambda_parameter_tail(names[1:])

private fun partial_lambda_parameter_tail(names: List[String]): String =
    match names[0] with
    case None -> ""
    case Some { name } -> ", " + java_identifier(name) + partial_lambda_parameter_tail(names[1:])

private fun partial_argument_name(names: List[String]): String =
    match names[0] with
    case Some { name } -> java_identifier(name)
    case None -> "__capy_missing_partial"

private fun partial_parameter_expression_list_code(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names[1:], env, module, allModules)
        else expression_code(expression, env, parameterType, module, allModules)
            + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names, env, module, allModules)

private fun partial_parameter_expression_list_tail(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names[1:], env, module, allModules)
        else ", " + expression_code(expression, env, parameterType, module, allModules)
            + partial_parameter_expression_list_tail(parameters[1:], expressions[1:], names, env, module, allModules)

private fun partial_expression_list_code(expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_expression_list_tail(expressions[1:], names[1:], env, module, allModules)
        else expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
            + partial_expression_list_tail(expressions[1:], names, env, module, allModules)

private fun partial_expression_list_tail(expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_expression_list_tail(expressions[1:], names[1:], env, module, allModules)
        else ", " + expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
            + partial_expression_list_tail(expressions[1:], names, env, module, allModules)

private fun partial_method_expression_list_code(expressions: List[CompiledExpression], names: List[String], receiverType: CompiledTypeReference, methodName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let argumentType = partial_method_argument_type(receiverType, methodName)
        if partial_placeholder_expression(expression)
        then partial_argument_name(names) + partial_method_expression_list_tail(expressions[1:], names[1:], receiverType, methodName, env, module, allModules)
        else expression_code(expression, env, argumentType, module, allModules)
            + partial_method_expression_list_tail(expressions[1:], names, receiverType, methodName, env, module, allModules)

private fun partial_method_expression_list_tail(expressions: List[CompiledExpression], names: List[String], receiverType: CompiledTypeReference, methodName: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let argumentType = partial_method_argument_type(receiverType, methodName)
        if partial_placeholder_expression(expression)
        then ", " + partial_argument_name(names) + partial_method_expression_list_tail(expressions[1:], names[1:], receiverType, methodName, env, module, allModules)
        else ", " + expression_code(expression, env, argumentType, module, allModules)
            + partial_method_expression_list_tail(expressions[1:], names, receiverType, methodName, env, module, allModules)

private fun partial_extension_parameter_expression_list_code(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        if partial_placeholder_expression(expression)
        then partial_extension_argument_code(partial_argument_name(names), declaredType, boundType)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names[1:], env, module, allModules)
        else extension_argument_code(expression, declaredType, boundType, env, module, allModules)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names, env, module, allModules)

private fun partial_extension_parameter_expression_list_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], names: List[String], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        if partial_placeholder_expression(expression)
        then ", " + partial_extension_argument_code(partial_argument_name(names), declaredType, boundType)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names[1:], env, module, allModules)
        else ", " + extension_argument_code(expression, declaredType, boundType, env, module, allModules)
            + partial_extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], names, env, module, allModules)

private fun partial_extension_argument_code(code: String, declaredType: CompiledTypeReference, boundType: CompiledTypeReference): String =
    if extension_function_argument_needs_erased_cast(declaredType, boundType)
    then "((" + java_type(declaredType) + ") (" + raw_java_functional_type(declaredType) + ") " + code + ")"
    else code

private fun function_reference_code(reference: CompiledFunctionReferenceExpression, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function_type(expectedType)
    then "((" + boxed_java_type(expectedType) + ") (" + typed_function_reference_lambda_code(reference, expectedType, module, allModules) + "))"
    else function_reference_lambda_code(reference, function_reference_parameter_type(reference, module, allModules), function_reference_type(reference, module, allModules), module, allModules)

private fun typed_function_reference_lambda_code(reference: CompiledFunctionReferenceExpression, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = function_type_parameters(expectedType)
    function_lambda_parameters(parameters, 0)
        + " -> " + java_function_call_name(reference.name, module, allModules)
        + "(" + typed_function_reference_argument_list(reference, parameters, 0, module, allModules) + ")"

private fun typed_function_reference_argument_list(reference: CompiledFunctionReferenceExpression, parameters: List[CompiledTypeReference], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ ->
        typed_function_reference_argument_code(reference, idx, module, allModules)
            + typed_function_reference_argument_tail(reference, parameters[1:], idx + 1, module, allModules)

private fun typed_function_reference_argument_tail(reference: CompiledFunctionReferenceExpression, parameters: List[CompiledTypeReference], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + typed_function_reference_argument_code(reference, idx, module, allModules)
        + typed_function_reference_argument_tail(reference, parameters[1:], idx + 1, module, allModules)

private fun typed_function_reference_argument_code(reference: CompiledFunctionReferenceExpression, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let argument = "__capy_arg" + idx
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        let parameterType = parameter_type_at(function.parameters, idx, object_type())
        if parameterType.name == "any" | type_parameter(parameterType)
        then argument
        else "((" + boxed_java_type(parameterType) + ") " + argument + ")"
    case None -> argument

private fun function_lambda_parameters(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> "()"
    case Some _ ->
        if parameters[1:].is_empty()
        then "__capy_arg" + idx
        else "(" + function_lambda_parameter_list(parameters, idx) + ")"

private fun function_lambda_parameter_list(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> "__capy_arg" + idx + function_lambda_parameter_tail(parameters[1:], idx + 1)

private fun function_lambda_parameter_tail(parameters: List[CompiledTypeReference], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", __capy_arg" + idx + function_lambda_parameter_tail(parameters[1:], idx + 1)

private fun ordinary_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if qualified_call_name(call.name)
    then
        match find_qualified_function(call.name, module, allModules) with
        case Some { function } ->
            qualified_call_class_name(call.name, module) + "." + java_function_name(function)
                + "(" + parameter_expression_list_code(function.parameters, call.arguments, env, module, allModules) + ")"
        case None ->
            qualified_call_class_name(call.name, module) + "." + java_identifier(qualified_call_member(call.name))
                + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"
    else match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
        case Some { function } ->
            java_function_name(function) + "(" + parameter_expression_list_code(function.parameters, call.arguments, env, module, allModules) + ")"
        case None -> java_function_call_name(call.name, module, allModules) + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun stdlib_to_seq_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "to_seq" & seq_member_imported("to_seq", module.imports) & one_method_argument(call.arguments)

private fun stdlib_to_seq_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    "capy.lang.Seq.toSeq(" + expression_code(argumentExpression, env, argumentType, module, allModules) + ")"

private fun enum_parse_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = enum_qualified_type_name(call.name)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    let parseByName = type_assignable(string_type(), argumentType)
    let inputName = "__capy_enum_parse_value_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<java.lang.Object>) () -> {" + newline()
        + "            java.lang.Object " + inputName + " = " + expression_code(argumentExpression, env, enum_parse_argument_type(argumentType), module, allModules) + ";" + newline()
        + enum_parse_cases_code(typeName, enum_values(typeName, module, allModules), 0, inputName, parseByName, module, allModules)
        + "            return __capy_data(\"Error\", java.util.Map.ofEntries(java.util.Map.entry(\"message\", \"Cannot parse "
        + escape_java_string(typeName)
        + " from \" + "
        + inputName
        + ")));" + newline()
        + "        }).get()"

private fun enum_parse_argument_type(argumentType: CompiledTypeReference): CompiledTypeReference =
    if type_assignable(string_type(), argumentType)
    then string_type()
    else int_type()

private fun enum_parse_cases_code(typeName: String, values: List[String], idx: int, inputName: String, parseByName: bool, module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        "            if (java.util.Objects.equals(" + inputName + ", " + enum_parse_expected_value_code(value, idx, parseByName) + ")) {" + newline()
            + "                return __capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", "
            + enum_value_reference_code(typeName, value, module, allModules)
            + ")));" + newline()
            + "            }" + newline()
            + enum_parse_cases_code(typeName, values[1:], idx + 1, inputName, parseByName, module, allModules)

private fun enum_parse_expected_value_code(value: String, idx: int, parseByName: bool): String =
    if parseByName
    then "\"" + escape_java_string(value) + "\""
    else "" + idx

private fun parameter_expression_list_code(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

private fun parameter_expression_list_tail(parameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let parameterType = parameter_type_at(parameters, 0, expression_type(expression, env, module, allModules))
        ", " + expression_code(expression, env, parameterType, module, allModules)
        + parameter_expression_list_tail(parameters[1:], expressions[1:], env, module, allModules)

private fun parameter_type_at(parameters: List[CompiledFunctionParameter], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match parameters[idx] with
    case Some { parameter } -> parameter.typeReference
    case None -> fallback

private fun argument(arguments: List[CompiledExpression], idx: int): CompiledExpression =
    match arguments[idx] with
    case Some { expression } -> expression
    case None -> missing_argument()

private fun missing_argument(): CompiledExpression =
    CompiledUnsupportedExpression {
        source: "missing argument",
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

private fun method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "size" & call.arguments.is_empty()
    then size_method_code(call, env, module, allModules)
    else if char_to_string_call(call, env, module, allModules)
    then char_to_string_code(call, env, module, allModules)
    else if enum_name_method_call(call, env, module, allModules)
    then "__capy_enum_name(" + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules) + ")"
    else if assert_is_empty_call(call)
    then assert_is_empty_code(call, env, module, allModules)
    else if option_assert_is_equal_to_call(call, env, module, allModules)
    then option_assert_is_equal_to_code(call, env, module, allModules)
    else if result_assert_is_equal_to_call(call, env, module, allModules)
    then result_assert_is_equal_to_code(call, env, module, allModules)
    else if result_assert_succeeds_lambda_call(call, env, module, allModules)
    then result_assert_succeeds_lambda_code(call, env, module, allModules)
    else if assert_method_call(call, env, module, allModules)
    then assert_method_call_code(call, env, module, allModules)
    else if negated_collection_is_empty_call(call, env, module, allModules)
    then negated_collection_is_empty_code(call, env, module, allModules)
    else if collection_is_empty_call(call, env, module, allModules)
    then collection_is_empty_code(call, env, module, allModules)
    else if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_code(call, env, module, allModules)
    else if collection_reduce_method_call(call, env, module, allModules)
    then reduce_expression_code(collection_reduce_method_expression(call, expression_type(call.receiver, env, module, allModules)), env, expectedType, module, allModules)
    else if option_method_call(call, env, module, allModules)
    then option_pipe_code(option_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if collection_method_call(call, env, module, allModules)
    then collection_pipe_code(collection_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if set_method_call(call, env, module, allModules)
    then set_method_call_code(call, env, module, allModules)
    else if native_stdlib_method_call(call, env, module, allModules)
    then native_stdlib_method_code(call, env, expectedType, module, allModules)
    else if seq_as_list_call(call, env, module, allModules)
    then seq_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".asList()"
    else if seq_first_call(call, env, module, allModules)
    then seq_receiver_code(call.receiver, expression_type(call.receiver, env, module, allModules), env, module, allModules) + ".first()"
    else if function_value_method_call(call, env, module, allModules)
    then function_value_method_code(call, env, module, allModules)
    else if result_reduce_method_call(call, env, module, allModules)
    then result_reduce_method_code(call, env, expectedType, module, allModules)
    else if result_map_method_call(call, env, module, allModules)
    then result_map_method_code(call, env, expectedType, module, allModules)
    else if result_or_else_method_call(call, env, module, allModules)
    then result_or_else_method_code(call, env, module, allModules)
    else if result_or_method_call(call, env, module, allModules)
    then result_or_method_code(call, env, module, allModules)
    else if call.name == "map" & expression_type(call.receiver, env, module, allModules).name == "Effect"
    then
        let receiverType = expression_type(call.receiver, env, module, allModules)
        let valueType = first_type_argument(receiverType)
        let bodyExpectedType = if expectedType.name == "Effect" then first_type_argument(expectedType) else object_type()
        match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda ->
            expression_code(call.receiver, env, receiverType, module, allModules)
                + ".map(" + lambda_code_for_value(lambda, valueType, bodyExpectedType, env, module, allModules) + ")"
        case _ -> "unsupported(\"effect map\")"
    else if string_parse_method_call(call, env, module, allModules)
    then string_parse_method_code(call, env, module, allModules)
    else if regex_method_call(call, env, module, allModules)
    then regex_method_code(call, env, module, allModules)
    else if primitive_conversion_method(call.name)
    then primitive_conversion_code(call, env, module, allModules)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> extension_method_call_code(function, call, env, module, allModules)
        case None -> expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
            + "." + java_method_name(call.name)
            + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun function_value_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "__capy_call"
    then function_type(expression_type(call.receiver, env, module, allModules))
    else false

private fun function_value_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let parameters = function_type_parameters(receiverType)
    let target = expression_code(call.receiver, env, receiverType, module, allModules)
    if parameters.is_empty()
    then target + ".get()"
    else target + ".apply(" + function_value_call_arguments(parameters, call.arguments, env, module, allModules) + ")"

private fun result_map_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    (call.name == "map" | call.name == "flat_map")
        & result_type_name(expression_type(call.receiver, env, module, allModules).name)
        & result_map_method_argument(call.arguments)

private fun result_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    (call.name == "reduce" | call.name == "reduce_left")
        & result_type_name(expression_type(call.receiver, env, module, allModules).name)
        & result_reduce_method_arguments(call.arguments)

private fun result_or_else_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or_else"
    then
        if one_method_argument(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

private fun result_or_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or"
    then
        if one_method_argument(call.arguments)
        then result_type_name(expression_type(call.receiver, env, module, allModules).name)
        else false
    else false

private fun result_reduce_method_arguments(arguments: List[CompiledExpression]): bool =
    result_reduce_method_argument_at(arguments, 0)
        & result_reduce_method_argument_at(arguments, 1)
        & no_third_expression(arguments)

private fun result_reduce_method_argument_at(arguments: List[CompiledExpression], idx: int): bool =
    match arguments[0] with
    case Some { expression } ->
        if idx == 0
        then result_reduce_method_lambda_argument(expression)
        else result_reduce_method_argument_at(arguments[1:], idx - 1)
    case None -> false

private fun result_reduce_method_lambda_argument(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case _ -> false

private fun result_map_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case Some { expression } -> result_map_method_lambda_argument(expression) & no_second_expression(arguments)
    case None -> false

private fun result_map_method_lambda_argument(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

private fun result_map_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    result_pipe_code(result_map_method_binary(call), receiverType, expectedType, env, module, allModules)

private fun result_reduce_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let resultType = if expectedType.name.is_empty() | expectedType.name == "any" then result_reduce_method_type(call, env, module, allModules) else expectedType
    let resultName = "__capy_result_reduce_" + call.location.line + "_" + call.location.column
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let successLambda = result_reduce_lambda_argument(argument(call.arguments, 0))
    let errorLambda = result_reduce_lambda_argument(argument(call.arguments, 1))
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + receiverCode + ";" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + result_reduce_success_binding_statement(successLambda.parameters, valueType, resultName, "                ")
    + "                return " + expression_code(successLambda.body, lambda_value_env(successLambda.parameters, valueType, env), resultType, module, allModules) + ";" + newline()
    + "            }" + newline()
    + result_reduce_error_binding_statement(errorLambda.parameters, resultName, "            ")
    + "            return " + expression_code(errorLambda.body, lambda_value_env(errorLambda.parameters, string_type(), env), resultType, module, allModules) + ";" + newline()
    + "        }).get()"

private fun result_or_else_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = result_or_else_method_type(call, env, module, allModules)
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let resultName = "__capy_result_or_else_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + expression_code(call.receiver, env, receiverType, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + "                return ((" + boxed_java_type(resultType) + ") __capy_result_success_value(" + resultName + "));" + newline()
    + "            }" + newline()
    + "            return " + expression_code(argument(call.arguments, 0), env, resultType, module, allModules) + ";" + newline()
    + "        }).get()"

private fun result_or_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = result_or_method_type(call, env, module, allModules)
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let resultName = "__capy_result_or_" + call.location.line + "_" + call.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + resultName + " = " + expression_code(call.receiver, env, receiverType, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_error(" + resultName + ")) {" + newline()
    + "                return " + expression_code(argument(call.arguments, 0), env, resultType, module, allModules) + ";" + newline()
    + "            }" + newline()
    + "            return ((" + boxed_java_type(resultType) + ") " + resultName + ");" + newline()
    + "        }).get()"

private fun result_reduce_lambda_argument(expression: CompiledExpression): CompiledLambdaExpression =
    match expression with
    case CompiledLambdaExpression lambda -> lambda
    case _ -> CompiledLambdaExpression {
        parameters: [],
        body: missing_argument(),
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

private fun result_reduce_success_binding_statement(parameters: List[String], valueType: CompiledTypeReference, resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + resultName + "));" + newline()

private fun result_reduce_error_binding_statement(parameters: List[String], resultName: String, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if parameter == "_"
        then ""
        else indent + "java.lang.String " + java_identifier(parameter) + " = java.lang.String.valueOf(__capy_result_error_value(" + resultName + "));" + newline()

private fun result_map_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: if call.name == "flat_map" then "|*" else "|",
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

private fun option_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    option_method_name(call.name)
        & option_type_name(expression_type(call.receiver, env, module, allModules).name)
        & one_method_argument(call.arguments)
        & match argument(call.arguments, 0) with
            case CompiledLambdaExpression _ -> true
            case _ -> false

private fun option_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "flat_map"

private fun option_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: option_method_operator(call.name),
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

private fun option_method_operator(name: String): String =
    if name == "filter" then "|-"
    else if name == "flat_map" then "|*"
    else "|"

private fun collection_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    collection_method_name(call.name)
        & collection_pipe_receiver_type(expression_type(call.receiver, env, module, allModules))
        & one_method_argument(call.arguments)
        & lambda_expression(argument(call.arguments, 0))

private fun collection_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "`|-`" | name == "reject" | name == "flat_map"

private fun collection_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: collection_method_operator(call.name),
        left: call.receiver,
        right: argument(call.arguments, 0),
        location: call.location
    }

private fun collection_method_operator(name: String): String =
    if name == "filter" | name == "`|-`" then "|-"
    else if name == "reject" then "|!"
    else if name == "flat_map" then "|*"
    else "|"

private fun collection_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    (call.name == "reduce" | call.name == "reduce_left")
        & collection_pipe_receiver_type(expression_type(call.receiver, env, module, allModules))
        & collection_reduce_method_arguments(call.arguments, expression_type(call.receiver, env, module, allModules))

private fun collection_reduce_method_arguments(arguments: List[CompiledExpression], receiverType: CompiledTypeReference): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some { reducer } ->
            no_third_expression(arguments)
                & match reducer with
                    case CompiledLambdaExpression lambda -> collection_reduce_lambda_parameters_supported(lambda.parameters, receiverType)
                    case CompiledFunctionReferenceExpression _ -> true
                    case _ -> false

private fun collection_reduce_lambda_parameters_supported(parameters: List[String], receiverType: CompiledTypeReference): bool =
    if receiverType.name == "Dict"
    then reduce_lambda_arity_supported(parameters, 3)
    else reduce_lambda_arity_supported(parameters, 2)

private fun reduce_lambda_arity_supported(parameters: List[String], arity: int): bool =
    if arity == 0
    then parameters.is_empty()
    else match parameters[0] with
        case None -> false
        case Some _ -> reduce_lambda_arity_supported(parameters[1:], arity - 1)

private fun collection_reduce_method_expression(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference): CompiledReduceExpression =
    match argument(call.arguments, 1) with
    case CompiledLambdaExpression lambda ->
        CompiledReduceExpression {
            receiver: call.receiver,
            initial: argument(call.arguments, 0),
            accumulatorName: reduce_lambda_parameter(lambda.parameters, 0),
            keyName: reduce_lambda_key_parameter(lambda.parameters),
            valueName: reduce_lambda_value_parameter(lambda.parameters),
            body: lambda.body,
            location: call.location
        }
    case CompiledFunctionReferenceExpression reference ->
        let dictReceiver = receiverType.name == "Dict"
        let accumulatorName = "__capy_acc"
        let valueName = "__capy_value"
        let keyName = if dictReceiver then "__capy_key" else ""
        CompiledReduceExpression {
            receiver: call.receiver,
            initial: argument(call.arguments, 0),
            accumulatorName: accumulatorName,
            keyName: keyName,
            valueName: valueName,
            body: CompiledFunctionCallExpression {
                name: reference.name,
                arguments: collection_reduce_reference_arguments(accumulatorName, keyName, valueName, reference.location),
                location: reference.location
            },
            location: call.location
        }
    case _ -> CompiledReduceExpression {
        receiver: call.receiver,
        initial: argument(call.arguments, 0),
        accumulatorName: "",
        keyName: "",
        valueName: "",
        body: missing_argument(),
        location: call.location
    }

private fun collection_reduce_reference_arguments(accumulatorName: String, keyName: String, valueName: String, location: CompiledSourceLocation): List[CompiledExpression] =
    if keyName.is_empty()
    then [
        CompiledVariableExpression { name: accumulatorName, location: location },
        CompiledVariableExpression { name: valueName, location: location }
    ]
    else [
        CompiledVariableExpression { name: accumulatorName, location: location },
        CompiledVariableExpression { name: keyName, location: location },
        CompiledVariableExpression { name: valueName, location: location }
    ]

private fun reduce_lambda_key_parameter(parameters: List[String]): String =
    if reduce_lambda_arity_supported(parameters, 3)
    then reduce_lambda_parameter(parameters, 1)
    else ""

private fun reduce_lambda_value_parameter(parameters: List[String]): String =
    if reduce_lambda_arity_supported(parameters, 3)
    then reduce_lambda_parameter(parameters, 2)
    else reduce_lambda_parameter(parameters, 1)

private fun reduce_lambda_parameter(parameters: List[String], idx: int): String =
    match parameters[idx] with
    case Some { parameter } -> parameter
    case None -> ""

private fun collection_reduce_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(argument(call.arguments, 0), env, module, allModules)

private fun seq_first_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "first"
        & call.arguments.is_empty()
        & seq_type_name(expression_type(call.receiver, env, module, allModules).name)

private fun regex_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if regex_method_name(call.name)
    then
        if one_method_argument(call.arguments)
        then
            let receiverType = expression_type(call.receiver, env, module, allModules)
            regex_type_name(receiverType.name)
        else false
    else false

private fun regex_method_name(name: String): bool =
    name == "matches" | name == "find" | name == "find_all" | name == "replace" | name == "split"

private fun regex_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let argumentCode = expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
    if call.name == "matches"
    then "__capy_regex_matches(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find"
    then "__capy_regex_find(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find_all"
    then "__capy_regex_find_all_seq(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "replace"
    then "__capy_regex_replacer(" + receiverCode + ", " + argumentCode + ")"
    else "__capy_regex_split(" + receiverCode + ", " + argumentCode + ")"

private fun regex_binary_code(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = expression_type(binary.left, env, module, allModules)
    let leftCode = expression_code(binary.left, env, leftType, module, allModules)
    let rightCode = expression_code(binary.right, env, string_type(), module, allModules)
    if binary.operator == "?"
    then "__capy_regex_matches(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~"
    then "__capy_regex_find(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~~"
    then "__capy_regex_find_all_seq(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~>"
    then "__capy_regex_replacer(" + leftCode + ", " + rightCode + ")"
    else "__capy_regex_split(" + leftCode + ", " + rightCode + ")"

private fun collection_predicate_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if collection_predicate_method(call.name) & collection_predicate_receiver_type(receiverType)
    then match call.arguments[0] with
        case None -> false
        case Some { predicate } ->
            match call.arguments[1] with
            case None -> lambda_expression(predicate)
            case Some _ -> false
    else false

private fun collection_predicate_method(name: String): bool =
    name == "any" | name == "all"

private fun collection_predicate_receiver_type(type: CompiledTypeReference): bool =
    collection_receiver_type(type) | type.name == "Dict"

private fun collection_predicate_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = collection_value_type(receiverType)
    let rawReceiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    let receiverCode =
        if seq_type_name(receiverType.name) | receiverType.name == "String"
        then seq_receiver_code(call.receiver, receiverType, env, module, allModules)
        else rawReceiverCode
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda ->
        if receiverType.name == "Dict"
        then dict_predicate_call_code(call.name, rawReceiverCode, lambda, valueType, env, module, allModules)
        else if receiverType.name == "String" & string_indexed_lambda(lambda.parameters)
        then string_indexed_predicate_code(call.name, rawReceiverCode, lambda, env, module, allModules)
        else if seq_type_name(receiverType.name) | receiverType.name == "String"
        then collection_seq_predicate_code(call.name, receiverCode, lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules))
        else receiverCode + ".stream()." + java_stream_predicate_method(call.name) + "(" + lambda_code_for_value(lambda, valueType, bool_type(), env, module, allModules) + ")"
    case CompiledFunctionReferenceExpression reference ->
        if receiverType.name == "Dict"
        then "unsupported(\"dict predicate reference\")"
        else if seq_type_name(receiverType.name) | receiverType.name == "String"
        then collection_seq_predicate_code(call.name, receiverCode, function_reference_lambda_code(reference, valueType, bool_type(), module, allModules))
        else receiverCode + ".stream()." + java_stream_predicate_method(call.name) + "(" + function_reference_lambda_code(reference, valueType, bool_type(), module, allModules) + ")"
    case _ -> "unsupported(\"collection predicate\")"

private fun dict_predicate_call_code(name: String, receiverCode: String, lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    receiverCode + ".entrySet().stream()." + java_stream_predicate_method(name) + "(__capy_entry -> {" + newline()
        + dict_predicate_lambda_bindings(lambda.parameters, valueType, "            ")
        + "            return " + expression_code(lambda.body, dict_predicate_lambda_env(lambda.parameters, valueType, env), bool_type(), module, allModules) + ";" + newline()
        + "        })"

private fun dict_predicate_lambda_bindings(parameters: List[String], valueType: CompiledTypeReference, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { keyParameter } ->
        match parameters[1] with
        case None -> ""
        case Some { valueParameter } ->
            dict_predicate_key_binding(keyParameter, indent)
                + dict_predicate_value_binding(valueParameter, valueType, indent)

private fun dict_predicate_key_binding(parameter: String, indent: String): String =
    if parameter == "_"
    then ""
    else indent + "java.lang.String " + java_identifier(parameter) + " = (java.lang.String) __capy_entry.getKey();" + newline()

private fun dict_predicate_value_binding(parameter: String, valueType: CompiledTypeReference, indent: String): String =
    if parameter == "_"
    then ""
    else indent + java_type(valueType) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(valueType) + ") __capy_entry.getValue());" + newline()

private fun dict_predicate_lambda_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { keyParameter } ->
        match parameters[1] with
        case None -> env
        case Some { valueParameter } ->
            dict_predicate_key_env(keyParameter) + dict_predicate_value_env(valueParameter, valueType) + env

private fun dict_predicate_key_env(parameter: String): List[JavaBinding] =
    if parameter == "_" then [] else [java_binding(parameter, string_type())]

private fun dict_predicate_value_env(parameter: String, valueType: CompiledTypeReference): List[JavaBinding] =
    if parameter == "_" then [] else [java_binding(parameter, valueType)]

private fun string_indexed_predicate_code(name: String, receiverCode: String, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "java.util.stream.IntStream.range(0, " + receiverCode + ".length())."
        + java_stream_predicate_method(name)
        + "(__capy_idx -> "
        + expression_code(lambda.body, string_indexed_lambda_env(lambda.parameters, receiverCode, env), bool_type(), module, allModules)
        + ")"

private fun string_indexed_lambda_env(parameters: List[String], receiverCode: String, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { charParameter } ->
        match parameters[1] with
        case None -> env
        case Some { indexParameter } ->
            string_indexed_lambda_binding(charParameter, string_type(), "java.lang.String.valueOf(" + receiverCode + ".charAt(__capy_idx))")
                + string_indexed_lambda_binding(indexParameter, int_type(), "__capy_idx")
                + env

private fun string_indexed_lambda_binding(name: String, type: CompiledTypeReference, javaName: String): List[JavaBinding] =
    if name == "_"
    then []
    else [java_binding_with_java_name(name, type, javaName)]

private fun string_indexed_lambda(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ ->
            match parameters[2] with
            case None -> true
            case Some _ -> false

private fun collection_seq_predicate_code(name: String, receiverCode: String, lambdaCode: String): String =
    if name == "any"
    then receiverCode + ".any(" + lambdaCode + ")"
    else receiverCode + ".asList().stream().allMatch(" + lambdaCode + ")"

private fun java_stream_predicate_method(name: String): String =
    if name == "any" then "anyMatch" else "allMatch"

private fun set_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    receiverType.name == "Set" & set_method_arity(call)

private fun set_method_arity(call: CompiledMethodCallExpression): bool =
    if set_no_argument_method(call.name)
    then call.arguments.is_empty()
    else if set_one_argument_method(call.name)
    then one_method_argument(call.arguments)
    else false

private fun set_no_argument_method(name: String): bool =
    name == "power_set" | name == "℘"

private fun set_one_argument_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"
        | name == "union" | name == "intersection" | name == "difference"
        | name == "symmetric_difference" | name == "cartesian_product"

private fun set_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if call.name == "power_set" | call.name == "℘"
    then "__capy_set_power_set(" + receiverCode + ")"
    else
        let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
        let argumentCode = expression_code(argument(call.arguments, 0), env, argumentType, module, allModules)
        if call.name == "contains"
        then receiverCode + ".contains(" + argumentCode + ")"
        else if call.name == "is_subset_of"
        then "__capy_set_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_proper_subset_of"
        then "__capy_set_proper_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_superset_of"
        then "__capy_set_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "is_proper_superset_of"
        then "__capy_set_proper_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "union"
        then "__capy_set_concat(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "intersection"
        then "__capy_set_intersection(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "difference"
        then "__capy_set_remove_all(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "symmetric_difference"
        then "__capy_set_symmetric_difference(" + receiverCode + ", " + argumentCode + ")"
        else "__capy_set_cartesian_product(" + receiverCode + ", " + argumentCode + ")"

private fun native_stdlib_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if receiverType.name == "String"
    then call.name == "get" & (one_method_argument(call.arguments) | two_method_arguments(call.arguments))
    else if receiverType.name == "List"
    then call.name == "get" & (one_method_argument(call.arguments) | two_method_arguments(call.arguments))
    else if receiverType.name == "Dict"
    then (call.name == "contains_key" | call.name == "get") & one_method_argument(call.arguments)
    else if receiverType.name == "Tuple"
    then call.name == "get" & one_method_argument(call.arguments)
    else false

private fun native_stdlib_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then string_get_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "List"
    then list_get_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "Dict"
    then dict_method_code(call, receiverCode, env, module, allModules)
    else if receiverType.name == "Tuple"
    then tuple_get_method_code(call, receiverCode, expectedType, env, module, allModules)
    else "unsupported(\"native stdlib method\")"

private fun string_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if one_method_argument(call.arguments)
    then string_optional_index_code(receiverCode, index_argument_code(argument(call.arguments, 0), env, module, allModules))
    else "__capy_string_slice("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + index_argument_code(argument(call.arguments, 1), env, module, allModules)
        + ")"

private fun list_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if one_method_argument(call.arguments)
    then list_optional_index_code(receiverCode, index_argument_code(argument(call.arguments, 0), env, module, allModules))
    else "__capy_list_slice("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + index_argument_code(argument(call.arguments, 1), env, module, allModules)
        + ")"

private fun dict_method_code(call: CompiledMethodCallExpression, receiverCode: String, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let keyCode = expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
    if call.name == "contains_key"
    then receiverCode + ".containsKey(" + keyCode + ")"
    else dict_optional_index_code(receiverCode, keyCode)

private fun tuple_get_method_code(call: CompiledMethodCallExpression, receiverCode: String, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let methodType = method_call_type(call, env, module, allModules)
    let resultType = if expectedType.name.is_empty() | expectedType.name == "any" then methodType else expectedType
    "((" + boxed_java_type(resultType) + ") "
        + receiverCode
        + ".get(__capy_normalized_index("
        + receiverCode
        + ", "
        + index_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ")))"

private fun one_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ -> arguments[1:].is_empty()

private fun two_method_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some _ -> arguments[2:].is_empty()

private fun seq_as_list_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    call.name == "as_list" & seq_type_name(receiverType.name) & call.arguments.is_empty()

private fun collection_is_empty_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    call.name == "is_empty" & call.arguments.is_empty() & collection_empty_receiver_type(receiverType)

private fun collection_empty_receiver_type(type: CompiledTypeReference): bool =
    type.name == "List" | type.name == "Set" | type.name == "Dict" | type.name == "String" | seq_type_name(type.name)

private fun collection_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if seq_type_name(receiverType.name)
    then seq_receiver_code(call.receiver, receiverType, env, module, allModules) + ".asList().isEmpty()"
    else expression_code(call.receiver, env, receiverType, module, allModules) + ".isEmpty()"

private fun negated_collection_is_empty_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "is_empty"
        & call.arguments.is_empty()
        & match call.receiver with
            case CompiledUnaryExpression unary ->
                unary.operator == "!"
                    & collection_empty_receiver_type(expression_type(unary.expression, env, module, allModules))
            case _ -> false

private fun negated_collection_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledUnaryExpression unary ->
        let receiverType = expression_type(unary.expression, env, module, allModules)
        if seq_type_name(receiverType.name)
        then "!(" + seq_receiver_code(unary.expression, receiverType, env, module, allModules) + ".asList().isEmpty())"
        else "!(" + expression_code(unary.expression, env, receiverType, module, allModules) + ".isEmpty())"
    case _ -> "unsupported(\"negated collection is_empty\")"

private fun size_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let receiverCode = expression_code(call.receiver, env, receiverType, module, allModules)
    if receiverType.name == "String"
    then receiverCode + ".length()"
    else if receiverType.name == "char"
    then "((java.lang.String) " + receiverCode + ").length()"
    else receiverCode + ".size()"

private fun assert_is_empty_call(call: CompiledMethodCallExpression): bool =
    call.name == "is_empty"
        & call.arguments.is_empty()
        & match call.receiver with
            case CompiledFunctionCallExpression receiver -> receiver.name == "assert_that"
            case _ -> false

private fun assert_status_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    (call.name == "succeeded" | call.name == "failed")
        & call.arguments.is_empty()
        & assert_expression(call.receiver, env, module, allModules)

private fun assert_is_empty_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        assert_that_code(actual, env, module, allModules) + ".isEmpty()"
    case _ -> "unsupported(\"assert is_empty\")"

private fun option_assert_is_equal_to_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "is_equal_to"
        & match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & option_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
                    & !call.arguments.is_empty()
            case _ -> false

private fun option_assert_is_equal_to_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let expected = argument(call.arguments, 0)
        assert_that_code(actual, env, module, allModules)
            + ".isEqualTo(__capy_optional_value("
            + expression_code(expected, env, expression_type(expected, env, module, allModules), module, allModules)
            + "))"
    case _ -> "unsupported(\"option assert is_equal_to\")"

private fun result_assert_is_equal_to_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "is_equal_to"
        & match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & result_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
                    & !call.arguments.is_empty()
            case _ -> false

private fun result_assert_is_equal_to_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let expected = argument(call.arguments, 0)
        assert_that_code(actual, env, module, allModules)
            + ".isEqualTo(__capy_result_value("
            + expression_code(expected, env, expression_type(expected, env, module, allModules), module, allModules)
            + "))"
    case _ -> "unsupported(\"result assert is_equal_to\")"

private fun result_assert_succeeds_lambda_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "succeeds"
        & match call.receiver with
            case CompiledFunctionCallExpression receiver ->
                receiver.name == "assert_that"
                    & result_type_name(expression_type(argument(receiver.arguments, 0), env, module, allModules).name)
                    & result_assert_succeeds_lambda_argument(call.arguments)
            case _ -> false

private fun result_assert_succeeds_lambda_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case Some { expression } -> result_assert_succeeds_lambda_expression(expression) & no_second_expression(arguments)
    case None -> false

private fun no_second_expression(arguments: List[CompiledExpression]): bool =
    match arguments[1] with
    case None -> true
    case Some _ -> false

private fun no_third_expression(arguments: List[CompiledExpression]): bool =
    match arguments[2] with
    case None -> true
    case Some _ -> false

private fun result_assert_succeeds_lambda_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case _ -> false

private fun result_assert_succeeds_lambda_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let resultType = expression_type(actual, env, module, allModules)
        result_assert_succeeds_lambda_argument_code(actual, resultType, argument(call.arguments, 0), env, module, allModules)
    case _ -> "unsupported(\"result assert succeeds\")"

private fun result_assert_succeeds_lambda_argument_code(actual: CompiledExpression, resultType: CompiledTypeReference, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledLambdaExpression lambda ->
        assert_that_code(actual, env, module, allModules)
            + ".succeeds(" + lambda_code_for_value(lambda, first_type_argument(resultType), assert_type(), env, module, allModules) + ")"
    case _ -> "unsupported(\"result assert succeeds\")"

private fun assert_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    assert_method_supported(call.name) & assert_expression(call.receiver, env, module, allModules)

private fun assert_expression(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "assert_that" | call.name == "assert_all"
    case CompiledMethodCallExpression call -> assert_method_call(call, env, module, allModules) | assert_status_call(call, env, module, allModules)
    case CompiledVariableExpression variable -> lookup_binding(variable.name, env).name == "Assert"
    case _ -> expression_type(expression, env, module, allModules).name == "Assert"

private fun assert_method_supported(name: String): bool =
    name == "is_equal_to" | name == "is_true" | name == "is_false"
        | name == "is_greater_than" | name == "is_less_than"
        | name == "is_greater_or_equals_than" | name == "is_less_or_equals_than"
        | name == "is_zero" | name == "is_one" | name == "is_between"
        | name == "starts_with" | name == "does_not_start_with" | name == "contains"
        | name == "has_size" | name == "is_empty" | name == "succeeds" | name == "fails"
        | name == "has_day" | name == "has_month" | name == "has_year"
        | name == "has_hour" | name == "has_minute" | name == "has_second" | name == "has_offset_minutes"
        | name == "has_date" | name == "has_time"
        | name == "has_years" | name == "has_months" | name == "has_days" | name == "has_hours"
        | name == "has_minutes" | name == "has_seconds" | name == "has_weeks"
        | name == "has_start" | name == "has_end" | name == "has_duration"
        | name == "does_not_contain" | name == "contains_key" | name == "does_not_contain_key" | name == "contains_value"

private fun assert_method_call_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(call.receiver, env, assert_type(), module, allModules)
        + "." + java_method_name(call.name)
        + "(" + expression_list_code(call.arguments, env, module, allModules) + ")"

private fun extension_method_call_code(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    extension_method_call_code_with_receiver_type(function, call, receiverType, env, module, allModules)

private fun extension_method_call_code_with_receiver_type(function: CompiledFunction, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = bound_extension_method_parameters(function, receiverType)
    java_function_name(function)
        + "("
        + expression_code(call.receiver, env, receiverType, module, allModules)
        + extension_method_call_argument_tail(function.parameters, parameters, call.arguments, env, module, allModules)
        + ")"

private fun extension_method_call_argument_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + extension_parameter_expression_list_code(declaredParameters, boundParameters, arguments, env, module, allModules)

private fun extension_parameter_expression_list_code(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        extension_argument_code(expression, declaredType, boundType, env, module, allModules)
        + extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], env, module, allModules)

private fun extension_parameter_expression_list_tail(declaredParameters: List[CompiledFunctionParameter], boundParameters: List[CompiledFunctionParameter], expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        let fallback = expression_type(expression, env, module, allModules)
        let declaredType = parameter_type_at(declaredParameters, 0, fallback)
        let boundType = parameter_type_at(boundParameters, 0, fallback)
        ", " + extension_argument_code(expression, declaredType, boundType, env, module, allModules)
        + extension_parameter_expression_list_tail(declaredParameters[1:], boundParameters[1:], expressions[1:], env, module, allModules)

private fun extension_argument_code(expression: CompiledExpression, declaredType: CompiledTypeReference, boundType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = expression_code(expression, env, boundType, module, allModules)
    if extension_function_argument_needs_erased_cast(declaredType, boundType)
    then "((" + java_type(declaredType) + ") (" + raw_java_functional_type(declaredType) + ") " + code + ")"
    else code

private fun extension_function_argument_needs_erased_cast(declaredType: CompiledTypeReference, boundType: CompiledTypeReference): bool =
    function_type(declaredType) & function_type(boundType) & java_type(declaredType) != java_type(boundType)

private fun raw_java_functional_type(type: CompiledTypeReference): String =
    let parameters = function_type_parameters(type)
    if parameters.is_empty()
    then "java.util.function.Supplier"
    else if parameters.size().value == 1
    then "java.util.function.Function"
    else if parameters.size().value == 2
    then "java.util.function.BiFunction"
    else if parameters.size().value == 3
    then "__CapyFunction3"
    else if parameters.size().value == 4
    then "__CapyFunction4"
    else "java.lang.Object"

private fun bound_extension_method_parameters(function: CompiledFunction, receiverType: CompiledTypeReference): List[CompiledFunctionParameter] =
    bound_extension_parameters(function.parameters, extension_method_type_bindings(function, receiverType))

private fun bound_extension_parameters(parameters: List[CompiledFunctionParameter], bindings: List[JavaBinding]): List[CompiledFunctionParameter] =
    match parameters[0] with
    case None -> []
    case Some { parameter } -> [CompiledFunctionParameter {
        name: parameter.name,
        typeReference: bound_extension_type(parameter.typeReference, bindings),
        location: parameter.location
    }] + bound_extension_parameters(parameters[1:], bindings)

private fun bound_extension_method_return_type(function: CompiledFunction, receiverType: CompiledTypeReference): CompiledTypeReference =
    bound_extension_type(function.returnType, extension_method_type_bindings(function, receiverType))

private fun extension_method_type_bindings(function: CompiledFunction, receiverType: CompiledTypeReference): List[JavaBinding] =
    inferred_type_bindings(schema_type_reference(method_owner_name(function.name)), receiverType)

private fun bound_extension_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    if function_type(type)
    then bound_function_type(type, bindings)
    else bound_schema_type(type, bindings)

private fun bound_function_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    let parameters = bound_schema_types(function_type_parameters(type), bindings)
    let returnType = bound_schema_type(function_type_return_type_with_arguments(type), bindings)
    CompiledTypeReference {
        name: function_type_reference_text(parameters, returnType),
        arguments: []
    }

private fun function_type_return_type_with_arguments(type: CompiledTypeReference): CompiledTypeReference =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0
    then object_type()
    else function_type_return_type_with_arguments_text(type.name[arrow + 2, type.name.size().value], type.arguments)

private fun function_type_return_type_with_arguments_text(returnText: String, arguments: List[CompiledTypeReference]): CompiledTypeReference =
    let parsed = schema_type_reference(returnText)
    if parsed.arguments.is_empty()
    then CompiledTypeReference {
        name: parsed.name,
        arguments: arguments
    }
    else parsed

private fun function_type_reference_text(parameters: List[CompiledTypeReference], returnType: CompiledTypeReference): String =
    function_type_parameter_reference_text(parameters) + "=>" + type_reference_text(returnType)

private fun function_type_parameter_reference_text(parameters: List[CompiledTypeReference]): String =
    if parameters.is_empty()
    then "()"
    else if parameters[1:].is_empty()
    then type_reference_text(function_type_parameter_at(parameters, 0))
    else "(" + type_reference_list_text(parameters) + ")"

private fun type_reference_text(type: CompiledTypeReference): String =
    type.name + type_reference_arguments_text(type.arguments)

private fun type_reference_arguments_text(arguments: List[CompiledTypeReference]): String =
    if arguments.is_empty()
    then ""
    else "[" + type_reference_list_text(arguments) + "]"

private fun type_reference_list_text(types: List[CompiledTypeReference]): String =
    match types[0] with
    case None -> ""
    case Some { type } -> type_reference_text(type) + type_reference_list_tail(types[1:])

private fun type_reference_list_tail(types: List[CompiledTypeReference]): String =
    match types[0] with
    case None -> ""
    case Some { type } -> ", " + type_reference_text(type) + type_reference_list_tail(types[1:])

private fun primitive_conversion_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((" + java_type(method_call_type(call, env, module, allModules)) + ") "
    + expression_code(call.receiver, env, expression_type(call.receiver, env, module, allModules), module, allModules)
    + ")"

private fun string_parse_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    string_parse_method(call.name)
        & expression_type(call.receiver, env, module, allModules).name == "String"
        & call.arguments.is_empty()

private fun string_parse_method(name: String): bool =
    name == "to_int" | name == "to_long" | name == "to_double" | name == "to_float" | name == "to_bool"

private fun string_parse_method_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_parse_" + string_parse_method_suffix(call.name)
        + "(" + expression_code(call.receiver, env, string_type(), module, allModules) + ")"

private fun string_parse_method_suffix(name: String): String =
    if name == "to_int"
    then "int"
    else if name == "to_long"
    then "long"
    else if name == "to_double"
    then "double"
    else if name == "to_float"
    then "float"
    else "bool"

private fun char_to_string_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "to_string"
        & expression_type(call.receiver, env, module, allModules).name == "char"
        & call.arguments.is_empty()

private fun char_to_string_code(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.String) " + expression_code(call.receiver, env, object_type(), module, allModules) + ")"

private fun enum_name_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    call.name == "name"
        & call.arguments.is_empty()
        & (receiverType.name == "enum" | enum_type_exists(receiverType.name, module, allModules))

private fun lambda_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let params = lambda_parameters(lambda.parameters)
    params + " -> " + expression_code(lambda.body, lambda_env(lambda.parameters, env), expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules), module, allModules)

private fun lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function_type(expectedType)
    then typed_lambda_expression_code(lambda, env, expectedType, module, allModules)
    else if expectedType.name == "Supplier"
    then supplier_lambda_expression_code(lambda, env, first_type_argument(expectedType), module, allModules)
    else
        let code = lambda_code(lambda, env, module, allModules)
        if lambda.parameters.is_empty() & expectedType.name != "Supplier"
        then "((java.util.function.Supplier<java.lang.Object>) (" + code + "))"
        else code

private fun supplier_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    lambda_parameters(lambda.parameters)
        + " -> "
        + expression_code(lambda.body, lambda_env(lambda.parameters, env), expectedType, module, allModules)

private fun typed_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let parameters = function_type_parameters(expectedType)
    let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
    "((" + boxed_java_type(expectedType) + ") ("
        + lambda_parameters(lambda.parameters)
        + " -> "
        + expression_code(lambda.body, lambdaEnv, function_type_return_type(expectedType), module, allModules)
        + "))"

private fun typed_lambda_env(parameters: List[String], types: List[CompiledTypeReference], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } ->
        if parameter == "_"
        then typed_lambda_env(parameters[1:], type_reference_tail(types), env)
        else [java_binding(parameter, function_type_parameter_at(types, 0))]
            + typed_lambda_env(parameters[1:], type_reference_tail(types), env)

private fun lambda_code_for_value(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyCode = expression_code(lambda.body, lambdaEnv, expectedType, module, allModules)
    lambda_code_with_result(lambda.parameters, valueType, bodyCode)

private fun flat_map_lambda_code(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
    let bodyType = expression_type(lambda.body, lambdaEnv, module, allModules)
    let bodyCode = expression_code(lambda.body, lambdaEnv, bodyType, module, allModules)
    let resultCode =
        if collection_receiver_type(bodyType)
        then seq_receiver_code(lambda.body, bodyType, lambdaEnv, module, allModules)
        else bodyCode
    lambda_code_with_result(lambda.parameters, valueType, resultCode)

private fun lambda_code_with_result(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_code(parameters, valueType, resultCode)
    else lambda_parameters(parameters) + " -> " + resultCode

private fun tuple_lambda_code(parameters: List[String], valueType: CompiledTypeReference, resultCode: String): String =
    let tupleName = "__capy_tuple"
    tupleName + " -> {" + newline()
    + tuple_lambda_binding_statements(parameters, valueType.arguments, tupleName, 0, "            ")
    + "            return " + resultCode + ";" + newline()
    + "        }"

private fun tuple_lambda_binding_statements(parameters: List[String], types: List[CompiledTypeReference], tupleName: String, idx: int, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        let type = tuple_argument(types, 0)
        let statement =
            if parameter == "_"
            then ""
            else indent + java_type(type) + " " + java_identifier(parameter) + " = ((" + boxed_java_type(type) + ") ((java.util.List<?>) " + tupleName + ").get(" + idx + "));" + newline()
        statement + tuple_lambda_binding_statements(parameters[1:], types[1:], tupleName, idx + 1, indent)

private fun lambda_parameters(parameters: List[String]): String =
    if parameters.is_empty()
    then "()"
    else "(" + java_identifier_list(parameters) + ")"

private fun lambda_env(parameters: List[String], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [java_binding(parameter, object_type())] + lambda_env(parameters[1:], env)

private fun lambda_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    if tuple_lambda_parameters(parameters)
    then tuple_lambda_env(parameters, valueType.arguments, env)
    else lambda_single_value_env(parameters, valueType, env)

private fun lambda_single_value_env(parameters: List[String], valueType: CompiledTypeReference, env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } -> [java_binding(parameter, valueType)] + env

private fun tuple_lambda_env(parameters: List[String], types: List[CompiledTypeReference], env: List[JavaBinding]): List[JavaBinding] =
    match parameters[0] with
    case None -> env
    case Some { parameter } ->
        let rest = match types[0] with
            case None -> tuple_lambda_env(parameters[1:], [], env)
            case Some _ -> tuple_lambda_env(parameters[1:], types[1:], env)
        if parameter == "_"
        then rest
        else [java_binding(parameter, tuple_argument(types, 0))] + rest

private fun tuple_lambda_parameters(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ -> true

private fun index_code(index: CompiledIndexExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = expression_type(index.receiver, env, module, allModules)
    let receiverCode = expression_code(index.receiver, env, receiverType, module, allModules)
    let indexCode = index_argument_code(index.index, env, module, allModules)
    let resultType = expression_type(index, env, module, allModules)
    if !built_in_index_expression(index, receiverType)
    then user_defined_index_code(index, receiverType, env, expectedType, module, allModules)
    else if receiverType.name == "String" & index.hasEndIndex
    then "__capy_string_slice("
        + receiverCode
        + ", "
        + indexCode
        + ", "
        + index_argument_code(index.endIndex, env, module, allModules)
        + ")"
    else if receiverType.name == "String"
    then string_optional_index_code(receiverCode, indexCode)
    else if receiverType.name == "Tuple" & !index.hasEndIndex
    then "((" + boxed_java_type(resultType) + ") " + receiverCode + ".get(__capy_normalized_index(" + receiverCode + ", " + indexCode + ")))"
    else if receiverType.name == "Dict" & !index.hasEndIndex
    then dict_optional_index_code(receiverCode, expression_code(index.index, env, string_type(), module, allModules))
    else if index.hasEndIndex
    then "__capy_list_slice("
        + receiverCode
        + ", "
        + list_slice_start_index_code(index.index, env, module, allModules)
        + ", "
        + list_slice_end_index_code(receiverCode, index.endIndex, env, module, allModules)
        + ")"
    else list_optional_index_code(receiverCode, indexCode)

private fun built_in_index_expression(index: CompiledIndexExpression, receiverType: CompiledTypeReference): bool =
    if index.hasEndIndex
    then receiverType.name == "String" | receiverType.name == "Tuple" | receiverType.name == "List"
    else receiverType.name == "String" | receiverType.name == "Tuple" | receiverType.name == "List" | receiverType.name == "Dict"

private fun user_defined_index_code(index: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let call = index_get_call(index)
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } ->
        let callType = bound_extension_method_return_type(function, receiverType)
        value_conversion_code(extension_method_call_code_with_receiver_type(function, call, receiverType, env, module, allModules), callType, expectedType, module, allModules)
    case None -> value_conversion_code("unsupported(\"index get\")", object_type(), expectedType, module, allModules)

private fun index_get_call(index: CompiledIndexExpression): CompiledMethodCallExpression =
    CompiledMethodCallExpression {
        receiver: index.receiver,
        name: "get",
        arguments: index_get_arguments(index),
        location: index.location
    }

private fun index_get_arguments(index: CompiledIndexExpression): List[CompiledExpression] =
    if index.hasEndIndex
    then [index.index, index.endIndex]
    else [index.index]

private fun list_slice_start_index_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_start(literal)
        then "0"
        else index_argument_code(expression, env, module, allModules)
    case _ -> index_argument_code(expression, env, module, allModules)

private fun list_slice_end_index_code(receiverCode: String, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_end(literal)
        then receiverCode + ".size()"
        else index_argument_code(expression, env, module, allModules)
    case _ -> index_argument_code(expression, env, module, allModules)

private fun omitted_slice_end(literal: CompiledIntLiteral): bool =
    literal.source == "__capy_slice_end__"

private fun omitted_slice_start(literal: CompiledIntLiteral): bool =
    literal.source == "__capy_slice_start__"

private fun index_argument_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(expression, env, int_type(), module, allModules)

private fun index_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & value_assignable(int_type(), expression_type(expression, env, module, allModules), module, allModules)

private fun string_optional_index_code(receiverCode: String, indexCode: String): String =
    "__capy_string_get_optional(" + receiverCode + ", " + indexCode + ")"

private fun list_optional_index_code(receiverCode: String, indexCode: String): String =
    "__capy_list_get_optional(" + receiverCode + ", " + indexCode + ")"

private fun dict_optional_index_code(receiverCode: String, keyCode: String): String =
    "__capy_dict_get_optional(" + receiverCode + ", " + keyCode + ")"

private fun block_expression_code(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = block_expression_result_type(block, env, expectedType, module, allModules)
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + block_statements(block.bindings, env, resultType, module, allModules, "            ")
    + "            return " + block_result_code(block, env, expectedType, module, allModules) + ";" + newline()
    + "        }).get()"

private fun block_expression_result_type(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let resultEnv = block_env(block.bindings, env, module, allModules)
    let rawResultType = expression_type(block.result, resultEnv, module, allModules)
    if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules)
    then expectedType
    else rawResultType

private fun block_result_code(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultEnv = block_env(block.bindings, env, module, allModules)
    let rawResultType = expression_type(block.result, resultEnv, module, allModules)
    let resultExpectedType = if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules) then first_type_argument(expectedType) else expectedType
    let resultCode = expression_code(block.result, resultEnv, resultExpectedType, module, allModules)
    if result_block_wraps_success(block, env, expectedType, rawResultType, module, allModules)
    then "__capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", " + resultCode + ")))"
    else resultCode

private fun result_block_wraps_success(block: CompiledBlockExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, rawResultType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    result_type_name(expectedType.name)
        & !result_type_name(rawResultType.name)
        & result_bindings(block.bindings, env, module, allModules)

private fun result_bindings(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        let valueType = binding_value_type(binding, env, module, allModules)
        let localType =
            if binding.typeReference.name.is_empty()
            then if binding.operator == "<-" then first_type_argument(valueType) else valueType
            else binding.typeReference
        if binding.operator == "<-" & result_type_name(valueType.name)
        then true
        else result_bindings(bindings[1:], [local_java_binding(binding.name, localType, binding.location, env)] + env, module, allModules)

private fun block_statements(bindings: List[CompiledLetBinding], env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let localBinding = local_java_binding(binding.name, valueType, binding.location, env)
        binding_statement(binding, localBinding, env, valueType, expectedType, module, allModules, indent)
        + block_statements(bindings[1:], [localBinding] + env, expectedType, module, allModules, indent)

private fun binding_statement(binding: CompiledLetBinding, localBinding: JavaBinding, env: List[JavaBinding], valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if binding.operator == "<-"
    then monadic_binding_statement(binding, localBinding, env, valueType, expectedType, module, allModules, indent)
    else indent + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, valueType, module, allModules) + ";" + newline()

private fun monadic_binding_statement(binding: CompiledLetBinding, localBinding: JavaBinding, env: List[JavaBinding], valueType: CompiledTypeReference, expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let wrapperType = binding_value_type(binding, env, module, allModules)
    let bindName = "__capy_bind_" + localBinding.javaName
    if wrapperType.name == "Effect"
    then indent + java_type(valueType) + " " + localBinding.javaName + " = "
        + expression_code(binding.value, env, wrapperType, module, allModules) + ".unsafeRun();" + newline()
    else if result_type_name(wrapperType.name)
    then indent + "java.lang.Object " + bindName + " = " + expression_code(binding.value, env, wrapperType, module, allModules) + ";" + newline()
        + indent + "if (!__capy_result_is_success(" + bindName + ")) {" + newline()
        + indent + "    return ((" + boxed_java_type(expectedType) + ") " + bindName + ");" + newline()
        + indent + "}" + newline()
        + indent + java_type(valueType) + " " + localBinding.javaName + " = ((" + boxed_java_type(valueType) + ") __capy_result_success_value(" + bindName + "));" + newline()
    else indent + "java.lang.Object " + bindName + " = " + expression_code(binding.value, env, wrapperType, module, allModules) + ";" + newline()
        + indent + java_type(valueType) + " " + localBinding.javaName + " = ((" + boxed_java_type(valueType) + ") __capy_data_value_field(" + bindName + "));" + newline()

private fun block_env(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        block_env(bindings[1:], [local_java_binding(binding.name, valueType, binding.location, env)] + env, module, allModules)

private fun local_java_binding(name: String, typeReference: CompiledTypeReference, location: CompiledSourceLocation, env: List[JavaBinding]): JavaBinding =
    if binding_exists(name, env)
    then java_binding_with_java_name(name, typeReference, java_identifier(name) + "__" + location.line + "_" + location.column)
    else java_binding(name, typeReference)

private fun binding_type(binding: CompiledLetBinding, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if binding.typeReference.name.is_empty()
    then
        let valueType = inferred_binding_value_type(binding.value, binding_value_type(binding, env, module, allModules), env, module, allModules)
        if binding.operator == "<-"
        then first_type_argument(valueType)
        else valueType
    else binding.typeReference

private fun binding_value_type(binding: CompiledLetBinding, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(binding.value, env, module, allModules)

private fun inferred_binding_value_type(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledDataLiteral literal ->
        if valueType.arguments.is_empty()
        then inferred_data_literal_reference(valueType.name, literal, env, module, allModules)
        else valueType
    case CompiledLambdaExpression lambda -> inferred_lambda_function_type(lambda, env, module, allModules)
    case _ -> valueType

private fun inferred_lambda_function_type(lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let parameters = lambda_object_parameter_types(lambda.parameters)
    let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
    CompiledTypeReference {
        name: function_type_reference_text(parameters, expression_type(lambda.body, lambdaEnv, module, allModules)),
        arguments: []
    }

private fun lambda_object_parameter_types(parameters: List[String]): List[CompiledTypeReference] =
    match parameters[0] with
    case None -> []
    case Some _ -> [object_type()] + lambda_object_parameter_types(parameters[1:])

private fun assert_that_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let actualType = expression_type(expression, env, module, allModules)
    let actual = expression_code(expression, env, actualType, module, allModules)
    if actualType.name == "int"
    then "new capy.test.Assert.IntAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "long"
    then "new capy.test.Assert.LongAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "float"
    then "new capy.test.Assert.FloatAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "double"
    then "new capy.test.Assert.DoubleAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "bool"
    then "new capy.test.Assert.BoolAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "String"
    then "new capy.test.Assert.StringAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "List"
    then "new capy.test.Assert.ListAssert(java.util.List.of(), " + actual + ")"
    else if seq_type_name(actualType.name)
    then "new capy.test.Assert.ListAssert(java.util.List.of(), " + seq_receiver_code(expression, actualType, env, module, allModules) + ".asList())"
    else if actualType.name == "Set"
    then "new capy.test.Assert.SetAssert(java.util.List.of(), " + actual + ")"
    else if actualType.name == "Dict"
    then "new capy.test.Assert.DictAssert(java.util.List.of(), " + actual + ")"
    else if option_type_name(actualType.name)
    then "new capy.test.Assert.OptionAssert<" + boxed_java_type(first_type_argument(actualType)) + ">(java.util.List.of(), __capy_optional_value(" + actual + "))"
    else if result_type_name(actualType.name)
    then "new capy.test.Assert.ResultAssert<" + boxed_java_type(first_type_argument(actualType)) + ">(java.util.List.of(), __capy_result_value(" + actual + "))"
    else "new capy.test.Assert.DataAssert(java.util.List.of(), " + actual + ")"

private fun expression_list_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules)
        + expression_list_tail(expressions[1:], env, module, allModules)

private fun expression_list_tail(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } -> ", " + expression_code(expression, env, expression_type(expression, env, module, allModules), module, allModules) + expression_list_tail(expressions[1:], env, module, allModules)

private fun list_literal_code(literal: CompiledListLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let elementType = if expectedType.name == "List" then first_type_argument(expectedType) else object_type()
    "java.util.List.of(" + list_expression_list_code(literal.values, elementType, env, module, allModules) + ")"

private fun list_expression_list_code(expressions: List[CompiledExpression], elementType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, list_element_expected_type(elementType, expression, env, module, allModules), module, allModules)
        + list_expression_list_tail(expressions[1:], elementType, env, module, allModules)

private fun list_expression_list_tail(expressions: List[CompiledExpression], elementType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, list_element_expected_type(elementType, expression, env, module, allModules), module, allModules)
        + list_expression_list_tail(expressions[1:], elementType, env, module, allModules)

private fun list_element_expected_type(elementType: CompiledTypeReference, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if elementType.name.is_empty() | elementType.name == "any" | elementType.name == "Object"
    then expression_type(expression, env, module, allModules)
    else elementType

private fun tuple_literal_code(literal: CompiledTupleLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "java.util.List.of(" + tuple_expression_list_code(literal.values, expectedType.arguments, env, module, allModules) + ")"

private fun tuple_expression_list_code(expressions: List[CompiledExpression], expectedTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        expression_code(expression, env, tuple_expression_expected_type(expectedTypes, 0, expression, env, module, allModules), module, allModules)
        + tuple_expression_list_tail(expressions[1:], type_reference_tail(expectedTypes), env, module, allModules)

private fun tuple_expression_list_tail(expressions: List[CompiledExpression], expectedTypes: List[CompiledTypeReference], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + expression_code(expression, env, tuple_expression_expected_type(expectedTypes, 0, expression, env, module, allModules), module, allModules)
        + tuple_expression_list_tail(expressions[1:], type_reference_tail(expectedTypes), env, module, allModules)

private fun tuple_expression_expected_type(expectedTypes: List[CompiledTypeReference], idx: int, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expectedTypes[idx] with
    case Some { type } -> type
    case None -> expression_type(expression, env, module, allModules)

private fun type_reference_tail(types: List[CompiledTypeReference]): List[CompiledTypeReference] =
    if types.is_empty() then [] else types[1:]

private fun dict_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if entries.is_empty()
    then "java.util.Map.of()"
    else "__capy_dict_literal(" + dict_entries_code(entries, env, module, allModules) + ")"

private fun dict_entries_code(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        "java.util.Map.entry(" + expression_code(entry.key, env, string_type(), module, allModules) + ", " + expression_code(entry.value, env, expression_type(entry.value, env, module, allModules), module, allModules) + ")"
        + dict_entries_tail(entries[1:], env, module, allModules)

private fun dict_entries_tail(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some _ -> ", " + dict_entries_code(entries, env, module, allModules)

private fun data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if primitive_char_constructor(literal, expectedType)
    then primitive_char_constructor_code(literal, env, module, allModules)
    else if stdlib_date_time_data_literal(literal.typeName, module.imports)
    then stdlib_date_time_data_literal_code(literal, env, module, allModules)
    else if option_constructor_type(literal.typeName)
    then option_data_literal_code(literal, env, expectedType, module, allModules)
    else if program_success_literal(literal.typeName, module.imports)
    then "capy.lang.Program.Success.INSTANCE"
    else if program_failed_literal(literal.typeName, module.imports)
    then match literal.fields[0] with
        case Some { field } -> "new capy.lang.Program.Failed(" + expression_code(field.value, env, int_type(), module, allModules) + ")"
        case None -> "new capy.lang.Program.Failed(0)"
    else if raw_data_literal(literal.typeName)
    then raw_data_literal_code(literal, env, expectedType, module, allModules)
    else
        let declaredType = data_literal_declared_type(literal.typeName)
        let parentConstructors = data_parent_constructor_type_names(declaredType.name, module, allModules)
        if parentConstructors.is_empty()
        then match data_constructor_function(literal.typeName, module) with
            case Some { function } -> data_constructor_call_code(function, literal, env, module, allModules)
            case None -> raw_data_literal_code(literal, env, expectedType, module, allModules)
        else data_constructor_pipeline_code(parentConstructors + data_own_constructor_type_names(declaredType.name, module), literal, env, expectedType, module, allModules)

private fun raw_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredType = data_literal_declared_type(literal.typeName)
    let typeName = declaredType.name
    let rawLiteral = CompiledDataLiteral {
        typeName: typeName,
        fields: literal.fields,
        location: literal.location
    }
    let dataType = find_data_type(typeName, module, allModules)
    let bindings = data_type_bindings(dataType, data_literal_context_type(declaredType, expectedType), module, allModules)
    "__capy_data(\"" + escape_java_string(data_literal_type_name(typeName, dataType)) + "\", " + data_fields_code(rawLiteral.fields, env, dataType, bindings, module, allModules) + ")"

private fun raw_data_literal(typeName: String): bool =
    java_generator_string_has_prefix(typeName, "__capy_raw|")

private fun raw_data_literal_type_name(typeName: String): String =
    if raw_data_literal(typeName)
    then typeName["__capy_raw|".size().value, typeName.size().value]
    else typeName

private fun data_literal_declared_type(typeName: String): CompiledTypeReference =
    schema_type_reference(raw_data_literal_type_name(typeName))

private fun data_literal_context_type(declaredType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if declaredType.arguments.is_empty()
    then expectedType
    else declaredType

private fun data_constructor_function(typeName: String, module: CompiledModule): /capy/lang/Option[CompiledFunction] =
    if raw_data_literal(typeName)
    then /capy/lang/Option.None {}
    else find_function(data_constructor_function_name(data_literal_declared_type(typeName).name), module.functions)

private fun data_constructor_function_name(typeName: String): String =
    "__capy_constructor|" + typeName

private fun data_own_constructor_type_names(typeName: String, module: CompiledModule): List[String] =
    match data_constructor_function(typeName, module) with
    case Some _ -> [typeName]
    case None -> []

private fun data_parent_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    data_parent_constructor_type_names_from(data_type_parent_types(typeName, module, allModules), module)

private fun data_parent_constructor_type_names_from(typeNames: List[String], module: CompiledModule): List[String] =
    match typeNames[0] with
    case None -> []
    case Some { typeName } ->
        match data_constructor_function(typeName, module) with
        case Some _ -> [typeName] + data_parent_constructor_type_names_from(typeNames[1:], module)
        case None -> data_parent_constructor_type_names_from(typeNames[1:], module)

private fun data_constructor_pipeline_code(constructorTypes: List[String], literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredType = data_literal_declared_type(literal.typeName)
    let resultType = data_constructor_pipeline_type(declaredType.name, constructorTypes, module, allModules)
    let dataName = "__capy_constructor_data_" + literal.location.line + "_" + literal.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
    + "            java.lang.Object " + dataName + " = " + raw_data_literal_code(literal, env, expectedType, module, allModules) + ";" + newline()
    + data_constructor_pipeline_steps(constructorTypes, declaredType.name, dataName, 0, module, allModules)
    + data_constructor_pipeline_return(dataName, resultType)
    + "        }).get()"

private fun data_constructor_pipeline_steps(constructorTypes: List[String], literalTypeName: String, dataName: String, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match constructorTypes[0] with
    case None -> ""
    case Some { constructorType } ->
        match data_constructor_function(constructorType, module) with
        case Some { function } ->
            data_constructor_pipeline_step(function, constructorType, constructorType != literalTypeName, dataName, idx, module, allModules)
                + data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, dataName, idx + 1, module, allModules)
        case None -> data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, dataName, idx, module, allModules)

private fun data_constructor_pipeline_step(function: CompiledFunction, constructorType: String, parentConstructor: bool, dataName: String, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultName = dataName + "_result_" + idx
    "            java.lang.Object " + resultName + " = " + data_constructor_data_call_code(function, dataName, module, allModules) + ";" + newline()
    + "            if (__capy_result_is_error(" + resultName + ")) {" + newline()
    + "                return " + resultName + ";" + newline()
    + "            }" + newline()
    + "            if (__capy_result_is_success(" + resultName + ")) {" + newline()
    + data_constructor_pipeline_assignment(dataName, "__capy_result_success_value(" + resultName + ")", constructorType, parentConstructor, "                ")
    + "            } else {" + newline()
    + data_constructor_pipeline_assignment(dataName, resultName, constructorType, parentConstructor, "                ")
    + "            }" + newline()

private fun data_constructor_pipeline_assignment(dataName: String, valueCode: String, constructorType: String, parentConstructor: bool, indent: String): String =
    let constructorValue = "__capy_constructor_value(\"" + escape_java_string(constructorType) + "\", " + valueCode + ")"
    if parentConstructor
    then indent + dataName + " = __capy_merge_data(" + dataName + ", " + constructorValue + ");" + newline()
    else indent + dataName + " = " + constructorValue + ";" + newline()

private fun data_constructor_pipeline_return(dataName: String, resultType: CompiledTypeReference): String =
    if result_type_name(resultType.name)
    then "            return __capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", " + dataName + ")));" + newline()
    else "            return " + dataName + ";" + newline()

private fun data_constructor_pipeline_type(typeName: String, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then result_type(data_type_reference(typeName))
    else data_type_reference(typeName)

private fun data_constructor_pipeline_returns_result(constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match constructorTypes[0] with
    case None -> false
    case Some { constructorType } ->
        data_constructor_type_returns_result(constructorType, module, allModules)
            | data_constructor_pipeline_returns_result(constructorTypes[1:], module, allModules)

private fun data_constructor_type_returns_result(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match data_constructor_function(typeName, module) with
    case Some { function } -> data_constructor_function_returns_result(function, module, allModules)
    case None -> false

private fun data_constructor_function_returns_result(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    result_type_name(function.returnType.name)
        | result_type_name(data_constructor_inferred_return_type(function, module, allModules).name)

private fun data_constructor_data_call_code(function: CompiledFunction, dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_function_name(function) + "(" + data_constructor_data_call_arguments(function.parameters, dataName, module, allModules) + ")"

private fun data_constructor_data_call_arguments(parameters: List[CompiledFunctionParameter], dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        data_constructor_data_call_argument(parameter, dataName, module, allModules)
            + data_constructor_data_call_argument_tail(parameters[1:], dataName, module, allModules)

private fun data_constructor_data_call_argument_tail(parameters: List[CompiledFunctionParameter], dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + data_constructor_data_call_arguments(parameters, dataName, module, allModules)

private fun data_constructor_data_call_argument(parameter: CompiledFunctionParameter, dataName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    "((" + boxed_java_type(parameter.typeReference) + ") __capy_data_field(" + dataName + ", \"" + escape_java_string(parameter.name) + "\"))"

private fun data_constructor_call_code(function: CompiledFunction, literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = data_literal_declared_type(literal.typeName).name
    let callCode = java_function_name(function) + "(" + data_constructor_call_arguments(function.parameters, literal.fields, 0, env, module, allModules) + ")"
    if data_constructor_function_returns_result(function, module, allModules)
    then "__capy_constructor_result(\"" + escape_java_string(typeName) + "\", " + callCode + ")"
    else "__capy_constructor_value(\"" + escape_java_string(typeName) + "\", " + callCode + ")"

private fun data_constructor_call_arguments(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        expression_code(data_constructor_argument_value(fields, parameter.name, "$" + idx), env, parameter.typeReference, module, allModules)
            + data_constructor_call_argument_tail(parameters[1:], fields, idx + 1, env, module, allModules)

private fun data_constructor_call_argument_tail(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + data_constructor_call_arguments(parameters, fields, idx, env, module, allModules)

private fun data_constructor_argument_value(fields: List[CompiledDataField], name: String, positionalName: String): CompiledExpression =
    match fields[0] with
    case None -> missing_argument()
    case Some { field } ->
        if field.name == name | field.name == positionalName
        then field.value
        else data_constructor_argument_value(fields[1:], name, positionalName)

private fun stdlib_date_time_data_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    type_unqualified_name(typeName) == "DateTime" & stdlib_date_time_type_imported("DateTime", imports)

private fun stdlib_date_time_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "new capy.dateTime.DateTime("
        + expression_code(data_field_value(literal.fields, "date"), env, date_type(), module, allModules)
        + ", "
        + expression_code(data_field_value(literal.fields, "time"), env, time_type(), module, allModules)
        + ")"

private fun data_field_value(fields: List[CompiledDataField], name: String): CompiledExpression =
    match fields[0] with
    case None -> missing_argument()
    case Some { field } -> if field.name == name then field.value else data_field_value(fields[1:], name)

private fun primitive_char_constructor(literal: CompiledDataLiteral, expectedType: CompiledTypeReference): bool =
    literal.typeName == "char" & result_type_name(expectedType.name)

private fun primitive_char_constructor_code(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_char(" + expression_code(first_data_field_value(literal.fields), env, string_type(), module, allModules) + ")"

private fun first_data_field_value(fields: List[CompiledDataField]): CompiledExpression =
    match fields[0] with
    case Some { field } -> field.value
    case None -> missing_argument()

private fun data_literal_type_name(typeName: String, dataType: /capy/lang/Option[String]): String =
    match dataType with
    case Some { value } -> value
    case None -> typeName

private fun data_fields_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if fields.is_empty()
    then "java.util.Map.of()"
    else if data_fields_have_spread(fields)
    then "__capy_data_fields(" + data_field_entries_code(fields, env, dataType, bindings, module, allModules) + ")"
    else "java.util.Map.ofEntries(" + data_field_entries_code(fields, env, dataType, bindings, module, allModules) + ")"

private fun data_fields_have_spread(fields: List[CompiledDataField]): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> field.spread | data_fields_have_spread(fields[1:])

private fun data_field_entries_code(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        data_field_entry_code(field, env, dataType, bindings, module, allModules)
        + data_field_entries_tail(fields[1:], env, dataType, bindings, module, allModules)

private fun data_field_entry_code(field: CompiledDataField, env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if field.spread
    then expression_code(field.value, env, expression_type(field.value, env, module, allModules), module, allModules)
    else
        let fieldName = data_constructor_field_name(field.name, dataType, module, allModules)
        let fieldType = data_constructor_field_type(field.name, dataType, bindings, expression_type(field.value, env, module, allModules), module, allModules)
        "java.util.Map.entry(\"" + escape_java_string(fieldName) + "\", " + expression_code(field.value, env, fieldType, module, allModules) + ")"

private fun data_field_entries_tail(fields: List[CompiledDataField], env: List[JavaBinding], dataType: /capy/lang/Option[String], bindings: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + data_field_entries_code(fields, env, dataType, bindings, module, allModules)

private fun with_expression_code(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let rawReceiverType = with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = with_constructor_type_names(rawReceiverType.name, module, allModules)
    let rawWithCode = raw_with_expression_code(withExpression, rawReceiverType, env, module, allModules)
    if constructorTypes.is_empty()
    then rawWithCode
    else
        let resultType = with_constructor_result_type(rawReceiverType, constructorTypes, module, allModules)
        let dataName = "__capy_constructor_data_" + withExpression.location.line + "_" + withExpression.location.column + "_" + with_expression_receiver_depth(withExpression.receiver)
        "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            java.lang.Object " + dataName + " = " + rawWithCode + ";" + newline()
        + data_constructor_pipeline_steps(constructorTypes, rawReceiverType.name, dataName, 0, module, allModules)
        + data_constructor_pipeline_return(dataName, resultType)
        + "        }).get()"

private fun raw_with_expression_code(withExpression: CompiledWithExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_merge_data("
        + expression_code(withExpression.receiver, env, receiverType, module, allModules)
        + ", __capy_data(\"\", " + with_fields_code(withExpression.fields, receiverType, env, module, allModules) + "))"

private fun with_expression_receiver_type(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    expression_type(withExpression.receiver, env, module, allModules)

private fun with_expression_receiver_depth(expression: CompiledExpression): int =
    match expression with
    case CompiledWithExpression withExpression -> 1 + with_expression_receiver_depth(withExpression.receiver)
    case _ -> 0

private fun with_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    data_parent_constructor_type_names(typeName, module, allModules) + data_own_constructor_type_names(typeName, module)

private fun with_constructor_result_type(receiverType: CompiledTypeReference, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then result_type(receiverType)
    else receiverType

private fun with_fields_code(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if fields.is_empty()
    then "java.util.Map.of()"
    else "java.util.Map.ofEntries(" + with_field_entries_code(fields, receiverType, env, module, allModules) + ")"

private fun with_field_entries_code(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        let fieldType = with_field_type(field.name, receiverType, expression_type(field.value, env, module, allModules), module, allModules)
        "java.util.Map.entry(\"" + escape_java_string(field.name) + "\", " + expression_code(field.value, env, fieldType, module, allModules) + ")"
        + with_field_entries_tail(fields[1:], receiverType, env, module, allModules)

private fun with_field_entries_tail(fields: List[CompiledDataField], receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + with_field_entries_code(fields, receiverType, env, module, allModules)

private fun with_field_type(name: String, receiverType: CompiledTypeReference, fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_data_type(receiverType.name, module, allModules) with
    case Some { dataType } ->
        let bindings = data_type_bindings(/capy/lang/Option.Some { dataType }, receiverType, module, allModules)
        declared_named_field_type(name, data_type_fields(dataType, module, allModules), bindings, fallback)
    case None -> fallback

private fun data_constructor_field_name(name: String, dataType: /capy/lang/Option[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_generator_string_has_prefix(name, "$")
    then match dataType with
        case Some { value } -> declared_positional_field_name(name, data_type_fields(value, module, allModules), 0)
        case None -> name
    else name

private fun declared_positional_field_name(name: String, fields: List[String], idx: int): String =
    match fields[0] with
    case None -> name
    case Some { field } ->
        if name == "$" + idx
        then schema_field_name(field)
        else declared_positional_field_name(name, fields[1:], idx + 1)

private fun data_constructor_field_type(name: String, dataType: /capy/lang/Option[String], bindings: List[JavaBinding], fallback: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match dataType with
    case Some { value } ->
        if java_generator_string_has_prefix(name, "$")
        then declared_positional_field_type(name, data_type_fields(value, module, allModules), bindings, 0, fallback)
        else declared_named_field_type(name, data_type_fields(value, module, allModules), bindings, fallback)
    case None -> fallback

private fun declared_named_field_type(name: String, fields: List[String], bindings: List[JavaBinding], fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if schema_field_name(field) == name
        then generic_data_field_type(field, bindings)
        else declared_named_field_type(name, fields[1:], bindings, fallback)

private fun declared_positional_field_type(name: String, fields: List[String], bindings: List[JavaBinding], idx: int, fallback: CompiledTypeReference): CompiledTypeReference =
    match fields[0] with
    case None -> fallback
    case Some { field } ->
        if name == "$" + idx
        then generic_data_field_type(field, bindings)
        else declared_positional_field_type(name, fields[1:], bindings, idx + 1, fallback)

private fun generic_data_field_type(field: String, bindings: List[JavaBinding]): CompiledTypeReference =
    bound_schema_type(schema_type_reference(schema_field_type_name(field)), bindings)

private fun bound_schema_type(type: CompiledTypeReference, bindings: List[JavaBinding]): CompiledTypeReference =
    match lookup_type_parameter(type.name, bindings) with
    case Some { value } -> value
    case None -> CompiledTypeReference {
        name: type.name,
        arguments: bound_schema_types(type.arguments, bindings)
    }

private fun bound_schema_types(types: List[CompiledTypeReference], bindings: List[JavaBinding]): List[CompiledTypeReference] =
    match types[0] with
    case None -> []
    case Some { type } -> [bound_schema_type(type, bindings)] + bound_schema_types(types[1:], bindings)

private fun field_access_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if enum_static_field_access(access, env, module, allModules)
    then enum_static_field_access_code(access, module, allModules)
    else if access.name == "value" & numeric_type(expression_type(access.receiver, env, module, allModules))
    then expression_code(access.receiver, env, expectedType, module, allModules)
    else if access.name == "value" & stdlib_byte_count_type(expression_type(access.receiver, env, module, allModules))
    then stdlib_byte_count_value_code(access, env, expectedType, module, allModules)
    else
        let sourceType = field_access_type(access, env, module, allModules)
        let castType = field_access_cast_type(sourceType, expectedType)
        numeric_widening_code(
            "((" + boxed_java_type(castType) + ") __capy_data_field("
            + expression_code(access.receiver, env, expression_type(access.receiver, env, module, allModules), module, allModules)
            + ", \"" + escape_java_string(access.name) + "\"))",
            castType,
            expectedType
        )

private fun field_access_cast_type(sourceType: CompiledTypeReference, expectedType: CompiledTypeReference): CompiledTypeReference =
    if sourceType.name == "any"
    then expectedType
    else sourceType

private fun enum_static_field_access(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match access.receiver with
    case CompiledVariableExpression variable ->
        !binding_exists(variable.name, env)
            & enum_type_exists(variable.name, module, allModules)
            & (access.name == "values" | enum_value_exists(variable.name, access.name, module, allModules))
    case _ -> false

private fun enum_static_field_access_code(access: CompiledFieldAccessExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = enum_static_field_access_type_name(access)
    if access.name == "values"
    then "java.util.Set.of(" + enum_value_references_code(typeName, enum_values(typeName, module, allModules), module, allModules) + ")"
    else enum_value_reference_code(typeName, access.name, module, allModules)

private fun enum_static_field_access_type(access: CompiledFieldAccessExpression): CompiledTypeReference =
    let typeName = enum_static_field_access_type_name(access)
    if access.name == "values"
    then set_type(data_type_reference(typeName))
    else data_type_reference(typeName)

private fun enum_static_field_access_type_name(access: CompiledFieldAccessExpression): String =
    match access.receiver with
    case CompiledVariableExpression variable -> variable.name
    case _ -> ""

private fun reduce_expression_code(reduce: CompiledReduceExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = reduce_result_type(reduce.initial, env, expectedType, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = reduce_value_type(receiverType)
    let accumulatorSnapshot = "__capy_" + java_identifier(reduce.accumulatorName) + "_snapshot"
    let reduceEnv = reduce_env(reduce, resultType, valueType, accumulatorSnapshot, env)
    let receiverIterableCode = reduce_receiver_iterable_code(reduce.receiver, receiverType, env, module, allModules)
    if option_type_name(receiverType.name)
    then option_reduce_expression_code(reduce, receiverType, valueType, resultType, accumulatorSnapshot, reduceEnv, env, module, allModules)
    else if receiverType.name == "Dict"
    then "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            for (java.util.Map.Entry<java.lang.String, " + boxed_java_type(valueType) + "> __capy_entry : " + expression_code(reduce.receiver, env, receiverType, module, allModules) + ".entrySet()) {" + newline()
        + reduce_key_statement(reduce.keyName, "                ")
        + "                " + java_type(valueType) + " " + java_identifier(reduce.valueName) + " = __capy_entry.getValue();" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"
    else "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            for (" + java_type(valueType) + " " + java_identifier(reduce.valueName) + " : " + receiverIterableCode + ") {" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"

private fun option_reduce_expression_code(reduce: CompiledReduceExpression, receiverType: CompiledTypeReference, valueType: CompiledTypeReference, resultType: CompiledTypeReference, accumulatorSnapshot: String, reduceEnv: List[JavaBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let optionName = "__capy_option_reduce_" + reduce.location.line + "_" + reduce.location.column
    "((java.util.function.Supplier<" + boxed_java_type(resultType) + ">) () -> {" + newline()
        + "            " + java_type(resultType) + " " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.initial, env, resultType, module, allModules) + ";" + newline()
        + "            java.util.Optional<" + boxed_java_type(valueType) + "> " + optionName + " = ((java.util.Optional<" + boxed_java_type(valueType) + ">) __capy_optional_value(" + expression_code(reduce.receiver, env, receiverType, module, allModules) + "));" + newline()
        + "            if (" + optionName + ".isPresent()) {" + newline()
        + "                " + java_type(valueType) + " " + java_identifier(reduce.valueName) + " = ((" + boxed_java_type(valueType) + ") " + optionName + ".get());" + newline()
        + "                final " + java_type(resultType) + " " + accumulatorSnapshot + " = " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "                " + java_identifier(reduce.accumulatorName) + " = " + expression_code(reduce.body, reduceEnv, resultType, module, allModules) + ";" + newline()
        + "            }" + newline()
        + "            return " + java_identifier(reduce.accumulatorName) + ";" + newline()
        + "        }).get()"

private fun reduce_receiver_iterable_code(receiver: CompiledExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType.name == "String" | seq_type_name(receiverType.name)
    then seq_receiver_code(receiver, receiverType, env, module, allModules) + ".asList()"
    else expression_code(receiver, env, receiverType, module, allModules)

private fun reduce_result_type(initial: CompiledExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if empty_collection_literal_assignable(expectedType, initial)
    then expectedType
    else expression_type(initial, env, module, allModules)

private fun reduce_value_type(receiverType: CompiledTypeReference): CompiledTypeReference =
    if option_type_name(receiverType.name)
    then first_type_argument(receiverType)
    else collection_value_type(receiverType)

private fun reduce_env(reduce: CompiledReduceExpression, resultType: CompiledTypeReference, valueType: CompiledTypeReference, accumulatorJavaName: String, env: List[JavaBinding]): List[JavaBinding] =
    [java_binding_with_java_name(reduce.accumulatorName, resultType, accumulatorJavaName)]
        + reduce_key_env(reduce.keyName)
        + [java_binding(reduce.valueName, valueType)]
        + env

private fun reduce_key_env(keyName: String): List[JavaBinding] =
    if keyName.is_empty()
    then []
    else [java_binding(keyName, string_type())]

private fun reduce_key_statement(keyName: String, indent: String): String =
    if keyName.is_empty()
    then ""
    else indent + "java.lang.String " + java_identifier(keyName) + " = __capy_entry.getKey();" + newline()

private fun collection_value_type(type: CompiledTypeReference): CompiledTypeReference =
    if type.name == "List" | type.name == "Set" | seq_type_name(type.name) | type.name == "Dict"
    then first_type_argument(type)
    else if type.name == "String"
    then string_type()
    else object_type()

private fun collection_receiver_type(type: CompiledTypeReference): bool =
    type.name == "List" | type.name == "Set" | seq_type_name(type.name) | type.name == "String"

private fun collection_pipe_receiver_type(type: CompiledTypeReference): bool =
    collection_receiver_type(type) | type.name == "Dict"

private fun option_type_name(name: String): bool =
    stdlib_type_name(name, "Option")

private fun result_type_name(name: String): bool =
    stdlib_type_name(name, "Result")

private fun seq_type_name(name: String): bool =
    stdlib_type_name(name, "Seq")

private fun stdlib_type_name(name: String, member: String): bool =
    name == member | name == "/capy/lang/" + member | name == "capy/lang/" + member

private fun stdlib_type_reference_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    stdlib_type_reference_assignable_as(target, source, "Option")
        | stdlib_type_reference_assignable_as(target, source, "Result")
        | stdlib_type_reference_assignable_as(target, source, "Seq")

private fun stdlib_type_reference_assignable_as(target: CompiledTypeReference, source: CompiledTypeReference, member: String): bool =
    stdlib_type_name_equivalent(target.name, source.name, member)
        & type_arguments_assignable(target.arguments, source.arguments)

private fun stdlib_type_name_equivalent(target: String, source: String, member: String): bool =
    stdlib_type_name(target, member) & stdlib_type_name(source, member)

private fun stdlib_data_constructor_name(typeName: String, owner: String, member: String): bool =
    typeName == member
        | typeName == "/capy/lang/" + owner + "." + member
        | typeName == owner + "." + member

private fun match_expression_code(matchExpression: CompiledMatchExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueType = expression_type(matchExpression.value, env, module, allModules)
    let valueCode = expression_code(matchExpression.value, env, valueType, module, allModules)
    let matchValueName = "__capy_match_value_" + matchExpression.location.line + "_" + matchExpression.location.column
    let cases = ordered_match_cases(matchExpression.cases)
    "((java.util.function.Supplier<" + boxed_java_type(expectedType) + ">) () -> {" + newline()
    + "            " + java_type(valueType) + " " + matchValueName + " = " + valueCode + ";" + newline()
    + match_case_statements(cases, matchValueName, valueType, env, expectedType, module, allModules, "            ")
    + "            return unsupported(\"match\");" + newline()
    + "        }).get()"

private fun ordered_match_cases(cases: List[CompiledMatchCase]): List[CompiledMatchCase] =
    match_cases_with_guard(cases, true) + match_cases_with_guard(cases, false)

private fun match_cases_with_guard(cases: List[CompiledMatchCase], guarded: bool): List[CompiledMatchCase] =
    match cases[0] with
    case None -> []
    case Some { matchCase } ->
        if matchCase.hasGuard == guarded
        then [matchCase] + match_cases_with_guard(cases[1:], guarded)
        else match_cases_with_guard(cases[1:], guarded)

private fun match_case_statements(cases: List[CompiledMatchCase], valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match cases[0] with
    case None -> ""
    case Some { matchCase } ->
        indent + "if (" + match_case_condition_code(matchCase, valueCode, valueType, env, module, allModules) + ") {" + newline()
        + match_binding_statements(matchCase.bindings, matchCase, valueCode, valueType, 0, module, allModules, indent + "    ")
        + match_guarded_return_statement(matchCase, valueCode, valueType, env, expectedType, module, allModules, indent + "    ")
        + indent + "}" + newline()
        + match_case_statements(cases[1:], valueCode, valueType, env, expectedType, module, allModules, indent)

private fun match_guarded_return_statement(matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
    if matchCase.hasGuard
    then indent + "if (" + truthy_expression_code(matchCase.guard, caseEnv, module, allModules) + ") {" + newline()
        + indent + "    return " + expression_code(matchCase.body, caseEnv, expectedType, module, allModules) + ";" + newline()
        + indent + "}" + newline()
    else indent + "return " + expression_code(matchCase.body, caseEnv, expectedType, module, allModules) + ";" + newline()

private fun match_case_condition_code(matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if matchCase.wildcard
    then "true"
    else if matchCase.hasLiteral
    then "java.util.Objects.equals(" + valueCode + ", " + expression_code(matchCase.literal, env, valueType, module, allModules) + ")"
    else if option_match_case(matchCase, valueType)
    then option_match_condition_code(matchCase, valueCode)
    else if result_match_case(matchCase, valueType)
    then result_match_condition_code(matchCase, valueCode)
    else if matchCase.typeName == "data"
    then "__capy_data_is_any(" + valueCode + ")"
    else if matchCase.typeName == "enum"
    then "__capy_enum_is(" + valueCode + ")"
    else if collection_match_type(matchCase.typeName)
    then collection_match_condition_code(matchCase.typeName, valueCode)
    else if primitive_match_type(matchCase.typeName)
    then primitive_match_condition_code(matchCase.typeName, valueCode, valueType)
    else "__capy_data_is(" + valueCode + ", \"" + escape_java_string(matchCase.typeName) + "\")"

private fun option_match_case(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): bool =
    option_type_name(valueType.name) & option_constructor_type(matchCase.typeName)

private fun option_constructor_type(typeName: String): bool =
    option_some_constructor(typeName) | option_none_constructor(typeName)

private fun option_some_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Option", "Some")

private fun option_none_constructor(typeName: String): bool =
    stdlib_data_constructor_name(typeName, "Option", "None")

private fun option_match_condition_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if option_some_constructor(matchCase.typeName)
    then option_value_code(valueCode) + ".isPresent()"
    else option_value_code(valueCode) + ".isEmpty()"

private fun option_value_code(valueCode: String): String =
    "((java.util.Optional<?>) __capy_optional_value(" + valueCode + "))"

private fun result_match_case(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): bool =
    result_type_name(valueType.name) & result_constructor_type(matchCase.typeName)

private fun result_match_condition_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_result_is_success(" + valueCode + ")"
    else "__capy_result_is_error(" + valueCode + ")"

private fun primitive_match_condition_code(typeName: String, valueCode: String, valueType: CompiledTypeReference): String =
    if valueType.name == typeName
    then "true"
    else valueCode + " instanceof " + boxed_java_type(CompiledTypeReference { name: typeName, arguments: [] })

private fun collection_match_type(typeName: String): bool =
    typeName == "List" | typeName == "Set" | typeName == "Dict" | option_type_name(typeName)

private fun collection_match_condition_code(typeName: String, valueCode: String): String =
    if typeName == "List"
    then valueCode + " instanceof java.util.List<?>"
    else if typeName == "Set"
    then valueCode + " instanceof java.util.Set<?>"
    else if typeName == "Dict"
    then valueCode + " instanceof java.util.Map<?, ?> __capy_match_map && !__capy_match_map.containsKey(\"__type\")"
    else valueCode + " instanceof java.util.Optional<?>"

private fun match_binding_statements(bindings: List[String], matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let bindingType = match_binding_type(matchCase, valueType, idx, module, allModules)
        indent + java_type(bindingType) + " " + match_binding_java_name(binding, matchCase, idx) + " = ((" + boxed_java_type(bindingType) + ") " + match_binding_value_code(matchCase, valueCode, valueType, idx, module, allModules) + ");" + newline()
        + match_binding_statements(bindings[1:], matchCase, valueCode, valueType, idx + 1, module, allModules, indent)

private fun match_env(bindings: List[String], matchCase: CompiledMatchCase, valueType: CompiledTypeReference, idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        [java_binding_with_java_name(binding, match_binding_type(matchCase, valueType, idx, module, allModules), match_binding_java_name(binding, matchCase, idx))]
            + match_env(bindings[1:], matchCase, valueType, idx + 1, env, module, allModules)

private fun match_binding_java_name(binding: String, matchCase: CompiledMatchCase, idx: int): String =
    java_identifier(binding) + "__match_" + matchCase.location.line + "_" + matchCase.location.column + "_" + idx

private fun match_binding_field_name(matchCase: CompiledMatchCase, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    let fields = data_type_fields(matchCase.typeName, module, allModules)
    if fields.is_empty() & idx == 0
    then "value"
    else declared_positional_field_name("$" + idx, fields, 0)

private fun match_binding_type(matchCase: CompiledMatchCase, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if match_binding_whole_value(matchCase)
    then match_binding_whole_value_type(matchCase, valueType)
    else if option_match_case(matchCase, valueType)
    then first_type_argument(valueType)
    else if result_match_case(matchCase, valueType)
    then if result_success_constructor(matchCase.typeName) then first_type_argument(valueType) else object_type()
    else
        let dataType = find_data_type(matchCase.typeName, module, allModules)
        let bindings = data_type_bindings(dataType, valueType, module, allModules)
        declared_positional_field_type("$" + idx, data_type_fields(matchCase.typeName, module, allModules), bindings, 0, object_type())

private fun match_binding_value_code(matchCase: CompiledMatchCase, valueCode: String, valueType: CompiledTypeReference, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    if result_match_case(matchCase, valueType) & match_binding_whole_value(matchCase)
    then result_match_whole_value_code(matchCase, valueCode)
    else if match_binding_whole_value(matchCase)
    then valueCode
    else if option_match_case(matchCase, valueType)
    then option_value_code(valueCode) + ".orElse(null)"
    else if result_match_case(matchCase, valueType)
    then result_match_binding_value_code(matchCase, valueCode)
    else "__capy_data_field(" + valueCode + ", \"" + escape_java_string(match_binding_field_name(matchCase, idx, module, allModules)) + "\")"

private fun result_match_whole_value_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_data(\"Success\", java.util.Map.ofEntries(java.util.Map.entry(\"value\", __capy_result_success_value(" + valueCode + "))))"
    else "__capy_data(\"Error\", java.util.Map.ofEntries(java.util.Map.entry(\"message\", __capy_result_error_value(" + valueCode + "))))"

private fun result_match_binding_value_code(matchCase: CompiledMatchCase, valueCode: String): String =
    if result_success_constructor(matchCase.typeName)
    then "__capy_result_success_value(" + valueCode + ")"
    else "__capy_result_error_value(" + valueCode + ")"

private fun match_binding_whole_value(matchCase: CompiledMatchCase): bool =
    matchCase.bindsWholeValue | matchCase.wildcard | primitive_match_type(matchCase.typeName)

private fun match_binding_whole_value_type(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): CompiledTypeReference =
    if matchCase.typeName.is_empty()
    then valueType
    else if result_match_case(matchCase, valueType)
    then result_match_whole_value_type(matchCase, valueType)
    else CompiledTypeReference { name: matchCase.typeName, arguments: [] }

private fun result_match_whole_value_type(matchCase: CompiledMatchCase, valueType: CompiledTypeReference): CompiledTypeReference =
    if result_success_constructor(matchCase.typeName)
    then CompiledTypeReference { name: "/capy/lang/Result.Success", arguments: [first_type_argument(valueType)] }
    else CompiledTypeReference { name: "/capy/lang/Result.Error", arguments: [] }

private fun primitive_match_type(typeName: String): bool =
    typeName == "byte" | typeName == "int" | typeName == "long" | typeName == "float" | typeName == "double" | typeName == "bool" | typeName == "String"

private fun option_data_literal_code(literal: CompiledDataLiteral, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    if option_some_constructor(literal.typeName)
    then match literal.fields[0] with
        case Some { field } ->
            let valueType = option_data_literal_value_expected_type(field.value, expectedType, env, module, allModules)
            "java.util.Optional.ofNullable(" + expression_code(field.value, env, valueType, module, allModules) + ")"
        case None -> "java.util.Optional.ofNullable(null)"
    else "java.util.Optional.empty()"

private fun option_data_literal_value_expected_type(value: CompiledExpression, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if option_type_name(expectedType.name)
    then first_type_argument(expectedType)
    else expression_type(value, env, module, allModules)

private fun expression_type(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledUnsupportedExpression unsupported -> if compiled_placeholder_source(unsupported.source) then nothing_type() else object_type()
    case CompiledIntLiteral literal -> if byte_literal_source(literal.source) then byte_type() else int_type()
    case CompiledLongLiteral _ -> long_type()
    case CompiledFloatLiteral _ -> float_type()
    case CompiledDoubleLiteral _ -> double_type()
    case CompiledBoolLiteral _ -> bool_type()
    case CompiledStringLiteral _ -> string_type()
    case CompiledVariableExpression variable -> variable_expression_type(variable, env, module, allModules)
    case CompiledIfExpression ifExpression -> expression_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBinaryExpression binary ->
        let leftType = expression_type(binary.left, env, module, allModules)
        if result_reduce_operator_expression(binary, leftType)
        then result_reduce_method_type(result_reduce_operator_call(binary), env, module, allModules)
        else if result_pipe_expression(binary, leftType)
        then result_pipe_result_type(binary, leftType, env, module, allModules)
        else if option_pipe_expression(binary, leftType)
        then option_pipe_result_type(binary, leftType, env, module, allModules)
        else if collection_pipe_chained_method_expression(binary, leftType)
        then method_call_type(collection_pipe_chained_method_call(binary), env, module, allModules)
        else if collection_pipe_expression(binary, leftType)
        then collection_pipe_result_type(binary, leftType, env, module, allModules)
        else if binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
        then binary_extension_operator_type_with_left_type(binary, leftType, module, allModules)
        else if stdlib_path_slash_expression(binary, leftType, module)
        then stdlib_path_type()
        else binary_result_type(
            binary.operator,
            leftType,
            expression_type(binary.right, env, module, allModules)
        )
    case CompiledUnaryExpression unary -> if unary.operator == "!" then bool_type() else expression_type(unary.expression, env, module, allModules)
    case CompiledFunctionCallExpression call ->
        if partial_function_call(call)
        then partial_function_call_type(call, env, module, allModules)
        else function_call_type(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> function_reference_type(reference, module, allModules)
    case CompiledMethodCallExpression call ->
        if partial_method_call(call)
        then partial_method_call_type(call, env, module, allModules)
        else method_call_type(call, env, module, allModules)
    case CompiledWithExpression withExpression -> with_expression_type(withExpression, env, module, allModules)
    case CompiledLambdaExpression _ -> supplier_type(assert_type())
    case CompiledListLiteral literal -> list_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledSetLiteral literal -> set_type(first_expression_type(literal.values, env, module, allModules))
    case CompiledDictLiteral literal -> dict_type(first_dict_value_type(literal.entries, env, module, allModules))
    case CompiledTupleLiteral literal -> tuple_type(expression_types(literal.values, env, module, allModules))
    case CompiledIndexExpression index -> indexed_type(index, expression_type(index.receiver, env, module, allModules), env, module, allModules)
    case CompiledDataLiteral literal -> data_literal_expression_type(literal, env, module, allModules)
    case CompiledFieldAccessExpression access -> field_access_type(access, env, module, allModules)
    case CompiledReduceExpression reduce -> expression_type(reduce.initial, env, module, allModules)
    case CompiledMatchExpression matchExpression -> match_expression_type(matchExpression.cases, env, module, allModules)
    case CompiledBlockExpression block -> expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)

private fun data_literal_expression_type(literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if program_success_literal(literal.typeName, module.imports) | program_failed_literal(literal.typeName, module.imports)
    then CompiledTypeReference { name: "/capy/lang/Program", arguments: [] }
    else if option_some_constructor(literal.typeName)
    then option_type(option_literal_value_type(literal, env, module, allModules))
    else if option_none_constructor(literal.typeName)
    then option_type(nothing_type())
    else if result_success_literal(literal.typeName, module.imports)
    then result_type(result_literal_value_type(literal, env, module, allModules))
    else if result_error_literal(literal.typeName, module.imports)
    then result_type(object_type())
    else if raw_data_literal(literal.typeName)
    then data_literal_declared_type(literal.typeName)
    else
        let declaredType = data_literal_declared_type(literal.typeName)
        let parentConstructors = data_parent_constructor_type_names(declaredType.name, module, allModules)
        if parentConstructors.is_empty()
        then match data_constructor_function(literal.typeName, module) with
            case Some { function } -> data_constructor_literal_type(declaredType.name, function, module, allModules)
            case None ->
                if declaredType.arguments.is_empty()
                then inferred_data_literal_reference(declaredType.name, literal, env, module, allModules)
                else declaredType
        else data_constructor_pipeline_type(declaredType.name, parentConstructors + data_own_constructor_type_names(declaredType.name, module), module, allModules)

private fun with_expression_type(withExpression: CompiledWithExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = with_constructor_type_names(receiverType.name, module, allModules)
    if constructorTypes.is_empty()
    then receiverType
    else with_constructor_result_type(receiverType, constructorTypes, module, allModules)

private fun data_constructor_literal_type(typeName: String, function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if result_type_name(function.returnType.name)
    then function.returnType
    else if concrete_return_type(function.returnType)
    then function.returnType
    else
        let inferred = data_constructor_inferred_return_type(function, module, allModules)
        if result_type_name(inferred.name)
        then inferred
        else data_type_reference(typeName)

private fun data_constructor_inferred_return_type(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let constructorEnv = java_function_bindings(function) + constant_bindings(constant_functions(module.functions), module, allModules)
    data_constructor_inferred_expression_type(function.body, constructorEnv, module, allModules)

private fun data_constructor_inferred_expression_type(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expression with
    case CompiledIfExpression ifExpression -> preferred_result_type(
        data_constructor_inferred_expression_type(ifExpression.thenBranch, env, module, allModules),
        data_constructor_inferred_expression_type(ifExpression.elseBranch, env, module, allModules)
    )
    case CompiledBlockExpression block ->
        data_constructor_inferred_expression_type(block.result, block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> result_expression_type(expression, expression_type(expression, env, module, allModules), env, module, allModules)

private fun preferred_result_type(first: CompiledTypeReference, second: CompiledTypeReference): CompiledTypeReference =
    if result_type_name(first.name) & result_type_name(second.name)
    then if result_value_type_needs_context(first_type_argument(first)) then second else first
    else if result_type_name(first.name)
    then first
    else if result_type_name(second.name)
    then second
    else first

private fun data_type_reference(typeName: String): CompiledTypeReference =
    CompiledTypeReference { name: typeName, arguments: [] }

private fun inferred_data_literal_reference(typeName: String, literal: CompiledDataLiteral, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_data_type(typeName, module, allModules) with
    case Some { dataType } ->
        let parameters = data_type_parameters(dataType, module, allModules)
        if parameters.is_empty()
        then data_type_reference(typeName)
        else CompiledTypeReference {
            name: typeName,
            arguments: data_literal_type_arguments(parameters, data_literal_type_parameter_bindings(dataType, literal.fields, env, module, allModules))
        }
    case None -> data_type_reference(typeName)

private fun data_literal_type_parameter_bindings(dataType: String, fields: List[CompiledDataField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    data_literal_schema_bindings(data_type_fields(dataType, module, allModules), fields, 0, env, module, allModules)

private fun data_literal_schema_bindings(schemaFields: List[String], fields: List[CompiledDataField], idx: int, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match schemaFields[0] with
    case None -> []
    case Some { schemaField } ->
        let fieldValue = data_constructor_argument_value(fields, schema_field_name(schemaField), "$" + idx)
        let fieldType = schema_type_reference(schema_field_type_name(schemaField))
        inferred_type_bindings(fieldType, expression_type(fieldValue, env, module, allModules))
            + data_literal_schema_bindings(schemaFields[1:], fields, idx + 1, env, module, allModules)

private fun data_literal_type_arguments(parameters: List[String], bindings: List[JavaBinding]): List[CompiledTypeReference] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [data_literal_type_argument(parameter, bindings)] + data_literal_type_arguments(parameters[1:], bindings)

private fun data_literal_type_argument(parameter: String, bindings: List[JavaBinding]): CompiledTypeReference =
    match lookup_type_parameter(parameter, bindings) with
    case Some { value } -> value
    case None -> object_type()

private fun inferred_type_bindings(expected: CompiledTypeReference, actual: CompiledTypeReference): List[JavaBinding] =
    if type_parameter(expected)
    then [java_binding(expected.name, actual)]
    else inferred_type_argument_bindings(expected.arguments, actual.arguments)

private fun inferred_type_argument_bindings(expected: List[CompiledTypeReference], actual: List[CompiledTypeReference]): List[JavaBinding] =
    match expected[0] with
    case None -> []
    case Some { expectedType } ->
        match actual[0] with
        case Some { actualType } ->
            inferred_type_bindings(expectedType, actualType) + inferred_type_argument_bindings(expected[1:], actual[1:])
        case None -> inferred_type_argument_bindings(expected[1:], [])

private fun variable_expression_type(variable: CompiledVariableExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if binding_exists(variable.name, env)
    then lookup_binding(variable.name, env)
    else if qualified_enum_value_name(variable.name, module, allModules)
    then data_type_reference(enum_qualified_type_name(variable.name))
    else if variable.name == "DEFAULT_FAILED_EXIT_CODE" & program_member_imported(variable.name, module.imports)
    then int_type()
    else match imported_stdlib_constant(variable.name, module.imports) with
        case Some { constant } -> constant.typeReference
        case None ->
            match find_constant_in_scope(variable.name, module, allModules) with
            case Some { function } -> effective_function_return_type(function, module, allModules)
            case None -> object_type()

private fun match_expression_type(cases: List[CompiledMatchCase], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let orderedCases = ordered_match_cases(cases)
    match orderedCases[0] with
    case None -> object_type()
    case Some { matchCase } -> expression_type(matchCase.body, match_env(matchCase.bindings, matchCase, object_type(), 0, env, module, allModules), module, allModules)

private fun collection_pipe_result_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if receiverType.name == "Dict"
    then dict_pipe_result_type(binary, receiverType, env, module, allModules)
    else
        let valueType = collection_value_type(receiverType)
        match binary.right with
        case CompiledLambdaExpression lambda ->
            let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
            if binary.operator == "|-" | binary.operator == "|!"
            then seq_type(valueType)
            else if binary.operator == "|*"
            then flat_map_result_type(expression_type(lambda.body, lambdaEnv, module, allModules))
            else seq_type(expression_type(lambda.body, lambdaEnv, module, allModules))
        case CompiledFunctionReferenceExpression reference ->
            if binary.operator == "|-" | binary.operator == "|!"
            then seq_type(valueType)
            else if binary.operator == "|*"
            then flat_map_result_type(function_reference_type(reference, module, allModules))
            else seq_type(function_reference_type(reference, module, allModules))
        case _ -> object_type()

private fun dict_pipe_result_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let valueType = collection_value_type(receiverType)
    match binary.right with
    case CompiledLambdaExpression lambda ->
        if binary.operator == "|-" | binary.operator == "|!"
        then receiverType
        else if binary.operator == "|"
        then dict_type(expression_type(lambda.body, dict_predicate_lambda_env(lambda.parameters, valueType, env), module, allModules))
        else object_type()
    case _ -> object_type()

private fun flat_map_result_type(bodyType: CompiledTypeReference): CompiledTypeReference =
    if collection_receiver_type(bodyType)
    then seq_type(collection_value_type(bodyType))
    else seq_type(object_type())

private fun option_type(argument: CompiledTypeReference): CompiledTypeReference =
    CompiledTypeReference { name: "Option", arguments: [argument] }

private fun field_access_type(access: CompiledFieldAccessExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if enum_static_field_access(access, env, module, allModules)
    then enum_static_field_access_type(access)
    else
        let receiverType = expression_type(access.receiver, env, module, allModules)
        if access.name == "value" & numeric_type(receiverType)
        then receiverType
        else if access.name == "value" & stdlib_byte_count_type(receiverType)
        then long_type()
        else if result_match_whole_value_field(access.name, receiverType)
        then result_match_whole_value_field_type(access.name, receiverType)
        else match find_data_type(receiverType.name, module, allModules) with
            case Some { dataType } ->
                let bindings = data_type_bindings(/capy/lang/Option.Some { dataType }, receiverType, module, allModules)
                declared_named_field_type(access.name, data_type_fields(dataType, module, allModules), bindings, object_type())
            case None -> object_type()

private fun result_match_whole_value_field(name: String, receiverType: CompiledTypeReference): bool =
    (receiverType.name == "/capy/lang/Result.Error" & name == "message")
        | (receiverType.name == "/capy/lang/Result.Success" & name == "value")

private fun result_match_whole_value_field_type(name: String, receiverType: CompiledTypeReference): CompiledTypeReference =
    if receiverType.name == "/capy/lang/Result.Success" & name == "value"
    then first_type_argument(receiverType)
    else string_type()

private fun function_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "delay"
    then delay_call_type(call.arguments, env, module, allModules)
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_type_return_type(lookup_binding(call.name, env))
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then effect_type(expression_type(argument(call.arguments, 0), env, module, allModules))
    else if stdlib_effect_function_call(call, module)
    then stdlib_effect_function_call_type(call.name)
    else if stdlib_path_function_call(call, module)
    then stdlib_path_type()
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_type(call.name)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then effect_type(expression_type(argument(call.arguments, 0), env, module, allModules))
    else if console_read_line_call(call, module)
    then effect_type(option_type(string_type()))
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_type(call, env, module, allModules)
    else if call.name == "assert_all" | call.name == "assert_that"
    then assert_type()
    else if call.name == "test"
    then test_case_type()
    else if call.name == "test_file"
    then effect_type(test_file_type())
    else if stdlib_math_sqrt_call(call, module)
    then sqrt_call_type(call, env, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then int_type()
    else if enum_parse_call(call, module, allModules)
    then result_type(data_type_reference(enum_qualified_type_name(call.name)))
    else if qualified_call_name(call.name)
    then qualified_function_call_type(call.name, module, allModules)
    else function_call_type_in_scope(call, env, module, allModules)

private fun function_call_type_in_scope(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function_for_arguments(call.name, call.arguments, env, module, allModules) with
    case Some { function } -> effective_function_return_type(function, module, allModules)
    case None -> lookup_function_type_in_scope(call.name, module, allModules)

private fun stdlib_to_seq_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if argumentType.name == "Dict"
    then seq_type(tuple_type([string_type(), first_type_argument(argumentType)]))
    else seq_type(collection_value_type(argumentType))

private fun qualified_function_call_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_qualified_function(name, module, allModules) with
    case Some { function } -> effective_function_return_type(function, module, allModules)
    case None ->
        if qualified_call_member(name) == "main"
        then effect_type(CompiledTypeReference { name: "/capy/lang/Program", arguments: [] })
        else object_type()

private fun function_reference_type(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    lookup_function_type_in_scope(reference.name, module, allModules)

private fun function_reference_parameter_type(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } -> first_parameter_type(function.parameters)
    case None -> object_type()

private fun first_parameter_type(parameters: List[CompiledFunctionParameter]): CompiledTypeReference =
    match parameters[0] with
    case Some { parameter } -> parameter.typeReference
    case None -> object_type()

private fun delay_call_type(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match arguments[0] with
    case None -> effect_type(object_type())
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression lambda -> effect_type(expression_type(lambda.body, lambda_env(lambda.parameters, env), module, allModules))
        case _ -> effect_type(object_type())

private fun stdlib_effect_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.arguments.is_empty()
        & !function_defined(call.name, module.functions)
        & if call.name == "current_millis"
            then system_member_imported("current_millis", module.imports)
            else if call.name == "nano_time"
            then system_member_imported("nano_time", module.imports)
            else if call.name == "now"
            then clock_member_imported("now", module.imports)
            else false

private fun stdlib_effect_function_call_code(name: String): String =
    if name == "current_millis"
    then "capy.lang.System.currentMillis()"
    else if name == "nano_time"
    then "capy.lang.System.nanoTime()"
    else "capy.dateTime.Clock.now()"

private fun stdlib_effect_function_call_type(name: String): CompiledTypeReference =
    if name == "now"
    then effect_type(date_time_type())
    else effect_type(long_type())

private fun stdlib_path_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "from_string"
        & one_method_argument(call.arguments)
        & !function_defined(call.name, module.functions)
        & stdlib_path_member_imported("from_string", module.imports)

private fun stdlib_path_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.Object) capy.io.PathModule.fromString("
        + expression_code(argument(call.arguments, 0), env, string_type(), module, allModules)
        + "))"

private fun stdlib_path_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { value } -> call.arguments[1:].is_empty()
        & type_assignable(string_type(), expression_type(value, env, module, allModules))
        & expression_emittable(value, env, module, allModules)

private fun stdlib_io_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    !function_defined(call.name, module.functions)
        & stdlib_io_function_name(call.name)
        & stdlib_io_member_imported(call.name, module.imports)

private fun stdlib_io_function_name(name: String): bool =
    stdlib_io_one_path_function(name)
        | stdlib_io_text_payload_function(name)
        | stdlib_io_lines_payload_function(name)
        | stdlib_io_bytes_payload_function(name)
        | stdlib_io_two_path_function(name)

private fun stdlib_io_one_path_function(name: String): bool =
    name == "read_text"
        | name == "read_lines"
        | name == "read_bytes"
        | name == "exists"
        | name == "is_file"
        | name == "is_directory"
        | name == "size"
        | name == "create_file"
        | name == "create_directory"
        | name == "create_directories"
        | name == "list_entries"
        | name == "delete"

private fun stdlib_io_text_payload_function(name: String): bool =
    name == "write_text" | name == "append_text"

private fun stdlib_io_lines_payload_function(name: String): bool =
    name == "write_lines" | name == "append_lines"

private fun stdlib_io_bytes_payload_function(name: String): bool =
    name == "write_bytes" | name == "append_bytes"

private fun stdlib_io_two_path_function(name: String): bool =
    name == "copy" | name == "copy_replace" | name == "move" | name == "move_replace"

private fun stdlib_io_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let callCode = "capy.io.IO." + stdlib_io_java_method(call.name) + "(" + stdlib_io_arguments_code(call, env, module, allModules) + ")"
    if stdlib_io_bool_effect_function(call.name)
    then callCode
    else stdlib_effect_object_cast(callCode)

private fun stdlib_io_arguments_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if stdlib_io_one_path_function(call.name)
    then stdlib_path_argument_code(argument(call.arguments, 0), env, module, allModules)
    else stdlib_path_argument_code(argument(call.arguments, 0), env, module, allModules)
        + ", "
        + stdlib_io_second_argument_code(call.name, argument(call.arguments, 1), env, module, allModules)

private fun stdlib_io_second_argument_code(name: String, expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if stdlib_io_text_payload_function(name)
    then expression_code(expression, env, string_type(), module, allModules)
    else if stdlib_io_lines_payload_function(name)
    then expression_code(expression, env, list_type(string_type()), module, allModules)
    else if stdlib_io_bytes_payload_function(name)
    then expression_code(expression, env, list_type(byte_type()), module, allModules)
    else stdlib_path_argument_code(expression, env, module, allModules)

private fun stdlib_path_argument_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((capy.io.Path) " + expression_code(expression, env, object_type(), module, allModules) + ")"

private fun stdlib_effect_object_cast(code: String): String =
    "((capy.lang.Effect<java.lang.Object>) (capy.lang.Effect<?>) " + code + ")"

private fun stdlib_io_java_method(name: String): String =
    if name == "read_text"
    then "readText"
    else if name == "read_lines"
    then "readLines"
    else if name == "read_bytes"
    then "readBytes"
    else if name == "write_text"
    then "writeText"
    else if name == "write_lines"
    then "writeLines"
    else if name == "write_bytes"
    then "writeBytes"
    else if name == "append_text"
    then "appendText"
    else if name == "append_lines"
    then "appendLines"
    else if name == "append_bytes"
    then "appendBytes"
    else if name == "is_file"
    then "isFile"
    else if name == "is_directory"
    then "isDirectory"
    else if name == "create_file"
    then "createFile"
    else if name == "create_directory"
    then "createDirectory"
    else if name == "create_directories"
    then "createDirectories"
    else if name == "list_entries"
    then "listEntries"
    else if name == "copy_replace"
    then "copyReplace"
    else if name == "move_replace"
    then "moveReplace"
    else name

private fun stdlib_io_bool_effect_function(name: String): bool =
    name == "exists" | name == "is_file" | name == "is_directory"

private fun stdlib_io_function_call_type(name: String): CompiledTypeReference =
    if stdlib_io_bool_effect_function(name)
    then effect_type(bool_type())
    else effect_type(result_type(stdlib_io_result_value_type(name)))

private fun stdlib_io_result_value_type(name: String): CompiledTypeReference =
    if name == "read_text" | stdlib_io_text_payload_function(name)
    then string_type()
    else if name == "read_lines" | stdlib_io_lines_payload_function(name)
    then list_type(string_type())
    else if name == "read_bytes" | stdlib_io_bytes_payload_function(name)
    then list_type(byte_type())
    else if name == "size"
    then stdlib_byte_count_type_reference()
    else if name == "list_entries"
    then list_type(stdlib_path_type())
    else if name == "delete"
    then bool_type()
    else stdlib_path_type()

private fun stdlib_io_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if stdlib_io_one_path_function(call.name)
    then one_method_argument(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
    else if stdlib_io_text_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), string_type(), env, module, allModules)
    else if stdlib_io_lines_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), list_type(string_type()), env, module, allModules)
    else if stdlib_io_bytes_payload_function(call.name)
    then two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & typed_argument_emittable(argument(call.arguments, 1), list_type(byte_type()), env, module, allModules)
    else two_method_arguments(call.arguments)
        & stdlib_path_argument_emittable(argument(call.arguments, 0), env, module, allModules)
        & stdlib_path_argument_emittable(argument(call.arguments, 1), env, module, allModules)

private fun typed_argument_emittable(expression: CompiledExpression, expectedType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & type_assignable(expectedType, expression_type(expression, env, module, allModules))

private fun stdlib_path_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(expression, env, module, allModules)
        & stdlib_path_type_reference(expression_type(expression, env, module, allModules), module)

private fun stdlib_path_slash_expression(binary: CompiledBinaryExpression, leftType: CompiledTypeReference, module: CompiledModule): bool =
    binary.operator == "/"
        & stdlib_path_type_reference(leftType, module)
        & stdlib_path_member_imported("/", module.imports)

private fun stdlib_path_slash_code(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "((java.lang.Object) "
        + stdlib_path_argument_code(binary.left, env, module, allModules)
        + ".slash("
        + stdlib_path_slash_right_code(binary.right, env, module, allModules)
        + "))"

private fun stdlib_path_slash_right_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let rightType = expression_type(expression, env, module, allModules)
    if type_assignable(string_type(), rightType)
    then expression_code(expression, env, string_type(), module, allModules)
    else stdlib_path_argument_code(expression, env, module, allModules)

private fun stdlib_path_slash_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let rightType = expression_type(binary.right, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & expression_emittable(binary.right, env, module, allModules)
        & (type_assignable(string_type(), rightType) | stdlib_path_type_reference(rightType, module))

private fun stdlib_path_type_reference(type: CompiledTypeReference, module: CompiledModule): bool =
    type.name == "/capy/io/Path"
        | (type_unqualified_name(type.name) == "Path" & stdlib_path_member_imported("Path", module.imports))

private fun stdlib_path_type(): CompiledTypeReference =
    data_type_reference("Path")

private fun stdlib_byte_count_type_reference(): CompiledTypeReference =
    data_type_reference("byte_count")

private fun stdlib_byte_count_type(type: CompiledTypeReference): bool =
    type.name == "/capy/io/ByteSize.byte_count" | type_unqualified_name(type.name) == "byte_count"

private fun stdlib_byte_count_value_code(access: CompiledFieldAccessExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    numeric_widening_code(
        "((java.lang.Long) " + expression_code(access.receiver, env, object_type(), module, allModules) + ")",
        long_type(),
        expectedType
    )

private fun method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if call.name == "size"
    then int_type()
    else if char_to_string_call(call, env, module, allModules)
    then string_type()
    else if enum_name_method_call(call, env, module, allModules)
    then string_type()
    else if assert_status_call(call, env, module, allModules)
    then bool_type()
    else if assert_method_call(call, env, module, allModules)
    then assert_type()
    else if assert_is_empty_call(call) | negated_collection_is_empty_call(call, env, module, allModules) | collection_is_empty_call(call, env, module, allModules)
    then bool_type()
    else if collection_predicate_call(call, env, module, allModules)
    then bool_type()
    else if collection_reduce_method_call(call, env, module, allModules)
    then collection_reduce_method_type(call, env, module, allModules)
    else if option_method_call(call, env, module, allModules)
    then option_pipe_result_type(option_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if collection_method_call(call, env, module, allModules)
    then collection_pipe_result_type(collection_method_binary(call), expression_type(call.receiver, env, module, allModules), env, module, allModules)
    else if set_method_call(call, env, module, allModules)
    then set_method_call_type(call, env, module, allModules)
    else if seq_as_list_call(call, env, module, allModules)
    then list_type(collection_value_type(expression_type(call.receiver, env, module, allModules)))
    else if seq_first_call(call, env, module, allModules)
    then option_type(collection_value_type(expression_type(call.receiver, env, module, allModules)))
    else if function_value_method_call(call, env, module, allModules)
    then function_type_return_type(expression_type(call.receiver, env, module, allModules))
    else if result_reduce_method_call(call, env, module, allModules)
    then result_reduce_method_type(call, env, module, allModules)
    else if result_map_method_call(call, env, module, allModules)
    then result_map_method_type(call, env, module, allModules)
    else if result_or_else_method_call(call, env, module, allModules)
    then result_or_else_method_type(call, env, module, allModules)
    else if result_or_method_call(call, env, module, allModules)
    then result_or_method_type(call, env, module, allModules)
    else if call.name == "map" & expression_type(call.receiver, env, module, allModules).name == "Effect"
    then
        let valueType = first_type_argument(expression_type(call.receiver, env, module, allModules))
        match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda -> effect_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
        case _ -> effect_type(object_type())
    else if string_parse_method_call(call, env, module, allModules)
    then string_parse_result_type(call.name)
    else if native_stdlib_method_call(call, env, module, allModules)
    then native_stdlib_method_type(call, env, module, allModules)
    else if regex_method_call(call, env, module, allModules)
    then regex_method_type(call.name)
    else if stdlib_date_time_method_call(call, env, module, allModules)
    then stdlib_date_time_method_type(call, env, module, allModules)
    else if string_java_method_call(call, env, module, allModules)
    then string_java_method_type(call.name)
    else if call.name == "to_int"
    then int_type()
    else if call.name == "to_long"
    then long_type()
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> bound_extension_method_return_type(function, expression_type(call.receiver, env, module, allModules))
        case None -> assert_type()

private fun result_map_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    result_pipe_result_type(
        result_map_method_binary(call),
        expression_type(call.receiver, env, module, allModules),
        env,
        module,
        allModules
    )

private fun result_reduce_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda -> expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    case _ -> object_type()

private fun result_or_else_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if result_value_type_needs_context(valueType) then argumentType else valueType

private fun result_or_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if result_value_type_needs_context(valueType) & result_type_name(argumentType.name) then argumentType else receiverType

private fun result_value_type_needs_context(type: CompiledTypeReference): bool =
    type.name == "any" | type.name.is_empty() | type_parameter(type)

private fun regex_method_type(name: String): CompiledTypeReference =
    if name == "matches"
    then bool_type()
    else if name == "find"
    then option_type(regex_match_type())
    else if name == "find_all"
    then seq_type(regex_match_type())
    else if name == "replace"
    then string_to_string_function_type()
    else list_type(string_type())

private fun string_parse_result_type(name: String): CompiledTypeReference =
    if name == "to_int"
    then result_type(int_type())
    else if name == "to_long"
    then result_type(long_type())
    else if name == "to_double"
    then result_type(double_type())
    else if name == "to_float"
    then result_type(float_type())
    else result_type(bool_type())

private fun string_java_method_call(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_type(call.receiver, env, module, allModules).name == "String"
        & string_java_method(call.name)

private fun string_java_method(name: String): bool =
    name == "trim" | name == "replace" | name == "contains" | name == "starts_with" | name == "end_with"

private fun string_java_method_type(name: String): CompiledTypeReference =
    if name == "trim" | name == "replace"
    then string_type()
    else bool_type()

private fun native_stdlib_method_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if receiverType.name == "String"
    then if one_method_argument(call.arguments) then option_type(string_type()) else string_type()
    else if receiverType.name == "List"
    then if one_method_argument(call.arguments) then option_type(first_type_argument(receiverType)) else receiverType
    else if receiverType.name == "Dict"
    then if call.name == "contains_key" then bool_type() else option_type(first_type_argument(receiverType))
    else if receiverType.name == "Tuple"
    then tuple_get_method_type(call, receiverType)
    else object_type()

private fun set_method_call_type(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if set_predicate_method(call.name)
    then bool_type()
    else if call.name == "cartesian_product"
    then set_type(tuple_type([first_type_argument(receiverType), first_type_argument(expression_type(argument(call.arguments, 0), env, module, allModules))]))
    else if call.name == "power_set" | call.name == "℘"
    then set_type(receiverType)
    else receiverType

private fun set_predicate_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"

private fun tuple_get_method_type(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference): CompiledTypeReference =
    tuple_argument(receiverType.arguments, normalized_tuple_type_index(receiverType.arguments, argument(call.arguments, 0), 0))

private fun first_expression_type(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match expressions[0] with
    case None -> object_type()
    case Some { expression } -> expression_type(expression, env, module, allModules)

private fun first_dict_value_type(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match entries[0] with
    case None -> object_type()
    case Some { entry } -> expression_type(entry.value, env, module, allModules)

private fun expression_types(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): List[CompiledTypeReference] =
    match expressions[0] with
    case None -> []
    case Some { expression } -> [expression_type(expression, env, module, allModules)] + expression_types(expressions[1:], env, module, allModules)

private fun indexed_type(indexExpression: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if !built_in_index_expression(indexExpression, receiverType)
    then user_defined_index_type(receiverType, module, allModules)
    else if receiverType.name == "Tuple"
    then
        if indexExpression.hasEndIndex
        then tuple_type(tuple_slice_arguments(
            receiverType.arguments,
            normalized_tuple_type_index(receiverType.arguments, indexExpression.index, 0),
            normalized_tuple_slice_end_index(receiverType.arguments, indexExpression.endIndex)
        ))
        else tuple_argument(receiverType.arguments, normalized_tuple_type_index(receiverType.arguments, indexExpression.index, 0))
    else if receiverType.name == "List"
    then
        if indexExpression.hasEndIndex
        then receiverType
        else option_type(first_type_argument(receiverType))
    else if receiverType.name == "String"
    then if indexExpression.hasEndIndex then string_type() else option_type(string_type())
    else if receiverType.name == "Dict"
    then if indexExpression.hasEndIndex then object_type() else option_type(first_type_argument(receiverType))
    else object_type()

private fun user_defined_index_type(receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } -> bound_extension_method_return_type(function, receiverType)
    case None -> object_type()

private fun normalized_tuple_slice_end_index(arguments: List[CompiledTypeReference], expression: CompiledExpression): int =
    match expression with
    case CompiledIntLiteral literal ->
        if omitted_slice_end(literal)
        then arguments.size().value
        else normalized_tuple_type_index(arguments, expression, arguments.size().value)
    case _ -> arguments.size().value

private fun normalized_tuple_type_index(arguments: List[CompiledTypeReference], expression: CompiledExpression, fallback: int): int =
    match expression with
    case CompiledIntLiteral literal -> normalize_tuple_index(arguments, literal.value)
    case CompiledUnaryExpression unary ->
        if unary.operator == "-"
        then match unary.expression with
            case CompiledIntLiteral literal -> normalize_tuple_index(arguments, 0 - literal.value)
            case _ -> fallback
        else fallback
    case _ -> fallback

private fun normalize_tuple_index(arguments: List[CompiledTypeReference], index: int): int =
    if index < 0 then arguments.size().value + index else index

private fun tuple_slice_arguments(arguments: List[CompiledTypeReference], start: int, end: int): List[CompiledTypeReference] =
    tuple_slice_arguments_from(arguments, start, end, 0)

private fun tuple_slice_arguments_from(arguments: List[CompiledTypeReference], start: int, end: int, idx: int): List[CompiledTypeReference] =
    match arguments[0] with
    case None -> []
    case Some { argument } ->
        let rest = tuple_slice_arguments_from(arguments[1:], start, end, idx + 1)
        if idx >= start & idx < end
        then [argument] + rest
        else rest

private fun tuple_argument(arguments: List[CompiledTypeReference], index: int): CompiledTypeReference =
    match arguments[index] with
    case None -> object_type()
    case Some { argument } -> argument

private fun lookup_binding(name: String, env: List[JavaBinding]): CompiledTypeReference =
    match env[0] with
    case None -> object_type()
    case Some { binding } -> if binding.name == name then binding.typeReference else lookup_binding(name, env[1:])

private fun lookup_binding_java_name(name: String, env: List[JavaBinding]): String =
    match env[0] with
    case None -> java_identifier(name)
    case Some { binding } -> if binding.name == name then binding.javaName else lookup_binding_java_name(name, env[1:])

private fun lookup_function_type_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    match find_function(name, module.functions) with
    case Some { function } -> effective_function_return_type(function, module, allModules)
    case None ->
        match find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> effective_function_return_type(function, module, allModules)
        case None -> object_type()

private fun effective_function_return_type(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    if concrete_return_type(function.returnType) | function.returnType.name == "any"
    then function.returnType
    else if expression_references_function(function.body, function.name)
    then function.returnType
    else
        let owner = function_owner_module(function, module, allModules)
        let env = java_function_bindings(function) + constant_bindings(constant_functions(owner.functions), owner, allModules)
        expression_type(function.body, env, owner, allModules)

private fun function_owner_module(function: CompiledFunction, fallback: CompiledModule, modules: List[CompiledModule]): CompiledModule =
    match modules[0] with
    case None -> fallback
    case Some { module } ->
        if module_contains_function(function, module.functions)
        then module
        else function_owner_module(function, fallback, modules[1:])

private fun module_contains_function(expected: CompiledFunction, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        same_function(expected, function) | module_contains_function(expected, functions[1:])

private fun same_function(first: CompiledFunction, second: CompiledFunction): bool =
    first.name == second.name
        & first.location.line == second.location.line
        & first.location.column == second.location.column

private fun expression_references_function(expression: CompiledExpression, name: String): bool =
    match expression with
    case CompiledUnsupportedExpression _ -> false
    case CompiledIntLiteral _ -> false
    case CompiledLongLiteral _ -> false
    case CompiledFloatLiteral _ -> false
    case CompiledDoubleLiteral _ -> false
    case CompiledBoolLiteral _ -> false
    case CompiledStringLiteral _ -> false
    case CompiledVariableExpression _ -> false
    case CompiledIfExpression ifExpression ->
        expression_references_function(ifExpression.condition, name)
            | expression_references_function(ifExpression.thenBranch, name)
            | expression_references_function(ifExpression.elseBranch, name)
    case CompiledBinaryExpression binary ->
        expression_references_function(binary.left, name) | expression_references_function(binary.right, name)
    case CompiledUnaryExpression unary -> expression_references_function(unary.expression, name)
    case CompiledFunctionCallExpression call ->
        call.name == name | expressions_reference_function(call.arguments, name)
    case CompiledFunctionReferenceExpression reference -> reference.name == name
    case CompiledMethodCallExpression call ->
        expression_references_function(call.receiver, name) | expressions_reference_function(call.arguments, name)
    case CompiledWithExpression withExpression ->
        expression_references_function(withExpression.receiver, name)
            | data_fields_reference_function(withExpression.fields, name)
    case CompiledLambdaExpression lambda -> expression_references_function(lambda.body, name)
    case CompiledListLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledSetLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledDictLiteral literal -> dict_entries_reference_function(literal.entries, name)
    case CompiledTupleLiteral literal -> expressions_reference_function(literal.values, name)
    case CompiledIndexExpression index ->
        expression_references_function(index.receiver, name)
            | expression_references_function(index.index, name)
            | (index.hasEndIndex & expression_references_function(index.endIndex, name))
    case CompiledDataLiteral literal -> data_fields_reference_function(literal.fields, name)
    case CompiledFieldAccessExpression access -> expression_references_function(access.receiver, name)
    case CompiledReduceExpression reduce ->
        expression_references_function(reduce.receiver, name)
            | expression_references_function(reduce.initial, name)
            | expression_references_function(reduce.body, name)
    case CompiledMatchExpression matchExpression ->
        expression_references_function(matchExpression.value, name)
            | match_cases_reference_function(matchExpression.cases, name)
    case CompiledBlockExpression block ->
        let_bindings_reference_function(block.bindings, name)
            | expression_references_function(block.result, name)

private fun expressions_reference_function(expressions: List[CompiledExpression], name: String): bool =
    match expressions[0] with
    case None -> false
    case Some { expression } -> expression_references_function(expression, name) | expressions_reference_function(expressions[1:], name)

private fun dict_entries_reference_function(entries: List[CompiledDictEntry], name: String): bool =
    match entries[0] with
    case None -> false
    case Some { entry } ->
        expression_references_function(entry.key, name)
            | expression_references_function(entry.value, name)
            | dict_entries_reference_function(entries[1:], name)

private fun data_fields_reference_function(fields: List[CompiledDataField], name: String): bool =
    match fields[0] with
    case None -> false
    case Some { field } ->
        expression_references_function(field.value, name) | data_fields_reference_function(fields[1:], name)

private fun match_cases_reference_function(cases: List[CompiledMatchCase], name: String): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        (matchCase.hasLiteral & expression_references_function(matchCase.literal, name))
            | (matchCase.hasGuard & expression_references_function(matchCase.guard, name))
            | expression_references_function(matchCase.body, name)
            | match_cases_reference_function(cases[1:], name)

private fun let_bindings_reference_function(bindings: List[CompiledLetBinding], name: String): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        expression_references_function(binding.value, name) | let_bindings_reference_function(bindings[1:], name)

private fun find_function_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_function(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports(name, module.imports, module, allModules)

private fun constant_exists_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_constant_in_scope(name, module, allModules) with
    case Some _ -> true
    case None -> false

private fun find_constant_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_constant(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_constant_in_imports(name, module.imports, module, allModules)

private fun find_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name & compiled_constant(function) & !compiled_schema(function)
        then /capy/lang/Option.Some { function }
        else find_constant(name, functions[1:])

private fun find_constant_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if constant_import_matches(name, declaration)
        then find_constant_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_constant_in_imports(name, imports[1:], module, allModules)

private fun find_constant_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_constant_in_imported_module(name, rest, module, allModules, importedModule)
    case None -> find_constant_in_imports(name, rest, module, allModules)

private fun find_constant_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_constant(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_constant_in_imports(name, rest, module, allModules)

private fun constant_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    !stdlib_import(declaration.modulePath)
        & !declaration.qualified
        & import_includes_name(name, declaration)

private fun find_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_function_for_arguments_in_functions(name, arguments, env, module.functions, module, allModules) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports_for_arguments(name, arguments, env, module.imports, module, allModules)

private fun find_function_for_arguments_in_functions(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    best_function_for_arguments(name, arguments, env, functions, module, allModules, /capy/lang/Option.None {}, 1000000)

private fun best_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> best
    case Some { function } ->
        if function.name == name
        then best_matching_function_for_arguments(name, arguments, env, functions, module, allModules, best, bestScore, function)
        else best_function_for_arguments(name, arguments, env, functions[1:], module, allModules, best, bestScore)

private fun best_matching_function_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], best: /capy/lang/Option[CompiledFunction], bestScore: int, function: CompiledFunction): /capy/lang/Option[CompiledFunction] =
    if compiled_constant(function)
    then best_function_for_arguments(name, arguments, env, functions[1:], module, allModules, best, bestScore)
    else if parameters_assignable(function.parameters, arguments, env, module, allModules)
    then
        let score = function_argument_score(function.parameters, arguments, env, module, allModules)
        if score < bestScore
        then best_function_for_arguments(name, arguments, env, functions[1:], module, allModules, /capy/lang/Option.Some { function }, score)
        else best_function_for_arguments(name, arguments, env, functions[1:], module, allModules, best, bestScore)
    else best_function_for_arguments(name, arguments, env, functions[1:], module, allModules, best, bestScore)

private fun find_function_in_imports_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then find_function_in_import_for_arguments(name, arguments, env, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_function_in_imports_for_arguments(name, arguments, env, imports[1:], module, allModules)

private fun find_function_in_import_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function_in_imported_module_for_arguments(name, arguments, env, rest, module, allModules, importedModule)
    case None -> find_function_in_imports_for_arguments(name, arguments, env, rest, module, allModules)

private fun find_function_in_imported_module_for_arguments(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function_for_arguments_in_functions(name, arguments, env, importedModule.functions, module, allModules) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_function_in_imports_for_arguments(name, arguments, env, rest, module, allModules)

private fun function_argument_score(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    match parameters[0] with
    case None -> 0
    case Some { parameter } ->
        match arguments[0] with
        case None -> 1000000
        case Some { argument } ->
            parameter_argument_score(parameter.typeReference, argument, env, module, allModules)
                + function_argument_score(parameters[1:], arguments[1:], env, module, allModules)

private fun parameter_argument_score(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): int =
    if empty_collection_literal_assignable(target, argument) | function_reference_assignable(target, argument, module, allModules) | function_lambda_assignable(target, argument, env, module, allModules)
    then 0
    else type_match_score(target, expression_type(argument, env, module, allModules), module, allModules)

private fun type_match_score(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): int =
    if target.name == source.name & type_arguments_assignable(target.arguments, source.arguments)
    then 0
    else if target.name == "any"
    then 1000
    else if primitive_numeric_widening_assignable(target, source)
    then 10
    else if runtime_supertype_assignable(target, source, module, allModules)
    then 100
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then data_type_match_score(target.name, source.name, module, allModules)
    else if type_assignable(target, source)
    then 100
    else primitive_backed_type_match_score(target, source, module, allModules)

private fun primitive_backed_type_match_score(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): int =
    match primitive_backed_backing_type(source.name, module, allModules) with
    case Some { backingType } -> if type_assignable(target, backingType) then 100 else 1000000
    case None -> 1000000

private fun data_type_match_score(targetName: String, sourceName: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    let distance = data_type_distance(targetName, sourceName, module, allModules)
    if distance >= 0 then distance else 500

private fun find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name & !compiled_constant(function)
        then /capy/lang/Option.Some { function }
        else find_function(name, functions[1:])

private fun find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then find_function_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_function_in_imports(name, imports[1:], module, allModules)

private fun function_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    !stdlib_import(declaration.modulePath)
        & !declaration.qualified
        & import_includes_name(name, declaration)

private fun find_extension_method(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    find_extension_method_in_scope(receiverType.name, call.name, module, allModules)

private fun find_binary_extension_operator(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = expression_type(binary.left, env, module, allModules)
    find_binary_extension_operator_with_left_type(binary, receiverType, module, allModules)

private fun find_binary_extension_operator_with_left_type(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    find_extension_method_in_scope(receiverType.name, binary.operator, module, allModules)

private fun find_extension_method_in_scope(ownerName: String, methodName: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_extension_method_in_imports(ownerName, methodName, module.imports, module, allModules)

private fun find_method_function(ownerName: String, methodName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if method_function_matches(ownerName, methodName, function)
        then /capy/lang/Option.Some { function }
        else find_method_function(ownerName, methodName, functions[1:])

private fun method_function_matches(ownerName: String, methodName: String, function: CompiledFunction): bool =
    if compiled_constant(function)
    then false
    else
        let idx = last_dot_index(function.name)
        if idx < 0
        then false
        else method_owner_matches(function.name[0, idx], ownerName)
            & method_member_matches(function.name[idx + 1, function.name.size().value], methodName)

private fun method_owner_matches(declaredOwner: String, actualOwner: String): bool =
    method_owner_base_name(declaredOwner) == method_owner_base_name(actualOwner)

private fun method_owner_base_name(name: String): String =
    let bracket = first_index_of(name, "[", 0)
    if bracket < 0 then name else name[0, bracket]

private fun method_member_matches(declaredMember: String, actualMember: String): bool =
    method_member_name_normalized(declaredMember) == method_member_name_normalized(actualMember)

private fun method_member_name_normalized(name: String): String =
    if name.size().value >= 2 & java_generator_string_has_prefix(name, "`")
    then name[1, name.size().value - 1]
    else name

private fun find_extension_method_in_imports(ownerName: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.wildcard
            & !stdlib_import(declaration.modulePath)
            & !declaration.qualified
            & !string_list_contains(declaration.excludedNames, methodName)
        then find_extension_method_in_import(ownerName, methodName, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_extension_method_in_imports(ownerName, methodName, imports[1:], module, allModules)

private fun find_extension_method_in_import(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_extension_method_in_imported_module(ownerName, methodName, rest, module, allModules, importedModule)
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

private fun find_extension_method_in_imported_module(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_method_function(ownerName, methodName, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

private fun find_function_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function_in_imported_module(name, rest, module, allModules, importedModule)
    case _ -> find_function_in_imports(name, rest, module, allModules)

private fun find_function_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case _ -> find_function_in_imports(name, rest, module, allModules)

private fun find_module_by_class(className: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } -> if module_fqcn(module) == className then /capy/lang/Option.Some { module } else find_module_by_class(className, modules[1:])

private fun find_data_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if qualified_call_name(name)
    then find_qualified_data_type(name, module, allModules)
    else if schema_type_exists(name, module.functions)
    then /capy/lang/Option.Some { name }
    else match find_data_type_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> /capy/lang/Option.Some { value }
        case None -> find_data_type_in_modules(name, allModules)

private fun find_qualified_data_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    find_qualified_data_type_in_class(
        qualified_call_class_name(name, module),
        qualified_call_member(name),
        allModules
    )

private fun find_qualified_data_type_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(member, importedModule.functions)
        then /capy/lang/Option.Some { member }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

private fun find_data_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then find_data_type_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else find_data_type_in_imports(name, imports[1:], module, allModules)

private fun find_data_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_imports(name, rest, module, allModules)
    case _ -> find_data_type_in_imports(name, rest, module, allModules)

private fun find_data_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then /capy/lang/Option.Some { name }
        else find_data_type_in_modules(name, modules[1:])

private fun schema_type_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        schema_function(function, "__capy_schema_type|" + name)
            | schema_type_exists(name, functions[1:])

private fun schema_function(function: CompiledFunction, name: String): bool =
    compiled_schema(function) & function.name == name

private fun schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if compiled_schema(function) & java_generator_string_has_prefix(function.name, prefix)
        then [schema_value(function)] + schema_values(prefix, functions[1:])
        else schema_values(prefix, functions[1:])

private fun schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

private fun schema_value_named(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if schema_function(function, name)
        then /capy/lang/Option.Some { schema_value(function) }
        else schema_value_named(name, functions[1:])

private fun enum_type_exists(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    !enum_values(name, module, allModules).is_empty()

private fun enum_value_exists(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    string_list_contains(enum_values(typeName, module, allModules), valueName)

private fun enum_values(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if enum_type_exists_in_functions(name, module.functions)
    then enum_values_in_functions(name, module.functions)
    else match enum_values_in_imports(name, module.imports, module, allModules) with
        case Some { values } -> values
        case None -> []

private fun enum_type_exists_in_functions(name: String, functions: List[CompiledFunction]): bool =
    !enum_values_in_functions(name, functions).is_empty()

private fun enum_values_in_functions(name: String, functions: List[CompiledFunction]): List[String] =
    schema_values("__capy_schema_enum|" + name + "|", functions)

private fun enum_values_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then enum_values_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else enum_values_in_imports(name, imports[1:], module, allModules)

private fun enum_values_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if enum_type_exists_in_functions(name, importedModule.functions)
        then /capy/lang/Option.Some { enum_values_in_functions(name, importedModule.functions) }
        else enum_values_in_imports(name, rest, module, allModules)
    case _ -> enum_values_in_imports(name, rest, module, allModules)

private fun qualified_enum_value_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    qualified_call_name(name)
        & enum_value_exists(enum_qualified_type_name(name), enum_qualified_member_name(name), module, allModules)

private fun enum_qualified_type_name(name: String): String =
    name[0, last_dot_index(name)]

private fun enum_qualified_member_name(name: String): String =
    name[last_dot_index(name) + 1, name.size().value]

private fun enum_qualified_value_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    enum_value_reference_code(enum_qualified_type_name(name), enum_qualified_member_name(name), module, allModules)

private fun enum_value_references_code(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        enum_value_reference_code(typeName, value, module, allModules)
            + enum_value_reference_tail(typeName, values[1:], module, allModules)

private fun enum_value_reference_tail(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + enum_value_references_code(typeName, values, module, allModules)

private fun enum_value_reference_code(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if enum_type_exists_in_functions(typeName, module.functions)
    then java_identifier(valueName)
    else match enum_type_imported_class(typeName, module.imports, module, allModules) with
        case Some { className } -> className + "." + java_identifier(valueName)
        case None -> java_identifier(valueName)

private fun enum_type_imported_class(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then enum_type_imported_class_from(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else enum_type_imported_class(name, imports[1:], module, allModules)

private fun enum_type_imported_class_from(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[String] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if enum_type_exists_in_functions(name, importedModule.functions)
        then /capy/lang/Option.Some { className }
        else enum_type_imported_class(name, rest, module, allModules)
    case _ -> enum_type_imported_class(name, rest, module, allModules)

private fun schema_field_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

private fun schema_field_type_name(value: String): String =
    let separator = first_index_of(value, "|", 0)
    if separator < 0
    then "any"
    else value[separator + 1, value.size().value]

private fun schema_type_reference(value: String): CompiledTypeReference =
    let trimmed = value.trim()
    let bracket = first_index_of(trimmed, "[", 0)
    if bracket < 0
    then CompiledTypeReference { name: trimmed, arguments: [] }
    else CompiledTypeReference {
        name: trimmed[0, bracket],
        arguments: schema_type_arguments(trimmed[bracket + 1, trimmed.size().value - 1])
    }

private fun schema_type_arguments(value: String): List[CompiledTypeReference] =
    if value.trim().is_empty()
    then []
    else schema_type_arguments_from(value, 0, 0, 0)

private fun schema_type_arguments_from(value: String, idx: int, depth: int, start: int): List[CompiledTypeReference] =
    if idx >= value.size().value
    then [schema_type_reference(value[start, value.size().value])]
    else match value[idx] with
    case None -> [schema_type_reference(value[start, value.size().value])]
    case Some { char } ->
        if char == "," & depth == 0
        then [schema_type_reference(value[start, idx])] + schema_type_arguments_from(value, idx + 1, depth, idx + 1)
        else schema_type_arguments_from(value, idx + 1, schema_type_argument_depth(depth, char), start)

private fun schema_type_argument_depth(depth: int, char: String): int =
    if char == "["
    then depth + 1
    else if char == "]"
    then depth - 1
    else depth

private fun first_index_of(value: String, needle: String, idx: int): int =
    if idx >= value.size().value
    then -1
    else match value[idx] with
        case None -> -1
        case Some { char } -> if char == needle then idx else first_index_of(value, needle, idx + 1)

private fun data_type_bindings(dataType: /capy/lang/Option[String], concreteType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): List[JavaBinding] =
    match dataType with
    case Some { value } -> type_parameter_bindings(data_type_parameters(value, module, allModules), concreteType.arguments)
    case None -> []

private fun data_type_parameters(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if schema_type_exists(name, module.functions)
    then schema_values("__capy_schema_param|" + name + "|", module.functions)
    else match data_type_parameters_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_parameters_in_modules(name, allModules)

private fun data_type_parameters_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_parameters_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_parameters_in_imports(name, imports[1:], module, allModules)

private fun data_type_parameters_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { schema_values("__capy_schema_param|" + name + "|", importedModule.functions) }
        else data_type_parameters_in_imports(name, rest, module, allModules)
    case _ -> data_type_parameters_in_imports(name, rest, module, allModules)

private fun data_type_parameters_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then schema_values("__capy_schema_param|" + name + "|", module.functions)
        else data_type_parameters_in_modules(name, modules[1:])

private fun primitive_backed_backing_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    if qualified_call_name(name)
    then primitive_backed_backing_type_in_class(qualified_call_class_name(name, module), qualified_call_member(name), allModules)
    else match primitive_backed_backing_type_in_functions(name, module.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> match primitive_backed_backing_type_in_imports(name, module.imports, module, allModules) with
            case Some { backingType } -> /capy/lang/Option.Some { backingType }
            case None -> primitive_backed_backing_type_in_modules(name, allModules)

private fun primitive_backed_backing_type_in_functions(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledTypeReference] =
    match schema_value_named("__capy_schema_primitive|" + name, functions) with
    case Some { value } -> /capy/lang/Option.Some { schema_type_reference(value) }
    case None -> /capy/lang/Option.None {}

private fun primitive_backed_backing_type_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> primitive_backed_backing_type_in_functions(member, importedModule.functions)
    case None -> /capy/lang/Option.None {}

private fun primitive_backed_backing_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then primitive_backed_backing_type_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else primitive_backed_backing_type_in_imports(name, imports[1:], module, allModules)

private fun primitive_backed_backing_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[CompiledTypeReference] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> primitive_backed_backing_type_in_imported_module(name, rest, module, allModules, importedModule)
    case _ -> primitive_backed_backing_type_in_imports(name, rest, module, allModules)

private fun primitive_backed_backing_type_in_imported_module(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledTypeReference] =
    match primitive_backed_backing_type_in_functions(name, importedModule.functions) with
    case Some { backingType } -> /capy/lang/Option.Some { backingType }
    case None -> primitive_backed_backing_type_in_imports(name, rest, module, allModules)

private fun primitive_backed_backing_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledTypeReference] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match primitive_backed_backing_type_in_functions(name, module.functions) with
            case Some { backingType } -> /capy/lang/Option.Some { backingType }
            case None -> primitive_backed_backing_type_in_modules(name, modules[1:])

private fun data_type_parent_types(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if schema_type_exists(name, module.functions)
    then schema_values("__capy_schema_parent|" + name + "|", module.functions)
    else match data_type_parent_types_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_parent_types_in_modules(name, allModules)

private fun data_type_parent_types_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_parent_types_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_parent_types_in_imports(name, imports[1:], module, allModules)

private fun data_type_parent_types_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { schema_values("__capy_schema_parent|" + name + "|", importedModule.functions) }
        else data_type_parent_types_in_imports(name, rest, module, allModules)
    case _ -> data_type_parent_types_in_imports(name, rest, module, allModules)

private fun data_type_parent_types_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then schema_values("__capy_schema_parent|" + name + "|", module.functions)
        else data_type_parent_types_in_modules(name, modules[1:])

private fun data_type_distance(targetName: String, sourceName: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    if targetName == sourceName
    then 0
    else data_type_parent_distance(targetName, data_type_parent_types(sourceName, module, allModules), 1, -1, module, allModules)

private fun data_type_parent_distance(targetName: String, parents: List[String], distance: int, best: int, module: CompiledModule, allModules: List[CompiledModule]): int =
    match parents[0] with
    case None -> best
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        let direct = if parentName == targetName then distance else data_type_parent_distance(targetName, data_type_parent_types(parentName, module, allModules), distance + 1, -1, module, allModules)
        let nextBest = if direct >= 0 & (best < 0 | direct < best) then direct else best
        data_type_parent_distance(targetName, parents[1:], distance, nextBest, module, allModules)

private fun data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    merge_schema_fields(
        data_type_direct_fields(name, module, allModules),
        data_type_parent_fields(data_type_parent_types(name, module, allModules), module, allModules)
    )

private fun data_type_direct_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if schema_type_exists(name, module.functions)
    then schema_values("__capy_schema_field|" + name + "|", module.functions)
    else match data_type_fields_in_imports(name, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> data_type_fields_in_modules(name, allModules)

private fun data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = schema_type_reference(parent).name
        merge_schema_fields(
            data_type_fields(parentName, module, allModules),
            data_type_parent_fields(parents[1:], module, allModules)
        )

private fun merge_schema_fields(first: List[String], second: List[String]): List[String] =
    first + schema_fields_not_named(second, first)

private fun schema_fields_not_named(fields: List[String], existing: List[String]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        if schema_field_name_exists(schema_field_name(field), existing)
        then schema_fields_not_named(fields[1:], existing)
        else [field] + schema_fields_not_named(fields[1:], existing + [field])

private fun schema_field_name_exists(name: String, fields: List[String]): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> schema_field_name(field) == name | schema_field_name_exists(name, fields[1:])

private fun data_type_fields_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if data_import_matches(name, declaration)
        then data_type_fields_in_import(name, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else data_type_fields_in_imports(name, imports[1:], module, allModules)

private fun data_type_fields_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): /capy/lang/Option[List[String]] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } ->
        if schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { schema_values("__capy_schema_field|" + name + "|", importedModule.functions) }
        else data_type_fields_in_imports(name, rest, module, allModules)
    case _ -> data_type_fields_in_imports(name, rest, module, allModules)

private fun data_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    !stdlib_import(declaration.modulePath)
        & !declaration.qualified
        & import_includes_name(name, declaration)

private fun import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !string_list_contains(declaration.excludedNames, name)
    else string_list_contains(declaration.importedNames, name)

private fun string_list_contains(values: List[String], expected: String): bool =
    match values[0] with
    case None -> false
    case Some { value } -> value == expected | string_list_contains(values[1:], expected)

private fun data_type_fields_in_modules(name: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if schema_type_exists(name, module.functions)
        then schema_values("__capy_schema_field|" + name + "|", module.functions)
        else data_type_fields_in_modules(name, modules[1:])

private fun type_parameter_bindings(parameters: List[String], arguments: List[CompiledTypeReference]): List[JavaBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        match arguments[0] with
        case Some { argument } -> [java_binding(parameter, argument)] + type_parameter_bindings(parameters[1:], arguments[1:])
        case None -> [java_binding(parameter, object_type())] + type_parameter_bindings(parameters[1:], [])

private fun lookup_type_parameter(name: String, bindings: List[JavaBinding]): /capy/lang/Option[CompiledTypeReference] =
    match bindings[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding.typeReference }
        else lookup_type_parameter(name, bindings[1:])

private fun binary_result_type(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if boolean_binary_operator(operator)
    then bool_type()
    else if set_binary_expression(operator, leftType, rightType) & set_predicate_operator(operator)
    then bool_type()
    else if set_binary_expression(operator, leftType, rightType) & operator == "×"
    then set_type(tuple_type([first_type_argument(leftType), first_type_argument(rightType)]))
    else if set_binary_expression(operator, leftType, rightType)
    then leftType
    else if regex_binary_expression(operator, leftType)
    then regex_binary_result_type(operator)
    else if comparison_operator(operator)
    then bool_type()
    else if operator == "+" & (leftType.name == "String" | rightType.name == "String")
    then string_type()
    else if string_left_numeric_operator(operator, leftType, rightType)
    then string_type()
    else if numeric_binary_operator(operator) & numeric_type(leftType) & numeric_type(rightType)
    then promoted_numeric_type(leftType, rightType)
    else leftType

private fun numeric_binary_operator(operator: String): bool =
    operator == "+" | operator == "-" | operator == "*" | operator == "/" | operator == "%" | operator == "^"

private fun string_left_numeric_operator(operator: String, leftType: CompiledTypeReference, rightType: CompiledTypeReference): bool =
    (operator == "-" | operator == "*" | operator == "/" | operator == "^") & leftType.name == "String" & numeric_type(rightType)

private fun promoted_numeric_type(leftType: CompiledTypeReference, rightType: CompiledTypeReference): CompiledTypeReference =
    if leftType.name == "double" | rightType.name == "double"
    then double_type()
    else if leftType.name == "float" | rightType.name == "float"
    then float_type()
    else if leftType.name == "long" | rightType.name == "long"
    then long_type()
    else if leftType.name == "int" | rightType.name == "int"
    then int_type()
    else byte_type()

private fun comparison_operator(operator: String): bool =
    operator == ">" | operator == "<" | operator == ">=" | operator == "<=" | operator == "==" | operator == "!=" | operator == "?"

private fun regex_binary_expression(operator: String, leftType: CompiledTypeReference): bool =
    regex_type_name(leftType.name) & regex_binary_operator(operator)

private fun regex_binary_operator(operator: String): bool =
    operator == "?" | operator == "~" | operator == "~~" | operator == "~>" | operator == "/>"

private fun regex_binary_result_type(operator: String): CompiledTypeReference =
    if operator == "?"
    then bool_type()
    else if operator == "~"
    then option_type(regex_match_type())
    else if operator == "~~"
    then seq_type(regex_match_type())
    else if operator == "~>"
    then string_to_string_function_type()
    else list_type(string_type())

private fun expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> compiled_placeholder_source(unsupported.source)
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression variable ->
        binding_exists(variable.name, env)
            | program_member_imported(variable.name, module.imports)
            | imported_stdlib_constant_exists(variable.name, module.imports)
            | constant_exists_in_scope(variable.name, module, allModules)
            | qualified_enum_value_name(variable.name, module, allModules)
    case CompiledIfExpression e -> truthy_expression_emittable(e.condition, env, module, allModules) & expression_emittable(e.thenBranch, env, module, allModules) & expression_emittable(e.elseBranch, env, module, allModules)
    case CompiledBinaryExpression e ->
        let leftType = expression_type(e.left, env, module, allModules)
        if result_reduce_operator_expression(e, leftType)
        then result_reduce_method_emittable(result_reduce_operator_call(e), env, module, allModules)
        else if result_pipe_expression(e, leftType)
        then result_pipe_emittable(e, env, module, allModules)
        else if option_pipe_expression(e, leftType)
        then option_pipe_emittable(e, env, module, allModules)
        else if collection_pipe_chained_method_expression(e, leftType)
        then expression_emittable(collection_pipe_chained_method_call(e), env, module, allModules)
        else if collection_pipe_expression(e, leftType)
        then collection_pipe_emittable(e, env, module, allModules)
        else if binary_extension_operator_expression_with_left_type(e, leftType, module, allModules)
        then binary_extension_operator_emittable_with_left_type(e, leftType, env, module, allModules)
        else if stdlib_path_slash_expression(e, leftType, module)
        then stdlib_path_slash_emittable(e, env, module, allModules)
        else java_binary_operator_emittable(e, env, module, allModules) & expression_emittable(e.left, env, module, allModules) & expression_emittable(e.right, env, module, allModules)
    case CompiledUnaryExpression e -> java_unary_operator_emittable(e, env, module, allModules) & expression_emittable(e.expression, env, module, allModules)
    case CompiledFunctionCallExpression e -> function_call_emittable(e, env, module, allModules)
    case CompiledFunctionReferenceExpression e -> function_reference_emittable(e, module, allModules)
    case CompiledMethodCallExpression e -> java_method_emittable(e, env, module, allModules)
    case CompiledWithExpression e -> expression_emittable(e.receiver, env, module, allModules) & data_fields_emittable(e.fields, env, module, allModules)
    case CompiledLambdaExpression lambda -> lambda_parameters_supported(lambda.parameters) & expression_emittable(lambda.body, lambda_env(lambda.parameters, env), module, allModules)
    case CompiledListLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledSetLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledDictLiteral e -> dict_entries_emittable(e.entries, env, module, allModules)
    case CompiledTupleLiteral e -> expressions_emittable(e.values, env, module, allModules)
    case CompiledIndexExpression e -> index_emittable(e, env, module, allModules)
    case CompiledDataLiteral e -> data_fields_emittable(e.fields, env, module, allModules)
    case CompiledFieldAccessExpression e -> enum_static_field_access(e, env, module, allModules) | expression_emittable(e.receiver, env, module, allModules)
    case CompiledReduceExpression e -> reduce_expression_emittable(e, env, module, allModules)
    case CompiledMatchExpression e -> expression_emittable(e.value, env, module, allModules) & match_cases_emittable(e.cases, expression_type(e.value, env, module, allModules), env, module, allModules)
    case CompiledBlockExpression e -> let_bindings_emittable(e.bindings, env, module, allModules) & expression_emittable(e.result, block_env(e.bindings, env, module, allModules), module, allModules)

private fun expressions_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> expression_emittable(expression, env, module, allModules) & expressions_emittable(expressions[1:], env, module, allModules)

private fun dict_entries_emittable(entries: List[CompiledDictEntry], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } -> expression_emittable(entry.key, env, module, allModules) & expression_emittable(entry.value, env, module, allModules) & dict_entries_emittable(entries[1:], env, module, allModules)

private fun data_fields_emittable(fields: List[CompiledDataField], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } -> expression_emittable(field.value, env, module, allModules) & data_fields_emittable(fields[1:], env, module, allModules)

private fun reduce_expression_emittable(reduce: CompiledReduceExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let resultType = expression_type(reduce.initial, env, module, allModules)
    let receiverType = expression_type(reduce.receiver, env, module, allModules)
    let valueType = reduce_value_type(receiverType)
    let reduceEnv = reduce_env(reduce, resultType, valueType, java_identifier(reduce.accumulatorName), env)
    let receiverReducible = receiverType.name == "List" | receiverType.name == "Set" | receiverType.name == "Dict" | receiverType.name == "String" | seq_type_name(receiverType.name) | option_type_name(receiverType.name)
    receiverReducible
        & expression_emittable(reduce.receiver, env, module, allModules)
        & expression_emittable(reduce.initial, env, module, allModules)
        & expression_emittable(reduce.body, reduceEnv, module, allModules)

private fun match_cases_emittable(cases: List[CompiledMatchCase], valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        let caseEnv = match_env(matchCase.bindings, matchCase, valueType, 0, env, module, allModules)
        expression_emittable(matchCase.body, caseEnv, module, allModules)
            & (!matchCase.hasGuard | truthy_expression_emittable(matchCase.guard, caseEnv, module, allModules))
            & (!matchCase.hasLiteral | expression_emittable(matchCase.literal, env, module, allModules))
            & (cases[1:].is_empty() | match_cases_emittable(cases[1:], valueType, env, module, allModules))

private fun let_bindings_emittable(bindings: List[CompiledLetBinding], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        let valueType = binding_type(binding, env, module, allModules)
        let bindingValueType = binding_value_type(binding, env, module, allModules)
        let effectBindNeedsSpecialCode = binding.operator == "<-" & bindingValueType.name == "Effect"
        !effectBindNeedsSpecialCode
            & expression_emittable(binding.value, env, module, allModules)
            & let_bindings_emittable(bindings[1:], [local_java_binding(binding.name, valueType, binding.location, env)] + env, module, allModules)

private fun binding_exists(name: String, env: List[JavaBinding]): bool =
    match env[0] with
    case None -> false
    case Some { binding } -> binding.name == name | binding_exists(name, env[1:])

private fun lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some { parameter } -> parameter != "_" & lambda_parameters_supported(parameters[1:])

private fun result_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let valueType = result_pipe_value_type(binary.left, leftType, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                lambda_parameter_shape_supported(lambda.parameters, valueType)
                    & expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
            case CompiledFunctionReferenceExpression reference -> result_function_reference_emittable(reference, valueType, module, allModules)
            case _ -> false

private fun result_function_reference_emittable(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        let returnType = effective_function_return_type(function, module, allModules)
        concrete_return_type(returnType)
            & result_type_name(returnType.name)
            & single_parameter_assignable(function.parameters, valueType)
    case None -> false

private fun option_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let valueType = option_pipe_value_type(binary.left, leftType, env, module, allModules)
    expression_emittable(binary.left, env, module, allModules)
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                let lambdaEnv = lambda_value_env(lambda.parameters, valueType, env)
                if binary.operator == "|-"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules)
                    & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
                else if binary.operator == "|*"
                then collection_lambda_emittable(lambda, valueType, env, module, allModules)
                    & option_type_name(expression_type(lambda.body, lambdaEnv, module, allModules).name)
                else collection_lambda_emittable(lambda, valueType, env, module, allModules)
            case _ -> false

private fun collection_pipe_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(binary.left, env, module, allModules)
    if receiverType.name == "Dict"
    then dict_pipe_emittable(binary, receiverType, env, module, allModules)
    else
        let valueType = collection_value_type(receiverType)
        expression_emittable(binary.left, env, module, allModules)
            & match binary.right with
                case CompiledLambdaExpression lambda ->
                    if binary.operator == "|-" | binary.operator == "|!"
                    then collection_lambda_emittable(lambda, valueType, env, module, allModules) & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                    else if binary.operator == "|*"
                    then collection_lambda_emittable(lambda, valueType, env, module, allModules) & collection_receiver_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                    else collection_lambda_emittable(lambda, valueType, env, module, allModules)
                case CompiledFunctionReferenceExpression reference ->
                    collection_function_reference_emittable(reference, valueType, module, allModules)
                        & ((binary.operator != "|-" & binary.operator != "|!") | type_assignable(bool_type(), function_reference_type(reference, module, allModules)))
                case _ -> false

private fun dict_pipe_emittable(binary: CompiledBinaryExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let valueType = collection_value_type(receiverType)
    expression_emittable(binary.left, env, module, allModules)
        & (binary.operator == "|" | binary.operator == "|-" | binary.operator == "|!")
        & match binary.right with
            case CompiledLambdaExpression lambda ->
                if dict_predicate_lambda_parameters_supported(lambda.parameters)
                then
                    let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
                    expression_emittable(lambda.body, lambdaEnv, module, allModules)
                        & ((binary.operator != "|-" & binary.operator != "|!") | truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules)))
                else false
            case _ -> false

private fun collection_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if lambda_parameter_shape_supported(lambda.parameters, valueType)
    then expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    else false

private fun collection_function_reference_emittable(reference: CompiledFunctionReferenceExpression, valueType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        concrete_return_type(function.returnType)
            & single_parameter_assignable(function.parameters, valueType)
    case None -> false

private fun single_parameter_assignable(parameters: List[CompiledFunctionParameter], valueType: CompiledTypeReference): bool =
    match parameters[0] with
    case None -> false
    case Some { parameter } -> parameters[1:].is_empty() & type_assignable(parameter.typeReference, valueType)

private fun lambda_parameter_shape_supported(parameters: List[String], valueType: CompiledTypeReference): bool =
    if tuple_lambda_parameters(parameters)
    then valueType.name == "Tuple" & tuple_lambda_arity_supported(parameters, valueType.arguments)
    else single_value_lambda_parameters_supported(parameters)

private fun single_value_lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> true
    case Some _ -> parameters[1:].is_empty()

private fun tuple_lambda_arity_supported(parameters: List[String], types: List[CompiledTypeReference]): bool =
    match parameters[0] with
    case None -> types.is_empty()
    case Some _ ->
        match types[0] with
        case None -> false
        case Some _ -> tuple_lambda_arity_supported(parameters[1:], types[1:])

private fun java_binary_operator_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = expression_type(binary.left, env, module, allModules)
    let rightType = expression_type(binary.right, env, module, allModules)
    if binary.operator == "+"
    then collection_plus_expression(binary.operator, leftType, rightType) | leftType.name == "String" | rightType.name == "String" | (numeric_type(leftType) & numeric_type(rightType))
    else if boolean_binary_operator(binary.operator)
    then truthy_type(leftType) & truthy_type(rightType)
    else if binary.operator == "^"
    then (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if binary.operator == ".nand." | bitwise_binary_operator(binary.operator)
    then integer_type(leftType) & integer_type(rightType)
    else if binary.operator == "%"
    then remainder_type(leftType) & remainder_type(rightType)
    else if binary.operator == "-" | binary.operator == "*" | binary.operator == "/"
    then collection_minus_expression(binary.operator, leftType, rightType) | (numeric_type(leftType) & numeric_type(rightType)) | string_left_numeric_operator(binary.operator, leftType, rightType)
    else if set_binary_expression(binary.operator, leftType, rightType)
    then true
    else if regex_binary_expression(binary.operator, leftType)
    then regex_binary_emittable(binary, env, module, allModules)
    else if binary.operator == ">" | binary.operator == "<" | binary.operator == ">=" | binary.operator == "<="
    then numeric_type(leftType) & numeric_type(rightType)
    else if binary.operator == "?"
    then
        if leftType.name == "Dict"
        then type_assignable(string_type(), rightType)
        else (leftType.name == "List" | leftType.name == "Set" | leftType.name == "String") & !rightType.name.is_empty()
    else binary.operator == "==" | binary.operator == "!="

private fun regex_binary_emittable(binary: CompiledBinaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(binary.left, env, module, allModules)
        & expression_emittable(binary.right, env, module, allModules)
        & type_assignable(string_type(), expression_type(binary.right, env, module, allModules))

private fun java_unary_operator_emittable(unary: CompiledUnaryExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let type = expression_type(unary.expression, env, module, allModules)
    if unary.operator == "!" then truthy_type(type)
    else if unary.operator == "-" then numeric_type(type)
    else if unary.operator == ".not." then integer_type(type)
    else false

private fun truthy_expression_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    truthy_type(expression_type(expression, env, module, allModules)) & expression_emittable(expression, env, module, allModules)

private fun truthy_type(type: CompiledTypeReference): bool =
    type.name == "bool"
        | integer_type(type)
        | type.name == "float"
        | type.name == "double"
        | type.name == "String"
        | type.name == "List"
        | type.name == "Set"
        | type.name == "Dict"
        | type.name == "any"

private fun integer_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long"

private fun numeric_type(type: CompiledTypeReference): bool =
    type.name == "byte" | type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"

private fun remainder_type(type: CompiledTypeReference): bool =
    numeric_type(type)

private fun byte_literal_source(source: String): bool =
    java_generator_string_has_prefix(source, "0x") | java_generator_string_has_prefix(source, "0X")

private fun java_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    if partial_method_call(call)
    then partial_method_call_emittable(call, env, module, allModules)
    else if call.name == "size"
    then (receiverType.name == "List" | receiverType.name == "Set" | receiverType.name == "Dict" | receiverType.name == "String" | receiverType.name == "char")
        & call.arguments.is_empty()
        & expression_emittable(call.receiver, env, module, allModules)
    else if char_to_string_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if enum_name_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if assert_status_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if assert_is_empty_call(call)
    then assert_is_empty_emittable(call, env, module, allModules)
    else if result_assert_succeeds_lambda_call(call, env, module, allModules)
    then result_assert_succeeds_lambda_emittable(call, env, module, allModules)
    else if assert_method_call(call, env, module, allModules)
    then assert_method_call_emittable(call, env, module, allModules)
    else if negated_collection_is_empty_call(call, env, module, allModules)
    then negated_collection_is_empty_emittable(call, env, module, allModules)
    else if collection_is_empty_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if collection_predicate_call(call, env, module, allModules)
    then collection_predicate_call_emittable(call, receiverType, env, module, allModules)
    else if collection_reduce_method_call(call, env, module, allModules)
    then reduce_expression_emittable(collection_reduce_method_expression(call, receiverType), env, module, allModules)
    else if option_method_call(call, env, module, allModules)
    then option_pipe_emittable(option_method_binary(call), env, module, allModules)
    else if collection_method_call(call, env, module, allModules)
    then collection_pipe_emittable(collection_method_binary(call), env, module, allModules)
    else if set_method_call(call, env, module, allModules)
    then set_method_call_emittable(call, receiverType, env, module, allModules)
    else if native_stdlib_method_call(call, env, module, allModules)
    then native_stdlib_method_emittable(call, receiverType, env, module, allModules)
    else if call.name == "as_list" & seq_type_name(receiverType.name)
    then call.arguments.is_empty() & expression_emittable(call.receiver, env, module, allModules)
    else if seq_first_call(call, env, module, allModules)
    then call.arguments.is_empty() & expression_emittable(call.receiver, env, module, allModules)
    else if function_value_method_call(call, env, module, allModules)
    then function_value_method_emittable(call, env, module, allModules)
    else if result_reduce_method_call(call, env, module, allModules)
    then result_reduce_method_emittable(call, env, module, allModules)
    else if result_map_method_call(call, env, module, allModules)
    then result_map_method_emittable(call, env, module, allModules)
    else if result_or_else_method_call(call, env, module, allModules)
    then result_or_else_method_emittable(call, env, module, allModules)
    else if result_or_method_call(call, env, module, allModules)
    then result_or_method_emittable(call, env, module, allModules)
    else if call.name == "map" & receiverType.name == "Effect"
    then match argument(call.arguments, 0) with
        case CompiledLambdaExpression lambda ->
            expression_emittable(call.receiver, env, module, allModules)
                & collection_lambda_emittable(lambda, first_type_argument(receiverType), env, module, allModules)
        case _ -> false
    else if string_parse_method_call(call, env, module, allModules)
    then expression_emittable(call.receiver, env, module, allModules)
    else if regex_method_call(call, env, module, allModules)
    then regex_method_emittable(call, env, module, allModules)
    else if stdlib_date_time_method_call(call, env, module, allModules)
    then stdlib_date_time_method_emittable(call, env, module, allModules)
    else if primitive_conversion_method(call.name)
    then primitive_conversion_method_emittable(call, receiverType, env, module, allModules)
    else match find_extension_method(call, env, module, allModules) with
        case Some { function } -> extension_method_call_emittable(function, call, env, module, allModules)
        case None -> java_method_supported(call.name)
            & expression_emittable(call.receiver, env, module, allModules)
            & expressions_emittable(call.arguments, env, module, allModules)

private fun function_value_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & function_type_call_arguments_emittable(function_type_parameters(receiverType), call.arguments, env, module, allModules)

private fun result_map_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    result_pipe_emittable(result_map_method_binary(call), env, module, allModules)

private fun result_reduce_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    expression_emittable(call.receiver, env, module, allModules)
        & result_reduce_argument_emittable(argument(call.arguments, 0), valueType, env, module, allModules)
        & result_reduce_argument_emittable(argument(call.arguments, 1), string_type(), env, module, allModules)

private fun result_or_else_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & (result_value_type_needs_context(valueType) | type_assignable(valueType, argumentType))

private fun result_or_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    let valueType = first_type_argument(receiverType)
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & result_type_name(argumentType.name)
        & (result_value_type_needs_context(valueType) | type_assignable(receiverType, argumentType))

private fun result_reduce_argument_emittable(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> result_reduce_lambda_emittable(lambda, valueType, env, module, allModules)
    case _ -> false

private fun result_reduce_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if lambda_parameter_shape_supported(lambda.parameters, valueType)
    then expression_emittable(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules)
    else false

private fun regex_method_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentExpression = argument(call.arguments, 0)
    expression_emittable(call.receiver, env, module, allModules)
        & expression_emittable(argumentExpression, env, module, allModules)
        & type_assignable(string_type(), expression_type(argumentExpression, env, module, allModules))

private fun extension_method_call_emittable(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(call.receiver, env, module, allModules)
    extension_method_call_emittable_with_receiver_type(function, call, receiverType, env, module, allModules)

private fun extension_method_call_emittable_with_receiver_type(function: CompiledFunction, call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let parameters = bound_extension_method_parameters(function, receiverType)
    concrete_return_type(bound_extension_method_return_type(function, receiverType))
        & expression_emittable(call.receiver, env, module, allModules)
        & parameters_assignable(parameters, call.arguments, env, module, allModules)
        & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

private fun native_stdlib_method_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & if receiverType.name == "String" | receiverType.name == "List"
            then index_method_arguments_emittable(call.arguments, env, module, allModules)
            else if receiverType.name == "Dict"
            then dict_method_arguments_emittable(call, env, module, allModules)
            else if receiverType.name == "Tuple"
            then tuple_get_method_arguments_emittable(call, env, module, allModules)
            else expressions_emittable(call.arguments, env, module, allModules)

private fun set_method_call_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & if set_no_argument_method(call.name)
            then call.arguments.is_empty()
            else if call.name == "contains"
            then set_contains_argument_emittable(call, env, module, allModules)
            else set_set_argument_emittable(call, env, module, allModules)

private fun set_contains_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    one_method_argument(call.arguments) & expression_emittable(argument(call.arguments, 0), env, module, allModules)

private fun set_set_argument_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    one_method_argument(call.arguments)
        & expression_type(argument(call.arguments, 0), env, module, allModules).name == "Set"
        & expression_emittable(argument(call.arguments, 0), env, module, allModules)

private fun dict_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let key = argument(call.arguments, 0)
    expression_emittable(key, env, module, allModules)
        & type_assignable(string_type(), expression_type(key, env, module, allModules))

private fun tuple_get_method_arguments_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let index = argument(call.arguments, 0)
    index_literal_emittable(index)
        & index_argument_emittable(index, env, module, allModules)

private fun index_method_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { first } ->
        index_argument_emittable(first, env, module, allModules)
            & match arguments[1] with
                case None -> true
                case Some { second } -> arguments[2:].is_empty() & index_argument_emittable(second, env, module, allModules)

private fun primitive_conversion_method_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.arguments.is_empty()
        & primitive_conversion_receiver(call.name, receiverType)
        & expression_emittable(call.receiver, env, module, allModules)

private fun result_assert_succeeds_lambda_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledFunctionCallExpression receiver ->
        let actual = argument(receiver.arguments, 0)
        let valueType = first_type_argument(expression_type(actual, env, module, allModules))
        expression_emittable(actual, env, module, allModules)
            & result_assert_succeeds_lambda_argument_emittable(argument(call.arguments, 0), valueType, env, module, allModules)
    case _ -> false

private fun result_assert_succeeds_lambda_argument_emittable(expression: CompiledExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> collection_lambda_emittable(lambda, valueType, env, module, allModules)
    case _ -> false

private fun assert_method_call_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    expression_emittable(call.receiver, env, module, allModules)
        & ordinary_call_arguments_emittable(call.arguments, env, module, allModules)

private fun negated_collection_is_empty_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledUnaryExpression unary -> expression_emittable(unary.expression, env, module, allModules)
    case _ -> false

private fun collection_predicate_call_emittable(call: CompiledMethodCallExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { predicate } ->
        match call.arguments[1] with
        case Some _ -> false
        case None ->
            expression_emittable(call.receiver, env, module, allModules)
            & match predicate with
                case CompiledLambdaExpression lambda ->
                    let valueType = collection_value_type(receiverType)
                    if receiverType.name == "Dict"
                    then dict_predicate_lambda_emittable(lambda, valueType, env, module, allModules)
                    else if receiverType.name == "String" & string_indexed_lambda(lambda.parameters)
                    then
                        let lambdaEnv = string_indexed_lambda_env(lambda.parameters, expression_code(call.receiver, env, receiverType, module, allModules), env)
                        expression_emittable(lambda.body, lambdaEnv, module, allModules)
                            & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
                    else collection_lambda_emittable(lambda, valueType, env, module, allModules)
                            & truthy_type(expression_type(lambda.body, lambda_value_env(lambda.parameters, valueType, env), module, allModules))
                case CompiledFunctionReferenceExpression reference ->
                    let valueType = collection_value_type(receiverType)
                    receiverType.name != "Dict"
                        & collection_function_reference_emittable(reference, valueType, module, allModules)
                        & type_assignable(bool_type(), function_reference_type(reference, module, allModules))
                case _ -> false

private fun dict_predicate_lambda_emittable(lambda: CompiledLambdaExpression, valueType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if dict_predicate_lambda_parameters_supported(lambda.parameters)
    then
        let lambdaEnv = dict_predicate_lambda_env(lambda.parameters, valueType, env)
        expression_emittable(lambda.body, lambdaEnv, module, allModules)
            & truthy_type(expression_type(lambda.body, lambdaEnv, module, allModules))
    else false

private fun dict_predicate_lambda_parameters_supported(parameters: List[String]): bool =
    match parameters[0] with
    case None -> false
    case Some _ ->
        match parameters[1] with
        case None -> false
        case Some _ -> parameters[2:].is_empty()

private fun assert_is_empty_emittable(call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.receiver with
    case CompiledFunctionCallExpression receiver -> assert_is_empty_arguments_emittable(receiver.arguments, env, module, allModules)
    case _ -> false

private fun assert_is_empty_arguments_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { actual } ->
        let actualType = expression_type(actual, env, module, allModules)
        if collection_empty_receiver_type(actualType) | option_type_name(actualType.name)
        then expression_emittable(actual, env, module, allModules)
        else false

private fun primitive_conversion_method(name: String): bool =
    name == "to_int" | name == "to_long"

private fun primitive_conversion_receiver(name: String, receiverType: CompiledTypeReference): bool =
    if name == "to_int"
    then receiverType.name == "long" | receiverType.name == "float" | receiverType.name == "double"
    else if name == "to_long"
    then receiverType.name == "float" | receiverType.name == "double"
    else false

private fun function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if partial_function_call(call)
    then partial_function_call_emittable(call, env, module, allModules)
    else if call.name == "delay"
    then delay_call_emittable(call.arguments, env, module, allModules)
    else if binding_exists(call.name, env) & function_type(lookup_binding(call.name, env))
    then function_value_call_emittable(call, env, module, allModules)
    else if call.name == "pure" & effect_member_imported("pure", module.imports)
    then match call.arguments[0] with
        case None -> false
        case Some { argument } -> call.arguments[1:].is_empty() & expression_emittable(argument, env, module, allModules)
    else if stdlib_effect_function_call(call, module)
    then true
    else if stdlib_path_function_call(call, module)
    then stdlib_path_function_call_emittable(call, env, module, allModules)
    else if stdlib_io_function_call(call, module)
    then stdlib_io_function_call_emittable(call, env, module, allModules)
    else if console_print_name(call.name) & console_member_imported(call.name, module.imports)
    then match call.arguments[0] with
        case None -> false
        case Some { argument } -> call.arguments[1:].is_empty() & expression_emittable(argument, env, module, allModules)
    else if console_read_line_call(call, module)
    then true
    else if stdlib_to_seq_call(call, module)
    then stdlib_to_seq_call_emittable(call, env, module, allModules)
    else if call.name == "assert_all"
    then expressions_emittable(call.arguments, env, module, allModules)
    else if call.name == "assert_that"
    then assert_that_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test"
    then test_call_emittable(call.arguments, env, module, allModules)
    else if call.name == "test_file"
    then test_file_call_emittable(call.arguments, env, module, allModules)
    else if stdlib_math_sqrt_call(call, module)
    then stdlib_math_sqrt_call_emittable(call.arguments, env, module, allModules)
    else if stdlib_math_digits_call(call, module)
    then stdlib_math_digits_call_emittable(call.arguments, env, module, allModules)
    else if enum_parse_call(call, module, allModules)
    then enum_parse_call_emittable(call, env, module, allModules)
    else if qualified_call_name(call.name)
    then qualified_function_call_emittable(call, env, module, allModules)
    else java_callable_name(call.name) & !binding_exists(call.name, env) & function_call_target_emittable(call.name, call.arguments, env, module, allModules)

private fun stdlib_to_seq_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let argumentExpression = argument(call.arguments, 0)
    let argumentType = expression_type(argumentExpression, env, module, allModules)
    if argumentType.name == "List" | argumentType.name == "Set" | argumentType.name == "Dict"
    then expression_emittable(argumentExpression, env, module, allModules)
    else false

private fun qualified_function_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    !binding_exists(call.name, env)
        & match find_qualified_function(call.name, module, allModules) with
            case Some { function } ->
                callable_return_type(effective_function_return_type(function, module, allModules))
                    & parameters_emittable_and_assignable(function.parameters, call.arguments, env, module, allModules)
            case None -> qualified_call_member(call.name) == "main"

private fun function_value_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let type = lookup_binding(call.name, env)
    function_type_call_arguments_emittable(function_type_parameters(type), call.arguments, env, module, allModules)

private fun function_type_call_arguments_emittable(parameters: List[CompiledTypeReference], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            expression_emittable(argument, env, module, allModules)
                & value_assignable(parameter, expression_type(argument, env, module, allModules), module, allModules)
                & function_type_call_arguments_emittable(parameters[1:], arguments[1:], env, module, allModules)

private fun function_reference_emittable(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } -> concrete_return_type(function.returnType)
    case None -> false

private fun stdlib_math_sqrt_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "sqrt" & !function_defined(call.name, module.functions)

private fun sqrt_call_type(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): CompiledTypeReference =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    if argumentType.name == "double" then double_type() else float_type()

private fun sqrt_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], expectedType: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = if expectedType.name == "double" then double_type() else sqrt_call_type(call, env, module, allModules)
    let code = "java.lang.Math.sqrt(" + expression_code(argument(call.arguments, 0), env, double_type(), module, allModules) + ")"
    if resultType.name == "double" then code else "((float) " + code + ")"

private fun stdlib_math_sqrt_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & numeric_type(expression_type(argument, env, module, allModules))
            & expression_emittable(argument, env, module, allModules)

private fun stdlib_math_digits_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "digits" & !function_defined(call.name, module.functions) & stdlib_math_wildcard_import(module.imports)

private fun function_defined(name: String, functions: List[CompiledFunction]): bool =
    match find_function(name, functions) with
    case Some _ -> true
    case None -> false

private fun stdlib_math_wildcard_import(imports: List[CompiledImportDeclaration]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.wildcard
            & (declaration.modulePath == "/capy/lang/Math" | declaration.modulePath == "capy/lang/Math")
            & !string_list_contains(declaration.excludedNames, "digits")
        then true
        else stdlib_math_wildcard_import(imports[1:])

private fun stdlib_math_digits_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
        & type_assignable(int_type(), expression_type(argument, env, module, allModules))
        & expression_emittable(argument, env, module, allModules)

private fun enum_parse_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    qualified_call_name(call.name)
        & enum_qualified_member_name(call.name) == "parse"
        & enum_type_exists(enum_qualified_type_name(call.name), module, allModules)

private fun enum_parse_call_emittable(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { argument } ->
        call.arguments[1:].is_empty()
            & expression_emittable(argument, env, module, allModules)
            & enum_parse_argument_supported(expression_type(argument, env, module, allModules))

private fun enum_parse_argument_supported(argumentType: CompiledTypeReference): bool =
    type_assignable(string_type(), argumentType) | type_assignable(int_type(), argumentType)

private fun assert_that_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        assert_type_supported(expression_type(expression, env, module, allModules))
        & expression_emittable(expression, env, module, allModules)

private fun assert_type_supported(type: CompiledTypeReference): bool =
    type.name == "int" | type.name == "long" | type.name == "float" | type.name == "double"
        | type.name == "bool" | type.name == "String" | type.name == "List" | type.name == "Set" | type.name == "Dict"
        | data_assert_type_supported(type)

private fun data_assert_type_supported(type: CompiledTypeReference): bool =
    concrete_return_type(type)
        & !collection_assert_type(type.name)
        & type.name != "Assert"
        & type.name != "Effect"
        & type.name != "Supplier"
        & (type.name == "data" | type.name == "enum" | java_generator_string_has_prefix(type.name, "/") | uppercase_data_type_name(type.name))

private fun collection_assert_type(name: String): bool =
    name == "List" | name == "Set" | name == "Dict" | seq_type_name(name)

private fun uppercase_data_type_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

private fun delay_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } ->
        arguments[1:].is_empty() & lambda_argument_emittable(expression, env, module, allModules)

private fun test_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { assertionExpression } ->
            expression_emittable(nameExpression, env, module, allModules) & test_supplier_emittable(assertionExpression)

private fun test_supplier_emittable(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

private fun lambda_argument_emittable(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda_parameters_supported(lambda.parameters) & expression_emittable(lambda.body, lambda_env(lambda.parameters, env), module, allModules)
    case _ -> false

private fun test_file_call_emittable(arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { nameExpression } ->
        match arguments[1] with
        case None -> false
        case Some { testsExpression } ->
            let testsType = expression_type(testsExpression, env, module, allModules)
            expression_emittable(nameExpression, env, module, allModules)
                & expression_emittable(testsExpression, env, module, allModules)
                & testsType.name == "List"
                & test_file_test_case_list_type(first_type_argument(testsType))

private fun index_emittable(index: CompiledIndexExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = expression_type(index.receiver, env, module, allModules)
    if !built_in_index_expression(index, receiverType)
    then user_defined_index_emittable(index, receiverType, env, module, allModules)
    else if receiverType.name == "List"
    then expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "Tuple"
    then index_literal_emittable(index.index)
        & (!index.hasEndIndex | index_literal_emittable(index.endIndex))
        & expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "String"
    then expression_emittable(index.receiver, env, module, allModules)
        & index_argument_emittable(index.index, env, module, allModules)
        & (!index.hasEndIndex | index_argument_emittable(index.endIndex, env, module, allModules))
    else if receiverType.name == "Dict"
    then !index.hasEndIndex
        & expression_emittable(index.receiver, env, module, allModules)
        & expression_emittable(index.index, env, module, allModules)
        & type_assignable(string_type(), expression_type(index.index, env, module, allModules))
    else false

private fun user_defined_index_emittable(index: CompiledIndexExpression, receiverType: CompiledTypeReference, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_extension_method_in_scope(receiverType.name, "get", module, allModules) with
    case Some { function } -> extension_method_call_emittable_with_receiver_type(function, index_get_call(index), receiverType, env, module, allModules)
    case None -> false

private fun index_literal_emittable(index: CompiledExpression): bool =
    match index with
    case CompiledIntLiteral _ -> true
    case CompiledUnaryExpression unary -> unary.operator == "-" & index_literal_emittable(unary.expression)
    case _ -> false

private fun function_call_target_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_for_arguments_in_functions(name, arguments, env, module.functions, module, allModules) with
    case Some { function } ->
        callable_return_type(effective_function_return_type(function, module, allModules))
            & parameters_emittable_and_assignable(function.parameters, arguments, env, module, allModules)
    case None -> imported_function_target_emittable(name, arguments, env, module.imports, module, allModules)

private fun imported_function_target_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if function_import_matches(name, declaration)
        then imported_module_function_emittable(name, arguments, env, imports[1:], module, allModules, imported_module_class(module, declaration.modulePath))
        else imported_function_target_emittable(name, arguments, env, imports[1:], module, allModules)

private fun imported_module_function_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], className: String): bool =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> imported_module_function_body_emittable(name, arguments, env, rest, module, allModules, importedModule)
    case _ -> imported_function_target_emittable(name, arguments, env, rest, module, allModules)

private fun imported_module_function_body_emittable(name: String, arguments: List[CompiledExpression], env: List[JavaBinding], rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): bool =
    match find_function_for_arguments_in_functions(name, arguments, env, importedModule.functions, module, allModules) with
    case Some { function } ->
        callable_return_type(effective_function_return_type(function, importedModule, allModules))
            & parameters_emittable_and_assignable(function.parameters, arguments, env, module, allModules)
    case _ -> imported_function_target_emittable(name, arguments, env, rest, module, allModules)

private fun concrete_return_type(type: CompiledTypeReference): bool =
    !type.name.is_empty() & type.name != "any"

private fun callable_return_type(type: CompiledTypeReference): bool =
    concrete_return_type(type) | type.name.is_empty() | type.name == "any"

private fun parameters_assignable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            parameter_argument_assignable(parameter.typeReference, argument, env, module, allModules)
            & parameters_assignable(parameters[1:], arguments[1:], env, module, allModules)

private fun parameters_emittable_and_assignable(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match parameters[0] with
    case None -> arguments.is_empty()
    case Some { parameter } ->
        match arguments[0] with
        case None -> false
        case Some { argument } ->
            parameter_argument_assignable(parameter.typeReference, argument, env, module, allModules)
                & parameter_argument_emittable(parameter.typeReference, argument, env, module, allModules)
                & parameters_emittable_and_assignable(parameters[1:], arguments[1:], env, module, allModules)

private fun parameter_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if function_type(target)
    then function_argument_emittable(target, argument, env, module, allModules)
    else expression_emittable(argument, env, module, allModules)

private fun function_argument_emittable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match argument with
    case CompiledLambdaExpression _ -> function_lambda_assignable(target, argument, env, module, allModules)
    case CompiledFunctionReferenceExpression _ -> function_reference_assignable(target, argument, module, allModules)
    case _ -> expression_emittable(argument, env, module, allModules)

private fun parameter_argument_assignable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if empty_collection_literal_assignable(target, argument)
    then true
    else if function_reference_assignable(target, argument, module, allModules)
    then true
    else if function_lambda_assignable(target, argument, env, module, allModules)
    then true
    else value_assignable(target, expression_type(argument, env, module, allModules), module, allModules)

private fun function_lambda_assignable(target: CompiledTypeReference, argument: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !function_type(target)
    then false
    else match argument with
        case CompiledLambdaExpression lambda ->
            let parameters = function_type_parameters(target)
            let lambdaEnv = typed_lambda_env(lambda.parameters, parameters, env)
            lambda_function_parameters_assignable(parameters, lambda.parameters)
                & expression_emittable(lambda.body, lambdaEnv, module, allModules)
                & type_assignable(function_type_return_type(target), expression_type(lambda.body, lambdaEnv, module, allModules))
        case _ -> false

private fun lambda_function_parameters_assignable(parameters: List[CompiledTypeReference], names: List[String]): bool =
    match parameters[0] with
    case None -> names.is_empty()
    case Some _ ->
        match names[0] with
        case None -> false
        case Some _ -> lambda_function_parameters_assignable(parameters[1:], names[1:])

private fun function_reference_assignable(target: CompiledTypeReference, argument: CompiledExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !function_type(target)
    then false
    else match argument with
        case CompiledFunctionReferenceExpression reference -> function_reference_type_assignable(target, reference, module, allModules)
        case _ -> false

private fun function_reference_type_assignable(target: CompiledTypeReference, reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match find_function_in_scope(reference.name, module, allModules) with
    case Some { function } ->
        type_assignable(function_type_return_type(target), effective_function_return_type(function, module, allModules))
            & function_parameters_assignable(function_type_parameters(target), function.parameters)
    case None -> false

private fun function_parameters_assignable(targetParameters: List[CompiledTypeReference], sourceParameters: List[CompiledFunctionParameter]): bool =
    match targetParameters[0] with
    case None -> sourceParameters.is_empty()
    case Some { targetParameter } ->
        match sourceParameters[0] with
        case None -> false
        case Some { sourceParameter } ->
            type_assignable(targetParameter, sourceParameter.typeReference)
                & function_parameters_assignable(targetParameters[1:], sourceParameters[1:])

private fun empty_collection_literal_assignable(target: CompiledTypeReference, argument: CompiledExpression): bool =
    match argument with
    case CompiledListLiteral literal -> literal.values.is_empty() & target.name == "List"
    case CompiledSetLiteral literal -> literal.values.is_empty() & target.name == "Set"
    case CompiledDictLiteral literal -> literal.entries.is_empty() & target.name == "Dict"
    case _ -> false

private fun type_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    if type_parameter(target) | type_parameter(source) | source.name == "nothing"
    then true
    else if target.name == "any"
    then true
    else if target.name.is_empty() | source.name.is_empty() | source.name == "any"
    then false
    else if function_type(target) & function_type(source)
    then function_type_assignable(target, source)
    else if primitive_numeric_widening_assignable(target, source)
    then true
    else if stdlib_type_reference_assignable(target, source)
    then true
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then true
    else if target.name == "data" & generated_data_object_type(source)
    then true
    else target.name == source.name & type_arguments_assignable(target.arguments, source.arguments)

private fun function_type_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    type_arguments_assignable(function_type_parameters(target), function_type_parameters(source))
        & type_assignable(function_type_return_type_with_arguments(target), function_type_return_type_with_arguments(source))

private fun value_assignable(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if stdlib_type_reference_assignable(target, source)
    then true
    else if runtime_supertype_assignable(target, source, module, allModules)
    then true
    else if generated_data_object_type(target) & generated_data_object_type(source)
    then data_type_distance(target.name, source.name, module, allModules) >= 0
    else if type_assignable(target, source)
    then true
    else match primitive_backed_backing_type(source.name, module, allModules) with
        case Some { backingType } -> type_assignable(target, backingType)
        case None -> false

private fun runtime_supertype_assignable(target: CompiledTypeReference, source: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if target.name == "enum"
    then source.name == "any" | enum_type_exists(source.name, module, allModules)
    else if target.name == "data"
    then source.name == "any" | generated_data_object_type(source)
    else false

private fun generated_data_object_type(type: CompiledTypeReference): bool =
    !type.name.is_empty()
        & !numeric_type(type)
        & type.name != "bool"
        & type.name != "String"
        & type.name != "List"
        & type.name != "Set"
        & type.name != "Dict"
        & type.name != "Tuple"
        & type.name != "Effect"
        & type.name != "Assert"
        & type.name != "TestFile"
        & type.name != "TestCase"
        & type.name != "Supplier"
        & uppercase_data_type_name(type_unqualified_name(type.name))

private fun type_unqualified_name(name: String): String =
    let dot = last_index_of(name, ".", 0, -1)
    let slash = last_index_of(name, "/", 0, -1)
    let idx = if dot > slash then dot else slash
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun last_index_of(value: String, needle: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { char } -> last_index_of(value, needle, idx + 1, if char == needle then idx else found)

private fun primitive_numeric_widening_assignable(target: CompiledTypeReference, source: CompiledTypeReference): bool =
    source.arguments.is_empty() & target.arguments.is_empty() & (
        (source.name == "byte" & (target.name == "int" | target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "int" & (target.name == "long" | target.name == "float" | target.name == "double"))
        | (source.name == "long" & (target.name == "float" | target.name == "double"))
        | (source.name == "float" & target.name == "double")
    )

private fun type_arguments_assignable(target: List[CompiledTypeReference], source: List[CompiledTypeReference]): bool =
    match target[0] with
    case None -> source.is_empty()
    case Some { targetArgument } ->
        match source[0] with
        case None -> false
        case Some { sourceArgument } -> type_assignable(targetArgument, sourceArgument) & type_arguments_assignable(target[1:], source[1:])

private fun ordinary_call_arguments_emittable(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression _ -> false
        case _ -> expression_emittable(expression, env, module, allModules) & ordinary_call_arguments_emittable(expressions[1:], env, module, allModules)

private fun java_callable_name(name: String): bool =
    !(name ? "/") & !(name ? ".") & !(name ? "`")

private fun java_method_supported(name: String): bool =
    name == "is_equal_to" | name == "is_true" | name == "is_false"
        | name == "is_greater_than" | name == "is_less_than"
        | name == "is_greater_or_equals_than" | name == "is_less_or_equals_than"
        | name == "is_zero" | name == "is_one"
        | name == "starts_with" | name == "does_not_start_with" | name == "end_with" | name == "contains"
        | name == "has_size" | name == "succeeds" | name == "fails"
        | name == "succeeded" | name == "failed"
        | name == "replace" | name == "trim" | name == "size"

private fun java_type(type: CompiledTypeReference): String =
    if type.name == "byte" then "byte"
    else if type.name == "int" then "int"
    else if type.name == "long" then "long"
    else if type.name == "float" then "float"
    else if type.name == "double" then "double"
    else if type.name == "bool" then "boolean"
    else boxed_java_type(type)

private fun boxed_java_type(type: CompiledTypeReference): String =
    if function_type(type) then java_functional_type(type)
    else if type.name == "byte" then "java.lang.Byte"
    else if type.name == "int" then "java.lang.Integer"
    else if type.name == "long" then "java.lang.Long"
    else if type.name == "float" then "java.lang.Float"
    else if type.name == "double" then "java.lang.Double"
    else if type.name == "bool" then "java.lang.Boolean"
    else if type.name == "String" then "java.lang.String"
    else if type.name == "List" then "java.util.List<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Set" then "java.util.Set<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Dict" then "java.util.Map<java.lang.String, " + boxed_java_type(first_type_argument(type)) + ">"
    else if option_type_name(type.name) then "java.util.Optional<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "Tuple" then "java.util.List<?>"
    else if type.name == "Effect" then "capy.lang.Effect<" + generic_argument_java_type(first_type_argument(type)) + ">"
    else if type.name == "Assert" then "capy.test.Assert"
    else if type.name == "TestFile" then "capy.test.CapyTest.TestFile"
    else if type.name == "TestCase" then "capy.test.CapyTest.TestCase"
    else if type.name == "Supplier" then "java.util.function.Supplier<" + boxed_java_type(first_type_argument(type)) + ">"
    else if type.name == "/capy/lang/Program" then "capy.lang.Program"
    else if stdlib_date_time_type_name(type.name) then stdlib_date_time_java_type(type.name)
    else "java.lang.Object"

private fun function_type(type: CompiledTypeReference): bool =
    type.name ? "=>"

private fun java_functional_type(type: CompiledTypeReference): String =
    let parameters = function_type_parameters(type)
    let returnType = function_type_return_type(type)
    if parameters.is_empty()
    then "java.util.function.Supplier<" + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 1
    then "java.util.function.Function<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 2
    then "java.util.function.BiFunction<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 3
    then "__CapyFunction3<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 2)) + ", " + boxed_java_type(returnType) + ">"
    else if parameters.size().value == 4
    then "__CapyFunction4<" + boxed_java_type(function_type_parameter_at(parameters, 0)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 1)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 2)) + ", " + boxed_java_type(function_type_parameter_at(parameters, 3)) + ", " + boxed_java_type(returnType) + ">"
    else "java.lang.Object"

private fun function_type_parameters(type: CompiledTypeReference): List[CompiledTypeReference] =
    let text = function_type_parameter_text(type)
    if text == "()"
    then []
    else function_type_parameter_list(function_type_parameter_inner_text(text))

private fun function_type_parameter_text(type: CompiledTypeReference): String =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0 then "" else type.name[0, arrow]

private fun function_type_parameter_inner_text(text: String): String =
    if java_generator_string_has_prefix(text, "(")
    then text[1, text.size().value - 1]
    else text

private fun function_type_parameter_list(text: String): List[CompiledTypeReference] =
    if text.trim().is_empty()
    then []
    else schema_type_arguments(text)

private fun function_type_return_type(type: CompiledTypeReference): CompiledTypeReference =
    let arrow = first_index_of(type.name, "=", 0)
    if arrow < 0
    then object_type()
    else schema_type_reference(type.name[arrow + 2, type.name.size().value])

private fun function_type_parameter_at(parameters: List[CompiledTypeReference], idx: int): CompiledTypeReference =
    match parameters[idx] with
    case Some { parameter } -> parameter
    case None -> object_type()

private fun java_seq_type(type: CompiledTypeReference): String =
    "capy.lang.Seq<" + boxed_java_type(first_type_argument(type)) + ">"

private fun first_type_argument(type: CompiledTypeReference): CompiledTypeReference =
    match type.arguments[0] with
    case None -> object_type()
    case Some { argument } -> argument

private fun generic_argument_java_type(type: CompiledTypeReference): String =
    if type_parameter(type) then "?" else boxed_java_type(type)

private fun type_parameter(type: CompiledTypeReference): bool =
    type.arguments.is_empty() & type.name.size().value == 1 & single_uppercase_name(type.name)

private fun single_uppercase_name(name: String): bool =
    match name[0] with
    case None -> false
    case Some { char } -> "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char

private fun result_success_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Result.Success"
        | typeName == "Result.Success"
        | (typeName == "Success" & result_member_imported("Success", imports))

private fun result_error_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Result.Error"
        | typeName == "Result.Error"
        | (typeName == "Error" & result_member_imported("Error", imports))

private fun program_success_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Success"
        | typeName == "Program.Success"
        | (typeName == "Success" & program_member_imported("Success", imports))

private fun program_failed_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Failed"
        | typeName == "Program.Failed"
        | (typeName == "Failed" & program_member_imported("Failed", imports))

private fun program_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Program", "capy/lang/Program")

private fun effect_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Effect", "capy/lang/Effect")

private fun system_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/System", "capy/lang/System")

private fun clock_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/date_time/Clock", "capy/date_time/Clock")

private fun result_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Result", "capy/lang/Result")

private fun seq_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/lang/Seq", "capy/lang/Seq")

private fun console_print_name(name: String): bool =
    name == "print" | name == "println" | name == "print_error" | name == "println_error"

private fun console_print_call_code(call: CompiledFunctionCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let argumentType = expression_type(argument(call.arguments, 0), env, module, allModules)
    let valueCode = expression_code(argument(call.arguments, 0), env, argumentType, module, allModules)
    "capy.lang.Effect.delay(() -> { var __capy_console_value = " + valueCode + "; "
        + "return dev.capylang.ConsoleUtil." + console_util_method(call.name) + "(__capy_console_value); })"

private fun console_read_line_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.name == "read_line" & call.arguments.is_empty() & console_member_imported("read_line", module.imports)

private fun console_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/Console", "capy/io/Console")

private fun stdlib_io_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/IO", "capy/io/IO")

private fun stdlib_path_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    module_member_imported(member, imports, "/capy/io/Path", "capy/io/Path")

private fun module_member_imported(member: String, imports: List[CompiledImportDeclaration], absoluteModulePath: String, relativeModulePath: String): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if (declaration.modulePath == absoluteModulePath | declaration.modulePath == relativeModulePath)
            & import_includes_name(member, declaration)
        then true
        else module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)

private fun console_util_method(name: String): String =
    if name == "print_error"
    then "printError"
    else if name == "println_error"
    then "printlnError"
    else name

private fun test_file_test_case_list_type(type: CompiledTypeReference): bool =
    type.name == "TestCase" | (type.name == "Effect" & first_type_argument(type).name == "TestCase")

private fun test_file_tests_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledListLiteral literal -> "java.util.List.of(" + test_file_test_elements_code(literal.values, env, module, allModules) + ")"
    case _ ->
        let testsType = expression_type(expression, env, module, allModules)
        if testsType.name == "List" & first_type_argument(testsType).name == "Effect" & first_type_argument(first_type_argument(testsType)).name == "TestCase"
        then expression_code(expression, env, list_type(effect_type(test_case_type())), module, allModules)
            + ".stream().map((capy.lang.Effect<capy.test.CapyTest.TestCase> __capy_effect_test_case) -> __capy_effect_test_case.unsafeRun()).toList()"
        else expression_code(expression, env, list_type(test_case_type()), module, allModules)

private fun test_file_test_elements_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        test_file_test_element_code(expression, env, module, allModules)
        + test_file_test_elements_tail_code(expressions[1:], env, module, allModules)

private fun test_file_test_elements_tail_code(expressions: List[CompiledExpression], env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + test_file_test_element_code(expression, env, module, allModules)
        + test_file_test_elements_tail_code(expressions[1:], env, module, allModules)

private fun test_file_test_element_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let type = expression_type(expression, env, module, allModules)
    if type.name == "Effect" & first_type_argument(type).name == "TestCase"
    then lazy_effect_test_case_code(expression, env, module, allModules)
    else expression_code(expression, env, test_case_type(), module, allModules)

private fun lazy_effect_test_case_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledMethodCallExpression call ->
        if call.name == "map"
        then lazy_effect_map_test_case_code(expression, call, env, module, allModules)
        else eager_effect_test_case_code(expression, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

private fun lazy_effect_map_test_case_code(expression: CompiledExpression, call: CompiledMethodCallExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match argument(call.arguments, 0) with
    case CompiledLambdaExpression lambda -> lazy_effect_test_case_lambda_code(expression, lambda, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

private fun lazy_effect_test_case_lambda_code(expression: CompiledExpression, lambda: CompiledLambdaExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match lambda.body with
    case CompiledFunctionCallExpression testCall ->
        if testCall.name == "test"
        then "new capy.test.CapyTest.TestCase("
            + expression_code(argument(testCall.arguments, 0), env, string_type(), module, allModules)
            + ", capy.test.CapyTest.Passed.INSTANCE, 0, 0.0, () -> "
            + expression_code(expression, env, effect_type(test_case_type()), module, allModules)
            + ".unsafeRun().assert_supplier().get())"
        else eager_effect_test_case_code(expression, env, module, allModules)
    case _ -> eager_effect_test_case_code(expression, env, module, allModules)

private fun eager_effect_test_case_code(expression: CompiledExpression, env: List[JavaBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    expression_code(expression, env, effect_type(test_case_type()), module, allModules) + ".unsafeRun()"

private fun qualified_call_name(name: String): bool =
    let idx = last_dot_index(name)
    idx > 0 & idx < name.size().value - 1

private fun qualified_call_member(name: String): String =
    name[last_dot_index(name) + 1, name.size().value]

private fun qualified_call_class_name(name: String, module: CompiledModule): String =
    let qualifier = name[0, last_dot_index(name)]
    if java_generator_string_has_prefix(qualifier, "/")
    then path_to_class(qualifier[1, qualifier.size()])
    else if qualifier ? "/"
    then path_to_class(qualifier)
    else imported_module_class(module, qualifier)

private fun find_qualified_function(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let className = qualified_call_class_name(name, module)
    let member = qualified_call_member(name)
    if absolute_qualified_call_name(name)
    then find_qualified_function_in_class(className, member, allModules)
    else match find_qualified_function_in_imports(
            className,
            member,
            module.imports,
            module,
            allModules
        ) with
        case Some { function } -> /capy/lang/Option.Some { function }
        case None -> find_qualified_function_in_class(className, member, allModules)

private fun absolute_qualified_call_name(name: String): bool =
    java_generator_string_has_prefix(name, "/")

private fun find_qualified_function_in_class(className: String, member: String, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_function(member, importedModule.functions)
    case None -> /capy/lang/Option.None {}

private fun find_qualified_function_in_imports(className: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !stdlib_import(declaration.modulePath) & imported_module_class(module, declaration.modulePath) == className
        then find_qualified_function_in_import(className, member, imports[1:], module, allModules)
        else find_qualified_function_in_imports(className, member, imports[1:], module, allModules)

private fun find_qualified_function_in_import(className: String, member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match find_module_by_class(className, allModules) with
    case Some { importedModule } -> find_qualified_function_in_module(member, rest, module, allModules, importedModule)
    case _ -> find_qualified_function_in_imports(className, member, rest, module, allModules)

private fun find_qualified_function_in_module(member: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], importedModule: CompiledModule): /capy/lang/Option[CompiledFunction] =
    match find_function(member, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> find_qualified_function_in_imports(module_fqcn(importedModule), member, rest, module, allModules)

private fun int_type(): CompiledTypeReference = CompiledTypeReference { name: "int", arguments: [] }
private fun byte_type(): CompiledTypeReference = CompiledTypeReference { name: "byte", arguments: [] }
private fun long_type(): CompiledTypeReference = CompiledTypeReference { name: "long", arguments: [] }
private fun float_type(): CompiledTypeReference = CompiledTypeReference { name: "float", arguments: [] }
private fun double_type(): CompiledTypeReference = CompiledTypeReference { name: "double", arguments: [] }
private fun bool_type(): CompiledTypeReference = CompiledTypeReference { name: "bool", arguments: [] }
private fun string_type(): CompiledTypeReference = CompiledTypeReference { name: "String", arguments: [] }
private fun nothing_type(): CompiledTypeReference = CompiledTypeReference { name: "nothing", arguments: [] }
private fun object_type(): CompiledTypeReference = CompiledTypeReference { name: "any", arguments: [] }
private fun assert_type(): CompiledTypeReference = CompiledTypeReference { name: "Assert", arguments: [] }
private fun test_file_type(): CompiledTypeReference = CompiledTypeReference { name: "TestFile", arguments: [] }
private fun test_case_type(): CompiledTypeReference = CompiledTypeReference { name: "TestCase", arguments: [] }
private fun list_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "List", arguments: [arg] }
private fun set_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Set", arguments: [arg] }
private fun dict_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Dict", arguments: [arg] }
private fun tuple_type(args: List[CompiledTypeReference]): CompiledTypeReference = CompiledTypeReference { name: "Tuple", arguments: args }
private fun seq_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Seq", arguments: [arg] }
private fun effect_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Effect", arguments: [arg] }
private fun supplier_type(arg: CompiledTypeReference): CompiledTypeReference = CompiledTypeReference { name: "Supplier", arguments: [arg] }
private fun regex_match_type(): CompiledTypeReference = CompiledTypeReference { name: "Match", arguments: [] }
private fun string_to_string_function_type(): CompiledTypeReference = CompiledTypeReference { name: "String=>String", arguments: [] }

private fun regex_type_name(name: String): bool =
    name == "Regex" | name == "/capy/lang/Regex" | name == "capy/lang/Regex" | name == "capy.lang.Regex"

private fun test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    let gather = test_gather_calls(modules, modules)
    if gather.is_empty()
    then []
    else [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.java",
        code: "package capy.test;" + newline() + newline()
            + "public final class CapyTestRuntime {" + newline()
            + "    private CapyTestRuntime() " + "{" + "}" + newline() + newline()
            + "    public static java.util.List<CapyTest.TestFile> gatherTests() {" + newline()
            + "        return java.util.List.of(" + gather + ");" + newline()
            + "    }" + newline()
            + "}" + newline()
    }]

private fun test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        let calls = test_gather_calls_for_module(module.functions, module, allModules)
        let rest = test_gather_calls(modules[1:], allModules)
        join_non_empty(calls, rest)

private fun test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        let env = parameter_bindings(function.parameters) + constant_bindings(constant_functions(module.functions), module, allModules)
        let current =
            if function.name == "tests" & expression_emittable(function.body, env, module, allModules)
            then module_fqcn(module) + ".tests().unsafeRun()"
            else ""
        join_non_empty(current, test_gather_calls_for_module(functions[1:], module, allModules))

private fun join_non_empty(first: String, second: String): String =
    if first.is_empty() then second
    else if second.is_empty() then first
    else first + ", " + second

private fun module_fqcn(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path.replace("/", ".") + "." + module.name

private fun module_source_file(module: CompiledModule): String =
    if module.path.is_empty()
    then "/" + module.name + ".cfun"
    else "/" + module.path + "/" + module.name + ".cfun"

private fun java_helpers(module: CompiledModule): String =
    if module.functions.is_empty()
    then ""
    else java_base_helpers() + java_collection_helpers() + java_truthy_helper()

