private fun python_test_runtime_assert_code(): String =
    "class ValueAssert:" + python_newline()
    + "    def __init__(self, value, assertions=None):" + python_newline()
    + "        self.value = value" + python_newline()
    + "        self.assertions = list(assertions or [])" + python_newline()
    + python_newline()
    + "    def failed(self):" + python_newline()
    + "        return any(not bool(assertion().get('result', False)) for assertion in self.assertions)" + python_newline()
    + python_newline()
    + "    def succeeded(self):" + python_newline()
    + "        return not self.failed()" + python_newline()
    + python_newline()
    + "    def _append(self, result, message, assertion_type):" + python_newline()
    + "        return ValueAssert(self.value, self.assertions + [lambda: dict(result=bool(result), message=str(message), type=assertion_type)])" + python_newline()
    + python_newline()
    + "    def is_equal_to(self, other, tolerance=None):" + python_newline()
    + "        if tolerance is None:" + python_newline()
    + "            result = globals()['__capy_deep_equal'](self.value, other)" + python_newline()
    + "        else:" + python_newline()
    + "            result = abs(self.value - other) <= tolerance" + python_newline()
    + "        return self._append(result, 'Expected ' + repr(self.value) + ' to be equal to ' + repr(other), 'Assert.is_equal_to')" + python_newline()
    + python_newline()
    + "    def is_true(self):" + python_newline()
    + "        return self._append(self.value is True, 'Expected ' + repr(self.value) + ' to be true', 'Assert.is_true')" + python_newline()
    + python_newline()
    + "    def is_false(self):" + python_newline()
    + "        return self._append(self.value is False, 'Expected ' + repr(self.value) + ' to be false', 'Assert.is_false')" + python_newline()
    + python_newline()
    + python_value_assert_extra_methods_code()
    + "class CombinedAssert:" + python_newline()
    + "    def __init__(self, assertions):" + python_newline()
    + "        self.assertions = assertions" + python_newline()
    + python_newline()
    + "    def failed(self):" + python_newline()
    + "        return any(not bool(assertion().get('result', False)) for assertion in self.assertions)" + python_newline()
    + python_newline()
    + "    def succeeded(self):" + python_newline()
    + "        return not self.failed()" + python_newline()
    + python_newline()
    + "def assert_that(value):" + python_newline()
    + "    return ValueAssert(value)" + python_newline()
    + python_newline()
    + "def assert_all(asserts):" + python_newline()
    + "    assertions = []" + python_newline()
    + "    for item in asserts:" + python_newline()
    + "        assertions.extend(getattr(item, 'assertions', item.get('assertions', []) if isinstance(item, dict) else []))" + python_newline()
    + "    return CombinedAssert(assertions)" + python_newline()
    + python_newline()
    + "def test(name, body):" + python_newline()
    + "    return dict(name=name, body=body, assert_supplier=body)" + python_newline()
    + python_newline()
    + "def test_file(file_name, test_cases):" + python_newline()
    + "    return Effect.delay(lambda: dict(file_name=file_name, fileName=file_name, path=file_name, test_cases=test_cases, testCases=test_cases, timestamp_millis=int(time.time() * 1000)))" + python_newline()
    + python_newline()

