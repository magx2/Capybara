from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledFunctionReferenceExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression, CompiledWithExpression }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/generator/GeneratedModule import { GeneratedModule }
from /dev/capylang/generator/GeneratedProgram import { GeneratedProgram }

data PythonBinding { name: String, pythonName: String }

fun python_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: python_modules(program.modules, program.modules) + python_test_runtime_modules(program.modules)
    }

private fun python_modules(modules: List[CompiledModule], allModules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: python_module_relative_path(module, ".py"),
        code: python_module_code(module, allModules)
    }] + python_modules(modules[1:], allModules)

private fun python_module_code(module: CompiledModule, allModules: List[CompiledModule]): String =
    "# Generated by Capybara." + python_newline()
    + python_runtime_import()
    + python_imports(module.imports, module)
    + python_newline()
    + python_functions(module.functions, module, allModules)

private fun python_runtime_import(): String =
    "from capy.test.CapyTestRuntime import *" + python_newline()

private fun python_imports(imports: List[CompiledImportDeclaration], module: CompiledModule): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        if python_stdlib_import(declaration.modulePath)
        then python_imports(imports[1:], module)
        else python_import(declaration, module) + python_imports(imports[1:], module)

private fun python_import(declaration: CompiledImportDeclaration, module: CompiledModule): String =
    let modulePath = python_import_module_name(declaration.modulePath, module)
    if declaration.qualified
    then "import " + modulePath + python_newline()
    else "from " + modulePath + " import *" + python_newline()

private fun python_import_module_name(modulePath: String, module: CompiledModule): String =
    if python_string_has_prefix(modulePath, "/")
    then modulePath[1, modulePath.size().value].replace("/", ".")
    else if modulePath ? "/"
    then modulePath.replace("/", ".")
    else if module.path.is_empty()
    then modulePath
    else module.path.replace("/", ".") + "." + modulePath

private fun python_stdlib_import(modulePath: String): bool =
    python_string_has_prefix(modulePath, "/capy/") | python_string_has_prefix(modulePath, "capy/")

private fun python_functions(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if python_skip_function(function)
        then python_functions(functions[1:], module, allModules)
        else python_function(function, module, allModules) + python_newline() + python_functions(functions[1:], module, allModules)

private fun python_skip_function(function: CompiledFunction): bool =
    python_string_has_prefix(function.visibility, "const:")
        | function.visibility == "imported"
        | python_compiled_object_helper_function(function)

private fun python_compiled_object_helper_function(function: CompiledFunction): bool =
    python_string_has_prefix(function.name, "__capy_oo_method|")
        | python_string_has_prefix(function.name, "__capy_oo_interface_method|")
        | python_string_has_prefix(function.name, "__capy_oo_field_init|")
        | python_string_has_prefix(function.name, "__capy_oo_init|")

private fun python_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    let env = python_parameter_bindings(function.parameters)
    "def " + python_function_name(function) + "(" + python_parameters(function.parameters) + "):" + python_newline()
    + python_return_statement(function.body, env, module, allModules, "    ")

private fun python_return_statement(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledBlockExpression block ->
        python_block_statements(block.bindings, env, module, allModules, indent)
        + indent + "return " + python_expression_code(block.result, python_block_env(block.bindings, env), module, allModules) + python_newline()
    case _ -> indent + "return " + python_expression_code(expression, env, module, allModules) + python_newline()

private fun python_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> python_identifier(parameter.name) + python_parameter_tail(parameters[1:])

private fun python_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + python_identifier(parameter.name) + python_parameter_tail(parameters[1:])

private fun python_parameter_bindings(parameters: List[CompiledFunctionParameter]): List[PythonBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [PythonBinding { name: parameter.name, pythonName: python_identifier(parameter.name) }]
            + python_parameter_bindings(parameters[1:])

private fun python_expression_code(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledUnsupportedExpression unsupported -> "__capy_unsupported(" + python_string_literal(unsupported.source) + ")"
    case CompiledIntLiteral literal -> literal.source
    case CompiledLongLiteral literal -> python_long_literal(literal.source)
    case CompiledFloatLiteral literal -> python_decimal_literal(literal.source)
    case CompiledDoubleLiteral literal -> python_decimal_literal(literal.source)
    case CompiledBoolLiteral literal -> if literal.value then "True" else "False"
    case CompiledStringLiteral literal -> python_string_literal(literal.value)
    case CompiledVariableExpression variable -> python_variable_code(variable.name, env)
    case CompiledIfExpression ifExpression ->
        "(" + python_expression_code(ifExpression.thenBranch, env, module, allModules)
        + " if " + python_truthy_expression_code(ifExpression.condition, env, module, allModules)
        + " else " + python_expression_code(ifExpression.elseBranch, env, module, allModules)
        + ")"
    case CompiledBinaryExpression binary -> python_binary_expression_code(binary, env, module, allModules)
    case CompiledUnaryExpression unary -> python_unary_expression_code(unary, env, module, allModules)
    case CompiledFunctionCallExpression call -> python_function_call_code(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> python_function_call_name(reference.name, module, allModules)
    case CompiledMethodCallExpression call -> python_method_call_code(call, env, module, allModules)
    case CompiledWithExpression _ -> "__capy_unsupported('with')"
    case CompiledLambdaExpression lambda -> python_lambda_expression_code(lambda, env, module, allModules)
    case CompiledListLiteral literal -> "[" + python_expression_list_code(literal.values, env, module, allModules) + "]"
    case CompiledSetLiteral literal -> python_set_literal_code(literal.values, env, module, allModules)
    case CompiledDictLiteral literal -> "{" + python_dict_entries_code(literal.entries, env, module, allModules) + "}"
    case CompiledTupleLiteral literal -> python_tuple_literal_code(literal.values, env, module, allModules)
    case CompiledIndexExpression index -> python_index_expression_code(index, env, module, allModules)
    case CompiledDataLiteral literal -> "__capy_data(" + python_string_literal(literal.typeName) + ", {" + python_data_fields_code(literal.fields, env, module, allModules) + "})"
    case CompiledFieldAccessExpression access -> python_expression_code(access.receiver, env, module, allModules) + "." + python_identifier(access.name)
    case CompiledReduceExpression _ -> "__capy_unsupported('reduce')"
    case CompiledMatchExpression _ -> "__capy_unsupported('match')"
    case CompiledBlockExpression block -> python_block_expression_code(block, env, module, allModules)

private fun python_variable_code(name: String, env: List[PythonBinding]): String =
    match python_lookup_binding(name, env) with
    case Some { binding } -> binding.pythonName
    case None -> python_identifier(name)

private fun python_binary_expression_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binary.operator == "&" | binary.operator == "|"
    then "(" + python_truthy_expression_code(binary.left, env, module, allModules)
        + " " + python_boolean_operator(binary.operator) + " "
        + python_truthy_expression_code(binary.right, env, module, allModules)
        + ")"
    else if binary.operator == "+"
    then python_binary_runtime_call("__capy_add", binary, env, module, allModules)
    else if binary.operator == "-"
    then python_binary_runtime_call("__capy_sub", binary, env, module, allModules)
    else if binary.operator == "*"
    then python_binary_runtime_call("__capy_mul", binary, env, module, allModules)
    else if binary.operator == "/"
    then python_binary_runtime_call("__capy_div", binary, env, module, allModules)
    else if binary.operator == "^"
    then python_binary_runtime_call("__capy_pow", binary, env, module, allModules)
    else "(" + python_expression_code(binary.left, env, module, allModules)
        + " " + python_binary_operator(binary.operator) + " "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"

private fun python_binary_runtime_call(name: String, binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    name
        + "("
        + python_expression_code(binary.left, env, module, allModules)
        + ", "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"

private fun python_binary_operator(operator: String): String =
    if operator == "!="
    then "!="
    else if operator == "=="
    then "=="
    else operator

private fun python_boolean_operator(operator: String): String =
    if operator == "&" then "and" else "or"

private fun python_unary_expression_code(unary: CompiledUnaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(not " + python_truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else "(" + unary.operator + python_expression_code(unary.expression, env, module, allModules) + ")"

private fun python_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_function_call_name(call.name, module, allModules) + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_expression_code(call.receiver, env, module, allModules)
        + "." + python_method_name(call.name)
        + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = python_lambda_bindings(lambda.parameters) + env
    "lambda " + python_lambda_parameters(lambda.parameters) + ": " + python_expression_code(lambda.body, lambdaEnv, module, allModules)

private fun python_lambda_parameters(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> python_identifier(parameter) + python_lambda_parameter_tail(parameters[1:])

private fun python_lambda_parameter_tail(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + python_identifier(parameter) + python_lambda_parameter_tail(parameters[1:])

private fun python_lambda_bindings(parameters: List[String]): List[PythonBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [PythonBinding { name: parameter, pythonName: python_identifier(parameter) }]
            + python_lambda_bindings(parameters[1:])

private fun python_expression_list_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        python_expression_code(expression, env, module, allModules)
            + python_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun python_expression_list_tail_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + python_expression_code(expression, env, module, allModules)
            + python_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun python_set_literal_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if expressions.is_empty()
    then "set()"
    else "{" + python_expression_list_code(expressions, env, module, allModules) + "}"

private fun python_tuple_literal_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> "()"
    case Some _ ->
        if expressions[1:].is_empty()
        then "(" + python_expression_list_code(expressions, env, module, allModules) + ",)"
        else "(" + python_expression_list_code(expressions, env, module, allModules) + ")"

private fun python_dict_entries_code(entries: List[CompiledDictEntry], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        python_expression_code(entry.key, env, module, allModules)
            + ": "
            + python_expression_code(entry.value, env, module, allModules)
            + python_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun python_dict_entries_tail_code(entries: List[CompiledDictEntry], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        ", "
        + python_expression_code(entry.key, env, module, allModules)
        + ": "
        + python_expression_code(entry.value, env, module, allModules)
        + python_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun python_data_fields_code(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        python_string_literal(field.name)
            + ": "
            + python_expression_code(field.value, env, module, allModules)
            + python_data_fields_tail_code(fields[1:], env, module, allModules)

private fun python_data_fields_tail_code(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
        + python_string_literal(field.name)
        + ": "
        + python_expression_code(field.value, env, module, allModules)
        + python_data_fields_tail_code(fields[1:], env, module, allModules)

private fun python_index_expression_code(index: CompiledIndexExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = python_expression_code(index.receiver, env, module, allModules)
    if index.hasEndIndex
    then receiver
        + "["
        + python_expression_code(index.index, env, module, allModules)
        + ":"
        + python_expression_code(index.endIndex, env, module, allModules)
        + "]"
    else receiver + "[" + python_expression_code(index.index, env, module, allModules) + "]"

private fun python_block_expression_code(block: CompiledBlockExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if block.bindings.is_empty()
    then python_expression_code(block.result, env, module, allModules)
    else "(lambda: (" + python_block_binding_expressions(block.bindings, env, module, allModules)
        + python_expression_code(block.result, python_block_env(block.bindings, env), module, allModules)
        + ")[-1])()"

private fun python_block_binding_expressions(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        "(" + python_identifier(binding.name) + " := " + python_expression_code(binding.value, env, module, allModules) + "), "
            + python_block_binding_expressions(bindings[1:], [PythonBinding { name: binding.name, pythonName: python_identifier(binding.name) }] + env, module, allModules)

private fun python_block_statements(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        indent + python_identifier(binding.name) + " = " + python_expression_code(binding.value, env, module, allModules) + python_newline()
            + python_block_statements(bindings[1:], [PythonBinding { name: binding.name, pythonName: python_identifier(binding.name) }] + env, module, allModules, indent)

private fun python_block_env(bindings: List[CompiledLetBinding], env: List[PythonBinding]): List[PythonBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        python_block_env(bindings[1:], [PythonBinding { name: binding.name, pythonName: python_identifier(binding.name) }] + env)

private fun python_truthy_expression_code(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "bool(" + python_expression_code(expression, env, module, allModules) + ")"

private fun python_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_runtime_function(name)
    then name
    else match python_find_local_function(name, module.functions) with
    case Some { function } -> python_function_name(function)
    case None ->
        match python_find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> python_function_name(function)
        case None -> python_identifier(name)

private fun python_runtime_function(name: String): bool =
    name == "assert_all"
        | name == "assert_that"
        | name == "test"
        | name == "test_file"
        | name == "pure"
        | name == "delay"

private fun python_find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if python_callable_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else python_find_function(name, functions[1:])

private fun python_callable_function(function: CompiledFunction): bool =
    !python_skip_function(function) & function.visibility != "private" & function.visibility != "const:private"

private fun python_find_local_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if !python_skip_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else python_find_local_function(name, functions[1:])

private fun python_find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified | !python_import_includes_name(name, declaration)
        then python_find_function_in_imports(name, imports[1:], module, allModules)
        else python_find_function_in_import(name, declaration, imports[1:], module, allModules)

private fun python_find_function_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> python_find_imported_function_or_rest(name, importedModule, rest, module, allModules)
    case None -> python_find_function_in_imports(name, rest, module, allModules)

private fun python_find_imported_function_or_rest(name: String, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match python_find_function(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> python_find_function_in_imports(name, rest, module, allModules)

private fun python_find_imported_module(declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    python_find_module_by_path(python_import_module_path(declaration.modulePath, module), allModules)

private fun python_import_module_path(modulePath: String, module: CompiledModule): String =
    if python_string_has_prefix(modulePath, "/")
    then modulePath[1, modulePath.size().value]
    else if modulePath ? "/"
    then modulePath
    else if module.path.is_empty()
    then modulePath
    else module.path + "/" + modulePath

private fun python_find_module_by_path(modulePath: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if python_module_path(module) == modulePath
        then /capy/lang/Option.Some { module }
        else python_find_module_by_path(modulePath, modules[1:])

private fun python_import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !python_string_list_contains(name, declaration.excludedNames)
    else python_string_list_contains(name, declaration.importedNames)

private fun python_string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> item == value | python_string_list_contains(value, values[1:])

private fun python_module_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

private fun python_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else python_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

private fun python_method_name(name: String): String =
    python_identifier(name)

private fun python_lookup_binding(name: String, env: List[PythonBinding]): /capy/lang/Option[PythonBinding] =
    match env[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding }
        else python_lookup_binding(name, env[1:])

private fun python_test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.py",
        code: python_test_runtime_code(modules)
    }]

private fun python_test_runtime_code(modules: List[CompiledModule]): String =
    "# Generated by Capybara." + python_newline()
    + "import importlib" + python_newline()
    + "import time" + python_newline()
    + python_newline()
    + "__all__ = ['Effect', 'pure', 'delay', 'assert_all', 'assert_that', 'test', 'test_file', '__capy_add', '__capy_sub', '__capy_mul', '__capy_div', '__capy_pow', '__capy_pow_int', '__capy_unsupported', '__capy_data']" + python_newline()
    + python_newline()
    + "class Effect:" + python_newline()
    + "    def __init__(self, thunk):" + python_newline()
    + "        self._thunk = thunk" + python_newline()
    + python_newline()
    + "    def unsafe_run(self):" + python_newline()
    + "        return self._thunk()" + python_newline()
    + python_newline()
    + "    @staticmethod" + python_newline()
    + "    def delay(thunk):" + python_newline()
    + "        return Effect(thunk)" + python_newline()
    + python_newline()
    + "    @staticmethod" + python_newline()
    + "    def pure(value):" + python_newline()
    + "        return Effect(lambda: value)" + python_newline()
    + python_newline()
    + "def pure(value):" + python_newline()
    + "    return Effect.pure(value)" + python_newline()
    + python_newline()
    + "def delay(thunk):" + python_newline()
    + "    return Effect.delay(thunk)" + python_newline()
    + python_newline()
    + "class ValueAssert:" + python_newline()
    + "    def __init__(self, value, assertions=None):" + python_newline()
    + "        self.value = value" + python_newline()
    + "        self.assertions = list(assertions or [])" + python_newline()
    + python_newline()
    + "    def _append(self, result, message, assertion_type):" + python_newline()
    + "        return ValueAssert(self.value, self.assertions + [lambda: dict(result=bool(result), message=str(message), type=assertion_type)])" + python_newline()
    + python_newline()
    + "    def is_equal_to(self, other):" + python_newline()
    + "        return self._append(self.value == other, 'Expected ' + repr(self.value) + ' to be equal to ' + repr(other), 'Assert.is_equal_to')" + python_newline()
    + python_newline()
    + "    def is_true(self):" + python_newline()
    + "        return self._append(self.value is True, 'Expected ' + repr(self.value) + ' to be true', 'Assert.is_true')" + python_newline()
    + python_newline()
    + "    def is_false(self):" + python_newline()
    + "        return self._append(self.value is False, 'Expected ' + repr(self.value) + ' to be false', 'Assert.is_false')" + python_newline()
    + python_newline()
    + "class CombinedAssert:" + python_newline()
    + "    def __init__(self, assertions):" + python_newline()
    + "        self.assertions = assertions" + python_newline()
    + python_newline()
    + "def assert_that(value):" + python_newline()
    + "    return ValueAssert(value)" + python_newline()
    + python_newline()
    + "def assert_all(asserts):" + python_newline()
    + "    assertions = []" + python_newline()
    + "    for item in asserts:" + python_newline()
    + "        assertions.extend(getattr(item, 'assertions', item.get('assertions', []) if isinstance(item, dict) else []))" + python_newline()
    + "    return CombinedAssert(assertions)" + python_newline()
    + python_newline()
    + "def test(name, body):" + python_newline()
    + "    return dict(name=name, body=body, assert_supplier=body)" + python_newline()
    + python_newline()
    + "def test_file(file_name, test_cases):" + python_newline()
    + "    return Effect.delay(lambda: dict(file_name=file_name, fileName=file_name, path=file_name, test_cases=test_cases, testCases=test_cases, timestamp_millis=int(time.time() * 1000)))" + python_newline()
    + python_newline()
    + "def __capy_str(value):" + python_newline()
    + "    if value is True:" + python_newline()
    + "        return 'true'" + python_newline()
    + "    if value is False:" + python_newline()
    + "        return 'false'" + python_newline()
    + "    if value is None:" + python_newline()
    + "        return 'null'" + python_newline()
    + "    return str(value)" + python_newline()
    + python_newline()
    + "def __capy_add(left, right):" + python_newline()
    + "    if isinstance(left, str) or isinstance(right, str):" + python_newline()
    + "        return __capy_str(left) + __capy_str(right)" + python_newline()
    + "    if isinstance(left, list):" + python_newline()
    + "        return left + (right if isinstance(right, list) else [right])" + python_newline()
    + "    if isinstance(left, set):" + python_newline()
    + "        result = set(left)" + python_newline()
    + "        if isinstance(right, set):" + python_newline()
    + "            result.update(right)" + python_newline()
    + "        else:" + python_newline()
    + "            result.add(right)" + python_newline()
    + "        return result" + python_newline()
    + "    if isinstance(left, dict):" + python_newline()
    + "        result = dict(left)" + python_newline()
    + "        if isinstance(right, dict):" + python_newline()
    + "            result.update(right)" + python_newline()
    + "        elif isinstance(right, (list, tuple)) and len(right) == 2:" + python_newline()
    + "            result[right[0]] = right[1]" + python_newline()
    + "        else:" + python_newline()
    + "            raise TypeError('Unsupported dict + operand: ' + repr(right))" + python_newline()
    + "        return result" + python_newline()
    + "    return left + right" + python_newline()
    + python_newline()
    + "def __capy_sub(left, right):" + python_newline()
    + "    if isinstance(left, str):" + python_newline()
    + "        return __capy_str(left) + __capy_str(right)" + python_newline()
    + "    if isinstance(left, list):" + python_newline()
    + "        if isinstance(right, list):" + python_newline()
    + "            return [item for item in left if item not in right]" + python_newline()
    + "        return [item for item in left if item != right]" + python_newline()
    + "    if isinstance(left, set):" + python_newline()
    + "        result = set(left)" + python_newline()
    + "        if isinstance(right, set):" + python_newline()
    + "            result.difference_update(right)" + python_newline()
    + "        else:" + python_newline()
    + "            result.discard(right)" + python_newline()
    + "        return result" + python_newline()
    + "    if isinstance(left, dict):" + python_newline()
    + "        result = dict(left)" + python_newline()
    + "        if isinstance(right, dict):" + python_newline()
    + "            for key in right.keys():" + python_newline()
    + "                result.pop(key, None)" + python_newline()
    + "        else:" + python_newline()
    + "            result.pop(right, None)" + python_newline()
    + "        return result" + python_newline()
    + "    return left - right" + python_newline()
    + python_newline()
    + "def __capy_mul(left, right):" + python_newline()
    + "    if isinstance(left, str):" + python_newline()
    + "        return __capy_str(left) + __capy_str(right)" + python_newline()
    + "    return left * right" + python_newline()
    + python_newline()
    + "def __capy_div(left, right):" + python_newline()
    + "    if isinstance(left, str):" + python_newline()
    + "        return __capy_str(left) + __capy_str(right)" + python_newline()
    + "    if isinstance(left, int) and isinstance(right, int) and not isinstance(left, bool) and not isinstance(right, bool):" + python_newline()
    + "        return int(left / right)" + python_newline()
    + "    return left / right" + python_newline()
    + python_newline()
    + "def __capy_pow(left, right):" + python_newline()
    + "    if isinstance(left, str):" + python_newline()
    + "        return __capy_str(left) + __capy_str(right)" + python_newline()
    + "    if isinstance(left, int) and isinstance(right, int) and not isinstance(left, bool) and not isinstance(right, bool):" + python_newline()
    + "        return __capy_pow_int(left, right)" + python_newline()
    + "    return left ** right" + python_newline()
    + python_newline()
    + "def __capy_pow_int(base, exponent):" + python_newline()
    + "    if exponent <= 0:" + python_newline()
    + "        return 1" + python_newline()
    + "    result = 1" + python_newline()
    + "    for _ in range(exponent):" + python_newline()
    + "        result *= base" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_unsupported(source):" + python_newline()
    + "    raise NotImplementedError('Unsupported CFUN expression: ' + str(source))" + python_newline()
    + python_newline()
    + "def __capy_data(type_name, fields):" + python_newline()
    + "    result = dict(fields)" + python_newline()
    + "    result['__type'] = type_name" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def _unsafe_run(value):" + python_newline()
    + "    while hasattr(value, 'unsafe_run') and callable(value.unsafe_run):" + python_newline()
    + "        value = value.unsafe_run()" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def _as_list(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if value is None:" + python_newline()
    + "        return []" + python_newline()
    + "    if isinstance(value, list):" + python_newline()
    + "        return value" + python_newline()
    + "    return [value]" + python_newline()
    + python_newline()
    + "def _gather_module(module_name):" + python_newline()
    + "    module = importlib.import_module(module_name)" + python_newline()
    + "    tests = getattr(module, 'tests', None)" + python_newline()
    + "    if not callable(tests):" + python_newline()
    + "        return []" + python_newline()
    + "    return _as_list(tests())" + python_newline()
    + python_newline()
    + "def gatherTests():" + python_newline()
    + "    files = []" + python_newline()
    + python_test_gather_calls(modules, modules)
    + "    return files" + python_newline()

private fun python_test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        python_test_gather_calls_for_module(module.functions, module, allModules)
            + python_test_gather_calls(modules[1:], allModules)

private fun python_test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if function.name == "tests" & python_test_function_gatherable(function) & python_module_gatherable(module, allModules)
        then "    files.extend(_gather_module(" + python_string_literal(python_module_import_name(module)) + "))" + python_newline()
            + python_test_gather_calls_for_module(functions[1:], module, allModules)
        else python_test_gather_calls_for_module(functions[1:], module, allModules)

private fun python_module_gatherable(module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_module_imports_gatherable(module.imports, module, allModules)
        & python_module_functions_gatherable(module.functions, module, allModules)

private fun python_module_imports_gatherable(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> true
    case Some { declaration } ->
        if python_stdlib_import(declaration.modulePath)
        then python_module_imports_gatherable(imports[1:], module, allModules)
        else match python_find_imported_module(declaration, module, allModules) with
            case Some { importedModule } ->
                python_module_functions_gatherable(importedModule.functions, importedModule, allModules)
                    & python_module_imports_gatherable(imports[1:], module, allModules)
            case None -> false

private fun python_module_functions_gatherable(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match functions[0] with
    case None -> true
    case Some { function } ->
        (python_skip_function(function) | python_expression_gatherable(function.body, module, allModules))
            & python_module_functions_gatherable(functions[1:], module, allModules)

private fun python_expression_gatherable(expression: CompiledExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression _ -> false
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression _ -> true
    case CompiledIfExpression ifExpression ->
        python_expression_gatherable(ifExpression.condition, module, allModules)
            & python_expression_gatherable(ifExpression.thenBranch, module, allModules)
            & python_expression_gatherable(ifExpression.elseBranch, module, allModules)
    case CompiledBinaryExpression binary ->
        python_binary_operator_gatherable(binary.operator)
            & python_expression_gatherable(binary.left, module, allModules)
            & python_expression_gatherable(binary.right, module, allModules)
    case CompiledUnaryExpression unary ->
        python_unary_operator_gatherable(unary.operator)
            & python_expression_gatherable(unary.expression, module, allModules)
    case CompiledFunctionCallExpression call ->
        python_function_call_gatherable(call, module, allModules)
    case CompiledFunctionReferenceExpression _ -> false
    case CompiledMethodCallExpression call ->
        python_method_call_gatherable(call, module, allModules)
    case CompiledWithExpression _ -> false
    case CompiledLambdaExpression lambda ->
        python_expression_gatherable(lambda.body, module, allModules)
    case CompiledListLiteral literal -> python_expressions_gatherable(literal.values, module, allModules)
    case CompiledSetLiteral literal -> python_expressions_gatherable(literal.values, module, allModules)
    case CompiledDictLiteral literal -> python_dict_entries_gatherable(literal.entries, module, allModules)
    case CompiledTupleLiteral literal -> python_expressions_gatherable(literal.values, module, allModules)
    case CompiledIndexExpression index ->
        python_expression_gatherable(index.receiver, module, allModules)
            & python_expression_gatherable(index.index, module, allModules)
            & (!index.hasEndIndex | python_expression_gatherable(index.endIndex, module, allModules))
    case CompiledDataLiteral _ -> false
    case CompiledFieldAccessExpression _ -> false
    case CompiledReduceExpression _ -> false
    case CompiledMatchExpression _ -> false
    case CompiledBlockExpression block ->
        python_bindings_gatherable(block.bindings, module, allModules)
            & python_expression_gatherable(block.result, module, allModules)

private fun python_binary_operator_gatherable(operator: String): bool =
    operator == "+"
        | operator == "-"
        | operator == "*"
        | operator == "/"
        | operator == "^"
        | operator == "=="
        | operator == "!="
        | operator == ">"
        | operator == "<"
        | operator == ">="
        | operator == "<="
        | operator == "&"
        | operator == "|"

private fun python_unary_operator_gatherable(operator: String): bool =
    operator == "-" | operator == "!"

private fun python_function_call_gatherable(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expressions_gatherable(call.arguments, module, allModules)
        & (python_runtime_function(call.name)
            | python_local_function_exists(call.name, module.functions)
            | python_imported_function_exists(call.name, module.imports, module, allModules))

private fun python_method_call_gatherable(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    (call.name == "is_equal_to" | call.name == "is_true" | call.name == "is_false")
        & python_expression_gatherable(call.receiver, module, allModules)
        & python_expressions_gatherable(call.arguments, module, allModules)

private fun python_local_function_exists(name: String, functions: List[CompiledFunction]): bool =
    match python_find_local_function(name, functions) with
    case Some _ -> true
    case None -> false

private fun python_imported_function_exists(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_function_in_imports(name, imports, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_expressions_gatherable(expressions: List[CompiledExpression], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        python_expression_gatherable(expression, module, allModules)
            & python_expressions_gatherable(expressions[1:], module, allModules)

private fun python_dict_entries_gatherable(entries: List[CompiledDictEntry], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } ->
        python_expression_gatherable(entry.key, module, allModules)
            & python_expression_gatherable(entry.value, module, allModules)
            & python_dict_entries_gatherable(entries[1:], module, allModules)

private fun python_bindings_gatherable(bindings: List[CompiledLetBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        binding.operator == "="
            & python_expression_gatherable(binding.value, module, allModules)
            & python_bindings_gatherable(bindings[1:], module, allModules)

private fun python_test_function_gatherable(function: CompiledFunction): bool =
    match function.body with
    case CompiledFunctionCallExpression call -> call.name == "test_file" & python_test_file_arguments_gatherable(call.arguments)
    case _ -> false

private fun python_test_file_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { fileName } ->
        match arguments[1] with
        case None -> false
        case Some { tests } ->
            arguments[2:].is_empty()
                & python_string_literal_expression(fileName)
                & python_test_case_list_gatherable(tests)

private fun python_test_case_list_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledListLiteral list -> python_test_case_expressions_gatherable(list.values)
    case _ -> false

private fun python_test_case_expressions_gatherable(expressions: List[CompiledExpression]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> python_test_case_expression_gatherable(expression) & python_test_case_expressions_gatherable(expressions[1:])

private fun python_test_case_expression_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "test" & python_test_call_arguments_gatherable(call.arguments)
    case _ -> false

private fun python_test_call_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { name } ->
        match arguments[1] with
        case None -> false
        case Some { body } ->
            arguments[2:].is_empty()
                & python_string_literal_expression(name)
                & python_zero_arg_lambda(body)

private fun python_string_literal_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledStringLiteral _ -> true
    case _ -> false

private fun python_zero_arg_lambda(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

private fun python_module_import_name(module: CompiledModule): String =
    python_module_path(module).replace("/", ".")

private fun python_module_relative_path(module: CompiledModule, extension: String): String =
    if module.path.is_empty()
    then module.name + extension
    else module.path + "/" + module.name + extension

private fun python_identifier(name: String): String =
    let sanitized = python_identifier_chars(name, 0, "")
    let nonEmpty = if sanitized.is_empty() then "_" else sanitized
    let prefixed = match nonEmpty[0] with
        case None -> "_"
        case Some { char } -> if python_identifier_start_char(char) then nonEmpty else "_" + nonEmpty
    if python_reserved_word(prefixed)
    then prefixed + "_"
    else prefixed

private fun python_identifier_chars(name: String, idx: int, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            let next = if python_identifier_part_char(char) then char else "_"
            python_identifier_chars(name, idx + 1, acc + next)

private fun python_identifier_start_char(char: String): bool =
    ("ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char) | ("abcdefghijklmnopqrstuvwxyz" ? char) | char == "_"

private fun python_identifier_part_char(char: String): bool =
    python_identifier_start_char(char) | ("0123456789" ? char)

private fun python_reserved_word(name: String): bool =
    "|False|None|True|and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|" ? ("|" + name + "|")

private fun python_string_literal(value: String): String =
    "\"" + escape_python_string(value) + "\""

private fun escape_python_string(value: String): String =
    value
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace('\n', '\\n')
        .replace('\r', '\\r')
        .replace('\t', '\\t')

private fun python_long_literal(source: String): String =
    if python_string_has_suffix(source, "L") | python_string_has_suffix(source, "l")
    then source[0, source.size().value - 1]
    else source

private fun python_decimal_literal(source: String): String =
    if python_string_has_suffix(source, "f") | python_string_has_suffix(source, "F") | python_string_has_suffix(source, "d") | python_string_has_suffix(source, "D")
    then source[0, source.size().value - 1]
    else source

private fun python_string_has_prefix(value: String, prefix: String): bool =
    python_string_has_prefix_at(value, prefix, 0)

private fun python_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then python_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun python_string_has_suffix(value: String, suffix: String): bool =
    if suffix.size().value > value.size().value
    then false
    else value[value.size().value - suffix.size().value, value.size().value] == suffix

private fun python_newline(): String = '\n'
