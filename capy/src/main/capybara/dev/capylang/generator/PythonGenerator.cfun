private fun python_test_runtime_copy_move_code(): String =
    "def copy(source, target):" + python_newline()
    + "    def run_copy():" + python_newline()
    + "        source_path = __capy_pathlib(source)" + python_newline()
    + "        target_path = __capy_pathlib(target)" + python_newline()
    + "        if target_path.exists():" + python_newline()
    + "            raise FileExistsError(str(target_path))" + python_newline()
    + "        shutil.copyfile(source_path, target_path)" + python_newline()
    + "        return target" + python_newline()
    + "    return Effect.delay(lambda: __capy_io_result('copy', run_copy))" + python_newline()
    + python_newline()
    + "def copy_replace(source, target):" + python_newline()
    + "    return Effect.delay(lambda: __capy_io_result('copy_replace', lambda: (shutil.copyfile(__capy_pathlib(source), __capy_pathlib(target)), target)[1]))" + python_newline()
    + python_newline()
    + "def move(source, target):" + python_newline()
    + "    def run_move():" + python_newline()
    + "        target_path = __capy_pathlib(target)" + python_newline()
    + "        if target_path.exists():" + python_newline()
    + "            raise FileExistsError(str(target_path))" + python_newline()
    + "        shutil.move(str(__capy_pathlib(source)), str(target_path))" + python_newline()
    + "        return target" + python_newline()
