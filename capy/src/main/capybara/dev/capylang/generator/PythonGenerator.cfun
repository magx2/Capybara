private fun python_test_runtime_path_code(): String =
    "def __capy_path_root_name(value):" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        return value.get('__type', 'RELATIVE')" + python_newline()
    + "    return str(value)" + python_newline()
    + python_newline()
    + "def __capy_path(root, segments):" + python_newline()
    + "    return __capy_data('Path', dict(root=__capy_data(root, dict()), prefix=__capy_none(), segments=list(segments)))" + python_newline()
    + python_newline()
    + "def __capy_path_is(value):" + python_newline()
    + "    return _capy_data_is(value, 'Path')" + python_newline()
    + python_newline()
    + "def __capy_normalize_path_segments(root, segments):" + python_newline()
    + "    result = []" + python_newline()
    + "    for segment in segments:" + python_newline()
    + "        segment = str(segment)" + python_newline()
    + "        if segment == '' or segment == '.':" + python_newline()
    + "            continue" + python_newline()
    + "        if segment == '..':" + python_newline()
    + "            if result:" + python_newline()
    + "                result.pop()" + python_newline()
    + "            elif root == 'RELATIVE':" + python_newline()
    + "                result.append(segment)" + python_newline()
    + "        else:" + python_newline()
    + "            result.append(segment)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def from_string(path_string):" + python_newline()
    + "    text = str(path_string)" + python_newline()
    + "    if text.startswith('/'):" + python_newline()
    + "        root = 'ABSOLUTE'" + python_newline()
    + "        body = text[1:]" + python_newline()
    + "    elif text.startswith('~'):" + python_newline()
    + "        root = 'HOME'" + python_newline()
    + "        body = text[2:] if text.startswith('~/') else text[1:]" + python_newline()
    + "    else:" + python_newline()
    + "        root = 'RELATIVE'" + python_newline()
    + "        body = text" + python_newline()
    + "    return __capy_path(root, __capy_normalize_path_segments(root, body.split('/')))" + python_newline()
    + python_newline()
    + "def __capy_path_segments(value):" + python_newline()
    + "    return list(value.get('segments', [])) if isinstance(value, dict) else [str(value)]" + python_newline()
    + python_newline()
    + "def __capy_path_join(left, right):" + python_newline()
    + "    root = __capy_path_root_name(left.get('root', 'RELATIVE'))" + python_newline()
    + "    segments = __capy_path_segments(left)" + python_newline()
    + "    if __capy_path_is(right):" + python_newline()
    + "        segments = segments + __capy_path_segments(right)" + python_newline()
    + "    else:" + python_newline()
    + "        segments = segments + [str(right)]" + python_newline()
    + "    return __capy_path(root, __capy_normalize_path_segments(root, segments))" + python_newline()
    + python_newline()
    + "def __capy_path_to_string(value):" + python_newline()
    + "    if not __capy_path_is(value):" + python_newline()
    + "        return str(value)" + python_newline()
    + "    root = __capy_path_root_name(value.get('root', 'RELATIVE'))" + python_newline()
    + "    segments = __capy_path_segments(value)" + python_newline()
    + "    if root == 'ABSOLUTE':" + python_newline()
    + "        return '/' + '/'.join(segments)" + python_newline()
    + "    if root == 'HOME':" + python_newline()
    + "        return str(pathlib.Path.home().joinpath(*segments)) if segments else str(pathlib.Path.home())" + python_newline()
    + "    return '/'.join(segments) if segments else '.'" + python_newline()
    + python_newline()
    + "def __capy_pathlib(value):" + python_newline()
    + "    return pathlib.Path(__capy_path_to_string(value)).expanduser()" + python_newline()
    + python_newline()

private fun python_test_runtime_io_result_code(): String =
    "def __capy_io_result(operation, thunk):" + python_newline()
