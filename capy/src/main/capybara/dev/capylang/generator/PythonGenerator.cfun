private fun python_test_runtime_calendar_helpers_code(): String =
    "def __capy_leap_year(year):" + python_newline()
    + "    year = int(year)" + python_newline()
    + "    return (year % 4 == 0 and year % 100 != 0) or year % 400 == 0" + python_newline()
    + python_newline()
    + "def __capy_days_in_month(year, month):" + python_newline()
    + "    if month in (4, 6, 9, 11):" + python_newline()
    + "        return 30" + python_newline()
    + "    if month == 2:" + python_newline()
    + "        return 29 if __capy_leap_year(year) else 28" + python_newline()
    + "    return 31" + python_newline()
    + python_newline()
    + "def __capy_date_to_days_since_unix_epoch(date):" + python_newline()
    + "    day = __capy_int_field(date, 'day')" + python_newline()
    + "    month = __capy_int_field(date, 'month')" + python_newline()
    + "    year = __capy_int_field(date, 'year')" + python_newline()
    + "    y = year - 1 if month <= 2 else year" + python_newline()
    + "    era = y // 400" + python_newline()
    + "    yoe = y - era * 400" + python_newline()
    + "    mp = month - 3 if month > 2 else month + 9" + python_newline()
    + "    doy = (153 * mp + 2) // 5 + day - 1" + python_newline()
    + "    doe = yoe * 365 + yoe // 4 - yoe // 100 + doy" + python_newline()
    + "    return era * 146097 + doe - 719468" + python_newline()
    + python_newline()
    + "def __capy_date_from_days_since_unix_epoch(days):" + python_newline()
    + "    z = int(days) + 719468" + python_newline()
    + "    era = z // 146097" + python_newline()
    + "    doe = z - era * 146097" + python_newline()
    + "    yoe = (doe - doe // 1460 + doe // 36524 - doe // 146096) // 365" + python_newline()
    + "    year = yoe + era * 400" + python_newline()
    + "    doy = doe - (365 * yoe + yoe // 4 - yoe // 100)" + python_newline()
    + "    mp = (5 * doy + 2) // 153" + python_newline()
    + "    day = doy - (153 * mp + 2) // 5 + 1" + python_newline()
    + "    month = mp + 3 if mp < 10 else mp - 9" + python_newline()
    + "    if month <= 2:" + python_newline()
    + "        year += 1" + python_newline()
    + "    return __capy_date(day, month, year)" + python_newline()
    + python_newline()
    + "def __capy_date_add_days(date, days):" + python_newline()
    + "    return __capy_date_from_days_since_unix_epoch(__capy_date_to_days_since_unix_epoch(date) + int(days))" + python_newline()
    + python_newline()

private fun python_test_runtime_date_format_helpers_code(): String =
    "def __capy_date_add_years_months(date, years, months):" + python_newline()
    + "    day = __capy_int_field(date, 'day')" + python_newline()
    + "    month = __capy_int_field(date, 'month')" + python_newline()
    + "    year = __capy_int_field(date, 'year')" + python_newline()
    + "    total_months = (year + int(years)) * 12 + (month + int(months) - 1)" + python_newline()
    + "    normalized_year = total_months // 12" + python_newline()
    + "    normalized_month = total_months % 12 + 1" + python_newline()
    + "    return __capy_date(min(day, __capy_days_in_month(normalized_year, normalized_month)), normalized_month, normalized_year)" + python_newline()
    + python_newline()
    + "def __capy_pad_int(value, size):" + python_newline()
    + "    return str(abs(int(value))).rjust(size, '0')" + python_newline()
    + python_newline()
    + "def __capy_date_to_iso_8601(date):" + python_newline()
    + "    year = __capy_int_field(date, 'year')" + python_newline()
    + "    if year < 0:" + python_newline()
    + "        year_text = '-' + __capy_pad_int(year, 4)" + python_newline()
    + "    elif year > 9999:" + python_newline()
    + "        year_text = '+' + str(year)" + python_newline()
    + "    else:" + python_newline()
    + "        year_text = __capy_pad_int(year, 4)" + python_newline()
    + "    return year_text + '-' + __capy_pad_int(__capy_int_field(date, 'month'), 2) + '-' + __capy_pad_int(__capy_int_field(date, 'day'), 2)" + python_newline()
    + python_newline()

private fun python_test_runtime_time_helpers_code(): String =
    "def __capy_time_to_seconds(time):" + python_newline()
    + "    return __capy_int_field(time, 'hour') * 3600 + __capy_int_field(time, 'minute') * 60 + __capy_int_field(time, 'second')" + python_newline()
    + python_newline()
    + "def __capy_time_add_seconds(time, seconds):" + python_newline()
    + "    total_seconds = (__capy_time_to_seconds(time) + int(seconds)) % 86400" + python_newline()
    + "    hour = (total_seconds // 3600) % 24" + python_newline()
    + "    minute = (total_seconds // 60) % 60" + python_newline()
    + "    second = total_seconds % 60" + python_newline()
    + "    return __capy_time(hour, minute, second, __capy_raw_field(time, 'offset_minutes'))" + python_newline()
    + python_newline()
    + "def __capy_time_to_iso_8601(time):" + python_newline()
    + "    text = __capy_pad_int(__capy_int_field(time, 'hour'), 2) + ':' + __capy_pad_int(__capy_int_field(time, 'minute'), 2) + ':' + __capy_pad_int(__capy_int_field(time, 'second'), 2)" + python_newline()
    + "    offset = __capy_raw_field(time, 'offset_minutes')" + python_newline()
    + "    if _capy_data_is(offset, 'None'):" + python_newline()
    + "        return text" + python_newline()
    + "    offset_minutes = __capy_int_value(_capy_data_value(offset))" + python_newline()
    + "    if offset_minutes == 0:" + python_newline()
    + "        return text + 'Z'" + python_newline()
    + "    absolute = abs(offset_minutes)" + python_newline()
    + "    return text + ('-' if offset_minutes < 0 else '+') + __capy_pad_int(absolute // 60, 2) + ':' + __capy_pad_int(absolute % 60, 2)" + python_newline()
    + python_newline()

private fun python_test_runtime_date_time_helpers_code(): String =
    "def __capy_date_time_timestamp(date_time):" + python_newline()
    + "    return __capy_date_to_days_since_unix_epoch(__capy_raw_field(date_time, 'date')) * 86400 + __capy_time_to_seconds(__capy_raw_field(date_time, 'time'))" + python_newline()
    + python_newline()
    + "def __capy_date_time_plus(date_time, duration):" + python_newline()
    + "    if _capy_data_is(duration, 'WeekDuration'):" + python_newline()
    + "        duration = __capy_date_duration(0, 0, __capy_int_field(duration, 'weeks') * 7, 0, 0, 0)" + python_newline()
    + "    date = __capy_raw_field(date_time, 'date')" + python_newline()
    + "    time = __capy_raw_field(date_time, 'time')" + python_newline()
    + "    date_with_months = __capy_date_add_years_months(date, __capy_duration_years(duration), __capy_duration_months(duration))" + python_newline()
    + "    days_from_hours = __capy_duration_hours(duration) // 24" + python_newline()
    + "    days_from_minutes = __capy_duration_minutes(duration) // 1440" + python_newline()
    + "    days_from_seconds = __capy_duration_seconds(duration) // 86400" + python_newline()
    + "    remainder_hours = __capy_duration_hours(duration) % 24" + python_newline()
    + "    remainder_minutes = __capy_duration_minutes(duration) % 1440" + python_newline()
    + "    remainder_seconds = __capy_duration_seconds(duration) % 86400" + python_newline()
    + "    intra_day_seconds = remainder_hours * 3600 + remainder_minutes * 60 + remainder_seconds" + python_newline()
    + "    extra_days = (__capy_time_to_seconds(time) + intra_day_seconds) // 86400" + python_newline()
    + "    new_date = __capy_date_add_days(date_with_months, __capy_duration_days(duration) + days_from_hours + days_from_minutes + days_from_seconds + extra_days)" + python_newline()
    + "    return __capy_date_time(new_date, __capy_time_add_seconds(time, intra_day_seconds))" + python_newline()
    + python_newline()
    + "def __capy_date_time_minus(date_time, other):" + python_newline()
    + "    if _capy_data_is(other, 'DateTime'):" + python_newline()
    + "        delta = __capy_date_time_timestamp(date_time) - __capy_date_time_timestamp(other)" + python_newline()
    + "        negative = delta < 0" + python_newline()
    + "        total_seconds = abs(delta)" + python_newline()
    + "        days = total_seconds // 86400" + python_newline()
    + "        remainder = total_seconds % 86400" + python_newline()
    + "        hours = remainder // 3600" + python_newline()
    + "        remainder = remainder % 3600" + python_newline()
    + "        minutes = remainder // 60" + python_newline()
    + "        seconds = remainder % 60" + python_newline()
    + "        duration = __capy_date_duration(0, 0, days, hours, minutes, seconds)" + python_newline()
    + "        return __capy_duration_negate(duration) if negative else duration" + python_newline()
    + "    return __capy_date_time_plus(date_time, __capy_duration_negate(other))" + python_newline()
    + python_newline()
    + "def __capy_date_time_to_iso_8601(date_time):" + python_newline()
    + "    time = __capy_raw_field(date_time, 'time')" + python_newline()
    + "    offset = __capy_raw_field(time, 'offset_minutes')" + python_newline()
    + "    if _capy_data_is(offset, 'Some'):" + python_newline()
    + "        offset_minutes = __capy_int_value(_capy_data_value(offset))" + python_newline()
    + "        time = __capy_time(__capy_int_field(time, 'hour'), __capy_int_field(time, 'minute'), __capy_int_field(time, 'second'))" + python_newline()
    + "        date_time = __capy_date_time_plus(__capy_date_time(__capy_raw_field(date_time, 'date'), time), __capy_date_duration(0, 0, 0, 0, 0 - offset_minutes, 0))" + python_newline()
    + "    return __capy_date_to_iso_8601(__capy_raw_field(date_time, 'date')) + 'T' + __capy_time_to_iso_8601(__capy_raw_field(date_time, 'time')) + 'Z'" + python_newline()
    + python_newline()

private fun python_test_runtime_duration_helpers_code(): String =
    "def __capy_duration_years(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'years') if _capy_data_is(duration, 'DateDuration') else 0" + python_newline()
    + python_newline()
    + "def __capy_duration_months(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'months') if _capy_data_is(duration, 'DateDuration') else 0" + python_newline()
    + python_newline()
    + "def __capy_duration_days(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'days') if _capy_data_is(duration, 'DateDuration') else __capy_int_field(duration, 'weeks') * 7" + python_newline()
    + python_newline()
    + "def __capy_duration_hours(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'hours') if _capy_data_is(duration, 'DateDuration') else 0" + python_newline()
    + python_newline()
    + "def __capy_duration_minutes(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'minutes') if _capy_data_is(duration, 'DateDuration') else 0" + python_newline()
    + python_newline()
    + "def __capy_duration_seconds(duration):" + python_newline()
    + "    return __capy_int_field(duration, 'seconds') if _capy_data_is(duration, 'DateDuration') else 0" + python_newline()
    + python_newline()
    + "def __capy_duration_negate(duration):" + python_newline()
    + "    if _capy_data_is(duration, 'WeekDuration'):" + python_newline()
    + "        return __capy_data('WeekDuration', dict(weeks=0 - __capy_int_field(duration, 'weeks')))" + python_newline()
    + "    return __capy_date_duration(0 - __capy_duration_years(duration), 0 - __capy_duration_months(duration), 0 - __capy_duration_days(duration), 0 - __capy_duration_hours(duration), 0 - __capy_duration_minutes(duration), 0 - __capy_duration_seconds(duration))" + python_newline()
    + python_newline()
    + "def __capy_duration_to_iso_8601(duration):" + python_newline()
    + "    if _capy_data_is(duration, 'WeekDuration'):" + python_newline()
    + "        return 'P' + str(__capy_int_field(duration, 'weeks')) + 'W'" + python_newline()
    + "    years = __capy_duration_years(duration)" + python_newline()
    + "    months = __capy_duration_months(duration)" + python_newline()
    + "    days = __capy_duration_days(duration)" + python_newline()
    + "    hours = __capy_duration_hours(duration)" + python_newline()
    + "    minutes = __capy_duration_minutes(duration)" + python_newline()
    + "    seconds = __capy_duration_seconds(duration)" + python_newline()
    + "    if years == 0 and months == 0 and days == 0 and hours == 0 and minutes == 0 and seconds == 0:" + python_newline()
    + "        return 'PT0S'" + python_newline()
    + "    text = 'P'" + python_newline()
    + "    if years != 0:" + python_newline()
    + "        text += str(years) + 'Y'" + python_newline()
    + "    if months != 0:" + python_newline()
    + "        text += str(months) + 'M'" + python_newline()
    + "    if days != 0:" + python_newline()
    + "        text += str(days) + 'D'" + python_newline()
    + "    if hours != 0 or minutes != 0 or seconds != 0:" + python_newline()
    + "        text += 'T'" + python_newline()
    + "    if hours != 0:" + python_newline()
    + "        text += str(hours) + 'H'" + python_newline()
    + "    if minutes != 0:" + python_newline()
    + "        text += str(minutes) + 'M'" + python_newline()
    + "    if seconds != 0:" + python_newline()
    + "        text += str(seconds) + 'S'" + python_newline()
    + "    return text" + python_newline()
    + python_newline()

private fun python_test_runtime_error_code(): String =
    "def __capy_unsupported(source):" + python_newline()
    + "    raise NotImplementedError('Unsupported CFUN expression: ' + str(source))" + python_newline()
    + python_newline()
    + "def __capy_not_implemented(function_name):" + python_newline()
    + "    if function_name:" + python_newline()
    + "        message = 'the function `' + str(function_name) + '` is not yet implemented'" + python_newline()
    + "    else:" + python_newline()
    + "        message = 'placeholder expression is not yet implemented'" + python_newline()
    + "    raise NotImplementedError(message)" + python_newline()
    + python_newline()
    + "def __capy_normalize_type_name(type_name):" + python_newline()
    + "    type_name = str(type_name or '')" + python_newline()
    + "    if type_name in ('/capy/lang/Program.Success', 'Program.Success'):" + python_newline()
    + "        return 'Success'" + python_newline()
    + "    if type_name in ('/capy/lang/Program.Failed', 'Program.Failed'):" + python_newline()
    + "        return 'Failed'" + python_newline()
    + "    if type_name in ('/capy/lang/Option.Some', 'Option.Some'):" + python_newline()
    + "        return 'Some'" + python_newline()
    + "    if type_name in ('/capy/lang/Option.None', 'Option.None'):" + python_newline()
    + "        return 'None'" + python_newline()
    + "    if type_name in ('/capy/lang/Result.Success', 'Result.Success'):" + python_newline()
    + "        return 'Success'" + python_newline()
    + "    if type_name in ('/capy/lang/Result.Error', 'Result.Error'):" + python_newline()
    + "        return 'Error'" + python_newline()
    + "    if type_name.startswith('__capy_raw|'):" + python_newline()
    + "        return '__capy_raw|' + __capy_normalize_type_name(type_name[len('__capy_raw|'):])" + python_newline()
    + "    if '/' in type_name:" + python_newline()
    + "        type_name = type_name.rsplit('/', 1)[1]" + python_newline()
    + "    if '.' in type_name:" + python_newline()
    + "        type_name = type_name.rsplit('.', 1)[1]" + python_newline()
    + "    return type_name" + python_newline()
    + python_newline()
    + "def __capy_data_fields(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        result = dict()" + python_newline()
    + "        for key, field in value.items():" + python_newline()
    + "            if key != '__type':" + python_newline()
    + "                result[key] = field" + python_newline()
    + "        return result" + python_newline()
    + "    if hasattr(value, '__dict__'):" + python_newline()
    + "        return dict(value.__dict__)" + python_newline()
    + "    try:" + python_newline()
    + "        return dict(value)" + python_newline()
    + "    except (TypeError, ValueError):" + python_newline()
    + "        return dict()" + python_newline()
    + python_newline()
    + "def __capy_data(type_name, fields):" + python_newline()
    + "    expanded = dict()" + python_newline()
    + "    for key, value in dict(fields or dict()).items():" + python_newline()
    + "        if key == '':" + python_newline()
    + "            expanded.update(__capy_data_fields(value))" + python_newline()
    + "        else:" + python_newline()
    + "            expanded[key] = value" + python_newline()
    + "    result = dict(expanded)" + python_newline()
    + "    result['__type'] = __capy_normalize_type_name(type_name)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_with(value, updates):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        result = dict(value)" + python_newline()
    + "        for key, field_value in updates.items():" + python_newline()
    + "            if key != '__type':" + python_newline()
    + "                result[key] = field_value" + python_newline()
    + "        return result" + python_newline()
    + "    result = value" + python_newline()
    + "    for key, field_value in updates.items():" + python_newline()
    + "        if key != '__type':" + python_newline()
    + "            setattr(result, key, field_value)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_constructor_value(type_name, value):" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        return value" + python_newline()
    + "    return __capy_data(type_name, dict(value=value))" + python_newline()
    + python_newline()
    + "def __capy_constructor_result(type_name, value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return __capy_data('Success', dict(value=__capy_constructor_value(type_name, _capy_data_value(value))))" + python_newline()
    + "    return __capy_constructor_value(type_name, value)" + python_newline()
    + python_newline()
    + "def __capy_primitive_constructor_result(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return __capy_data('Success', dict(value=_capy_data_value(value)))" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def __capy_merge_data(target, source):" + python_newline()
    + "    result = dict(target) if isinstance(target, dict) else __capy_data('', dict())" + python_newline()
    + "    if isinstance(source, dict):" + python_newline()
    + "        for key, value in source.items():" + python_newline()
    + "            if key != '__type':" + python_newline()
    + "                result[key] = value" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_constructor_pipeline(data, steps, returns_result):" + python_newline()
    + "    current = data" + python_newline()
    + "    for step_type, merge, step in steps:" + python_newline()
    + "        result = _unsafe_run(step(current))" + python_newline()
    + "        if _capy_data_is(result, 'Error'):" + python_newline()
    + "            return result" + python_newline()
    + "        if _capy_data_is(result, 'Success'):" + python_newline()
    + "            constructed = __capy_constructor_value(step_type, _capy_data_value(result))" + python_newline()
    + "        else:" + python_newline()
    + "            constructed = __capy_constructor_value(step_type, result)" + python_newline()
    + "        current = __capy_merge_data(current, constructed) if merge else constructed" + python_newline()
    + "    if returns_result:" + python_newline()
    + "        return __capy_data('Success', dict(value=current))" + python_newline()
    + "    return current" + python_newline()
    + python_newline()

private fun python_test_runtime_effect_helpers_code(): String =
    "DEFAULT_FAILED_EXIT_CODE = __capy_data('/capy/lang/Program.ExitCode', dict(value=1))" + python_newline()
    + python_newline()
    + "def _unsafe_run(value):" + python_newline()
    + "    while hasattr(value, 'unsafe_run') and callable(value.unsafe_run):" + python_newline()
    + "        value = value.unsafe_run()" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def __capy_bind_value(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Success', 'Some'):" + python_newline()
    + "        return _capy_data_value(value)" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def _as_list(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if value is None:" + python_newline()
    + "        return []" + python_newline()
    + "    if isinstance(value, list):" + python_newline()
    + "        return value" + python_newline()
    + "    return [value]" + python_newline()
    + python_newline()
    + "def _gather_module(module_name):" + python_newline()
    + "    module = importlib.import_module(module_name)" + python_newline()
    + "    tests = getattr(module, 'tests', None)" + python_newline()
    + "    if not callable(tests):" + python_newline()
    + "        return []" + python_newline()
    + "    return _as_list(tests())" + python_newline()
    + python_newline()

private fun python_test_runtime_gather_code(modules: List[CompiledModule]): String =
    "def gatherTests():" + python_newline()
    + "    files = []" + python_newline()
    + python_test_gather_calls(modules, modules)
    + "    return files" + python_newline()

private fun python_value_assert_extra_methods_code(): String =
    "    def is_empty(self):" + python_newline()
    + "        if _capy_data_is(self.value, 'None'):" + python_newline()
    + "            result = True" + python_newline()
    + "        else:" + python_newline()
    + "            try:" + python_newline()
    + "                result = len(self.value) == 0" + python_newline()
    + "            except TypeError:" + python_newline()
    + "                result = False" + python_newline()
    + "        return self._append(result, 'Expected ' + repr(self.value) + ' to be empty', 'Assert.is_empty')" + python_newline()
    + python_newline()
    + "    def is_zero(self):" + python_newline()
    + "        return self._append(self.value == 0, 'Expected ' + repr(self.value) + ' to be zero', 'Assert.is_zero')" + python_newline()
    + python_newline()
    + "    def is_one(self):" + python_newline()
    + "        return self._append(self.value == 1, 'Expected ' + repr(self.value) + ' to be one', 'Assert.is_one')" + python_newline()
    + python_newline()
    + "    def has_size(self, expected):" + python_newline()
    + "        actual = globals()['__capy_size'](self.value)" + python_newline()
    + "        return self._append(actual == expected, 'Expected ' + repr(self.value) + ' to have size ' + repr(expected), 'Assert.has_size')" + python_newline()
    + python_newline()
    + "    def contains(self, other):" + python_newline()
    + "        if _capy_data_is(self.value, 'Some'):" + python_newline()
    + "            result = globals()['__capy_deep_equal'](_capy_data_value(self.value), other)" + python_newline()
    + "        else:" + python_newline()
    + "            result = globals()['__capy_contains'](self.value, other)" + python_newline()
    + "        return self._append(result, 'Expected ' + repr(self.value) + ' to contain ' + repr(other), 'Assert.contains')" + python_newline()
    + python_newline()
    + "    def starts_with(self, other):" + python_newline()
    + "        result = str(self.value).startswith(str(other))" + python_newline()
    + "        return self._append(result, 'Expected ' + repr(self.value) + ' to start with ' + repr(other), 'Assert.starts_with')" + python_newline()
    + python_newline()
    + "    def does_not_start_with(self, other):" + python_newline()
    + "        result = not str(self.value).startswith(str(other))" + python_newline()
    + "        return self._append(result, 'Expected ' + repr(self.value) + ' not to start with ' + repr(other), 'Assert.does_not_start_with')" + python_newline()
    + python_newline()
    + "    def succeeds(self, expected=None):" + python_newline()
    + "        if not _capy_data_is(self.value, 'Success'):" + python_newline()
    + "            return self._append(False, 'Expected ' + repr(self.value) + ' to succeed', 'Assert.succeeds')" + python_newline()
    + "        success_value = _capy_data_value(self.value)" + python_newline()
    + "        if callable(expected):" + python_newline()
    + "            assertion = expected(success_value)" + python_newline()
    + "            return ValueAssert(self.value, self.assertions + getattr(assertion, 'assertions', []))" + python_newline()
    + "        if expected is None:" + python_newline()
    + "            return self._append(True, 'Expected ' + repr(self.value) + ' to succeed', 'Assert.succeeds')" + python_newline()
    + "        return self._append(globals()['__capy_deep_equal'](success_value, expected), 'Expected ' + repr(self.value) + ' to succeed with ' + repr(expected), 'Assert.succeeds')" + python_newline()
    + python_newline()
    + "    def fails(self, expected=None):" + python_newline()
    + "        if not _capy_data_is(self.value, 'Error'):" + python_newline()
    + "            return self._append(False, 'Expected ' + repr(self.value) + ' to fail', 'Assert.fails')" + python_newline()
    + "        error_value = _capy_data_value(self.value)" + python_newline()
    + "        if expected is None:" + python_newline()
    + "            return self._append(True, 'Expected ' + repr(self.value) + ' to fail', 'Assert.fails')" + python_newline()
    + "        return self._append(globals()['__capy_deep_equal'](error_value, expected), 'Expected ' + repr(self.value) + ' to fail with ' + repr(expected), 'Assert.fails')" + python_newline()
    + python_newline()

private fun python_runtime_data_helpers_code(): String =
    "def _capy_data_is(value, *type_names):" + python_newline()
    + "    if not isinstance(value, dict):" + python_newline()
    + "        return False" + python_newline()
    + "    actual = __capy_normalize_type_name(value.get('__type'))" + python_newline()
    + "    return any(actual == __capy_normalize_type_name(type_name) for type_name in type_names)" + python_newline()
    + python_newline()
    + "def _capy_data_value(value):" + python_newline()
    + "    if not isinstance(value, dict):" + python_newline()
    + "        return value" + python_newline()
    + "    if 'value' in value:" + python_newline()
    + "        return value['value']" + python_newline()
    + "    if '$0' in value:" + python_newline()
    + "        return value['$0']" + python_newline()
    + "    fields = [key for key in value.keys() if key != '__type']" + python_newline()
    + "    if fields:" + python_newline()
    + "        return value[fields[0]]" + python_newline()
    + "    return value" + python_newline()
    + python_newline()

