private fun python_test_runtime_capy_set_class_code(): String =
    "class CapySet:" + python_newline()
    + "    def __init__(self, values=None):" + python_newline()
    + "        self._values = []" + python_newline()
    + "        if values is not None:" + python_newline()
    + "            for value in values:" + python_newline()
    + "                self.add(value)" + python_newline()
    + python_newline()
    + "    def __iter__(self):" + python_newline()
    + "        return iter(self._values)" + python_newline()
    + python_newline()
    + "    def __len__(self):" + python_newline()
    + "        return len(self._values)" + python_newline()
    + python_newline()
    + "    def __contains__(self, value):" + python_newline()
    + "        return any(globals()['__capy_deep_equal'](item, value) for item in self._values)" + python_newline()
    + python_newline()
    + "    def __eq__(self, other):" + python_newline()
    + "        return globals()['__capy_set_equal'](self, other)" + python_newline()
    + python_newline()
    + "    def __repr__(self):" + python_newline()
    + "        if not self._values:" + python_newline()
    + "            return 'set()'" + python_newline()
    + "        return chr(123) + ', '.join(repr(value) for value in self._values) + chr(125)" + python_newline()
    + python_newline()
    + "    def add(self, value):" + python_newline()
    + "        if value not in self:" + python_newline()
    + "            self._values.append(value)" + python_newline()
    + "        return self" + python_newline()
    + python_newline()
    + "    def discard(self, value):" + python_newline()
    + "        self._values = [item for item in self._values if not globals()['__capy_deep_equal'](item, value)]" + python_newline()
    + "        return self" + python_newline()
    + python_newline()
    + "    def update(self, values):" + python_newline()
    + "        for value in globals()['__capy_set_values'](values):" + python_newline()
    + "            self.add(value)" + python_newline()
    + "        return self" + python_newline()
    + python_newline()
    + "    def copy(self):" + python_newline()
    + "        return CapySet(self._values)" + python_newline()
    + python_newline()
    + "    def contains(self, value):" + python_newline()
    + "        return value in self" + python_newline()
    + python_newline()
    + "    def size(self):" + python_newline()
    + "        return len(self)" + python_newline()
    + python_newline()
    + "    def is_empty(self):" + python_newline()
    + "        return len(self) == 0" + python_newline()
    + python_newline()
    + "    def to_list(self):" + python_newline()
    + "        return list(self._values)" + python_newline()
    + python_newline()
    + "    def union(self, other):" + python_newline()
    + "        return globals()['__capy_set_concat'](self, other)" + python_newline()
    + python_newline()
    + "    def intersection(self, other):" + python_newline()
    + "        return globals()['__capy_set_intersection'](self, other)" + python_newline()
    + python_newline()
    + "    def difference(self, other):" + python_newline()
    + "        return globals()['__capy_set_remove_all'](self, other)" + python_newline()
    + python_newline()
    + "    def symmetric_difference(self, other):" + python_newline()
    + "        return globals()['__capy_set_symmetric_difference'](self, other)" + python_newline()
    + python_newline()
    + "    def cartesian_product(self, other):" + python_newline()
    + "        return globals()['__capy_set_cartesian_product'](self, other)" + python_newline()
    + python_newline()
    + "    def power_set(self):" + python_newline()
    + "        return globals()['__capy_set_power_set'](self)" + python_newline()
    + python_newline()
    + "    def _(self):" + python_newline()
    + "        return self.power_set()" + python_newline()
    + python_newline()
    + "    def is_subset_of(self, other):" + python_newline()
    + "        return globals()['__capy_set_subset'](self, other)" + python_newline()
    + python_newline()
    + "    def is_proper_subset_of(self, other):" + python_newline()
    + "        return globals()['__capy_set_proper_subset'](self, other)" + python_newline()
    + python_newline()
    + "    def is_superset_of(self, other):" + python_newline()
    + "        return globals()['__capy_set_subset'](other, self)" + python_newline()
    + python_newline()
    + "    def is_proper_superset_of(self, other):" + python_newline()
    + "        return globals()['__capy_set_proper_subset'](other, self)" + python_newline()
    + python_newline()

private fun python_test_runtime_set_helpers_code(): String =
    "def __capy_is_set(value):" + python_newline()
    + "    return isinstance(value, (CapySet, set))" + python_newline()
    + python_newline()
    + "def __capy_set_values(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, CapySet):" + python_newline()
    + "        return list(value._values)" + python_newline()
    + "    return list(value)" + python_newline()
    + python_newline()
    + "def __capy_set(values):" + python_newline()
    + "    return CapySet(values)" + python_newline()
    + python_newline()
    + "def __capy_set_equal(left, right):" + python_newline()
    + "    if not (__capy_is_set(left) and __capy_is_set(right)):" + python_newline()
    + "        return False" + python_newline()
    + "    return len(left) == len(right) and __capy_set_subset(left, right)" + python_newline()
    + python_newline()
    + "def __capy_deep_equal(left, right):" + python_newline()
    + "    if left is right:" + python_newline()
    + "        return True" + python_newline()
    + "    if __capy_is_set(left) or __capy_is_set(right):" + python_newline()
    + "        return __capy_set_equal(left, right)" + python_newline()
    + "    if isinstance(left, (list, tuple)) and isinstance(right, (list, tuple)):" + python_newline()
    + "        return len(left) == len(right) and all(__capy_deep_equal(a, b) for a, b in zip(left, right))" + python_newline()
    + "    if isinstance(left, dict) and isinstance(right, dict):" + python_newline()
    + "        if set(left.keys()) != set(right.keys()):" + python_newline()
    + "            return False" + python_newline()
    + "        return all(__capy_deep_equal(left[key], right[key]) for key in left.keys())" + python_newline()
    + "    try:" + python_newline()
    + "        return left == right" + python_newline()
    + "    except Exception:" + python_newline()
    + "        return False" + python_newline()
    + python_newline()
    + "def __capy_set_append(values, value):" + python_newline()
    + "    return __capy_set(values).add(value)" + python_newline()
    + python_newline()
    + "def __capy_set_concat(left, right):" + python_newline()
    + "    result = __capy_set(left)" + python_newline()
    + "    result.update(right)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_set_remove(values, value):" + python_newline()
    + "    return __capy_set(values).discard(value)" + python_newline()
    + python_newline()
    + "def __capy_set_remove_all(left, right):" + python_newline()
    + "    result = __capy_set([])" + python_newline()
    + "    for value in __capy_set_values(left):" + python_newline()
    + "        if not __capy_contains(right, value):" + python_newline()
    + "            result.add(value)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_set_subset(left, right):" + python_newline()
    + "    return all(__capy_contains(right, value) for value in __capy_set_values(left))" + python_newline()
    + python_newline()
    + "def __capy_set_proper_subset(left, right):" + python_newline()
    + "    return len(left) < len(right) and __capy_set_subset(left, right)" + python_newline()
    + python_newline()
    + "def __capy_set_intersection(left, right):" + python_newline()
    + "    result = __capy_set([])" + python_newline()
    + "    for value in __capy_set_values(left):" + python_newline()
    + "        if __capy_contains(right, value):" + python_newline()
    + "            result.add(value)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_set_symmetric_difference(left, right):" + python_newline()
    + "    result = __capy_set_remove_all(left, right)" + python_newline()
    + "    for value in __capy_set_values(right):" + python_newline()
    + "        if not __capy_contains(left, value):" + python_newline()
    + "            result.add(value)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_set_cartesian_product(left, right):" + python_newline()
    + "    result = __capy_set([])" + python_newline()
    + "    for left_value in __capy_set_values(left):" + python_newline()
    + "        for right_value in __capy_set_values(right):" + python_newline()
    + "            result.add((left_value, right_value))" + python_newline()
    + "    return result" + python_newline()
    + python_newline()
    + "def __capy_set_power_set(values):" + python_newline()
    + "    result = __capy_set([__capy_set([])])" + python_newline()
    + "    for value in __capy_set_values(values):" + python_newline()
    + "        additions = __capy_set([])" + python_newline()
    + "        for subset in list(result):" + python_newline()
    + "            additions.add(__capy_set_append(subset, value))" + python_newline()
    + "        result = __capy_set_concat(result, additions)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()

private fun python_test_runtime_collection_string_helpers_code(): String =
    "def __capy_contains(left, right):" + python_newline()
    + "    left = _unsafe_run(left)" + python_newline()
    + "    if __capy_is_set(left):" + python_newline()
    + "        return any(__capy_deep_equal(item, right) for item in __capy_set_values(left))" + python_newline()
    + "    if isinstance(left, (list, tuple)):" + python_newline()
    + "        return any(__capy_deep_equal(item, right) for item in left)" + python_newline()
    + "    return right in left" + python_newline()
    + python_newline()
    + "def __capy_size(value):" + python_newline()
    + "    return len(value)" + python_newline()
    + python_newline()
    + "def __capy_is_empty(value):" + python_newline()
    + "    return len(value) == 0" + python_newline()
    + python_newline()
    + "def __capy_string_trim(value):" + python_newline()
    + "    return str(value).strip()" + python_newline()
    + python_newline()
    + "def __capy_string_replace(value, old, new):" + python_newline()
    + "    return str(value).replace(str(old), str(new))" + python_newline()
    + python_newline()
    + "def __capy_string_starts_with(value, prefix):" + python_newline()
    + "    return str(value).startswith(str(prefix))" + python_newline()
    + python_newline()
    + "def __capy_string_end_with(value, suffix):" + python_newline()
    + "    return str(value).endswith(str(suffix))" + python_newline()
    + python_newline()
    + "def __capy_string_get(value, index):" + python_newline()
    + "    text = str(value)" + python_newline()
    + "    idx = int(index)" + python_newline()
    + "    if idx < 0:" + python_newline()
    + "        idx = len(text) + idx" + python_newline()
    + "    if idx < 0 or idx >= len(text):" + python_newline()
    + "        return __capy_none()" + python_newline()
    + "    return __capy_some(text[idx])" + python_newline()
    + python_newline()
    + "def __capy_string_slice(value, start, end):" + python_newline()
    + "    return str(value)[int(start):int(end)]" + python_newline()
    + python_newline()

private fun python_test_runtime_regex_helpers_code(): String =
    "def __capy_regex_pattern(regex):" + python_newline()
    + "    regex = _unsafe_run(regex)" + python_newline()
    + "    if isinstance(regex, dict):" + python_newline()
    + "        return str(regex.get('pattern', ''))" + python_newline()
    + "    return str(regex)" + python_newline()
    + python_newline()
    + "def __capy_regex_flags(regex):" + python_newline()
    + "    regex = _unsafe_run(regex)" + python_newline()
    + "    if isinstance(regex, dict):" + python_newline()
    + "        return str(regex.get('flags', ''))" + python_newline()
    + "    return ''" + python_newline()
    + python_newline()
    + "def __capy_regex_compile(regex):" + python_newline()
    + "    flags_value = __capy_regex_flags(regex)" + python_newline()
    + "    flags = 0" + python_newline()
    + "    if 'i' in flags_value:" + python_newline()
    + "        flags |= re.IGNORECASE" + python_newline()
    + "    if 'm' in flags_value:" + python_newline()
    + "        flags |= re.MULTILINE" + python_newline()
    + "    if 's' in flags_value:" + python_newline()
    + "        flags |= re.DOTALL" + python_newline()
    + "    return re.compile(__capy_regex_pattern(regex), flags)" + python_newline()
    + python_newline()
    + "def __capy_regex_matches(regex, input):" + python_newline()
    + "    return __capy_regex_compile(regex).search(str(_unsafe_run(input))) is not None" + python_newline()
    + python_newline()
    + "def __capy_regex_find(regex, input):" + python_newline()
    + "    match = __capy_regex_compile(regex).search(str(_unsafe_run(input)))" + python_newline()
    + "    if match is None:" + python_newline()
    + "        return __capy_none()" + python_newline()
    + "    return __capy_some(__capy_data('Match', dict(group_value=match.group(0))))" + python_newline()
    + python_newline()
    + "def __capy_regex_find_all(regex, input):" + python_newline()
    + "    return [__capy_data('Match', dict(group_value=match.group(0))) for match in __capy_regex_compile(regex).finditer(str(_unsafe_run(input)))]" + python_newline()
    + python_newline()
    + "def __capy_regex_replace(regex, replacement, input=None):" + python_newline()
    + "    if input is None:" + python_newline()
    + "        return lambda value: __capy_regex_replace(regex, replacement, value)" + python_newline()
    + "    replacement_value = str(_unsafe_run(replacement))" + python_newline()
    + "    return __capy_regex_compile(regex).sub(lambda _: replacement_value, str(_unsafe_run(input)))" + python_newline()
    + python_newline()
    + "def __capy_regex_split(regex, input):" + python_newline()
    + "    return __capy_regex_compile(regex).split(str(_unsafe_run(input)))" + python_newline()
    + python_newline()

private fun python_test_runtime_iterable_helpers_code(): String =
    "def __capy_as_iterable(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if value is None:" + python_newline()
    + "        return []" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        if value.get('__type') == 'End':" + python_newline()
    + "            return []" + python_newline()
    + "        if value.get('__type') == 'Cons':" + python_newline()
    + "            return __capy_seq_iter(value)" + python_newline()
    + "        if '__type' not in value:" + python_newline()
    + "            return value.items()" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def __capy_as_list(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, list):" + python_newline()
    + "        return value" + python_newline()
    + "    return list(__capy_as_iterable(value))" + python_newline()
    + python_newline()
    + "def to_seq(value):" + python_newline()
    + "    return __capy_as_list(value)" + python_newline()
    + python_newline()
    + "def __capy_seq_iter(seq):" + python_newline()
    + "    while isinstance(seq, dict) and seq.get('__type') == 'Cons':" + python_newline()
    + "        yield __capy_match_binding(seq, 'value', 0)" + python_newline()
    + "        rest = __capy_match_binding(seq, 'rest', 1)" + python_newline()
    + "        seq = _unsafe_run(rest() if callable(rest) else rest)" + python_newline()
    + python_newline()

private fun python_test_runtime_sequence_helpers_code(): String =
    "def __capy_lambda_arity(fn):" + python_newline()
    + "    try:" + python_newline()
    + "        parameters = inspect.signature(fn).parameters.values()" + python_newline()
    + "        return len([param for param in parameters if param.kind in (param.POSITIONAL_ONLY, param.POSITIONAL_OR_KEYWORD)])" + python_newline()
    + "    except (TypeError, ValueError):" + python_newline()
    + "        return 1" + python_newline()
    + python_newline()
    + "def __capy_apply_lambda(fn, item):" + python_newline()
    + "    arity = __capy_lambda_arity(fn)" + python_newline()
    + "    if arity == 0:" + python_newline()
    + "        return fn()" + python_newline()
    + "    if arity > 1 and isinstance(item, (list, tuple)):" + python_newline()
    + "        return fn(*item)" + python_newline()
    + "    return fn(item)" + python_newline()
    + python_newline()
    + "def __capy_seq_map(value, mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict) and '__type' not in value:" + python_newline()
    + "        return dict((key, __capy_apply_lambda(mapper, (key, item))) for key, item in value.items())" + python_newline()
    + "    return [__capy_apply_lambda(mapper, item) for item in __capy_as_iterable(value)]" + python_newline()
    + python_newline()
    + "def __capy_seq_filter(value, predicate):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict) and '__type' not in value:" + python_newline()
    + "        return dict((key, item) for key, item in value.items() if __capy_apply_lambda(predicate, (key, item)))" + python_newline()
    + "    return [item for item in __capy_as_iterable(value) if __capy_apply_lambda(predicate, item)]" + python_newline()
    + python_newline()
    + "def __capy_seq_reject(value, predicate):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict) and '__type' not in value:" + python_newline()
    + "        return dict((key, item) for key, item in value.items() if not __capy_apply_lambda(predicate, (key, item)))" + python_newline()
    + "    return [item for item in __capy_as_iterable(value) if not __capy_apply_lambda(predicate, item)]" + python_newline()
    + python_newline()
    + "def __capy_seq_flat_map(value, mapper):" + python_newline()
    + "    result = []" + python_newline()
    + "    for item in __capy_as_iterable(value):" + python_newline()
    + "        mapped = _unsafe_run(__capy_apply_lambda(mapper, item))" + python_newline()
    + "        if mapped is None:" + python_newline()
    + "            continue" + python_newline()
    + "        if __capy_is_set(mapped):" + python_newline()
    + "            result.extend(__capy_set_values(mapped))" + python_newline()
    + "        else:" + python_newline()
    + "            result.extend(mapped if isinstance(mapped, (list, tuple)) else [mapped])" + python_newline()
    + "    return result" + python_newline()
    + python_newline()

private fun python_test_runtime_option_helpers_code(): String =
    "def __capy_option_map(value, mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'None'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Some'):" + python_newline()
    + "        return __capy_data('Some', dict(value=_unsafe_run(__capy_apply_lambda(mapper, _capy_data_value(value)))))" + python_newline()
    + "    return __capy_unsupported('option map')" + python_newline()
    + python_newline()
    + "def __capy_option_filter(value, predicate):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'None'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Some'):" + python_newline()
    + "        inner = _capy_data_value(value)" + python_newline()
    + "        return __capy_data('None', dict()) if _unsafe_run(__capy_apply_lambda(predicate, inner)) else value" + python_newline()
    + "    return __capy_unsupported('option filter')" + python_newline()
    + python_newline()
    + "def __capy_option_flat_map(value, mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'None'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Some'):" + python_newline()
    + "        mapped = _unsafe_run(__capy_apply_lambda(mapper, _capy_data_value(value)))" + python_newline()
    + "        if _capy_data_is(mapped, 'Some', 'None'):" + python_newline()
    + "            return mapped" + python_newline()
    + "        return __capy_data('Some', dict(value=mapped))" + python_newline()
    + "    return __capy_unsupported('option flat_map')" + python_newline()
    + python_newline()
    + "def __capy_option_reduce(value, initial, reducer):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'None'):" + python_newline()
    + "        return initial" + python_newline()
    + "    if _capy_data_is(value, 'Some'):" + python_newline()
    + "        return _unsafe_run(reducer(initial, _capy_data_value(value)))" + python_newline()
    + "    return __capy_unsupported('option reduce')" + python_newline()
    + python_newline()

private fun python_test_runtime_result_helpers_code(): String =
    "def __capy_result_map(value, mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return _unsafe_run(mapper(_capy_data_value(value)))" + python_newline()
    + "    return __capy_unsupported('result map')" + python_newline()
    + python_newline()
    + "def __capy_result_flat_map(value, mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        mapped = _unsafe_run(mapper(_capy_data_value(value)))" + python_newline()
    + "        if _capy_data_is(mapped, 'Error'):" + python_newline()
    + "            return mapped" + python_newline()
    + "        if _capy_data_is(mapped, 'Success'):" + python_newline()
    + "            return _capy_data_value(mapped)" + python_newline()
    + "    return __capy_unsupported('result flat_map')" + python_newline()
    + python_newline()
    + "def __capy_result_or(value, fallback):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return value" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return _unsafe_run(fallback)" + python_newline()
    + "    return __capy_unsupported('result or')" + python_newline()
    + python_newline()
    + "def __capy_result_or_else(value, fallback):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return _capy_data_value(value)" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return _unsafe_run(fallback)" + python_newline()
    + "    return __capy_unsupported('result or_else')" + python_newline()
    + python_newline()
    + "def __capy_result_reduce(value, success_mapper, error_mapper):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if _capy_data_is(value, 'Success'):" + python_newline()
    + "        return _unsafe_run(success_mapper(_capy_data_value(value)))" + python_newline()
    + "    if _capy_data_is(value, 'Error'):" + python_newline()
    + "        return _unsafe_run(error_mapper(_capy_data_value(value)))" + python_newline()
    + "    return __capy_unsupported('result reduce')" + python_newline()
    + python_newline()

private fun python_test_runtime_lambda_predicate_code(): String =
    "def __capy_any(value, predicate):" + python_newline()
    + "    return any(__capy_apply_lambda(predicate, item) for item in __capy_as_iterable_for_lambda(value, predicate))" + python_newline()
    + python_newline()
    + "def __capy_all(value, predicate):" + python_newline()
    + "    return all(__capy_apply_lambda(predicate, item) for item in __capy_as_iterable_for_lambda(value, predicate))" + python_newline()
    + python_newline()
    + "def __capy_as_iterable_for_lambda(value, fn):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, str) and __capy_lambda_arity(fn) > 1:" + python_newline()
    + "        return ((char, idx) for idx, char in enumerate(value))" + python_newline()
    + "    return __capy_as_iterable(value)" + python_newline()
    + python_newline()

private fun python_test_runtime_lookup_helpers_code(): String =
    "def __capy_index(value, index):" + python_newline()
    + "    try:" + python_newline()
    + "        if isinstance(value, tuple):" + python_newline()
    + "            return value[index]" + python_newline()
    + "        if isinstance(value, dict):" + python_newline()
    + "            if index in value:" + python_newline()
    + "                return __capy_some(value[index])" + python_newline()
    + "            return __capy_none()" + python_newline()
    + "        return __capy_some(value[index])" + python_newline()
    + "    except (IndexError, KeyError):" + python_newline()
    + "        return __capy_none()" + python_newline()
    + python_newline()
    + "def __capy_get_field(value, name):" + python_newline()
    + "    if name == 'value' and isinstance(value, (int, float)) and not isinstance(value, bool):" + python_newline()
    + "        return value" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        return value[name]" + python_newline()
    + "    return getattr(value, name)" + python_newline()
    + python_newline()
    + "def __capy_reduce(value, initial, keyed, reducer):" + python_newline()
    + "    result = initial" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        for key, item in value.items():" + python_newline()
    + "            result = reducer(result, key, item) if keyed else reducer(result, item)" + python_newline()
    + "        return result" + python_newline()
    + "    for item in value:" + python_newline()
    + "        result = reducer(result, item)" + python_newline()
    + "    return result" + python_newline()
    + python_newline()

private fun python_test_runtime_type_match_helpers_code(): String =
    "def __capy_type_matches(value, type_name):" + python_newline()
    + "    if type_name == 'String':" + python_newline()
    + "        return isinstance(value, str)" + python_newline()
    + "    if type_name == 'char':" + python_newline()
    + "        return isinstance(value, str) and len(value) == 1" + python_newline()
    + "    if type_name == 'bool':" + python_newline()
    + "        return isinstance(value, bool)" + python_newline()
    + "    if type_name in ('byte', 'int', 'long'):" + python_newline()
    + "        return isinstance(value, int) and not isinstance(value, bool)" + python_newline()
    + "    if type_name in ('float', 'double'):" + python_newline()
    + "        return isinstance(value, float)" + python_newline()
    + "    if type_name == 'List':" + python_newline()
    + "        return isinstance(value, list)" + python_newline()
    + "    if type_name == 'Set':" + python_newline()
    + "        return __capy_is_set(value)" + python_newline()
    + "    if type_name == 'Dict':" + python_newline()
    + "        return isinstance(value, dict) and '__type' not in value" + python_newline()
    + "    if not isinstance(value, dict):" + python_newline()
    + "        return False" + python_newline()
    + "    actual = __capy_normalize_type_name(value.get('__type'))" + python_newline()
    + "    expected = __capy_normalize_type_name(type_name)" + python_newline()
    + "    if expected == 'data':" + python_newline()
    + "        return bool(actual) and actual not in ('Some', 'None', 'Success', 'Error', 'Failed')" + python_newline()
    + "    if expected == 'enum':" + python_newline()
    + "        return __capy_enum_is(value)" + python_newline()
    + "    if expected == 'Option':" + python_newline()
    + "        return actual in ('Some', 'None')" + python_newline()
    + "    return actual == expected or actual == '__capy_raw|' + expected" + python_newline()
    + python_newline()

private fun python_test_runtime_pattern_helpers_code(): String =
    "def __capy_match_binding(value, name, index):" + python_newline()
    + "    if not isinstance(value, dict):" + python_newline()
    + "        return getattr(value, name)" + python_newline()
    + "    if name in value:" + python_newline()
    + "        return value[name]" + python_newline()
    + "    positional = '$' + str(index)" + python_newline()
    + "    if positional in value:" + python_newline()
    + "        return value[positional]" + python_newline()
    + "    fields = [key for key in value.keys() if key != '__type']" + python_newline()
    + "    if index < len(fields):" + python_newline()
    + "        return value[fields[index]]" + python_newline()
    + "    return value[name]" + python_newline()
    + python_newline()
    + "def __capy_no_match(value):" + python_newline()
    + "    raise ValueError('No Capybara match case for ' + repr(value))" + python_newline()
    + python_newline()
    + "def __capy_some(value):" + python_newline()
    + "    return __capy_data('Some', dict(value=value))" + python_newline()
    + python_newline()
    + "def __capy_none():" + python_newline()
    + "    return __capy_data('None', dict())" + python_newline()
    + python_newline()

private fun python_test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        python_test_gather_calls_for_module(module.functions, module, allModules)
            + python_test_gather_calls(modules[1:], allModules)

private fun python_test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        python_test_gather_call_for_function(function, module, allModules)
            + python_test_gather_calls_for_module(functions[1:], module, allModules)

private fun python_test_gather_call_for_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function.name == "tests"
    then if python_test_function_gatherable(function)
        then if python_module_gatherable(module, allModules)
            then "    files.extend(_gather_module(" + python_string_literal(python_module_import_name(module)) + "))" + python_newline()
            else ""
        else ""
    else ""

private fun python_module_gatherable(module: CompiledModule, allModules: List[CompiledModule]): bool =
    !python_module_has_primitive_backed_type(module.functions)
        & python_module_imports_gatherable(module.imports, module, allModules)
        & python_module_functions_gatherable(module.functions, module, allModules)

private fun python_module_imports_gatherable(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> true
    case Some { declaration } ->
        if python_stdlib_import(declaration.modulePath)
        then python_module_imports_gatherable(imports[1:], module, allModules)
        else match python_find_imported_module(declaration, module, allModules) with
            case Some { importedModule } ->
                !python_module_has_primitive_backed_type(importedModule.functions)
                    & python_module_functions_gatherable(importedModule.functions, importedModule, allModules)
                    & python_module_imports_gatherable(imports[1:], module, allModules)
            case None -> false

private fun python_module_has_primitive_backed_type(functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        (python_compiled_schema(function) & python_string_has_prefix(function.name, "__capy_schema_primitive|"))
            | python_module_has_primitive_backed_type(functions[1:])

private fun python_module_functions_gatherable(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match functions[0] with
    case None -> true
    case Some { function } ->
        python_function_gatherable(function, module, allModules)
            & python_module_functions_gatherable(functions[1:], module, allModules)

private fun python_function_gatherable(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if python_imported_function(function)
    then true
    else if python_compiled_schema(function)
    then true
    else if python_compiled_object_helper_function(function)
    then true
    else python_expression_gatherable(function.body, python_function_bindings(function), module, allModules)

private fun python_expression_gatherable(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> python_compiled_placeholder_source(unsupported.source)
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression _ -> true
    case CompiledIfExpression ifExpression ->
        python_expression_gatherable(ifExpression.condition, env, module, allModules)
            & python_expression_gatherable(ifExpression.thenBranch, env, module, allModules)
            & python_expression_gatherable(ifExpression.elseBranch, env, module, allModules)
    case CompiledBinaryExpression binary -> python_binary_expression_gatherable(binary, env, module, allModules)
    case CompiledUnaryExpression unary ->
        python_unary_operator_gatherable(unary.operator)
            & python_expression_gatherable(unary.expression, env, module, allModules)
    case CompiledFunctionCallExpression call ->
        python_function_call_gatherable(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> python_function_reference_gatherable(reference, module, allModules)
    case CompiledMethodCallExpression call ->
        python_method_call_gatherable(call, env, module, allModules)
    case CompiledWithExpression withExpression ->
        python_expression_gatherable(withExpression.receiver, env, module, allModules)
            & python_data_fields_gatherable(withExpression.fields, env, module, allModules)
    case CompiledLambdaExpression lambda ->
        python_expression_gatherable(lambda.body, python_lambda_bindings(lambda.parameters) + env, module, allModules)
    case CompiledListLiteral literal -> python_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledSetLiteral literal -> python_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledDictLiteral literal -> python_dict_entries_gatherable(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> python_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledIndexExpression index -> python_index_expression_gatherable(index, env, module, allModules)
    case CompiledDataLiteral literal -> python_data_fields_gatherable(literal.fields, env, module, allModules)
    case CompiledFieldAccessExpression access -> python_enum_static_field_access(access, env, module, allModules) | python_expression_gatherable(access.receiver, env, module, allModules)
    case CompiledReduceExpression reduce -> python_reduce_expression_gatherable(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> python_match_expression_gatherable(matchExpression, env, module, allModules)
    case CompiledBlockExpression block ->
        python_bindings_gatherable(block.bindings, env, module, allModules)
            & python_expression_gatherable(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)

private fun python_binary_operator_gatherable(operator: String): bool =
    python_binary_runtime_operator(operator)
        | python_comparison_operator(operator)
        | python_bool_binary_operator(operator)
        | python_bitwise_binary_operator(operator)
        | operator == ".nand."

private fun python_binary_expression_gatherable(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = python_expression_type(binary.left, env, module, allModules)
    if python_result_reduce_operator_expression_with_left_type(binary, leftType)
    then python_result_reduce_operator_gatherable(binary, env, module, allModules)
    else if python_result_pipe_expression_with_left_type(binary, leftType)
    then python_result_pipe_gatherable(binary, env, module, allModules)
    else if python_option_pipe_expression_with_left_type(binary, leftType)
    then python_option_pipe_gatherable(binary, env, module, allModules)
    else if python_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then python_method_call_gatherable(python_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if python_collection_pipe_expression_with_left_type(binary, leftType)
    then python_collection_pipe_gatherable(binary, env, module, allModules)
    else if python_binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
    then python_expression_gatherable(binary.left, env, module, allModules)
        & python_expression_gatherable(binary.right, env, module, allModules)
    else if python_regex_binary_expression_with_left_type(binary, leftType)
    then python_expression_gatherable(binary.left, env, module, allModules)
        & python_expression_gatherable(binary.right, env, module, allModules)
    else if python_set_binary_expression_with_left_type(binary, leftType)
    then python_expression_gatherable(binary.left, env, module, allModules)
        & python_expression_gatherable(binary.right, env, module, allModules)
    else python_binary_operator_gatherable(binary.operator)
        & !python_unsupported_callable_pipe(binary)
        & python_expression_gatherable(binary.left, env, module, allModules)
        & python_expression_gatherable(binary.right, env, module, allModules)

private fun python_collection_pipe_gatherable(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(binary.left, env, module, allModules)
        & python_callable_expression_gatherable(binary.right, env, module, allModules)

private fun python_lambda_expression_gatherable(lambda: CompiledLambdaExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(lambda.body, python_lambda_bindings(lambda.parameters) + env, module, allModules)

private fun python_lambda_expression_gatherable_with_bindings(lambda: CompiledLambdaExpression, bindings: List[PythonBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(lambda.body, bindings + env, module, allModules)

private fun python_result_pipe_gatherable(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(binary.left, env, module, allModules)
        & python_result_callable_expression_gatherable(binary.left, binary.right, env, module, allModules)

private fun python_result_reduce_operator_gatherable(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match binary.right with
    case CompiledTupleLiteral literal ->
        python_expression_gatherable(binary.left, env, module, allModules)
            & python_result_reduce_arguments_gatherable(binary.left, literal.values, env, module, allModules)
    case _ -> false

private fun python_option_pipe_gatherable(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(binary.left, env, module, allModules)
        & python_callable_expression_gatherable(binary.right, env, module, allModules)

private fun python_callable_expression_gatherable(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> python_lambda_expression_gatherable(lambda, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> python_function_reference_gatherable(reference, module, allModules)
    case _ -> false

private fun python_function_reference_gatherable(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if python_runtime_function(reference.name)
    then true
    else if python_qualified_name(reference.name)
    then python_qualified_function_reference_gatherable(reference, module, allModules)
    else if python_local_function_unambiguous(reference.name, module.functions)
    then true
    else python_imported_function_exists(reference.name, module.imports, module, allModules)

private fun python_qualified_function_reference_gatherable(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_qualified_function_binding(reference.name, module, allModules) with
    case Some { binding } -> python_callable_function(binding.function)
    case None -> false

private fun python_unsupported_callable_pipe(binary: CompiledBinaryExpression): bool =
    binary.operator == "|" & python_callable_expression(binary.right)

private fun python_callable_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

private fun python_unary_operator_gatherable(operator: String): bool =
    operator == "-" | operator == "!" | operator == ".not."

private fun python_function_call_gatherable(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if python_expressions_gatherable(call.arguments, env, module, allModules)
    then if python_runtime_function(call.name)
        then true
        else if python_enum_parse_call(call, module, allModules)
        then python_enum_parse_call_gatherable(call, env, module, allModules)
        else if python_qualified_name(call.name)
        then python_qualified_function_call_gatherable(call, module, allModules)
        else if python_callable_binding_exists(call.name, env)
        then true
        else if python_local_function_unambiguous(call.name, module.functions)
        then true
        else python_imported_function_exists(call.name, module.imports, module, allModules)
    else false

private fun python_qualified_function_call_gatherable(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_qualified_function_binding(call.name, module, allModules) with
    case Some { binding } -> python_callable_function(binding.function)
    case None -> false

private fun python_callable_binding_exists(name: String, env: List[PythonBinding]): bool =
    match python_lookup_binding(name, env) with
    case Some { binding } -> python_callable_binding_type(binding.typeName)
    case None -> false

private fun python_callable_binding_type(typeName: String): bool =
    typeName ? "=>"

private fun python_method_call_gatherable(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    if python_assert_method(call.name)
    then if python_expression_gatherable(call.receiver, env, module, allModules)
        then python_expressions_gatherable(call.arguments, env, module, allModules)
        else false
    else if call.name == "__capy_call"
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if call.name == "size"
    then if call.arguments.is_empty()
        then python_expression_gatherable(call.receiver, env, module, allModules)
        else false
    else if python_char_to_string_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else if python_string_get_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_string_parse_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else if python_string_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_regex_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_stdlib_date_time_method_call(call, env, module, allModules)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_set_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_native_collection_method_call_with_receiver_type(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if python_seq_as_list_call(call)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else if python_collection_predicate_call(call, receiverType)
    then python_collection_predicate_gatherable(call, env, module, allModules)
    else if python_primitive_conversion_method_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else if python_enum_name_method_call(call, receiverType, module, allModules)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else if python_effect_method_call(call, receiverType)
    then python_effect_method_gatherable(call, env, module, allModules)
    else if python_result_method_call(call, receiverType)
    then python_result_method_gatherable(call, env, module, allModules)
    else if python_option_method_call(call, receiverType)
    then python_option_pipe_gatherable(python_option_method_binary(call), env, module, allModules)
    else if python_collection_reduce_method_call(call, receiverType)
    then python_collection_reduce_method_gatherable(call, receiverType, env, module, allModules)
    else if python_collection_method_call(call, receiverType)
    then python_collection_pipe_gatherable(python_collection_method_binary(call), env, module, allModules)
    else if python_seq_first_call(call, receiverType)
    then python_expression_gatherable(call.receiver, env, module, allModules)
    else match python_find_extension_method(call, env, module, allModules) with
        case Some _ ->
            python_expression_gatherable(call.receiver, env, module, allModules)
                & python_expressions_gatherable(call.arguments, env, module, allModules)
        case None -> false

private fun python_effect_method_gatherable(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(call.receiver, env, module, allModules)
        & python_single_callable_argument_gatherable(call.arguments, env, module, allModules)

private fun python_result_method_gatherable(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or" | call.name == "or_else"
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_expressions_gatherable(call.arguments, env, module, allModules)
    else if call.name == "reduce" | call.name == "reduce_left"
    then python_expression_gatherable(call.receiver, env, module, allModules)
        & python_result_reduce_arguments_gatherable(call.receiver, call.arguments, env, module, allModules)
    else python_expression_gatherable(call.receiver, env, module, allModules)
        & python_result_single_callable_argument_gatherable(call.receiver, call.arguments, env, module, allModules)

private fun python_collection_reduce_method_gatherable(call: CompiledMethodCallExpression, receiverType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(call.receiver, env, module, allModules)
        & match call.arguments[0] with
            case None -> false
            case Some { initial } ->
                python_expression_gatherable(initial, env, module, allModules)
                    & match call.arguments[1] with
                        case None -> false
                        case Some { reducer } ->
                            match reducer with
                            case CompiledLambdaExpression lambda ->
                                let accumulatorName = python_lambda_parameter_at(lambda.parameters, 0)
                                let keyName = python_reduce_key_parameter(lambda.parameters, receiverType)
                                let valueName = python_reduce_value_parameter(lambda.parameters, receiverType)
                                python_expression_gatherable(lambda.body, python_reduce_bindings_from_names(accumulatorName, keyName, valueName, env), module, allModules)
                            case _ -> false

private fun python_collection_predicate_gatherable(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(call.receiver, env, module, allModules)
        & python_single_callable_argument_gatherable(call.arguments, env, module, allModules)

private fun python_single_callable_argument_gatherable(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & python_callable_expression_gatherable(argument, env, module, allModules)

private fun python_result_single_callable_argument_gatherable(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & python_result_callable_expression_gatherable(receiver, argument, env, module, allModules)

private fun python_result_reduce_arguments_gatherable(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { successMapper } ->
        match arguments[1] with
        case None -> false
        case Some { errorMapper } ->
            arguments[2:].is_empty()
                & python_result_callable_expression_gatherable(receiver, successMapper, env, module, allModules)
                & python_callable_expression_gatherable(errorMapper, env, module, allModules)

private fun python_result_callable_expression_gatherable(receiver: CompiledExpression, mapper: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match mapper with
    case CompiledLambdaExpression lambda ->
        python_lambda_expression_gatherable_with_bindings(
            lambda,
            python_lambda_bindings_with_single_type(lambda.parameters, python_result_payload_type(receiver, env, module, allModules)),
            env,
            module,
            allModules
        )
    case CompiledFunctionReferenceExpression reference -> python_function_reference_gatherable(reference, module, allModules)
    case _ -> false

private fun python_local_function_unambiguous(name: String, functions: List[CompiledFunction]): bool =
    python_local_function_count(name, functions) == 1

private fun python_local_function_count(name: String, functions: List[CompiledFunction]): int =
    match functions[0] with
    case None -> 0
    case Some { function } ->
        let current = if !python_skip_function(function) & function.name == name then 1 else 0
        current + python_local_function_count(name, functions[1:])

private fun python_imported_function_exists(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_function_in_imports(name, imports, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_expressions_gatherable(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        python_expression_gatherable(expression, env, module, allModules)
            & python_expressions_gatherable(expressions[1:], env, module, allModules)

private fun python_dict_entries_gatherable(entries: List[CompiledDictEntry], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } ->
        python_expression_gatherable(entry.key, env, module, allModules)
            & python_expression_gatherable(entry.value, env, module, allModules)
            & python_dict_entries_gatherable(entries[1:], env, module, allModules)

private fun python_index_expression_gatherable(index: CompiledIndexExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = python_expression_type(index.receiver, env, module, allModules)
    if !python_built_in_index_expression(index, receiverType)
    then python_user_defined_index_gatherable(index, receiverType, env, module, allModules)
    else python_expression_gatherable(index.receiver, env, module, allModules)
        & python_expression_gatherable(index.index, env, module, allModules)
        & (!index.hasEndIndex | python_expression_gatherable(index.endIndex, env, module, allModules))

private fun python_user_defined_index_gatherable(index: CompiledIndexExpression, receiverType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_extension_method_in_scope(receiverType, "get", module, allModules) with
    case Some _ ->
        python_expression_gatherable(index.receiver, env, module, allModules)
            & python_expression_gatherable(index.index, env, module, allModules)
            & (!index.hasEndIndex | python_expression_gatherable(index.endIndex, env, module, allModules))
    case None -> false

private fun python_data_fields_gatherable(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } ->
        !field.spread
            & python_expression_gatherable(field.value, env, module, allModules)
            & python_data_fields_gatherable(fields[1:], env, module, allModules)

private fun python_reduce_expression_gatherable(reduce: CompiledReduceExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    !reduce.accumulatorName.is_empty()
        & !reduce.valueName.is_empty()
        & python_expression_gatherable(reduce.receiver, env, module, allModules)
        & python_expression_gatherable(reduce.initial, env, module, allModules)
        & python_expression_gatherable(reduce.body, python_reduce_bindings(reduce, env), module, allModules)

private fun python_match_expression_gatherable(matchExpression: CompiledMatchExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_gatherable(matchExpression.value, env, module, allModules)
        & python_match_cases_gatherable(matchExpression.cases, env, module, allModules)

private fun python_match_supported(matchExpression: CompiledMatchExpression): bool =
    python_match_cases_supported(matchExpression.cases)

private fun python_match_cases_gatherable(cases: List[CompiledMatchCase], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        python_match_case_gatherable(matchCase, env, module, allModules)
            & (cases[1:].is_empty() | python_match_cases_gatherable(cases[1:], env, module, allModules))

private fun python_match_case_gatherable(matchCase: CompiledMatchCase, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_match_case_supported(matchCase)
        & (!matchCase.hasLiteral | python_expression_gatherable(matchCase.literal, env, module, allModules))
        & (!matchCase.hasGuard | python_expression_gatherable(matchCase.guard, python_match_case_env(matchCase, env), module, allModules))
        & python_expression_gatherable(matchCase.body, python_match_case_env(matchCase, env), module, allModules)

private fun python_match_cases_supported(cases: List[CompiledMatchCase]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        python_match_case_supported(matchCase)
            & (cases[1:].is_empty() | python_match_cases_supported(cases[1:]))

private fun python_match_case_supported(matchCase: CompiledMatchCase): bool =
    matchCase.wildcard | !matchCase.typeName.is_empty() | matchCase.hasLiteral

private fun python_bindings_gatherable(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        (binding.operator == "=" | binding.operator == "<-")
            & python_expression_gatherable(binding.value, env, module, allModules)
            & python_bindings_gatherable(bindings[1:], [python_let_binding(binding, env, module, allModules)] + env, module, allModules)

private fun python_test_function_gatherable(function: CompiledFunction): bool =
    match function.body with
    case CompiledFunctionCallExpression call -> call.name == "test_file" & python_test_file_arguments_gatherable(call.arguments)
    case _ -> false

private fun python_test_file_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { fileName } ->
        match arguments[1] with
        case None -> false
        case Some { tests } ->
            arguments[2:].is_empty()
                & python_string_literal_expression(fileName)
                & python_test_case_list_gatherable(tests)

private fun python_test_case_list_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledListLiteral list -> python_test_case_expressions_gatherable(list.values)
    case _ -> false

private fun python_test_case_expressions_gatherable(expressions: List[CompiledExpression]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> python_test_case_expression_gatherable(expression) & python_test_case_expressions_gatherable(expressions[1:])

private fun python_test_case_expression_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "test" & python_test_call_arguments_gatherable(call.arguments)
    case CompiledMethodCallExpression call -> python_effect_test_case_map_gatherable(call)
    case _ -> false

private fun python_effect_test_case_map_gatherable(call: CompiledMethodCallExpression): bool =
    call.name == "map"
        & match call.arguments[0] with
            case None -> false
            case Some { mapper } ->
                match mapper with
                case CompiledLambdaExpression lambda -> python_test_case_expression_gatherable(lambda.body)
                case _ -> false

private fun python_test_call_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { name } ->
        match arguments[1] with
        case None -> false
        case Some { body } ->
            arguments[2:].is_empty()
                & python_string_literal_expression(name)
                & python_zero_arg_lambda(body)

private fun python_string_literal_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledStringLiteral _ -> true
    case _ -> false

private fun python_zero_arg_lambda(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

private fun python_assert_method(name: String): bool =
    name == "is_equal_to"
        | name == "is_true"
        | name == "is_false"
        | name == "is_zero"
        | name == "is_one"
        | name == "is_empty"
        | name == "has_size"
        | name == "contains"
        | name == "starts_with"
        | name == "does_not_start_with"
        | name == "succeeds"
        | name == "fails"
        | name == "failed"
        | name == "succeeded"

private fun python_data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    python_merge_schema_fields(
        python_data_type_direct_fields(name, module, allModules),
        python_data_type_parent_fields(python_data_type_parent_types(name, module, allModules), module, allModules)
    )

private fun python_data_type_direct_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    python_data_type_schema_values(name, "__capy_schema_field|", module, allModules)

private fun python_data_type_parent_types(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    python_data_type_schema_values(name, "__capy_schema_parent|", module, allModules)

private fun python_data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = python_schema_type_name(parent)
        python_merge_schema_fields(
            python_data_type_fields(parentName, module, allModules),
            python_data_type_parent_fields(parents[1:], module, allModules)
        )

private fun python_data_type_schema_values(name: String, prefix: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if python_schema_type_exists(name, module.functions)
    then python_schema_values(prefix + name + "|", module.functions)
    else match python_data_type_schema_values_in_imports(name, prefix, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> python_data_type_schema_values_in_modules(name, prefix, allModules)

private fun python_data_type_schema_values_in_modules(name: String, prefix: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        if python_schema_type_exists(name, module.functions)
        then python_schema_values(prefix + name + "|", module.functions)
        else python_data_type_schema_values_in_modules(name, prefix, modules[1:])

private fun python_data_type_schema_values_in_imports(name: String, prefix: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if python_data_import_matches(name, declaration)
        then python_data_type_schema_values_in_import(name, prefix, imports[1:], module, allModules, declaration)
        else python_data_type_schema_values_in_imports(name, prefix, imports[1:], module, allModules)

private fun python_data_type_schema_values_in_import(name: String, prefix: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[List[String]] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if python_schema_type_exists(name, importedModule.functions)
        then /capy/lang/Option.Some { python_schema_values(prefix + name + "|", importedModule.functions) }
        else python_data_type_schema_values_in_imports(name, prefix, rest, module, allModules)
    case _ -> python_data_type_schema_values_in_imports(name, prefix, rest, module, allModules)

private fun python_data_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    !python_stdlib_import(declaration.modulePath)
        & !declaration.qualified
        & python_import_includes_name(name, declaration)

private fun python_primitive_backed_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_primitive_backed_backing_type(name, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_primitive_backed_backing_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if python_qualified_name(name)
    then python_primitive_backed_backing_type_in_qualified_name(name, module, allModules)
    else match python_primitive_backed_backing_type_in_functions(name, module.functions) with
    case Some { backingType } -> /capy/lang/Option.Some { backingType }
    case None ->
        match python_primitive_backed_backing_type_in_imports(name, module.imports, module, allModules) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> python_primitive_backed_backing_type_in_modules(name, allModules)

private fun python_primitive_backed_backing_type_in_qualified_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match python_find_module_by_path(python_qualified_call_module_path(name, module), allModules) with
    case Some { targetModule } -> python_primitive_backed_backing_type_in_functions(python_qualified_call_member(name), targetModule.functions)
    case None -> /capy/lang/Option.None {}

private fun python_primitive_backed_backing_type_in_functions(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match python_schema_value_named("__capy_schema_primitive|" + name, functions) with
    case Some { value } -> /capy/lang/Option.Some { python_schema_type_name(value) }
    case None -> /capy/lang/Option.None {}

private fun python_primitive_backed_backing_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if python_data_import_matches(name, declaration)
        then python_primitive_backed_backing_type_in_import(name, imports[1:], module, allModules, declaration)
        else python_primitive_backed_backing_type_in_imports(name, imports[1:], module, allModules)

private fun python_primitive_backed_backing_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[String] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match python_primitive_backed_backing_type_in_functions(name, importedModule.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> python_primitive_backed_backing_type_in_imports(name, rest, module, allModules)
    }
    case _ -> python_primitive_backed_backing_type_in_imports(name, rest, module, allModules)

private fun python_primitive_backed_backing_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match python_primitive_backed_backing_type_in_functions(name, module.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> python_primitive_backed_backing_type_in_modules(name, modules[1:])

private fun python_merge_schema_fields(first: List[String], second: List[String]): List[String] =
    first + python_schema_fields_not_named(second, first)

private fun python_schema_fields_not_named(fields: List[String], existing: List[String]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        if python_schema_field_name_exists(python_schema_field_name(field), existing)
        then python_schema_fields_not_named(fields[1:], existing)
        else [field] + python_schema_fields_not_named(fields[1:], existing + [field])

private fun python_schema_field_name_exists(name: String, fields: List[String]): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> python_schema_field_name(field) == name | python_schema_field_name_exists(name, fields[1:])

private fun python_schema_type_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        (python_compiled_schema(function) & function.name == "__capy_schema_type|" + name)
            | python_schema_type_exists(name, functions[1:])

private fun python_schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_schema(function) & python_string_has_prefix(function.name, prefix)
        then [python_schema_value(function)] + python_schema_values(prefix, functions[1:])
        else python_schema_values(prefix, functions[1:])

private fun python_schema_value_named(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if python_compiled_schema(function) & function.name == name
        then /capy/lang/Option.Some { python_schema_value(function) }
        else python_schema_value_named(name, functions[1:])

private fun python_schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

private fun python_schema_field_name(value: String): String =
    let separator = python_first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

private fun python_schema_field_type_name(value: String): String =
    let separator = python_first_index_of(value, "|", 0)
    if separator < 0
    then python_unknown_type()
    else python_schema_type_name(value[separator + 1, value.size().value])

private fun python_schema_type_name(value: String): String =
    let trimmed = value.trim()
    let bracket = python_first_index_of(trimmed, "[", 0)
    if bracket < 0
    then trimmed
    else trimmed[0, bracket]

private fun python_module_import_name(module: CompiledModule): String =
    python_module_path(module).replace("/", ".")

private fun python_module_relative_path(module: CompiledModule, extension: String): String =
    if module.path.is_empty()
    then module.name + extension
    else module.path + "/" + module.name + extension

private fun python_identifier(name: String): String =
    let sanitized = python_identifier_chars(name, 0, "")
    let nonEmpty = if sanitized.is_empty() then "_" else sanitized
    let prefixed = match nonEmpty[0] with
        case None -> "_"
        case Some { char } -> if python_identifier_start_char(char) then nonEmpty else "_" + nonEmpty
    if python_reserved_word(prefixed)
    then prefixed + "_"
    else prefixed

private fun python_identifier_chars(name: String, idx: int, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            let next = if python_identifier_part_char(char) then char else "_"
            python_identifier_chars(name, idx + 1, acc + next)

private fun python_identifier_start_char(char: String): bool =
    ("ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char) | ("abcdefghijklmnopqrstuvwxyz" ? char) | char == "_"

private fun python_identifier_part_char(char: String): bool =
    python_identifier_start_char(char) | ("0123456789" ? char)

private fun python_reserved_word(name: String): bool =
    "|False|None|True|and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|" ? ("|" + name + "|")

private fun python_string_literal(value: String): String =
    "\"" + escape_python_string(value) + "\""

private fun escape_python_string(value: String): String =
    value
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace('\n', '\\n')
        .replace('\r', '\\r')
        .replace('\t', '\\t')

private fun python_long_literal(source: String): String =
    if python_string_has_suffix(source, "L") | python_string_has_suffix(source, "l")
    then source[0, source.size().value - 1]
    else source

private fun python_decimal_literal(source: String): String =
    if python_string_has_suffix(source, "f") | python_string_has_suffix(source, "F") | python_string_has_suffix(source, "d") | python_string_has_suffix(source, "D")
    then source[0, source.size().value - 1]
    else source

private fun python_string_has_prefix(value: String, prefix: String): bool =
    python_string_has_prefix_at(value, prefix, 0)

private fun python_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then python_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun python_string_has_suffix(value: String, suffix: String): bool =
    if suffix.size().value > value.size().value
    then false
    else value[value.size().value - suffix.size().value, value.size().value] == suffix

private fun python_first_index_of(value: String, expected: String, idx: int): int =
    if idx >= value.size().value
    then -1
    else match value[idx] with
        case None -> -1
        case Some { actual } ->
            if actual == expected
            then idx
            else python_first_index_of(value, expected, idx + 1)

private fun python_last_dot_index(value: String): int =
    python_last_dot_index_from(value, 0, -1)

private fun python_last_dot_index_from(value: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { actual } ->
            python_last_dot_index_from(value, idx + 1, if actual == "." then idx else found)

private fun python_last_index_of(value: String, expected: String): int =
    python_last_index_of_from(value, expected, 0, -1)

private fun python_last_index_of_from(value: String, expected: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { actual } ->
            python_last_index_of_from(value, expected, idx + 1, if actual == expected then idx else found)

private fun python_newline(): String = '\n'
