    + python_newline()
    + "def __capy_date(day, month, year):" + python_newline()
    + "    return __capy_data('Date', dict(day=int(day), month=int(month), year=int(year)))" + python_newline()
    + python_newline()
    + "def __capy_time(hour, minute, second, offset_minutes=None):" + python_newline()
