from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledAnnotationDeclaration import { CompiledAnnotationDeclaration }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledFunctionReferenceExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression, CompiledWithExpression }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledDeriverDeclaration import { CompiledDeriverDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledNativeProviderBinding import { CompiledNativeProviderBinding }
from /dev/capylang/compiler/CompiledNativeProviderDeclaration import { CompiledNativeProviderDeclaration }
from /dev/capylang/compiler/CompiledObjectOrientedClass import { CompiledObjectOrientedClass }
from /dev/capylang/compiler/CompiledObjectOrientedField import { CompiledObjectOrientedField }
from /dev/capylang/compiler/CompiledObjectOrientedMethod import { CompiledObjectOrientedMethod }
from /dev/capylang/compiler/CompiledPrimitiveBackedType import { CompiledPrimitiveBackedType }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from /dev/capylang/compiler/GenericDataType import { GenericDataType }
from /dev/capylang/compiler/NativeProviderBackendBinding import { NativeProviderBackendBinding }
from /dev/capylang/compiler/NativeProviderCatalog import { NativeProviderCatalog }
from /dev/capylang/compiler/StaticImport import { StaticImport }
from /dev/capylang/generator/GeneratedModule import { GeneratedModule }
from /dev/capylang/generator/GeneratedProgram import { GeneratedProgram }

data PythonBinding { name: String, pythonName: String, typeName: String }
data PythonAnnotationBinding { declaration: CompiledAnnotationDeclaration, module: CompiledModule }
data PythonObjectClassBinding { module: CompiledModule, objectClass: CompiledObjectOrientedClass }
data PythonObjectMethodBinding { module: CompiledModule, objectClass: CompiledObjectOrientedClass, method: CompiledObjectOrientedMethod }
data PythonQualifiedFunctionBinding { module: CompiledModule, function: CompiledFunction }
data PythonSchemaAnnotationArgument { name: String, kind: String, value: String }
data PythonStdlibValue { pythonName: String, typeName: String }

fun python_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: python_native_provider_interface_modules(program.nativeProviderCatalog.declarations)
            + python_modules(program.modules, program.modules, program.nativeProviderCatalog)
            + python_test_runtime_modules(program.modules)
            + python_native_runtime_modules()
    }

private fun python_native_provider_interface_modules(declarations: List[CompiledNativeProviderDeclaration]): List[GeneratedModule] =
    match declarations[0] with
    case None -> []
    case Some { declaration } ->
        if declaration.interfaceId.is_empty()
        then python_native_provider_interface_modules(declarations[1:])
        else [GeneratedModule {
            relativePath: declaration.interfaceId.replace(".", "/") + ".py",
            code: python_native_provider_interface_module_code(declaration.interfaceId)
        }] + python_native_provider_interface_modules(declarations[1:])

private fun python_native_provider_interface_module_code(interfaceId: String): String =
    "# Generated by Capybara." + python_newline()
    + python_runtime_import()
    + python_newline()
    + "class " + python_identifier(python_native_provider_interface_name(interfaceId)) + ":" + python_newline()
    + "    pass" + python_newline()

private fun python_native_provider_interface_name(interfaceId: String): String =
    let separator = python_last_index_of(interfaceId, ".")
    if separator < 0
    then interfaceId
    else interfaceId[separator + 1, interfaceId.size().value]

private fun python_modules(modules: List[CompiledModule], allModules: List[CompiledModule], nativeProviderCatalog: NativeProviderCatalog): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: python_module_relative_path(module, ".py"),
        code: python_module_code(module, allModules, nativeProviderCatalog)
    }] + python_modules(modules[1:], allModules, nativeProviderCatalog)

private fun python_module_code(module: CompiledModule, allModules: List[CompiledModule], nativeProviderCatalog: NativeProviderCatalog): String =
    "# Generated by Capybara." + python_newline()
    + python_runtime_import()
    + python_imports(module.imports, module, allModules)
    + python_newline()
    + python_object_classes(python_compiled_object_classes(module.functions), module, allModules)
    + python_constants(module.functions, module, allModules)
    + python_functions(module.functions, module, allModules, nativeProviderCatalog)

private fun python_runtime_import(): String =
    "from capy.test.CapyTestRuntime import *" + python_newline()

private fun python_object_classes(classes: List[CompiledObjectOrientedClass], module: CompiledModule, allModules: List[CompiledModule]): String =
    match classes[0] with
    case None -> ""
    case Some { objectClass } ->
        python_object_class(objectClass, module, allModules) + python_newline()
            + python_object_classes(classes[1:], module, allModules)

private fun python_object_class(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    "class " + python_identifier(objectClass.name) + ":" + python_newline()
    + python_object_type_method(objectClass, module, allModules)
    + python_object_constructor(objectClass, module, allModules)
    + python_object_methods(objectClass.methods, objectClass, module, allModules)
    + python_object_runtime_aliases(python_identifier(objectClass.name))

private fun python_object_runtime_aliases(classIdentifier: String): String =
    let classPrefix = python_object_mangle_prefix(classIdentifier)
    if classPrefix.is_empty()
    then ""
    else python_object_runtime_alias(classPrefix, "__capy_bind_value")
        + python_object_runtime_alias(classPrefix, "__capy_effect_bind_value")
        + python_object_runtime_alias(classPrefix, "__capy_data")
        + python_object_runtime_alias(classPrefix, "__capy_set")
        + python_object_runtime_alias(classPrefix, "__capy_add")
        + python_object_runtime_alias(classPrefix, "__capy_sub")
        + python_object_runtime_alias(classPrefix, "__capy_deep_equal")
        + python_object_runtime_alias(classPrefix, "__capy_size")
        + python_object_runtime_alias(classPrefix, "__capy_contains")
        + python_object_runtime_alias(classPrefix, "__capy_is_empty")
        + python_object_runtime_alias(classPrefix, "__capy_get_field")
        + python_object_runtime_alias(classPrefix, "__capy_index")
        + python_object_runtime_alias(classPrefix, "__capy_as_list")
        + python_object_runtime_alias(classPrefix, "__capy_seq_map")
        + python_object_runtime_alias(classPrefix, "__capy_seq_filter")
        + python_object_runtime_alias(classPrefix, "__capy_seq_reject")
        + python_object_runtime_alias(classPrefix, "__capy_seq_flat_map")
        + python_object_runtime_alias(classPrefix, "__capy_any")
        + python_object_runtime_alias(classPrefix, "__capy_all")
        + python_object_runtime_alias(classPrefix, "__capy_type_matches")
        + python_object_runtime_alias(classPrefix, "__capy_match_binding")
        + python_object_runtime_alias(classPrefix, "__capy_no_match")
        + python_object_runtime_alias(classPrefix, "__capy_unsupported")
        + python_object_runtime_alias(classPrefix, "__capy_not_implemented")
        + python_object_runtime_alias(classPrefix, "__capy_reflection_annotations")
        + python_object_runtime_alias(classPrefix, "__capy_long")
        + python_object_runtime_alias(classPrefix, "__capy_to_int")
        + python_object_runtime_alias(classPrefix, "__capy_to_long")
        + python_object_runtime_alias(classPrefix, "__capy_to_string")
        + python_object_runtime_alias(classPrefix, "__capy_with")
        + python_object_runtime_alias(classPrefix, "__capy_constructor_value")
        + python_object_runtime_alias(classPrefix, "__capy_constructor_result")
        + python_object_runtime_alias(classPrefix, "__capy_primitive_constructor_result")
        + python_object_runtime_alias(classPrefix, "__capy_constructor_pipeline")
        + python_object_runtime_alias(classPrefix, "__capy_set_append")
        + python_object_runtime_alias(classPrefix, "__capy_set_concat")
        + python_object_runtime_alias(classPrefix, "__capy_set_remove")
        + python_object_runtime_alias(classPrefix, "__capy_set_remove_all")
        + python_object_runtime_alias(classPrefix, "__capy_set_subset")
        + python_object_runtime_alias(classPrefix, "__capy_set_proper_subset")
        + python_object_runtime_alias(classPrefix, "__capy_set_intersection")
        + python_object_runtime_alias(classPrefix, "__capy_set_symmetric_difference")
        + python_object_runtime_alias(classPrefix, "__capy_set_cartesian_product")
        + python_object_runtime_alias(classPrefix, "__capy_set_power_set")
        + python_object_runtime_alias(classPrefix, "__capy_mul")
        + python_object_runtime_alias(classPrefix, "__capy_div")
        + python_object_runtime_alias(classPrefix, "__capy_mod")
        + python_object_runtime_alias(classPrefix, "__capy_pow")
        + python_object_runtime_alias(classPrefix, "__capy_pow_int")

private fun python_object_runtime_alias(classPrefix: String, name: String): String =
    "_" + classPrefix + name + " = " + name + python_newline()

private fun python_object_mangle_prefix(classIdentifier: String): String =
    if classIdentifier.is_empty()
    then ""
    else if classIdentifier[0, 1] == "_"
    then python_object_mangle_prefix(classIdentifier[1, classIdentifier.size().value])
    else classIdentifier

private fun python_object_type_method(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    "    @staticmethod" + python_newline()
    + "    def type():" + python_newline()
    + "        return " + python_object_info_literal(objectClass, module, allModules) + python_newline()
    + python_newline()

private fun python_object_info_literal(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"ObjectInfo\", dict("
        + "name=" + python_string_literal(objectClass.name)
        + ", pkg=" + python_package_info_literal(module.name, module.path)
        + ", open=" + python_bool_code(objectClass.open)
        + ", fields=" + python_object_field_infos_literal(objectClass.name, objectClass.fields, 0, module, allModules)
        + ", methods=" + python_object_method_infos_literal(objectClass.name, objectClass.methods, module, allModules)
        + ", parents=" + python_object_parent_infos_literal(objectClass.parents, module, allModules)
        + ", annotations=" + python_reflection_annotation_infos_literal(
            python_schema_values("__capy_oo_annotation|type|" + objectClass.name + "|", module.functions),
            module,
            allModules
        )
        + "))"

private fun python_object_interface_info_literal(interfaceName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"" + python_object_interface_info_type(python_object_interface_kind(interfaceName, module.functions)) + "\", dict("
        + "name=" + python_string_literal(interfaceName)
        + ", pkg=" + python_package_info_literal(module.name, module.path)
        + ", methods=" + python_object_interface_method_infos_literal(interfaceName, module.functions, module, allModules)
        + ", parents=" + python_object_parent_infos_literal(
            python_object_schema_type_references(python_schema_values("__capy_oo_interface_parent|" + interfaceName + "|", module.functions)),
            module,
            allModules
        )
        + ", annotations=" + python_reflection_annotation_infos_literal(
            python_schema_values("__capy_oo_annotation|type|" + interfaceName + "|", module.functions),
            module,
            allModules
        )
        + "))"

private fun python_object_interface_kind(interfaceName: String, functions: List[CompiledFunction]): String =
    match python_schema_value_named("__capy_oo_interface_kind|" + interfaceName, functions) with
    case Some { value } -> value
    case None -> "interface"

private fun python_object_interface_info_type(kind: String): String =
    if kind == "trait" then "TraitInfo" else "InterfaceInfo"

private fun python_object_field_infos_literal(className: String, fields: List[CompiledObjectOrientedField], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> "[]"
    case Some { field } ->
        "[" + python_object_field_info_literal(className, field, idx, module, allModules)
            + python_object_field_infos_tail_literal(className, fields[1:], idx + 1, module, allModules)
            + "]"

private fun python_object_field_infos_tail_literal(className: String, fields: List[CompiledObjectOrientedField], idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", " + python_object_field_info_literal(className, field, idx, module, allModules)
            + python_object_field_infos_tail_literal(className, fields[1:], idx + 1, module, allModules)

private fun python_object_field_info_literal(className: String, field: CompiledObjectOrientedField, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"FieldInfo\", dict("
        + "name=" + python_string_literal(field.name)
        + ", type=" + python_any_info_literal(field.typeReference, module, allModules)
        + ", annotations=" + python_reflection_annotation_infos_literal(
            python_schema_values("__capy_oo_annotation|field|" + className + "|" + idx + "|", module.functions),
            module,
            allModules
        )
        + "))"

private fun python_object_method_infos_literal(className: String, methods: List[CompiledObjectOrientedMethod], module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> "[]"
    case Some { method } ->
        "[" + python_object_method_info_literal(className, method, module, allModules)
            + python_object_method_infos_tail_literal(className, methods[1:], module, allModules)
            + "]"

private fun python_object_method_infos_tail_literal(className: String, methods: List[CompiledObjectOrientedMethod], module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> ""
    case Some { method } ->
        ", " + python_object_method_info_literal(className, method, module, allModules)
            + python_object_method_infos_tail_literal(className, methods[1:], module, allModules)

private fun python_object_method_info_literal(className: String, method: CompiledObjectOrientedMethod, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"MethodInfo\", dict("
        + "name=" + python_string_literal(method.name)
        + ", pkg=" + python_package_info_literal(module.name, module.path)
        + ", params=" + python_object_method_param_infos_literal(method.parameters, module, allModules)
        + ", return_type=" + python_any_info_literal(method.returnType, module, allModules)
        + ", annotations=" + python_reflection_annotation_infos_literal(
            python_schema_values("__capy_oo_annotation|method|" + className + "|" + method.name + "|", module.functions),
            module,
            allModules
        )
        + "))"

private fun python_object_interface_method_infos_literal(interfaceName: String, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> "[]"
    case Some { function } ->
        if python_compiled_object_interface_method_function_for_interface(function, interfaceName)
        then "[" + python_object_interface_method_info_literal(function, module, allModules)
            + python_object_interface_method_infos_tail_literal(interfaceName, functions[1:], module, allModules)
            + "]"
        else python_object_interface_method_infos_literal(interfaceName, functions[1:], module, allModules)

private fun python_object_interface_method_infos_tail_literal(interfaceName: String, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if python_compiled_object_interface_method_function_for_interface(function, interfaceName)
        then ", " + python_object_interface_method_info_literal(function, module, allModules)
            + python_object_interface_method_infos_tail_literal(interfaceName, functions[1:], module, allModules)
        else python_object_interface_method_infos_tail_literal(interfaceName, functions[1:], module, allModules)

private fun python_object_interface_method_info_literal(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    let interfaceName = python_compiled_object_interface_method_owner_name(function.name)
    let methodName = python_compiled_object_interface_method_name(function.name)
    "__capy_data(\"MethodInfo\", dict("
        + "name=" + python_string_literal(methodName)
        + ", pkg=" + python_package_info_literal(module.name, module.path)
        + ", params=" + python_object_method_param_infos_literal(function.parameters, module, allModules)
        + ", return_type=" + python_any_info_literal(function.returnType, module, allModules)
        + ", annotations=" + python_reflection_annotation_infos_literal(
            python_schema_values("__capy_oo_annotation|method|" + interfaceName + "|" + methodName + "|", module.functions),
            module,
            allModules
        )
        + "))"

private fun python_object_method_param_infos_literal(parameters: List[CompiledFunctionParameter], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> "[]"
    case Some { parameter } ->
        "[" + python_object_method_param_info_literal(parameter, module, allModules)
            + python_object_method_param_infos_tail_literal(parameters[1:], module, allModules)
            + "]"

private fun python_object_method_param_infos_tail_literal(parameters: List[CompiledFunctionParameter], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", " + python_object_method_param_info_literal(parameter, module, allModules)
            + python_object_method_param_infos_tail_literal(parameters[1:], module, allModules)

private fun python_object_method_param_info_literal(parameter: CompiledFunctionParameter, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"FieldInfo\", dict("
        + "name=" + python_string_literal(parameter.name)
        + ", type=" + python_any_info_literal(parameter.typeReference, module, allModules)
        + ", annotations=[]"
        + "))"

private fun python_object_parent_infos_literal(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> "__capy_set([])"
    case Some { parent } ->
        "__capy_set([" + python_any_info_literal(parent, module, allModules)
            + python_object_parent_infos_tail_literal(parents[1:], module, allModules)
            + "])"

private fun python_object_parent_infos_tail_literal(parents: List[CompiledTypeReference], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parents[0] with
    case None -> ""
    case Some { parent } ->
        ", " + python_any_info_literal(parent, module, allModules)
            + python_object_parent_infos_tail_literal(parents[1:], module, allModules)

private fun python_any_info_literal(typeReference: CompiledTypeReference, module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(\"DataInfo\", dict("
        + "name=" + python_string_literal(python_type_unqualified_name(typeReference.name))
        + ", pkg=" + python_type_package_info_literal(typeReference.name, module, allModules)
        + ", annotations=[]"
        + "))"

private fun python_type_package_info_literal(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_class_by_type(typeName, allModules) with
    case Some { binding } -> python_package_info_literal(binding.module.name, binding.module.path)
    case None ->
        match python_data_type_owner_module(python_type_unqualified_name(typeName), module, allModules) with
        case Some { owner } -> python_package_info_literal(owner.name, owner.path)
        case None -> python_package_info_literal("", "")

private fun python_package_info_literal(name: String, path: String): String =
    "__capy_data(\"PackageInfo\", dict(name=" + python_string_literal(name) + ", path=" + python_string_literal(path) + "))"

private fun python_object_constructor(objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    let env = python_object_constructor_bindings(objectClass, module)
    let body = python_object_constructor_body(objectClass, env, module, allModules)
    "    def __init__(self" + python_object_constructor_parameter_tail(objectClass.parameters) + "):" + python_newline()
    + (if body.is_empty() then "        pass" + python_newline() else body)
    + python_newline()

private fun python_object_constructor_bindings(objectClass: CompiledObjectOrientedClass, module: CompiledModule): List[PythonBinding] =
    [PythonBinding {
        name: "this",
        pythonName: "self",
        typeName: python_object_type_name(module, objectClass.name)
    }]
        + python_parameter_bindings(objectClass.parameters)

private fun python_object_constructor_body(objectClass: CompiledObjectOrientedClass, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_object_field_assignments(objectClass.fields, env, module, allModules)
        + python_object_init_statements(objectClass.initBlocks, env, module, allModules)

private fun python_object_field_assignments(fields: List[CompiledObjectOrientedField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        (if field.hasValue
        then "        self." + python_identifier(field.name) + " = " + python_expression_code(field.value, env, module, allModules) + python_newline()
        else "")
            + python_object_field_assignments(fields[1:], env, module, allModules)

private fun python_object_init_statements(initBlocks: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match initBlocks[0] with
    case None -> ""
    case Some { initBlock } ->
        python_object_init_statement(initBlock, env, module, allModules)
            + python_object_init_statements(initBlocks[1:], env, module, allModules)

private fun python_object_init_statement(initBlock: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = python_expression_code(initBlock, env, module, allModules)
    if python_expression_type(initBlock, env, module, allModules) == python_effect_type()
    then "        _unsafe_run(" + code + ")" + python_newline()
    else "        " + code + python_newline()

private fun python_object_constructor_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else ", " + python_parameters(parameters)

private fun python_object_methods(methods: List[CompiledObjectOrientedMethod], objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    match methods[0] with
    case None -> ""
    case Some { method } ->
        python_object_method(method, objectClass, module, allModules) + python_newline()
            + python_object_methods(methods[1:], objectClass, module, allModules)

private fun python_object_method(method: CompiledObjectOrientedMethod, objectClass: CompiledObjectOrientedClass, module: CompiledModule, allModules: List[CompiledModule]): String =
    let env = python_object_method_bindings(method.parameters, objectClass, module)
    "    def " + python_method_name(method.name) + "(self" + python_method_parameter_tail(method.parameters) + "):" + python_newline()
    + python_object_return_statement(method.body, env, module, allModules, "        ")

private fun python_object_method_bindings(parameters: List[CompiledFunctionParameter], objectClass: CompiledObjectOrientedClass, module: CompiledModule): List[PythonBinding] =
    [PythonBinding {
        name: "this",
        pythonName: "self",
        typeName: python_object_type_name(module, objectClass.name)
    }]
        + python_parameter_bindings(parameters)

private fun python_object_return_statement(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledIfExpression ifExpression ->
        indent + "if " + python_truthy_expression_code(ifExpression.condition, env, module, allModules) + ":" + python_newline()
            + python_object_return_statement(ifExpression.thenBranch, env, module, allModules, indent + "    ")
            + indent + "else:" + python_newline()
            + python_object_return_statement(ifExpression.elseBranch, env, module, allModules, indent + "    ")
    case CompiledBlockExpression block ->
        python_block_statements(block.bindings, env, module, allModules, indent)
            + python_object_return_statement(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules, indent)
    case _ -> indent + "return " + python_expression_code(expression, env, module, allModules) + python_newline()

private fun python_imports(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        if python_stdlib_import(declaration.modulePath)
        then python_imports(imports[1:], module, allModules)
        else python_import(declaration, module, allModules) + python_imports(imports[1:], module, allModules)

private fun python_import(declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): String =
    let modulePath = python_import_module_name(declaration.modulePath, module)
    "import " + modulePath + python_newline()
        + python_import_extension_method_aliases(declaration, modulePath, module, allModules)

private fun python_import_extension_method_aliases(declaration: CompiledImportDeclaration, modulePath: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if declaration.wildcard & !declaration.qualified
    then match python_find_imported_module(declaration, module, allModules) with
        case Some { importedModule } -> python_import_extension_method_aliases_for_functions(declaration, modulePath, importedModule.functions)
        case None -> ""
    else ""

private fun python_import_extension_method_aliases_for_functions(declaration: CompiledImportDeclaration, modulePath: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if python_imported_extension_method_alias(function, declaration)
        then python_function_name(function) + " = " + modulePath + "." + python_function_name(function) + python_newline()
            + python_import_extension_method_aliases_for_functions(declaration, modulePath, functions[1:])
        else python_import_extension_method_aliases_for_functions(declaration, modulePath, functions[1:])

private fun python_imported_extension_method_alias(function: CompiledFunction, declaration: CompiledImportDeclaration): bool =
    python_extension_method_function(function)
        & !python_skip_function(function)
        & !python_string_list_contains(python_method_member_name(python_method_owner_member_name(function.name)), declaration.excludedNames)

private fun python_method_owner_member_name(name: String): String =
    let idx = python_last_dot_index(name)
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun python_import_module_name(modulePath: String, module: CompiledModule): String =
    python_import_module_path(modulePath, module).replace("/", ".")

private fun python_stdlib_import(modulePath: String): bool =
    python_string_has_prefix(modulePath, "/capy/") | python_string_has_prefix(modulePath, "capy/")

private fun python_functions(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], nativeProviderCatalog: NativeProviderCatalog): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if python_skip_function(function)
        then python_functions(functions[1:], module, allModules, nativeProviderCatalog)
        else python_function(function, module, allModules, nativeProviderCatalog) + python_newline() + python_functions(functions[1:], module, allModules, nativeProviderCatalog)

private fun python_skip_function(function: CompiledFunction): bool =
    python_compiled_constant(function)
        | python_imported_function(function)
        | python_compiled_object_helper_function(function)

private fun python_compiled_constant(function: CompiledFunction): bool =
    python_string_has_prefix(function.visibility, "const:")

private fun python_compiled_schema(function: CompiledFunction): bool =
    python_string_has_prefix(function.visibility, "const:schema")

private fun python_imported_function(function: CompiledFunction): bool =
    function.visibility == "imported"

private fun python_compiled_object_helper_function(function: CompiledFunction): bool =
    python_string_has_prefix(function.name, "__capy_oo_method|")
        | python_string_has_prefix(function.name, "__capy_oo_interface_method|")
        | python_string_has_prefix(function.name, "__capy_oo_field_init|")
        | python_string_has_prefix(function.name, "__capy_oo_init|")

private fun python_constants(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if python_emitted_constant(function)
        then python_constant(function, module, allModules) + python_constants(functions[1:], module, allModules)
        else python_constants(functions[1:], module, allModules)

private fun python_emitted_constant(function: CompiledFunction): bool =
    python_compiled_constant(function) & !python_compiled_schema(function)

private fun python_constant(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    python_identifier(function.name) + " = " + python_expression_code(function.body, [], module, allModules) + python_newline()

private fun python_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], nativeProviderCatalog: NativeProviderCatalog): String =
    let env = python_function_bindings(function)
    "def " + python_function_name(function) + "(" + python_function_parameters(function) + "):" + python_newline()
    + python_function_body(function, env, module, allModules, nativeProviderCatalog)

private fun python_function_body(function: CompiledFunction, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], nativeProviderCatalog: NativeProviderCatalog): String =
    match python_find_native_provider_declaration(function, module, nativeProviderCatalog.declarations) with
    case Some { declaration } -> python_native_provider_function_body(declaration, function.returnType, nativeProviderCatalog)
    case None -> python_return_statement(function.body, env, module, allModules, "    ", function.returnType)

private fun python_find_native_provider_declaration(function: CompiledFunction, module: CompiledModule, declarations: List[CompiledNativeProviderDeclaration]): /capy/lang/Option[CompiledNativeProviderDeclaration] =
    match declarations[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.providerName == function.name
            & declaration.sourceModuleName == module.name
            & declaration.sourceModulePath == module.path
        then /capy/lang/Option.Some { declaration }
        else python_find_native_provider_declaration(function, module, declarations[1:])

private fun python_native_provider_function_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, catalog: NativeProviderCatalog): String =
    match python_find_native_provider_binding(declaration, catalog.bindings) with
    case Some { binding } -> python_native_provider_binding_body(declaration, returnType, binding)
    case None -> python_native_provider_not_wired_body(declaration, returnType)

private fun python_native_provider_binding_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, binding: CompiledNativeProviderBinding): String =
    match binding.pythonBinding with
    case Some { backend } -> python_native_provider_bound_body(declaration, returnType, backend)
    case None -> python_native_provider_not_wired_body(declaration, returnType)

private fun python_find_native_provider_binding(declaration: CompiledNativeProviderDeclaration, bindings: List[CompiledNativeProviderBinding]): /capy/lang/Option[CompiledNativeProviderBinding] =
    match bindings[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.interfaceId == declaration.interfaceId & binding.qualifier == declaration.qualifier & python_native_provider_binding_has_python(binding)
        then /capy/lang/Option.Some { binding }
        else python_find_native_provider_binding(declaration, bindings[1:])

private fun python_native_provider_binding_has_python(binding: CompiledNativeProviderBinding): bool =
    match binding.pythonBinding with
    case Some _ -> true
    case None -> false

private fun python_native_provider_bound_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, backend: NativeProviderBackendBinding): String =
    let valueCode = python_native_provider_backend_value_code(backend)
    if valueCode.is_empty()
    then python_native_provider_not_wired_body(declaration, returnType)
    else if returnType.name == python_effect_type()
    then "    return Effect.delay(lambda: " + valueCode + ")" + python_newline()
    else "    return " + valueCode + python_newline()

private fun python_native_provider_backend_value_code(backend: NativeProviderBackendBinding): String =
    match backend.factory with
    case Some { factory } -> factory + "()"
    case None -> python_native_provider_backend_class_value_code(backend)

private fun python_native_provider_backend_class_value_code(backend: NativeProviderBackendBinding): String =
    match backend.moduleName with
    case Some { moduleName } -> python_native_provider_backend_export_value_code(moduleName, backend)
    case None -> python_native_provider_backend_class_name_value_code(backend)

private fun python_native_provider_backend_export_value_code(moduleName: String, backend: NativeProviderBackendBinding): String =
    match backend.exportName with
    case Some { exportName } -> python_native_provider_imported_export_call(moduleName, exportName)
    case None -> ""

private fun python_native_provider_backend_class_name_value_code(backend: NativeProviderBackendBinding): String =
    match backend.className with
    case Some { className } -> python_native_provider_class_call(className)
    case None -> ""

private fun python_native_provider_imported_export_call(moduleName: String, exportName: String): String =
    "getattr(__import__("
        + python_string_literal(moduleName)
        + ", fromlist=["
        + python_string_literal(exportName)
        + "]), "
        + python_string_literal(exportName)
        + ")()"

private fun python_native_provider_class_call(className: String): String =
    let separator = python_last_index_of(className, ".")
    if separator < 0
    then ""
    else python_native_provider_imported_export_call(className[0, separator], className[separator + 1, className.size().value])

private fun python_native_provider_not_wired_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference): String =
    let message = "NotWired: No native provider registered for interface `" + declaration.interfaceId + "` with qualifier `" + declaration.qualifier + "`."
    if returnType.name == python_effect_type()
    then "    return Effect.delay(lambda: __capy_unsupported(" + python_string_literal(message) + "))" + python_newline()
    else "    return __capy_unsupported(" + python_string_literal(message) + ")" + python_newline()

private fun python_function_parameters(function: CompiledFunction): String =
    if python_extension_method_function(function)
    then python_identifier("this") + python_method_parameter_tail(function.parameters)
    else python_parameters(function.parameters)

private fun python_method_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else ", " + python_parameters(parameters)

private fun python_function_bindings(function: CompiledFunction): List[PythonBinding] =
    if python_extension_method_function(function)
    then [PythonBinding {
            name: "this",
            pythonName: python_identifier("this"),
            typeName: python_method_owner_name(function.name)
        }]
        + python_parameter_bindings(function.parameters)
    else python_parameter_bindings(function.parameters)

private fun python_return_statement(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String, returnType: CompiledTypeReference): String =
    match expression with
    case CompiledBlockExpression block ->
        if returnType.name == python_effect_type() & python_effect_block(block)
        then indent + "return Effect.delay(lambda: ("
            + python_block_binding_expressions(block.bindings, env, module, allModules)
            + "_unsafe_run(" + python_expression_code(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules) + "))[-1])"
            + python_newline()
        else if returnType.name == python_result_type() & python_result_block(block, env, module, allModules)
        then python_result_block_return_statement(block, env, module, allModules, indent, returnType)
        else
            python_block_statements(block.bindings, env, module, allModules, indent)
            + indent + "return " + python_expression_code(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules) + python_newline()
    case _ -> indent + "return " + python_expression_code(expression, env, module, allModules) + python_newline()

private fun python_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> python_identifier(parameter.name) + python_parameter_tail(parameters[1:])

private fun python_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + python_identifier(parameter.name) + python_parameter_tail(parameters[1:])

private fun python_parameter_bindings(parameters: List[CompiledFunctionParameter]): List[PythonBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [PythonBinding {
            name: parameter.name,
            pythonName: python_identifier(parameter.name),
            typeName: parameter.typeReference.name
        }]
            + python_parameter_bindings(parameters[1:])

private fun python_expression_code(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledUnsupportedExpression unsupported ->
        if python_compiled_placeholder_source(unsupported.source)
        then "__capy_not_implemented(" + python_string_literal(python_placeholder_function_name(unsupported.source)) + ")"
        else "__capy_unsupported(" + python_string_literal(unsupported.source) + ")"
    case CompiledIntLiteral literal -> literal.source
    case CompiledLongLiteral literal -> python_long_literal(literal.source)
    case CompiledFloatLiteral literal -> python_decimal_literal(literal.source)
    case CompiledDoubleLiteral literal -> python_decimal_literal(literal.source)
    case CompiledBoolLiteral literal -> if literal.value then "True" else "False"
    case CompiledStringLiteral literal -> python_string_literal(literal.value)
    case CompiledVariableExpression variable -> python_variable_code(variable.name, env, module, allModules)
    case CompiledIfExpression ifExpression ->
        "(" + python_expression_code(ifExpression.thenBranch, env, module, allModules)
        + " if " + python_truthy_expression_code(ifExpression.condition, env, module, allModules)
        + " else " + python_expression_code(ifExpression.elseBranch, env, module, allModules)
        + ")"
    case CompiledBinaryExpression binary -> python_binary_expression_code(binary, env, module, allModules)
    case CompiledUnaryExpression unary -> python_unary_expression_code(unary, env, module, allModules)
    case CompiledFunctionCallExpression call -> python_function_call_code(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> python_function_call_name(reference.name, module, allModules)
    case CompiledMethodCallExpression call -> python_method_call_code(call, env, module, allModules)
    case CompiledWithExpression withExpression -> python_with_expression_code(withExpression, env, module, allModules)
    case CompiledLambdaExpression lambda -> python_lambda_expression_code(lambda, env, module, allModules)
    case CompiledListLiteral literal -> "[" + python_expression_list_code(literal.values, env, module, allModules) + "]"
    case CompiledSetLiteral literal -> python_set_literal_code(literal.values, env, module, allModules)
    case CompiledDictLiteral literal -> "{" + python_dict_entries_code(literal.entries, env, module, allModules) + "}"
    case CompiledTupleLiteral literal -> python_tuple_literal_code(literal.values, env, module, allModules)
    case CompiledIndexExpression index -> python_index_expression_code(index, env, module, allModules)
    case CompiledDataLiteral literal -> python_data_literal_code(literal, env, module, allModules)
    case CompiledFieldAccessExpression access -> python_field_access_code(access, env, module, allModules)
    case CompiledReduceExpression reduce -> python_reduce_expression_code(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> python_match_expression_code(matchExpression, env, module, allModules)
    case CompiledBlockExpression block -> python_block_expression_code(block, env, module, allModules)

private fun python_compiled_placeholder_source(source: String): bool =
    python_string_has_prefix(source, "__capy_placeholder__|")

private fun python_placeholder_function_name(source: String): String =
    if python_compiled_placeholder_source(source)
    then source["__capy_placeholder__|".size().value, source.size().value]
    else ""

private fun python_variable_code(name: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_lookup_binding(name, env) with
    case Some { binding } -> binding.pythonName
    case None ->
        if name == "receiver"
        then match python_lookup_binding("this", env) with
            case Some { binding } -> binding.pythonName
            case None -> python_unbound_variable_code(name, module, allModules)
        else python_unbound_variable_code(name, module, allModules)

private fun python_unbound_variable_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_qualified_enum_value_name(name, module, allModules)
    then python_enum_qualified_value_code(name, module, allModules)
    else match python_find_constant_binding_in_imports(name, module.imports, module, allModules) with
        case Some { binding } -> python_module_import_expression(binding.module) + "." + python_identifier(binding.function.name)
        case None ->
            match python_imported_stdlib_constant(name, module.imports) with
            case Some { value } -> value.pythonName
            case None -> python_identifier(name)

private fun python_binary_expression_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = python_expression_type(binary.left, env, module, allModules)
    if python_result_reduce_operator_expression_with_left_type(binary, leftType)
    then python_result_reduce_operator_code(binary, env, module, allModules)
    else if python_result_pipe_expression_with_left_type(binary, leftType)
    then python_result_pipe_code(binary, env, module, allModules)
    else if python_option_pipe_expression_with_left_type(binary, leftType)
    then python_option_pipe_code(binary, env, module, allModules)
    else if python_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then python_method_call_code(python_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if python_collection_pipe_expression_with_left_type(binary, leftType)
    then python_collection_pipe_code(binary, env, module, allModules)
    else if python_regex_binary_expression_with_left_type(binary, leftType)
    then python_regex_binary_code(binary, env, module, allModules)
    else if python_binary_extension_operator_expression_with_left_type(binary, leftType, module, allModules)
    then python_binary_extension_operator_code_with_left_type(binary, leftType, env, module, allModules)
    else if python_set_binary_expression_with_left_type(binary, leftType)
    then python_set_binary_code(binary, env, module, allModules)
    else if python_string_concat_expression(binary, leftType, env, module, allModules)
    then "(" + python_expression_code(binary.left, env, module, allModules)
        + " + "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"
    else if binary.operator == ".nand."
    then "(~(" + python_expression_code(binary.left, env, module, allModules)
        + " & "
        + python_expression_code(binary.right, env, module, allModules)
        + "))"
    else if python_bitwise_binary_operator(binary.operator)
    then "(" + python_expression_code(binary.left, env, module, allModules)
        + " " + python_bitwise_operator(binary.operator) + " "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"
    else if binary.operator == "&" | binary.operator == "|"
    then "(" + python_truthy_expression_code(binary.left, env, module, allModules)
        + " " + python_boolean_operator(binary.operator) + " "
        + python_truthy_expression_code(binary.right, env, module, allModules)
        + ")"
    else match python_binary_runtime_helper(binary.operator) with
    case Some { helper } -> python_binary_runtime_call(helper, binary, env, module, allModules)
    case None -> "(" + python_expression_code(binary.left, env, module, allModules)
        + " " + binary.operator + " "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"

private fun python_string_concat_expression(binary: CompiledBinaryExpression, leftType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    binary.operator == "+"
        & leftType == python_string_type()
        & python_expression_type(binary.right, env, module, allModules) == python_string_type()

private fun python_binary_extension_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_binary_extension_operator_code_with_left_type(binary: CompiledBinaryExpression, leftType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } ->
        python_function_name(function)
            + "("
            + python_expression_code(binary.left, env, module, allModules)
            + python_extension_method_argument_tail([binary.right], env, module, allModules)
            + ")"
    case None -> "__capy_unsupported('extension operator')"

private fun python_binary_runtime_call(name: String, binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let code = name
        + "("
        + python_expression_code(binary.left, env, module, allModules)
        + ", "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"
    if python_long_binary_expression(binary, env, module, allModules)
    then "__capy_long(" + code + ")"
    else code

private fun python_binary_runtime_helper(operator: String): /capy/lang/Option[String] =
    if operator == "+"
    then Some { "__capy_add" }
    else if operator == "-"
    then Some { "__capy_sub" }
    else if operator == "*"
    then Some { "__capy_mul" }
    else if operator == "/"
    then Some { "__capy_div" }
    else if operator == "^"
    then Some { "__capy_pow" }
    else if operator == "%"
    then Some { "__capy_mod" }
    else if operator == "?"
    then Some { "__capy_contains" }
    else /capy/lang/Option.None {}

private fun python_binary_runtime_operator(operator: String): bool =
    match python_binary_runtime_helper(operator) with
    case Some _ -> true
    case None -> false

private fun python_long_binary_expression(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_expression_type(binary, env, module, allModules) == python_long_type()

private fun python_boolean_operator(operator: String): String =
    if operator == "&" then "and" else "or"

private fun python_bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

private fun python_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

private fun python_unary_expression_code(unary: CompiledUnaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(not " + python_truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then "(~" + python_expression_code(unary.expression, env, module, allModules) + ")"
    else "(" + unary.operator + python_expression_code(unary.expression, env, module, allModules) + ")"

private fun python_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_stdlib_effect_function_call(call, module)
    then python_stdlib_effect_function_call_code(call.name)
    else if python_stdlib_parse_function_call(call, module)
    then python_stdlib_parse_function_call_code(call, env, module, allModules)
    else if python_stdlib_path_function_call(call, module)
    then python_stdlib_path_function_call_code(call, env, module, allModules)
    else if python_stdlib_io_function_call(call, module)
    then python_stdlib_io_function_call_code(call, env, module, allModules)
    else if python_reflection_function_call(call)
    then python_reflection_function_call_code(call, env, module, allModules)
    else if python_object_type_function_call(call, module, allModules)
    then python_object_type_function_call_code(call, module, allModules)
    else if python_object_constructor_call(call, module, allModules)
    then python_object_constructor_call_code(call, env, module, allModules)
    else if python_partial_function_call(call)
    then
        let names = python_partial_placeholder_names(call.arguments, env)
        "lambda " + python_lambda_parameters(names) + ": "
            + python_function_call_name(call.name, module, allModules)
            + "(" + python_partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"
    else if python_enum_parse_call(call, module, allModules)
    then python_enum_parse_call_code(call, env, module, allModules)
    else
        let resolvedName =
            if python_local_function_count(call.name, module.functions) > 1 & python_one_method_argument(call.arguments)
            then
                let argumentType = python_first_method_argument_type(call.arguments, env, module, allModules)
                if argumentType == python_unknown_type()
                then python_function_call_name(call.name, module, allModules)
                else match python_find_local_overload_in_module(call.name, argumentType, module, allModules) with
                case Some { function } -> python_function_name(function)
                case None -> python_function_call_name(call.name, module, allModules)
            else python_function_call_name(call.name, module, allModules)
        resolvedName + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_reflection_function_call(call: CompiledFunctionCallExpression): bool =
    call.name == "reflection" & python_one_method_argument(call.arguments)

private fun python_reflection_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let valueCode = python_first_method_argument_code(call.arguments, env, module, allModules)
    let typeName = python_first_method_argument_type(call.arguments, env, module, allModules)
    if python_reflection_static_type(typeName, module, allModules)
    then "reflection(" + valueCode + ", " + python_string_literal(python_type_unqualified_name(typeName)) + ")"
    else "reflection(" + valueCode + ")"

private fun python_reflection_static_type(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    !typeName.is_empty()
        & typeName != python_unknown_type()
        & typeName != "data"
        & typeName != "enum"
        & !python_enum_type_exists(typeName, module, allModules)

private fun python_field_access_code(access: CompiledFieldAccessExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(access.receiver, env, module, allModules)
    if python_enum_static_field_access(access, env, module, allModules)
    then python_enum_static_field_access_code(access, module, allModules)
    else if python_this_field_access(access, env, allModules)
    then python_expression_code(access.receiver, env, module, allModules) + "." + python_identifier(access.name)
    else if access.name == "value" & python_primitive_backed_type(receiverType, module, allModules)
    then python_expression_code(access.receiver, env, module, allModules)
    else "__capy_get_field(" + python_expression_code(access.receiver, env, module, allModules) + ", " + python_string_literal(access.name) + ")"

private fun python_this_field_access(access: CompiledFieldAccessExpression, env: List[PythonBinding], allModules: List[CompiledModule]): bool =
    match access.receiver with
    case CompiledVariableExpression variable ->
        if variable.name == "this"
        then python_this_binding_is_object(variable.name, env, allModules)
        else false
    case _ -> false

private fun python_this_binding_is_object(name: String, env: List[PythonBinding], allModules: List[CompiledModule]): bool =
    match python_lookup_binding(name, env) with
    case Some { binding } -> {
        match python_find_object_class_by_type(binding.typeName, allModules) with
        case Some _ -> true
        case None -> false
    }
    case None -> false

private fun python_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    let receiver = python_expression_code(call.receiver, env, module, allModules)
    if python_partial_method_call(call)
    then
        let names = python_partial_placeholder_names(call.arguments, env)
        "lambda " + python_lambda_parameters(names) + ": "
            + python_partial_method_call_body_code(call, receiverType, receiver, names, env, module, allModules)
    else if call.name == "__capy_call"
    then python_callable_call_code(call, env, module, allModules)
    else if python_effect_method_call(call, receiverType)
    then python_effect_method_call_code(call, env, module, allModules)
    else if python_result_method_call(call, receiverType)
    then python_result_method_call_code(call, env, module, allModules)
    else if python_option_method_call(call, receiverType)
    then python_option_pipe_code(python_option_method_binary(call), env, module, allModules)
    else if call.name == "size" & call.arguments.is_empty()
    then "__capy_size(" + receiver + ")"
    else if python_enum_name_method_call(call, receiverType, module, allModules)
    then "__capy_enum_name(" + receiver + ")"
    else if python_char_to_string_method_call(call, receiverType)
    then "__capy_to_string(" + receiver + ")"
    else if python_string_get_method_call(call, receiverType)
    then python_string_get_method_code(call, env, module, allModules)
    else if python_string_parse_method_call(call, receiverType)
    then python_string_parse_method_code(call, env, module, allModules)
    else if python_string_method_call(call, receiverType)
    then python_string_method_code(call, env, module, allModules)
    else if python_regex_method_call(call, receiverType)
    then python_regex_method_call_code(call, env, module, allModules)
    else if python_stdlib_date_time_method_call(call, env, module, allModules)
    then python_stdlib_date_time_method_call_code(call, env, module, allModules)
    else if python_set_method_call(call, receiverType)
    then python_set_method_call_code(call, env, module, allModules)
    else if python_collection_reduce_method_call(call, receiverType)
    then python_collection_reduce_method_code(call, receiverType, env, module, allModules)
    else if python_collection_method_call(call, receiverType)
    then python_collection_pipe_code(python_collection_method_binary(call), env, module, allModules)
    else if python_native_collection_method_call_with_receiver_type(call, receiverType)
    then python_native_collection_method_call_code(call, receiverType, receiver, env, module, allModules)
    else if python_seq_as_list_call(call)
    then "__capy_as_list(" + receiver + ")"
    else if python_seq_first_call(call, receiverType)
    then "__capy_index(__capy_as_list(" + receiver + "), 0)"
    else if python_collection_predicate_call(call, receiverType)
    then python_collection_predicate_call_code(call, env, module, allModules)
    else if python_primitive_conversion_method_call(call, receiverType)
    then python_primitive_conversion_method_code(call, env, module, allModules)
    else if python_object_type_method_call(call, env, module, allModules)
    then python_object_type_method_call_code(call, module, allModules)
    else if python_object_method_call(call, env, module, allModules)
    then python_object_method_call_code(call, env, module, allModules)
    else match python_find_extension_method(call, env, module, allModules) with
        case Some { function } -> python_extension_method_call_code(function, call, env, module, allModules)
        case None ->
            receiver + "." + python_method_name(call.name)
                + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_object_constructor_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_object_class_in_scope(call.name, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_object_constructor_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_class_in_scope(call.name, module, allModules) with
    case Some { binding } ->
        "Effect.delay(lambda: " + python_object_class_reference(binding, module)
            + "(" + python_expression_list_code(call.arguments, env, module, allModules) + "))"
    case None -> python_function_call_name(call.name, module, allModules)
        + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_object_type_method_call(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "type"
        & call.arguments.is_empty()
        & match call.receiver with
            case CompiledVariableExpression variable ->
                !python_binding_exists(variable.name, env)
                    & python_object_type_receiver_name(variable.name, module, allModules)
            case _ -> false

private fun python_object_type_method_call_code(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledVariableExpression variable -> python_object_type_call_code_for_name(variable.name, module, allModules)
    case _ -> "__capy_unsupported('COO type')"

private fun python_object_type_function_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_qualified_name(call.name)
        & python_qualified_call_member(call.name) == "type"
        & call.arguments.is_empty()
        & python_object_type_receiver_name(python_object_type_function_receiver_name(call.name), module, allModules)

private fun python_object_type_function_call_code(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    python_object_type_call_code_for_name(python_object_type_function_receiver_name(call.name), module, allModules)

private fun python_object_type_function_receiver_name(name: String): String =
    let idx = python_last_dot_index(name)
    if idx < 0 then name else name[0, idx]

private fun python_object_type_receiver_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_object_class_in_scope(name, module, allModules) with
    case Some _ -> true
    case None ->
        match python_find_object_interface_module_in_scope(name, module, allModules) with
        case Some _ -> true
        case None -> false

private fun python_object_type_call_code_for_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_class_in_scope(name, module, allModules) with
    case Some { binding } -> python_object_class_reference(binding, module) + ".type()"
    case None ->
        match python_find_object_interface_module_in_scope(name, module, allModules) with
        case Some { owner } -> python_object_interface_info_literal(python_object_interface_member_name(name), owner, allModules)
        case None -> "__capy_unsupported('COO type')"

private fun python_object_method_call(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_find_object_method(call, env, module, allModules) with
    case Some _ -> true
    case None -> false

private fun python_object_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_method(call, env, module, allModules) with
    case Some _ ->
        "Effect.delay(lambda: "
            + python_expression_code(call.receiver, env, module, allModules)
            + "." + python_method_name(call.name)
            + "(" + python_expression_list_code(call.arguments, env, module, allModules) + "))"
    case None ->
        python_expression_code(call.receiver, env, module, allModules)
            + "." + python_method_name(call.name)
            + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_callable_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "(" + python_expression_code(call.receiver, env, module, allModules) + ")(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_partial_function_call(call: CompiledFunctionCallExpression): bool =
    python_arguments_contain_placeholder(call.arguments)

private fun python_partial_method_call(call: CompiledMethodCallExpression): bool =
    python_arguments_contain_placeholder(call.arguments)

private fun python_arguments_contain_placeholder(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { expression } -> python_partial_placeholder_expression(expression) | python_arguments_contain_placeholder(arguments[1:])

private fun python_partial_placeholder_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledUnsupportedExpression unsupported -> python_compiled_placeholder_source(unsupported.source)
    case _ -> false

private fun python_partial_method_call_body_code(call: CompiledMethodCallExpression, receiverType: String, receiver: String, names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "__capy_call"
    then "(" + receiver + ")(" + python_partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"
    else if python_string_method_call(call, receiverType)
    then python_partial_string_method_call_body_code(call, receiver, names, env, module, allModules)
    else receiver + "." + python_method_name(call.name)
        + "(" + python_partial_expression_list_code(call.arguments, names, env, module, allModules) + ")"

private fun python_partial_string_method_call_body_code(call: CompiledMethodCallExpression, receiver: String, names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_string_method_body_code(
        call.name,
        receiver,
        python_partial_expression_at_code(call.arguments, 0, names, env, module, allModules),
        python_partial_expression_at_code(call.arguments, 1, names, env, module, allModules)
    )

private fun python_partial_expression_at_code(expressions: List[CompiledExpression], target: int, names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        if target == 0
        then python_partial_expression_code(expression, names, env, module, allModules)
        else python_partial_expression_at_code(expressions[1:], target - 1, python_partial_remaining_names(expression, names), env, module, allModules)

private fun python_partial_expression_list_code(expressions: List[CompiledExpression], names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        python_partial_expression_code(expression, names, env, module, allModules)
            + python_partial_expression_list_tail_code(expressions[1:], python_partial_remaining_names(expression, names), env, module, allModules)

private fun python_partial_expression_list_tail_code(expressions: List[CompiledExpression], names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", "
            + python_partial_expression_code(expression, names, env, module, allModules)
            + python_partial_expression_list_tail_code(expressions[1:], python_partial_remaining_names(expression, names), env, module, allModules)

private fun python_partial_expression_code(expression: CompiledExpression, names: List[String], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_partial_placeholder_expression(expression)
    then python_partial_argument_name(names)
    else python_expression_code(expression, env, module, allModules)

private fun python_partial_remaining_names(expression: CompiledExpression, names: List[String]): List[String] =
    if python_partial_placeholder_expression(expression)
    then names[1:]
    else names

private fun python_partial_argument_name(names: List[String]): String =
    match names[0] with
    case Some { name } -> python_identifier(name)
    case None -> "__capy_missing_partial"

private fun python_partial_placeholder_names(arguments: List[CompiledExpression], env: List[PythonBinding]): List[String] =
    python_partial_placeholder_names_with_used(arguments, env, [])

private fun python_partial_placeholder_names_with_used(arguments: List[CompiledExpression], env: List[PythonBinding], used: List[String]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { expression } ->
        if python_partial_placeholder_expression(expression)
        then
            let name = python_available_partial_parameter_name(used, env, 1)
            [name] + python_partial_placeholder_names_with_used(arguments[1:], env, [name] + used)
        else python_partial_placeholder_names_with_used(arguments[1:], env, used)

private fun python_available_partial_parameter_name(used: List[String], env: List[PythonBinding], idx: int): String =
    let name = "capybaraPartial" + idx
    if python_binding_exists(name, env) | python_string_list_contains(name, used)
    then python_available_partial_parameter_name(used, env, idx + 1)
    else name

private fun python_enum_name_method_call(call: CompiledMethodCallExpression, receiverType: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    call.name == "name"
        & call.arguments.is_empty()
        & (receiverType == python_unknown_type() | receiverType == "enum" | python_enum_type_exists(receiverType, module, allModules))

private fun python_effect_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    (call.name == "map" | call.name == "flat_map")
        & receiverType == python_effect_type()
        & python_single_callable_argument(call.arguments)

private fun python_effect_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let methodName = if call.name == "flat_map" then "flat_map" else "map"
    python_expression_code(call.receiver, env, module, allModules)
        + "." + methodName
        + "(" + python_expression_list_code(call.arguments, env, module, allModules) + ")"

private fun python_result_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    if call.name == "map" | call.name == "flat_map"
    then python_result_pipe_receiver_type(receiverType)
        & python_single_callable_argument(call.arguments)
    else if call.name == "or" | call.name == "or_else"
    then python_result_pipe_receiver_type(receiverType)
        & python_one_method_argument(call.arguments)
    else if call.name == "reduce" | call.name == "reduce_left"
    then python_result_pipe_receiver_type(receiverType)
        & python_two_callable_arguments(call.arguments)
    else false

private fun python_result_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "or"
    then "__capy_result_or("
        + python_expression_code(call.receiver, env, module, allModules)
        + ", "
        + python_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"
    else if call.name == "or_else"
    then "__capy_result_or_else("
        + python_expression_code(call.receiver, env, module, allModules)
        + ", "
        + python_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"
    else if call.name == "reduce" | call.name == "reduce_left"
    then "__capy_result_reduce("
        + python_expression_code(call.receiver, env, module, allModules)
        + ", "
        + python_result_reduce_success_callable_code(call.receiver, call.arguments, env, module, allModules)
        + ", "
        + python_result_reduce_error_callable_code(call.arguments, env, module, allModules)
        + ")"
    else python_result_method_helper(call.name)
            + "("
            + python_expression_code(call.receiver, env, module, allModules)
            + ", "
            + python_result_callable_argument_code(call.receiver, call.arguments, env, module, allModules)
            + ")"

private fun python_result_method_helper(name: String): String =
    if name == "flat_map"
    then "__capy_result_flat_map"
    else "__capy_result_map"

private fun python_option_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    python_option_method_name(call.name)
        & python_option_pipe_receiver_type(receiverType)
        & python_single_callable_argument(call.arguments)

private fun python_option_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "flat_map"

private fun python_option_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    match call.arguments[0] with
    case None ->
        CompiledBinaryExpression {
            operator: python_option_method_operator(call.name),
            left: call.receiver,
            right: python_missing_argument(),
            location: call.location
        }
    case Some { argument } ->
        CompiledBinaryExpression {
            operator: python_option_method_operator(call.name),
            left: call.receiver,
            right: argument,
            location: call.location
        }

private fun python_option_method_operator(name: String): String =
    if name == "filter"
    then "|-"
    else if name == "flat_map"
    then "|*"
    else "|"

private fun python_collection_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    python_collection_method_name(call.name)
        & python_collection_pipe_receiver_type(receiverType)
        & python_single_callable_argument(call.arguments)

private fun python_collection_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "`|-`" | name == "reject" | name == "flat_map"

private fun python_collection_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    match call.arguments[0] with
    case None ->
        CompiledBinaryExpression {
            operator: python_collection_method_operator(call.name),
            left: call.receiver,
            right: python_missing_argument(),
            location: call.location
        }
    case Some { argument } ->
        CompiledBinaryExpression {
            operator: python_collection_method_operator(call.name),
            left: call.receiver,
            right: argument,
            location: call.location
        }

private fun python_collection_method_operator(name: String): String =
    if name == "filter" | name == "`|-`"
    then "|-"
    else if name == "reject"
    then "|!"
    else if name == "flat_map"
    then "|*"
    else "|"

private fun python_collection_reduce_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    (call.name == "reduce" | call.name == "reduce_left")
        & python_collection_pipe_receiver_type(receiverType)
        & match call.arguments[0] with
            case None -> false
            case Some _ ->
                match call.arguments[1] with
                case None -> false
                case Some { reducer } ->
                    call.arguments[2:].is_empty()
                        & match reducer with
                            case CompiledLambdaExpression lambda -> python_collection_reduce_lambda_parameters_supported(lambda.parameters, receiverType)
                            case CompiledFunctionReferenceExpression _ -> true
                            case _ -> false

private fun python_collection_reduce_lambda_parameters_supported(parameters: List[String], receiverType: String): bool =
    if receiverType == python_dict_type()
    then python_reduce_lambda_arity_supported(parameters, 3)
    else python_reduce_lambda_arity_supported(parameters, 2)

private fun python_reduce_lambda_arity_supported(parameters: List[String], arity: int): bool =
    if arity == 0
    then parameters.is_empty()
    else match parameters[0] with
        case None -> false
        case Some _ -> python_reduce_lambda_arity_supported(parameters[1:], arity - 1)

private fun python_collection_reduce_method_code(call: CompiledMethodCallExpression, receiverType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None ->
        "__capy_unsupported('collection reduce')"
    case Some { initial } ->
        match call.arguments[1] with
        case None -> "__capy_unsupported('collection reduce')"
        case Some { reducer } ->
            match reducer with
            case CompiledLambdaExpression lambda ->
                let accumulatorName = python_lambda_parameter_at(lambda.parameters, 0)
                let keyName = python_reduce_key_parameter(lambda.parameters, receiverType)
                let valueName = python_reduce_value_parameter(lambda.parameters, receiverType)
                python_collection_reduce_method_lambda_code(call.receiver, initial, lambda.body, accumulatorName, keyName, valueName, env, module, allModules)
            case CompiledFunctionReferenceExpression reference ->
                python_collection_reduce_method_callable_code(call.receiver, initial, reference, receiverType, env, module, allModules)
            case _ -> "__capy_unsupported('collection reduce')"

private fun python_collection_reduce_method_lambda_code(receiver: CompiledExpression, initial: CompiledExpression, body: CompiledExpression, accumulatorName: String, keyName: String, valueName: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = python_reduce_bindings_from_names(accumulatorName, keyName, valueName, env)
    let keyed = if keyName.is_empty() then "False" else "True"
    "__capy_reduce("
        + python_expression_code(receiver, env, module, allModules)
        + ", "
        + python_expression_code(initial, env, module, allModules)
        + ", "
        + keyed
        + ", lambda "
        + python_reduce_parameters_from_names(accumulatorName, keyName, valueName)
        + ": "
        + python_expression_code(body, reduceEnv, module, allModules)
        + ")"

private fun python_collection_reduce_method_callable_code(receiver: CompiledExpression, initial: CompiledExpression, reducer: CompiledExpression, receiverType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let keyed = if receiverType == python_dict_type() then "True" else "False"
    "__capy_reduce("
        + python_expression_code(receiver, env, module, allModules)
        + ", "
        + python_expression_code(initial, env, module, allModules)
        + ", "
        + keyed
        + ", "
        + python_expression_code(reducer, env, module, allModules)
        + ")"

private fun python_reduce_parameters_from_names(accumulatorName: String, keyName: String, valueName: String): String =
    if keyName.is_empty()
    then python_identifier(accumulatorName) + ", " + python_identifier(valueName)
    else python_identifier(accumulatorName) + ", " + python_identifier(keyName) + ", " + python_identifier(valueName)

private fun python_reduce_bindings_from_names(accumulatorName: String, keyName: String, valueName: String, env: List[PythonBinding]): List[PythonBinding] =
    if keyName.is_empty()
    then [
            PythonBinding { name: accumulatorName, pythonName: python_identifier(accumulatorName), typeName: python_unknown_type() },
            PythonBinding { name: valueName, pythonName: python_identifier(valueName), typeName: python_unknown_type() },
        ] + env
    else [
            PythonBinding { name: accumulatorName, pythonName: python_identifier(accumulatorName), typeName: python_unknown_type() },
            PythonBinding { name: keyName, pythonName: python_identifier(keyName), typeName: python_unknown_type() },
            PythonBinding { name: valueName, pythonName: python_identifier(valueName), typeName: python_unknown_type() },
        ] + env

private fun python_reduce_key_parameter(parameters: List[String], receiverType: String): String =
    if receiverType == python_dict_type()
    then python_lambda_parameter_at(parameters, 1)
    else ""

private fun python_reduce_value_parameter(parameters: List[String], receiverType: String): String =
    if receiverType == python_dict_type()
    then python_lambda_parameter_at(parameters, 2)
    else python_lambda_parameter_at(parameters, 1)

private fun python_lambda_parameter_at(parameters: List[String], target: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if target == 0
        then parameter
        else python_lambda_parameter_at(parameters[1:], target - 1)

private fun python_result_reduce_success_callable_code(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> "__capy_unsupported('result reduce success mapper')"
    case Some { argument } -> python_result_callable_code(receiver, argument, env, module, allModules)

private fun python_result_reduce_error_callable_code(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[1] with
    case None -> "__capy_unsupported('result reduce error mapper')"
    case Some { argument } -> python_result_error_callable_code(argument, env, module, allModules)

private fun python_result_error_callable_code(mapper: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match mapper with
    case CompiledLambdaExpression lambda ->
        python_lambda_expression_code_with_bindings(
            lambda,
            python_lambda_bindings_with_single_type(lambda.parameters, python_string_type()),
            env,
            module,
            allModules
        )
    case _ -> python_expression_code(mapper, env, module, allModules)

private fun python_extension_method_call_code(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_function_name(function)
        + "("
        + python_expression_code(call.receiver, env, module, allModules)
        + python_extension_method_argument_tail(call.arguments, env, module, allModules)
        + ")"

private fun python_extension_method_argument_tail(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + python_expression_list_code(arguments, env, module, allModules)

private fun python_option_pipe_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_option_pipe_helper(binary.operator)
        + "("
        + python_expression_code(binary.left, env, module, allModules)
        + ", "
        + python_expression_code(binary.right, env, module, allModules)
        + ")"

private fun python_option_pipe_helper(operator: String): String =
    if operator == "|-"
    then "__capy_option_filter"
    else if operator == "|*"
    then "__capy_option_flat_map"
    else "__capy_option_map"

private fun python_collection_pipe_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledLambdaExpression lambda ->
        python_collection_pipe_helper(binary.operator)
            + "("
            + python_expression_code(binary.left, env, module, allModules)
            + ", "
            + python_lambda_expression_code(lambda, env, module, allModules)
            + ")"
    case CompiledFunctionReferenceExpression reference ->
        python_collection_pipe_helper(binary.operator)
            + "("
            + python_expression_code(binary.left, env, module, allModules)
            + ", "
            + python_expression_code(reference, env, module, allModules)
            + ")"
    case _ -> "__capy_unsupported('collection pipe')"

private fun python_collection_pipe_helper(operator: String): String =
    if operator == "|-"
    then "__capy_seq_filter"
    else if operator == "|!"
    then "__capy_seq_reject"
    else if operator == "|*"
    then "__capy_seq_flat_map"
    else "__capy_seq_map"

private fun python_collection_pipe_chained_method_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    python_collection_pipe_operator(binary.operator)
        & python_collection_pipe_receiver_type(leftType)
        & match binary.right with
            case CompiledMethodCallExpression call -> python_callable_expression(call.receiver)
            case _ -> false

private fun python_collection_pipe_chained_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    match binary.right with
    case CompiledMethodCallExpression call ->
        CompiledMethodCallExpression {
            receiver: CompiledBinaryExpression {
                operator: binary.operator,
                left: binary.left,
                right: call.receiver,
                location: binary.location
            },
            name: call.name,
            arguments: call.arguments,
            location: call.location
        }
    case _ -> CompiledMethodCallExpression {
        receiver: binary,
        name: "",
        arguments: [],
        location: binary.location
    }

private fun python_result_pipe_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_result_pipe_helper(binary.operator)
        + "("
        + python_expression_code(binary.left, env, module, allModules)
        + ", "
        + python_result_callable_code(binary.left, binary.right, env, module, allModules)
        + ")"

private fun python_result_reduce_operator_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledTupleLiteral literal ->
        "__capy_result_reduce("
            + python_expression_code(binary.left, env, module, allModules)
            + ", "
            + python_result_reduce_success_callable_code(binary.left, literal.values, env, module, allModules)
            + ", "
            + python_result_reduce_error_callable_code(literal.values, env, module, allModules)
            + ")"
    case _ -> "__capy_unsupported('result reduce')"

private fun python_result_pipe_helper(operator: String): String =
    if operator == "|*"
    then "__capy_result_flat_map"
    else "__capy_result_map"

private fun python_result_callable_argument_code(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> python_result_callable_code(receiver, argument, env, module, allModules)

private fun python_result_callable_code(receiver: CompiledExpression, mapper: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match mapper with
    case CompiledLambdaExpression lambda ->
        python_lambda_expression_code_with_bindings(
            lambda,
            python_lambda_bindings_with_single_type(lambda.parameters, python_result_payload_type(receiver, env, module, allModules)),
            env,
            module,
            allModules
        )
    case _ -> python_expression_code(mapper, env, module, allModules)

private fun python_collection_predicate_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None -> "__capy_unsupported('collection predicate')"
    case Some { predicate } ->
        python_collection_predicate_helper(call.name)
            + "("
            + python_expression_code(call.receiver, env, module, allModules)
            + ", "
            + python_expression_code(predicate, env, module, allModules)
            + ")"

private fun python_collection_predicate_helper(name: String): String =
    if name == "all" then "__capy_all" else "__capy_any"

private fun python_set_binary_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    leftType == python_set_type() & python_set_binary_operator(binary.operator)

private fun python_set_binary_operator(operator: String): bool =
    python_set_predicate_operator(operator) | python_set_algebra_operator(operator)

private fun python_set_predicate_operator(operator: String): bool =
    operator == "⊆" | operator == "⊂" | operator == "⊇" | operator == "⊃"

private fun python_set_algebra_operator(operator: String): bool =
    operator == "∪" | operator == "∩" | operator == "△" | operator == "×"

private fun python_set_binary_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = python_expression_code(binary.left, env, module, allModules)
    let rightCode = python_expression_code(binary.right, env, module, allModules)
    if binary.operator == "⊆"
    then "__capy_set_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊂"
    then "__capy_set_proper_subset(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "⊇"
    then "__capy_set_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "⊃"
    then "__capy_set_proper_subset(" + rightCode + ", " + leftCode + ")"
    else if binary.operator == "∪"
    then "__capy_set_concat(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "∩"
    then "__capy_set_intersection(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "△"
    then "__capy_set_symmetric_difference(" + leftCode + ", " + rightCode + ")"
    else "__capy_set_cartesian_product(" + leftCode + ", " + rightCode + ")"

private fun python_regex_binary_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    python_regex_receiver_type(leftType) & python_regex_binary_operator(binary.operator)

private fun python_regex_binary_operator(operator: String): bool =
    operator == "?" | operator == "~" | operator == "~~" | operator == "~>" | operator == "/>"

private fun python_regex_binary_code(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = python_expression_code(binary.left, env, module, allModules)
    let rightCode = python_expression_code(binary.right, env, module, allModules)
    if binary.operator == "?"
    then "__capy_regex_matches(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~"
    then "__capy_regex_find(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~~"
    then "__capy_regex_find_all(" + leftCode + ", " + rightCode + ")"
    else if binary.operator == "~>"
    then "__capy_regex_replace(" + leftCode + ", " + rightCode + ")"
    else "__capy_regex_split(" + leftCode + ", " + rightCode + ")"

private fun python_regex_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    python_regex_receiver_type(receiverType) & python_regex_method_arity(call)

private fun python_regex_method_arity(call: CompiledMethodCallExpression): bool =
    python_regex_method_name(call.name) & python_one_method_argument(call.arguments)

private fun python_regex_method_name(name: String): bool =
    name == "matches" | name == "find" | name == "find_all" | name == "replace" | name == "split"

private fun python_regex_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = python_expression_code(call.receiver, env, module, allModules)
    let argumentCode = python_first_method_argument_code(call.arguments, env, module, allModules)
    if call.name == "matches"
    then "__capy_regex_matches(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find"
    then "__capy_regex_find(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "find_all"
    then "__capy_regex_find_all(" + receiverCode + ", " + argumentCode + ")"
    else if call.name == "replace"
    then "__capy_regex_replace(" + receiverCode + ", " + argumentCode + ")"
    else "__capy_regex_split(" + receiverCode + ", " + argumentCode + ")"

private fun python_regex_receiver_type(typeName: String): bool =
    typeName == python_regex_type()
        | typeName == "/capy/lang/Regex"
        | typeName == "capy/lang/Regex"
        | typeName == "capy.lang.Regex"

private fun python_stdlib_date_time_method_call(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_stdlib_date_time_method(python_type_unqualified_name(python_expression_type(call.receiver, env, module, allModules)), call.name, call.arguments, env, module, allModules)

private fun python_stdlib_date_time_method(receiver: String, methodName: String, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if receiver == "Date"
    then if methodName == "add_days"
        then python_one_method_argument(arguments)
        else if methodName == "add_years_months"
        then python_two_method_arguments(arguments)
        else (methodName == "to_days_since_unix_epoch" | methodName == "to_iso_8601") & arguments.is_empty()
    else if receiver == "Time"
    then if methodName == "add_seconds"
        then python_one_method_argument(arguments)
        else (methodName == "to_seconds" | methodName == "to_iso_8601") & arguments.is_empty()
    else if receiver == "DateTime"
    then if methodName == "plus"
        then python_one_method_argument(arguments)
        else if methodName == "minus"
        then python_one_method_argument(arguments)
        else (methodName == "to_iso_8601" | methodName == "timestamp") & arguments.is_empty()
    else if receiver == "Duration" | receiver == "DateDuration" | receiver == "WeekDuration"
    then if methodName == "to_iso_8601" | methodName == "negate" | methodName == "years" | methodName == "months" | methodName == "days" | methodName == "hours" | methodName == "minutes" | methodName == "seconds"
        then arguments.is_empty()
        else false
    else false

private fun python_stdlib_date_time_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_type_unqualified_name(python_expression_type(call.receiver, env, module, allModules))
    let receiver = python_expression_code(call.receiver, env, module, allModules)
    if receiverType == "Date"
    then python_stdlib_date_method_call_code(call, receiver, env, module, allModules)
    else if receiverType == "Time"
    then python_stdlib_time_method_call_code(call, receiver, env, module, allModules)
    else if receiverType == "DateTime"
    then python_stdlib_date_time_value_method_call_code(call, receiver, env, module, allModules)
    else python_stdlib_duration_method_call_code(call, receiver)

private fun python_stdlib_date_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "add_days"
    then "__capy_date_add_days(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "add_years_months"
    then "__capy_date_add_years_months(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ", " + python_second_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "to_days_since_unix_epoch"
    then "__capy_date_to_days_since_unix_epoch(" + receiver + ")"
    else "__capy_date_to_iso_8601(" + receiver + ")"

private fun python_stdlib_time_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "add_seconds"
    then "__capy_time_add_seconds(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "to_seconds"
    then "__capy_time_to_seconds(" + receiver + ")"
    else "__capy_time_to_iso_8601(" + receiver + ")"

private fun python_stdlib_date_time_value_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "plus"
    then "__capy_date_time_plus(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "minus"
    then "__capy_date_time_minus(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "timestamp"
    then "__capy_date_time_timestamp(" + receiver + ")"
    else "__capy_date_time_to_iso_8601(" + receiver + ")"

private fun python_stdlib_duration_method_call_code(call: CompiledMethodCallExpression, receiver: String): String =
    if call.name == "to_iso_8601"
    then "__capy_duration_to_iso_8601(" + receiver + ")"
    else if call.name == "negate"
    then "__capy_duration_negate(" + receiver + ")"
    else "__capy_duration_" + call.name + "(" + receiver + ")"

private fun python_set_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    receiverType == python_set_type() & python_set_method_arity(call)

private fun python_set_method_arity(call: CompiledMethodCallExpression): bool =
    if python_set_no_argument_method(call.name)
    then call.arguments.is_empty()
    else if python_set_one_argument_method(call.name)
    then python_one_method_argument(call.arguments)
    else false

private fun python_set_no_argument_method(name: String): bool =
    name == "power_set" | name == "℘"

private fun python_set_one_argument_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"
        | name == "union" | name == "intersection" | name == "difference"
        | name == "symmetric_difference" | name == "cartesian_product"

private fun python_set_method_call_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = python_expression_code(call.receiver, env, module, allModules)
    if call.name == "power_set" | call.name == "℘"
    then "__capy_set_power_set(" + receiverCode + ")"
    else
        let argumentCode = python_first_method_argument_code(call.arguments, env, module, allModules)
        if call.name == "contains"
        then "__capy_contains(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_subset_of"
        then "__capy_set_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_proper_subset_of"
        then "__capy_set_proper_subset(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "is_superset_of"
        then "__capy_set_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "is_proper_superset_of"
        then "__capy_set_proper_subset(" + argumentCode + ", " + receiverCode + ")"
        else if call.name == "union"
        then "__capy_set_concat(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "intersection"
        then "__capy_set_intersection(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "difference"
        then "__capy_set_remove_all(" + receiverCode + ", " + argumentCode + ")"
        else if call.name == "symmetric_difference"
        then "__capy_set_symmetric_difference(" + receiverCode + ", " + argumentCode + ")"
        else "__capy_set_cartesian_product(" + receiverCode + ", " + argumentCode + ")"

private fun python_char_to_string_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    call.name == "to_string"
        & call.arguments.is_empty()
        & python_char_to_string_receiver_type(receiverType)

private fun python_char_to_string_receiver_type(typeName: String): bool =
    typeName == "char" | typeName == python_unknown_type()

private fun python_string_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    python_string_method_receiver_type(call.name, receiverType)
        & python_string_method_arity(call.name, call.arguments)

private fun python_string_method_receiver_type(name: String, typeName: String): bool =
    typeName == python_string_type()
        | (typeName == python_unknown_type() & python_string_only_method(name))

private fun python_string_only_method(name: String): bool =
    name == "trim" | name == "starts_with" | name == "end_with" | name == "replace"

private fun python_string_method_arity(name: String, arguments: List[CompiledExpression]): bool =
    if name == "trim" | name == "is_empty"
    then arguments.is_empty()
    else if name == "contains" | name == "starts_with" | name == "end_with"
    then python_one_method_argument(arguments)
    else if name == "replace"
    then python_two_method_arguments(arguments)
    else false

private fun python_string_method_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = python_expression_code(call.receiver, env, module, allModules)
    python_string_method_body_code(
        call.name,
        receiver,
        python_first_method_argument_code(call.arguments, env, module, allModules),
        python_second_method_argument_code(call.arguments, env, module, allModules)
    )

private fun python_string_method_body_code(name: String, receiver: String, firstArgument: String, secondArgument: String): String =
    if name == "trim"
    then "__capy_string_trim(" + receiver + ")"
    else if name == "is_empty"
    then "__capy_is_empty(" + receiver + ")"
    else if name == "contains"
    then "__capy_contains(" + receiver + ", " + firstArgument + ")"
    else if name == "starts_with"
    then "__capy_string_starts_with(" + receiver + ", " + firstArgument + ")"
    else if name == "end_with"
    then "__capy_string_end_with(" + receiver + ", " + firstArgument + ")"
    else if name == "replace"
    then "__capy_string_replace(" + receiver + ", " + firstArgument + ", " + secondArgument + ")"
    else "__capy_unsupported('string method')"

private fun python_string_get_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    call.name == "get"
        & receiverType == python_string_type()
        & (python_one_method_argument(call.arguments) | python_two_method_arguments(call.arguments))

private fun python_string_get_method_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = python_expression_code(call.receiver, env, module, allModules)
    if python_two_method_arguments(call.arguments)
    then "__capy_string_slice(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ", " + python_second_method_argument_code(call.arguments, env, module, allModules) + ")"
    else "__capy_string_get(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"

private fun python_string_parse_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    call.arguments.is_empty()
        & receiverType == python_string_type()
        & python_string_parse_method_name(call.name)

private fun python_string_parse_method_name(name: String): bool =
    name == "to_int" | name == "to_long" | name == "to_double" | name == "to_float" | name == "to_bool"

private fun python_string_parse_method_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_string_parse_helper(call.name) + "(" + python_expression_code(call.receiver, env, module, allModules) + ")"

private fun python_string_parse_helper(name: String): String =
    if name == "to_int"
    then "__capy_parse_int"
    else if name == "to_long"
    then "__capy_parse_long"
    else if name == "to_double"
    then "__capy_parse_double"
    else if name == "to_float"
    then "__capy_parse_float"
    else "__capy_parse_bool"

private fun python_one_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ -> arguments[1:].is_empty()

private fun python_two_method_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some _ -> arguments[2:].is_empty()

private fun python_first_method_argument_code(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> python_expression_code(argument, env, module, allModules)

private fun python_second_method_argument_code(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[1] with
    case None -> ""
    case Some { argument } -> python_expression_code(argument, env, module, allModules)

private fun python_primitive_conversion_method_code(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let helper = if call.name == "to_int" then "__capy_to_int" else "__capy_to_long"
    helper + "(" + python_expression_code(call.receiver, env, module, allModules) + ")"

private fun python_primitive_conversion_method_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    if call.arguments.is_empty() & (call.name == "to_int" | call.name == "to_long")
    then python_primitive_conversion_receiver(call.name, receiverType)
    else false

private fun python_primitive_conversion_receiver(name: String, receiverType: String): bool =
    if name == "to_int"
    then receiverType == "long" | receiverType == "float" | receiverType == "double"
    else if name == "to_long"
    then receiverType == "float" | receiverType == "double"
    else false

private fun python_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = python_lambda_bindings(lambda.parameters) + env
    "lambda " + python_lambda_parameters(lambda.parameters) + ": " + python_expression_code(lambda.body, lambdaEnv, module, allModules)

private fun python_lambda_expression_code_with_bindings(lambda: CompiledLambdaExpression, bindings: List[PythonBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "lambda " + python_lambda_parameters(lambda.parameters) + ": " + python_expression_code(lambda.body, bindings + env, module, allModules)

private fun python_lambda_parameters(parameters: List[String]): String =
    python_lambda_parameters_from(parameters, 0)

private fun python_lambda_parameters_from(parameters: List[String], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> python_lambda_parameter_name(parameter, idx) + python_lambda_parameter_tail(parameters[1:], idx + 1)

private fun python_lambda_parameter_tail(parameters: List[String], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + python_lambda_parameters_from(parameters, idx)

private fun python_lambda_parameter_name(parameter: String, idx: int): String =
    if parameter == "_"
    then "__capy_lambda_unused_" + idx
    else python_identifier(parameter)

private fun python_lambda_bindings(parameters: List[String]): List[PythonBinding] =
    python_lambda_bindings_from(parameters, 0)

private fun python_lambda_bindings_from(parameters: List[String], idx: int): List[PythonBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [PythonBinding { name: parameter, pythonName: python_lambda_parameter_name(parameter, idx), typeName: python_unknown_type() }]
            + python_lambda_bindings_from(parameters[1:], idx + 1)

private fun python_lambda_bindings_with_single_type(parameters: List[String], typeName: String): List[PythonBinding] =
    python_lambda_bindings_with_single_type_from(parameters, typeName, 0)

private fun python_lambda_bindings_with_single_type_from(parameters: List[String], typeName: String, idx: int): List[PythonBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [PythonBinding { name: parameter, pythonName: python_lambda_parameter_name(parameter, idx), typeName: typeName }]
            + python_lambda_bindings_with_single_type_from(parameters[1:], typeName, idx + 1)

private fun python_expression_list_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        python_expression_code(expression, env, module, allModules)
            + python_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun python_expression_list_tail_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + python_expression_code(expression, env, module, allModules)
            + python_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun python_set_literal_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_set([" + python_expression_list_code(expressions, env, module, allModules) + "])"

private fun python_tuple_literal_code(expressions: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> "()"
    case Some _ ->
        if expressions[1:].is_empty()
        then "(" + python_expression_list_code(expressions, env, module, allModules) + ",)"
        else "(" + python_expression_list_code(expressions, env, module, allModules) + ")"

private fun python_dict_entries_code(entries: List[CompiledDictEntry], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        python_expression_code(entry.key, env, module, allModules)
            + ": "
            + python_expression_code(entry.value, env, module, allModules)
            + python_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun python_dict_entries_tail_code(entries: List[CompiledDictEntry], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        ", "
        + python_expression_code(entry.key, env, module, allModules)
        + ": "
        + python_expression_code(entry.value, env, module, allModules)
        + python_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun python_data_fields_code(fields: List[CompiledDataField], typeName: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        python_string_literal(python_data_field_name(field.name, typeName, module, allModules))
            + ": "
            + python_expression_code(field.value, env, module, allModules)
            + python_data_fields_tail_code(fields[1:], typeName, env, module, allModules)

private fun python_data_fields_tail_code(fields: List[CompiledDataField], typeName: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
        + python_string_literal(python_data_field_name(field.name, typeName, module, allModules))
        + ": "
        + python_expression_code(field.value, env, module, allModules)
        + python_data_fields_tail_code(fields[1:], typeName, env, module, allModules)

private fun python_with_expression_code(withExpression: CompiledWithExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = python_with_constructor_type_names(receiverType, module, allModules)
    let rawWithCode = python_raw_with_expression_code(withExpression, env, module, allModules)
    if constructorTypes.is_empty()
    then rawWithCode
    else "__capy_constructor_pipeline("
        + rawWithCode
        + ", ["
        + python_data_constructor_pipeline_steps(constructorTypes, receiverType, module)
        + "], "
        + python_bool_code(python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules))
        + ")"

private fun python_raw_with_expression_code(withExpression: CompiledWithExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_with("
        + python_expression_code(withExpression.receiver, env, module, allModules)
        + ", {"
        + python_with_fields_code(withExpression.fields, env, module, allModules)
        + "})"

private fun python_with_expression_receiver_type(withExpression: CompiledWithExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_expression_type(withExpression.receiver, env, module, allModules)

private fun python_with_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    python_data_parent_constructor_type_names(typeName, module, allModules) + python_data_own_constructor_type_names(typeName, module)

private fun python_with_fields_code(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        python_string_literal(field.name)
            + ": "
            + python_expression_code(field.value, env, module, allModules)
            + python_with_fields_tail_code(fields[1:], env, module, allModules)

private fun python_with_fields_tail_code(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
            + python_string_literal(field.name)
            + ": "
            + python_expression_code(field.value, env, module, allModules)
            + python_with_fields_tail_code(fields[1:], env, module, allModules)

private fun python_data_field_name(name: String, typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_string_has_prefix(name, "$")
    then python_declared_positional_field_name(name, python_data_type_fields(python_raw_data_literal_type_name(typeName), module, allModules), 0)
    else name

private fun python_data_literal_code(literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if literal.typeName == "char"
    then python_char_constructor_code(literal.fields, env, module, allModules)
    else
        let declaredTypeName = python_data_literal_declared_type_name(literal.typeName)
        if python_primitive_backed_type(declaredTypeName, module, allModules)
        then python_primitive_backed_data_literal_code(declaredTypeName, literal, env, module, allModules)
        else if python_raw_data_literal(literal.typeName)
        then python_raw_data_literal_code(literal, env, module, allModules)
        else
        let parentConstructors = python_data_parent_constructor_type_names(declaredTypeName, module, allModules)
        if parentConstructors.is_empty()
        then match python_data_constructor_function(declaredTypeName, module) with
            case Some { function } -> python_data_constructor_call_code(declaredTypeName, python_function_name(function), function.parameters, literal, env, module, allModules)
            case None -> python_raw_data_literal_code(literal, env, module, allModules)
        else python_data_constructor_pipeline_code(parentConstructors + python_data_own_constructor_type_names(declaredTypeName, module), literal, env, module, allModules)

private fun python_primitive_backed_data_literal_code(typeName: String, literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_raw_data_literal(literal.typeName)
    then python_primitive_backed_literal_value_code(literal, env, module, allModules)
    else match python_data_constructor_function(typeName, module) with
    case Some { function } ->
        "__capy_primitive_constructor_result("
            + python_function_name(function)
            + "("
            + python_data_constructor_call_arguments(function.parameters, literal.fields, literal.typeName, env, module, allModules)
            + "))"
    case None -> python_primitive_backed_literal_value_code(literal, env, module, allModules)

private fun python_primitive_backed_literal_value_code(literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_expression_code(python_data_constructor_argument_value(literal.fields, "value", literal.typeName, module, allModules), env, module, allModules)

private fun python_raw_data_literal_code(literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_data(" + python_string_literal(literal.typeName) + ", {" + python_data_fields_code(literal.fields, literal.typeName, env, module, allModules) + "})"

private fun python_data_literal_declared_type_name(typeName: String): String =
    python_schema_type_name(python_raw_data_literal_type_name(typeName))

private fun python_data_constructor_function(typeName: String, module: CompiledModule): /capy/lang/Option[CompiledFunction] =
    if python_raw_data_literal(typeName)
    then /capy/lang/Option.None {}
    else python_find_local_function("__capy_constructor|" + typeName, module.functions)

private fun python_data_constructor_call_code(typeName: String, functionName: String, parameters: List[CompiledFunctionParameter], literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_constructor_result("
        + python_string_literal(typeName)
        + ", "
        + functionName
        + "("
        + python_data_constructor_call_arguments(parameters, literal.fields, literal.typeName, env, module, allModules)
        + "))"

private fun python_data_own_constructor_type_names(typeName: String, module: CompiledModule): List[String] =
    match python_data_constructor_function(typeName, module) with
    case Some _ -> [typeName]
    case None -> []

private fun python_data_parent_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    python_data_parent_constructor_type_names_from(python_data_type_parent_types(typeName, module, allModules), module)

private fun python_data_parent_constructor_type_names_from(typeNames: List[String], module: CompiledModule): List[String] =
    match typeNames[0] with
    case None -> []
    case Some { typeName } ->
        match python_data_constructor_function(python_schema_type_name(typeName), module) with
        case Some _ -> [python_schema_type_name(typeName)] + python_data_parent_constructor_type_names_from(typeNames[1:], module)
        case None -> python_data_parent_constructor_type_names_from(typeNames[1:], module)

private fun python_data_constructor_pipeline_code(constructorTypes: List[String], literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredTypeName = python_data_literal_declared_type_name(literal.typeName)
    "__capy_constructor_pipeline("
        + python_raw_data_literal_code(literal, env, module, allModules)
        + ", ["
        + python_data_constructor_pipeline_steps(constructorTypes, declaredTypeName, module)
        + "], "
        + python_bool_code(python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules))
        + ")"

private fun python_data_constructor_pipeline_steps(constructorTypes: List[String], literalTypeName: String, module: CompiledModule): String =
    match constructorTypes[0] with
    case None -> ""
    case Some { constructorType } ->
        match python_data_constructor_function(constructorType, module) with
        case Some { function } ->
            python_data_constructor_pipeline_step(python_function_name(function), function.parameters, constructorType, constructorType != literalTypeName)
                + python_data_constructor_pipeline_step_tail(constructorTypes[1:], literalTypeName, module)
        case None -> python_data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, module)

private fun python_data_constructor_pipeline_step_tail(constructorTypes: List[String], literalTypeName: String, module: CompiledModule): String =
    match constructorTypes[0] with
    case None -> ""
    case Some _ ->
        let tail = python_data_constructor_pipeline_steps(constructorTypes, literalTypeName, module)
        if tail.is_empty()
        then ""
        else ", " + tail

private fun python_data_constructor_pipeline_step(functionName: String, parameters: List[CompiledFunctionParameter], constructorType: String, parentConstructor: bool): String =
    "("
        + python_string_literal(constructorType)
        + ", "
        + python_bool_code(parentConstructor)
        + ", lambda __capy_constructor_data: "
        + python_data_constructor_data_call_code(functionName, parameters, "__capy_constructor_data")
        + ")"

private fun python_data_constructor_data_call_code(functionName: String, parameters: List[CompiledFunctionParameter], dataName: String): String =
    functionName
        + "("
        + python_data_constructor_data_call_arguments(parameters, dataName)
        + ")"

private fun python_data_constructor_data_call_arguments(parameters: List[CompiledFunctionParameter], dataName: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        "__capy_get_field(" + dataName + ", " + python_string_literal(parameter.name) + ")"
            + python_data_constructor_data_call_argument_tail(parameters[1:], dataName)

private fun python_data_constructor_data_call_argument_tail(parameters: List[CompiledFunctionParameter], dataName: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", __capy_get_field(" + dataName + ", " + python_string_literal(parameter.name) + ")"
            + python_data_constructor_data_call_argument_tail(parameters[1:], dataName)

private fun python_data_constructor_call_arguments(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], typeName: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        python_expression_code(python_data_constructor_argument_value(fields, parameter.name, typeName, module, allModules), env, module, allModules)
            + python_data_constructor_call_argument_tail(parameters[1:], fields, typeName, env, module, allModules)

private fun python_data_constructor_call_argument_tail(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], typeName: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", "
        + python_expression_code(python_data_constructor_argument_value(fields, parameter.name, typeName, module, allModules), env, module, allModules)
        + python_data_constructor_call_argument_tail(parameters[1:], fields, typeName, env, module, allModules)

private fun python_data_constructor_argument_value(fields: List[CompiledDataField], name: String, typeName: String, module: CompiledModule, allModules: List[CompiledModule]): CompiledExpression =
    match fields[0] with
    case None -> python_missing_argument()
    case Some { field } ->
        if python_data_field_name(field.name, typeName, module, allModules) == name
        then field.value
        else python_data_constructor_argument_value(fields[1:], name, typeName, module, allModules)

private fun python_missing_argument(): CompiledExpression =
    CompiledUnsupportedExpression {
        source: "missing constructor argument",
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

private fun python_char_constructor_code(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> "__capy_char(\"\")"
    case Some { field } -> "__capy_char(" + python_expression_code(field.value, env, module, allModules) + ")"

private fun python_raw_data_literal(typeName: String): bool =
    python_string_has_prefix(typeName, "__capy_raw|")

private fun python_raw_data_literal_type_name(typeName: String): String =
    if python_string_has_prefix(typeName, "__capy_raw|")
    then typeName["__capy_raw|".size().value, typeName.size().value]
    else typeName

private fun python_declared_positional_field_name(name: String, fields: List[String], idx: int): String =
    match fields[0] with
    case None -> name
    case Some { field } ->
        if name == "$" + idx
        then python_schema_field_name(field)
        else python_declared_positional_field_name(name, fields[1:], idx + 1)

private fun python_index_expression_code(index: CompiledIndexExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(index.receiver, env, module, allModules)
    let receiver = python_expression_code(index.receiver, env, module, allModules)
    if !python_built_in_index_expression(index, receiverType)
    then python_user_defined_index_code(index, receiverType, env, module, allModules)
    else if index.hasEndIndex
    then receiver
        + "["
        + python_slice_bound_code(index.index, true, env, module, allModules)
        + ":"
        + python_slice_bound_code(index.endIndex, false, env, module, allModules)
        + "]"
    else "__capy_index(" + receiver + ", " + python_expression_code(index.index, env, module, allModules) + ")"

private fun python_slice_bound_code(expression: CompiledExpression, start: bool, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if python_omitted_slice_bound(literal, start)
        then ""
        else python_expression_code(expression, env, module, allModules)
    case _ -> python_expression_code(expression, env, module, allModules)

private fun python_omitted_slice_bound(literal: CompiledIntLiteral, start: bool): bool =
    if start
    then literal.source == "__capy_slice_start__"
    else literal.source == "__capy_slice_end__"

private fun python_built_in_index_expression(index: CompiledIndexExpression, receiverType: String): bool =
    if index.hasEndIndex
    then python_built_in_slice_receiver_type(receiverType)
    else python_built_in_index_receiver_type(receiverType)

private fun python_built_in_slice_receiver_type(receiverType: String): bool =
    python_built_in_sequence_receiver_type(receiverType)

private fun python_built_in_index_receiver_type(receiverType: String): bool =
    python_built_in_sequence_receiver_type(receiverType)
        | receiverType == python_dict_type()

private fun python_built_in_sequence_receiver_type(receiverType: String): bool =
    receiverType == python_unknown_type()
        | receiverType == python_string_type()
        | receiverType == python_tuple_type()
        | receiverType == python_list_type()

private fun python_user_defined_index_code(index: CompiledIndexExpression, receiverType: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_extension_method_in_scope(receiverType, "get", module, allModules) with
    case Some { function } ->
        python_function_name(function)
            + "("
            + python_expression_code(index.receiver, env, module, allModules)
            + python_index_argument_tail(index, env, module, allModules)
            + ")"
    case None -> "__capy_unsupported('index get')"

private fun python_index_argument_tail(index: CompiledIndexExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if index.hasEndIndex
    then ", "
        + python_expression_code(index.index, env, module, allModules)
        + ", "
        + python_expression_code(index.endIndex, env, module, allModules)
    else ", " + python_expression_code(index.index, env, module, allModules)

private fun python_reduce_expression_code(reduce: CompiledReduceExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_option_reduce_expression(reduce, env, module, allModules)
    then python_option_reduce_expression_code(reduce, env, module, allModules)
    else python_collection_reduce_expression_code(reduce, env, module, allModules)

private fun python_option_reduce_expression(reduce: CompiledReduceExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    reduce.keyName.is_empty()
        & python_option_pipe_receiver_type(python_expression_type(reduce.receiver, env, module, allModules))

private fun python_option_reduce_expression_code(reduce: CompiledReduceExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = python_reduce_bindings(reduce, env)
    "__capy_option_reduce("
        + python_expression_code(reduce.receiver, env, module, allModules)
        + ", "
        + python_expression_code(reduce.initial, env, module, allModules)
        + ", lambda "
        + python_reduce_parameters(reduce)
        + ": "
        + python_expression_code(reduce.body, reduceEnv, module, allModules)
        + ")"

private fun python_collection_reduce_expression_code(reduce: CompiledReduceExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = python_reduce_bindings(reduce, env)
    let keyed = if reduce.keyName.is_empty() then "False" else "True"
    "__capy_reduce("
        + python_expression_code(reduce.receiver, env, module, allModules)
        + ", "
        + python_expression_code(reduce.initial, env, module, allModules)
        + ", "
        + keyed
        + ", lambda "
        + python_reduce_parameters(reduce)
        + ": "
        + python_expression_code(reduce.body, reduceEnv, module, allModules)
        + ")"

private fun python_reduce_parameters(reduce: CompiledReduceExpression): String =
    if reduce.keyName.is_empty()
    then python_identifier(reduce.accumulatorName) + ", " + python_identifier(reduce.valueName)
    else python_identifier(reduce.accumulatorName) + ", " + python_identifier(reduce.keyName) + ", " + python_identifier(reduce.valueName)

private fun python_reduce_bindings(reduce: CompiledReduceExpression, env: List[PythonBinding]): List[PythonBinding] =
    if reduce.keyName.is_empty()
    then [
            PythonBinding { name: reduce.accumulatorName, pythonName: python_identifier(reduce.accumulatorName), typeName: python_unknown_type() },
            PythonBinding { name: reduce.valueName, pythonName: python_identifier(reduce.valueName), typeName: python_unknown_type() },
        ] + env
    else [
            PythonBinding { name: reduce.accumulatorName, pythonName: python_identifier(reduce.accumulatorName), typeName: python_unknown_type() },
            PythonBinding { name: reduce.keyName, pythonName: python_identifier(reduce.keyName), typeName: python_unknown_type() },
            PythonBinding { name: reduce.valueName, pythonName: python_identifier(reduce.valueName), typeName: python_unknown_type() },
        ] + env

private fun python_match_expression_code(matchExpression: CompiledMatchExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_match_supported(matchExpression)
    then "(lambda __capy_match_value: " + python_match_cases_code(python_ordered_match_cases(matchExpression.cases), env, module, allModules) + ")("
        + python_expression_code(matchExpression.value, env, module, allModules) + ")"
    else "__capy_unsupported('match')"

private fun python_ordered_match_cases(cases: List[CompiledMatchCase]): List[CompiledMatchCase] =
    python_match_cases_with_guard(cases, true) + python_match_cases_with_guard(cases, false)

private fun python_match_cases_with_guard(cases: List[CompiledMatchCase], guarded: bool): List[CompiledMatchCase] =
    match cases[0] with
    case None -> []
    case Some { matchCase } ->
        if matchCase.hasGuard == guarded
        then [matchCase] + python_match_cases_with_guard(cases[1:], guarded)
        else python_match_cases_with_guard(cases[1:], guarded)

private fun python_match_cases_code(cases: List[CompiledMatchCase], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match cases[0] with
    case None -> "__capy_no_match(__capy_match_value)"
    case Some { matchCase } ->
        "(" + python_match_case_body_code(matchCase, env, module, allModules)
            + " if " + python_match_case_condition_code(matchCase, env, module, allModules)
            + " else " + python_match_cases_code(cases[1:], env, module, allModules)
            + ")"

private fun python_match_case_condition_code(matchCase: CompiledMatchCase, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let base = if matchCase.wildcard
        then "True"
        else if matchCase.hasLiteral
        then "__capy_match_value == " + python_expression_code(matchCase.literal, env, module, allModules)
        else "__capy_type_matches(__capy_match_value, " + python_string_literal(matchCase.typeName) + ")"
    if matchCase.hasGuard
    then "(" + base + " and " + python_match_case_guard_code(matchCase, env, module, allModules) + ")"
    else base

private fun python_match_case_guard_code(matchCase: CompiledMatchCase, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let caseEnv = python_match_case_env(matchCase, env)
    let guard = python_truthy_expression_code(matchCase.guard, caseEnv, module, allModules)
    if matchCase.bindings.is_empty()
    then guard
    else "(lambda " + python_match_case_parameters(matchCase.bindings) + ": "
        + guard
        + ")(" + python_match_case_arguments(matchCase.bindings, matchCase.bindsWholeValue, 0) + ")"

private fun python_match_case_body_code(matchCase: CompiledMatchCase, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let caseEnv = python_match_case_env(matchCase, env)
    if matchCase.bindings.is_empty()
    then python_expression_code(matchCase.body, caseEnv, module, allModules)
    else "(lambda " + python_match_case_parameters(matchCase.bindings) + ": "
        + python_expression_code(matchCase.body, caseEnv, module, allModules)
        + ")(" + python_match_case_arguments(matchCase.bindings, matchCase.bindsWholeValue, 0) + ")"

private fun python_match_case_parameters(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> python_identifier(binding) + python_match_case_parameter_tail(bindings[1:])

private fun python_match_case_parameter_tail(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> ", " + python_identifier(binding) + python_match_case_parameter_tail(bindings[1:])

private fun python_match_case_arguments(bindings: List[String], bindsWholeValue: bool, idx: int): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        (if bindsWholeValue
        then "__capy_match_value"
        else "__capy_match_binding(__capy_match_value, " + python_string_literal(binding) + ", " + idx + ")")
            + python_match_case_argument_tail(bindings[1:], bindsWholeValue, idx + 1)

private fun python_match_case_argument_tail(bindings: List[String], bindsWholeValue: bool, idx: int): String =
    match bindings[0] with
    case None -> ""
    case Some _ -> ", " + python_match_case_arguments(bindings, bindsWholeValue, idx)

private fun python_match_case_env(matchCase: CompiledMatchCase, env: List[PythonBinding]): List[PythonBinding] =
    python_match_case_bindings(matchCase.bindings) + env

private fun python_match_case_bindings(bindings: List[String]): List[PythonBinding] =
    match bindings[0] with
    case None -> []
    case Some { binding } ->
        [PythonBinding { name: binding, pythonName: python_identifier(binding), typeName: python_unknown_type() }]
            + python_match_case_bindings(bindings[1:])

private fun python_block_expression_code(block: CompiledBlockExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if block.bindings.is_empty()
    then python_expression_code(block.result, env, module, allModules)
    else "(lambda: (" + python_block_binding_expressions(block.bindings, env, module, allModules)
        + python_expression_code(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)
        + ")[-1])()"

private fun python_block_binding_expressions(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        "(" + python_binding_python_name(binding.name) + " := " + python_binding_value_code(binding, env, module, allModules) + "), "
            + python_block_binding_expressions(bindings[1:], [python_let_binding(binding, env, module, allModules)] + env, module, allModules)

private fun python_effect_block(block: CompiledBlockExpression): bool =
    python_effect_bindings(block.bindings)

private fun python_effect_bindings(bindings: List[CompiledLetBinding]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } -> binding.operator == "<-" | python_effect_bindings(bindings[1:])

private fun python_result_block(block: CompiledBlockExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_result_bindings(block.bindings, env, module, allModules)

private fun python_result_bindings(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        let valueType = python_expression_type(binding.value, env, module, allModules)
        let localEnv = [python_let_binding(binding, env, module, allModules)] + env
        if binding.operator == "<-" & python_result_pipe_receiver_type(valueType)
        then true
        else python_result_bindings(bindings[1:], localEnv, module, allModules)

private fun python_result_block_return_statement(block: CompiledBlockExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String, returnType: CompiledTypeReference): String =
    let resultEnv = python_block_env(block.bindings, env, module, allModules)
    python_result_block_statements(block.bindings, env, module, allModules, indent)
        + indent + "return " + python_result_block_result_code(block.result, resultEnv, module, allModules, returnType) + python_newline()

private fun python_result_block_result_code(result: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], returnType: CompiledTypeReference): String =
    let resultType = python_expression_type(result, env, module, allModules)
    let resultCode = python_expression_code(result, env, module, allModules)
    if returnType.name == python_result_type() & !python_result_pipe_receiver_type(resultType)
    then "__capy_data('Success', dict(value=" + resultCode + "))"
    else resultCode

private fun python_result_block_statements(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        python_result_binding_statement(binding, env, module, allModules, indent)
            + python_result_block_statements(bindings[1:], [python_let_binding(binding, env, module, allModules)] + env, module, allModules, indent)

private fun python_result_binding_statement(binding: CompiledLetBinding, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let valueType = python_expression_type(binding.value, env, module, allModules)
    if binding.operator == "<-" & python_result_pipe_receiver_type(valueType)
    then python_result_bind_statement(binding, env, module, allModules, indent)
    else indent + python_binding_python_name(binding.name) + " = " + python_expression_code(binding.value, env, module, allModules) + python_newline()

private fun python_result_bind_statement(binding: CompiledLetBinding, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    let localName = python_binding_python_name(binding.name)
    let bindName = "__capy_bind_" + localName + "__" + binding.location.line + "_" + binding.location.column
    indent + bindName + " = _unsafe_run(" + python_expression_code(binding.value, env, module, allModules) + ")" + python_newline()
        + indent + "if not _capy_data_is(" + bindName + ", 'Success'):" + python_newline()
        + indent + "    return " + bindName + python_newline()
        + indent + localName + " = _capy_data_value(" + bindName + ")" + python_newline()

private fun python_block_statements(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        indent + python_binding_python_name(binding.name) + " = " + python_binding_value_code(binding, env, module, allModules) + python_newline()
            + python_block_statements(bindings[1:], [python_let_binding(binding, env, module, allModules)] + env, module, allModules, indent)

private fun python_binding_value_code(binding: CompiledLetBinding, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding.operator == "<-"
    then
        if python_expression_type(binding.value, env, module, allModules) == python_effect_type()
        then "__capy_effect_bind_value(" + python_expression_code(binding.value, env, module, allModules) + ")"
        else "__capy_bind_value(" + python_expression_code(binding.value, env, module, allModules) + ")"
    else python_expression_code(binding.value, env, module, allModules)

private fun python_block_env(bindings: List[CompiledLetBinding], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): List[PythonBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } ->
        python_block_env(bindings[1:], [python_let_binding(binding, env, module, allModules)] + env, module, allModules)

private fun python_let_binding(binding: CompiledLetBinding, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): PythonBinding =
    PythonBinding {
        name: binding.name,
        pythonName: python_binding_python_name(binding.name),
        typeName: python_let_binding_type_name(binding, env, module, allModules)
    }

private fun python_let_binding_type_name(binding: CompiledLetBinding, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding.typeReference.name.is_empty()
    then
        let valueType = python_expression_type(binding.value, env, module, allModules)
        if binding.operator == "<-" & valueType == python_effect_type()
        then python_effect_payload_type(binding.value, env, module, allModules)
        else if binding.operator == "<-" & python_result_pipe_receiver_type(valueType)
        then python_result_payload_type(binding.value, env, module, allModules)
        else valueType
    else binding.typeReference.name

private fun python_binding_python_name(name: String): String =
    if python_reserved_binding_name(name)
    then "_capy_" + python_identifier(name)
    else python_identifier(name)

private fun python_reserved_binding_name(name: String): bool =
    python_runtime_function(name)
        | name == "Effect"
        | name == "ValueAssert"
        | name == "CombinedAssert"

private fun python_expression_type(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral _ -> python_int_type()
    case CompiledLongLiteral _ -> python_long_type()
    case CompiledFloatLiteral _ -> python_float_type()
    case CompiledDoubleLiteral _ -> python_double_type()
    case CompiledBoolLiteral _ -> python_bool_type()
    case CompiledStringLiteral _ -> python_string_type()
    case CompiledVariableExpression variable -> python_variable_type(variable.name, env, module, allModules)
    case CompiledUnaryExpression unary -> if unary.operator == "!" then python_bool_type() else python_expression_type(unary.expression, env, module, allModules)
    case CompiledBinaryExpression binary -> python_binary_expression_type(binary, env, module, allModules)
    case CompiledFunctionCallExpression call -> python_function_call_expression_type(call, module, allModules)
    case CompiledMethodCallExpression call -> python_method_call_expression_type(call, env, module, allModules)
    case CompiledListLiteral _ -> python_list_type()
    case CompiledSetLiteral _ -> python_set_type()
    case CompiledDictLiteral _ -> python_dict_type()
    case CompiledTupleLiteral _ -> python_unknown_type()
    case CompiledIndexExpression index -> python_index_expression_type(index, env, module, allModules)
    case CompiledDataLiteral literal -> python_data_literal_expression_type(literal, env, module, allModules)
    case CompiledFieldAccessExpression access -> python_field_access_type(access, env, module, allModules)
    case CompiledWithExpression withExpression -> python_with_expression_type(withExpression, env, module, allModules)
    case CompiledReduceExpression reduce -> python_expression_type(reduce.initial, env, module, allModules)
    case CompiledIfExpression ifExpression -> python_expression_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBlockExpression block -> python_expression_type(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> python_unknown_type()

private fun python_variable_type(name: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_lookup_binding(name, env) with
    case Some { binding } -> binding.typeName
    case None ->
        if name == "receiver"
        then match python_lookup_binding("this", env) with
            case Some { binding } -> binding.typeName
            case None -> python_unbound_variable_type(name, module, allModules)
        else python_unbound_variable_type(name, module, allModules)

private fun python_unbound_variable_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_qualified_enum_value_name(name, module, allModules)
    then python_enum_qualified_type_name(name)
    else match python_find_constant(name, module.functions) with
        case Some { function } -> function.returnType.name
        case None -> match python_find_constant_binding_in_imports(name, module.imports, module, allModules) with
        case Some { binding } -> binding.function.returnType.name
        case None ->
            match python_imported_stdlib_constant(name, module.imports) with
            case Some { value } -> value.typeName
            case None -> python_unknown_type()

private fun python_imported_stdlib_constant(name: String, imports: List[CompiledImportDeclaration]): /capy/lang/Option[PythonStdlibValue] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !declaration.qualified & python_import_includes_name(name, declaration)
        then match python_stdlib_constant(name, declaration.modulePath) with
            case Some { value } -> /capy/lang/Option.Some { value }
            case None -> python_imported_stdlib_constant(name, imports[1:])
        else python_imported_stdlib_constant(name, imports[1:])

private fun python_stdlib_constant(name: String, modulePath: String): /capy/lang/Option[PythonStdlibValue] =
    let path = python_normalize_import_module_path(modulePath)
    if path == "capy/date_time/Date" & name == "UNIX_DATE"
    then /capy/lang/Option.Some { PythonStdlibValue { pythonName: "__capy_date_unix_date()", typeName: "Date" } }
    else if path == "capy/date_time/Time" & name == "MIDNIGHT"
    then /capy/lang/Option.Some { PythonStdlibValue { pythonName: "__capy_time_midnight()", typeName: "Time" } }
    else if path == "capy/date_time/DateTime" & name == "UNIX_EPOCH"
    then /capy/lang/Option.Some { PythonStdlibValue { pythonName: "__capy_date_time_unix_epoch()", typeName: "DateTime" } }
    else if path == "capy/date_time/Duration" & name == "ZERO"
    then /capy/lang/Option.Some { PythonStdlibValue { pythonName: "__capy_duration_zero()", typeName: "Duration" } }
    else /capy/lang/Option.None {}

private fun python_field_access_type(access: CompiledFieldAccessExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_enum_static_field_access(access, env, module, allModules)
    then python_enum_static_field_access_type(access)
    else
    let receiverType = python_expression_type(access.receiver, env, module, allModules)
    match python_reflection_field_type(access.name, receiverType) with
    case Some { typeName } -> typeName
    case None ->
        match python_find_object_class_by_type(receiverType, allModules) with
        case Some { binding } -> python_object_field_type(access.name, binding.objectClass.fields)
        case None ->
            if receiverType == python_unknown_type()
            then python_unknown_type()
            else python_data_field_type(access.name, python_data_type_fields(receiverType, module, allModules))

private fun python_object_field_type(name: String, fields: List[CompiledObjectOrientedField]): String =
    match fields[0] with
    case None -> python_unknown_type()
    case Some { field } ->
        if field.name == name
        then field.typeReference.name
        else python_object_field_type(name, fields[1:])

private fun python_reflection_field_type(name: String, receiverType: String): /capy/lang/Option[String] =
    if (receiverType == "AnyInfo" | receiverType == "CFunInfo" | receiverType == "CooInfo"
        | receiverType == "DataValueInfo" | receiverType == "DataInfo" | receiverType == "AnnotationInfo"
        | receiverType == "FieldInfo" | receiverType == "FunctionTypeInfo" | receiverType == "ListInfo"
        | receiverType == "SetInfo" | receiverType == "DictInfo" | receiverType == "TupleInfo"
        | receiverType == "InterfaceInfo" | receiverType == "ObjectInfo" | receiverType == "TraitInfo"
        | receiverType == "MethodInfo") & name == "name"
    then /capy/lang/Option.Some { python_string_type() }
    else if (receiverType == "AnyInfo" | receiverType == "CFunInfo" | receiverType == "CooInfo"
        | receiverType == "DataValueInfo" | receiverType == "DataInfo" | receiverType == "AnnotationInfo"
        | receiverType == "FunctionTypeInfo" | receiverType == "ListInfo" | receiverType == "SetInfo"
        | receiverType == "DictInfo" | receiverType == "TupleInfo" | receiverType == "InterfaceInfo"
        | receiverType == "ObjectInfo" | receiverType == "TraitInfo" | receiverType == "MethodInfo") & name == "pkg"
    then /capy/lang/Option.Some { "PackageInfo" }
    else if receiverType == "DataValueInfo" & (name == "fields" | name == "annotations")
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "FieldValueInfo" & name == "name"
    then /capy/lang/Option.Some { python_string_type() }
    else if receiverType == "FieldValueInfo" & name == "type"
    then /capy/lang/Option.Some { "DataInfo" }
    else if receiverType == "FieldValueInfo" & name == "value"
    then /capy/lang/Option.Some { python_unknown_type() }
    else if receiverType == "FieldValueInfo" & name == "annotations"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "FieldInfo" & name == "type"
    then /capy/lang/Option.Some { "AnyInfo" }
    else if receiverType == "FieldInfo" & name == "annotations"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "DataInfo" & name == "annotations"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "FunctionTypeInfo" & name == "params"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "FunctionTypeInfo" & name == "return_type"
    then /capy/lang/Option.Some { "AnyInfo" }
    else if (receiverType == "ListInfo" | receiverType == "SetInfo") & name == "element_type"
    then /capy/lang/Option.Some { "AnyInfo" }
    else if receiverType == "DictInfo" & name == "value_type"
    then /capy/lang/Option.Some { "AnyInfo" }
    else if receiverType == "TupleInfo" & name == "elements"
    then /capy/lang/Option.Some { python_list_type() }
    else if (receiverType == "InterfaceInfo" | receiverType == "TraitInfo") & name == "methods"
    then /capy/lang/Option.Some { python_list_type() }
    else if (receiverType == "InterfaceInfo" | receiverType == "ObjectInfo" | receiverType == "TraitInfo") & name == "parents"
    then /capy/lang/Option.Some { python_set_type() }
    else if (receiverType == "InterfaceInfo" | receiverType == "ObjectInfo" | receiverType == "TraitInfo") & name == "annotations"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "ObjectInfo" & name == "open"
    then /capy/lang/Option.Some { python_bool_type() }
    else if receiverType == "ObjectInfo" & (name == "fields" | name == "methods")
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "MethodInfo" & name == "params"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "MethodInfo" & name == "return_type"
    then /capy/lang/Option.Some { "AnyInfo" }
    else if receiverType == "MethodInfo" & name == "annotations"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "PackageInfo" & (name == "name" | name == "path")
    then /capy/lang/Option.Some { python_string_type() }
    else if receiverType == "AnnotationInfo" & name == "arguments"
    then /capy/lang/Option.Some { python_list_type() }
    else if receiverType == "AnnotationArgumentInfo" & name == "name"
    then /capy/lang/Option.Some { python_string_type() }
    else if receiverType == "AnnotationArgumentInfo" & name == "value"
    then /capy/lang/Option.Some { python_unknown_type() }
    else /capy/lang/Option.None {}

private fun python_data_field_type(name: String, fields: List[String]): String =
    match fields[0] with
    case None -> python_unknown_type()
    case Some { field } ->
        if python_schema_field_name(field) == name
        then python_schema_field_type_name(field)
        else python_data_field_type(name, fields[1:])

private fun python_index_expression_type(index: CompiledIndexExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(index.receiver, env, module, allModules)
    if !python_built_in_index_expression(index, receiverType)
    then python_user_defined_index_type(receiverType, module, allModules)
    else python_unknown_type()

private fun python_user_defined_index_type(receiverType: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_extension_method_in_scope(receiverType, "get", module, allModules) with
    case Some { function } -> function.returnType.name
    case None -> python_unknown_type()

private fun python_function_call_expression_type(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_stdlib_effect_function_call(call, module)
    then python_stdlib_effect_function_call_type(call.name)
    else if python_object_type_function_call(call, module, allModules)
    then python_object_type_function_call_type(call, module, allModules)
    else if python_object_constructor_call(call, module, allModules)
    then python_effect_type()
    else python_function_name_expression_type(call.name, module, allModules)

private fun python_function_name_expression_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_enum_parse_call_name(name, module, allModules)
    then python_result_type()
    else if python_qualified_name(name)
    then match python_find_qualified_function_binding(name, module, allModules) with
        case Some { binding } -> binding.function.returnType.name
        case None -> python_unknown_type()
    else match python_find_local_function(name, module.functions) with
    case Some { function } -> function.returnType.name
    case None ->
        match python_find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> function.returnType.name
        case None -> python_runtime_function_type(name)

private fun python_runtime_function_type(name: String): String =
    if name == "assert_that" | name == "assert_all"
    then python_assert_type()
    else if name == "test"
    then python_test_case_type()
    else if name == "test_file"
    then python_effect_type()
    else if name == "reflection"
    then "DataValueInfo"
    else if name == "to_seq"
    then python_seq_type()
    else if python_console_function(name)
    then python_effect_type()
    else python_unknown_type()

private fun python_object_type_function_call_type(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    python_object_info_type_for_name(python_object_type_function_receiver_name(call.name), module, allModules)

private fun python_object_type_method_call_type(call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.receiver with
    case CompiledVariableExpression variable -> python_object_info_type_for_name(variable.name, module, allModules)
    case _ -> "ObjectInfo"

private fun python_object_info_type_for_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_class_in_scope(name, module, allModules) with
    case Some _ -> "ObjectInfo"
    case None ->
        match python_find_object_interface_module_in_scope(name, module, allModules) with
        case Some { owner } -> python_object_interface_info_type(python_object_interface_kind(python_object_interface_member_name(name), owner.functions))
        case None -> "ObjectInfo"

private fun python_stdlib_effect_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    call.arguments.is_empty()
        & python_local_function_count(call.name, module.functions) == 0
        & if call.name == "current_millis"
            then python_system_member_imported("current_millis", module.imports)
            else if call.name == "nano_time"
            then python_system_member_imported("nano_time", module.imports)
            else if call.name == "now"
            then python_clock_member_imported("now", module.imports)
            else false

private fun python_stdlib_effect_function_call_code(name: String): String =
    if name == "current_millis"
    then "__capy_current_millis()"
    else if name == "nano_time"
    then "__capy_nano_time()"
    else "__capy_clock_now()"

private fun python_stdlib_effect_function_call_type(name: String): String =
    python_effect_type()

private fun python_stdlib_parse_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    python_one_method_argument(call.arguments)
        & python_local_function_count(call.name, module.functions) == 0
        & python_string_parse_method_name(call.name)
        & python_primitives_member_imported(call.name, module.imports)

private fun python_stdlib_parse_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    python_string_parse_helper(call.name)
        + "("
        + python_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"

private fun python_stdlib_path_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    python_one_method_argument(call.arguments)
        & python_local_function_count(call.name, module.functions) == 0
        & call.name == "from_string"
        & python_path_member_imported("from_string", module.imports)

private fun python_stdlib_path_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "from_string("
        + python_expression_list_code(call.arguments, env, module, allModules)
        + ")"

private fun python_stdlib_io_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    python_stdlib_io_function_call_by_name(call.name, module)
        & python_stdlib_io_function_argument_count(call.name, call.arguments)

private fun python_stdlib_io_function_call_by_name(name: String, module: CompiledModule): bool =
    python_local_function_count(name, module.functions) == 0
        & python_io_function_name(name)
        & python_io_member_imported(name, module.imports)

private fun python_stdlib_io_function_argument_count(name: String, arguments: List[CompiledExpression]): bool =
    if python_io_unary_function_name(name)
    then python_one_method_argument(arguments)
    else if python_io_binary_function_name(name)
    then python_two_method_arguments(arguments)
    else false

private fun python_io_unary_function_name(name: String): bool =
    name == "read_text"
        | name == "read_lines"
        | name == "read_bytes"
        | name == "exists"
        | name == "is_file"
        | name == "is_directory"
        | name == "size"
        | name == "create_file"
        | name == "create_directory"
        | name == "create_directories"
        | name == "list_entries"
        | name == "delete"

private fun python_io_binary_function_name(name: String): bool =
    name == "write_text"
        | name == "write_lines"
        | name == "write_bytes"
        | name == "append_text"
        | name == "append_lines"
        | name == "append_bytes"
        | name == "copy"
        | name == "copy_replace"
        | name == "move"
        | name == "move_replace"

private fun python_io_function_name(name: String): bool =
    python_io_unary_function_name(name) | python_io_binary_function_name(name)

private fun python_stdlib_io_function_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    call.name
        + "("
        + python_expression_list_code(call.arguments, env, module, allModules)
        + ")"

private fun python_system_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    python_module_member_imported(member, imports, "/capy/lang/System", "capy/lang/System")

private fun python_clock_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    python_module_member_imported(member, imports, "/capy/date_time/Clock", "capy/date_time/Clock")

private fun python_primitives_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    python_module_member_imported(member, imports, "/capy/lang/Primitives", "capy/lang/Primitives")

private fun python_path_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    python_module_member_imported(member, imports, "/capy/io/Path", "capy/io/Path")

private fun python_io_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    python_module_member_imported(member, imports, "/capy/io/IO", "capy/io/IO")

private fun python_module_member_imported(member: String, imports: List[CompiledImportDeclaration], absoluteModulePath: String, relativeModulePath: String): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if (declaration.modulePath == absoluteModulePath | declaration.modulePath == relativeModulePath)
            & python_import_includes_name(member, declaration)
        then true
        else python_module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)

private fun python_method_call_expression_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    if call.name == "__capy_call"
    then python_callable_call_expression_type(call, env, module, allModules)
    else if call.name == "size"
    then python_int_type()
    else if python_enum_name_method_call(call, receiverType, module, allModules)
    then python_string_type()
    else if python_char_to_string_method_call(call, receiverType)
    then python_string_type()
    else if python_string_get_method_call(call, receiverType)
    then python_string_get_method_return_type(call)
    else if python_string_parse_method_call(call, receiverType)
    then python_result_type()
    else if python_string_method_call(call, receiverType)
    then python_string_method_return_type(call.name)
    else if python_regex_method_call(call, receiverType)
    then python_regex_method_call_type(call.name)
    else if python_stdlib_date_time_method_call(call, env, module, allModules)
    then python_stdlib_date_time_method_call_type(call, env, module, allModules)
    else if python_set_method_call(call, receiverType)
    then python_set_method_call_type(call, env, module, allModules)
    else if python_native_collection_method_call_with_receiver_type(call, receiverType)
    then python_native_collection_method_call_type(call, receiverType)
    else if python_seq_as_list_call(call)
    then python_list_type()
    else if python_collection_predicate_call(call, receiverType)
    then python_bool_type()
    else if python_primitive_conversion_method_call(call, receiverType)
    then if call.name == "to_int" then python_int_type() else python_long_type()
    else if python_object_type_method_call(call, env, module, allModules)
    then python_object_type_method_call_type(call, module, allModules)
    else if python_effect_method_call(call, receiverType)
    then python_effect_type()
    else if python_result_method_call(call, receiverType)
    then python_result_method_call_type(call, env, module, allModules)
    else if python_option_method_call(call, receiverType)
    then python_option_type()
    else if python_assert_method(call.name)
    then python_assert_type()
    else if python_object_method_call(call, env, module, allModules)
    then python_effect_type()
    else if python_collection_reduce_method_call(call, receiverType)
    then python_first_method_argument_type(call.arguments, env, module, allModules)
    else if python_collection_method_call(call, receiverType)
    then python_collection_pipe_result_type(python_collection_method_operator(call.name), receiverType)
    else if python_seq_first_call(call, receiverType)
    then python_option_type()
    else match python_find_extension_method(call, env, module, allModules) with
        case Some { function } -> function.returnType.name
        case None -> python_unknown_type()

private fun python_result_method_call_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "or_else"
    then python_first_method_argument_type(call.arguments, env, module, allModules)
    else if call.name == "reduce" | call.name == "reduce_left"
    then python_unknown_type()
    else python_result_type()

private fun python_data_literal_expression_type(literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_result_constructor_type(literal.typeName)
    then python_result_type()
    else if python_option_constructor_type(literal.typeName)
    then python_option_type()
    else if python_raw_data_literal(literal.typeName)
    then python_data_literal_declared_type_name(literal.typeName)
    else
        let declaredTypeName = python_data_literal_declared_type_name(literal.typeName)
        let parentConstructors = python_data_parent_constructor_type_names(declaredTypeName, module, allModules)
        if parentConstructors.is_empty()
        then match python_data_constructor_function(declaredTypeName, module) with
            case Some _ ->
                if python_data_constructor_type_returns_result(declaredTypeName, module, allModules)
                then python_result_type()
                else declaredTypeName
            case None -> declaredTypeName
        else python_data_constructor_pipeline_type(declaredTypeName, parentConstructors + python_data_own_constructor_type_names(declaredTypeName, module), module, allModules)

private fun python_data_constructor_pipeline_type(typeName: String, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then python_result_type()
    else typeName

private fun python_with_expression_type(withExpression: CompiledWithExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = python_with_constructor_type_names(receiverType, module, allModules)
    if constructorTypes.is_empty()
    then receiverType
    else python_with_constructor_result_type(receiverType, constructorTypes, module, allModules)

private fun python_with_constructor_result_type(receiverType: String, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then python_result_type()
    else receiverType

private fun python_data_constructor_pipeline_returns_result(constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match constructorTypes[0] with
    case None -> false
    case Some { constructorType } ->
        python_data_constructor_type_returns_result(constructorType, module, allModules)
            | python_data_constructor_pipeline_returns_result(constructorTypes[1:], module, allModules)

private fun python_data_constructor_type_returns_result(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match python_data_constructor_function(typeName, module) with
    case Some { function } ->
        python_result_pipe_receiver_type(function.returnType.name)
            | python_result_pipe_receiver_type(python_data_constructor_inferred_expression_type(function.body, python_function_bindings(function), module, allModules))
    case None -> false

private fun python_data_constructor_inferred_expression_type(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIfExpression ifExpression ->
        python_preferred_constructor_type(
            python_data_constructor_inferred_expression_type(ifExpression.thenBranch, env, module, allModules),
            python_data_constructor_inferred_expression_type(ifExpression.elseBranch, env, module, allModules)
        )
    case CompiledBlockExpression block ->
        python_data_constructor_inferred_expression_type(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> python_expression_type(expression, env, module, allModules)

private fun python_preferred_constructor_type(first: String, second: String): String =
    if python_result_pipe_receiver_type(first)
    then python_result_type()
    else if python_result_pipe_receiver_type(second)
    then python_result_type()
    else first

private fun python_first_method_argument_type(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> python_unknown_type()
    case Some { argument } ->
        match argument with
        case CompiledFunctionCallExpression call ->
            if call.arguments.is_empty()
            then match python_find_local_function(call.name, module.functions) with
                case Some { function } -> python_type_reference_name_key(function.returnType.name, python_first_type_argument_name(function.returnType.arguments))
                case None -> python_expression_type(argument, env, module, allModules)
            else python_expression_type(argument, env, module, allModules)
        case _ -> python_expression_type(argument, env, module, allModules)

private fun python_callable_call_expression_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    if python_callable_binding_type(receiverType)
    then python_callable_return_type(receiverType)
    else python_unknown_type()

private fun python_callable_return_type(typeName: String): String =
    let arrow = python_first_index_of(typeName, ">", 0)
    if arrow < 0 | arrow >= typeName.size().value - 1
    then python_unknown_type()
    else typeName[arrow + 1, typeName.size().value]

private fun python_result_payload_type(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledBinaryExpression binary -> python_result_payload_type_from_binary(binary, env, module, allModules)
    case CompiledFunctionCallExpression call -> python_result_payload_type_from_function_call(call.name, module, allModules)
    case CompiledMethodCallExpression call -> python_result_payload_type_from_method_call(call, env, module, allModules)
    case CompiledWithExpression withExpression -> python_result_payload_type_from_with_expression(withExpression, env, module, allModules)
    case CompiledDataLiteral literal -> python_result_payload_type_from_data_literal(literal, env, module, allModules)
    case CompiledIfExpression ifExpression -> python_result_payload_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBlockExpression block -> python_result_payload_type(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)
    case CompiledReduceExpression reduce -> python_result_payload_type(reduce.initial, env, module, allModules)
    case _ -> python_unknown_type()

private fun python_effect_payload_type(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledFunctionCallExpression call -> python_effect_payload_type_from_function_call(call, env, module, allModules)
    case CompiledMethodCallExpression call -> python_effect_payload_type_from_method_call(call, env, module, allModules)
    case CompiledIfExpression ifExpression -> python_effect_payload_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBlockExpression block -> python_effect_payload_type(block.result, python_block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> python_unknown_type()

private fun python_effect_payload_type_from_function_call(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_stdlib_effect_function_call(call, module)
    then python_stdlib_effect_payload_type(call.name)
    else match python_find_object_class_in_scope(call.name, module, allModules) with
    case Some { binding } -> python_object_type_name(binding.module, binding.objectClass.name)
    case None ->
    if call.name == "pure"
    then python_effect_payload_type_from_pure_call(call.arguments, env, module, allModules)
    else if call.name == "delay"
    then python_effect_payload_type_from_delay_call(call.arguments, env, module, allModules)
    else if python_qualified_name(call.name)
    then match python_find_qualified_function_binding(call.name, module, allModules) with
        case Some { binding } -> python_effect_payload_type_from_type_reference(binding.function.returnType)
        case None -> python_unknown_type()
    else match python_find_local_function(call.name, module.functions) with
    case Some { function } -> python_effect_payload_type_from_type_reference(function.returnType)
    case None ->
        match python_find_function_in_imports(call.name, module.imports, module, allModules) with
        case Some { function } -> python_effect_payload_type_from_type_reference(function.returnType)
        case None -> python_unknown_type()

private fun python_effect_payload_type_from_method_call(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_object_method(call, env, module, allModules) with
    case Some { binding } -> binding.method.returnType.name
    case None -> python_unknown_type()

private fun python_effect_payload_type_from_pure_call(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> python_unknown_type()
    case Some { value } -> python_expression_type(value, env, module, allModules)

private fun python_effect_payload_type_from_delay_call(arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> python_unknown_type()
    case Some { expression } ->
        match expression with
        case CompiledLambdaExpression lambda -> python_expression_type(lambda.body, python_lambda_bindings(lambda.parameters) + env, module, allModules)
        case _ -> python_unknown_type()

private fun python_effect_payload_type_from_type_reference(typeReference: CompiledTypeReference): String =
    if typeReference.name == python_effect_type()
    then python_first_type_argument_name(typeReference.arguments)
    else python_unknown_type()

private fun python_stdlib_effect_payload_type(name: String): String =
    if name == "now"
    then "DateTime"
    else python_long_type()

private fun python_result_payload_type_from_binary(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = python_expression_type(binary.left, env, module, allModules)
    if python_result_pipe_expression_with_left_type(binary, leftType)
    then python_result_pipe_payload_type(binary, env, module, allModules)
    else python_unknown_type()

private fun python_result_pipe_payload_type(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let lambdaEnv = python_lambda_bindings_with_single_type(lambda.parameters, python_result_payload_type(binary.left, env, module, allModules)) + env
        let bodyType = python_expression_type(lambda.body, lambdaEnv, module, allModules)
        if python_result_pipe_receiver_type(bodyType)
        then python_result_payload_type(lambda.body, lambdaEnv, module, allModules)
        else bodyType
    case CompiledFunctionReferenceExpression reference -> python_result_payload_type_from_function_call(reference.name, module, allModules)
    case _ -> python_unknown_type()

private fun python_result_payload_type_from_function_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_enum_parse_call_name(name, module, allModules)
    then python_enum_qualified_type_name(name)
    else if python_qualified_name(name)
    then match python_find_qualified_function_binding(name, module, allModules) with
        case Some { binding } -> python_result_payload_type_from_type_reference(binding.function.returnType)
        case None -> python_unknown_type()
    else match python_find_local_function(name, module.functions) with
    case Some { function } -> python_result_payload_type_from_type_reference(function.returnType)
    case None ->
        match python_find_function_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> python_result_payload_type_from_type_reference(function.returnType)
        case None -> python_unknown_type()

private fun python_result_payload_type_from_method_call(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_string_parse_method_call(call, python_expression_type(call.receiver, env, module, allModules))
    then python_string_parse_payload_type(call.name)
    else python_unknown_type()

private fun python_result_payload_type_from_with_expression(withExpression: CompiledWithExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = python_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = python_with_constructor_type_names(receiverType, module, allModules)
    if python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then receiverType
    else python_unknown_type()

private fun python_string_parse_payload_type(name: String): String =
    if name == "to_int"
    then python_int_type()
    else if name == "to_long"
    then python_long_type()
    else if name == "to_double"
    then python_double_type()
    else if name == "to_float"
    then python_float_type()
    else python_bool_type()

private fun python_result_payload_type_from_data_literal(literal: CompiledDataLiteral, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_type_unqualified_name(literal.typeName) == "Success"
    then python_success_literal_payload_type(literal.fields, env, module, allModules)
    else
        let declaredTypeName = python_data_literal_declared_type_name(literal.typeName)
        let constructorTypes = python_data_parent_constructor_type_names(declaredTypeName, module, allModules) + python_data_own_constructor_type_names(declaredTypeName, module)
        if !python_raw_data_literal(literal.typeName) & python_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
        then declaredTypeName
        else python_unknown_type()

private fun python_success_literal_payload_type(fields: List[CompiledDataField], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> python_unknown_type()
    case Some { field } ->
        if field.name == "value" | field.name == "$0"
        then python_expression_type(field.value, env, module, allModules)
        else python_success_literal_payload_type(fields[1:], env, module, allModules)

private fun python_result_payload_type_from_type_reference(typeReference: CompiledTypeReference): String =
    if python_result_pipe_receiver_type(typeReference.name)
    then python_first_type_argument_name(typeReference.arguments)
    else python_unknown_type()

private fun python_first_type_argument_name(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> python_unknown_type()
    case Some { argument } -> argument.name

private fun python_string_get_method_return_type(call: CompiledMethodCallExpression): String =
    if python_two_method_arguments(call.arguments)
    then python_string_type()
    else python_option_type()

private fun python_string_method_return_type(name: String): String =
    if name == "trim" | name == "replace"
    then python_string_type()
    else python_bool_type()

private fun python_binary_expression_type(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = python_expression_type(binary.left, env, module, allModules)
    let rightType = python_expression_type(binary.right, env, module, allModules)
    if python_result_reduce_operator_expression_with_left_type(binary, leftType)
    then python_result_reduce_operator_type(binary, env, module, allModules)
    else if python_result_pipe_expression_with_left_type(binary, leftType)
    then python_result_type()
    else if python_option_pipe_expression_with_left_type(binary, leftType)
    then python_option_type()
    else if python_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then python_method_call_expression_type(python_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if python_collection_pipe_expression_with_left_type(binary, leftType)
    then python_collection_pipe_result_type(binary.operator, leftType)
    else if python_regex_binary_expression_with_left_type(binary, leftType)
    then python_regex_binary_expression_type(binary.operator)
    else if python_set_binary_expression_with_left_type(binary, leftType)
    then python_set_binary_expression_type(binary)
    else match python_find_binary_extension_operator_with_left_type(binary, leftType, module, allModules) with
    case Some { function } -> function.returnType.name
    case None ->
    if python_bool_binary_operator(binary.operator) | python_comparison_operator(binary.operator)
    then python_bool_type()
    else if binary.operator == "+" & (leftType == "String" | rightType == "String")
    then python_string_type()
    else if python_numeric_binary_operator(binary.operator) & python_numeric_type(leftType) & python_numeric_type(rightType)
    then python_promoted_numeric_type(leftType, rightType)
    else python_unknown_type()

private fun python_bool_binary_operator(operator: String): bool =
    operator == "&" | operator == "|"

private fun python_comparison_operator(operator: String): bool =
    operator == "==" | operator == "!=" | operator == ">" | operator == "<" | operator == ">=" | operator == "<=" | operator == "?"

private fun python_numeric_binary_operator(operator: String): bool =
    (python_binary_runtime_operator(operator) & operator != "?")
        | python_bitwise_binary_operator(operator)
        | operator == ".nand."

private fun python_numeric_type(type: String): bool =
    type == "byte" | type == "int" | type == "long" | type == "float" | type == "double"

private fun python_promoted_numeric_type(leftType: String, rightType: String): String =
    if leftType == "double" | rightType == "double"
    then python_double_type()
    else if leftType == "float" | rightType == "float"
    then python_float_type()
    else if leftType == "long" | rightType == "long"
    then python_long_type()
    else python_int_type()

private fun python_set_method_call_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_set_predicate_method(call.name)
    then python_bool_type()
    else python_set_type()

private fun python_set_predicate_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"

private fun python_set_binary_expression_type(binary: CompiledBinaryExpression): String =
    if python_set_predicate_operator(binary.operator)
    then python_bool_type()
    else python_set_type()

private fun python_int_type(): String = "int"
private fun python_long_type(): String = "long"
private fun python_float_type(): String = "float"
private fun python_double_type(): String = "double"
private fun python_bool_type(): String = "bool"
private fun python_string_type(): String = "String"
private fun python_assert_type(): String = "Assert"
private fun python_test_case_type(): String = "TestCase"
private fun python_unknown_type(): String = "any"
private fun python_list_type(): String = "List"
private fun python_set_type(): String = "Set"
private fun python_dict_type(): String = "Dict"
private fun python_tuple_type(): String = "Tuple"
private fun python_seq_type(): String = "Seq"
private fun python_effect_type(): String = "Effect"
private fun python_option_type(): String = "Option"
private fun python_result_type(): String = "Result"
private fun python_regex_type(): String = "Regex"
private fun python_string_to_string_function_type(): String = "String=>String"

private fun python_bool_code(value: bool): String =
    if value then "True" else "False"

private fun python_regex_method_call_type(name: String): String =
    if name == "matches"
    then python_bool_type()
    else if name == "find"
    then python_option_type()
    else if name == "find_all"
    then python_seq_type()
    else if name == "replace"
    then python_string_to_string_function_type()
    else python_list_type()

private fun python_regex_binary_expression_type(operator: String): String =
    if operator == "?"
    then python_bool_type()
    else if operator == "~"
    then python_option_type()
    else if operator == "~~"
    then python_seq_type()
    else if operator == "~>"
    then python_string_to_string_function_type()
    else python_list_type()

private fun python_option_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    python_option_pipe_operator(binary.operator)
        & python_option_pipe_receiver_type(leftType)
        & python_callable_expression(binary.right)

private fun python_option_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*"

private fun python_option_pipe_receiver_type(typeName: String): bool =
    typeName == python_option_type()
        | python_option_constructor_type(typeName)

private fun python_option_constructor_type(typeName: String): bool =
    python_stdlib_data_constructor_type(typeName, "Option", "Some")
        | python_stdlib_data_constructor_type(typeName, "Option", "None")

private fun python_stdlib_data_constructor_type(typeName: String, family: String, ctor: String): bool =
    typeName == ctor
        | typeName == family + "." + ctor
        | typeName == "/capy/lang/" + family + "." + ctor
        | typeName == "capy/lang/" + family + "." + ctor
        | typeName == "capy.lang." + family + "." + ctor

private fun python_stdlib_date_time_method_call_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = python_type_unqualified_name(python_expression_type(call.receiver, env, module, allModules))
    if receiver == "Date"
    then if call.name == "to_days_since_unix_epoch" then python_int_type() else if call.name == "to_iso_8601" then python_string_type() else "Date"
    else if receiver == "Time"
    then if call.name == "to_seconds" then python_int_type() else if call.name == "to_iso_8601" then python_string_type() else "Time"
    else if receiver == "DateTime"
    then python_stdlib_date_time_value_method_call_type(call, env, module, allModules)
    else python_stdlib_duration_method_call_type(call.name)

private fun python_stdlib_date_time_value_method_call_type(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "to_iso_8601"
    then python_string_type()
    else if call.name == "timestamp"
    then python_long_type()
    else if call.name == "plus"
    then "DateTime"
    else if call.name == "minus"
    then
        match call.arguments[0] with
        case Some { argument } ->
            let argumentType = python_type_unqualified_name(python_expression_type(argument, env, module, allModules))
            if argumentType == "DateTime" then "Duration" else "DateTime"
        case None -> "DateTime"
    else "DateTime"

private fun python_stdlib_duration_method_call_type(name: String): String =
    if name == "to_iso_8601"
    then python_string_type()
    else if name == "negate"
    then "Duration"
    else python_int_type()

private fun python_collection_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    python_collection_pipe_operator(binary.operator)
        & python_collection_pipe_receiver_type(leftType)
        & python_callable_expression(binary.right)

private fun python_collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*" | operator == "|!"

private fun python_collection_pipe_receiver_type(type: String): bool =
    type == python_unknown_type()
        | type == python_list_type()
        | type == python_set_type()
        | type == python_string_type()
        | type == python_seq_type()
        | type == python_dict_type()

private fun python_collection_pipe_result_type(operator: String, leftType: String): String =
    if leftType == python_dict_type() & operator != "|*"
    then python_dict_type()
    else python_seq_type()

private fun python_result_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    python_result_pipe_operator(binary.operator)
        & python_result_pipe_receiver_type(leftType)
        & python_callable_expression(binary.right)

private fun python_result_reduce_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    binary.operator == "|>"
        & python_result_pipe_receiver_type(leftType)
        & python_result_reduce_operator_arguments_shape(binary.right)

private fun python_result_reduce_operator_arguments_shape(expression: CompiledExpression): bool =
    match expression with
    case CompiledTupleLiteral literal -> python_two_callable_arguments(literal.values)
    case _ -> false

private fun python_result_reduce_operator_type(binary: CompiledBinaryExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledTupleLiteral literal -> python_result_reduce_success_type(binary.left, literal.values, env, module, allModules)
    case _ -> python_unknown_type()

private fun python_result_reduce_success_type(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> python_unknown_type()
    case Some { argument } ->
        match argument with
        case CompiledLambdaExpression lambda ->
            python_expression_type(
                lambda.body,
                python_lambda_bindings_with_single_type(lambda.parameters, python_result_payload_type(receiver, env, module, allModules)) + env,
                module,
                allModules
            )
        case CompiledFunctionReferenceExpression reference -> python_function_name_expression_type(reference.name, module, allModules)
        case _ -> python_unknown_type()

private fun python_result_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|*"

private fun python_result_pipe_receiver_type(type: String): bool =
    type == python_result_type()
        | python_result_constructor_type(type)

private fun python_result_constructor_type(typeName: String): bool =
    python_stdlib_data_constructor_type(typeName, "Result", "Success")
        | python_stdlib_data_constructor_type(typeName, "Result", "Error")

private fun python_seq_as_list_call(call: CompiledMethodCallExpression): bool =
    call.name == "as_list"
        & call.arguments.is_empty()

private fun python_seq_first_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    call.name == "first"
        & call.arguments.is_empty()
        & python_collection_pipe_receiver_type(receiverType)

private fun python_native_collection_method_call_with_receiver_type(call: CompiledMethodCallExpression, receiverType: String): bool =
    if receiverType == python_list_type()
    then if call.name == "is_empty"
        then call.arguments.is_empty()
        else if call.name == "contains"
        then python_one_method_argument(call.arguments)
        else if call.name == "get"
        then python_one_method_argument(call.arguments) | python_two_method_arguments(call.arguments)
        else false
    else if receiverType == python_set_type()
    then if call.name == "is_empty"
        then call.arguments.is_empty()
        else if call.name == "contains"
        then python_one_method_argument(call.arguments)
        else false
    else if receiverType == python_dict_type()
    then if call.name == "is_empty"
        then call.arguments.is_empty()
        else (call.name == "contains_key" | call.name == "get") & python_one_method_argument(call.arguments)
    else if receiverType == python_tuple_type()
    then call.name == "get" & python_one_method_argument(call.arguments)
    else false

private fun python_native_collection_method_call_code(call: CompiledMethodCallExpression, receiverType: String, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType == python_list_type()
    then python_list_native_method_call_code(call, receiver, env, module, allModules)
    else if receiverType == python_set_type()
    then python_set_native_method_call_code(call, receiver, env, module, allModules)
    else if receiverType == python_dict_type()
    then python_dict_native_method_call_code(call, receiver, env, module, allModules)
    else python_tuple_native_method_call_code(call, receiver, env, module, allModules)

private fun python_list_native_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "is_empty"
    then "__capy_is_empty(" + receiver + ")"
    else if call.name == "contains"
    then "__capy_contains(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if python_two_method_arguments(call.arguments)
    then receiver + "[" + python_first_method_argument_code(call.arguments, env, module, allModules) + ":" + python_second_method_argument_code(call.arguments, env, module, allModules) + "]"
    else "__capy_index(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"

private fun python_set_native_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "is_empty"
    then "__capy_is_empty(" + receiver + ")"
    else "__capy_contains(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"

private fun python_dict_native_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "is_empty"
    then "__capy_is_empty(" + receiver + ")"
    else if call.name == "contains_key"
    then "__capy_contains(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else "__capy_index(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"

private fun python_tuple_native_method_call_code(call: CompiledMethodCallExpression, receiver: String, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_index(" + receiver + ", " + python_first_method_argument_code(call.arguments, env, module, allModules) + ")"

private fun python_native_collection_method_call_type(call: CompiledMethodCallExpression, receiverType: String): String =
    if receiverType == python_list_type()
    then if call.name == "is_empty" | call.name == "contains"
        then python_bool_type()
        else if python_two_method_arguments(call.arguments)
        then python_list_type()
        else python_option_type()
    else if receiverType == python_set_type()
    then python_bool_type()
    else if receiverType == python_dict_type()
    then if call.name == "is_empty" | call.name == "contains_key" then python_bool_type() else python_option_type()
    else python_unknown_type()

private fun python_collection_predicate_call(call: CompiledMethodCallExpression, receiverType: String): bool =
    if call.name == "any" | call.name == "all"
    then python_collection_predicate_receiver_type(receiverType)
        & python_single_callable_argument(call.arguments)
    else false

private fun python_collection_predicate_receiver_type(type: String): bool =
    type == python_list_type()
        | type == python_set_type()
        | type == python_string_type()
        | type == python_seq_type()
        | type == python_dict_type()

private fun python_single_callable_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & python_callable_expression(argument)

private fun python_two_callable_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { first } ->
        match arguments[1] with
        case None -> false
        case Some { second } ->
            arguments[2:].is_empty()
                & python_callable_expression(first)
                & python_callable_expression(second)

private fun python_truthy_expression_code(expression: CompiledExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "bool(" + python_expression_code(expression, env, module, allModules) + ")"

private fun python_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_runtime_function(name)
    then name
    else if python_qualified_name(name)
    then python_qualified_function_call_name(name, module, allModules)
    else match python_find_local_function(name, module.functions) with
    case Some { function } -> python_function_name(function)
    case None ->
        match python_find_function_binding_in_imports(name, module.imports, module, allModules) with
        case Some { binding } -> python_module_import_expression(binding.module) + "." + python_function_name(binding.function)
        case None -> python_identifier(name)

private fun python_runtime_function(name: String): bool =
    name == "assert_all"
        | name == "assert_that"
        | name == "test"
        | name == "test_file"
        | name == "reflection"
        | name == "digits"
        | name == "to_seq"
        | name == "pure"
        | name == "delay"
        | python_console_function(name)

private fun python_console_function(name: String): bool =
    name == "print" | name == "println" | name == "print_error" | name == "println_error"

private fun python_enum_parse_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_enum_parse_call_name(call.name, module, allModules)
        & python_one_method_argument(call.arguments)

private fun python_enum_parse_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_qualified_name(name)
        & python_enum_qualified_member_name(name) == "parse"
        & python_enum_type_exists(python_enum_qualified_type_name(name), module, allModules)

private fun python_enum_parse_call_code(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = python_enum_qualified_type_name(call.name)
    "__capy_enum_parse("
        + python_string_literal(typeName)
        + ", ["
        + python_enum_value_references_code(typeName, python_enum_values(typeName, module, allModules), module, allModules)
        + "], "
        + python_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"

private fun python_enum_parse_call_gatherable(call: CompiledFunctionCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_one_method_argument(call.arguments)
        & python_expressions_gatherable(call.arguments, env, module, allModules)

private fun python_enum_static_field_access(access: CompiledFieldAccessExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match access.receiver with
    case CompiledVariableExpression variable ->
        !python_binding_exists(variable.name, env)
            & python_enum_type_exists(variable.name, module, allModules)
            & (access.name == "values" | python_enum_value_exists(variable.name, access.name, module, allModules))
    case _ -> false

private fun python_enum_static_field_access_code(access: CompiledFieldAccessExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = python_enum_static_field_access_type_name(access)
    if access.name == "values"
    then "__capy_set([" + python_enum_value_references_code(typeName, python_enum_values(typeName, module, allModules), module, allModules) + "])"
    else python_enum_value_reference_code(typeName, access.name, module, allModules)

private fun python_enum_static_field_access_type(access: CompiledFieldAccessExpression): String =
    if access.name == "values"
    then python_set_type()
    else python_enum_static_field_access_type_name(access)

private fun python_enum_static_field_access_type_name(access: CompiledFieldAccessExpression): String =
    match access.receiver with
    case CompiledVariableExpression variable -> variable.name
    case _ -> ""

private fun python_qualified_enum_value_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_qualified_name(name)
        & python_enum_value_exists(python_enum_qualified_type_name(name), python_enum_qualified_member_name(name), module, allModules)

private fun python_enum_qualified_type_name(name: String): String =
    name[0, python_last_dot_index(name)]

private fun python_enum_qualified_member_name(name: String): String =
    name[python_last_dot_index(name) + 1, name.size().value]

private fun python_enum_qualified_value_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    python_enum_value_reference_code(python_enum_qualified_type_name(name), python_enum_qualified_member_name(name), module, allModules)

private fun python_enum_type_exists(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    !python_enum_values(name, module, allModules).is_empty()

private fun python_enum_value_exists(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    python_string_list_contains(valueName, python_enum_values(typeName, module, allModules))

private fun python_enum_values(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if python_enum_type_exists_in_functions(name, module.functions)
    then python_enum_values_in_functions(name, module.functions)
    else match python_enum_values_in_imports(name, module.imports, module, allModules) with
        case Some { values } -> values
        case None -> []

private fun python_enum_type_exists_in_functions(name: String, functions: List[CompiledFunction]): bool =
    !python_enum_values_in_functions(name, functions).is_empty()

private fun python_enum_values_in_functions(name: String, functions: List[CompiledFunction]): List[String] =
    python_schema_values("__capy_schema_enum|" + name + "|", functions)

private fun python_enum_values_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if python_data_import_matches(name, declaration)
        then python_enum_values_in_import(name, imports[1:], module, allModules, declaration)
        else python_enum_values_in_imports(name, imports[1:], module, allModules)

private fun python_enum_values_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[List[String]] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if python_enum_type_exists_in_functions(name, importedModule.functions)
        then /capy/lang/Option.Some { python_enum_values_in_functions(name, importedModule.functions) }
        else python_enum_values_in_imports(name, rest, module, allModules)
    case _ -> python_enum_values_in_imports(name, rest, module, allModules)

private fun python_enum_value_references_code(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        python_enum_value_reference_code(typeName, value, module, allModules)
            + python_enum_value_reference_tail(typeName, values[1:], module, allModules)

private fun python_enum_value_reference_tail(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + python_enum_value_references_code(typeName, values, module, allModules)

private fun python_enum_value_reference_code(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if python_enum_type_exists_in_functions(typeName, module.functions)
    then python_identifier(valueName)
    else match python_enum_type_imported_module(typeName, module.imports, module, allModules) with
        case Some { importedModule } -> python_module_import_expression(importedModule) + "." + python_identifier(valueName)
        case None -> python_identifier(valueName)

private fun python_enum_type_imported_module(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if python_data_import_matches(name, declaration)
        then python_enum_type_imported_module_from(name, imports[1:], module, allModules, declaration)
        else python_enum_type_imported_module(name, imports[1:], module, allModules)

private fun python_enum_type_imported_module_from(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[CompiledModule] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if python_enum_type_exists_in_functions(name, importedModule.functions)
        then /capy/lang/Option.Some { importedModule }
        else python_enum_type_imported_module(name, rest, module, allModules)
    case _ -> python_enum_type_imported_module(name, rest, module, allModules)

private fun python_qualified_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match python_find_qualified_function_binding(name, module, allModules) with
    case Some { binding } -> python_module_import_expression(binding.module) + "." + python_function_name(binding.function)
    case None -> python_identifier(name)

private fun python_module_import_expression(module: CompiledModule): String =
    "__import__(" + python_string_literal(python_module_import_name(module)) + ", fromlist=['*'])"

private fun python_find_qualified_function_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    match python_find_module_by_path(python_qualified_call_module_path(name, module), allModules) with
    case Some { targetModule } -> python_find_qualified_function_in_module(python_qualified_call_member(name), targetModule)
    case None -> /capy/lang/Option.None {}

private fun python_find_qualified_function_in_module(name: String, module: CompiledModule): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    match python_find_local_function(name, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { PythonQualifiedFunctionBinding { module: module, function: function } }
    case None -> /capy/lang/Option.None {}

private fun python_qualified_name(name: String): bool =
    let idx = python_last_dot_index(name)
    idx > 0 & idx < name.size().value - 1

private fun python_qualified_call_member(name: String): String =
    let idx = python_last_dot_index(name)
    if idx < 0 then name else name[idx + 1, name.size().value]

private fun python_qualified_call_module_path(name: String, module: CompiledModule): String =
    python_qualified_module_path(python_qualified_call_class_name(name), module)

private fun python_qualified_call_class_name(name: String): String =
    let idx = python_last_dot_index(name)
    if idx < 0 then name else name[0, idx]

private fun python_qualified_import_matches(qualifier: String, declaration: CompiledImportDeclaration, module: CompiledModule): bool =
    let importPath = python_import_module_path(declaration.modulePath, module)
    qualifier == declaration.modulePath
        | qualifier == importPath
        | qualifier == python_module_leaf_name(importPath)

private fun python_qualified_module_path(name: String, module: CompiledModule): String =
    if python_string_has_prefix(name, "/")
    then python_normalize_import_module_path(name).replace(".", "/")
    else if name ? "/"
    then python_normalize_import_module_path(name)
    else if name ? "."
    then name.replace(".", "/")
    else if module.path.is_empty()
    then name
    else module.path + "/" + name

private fun python_module_leaf_name(modulePath: String): String =
    let idx = python_last_index_of(modulePath, "/")
    if idx < 0 then modulePath else modulePath[idx + 1, modulePath.size().value]

private fun python_overload_request_name(name: String, argumentType: String): String =
    name + "__capy_overload_arg__" + argumentType

private fun python_overload_request(name: String): bool =
    name ? "__capy_overload_arg__"

private fun python_overload_requested_function_name(name: String): String =
    let marker = python_first_index_of(name, "__capy_overload_arg__", 0)
    if marker < 0 then name else name[0, marker]

private fun python_overload_requested_argument_type(name: String): String =
    let marker = python_first_index_of(name, "__capy_overload_arg__", 0)
    if marker < 0 then python_unknown_type() else name[marker + "__capy_overload_arg__".size().value, name.size().value]

private fun python_type_reference_name_key(name: String, argumentName: String): String =
    if argumentName.is_empty()
    then name
    else name + "[" + argumentName + "]"

private fun python_type_key_match_score(target: String, source: String): int =
    if target == source
    then 0
    else if source == python_unknown_type() | source.is_empty()
    then 1000000
    else if python_type_key_base(target) == python_type_key_base(source) & python_type_key_has_argument(target) & python_type_key_has_argument(source)
    then python_type_key_match_score(python_type_key_argument(target), python_type_key_argument(source))
    else if python_primitive_numeric_widening_type_key(target, source)
    then 10
    else 1000000

private fun python_type_key_base(typeKey: String): String =
    let bracket = python_first_index_of(typeKey, "[", 0)
    if bracket < 0 then typeKey else typeKey[0, bracket]

private fun python_type_key_has_argument(typeKey: String): bool =
    python_first_index_of(typeKey, "[", 0) >= 0

private fun python_type_key_argument(typeKey: String): String =
    let start = python_first_index_of(typeKey, "[", 0)
    let end = python_first_index_of(typeKey, "]", 0)
    if start < 0 | end <= start
    then python_unknown_type()
    else typeKey[start + 1, end]

private fun python_primitive_numeric_widening_type_key(target: String, source: String): bool =
    !(source ? "[") & !(target ? "[") & (
        (source == "byte" & (target == "int" | target == "long" | target == "float" | target == "double"))
        | (source == "int" & (target == "long" | target == "float" | target == "double"))
        | (source == "long" & (target == "float" | target == "double"))
        | (source == "float" & target == "double")
    )

private fun python_find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if python_callable_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else python_find_function(name, functions[1:])

private fun python_callable_function(function: CompiledFunction): bool =
    !python_skip_function(function) & function.visibility != "private" & function.visibility != "const:private"

private fun python_find_local_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    if python_overload_request(name)
    then python_find_local_overload(
        python_overload_requested_function_name(name),
        python_overload_requested_argument_type(name),
        functions,
        /capy/lang/Option.None {},
        1000000
    )
    else python_find_local_function_by_name(name, functions)

private fun python_find_local_function_by_name(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if !python_skip_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else python_find_local_function_by_name(name, functions[1:])

private fun python_find_local_overload(name: String, argumentType: String, functions: List[CompiledFunction], best: /capy/lang/Option[CompiledFunction], bestScore: int): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> best
    case Some { function } ->
        if !python_skip_function(function) & function.name == name
        then
            let score = python_function_first_parameter_match_score(function, argumentType)
            if score == 0
            then /capy/lang/Option.Some { function }
            else if score < bestScore
            then python_find_local_overload(name, argumentType, functions[1:], /capy/lang/Option.Some { function }, score)
            else python_find_local_overload(name, argumentType, functions[1:], best, bestScore)
        else python_find_local_overload(name, argumentType, functions[1:], best, bestScore)

private fun python_function_first_parameter_match_score(function: CompiledFunction, argumentType: String): int =
    match function.parameters[0] with
    case None -> 1000000
    case Some { parameter } ->
        python_type_key_match_score(
            python_type_reference_name_key(parameter.typeReference.name, python_first_type_argument_name(parameter.typeReference.arguments)),
            argumentType
        )

private fun python_find_local_overload_in_module(name: String, argumentType: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    python_find_local_overload_in_module_functions(name, argumentType, module.functions, /capy/lang/Option.None {}, 1000000, module, allModules)

private fun python_find_local_overload_in_module_functions(name: String, argumentType: String, functions: List[CompiledFunction], best: /capy/lang/Option[CompiledFunction], bestScore: int, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> best
    case Some { function } ->
        if !python_skip_function(function) & function.name == name
        then
            let score = python_function_first_parameter_match_score_in_module(function, argumentType, module, allModules)
            if score == 0
            then /capy/lang/Option.Some { function }
            else if score < bestScore
            then python_find_local_overload_in_module_functions(name, argumentType, functions[1:], /capy/lang/Option.Some { function }, score, module, allModules)
            else python_find_local_overload_in_module_functions(name, argumentType, functions[1:], best, bestScore, module, allModules)
        else python_find_local_overload_in_module_functions(name, argumentType, functions[1:], best, bestScore, module, allModules)

private fun python_function_first_parameter_match_score_in_module(function: CompiledFunction, argumentType: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    match function.parameters[0] with
    case None -> 1000000
    case Some { parameter } ->
        python_type_key_match_score_in_module(
            python_type_reference_name_key(parameter.typeReference.name, python_first_type_argument_name(parameter.typeReference.arguments)),
            argumentType,
            module,
            allModules
        )

private fun python_type_key_match_score_in_module(target: String, source: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    if target == source
    then 0
    else if source == python_unknown_type() | source.is_empty()
    then 1000000
    else if target == python_unknown_type()
    then 1000
    else if python_type_key_base(target) == python_type_key_base(source) & python_type_key_has_argument(target) & python_type_key_has_argument(source)
    then python_type_key_match_score_in_module(python_type_key_argument(target), python_type_key_argument(source), module, allModules)
    else if python_primitive_numeric_widening_type_key(target, source)
    then 10
    else python_parent_type_key_match_score(target, source, module, allModules)

private fun python_parent_type_key_match_score(target: String, source: String, module: CompiledModule, allModules: List[CompiledModule]): int =
    if python_type_key_has_argument(target) | python_type_key_has_argument(source)
    then 1000000
    else python_parent_type_key_match_score_from(target, python_data_type_parent_types(python_type_key_base(source), module, allModules), module, allModules, 1, 1000000)

private fun python_parent_type_key_match_score_from(target: String, parents: List[String], module: CompiledModule, allModules: List[CompiledModule], distance: int, best: int): int =
    match parents[0] with
    case None -> best
    case Some { parent } ->
        let parentName = python_schema_type_name(parent)
        let score =
            if target == parentName
            then distance
            else python_parent_type_key_match_score_from(target, python_data_type_parent_types(parentName, module, allModules), module, allModules, distance + 1, best)
        let nextBest = if score < best then score else best
        python_parent_type_key_match_score_from(target, parents[1:], module, allModules, distance, nextBest)

private fun python_find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match python_find_function_binding_in_imports(name, imports, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding.function }
    case None -> /capy/lang/Option.None {}

private fun python_find_constant_binding_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    python_find_binding_in_imports(name, imports, module, allModules, true)

private fun python_find_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if python_emitted_constant(function) & function.visibility != "const:private" & function.name == name
        then /capy/lang/Option.Some { function }
        else python_find_constant(name, functions[1:])

private fun python_find_function_binding_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    python_find_binding_in_imports(name, imports, module, allModules, false)

private fun python_find_binding_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], constant: bool): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified | !python_import_includes_name(name, declaration)
        then python_find_binding_in_imports(name, imports[1:], module, allModules, constant)
        else python_find_binding_in_import(name, declaration, imports[1:], module, allModules, constant)

private fun python_find_binding_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], constant: bool): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> python_find_imported_binding_or_rest(name, importedModule, rest, module, allModules, constant)
    case None -> python_find_binding_in_imports(name, rest, module, allModules, constant)

private fun python_find_imported_binding_or_rest(name: String, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], constant: bool): /capy/lang/Option[PythonQualifiedFunctionBinding] =
    match python_find_imported_binding(name, importedModule.functions, constant) with
    case Some { function } -> /capy/lang/Option.Some { PythonQualifiedFunctionBinding { module: importedModule, function: function } }
    case None -> python_find_binding_in_imports(name, rest, module, allModules, constant)

private fun python_find_imported_binding(name: String, functions: List[CompiledFunction], constant: bool): /capy/lang/Option[CompiledFunction] =
    if constant
    then python_find_constant(name, functions)
    else python_find_function(name, functions)

private fun python_find_imported_module(declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    python_find_module_by_path(python_import_module_path(declaration.modulePath, module), allModules)

private fun python_compiled_object_classes(functions: List[CompiledFunction]): List[CompiledObjectOrientedClass] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_object_class_schema(function)
        then [python_compiled_object_class(function, functions)] + python_compiled_object_classes(functions[1:])
        else python_compiled_object_classes(functions[1:])

private fun python_compiled_object_class_schema(function: CompiledFunction): bool =
    python_compiled_schema(function) & python_string_has_prefix(function.name, "__capy_oo_class|")

private fun python_compiled_object_class(function: CompiledFunction, functions: List[CompiledFunction]): CompiledObjectOrientedClass =
    let className = function.name["__capy_oo_class|".size().value, function.name.size().value]
    CompiledObjectOrientedClass {
        name: className,
        visibility: python_schema_value(function),
        open: python_compiled_object_class_open(className, functions),
        parameters: python_compiled_object_class_parameters(className, functions),
        parents: python_object_schema_type_references(python_schema_values("__capy_oo_parent|" + className + "|", functions)),
        fields: python_compiled_object_fields(className, functions),
        initBlocks: python_compiled_object_init_blocks(className, functions),
        methods: python_compiled_object_methods(className, functions),
        location: function.location
    }

private fun python_compiled_object_class_open(className: String, functions: List[CompiledFunction]): bool =
    match python_schema_value_named("__capy_oo_class_open|" + className, functions) with
    case Some { value } -> value == "true"
    case None -> false

private fun python_compiled_object_class_parameters(className: String, functions: List[CompiledFunction]): List[CompiledFunctionParameter] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_object_class_parameter_schema(function, className)
        then [python_compiled_object_class_parameter(function)] + python_compiled_object_class_parameters(className, functions[1:])
        else python_compiled_object_class_parameters(className, functions[1:])

private fun python_compiled_object_class_parameter_schema(function: CompiledFunction, className: String): bool =
    python_compiled_schema(function) & python_string_has_prefix(function.name, "__capy_oo_param|" + className + "|")

private fun python_compiled_object_class_parameter(function: CompiledFunction): CompiledFunctionParameter =
    let value = python_schema_value(function)
    let separator = python_first_index_of(value, "|", 0)
    if separator < 0
    then CompiledFunctionParameter {
        name: value,
        typeReference: CompiledTypeReference { name: python_unknown_type(), arguments: [] },
        location: function.location
    }
    else CompiledFunctionParameter {
        name: value[0, separator],
        typeReference: python_object_schema_type_reference(value[separator + 1, value.size().value]),
        location: function.location
    }

private fun python_object_schema_type_reference(value: String): CompiledTypeReference =
    CompiledTypeReference { name: python_schema_type_name(value), arguments: [] }

private fun python_object_schema_type_references(values: List[String]): List[CompiledTypeReference] =
    match values[0] with
    case None -> []
    case Some { value } -> [python_object_schema_type_reference(value)] + python_object_schema_type_references(values[1:])

private fun python_compiled_object_fields(className: String, functions: List[CompiledFunction]): List[CompiledObjectOrientedField] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_object_field_schema_for_class(function, className)
        then [python_compiled_object_field(className, function, functions)] + python_compiled_object_fields(className, functions[1:])
        else python_compiled_object_fields(className, functions[1:])

private fun python_compiled_object_field_schema_for_class(function: CompiledFunction, className: String): bool =
    python_compiled_schema(function) & python_string_has_prefix(function.name, "__capy_oo_field|" + className + "|")

private fun python_compiled_object_field(className: String, function: CompiledFunction, functions: List[CompiledFunction]): CompiledObjectOrientedField =
    let value = python_schema_value(function)
    let fieldName = python_object_field_schema_name(value)
    CompiledObjectOrientedField {
        name: fieldName,
        visibility: python_object_field_schema_visibility(value),
        typeReference: python_object_schema_type_reference(python_object_field_schema_type(value)),
        value: python_compiled_object_field_value(className, fieldName, functions, function.location),
        hasValue: python_object_field_schema_has_value(value),
        location: function.location
    }

private fun python_compiled_object_field_value(className: String, fieldName: String, functions: List[CompiledFunction], location: CompiledSourceLocation): CompiledExpression =
    match python_find_compiled_object_field_init(className, fieldName, functions) with
    case Some { function } -> function.body
    case None -> CompiledUnsupportedExpression { source: "", location: location }

private fun python_find_compiled_object_field_init(className: String, fieldName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == "__capy_oo_field_init|" + className + "|" + fieldName
        then /capy/lang/Option.Some { function }
        else python_find_compiled_object_field_init(className, fieldName, functions[1:])

private fun python_object_field_schema_name(value: String): String =
    let first = python_first_index_of(value, "|", 0)
    if first < 0 then value else value[0, first]

private fun python_object_field_schema_visibility(value: String): String =
    let first = python_first_index_of(value, "|", 0)
    let second = if first < 0 then -1 else python_first_index_of(value, "|", first + 1)
    if first < 0 | second < 0 then "public" else value[first + 1, second]

private fun python_object_field_schema_type(value: String): String =
    let second = python_object_field_schema_second_separator(value)
    let last = python_object_field_schema_last_separator(value)
    if second < 0
    then "any"
    else if last <= second
    then value[second + 1, value.size().value]
    else value[second + 1, last]

private fun python_object_field_schema_has_value(value: String): bool =
    let last = python_object_field_schema_last_separator(value)
    last >= 0 & value[last + 1, value.size().value] == "true"

private fun python_object_field_schema_second_separator(value: String): int =
    let first = python_first_index_of(value, "|", 0)
    if first < 0 then -1 else python_first_index_of(value, "|", first + 1)

private fun python_object_field_schema_last_separator(value: String): int =
    python_last_index_of(value, "|")

private fun python_compiled_object_init_blocks(className: String, functions: List[CompiledFunction]): List[CompiledExpression] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_object_init_function_for_class(function, className)
        then [function.body] + python_compiled_object_init_blocks(className, functions[1:])
        else python_compiled_object_init_blocks(className, functions[1:])

private fun python_compiled_object_init_function_for_class(function: CompiledFunction, className: String): bool =
    if python_string_has_prefix(function.name, "__capy_oo_init|")
    then python_compiled_object_init_class_name(function.name) == className
    else false

private fun python_compiled_object_init_class_name(name: String): String =
    let rest = name["__capy_oo_init|".size().value, name.size().value]
    let separator = python_first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

private fun python_compiled_object_methods(className: String, functions: List[CompiledFunction]): List[CompiledObjectOrientedMethod] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if python_compiled_object_method_function(function, className)
        then [python_compiled_object_method(function)] + python_compiled_object_methods(className, functions[1:])
        else python_compiled_object_methods(className, functions[1:])

private fun python_compiled_object_method_function(function: CompiledFunction, className: String): bool =
    python_string_has_prefix(function.name, "__capy_oo_method|") & python_compiled_object_method_class_name(function.name) == className

private fun python_compiled_object_method(function: CompiledFunction): CompiledObjectOrientedMethod =
    CompiledObjectOrientedMethod {
        name: python_compiled_object_method_name(function.name),
        visibility: python_compiled_object_method_visibility(function.visibility),
        parameters: function.parameters,
        returnType: function.returnType,
        body: function.body,
        location: function.location
    }

private fun python_compiled_object_method_class_name(name: String): String =
    let rest = name["__capy_oo_method|".size().value, name.size().value]
    let separator = python_first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

private fun python_compiled_object_method_name(name: String): String =
    let rest = name["__capy_oo_method|".size().value, name.size().value]
    let separator = python_first_index_of(rest, "|", 0)
    if separator < 0 then "" else rest[separator + 1, rest.size().value]

private fun python_compiled_object_method_visibility(visibility: String): String =
    if python_string_has_prefix(visibility, "oo:")
    then visibility[3, visibility.size().value]
    else visibility

private fun python_compiled_object_interface_method_function_for_interface(function: CompiledFunction, interfaceName: String): bool =
    if python_compiled_object_interface_method_function(function)
    then python_compiled_object_interface_method_owner_name(function.name) == interfaceName
    else false

private fun python_compiled_object_interface_method_function(function: CompiledFunction): bool =
    python_string_has_prefix(function.name, "__capy_oo_interface_method|")

private fun python_compiled_object_interface_method_owner_name(name: String): String =
    let rest = name["__capy_oo_interface_method|".size().value, name.size().value]
    let separator = python_first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

private fun python_compiled_object_interface_method_name(name: String): String =
    let rest = name["__capy_oo_interface_method|".size().value, name.size().value]
    let separator = python_first_index_of(rest, "|", 0)
    if separator < 0 then "" else rest[separator + 1, rest.size().value]

private fun python_find_object_class_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonObjectClassBinding] =
    if python_qualified_name(name)
    then python_find_qualified_object_class(name, module, allModules)
    else match python_find_object_class(name, module) with
    case Some { binding } -> /capy/lang/Option.Some { binding }
    case None -> python_find_object_class_in_imports(name, module.imports, module, allModules)

private fun python_find_qualified_object_class(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonObjectClassBinding] =
    let className = python_qualified_call_member(name)
    match python_find_module_by_path(python_qualified_call_module_path(name, module), allModules) with
    case Some { targetModule } -> python_find_object_class(className, targetModule)
    case None -> /capy/lang/Option.None {}

private fun python_find_object_class(name: String, module: CompiledModule): /capy/lang/Option[PythonObjectClassBinding] =
    python_find_object_class_in_classes(name, python_compiled_object_classes(module.functions), module)

private fun python_find_object_class_in_classes(name: String, classes: List[CompiledObjectOrientedClass], module: CompiledModule): /capy/lang/Option[PythonObjectClassBinding] =
    match classes[0] with
    case None -> /capy/lang/Option.None {}
    case Some { objectClass } ->
        if objectClass.name == name
        then /capy/lang/Option.Some { PythonObjectClassBinding { module: module, objectClass: objectClass } }
        else python_find_object_class_in_classes(name, classes[1:], module)

private fun python_find_object_class_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonObjectClassBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !python_stdlib_import(declaration.modulePath) & !declaration.qualified & python_import_includes_name(name, declaration)
        then python_find_object_class_in_import(name, imports[1:], declaration, module, allModules)
        else python_find_object_class_in_imports(name, imports[1:], module, allModules)

private fun python_find_object_class_in_import(name: String, rest: List[CompiledImportDeclaration], declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonObjectClassBinding] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match python_find_object_class(name, importedModule) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> python_find_object_class_in_imports(name, rest, module, allModules)
    }
    case None -> python_find_object_class_in_imports(name, rest, module, allModules)

private fun python_find_object_interface_module_in_scope(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    if python_qualified_name(name)
    then python_find_qualified_object_interface_module(name, module, allModules)
    else if python_object_interface_declared(name, module)
    then /capy/lang/Option.Some { module }
    else python_find_object_interface_module_in_imports(name, module.imports, module, allModules)

private fun python_find_qualified_object_interface_module(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    let interfaceName = python_qualified_call_member(name)
    match python_find_module_by_path(python_qualified_call_module_path(name, module), allModules) with
    case Some { targetModule } ->
        if python_object_interface_declared(interfaceName, targetModule)
        then /capy/lang/Option.Some { targetModule }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

private fun python_object_interface_declared(name: String, module: CompiledModule): bool =
    match python_schema_value_named("__capy_oo_interface|" + name, module.functions) with
    case Some _ -> true
    case None -> false

private fun python_find_object_interface_module_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !python_stdlib_import(declaration.modulePath) & !declaration.qualified & python_import_includes_name(name, declaration)
        then python_find_object_interface_module_in_import(name, imports[1:], declaration, module, allModules)
        else python_find_object_interface_module_in_imports(name, imports[1:], module, allModules)

private fun python_find_object_interface_module_in_import(name: String, rest: List[CompiledImportDeclaration], declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match python_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if python_object_interface_declared(name, importedModule)
        then /capy/lang/Option.Some { importedModule }
        else python_find_object_interface_module_in_imports(name, rest, module, allModules)
    case None -> python_find_object_interface_module_in_imports(name, rest, module, allModules)

private fun python_object_interface_member_name(name: String): String =
    if python_qualified_name(name) then python_qualified_call_member(name) else name

private fun python_find_object_class_by_type(typeName: String, modules: List[CompiledModule]): /capy/lang/Option[PythonObjectClassBinding] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match python_find_object_class_by_type_in_module(typeName, python_compiled_object_classes(module.functions), module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> python_find_object_class_by_type(typeName, modules[1:])

private fun python_find_object_class_by_type_in_module(typeName: String, classes: List[CompiledObjectOrientedClass], module: CompiledModule): /capy/lang/Option[PythonObjectClassBinding] =
    match classes[0] with
    case None -> /capy/lang/Option.None {}
    case Some { objectClass } ->
        if typeName == python_object_type_name(module, objectClass.name)
        then /capy/lang/Option.Some { PythonObjectClassBinding { module: module, objectClass: objectClass } }
        else python_find_object_class_by_type_in_module(typeName, classes[1:], module)

private fun python_find_object_method(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[PythonObjectMethodBinding] =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    match python_find_object_class_by_type(receiverType, allModules) with
    case Some { binding } -> {
        match python_find_object_method_in_methods(call.name, binding.objectClass.methods) with
        case Some { method } -> /capy/lang/Option.Some { PythonObjectMethodBinding { module: binding.module, objectClass: binding.objectClass, method: method } }
        case None -> /capy/lang/Option.None {}
    }
    case None -> /capy/lang/Option.None {}

private fun python_find_object_method_in_methods(name: String, methods: List[CompiledObjectOrientedMethod]): /capy/lang/Option[CompiledObjectOrientedMethod] =
    match methods[0] with
    case None -> /capy/lang/Option.None {}
    case Some { method } ->
        if method.name == name
        then /capy/lang/Option.Some { method }
        else python_find_object_method_in_methods(name, methods[1:])

private fun python_object_class_reference(binding: PythonObjectClassBinding, module: CompiledModule): String =
    if python_same_module(binding.module, module)
    then python_identifier(binding.objectClass.name)
    else python_module_import_expression(binding.module) + "." + python_identifier(binding.objectClass.name)

private fun python_same_module(first: CompiledModule, second: CompiledModule): bool =
    first.name == second.name & first.path == second.path

private fun python_object_type_name(module: CompiledModule, className: String): String =
    "__capy_oo|" + python_module_path(module) + "." + python_identifier(className)

private fun python_find_extension_method(call: CompiledMethodCallExpression, env: List[PythonBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = python_expression_type(call.receiver, env, module, allModules)
    if receiverType == python_unknown_type()
    then /capy/lang/Option.None {}
    else python_find_extension_method_in_scope(receiverType, call.name, module, allModules)

private fun python_find_binary_extension_operator_with_left_type(binary: CompiledBinaryExpression, leftType: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    if leftType == python_unknown_type()
    then /capy/lang/Option.None {}
    else python_find_extension_method_in_scope(leftType, binary.operator, module, allModules)

private fun python_find_extension_method_in_scope(ownerName: String, methodName: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match python_find_method_function(ownerName, methodName, module.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> python_find_extension_method_in_imports(ownerName, methodName, module.imports, module, allModules)

private fun python_find_method_function(ownerName: String, methodName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if python_method_function_matches(ownerName, methodName, function)
        then /capy/lang/Option.Some { function }
        else python_find_method_function(ownerName, methodName, functions[1:])

private fun python_method_function_matches(ownerName: String, methodName: String, function: CompiledFunction): bool =
    if python_skip_function(function) | !python_extension_method_function(function)
    then false
    else
        let idx = python_last_dot_index(function.name)
        if idx < 0
        then false
        else python_method_owner_base_name(function.name[0, idx]) == python_method_owner_base_name(ownerName)
            & python_method_member_name(function.name[idx + 1, function.name.size().value]) == python_method_member_name(methodName)

private fun python_find_extension_method_in_imports(ownerName: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.wildcard
            & !declaration.qualified
            & !python_stdlib_import(declaration.modulePath)
            & !python_string_list_contains(methodName, declaration.excludedNames)
        then python_find_extension_method_in_import(ownerName, methodName, imports[1:], declaration, module, allModules)
        else python_find_extension_method_in_imports(ownerName, methodName, imports[1:], module, allModules)

private fun python_find_extension_method_in_import(ownerName: String, methodName: String, rest: List[CompiledImportDeclaration], declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match python_find_imported_module(declaration, module, allModules) with
    case None -> python_find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)
    case Some { importedModule } ->
        match python_find_method_function(ownerName, methodName, importedModule.functions) with
        case Some { function } -> /capy/lang/Option.Some { function }
        case None -> python_find_extension_method_in_imports(ownerName, methodName, rest, module, allModules)

private fun python_import_module_path(modulePath: String, module: CompiledModule): String =
    if python_string_has_prefix(modulePath, "/")
    then python_normalize_import_module_path(modulePath)
    else if modulePath ? "/"
    then python_normalize_import_module_path(modulePath)
    else if module.path.is_empty()
    then modulePath
    else module.path + "/" + modulePath

private fun python_normalize_import_module_path(path: String): String =
    let normalized = if python_string_has_prefix(path, "/") then path[1, path.size().value] else path
    if python_string_has_prefix(normalized, "dev/capylang/capybara/")
    then python_normalize_capybara_import_suffix(normalized["dev/capylang/capybara/".size().value, normalized.size().value], "dev/capylang/")
    else if python_string_has_prefix(normalized, "capybara/")
    then python_normalize_capybara_import_suffix(normalized["capybara/".size().value, normalized.size().value], "")
    else normalized

private fun python_normalize_capybara_import_suffix(suffix: String, prefix: String): String =
    if python_string_has_prefix(suffix, "test/")
    then prefix + suffix
    else prefix + "test/" + suffix

private fun python_find_module_by_path(modulePath: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if python_module_path(module) == modulePath
        then /capy/lang/Option.Some { module }
        else python_find_module_by_path(modulePath, modules[1:])

private fun python_import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !python_string_list_contains(name, declaration.excludedNames)
    else python_string_list_contains(name, declaration.importedNames)

private fun python_string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> item == value | python_string_list_contains(value, values[1:])

private fun python_module_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

private fun python_extension_method_function(function: CompiledFunction): bool =
    python_last_dot_index(function.name) >= 0 & !(function.name ? "__local__")

private fun python_method_owner_name(name: String): String =
    let idx = python_last_dot_index(name)
    if idx < 0 then "" else name[0, idx]

private fun python_method_owner_base_name(name: String): String =
    let bracket = python_first_index_of(name, "[", 0)
    if bracket < 0 then name else name[0, bracket]

private fun python_type_unqualified_name(name: String): String =
    let withoutArguments = python_method_owner_base_name(name)
    let afterSlash = python_after_last_separator(withoutArguments, "/")
    python_after_last_separator(afterSlash, ".")

private fun python_after_last_separator(value: String, separator: String): String =
    let idx = python_last_index_of(value, separator)
    if idx < 0 then value else value[idx + 1, value.size().value]

private fun python_method_member_name(name: String): String =
    if name.size().value >= 2 & python_string_has_prefix(name, "`")
    then name[1, name.size().value - 1]
    else name

private fun python_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else python_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

private fun python_method_name(name: String): String =
    python_identifier(name)

private fun python_lookup_binding(name: String, env: List[PythonBinding]): /capy/lang/Option[PythonBinding] =
    match env[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding }
        else python_lookup_binding(name, env[1:])

private fun python_binding_exists(name: String, env: List[PythonBinding]): bool =
    match python_lookup_binding(name, env) with
    case Some _ -> true
    case None -> false

private fun python_test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.py",
        code: python_test_runtime_code(modules)
    }]

private fun python_native_runtime_modules(): List[GeneratedModule] =
    [GeneratedModule {
        relativePath: "dev/capylang/capybara.py",
        code: python_native_runtime_code()
    }]

private fun python_native_runtime_code(): String =
    "# Generated by Capybara." + python_newline()
    + python_newline()
    + "def NativeImplementation(_target=None, qualifier=\"\"):" + python_newline()
    + "    if isinstance(_target, str):" + python_newline()
    + "        selected_qualifier = _target" + python_newline()
    + "        def decorate(cls):" + python_newline()
    + "            cls.__capy_native_qualifier__ = selected_qualifier" + python_newline()
    + "            return cls" + python_newline()
    + "        return decorate" + python_newline()
    + "    def decorate(cls):" + python_newline()
    + "        cls.__capy_native_qualifier__ = qualifier" + python_newline()
    + "        return cls" + python_newline()
    + "    if _target is None:" + python_newline()
    + "        return decorate" + python_newline()
    + "    return decorate(_target)" + python_newline()

private fun python_test_runtime_code(modules: List[CompiledModule]): String =
    python_test_runtime_header_code()
    + python_test_runtime_effect_code()
    + python_test_runtime_io_code()
    + python_test_runtime_assert_code()
    + python_test_runtime_numeric_code()
    + python_test_runtime_enum_code()
    + python_test_runtime_date_time_code()
    + python_test_runtime_collection_helpers_code()
    + python_test_runtime_error_code()
    + python_runtime_data_helpers_code()
    + python_test_runtime_reflection_code(modules)
    + python_test_runtime_effect_helpers_code()
    + python_test_runtime_gather_code(modules)

private fun python_test_runtime_header_code(): String =
    "# Generated by Capybara." + python_newline()
    + "import builtins" + python_newline()
    + "import importlib" + python_newline()
    + "import inspect" + python_newline()
    + "import math" + python_newline()
    + "import pathlib" + python_newline()
    + "import re" + python_newline()
    + "import shutil" + python_newline()
    + "import sys" + python_newline()
    + "import time" + python_newline()
    + python_newline()
    + "__all__ = ['Effect', 'CapySet', 'pure', 'delay', 'print', 'println', 'print_error', 'println_error', 'DEFAULT_FAILED_EXIT_CODE', 'assert_all', 'assert_that', 'test', 'test_file', 'reflection', 'from_string', 'read_text', 'read_lines', 'read_bytes', 'write_text', 'write_lines', 'write_bytes', 'append_text', 'append_lines', 'append_bytes', 'exists', 'is_file', 'is_directory', 'size', 'create_file', 'create_directory', 'create_directories', 'list_entries', 'delete', 'copy', 'copy_replace', 'move', 'move_replace', 'digits', 'to_seq', '__capy_current_millis', '__capy_nano_time', '__capy_clock_now', '_unsafe_run', '_capy_data_is', '_capy_data_value', '__capy_bind_value', '__capy_effect_bind_value', '__capy_long', '__capy_to_int', '__capy_to_long', '__capy_parse_int', '__capy_parse_long', '__capy_parse_double', '__capy_parse_float', '__capy_parse_bool', '__capy_enum_parse', '__capy_enum_name', '__capy_char', '__capy_to_string', '__capy_date_unix_date', '__capy_time_midnight', '__capy_date_time_unix_epoch', '__capy_duration_zero', '__capy_date_add_days', '__capy_date_add_years_months', '__capy_date_to_days_since_unix_epoch', '__capy_date_to_iso_8601', '__capy_time_add_seconds', '__capy_time_to_seconds', '__capy_time_to_iso_8601', '__capy_date_time_plus', '__capy_date_time_minus', '__capy_date_time_timestamp', '__capy_date_time_to_iso_8601', '__capy_duration_to_iso_8601', '__capy_duration_negate', '__capy_duration_years', '__capy_duration_months', '__capy_duration_days', '__capy_duration_hours', '__capy_duration_minutes', '__capy_duration_seconds', '__capy_set', '__capy_set_append', '__capy_set_concat', '__capy_set_remove', '__capy_set_remove_all', '__capy_set_subset', '__capy_set_proper_subset', '__capy_set_intersection', '__capy_set_symmetric_difference', '__capy_set_cartesian_product', '__capy_set_power_set', '__capy_deep_equal', '__capy_add', '__capy_sub', '__capy_mul', '__capy_div', '__capy_mod', '__capy_pow', '__capy_pow_int', '__capy_contains', '__capy_size', '__capy_is_empty', '__capy_string_trim', '__capy_string_replace', '__capy_string_starts_with', '__capy_string_end_with', '__capy_string_get', '__capy_string_slice', '__capy_regex_matches', '__capy_regex_find', '__capy_regex_find_all', '__capy_regex_replace', '__capy_regex_split', '__capy_index', '__capy_get_field', '__capy_reduce', '__capy_as_list', '__capy_seq_map', '__capy_seq_filter', '__capy_seq_reject', '__capy_seq_flat_map', '__capy_option_map', '__capy_option_filter', '__capy_option_flat_map', '__capy_option_reduce', '__capy_result_map', '__capy_result_flat_map', '__capy_result_or', '__capy_result_or_else', '__capy_result_reduce', '__capy_any', '__capy_all', '__capy_type_matches', '__capy_match_binding', '__capy_no_match', '__capy_unsupported', '__capy_not_implemented', '__capy_reflection_annotations', '__capy_data', '__capy_with', '__capy_constructor_value', '__capy_constructor_result', '__capy_primitive_constructor_result', '__capy_constructor_pipeline']" + python_newline()
    + python_newline()

private fun python_test_runtime_effect_code(): String =
    "class Effect:" + python_newline()
    + "    def __init__(self, thunk):" + python_newline()
    + "        self._thunk = thunk" + python_newline()
    + python_newline()
    + "    def unsafe_run(self):" + python_newline()
    + "        return self._thunk()" + python_newline()
    + python_newline()
    + "    def map(self, mapper):" + python_newline()
    + "        return Effect(lambda: mapper(self.unsafe_run()))" + python_newline()
    + python_newline()
    + "    def flat_map(self, mapper):" + python_newline()
    + "        return Effect(lambda: _unsafe_run(mapper(self.unsafe_run())))" + python_newline()
    + python_newline()
    + "    @staticmethod" + python_newline()
    + "    def delay(thunk):" + python_newline()
    + "        return Effect(thunk)" + python_newline()
    + python_newline()
    + "    @staticmethod" + python_newline()
    + "    def pure(value):" + python_newline()
    + "        return Effect(lambda: value)" + python_newline()
    + python_newline()
    + "def pure(value):" + python_newline()
    + "    return Effect.pure(value)" + python_newline()
    + python_newline()
    + "def delay(thunk):" + python_newline()
    + "    return Effect.delay(thunk)" + python_newline()
    + python_newline()
    + "def __capy_current_millis():" + python_newline()
    + "    return Effect.delay(lambda: __capy_long(int(time.time() * 1000)))" + python_newline()
    + python_newline()
    + "def __capy_nano_time():" + python_newline()
    + "    return Effect.delay(lambda: __capy_long(time.monotonic_ns()))" + python_newline()
    + python_newline()
    + "def __capy_clock_now():" + python_newline()
    + "    def __capy_run_clock_now():" + python_newline()
    + "        current = time.gmtime()" + python_newline()
    + "        return __capy_date_time(__capy_date(current.tm_mday, current.tm_mon, current.tm_year), __capy_time(current.tm_hour, current.tm_min, current.tm_sec, __capy_some(0)))" + python_newline()
    + "    return Effect.delay(__capy_run_clock_now)" + python_newline()
    + python_newline()
    + "def _console_print(value, newline, error):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    builtins.print(__capy_str(value), end='\\n' if newline else '', file=sys.stderr if error else sys.stdout)" + python_newline()
    + "    return value" + python_newline()
    + python_newline()
    + "def print(value):" + python_newline()
    + "    return Effect.delay(lambda: _console_print(value, False, False))" + python_newline()
    + python_newline()
    + "def println(value):" + python_newline()
    + "    return Effect.delay(lambda: _console_print(value, True, False))" + python_newline()
    + python_newline()
    + "def print_error(value):" + python_newline()
    + "    return Effect.delay(lambda: _console_print(value, False, True))" + python_newline()
    + python_newline()
    + "def println_error(value):" + python_newline()
    + "    return Effect.delay(lambda: _console_print(value, True, True))" + python_newline()
    + python_newline()

