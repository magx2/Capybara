    + "    if isinstance(left, list):" + python_newline()
    + "        if isinstance(right, list):" + python_newline()
    + "            return [item for item in left if item not in right]" + python_newline()
    + "        return [item for item in left if item != right]" + python_newline()
    + "    if isinstance(left, set):" + python_newline()
