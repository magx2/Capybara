private fun python_test_runtime_date_time_value_code(): String =
    "def __capy_raw_field(value, name):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        return value[name]" + python_newline()
    + "    return getattr(value, name)" + python_newline()
    + python_newline()
    + "def __capy_int_value(value):" + python_newline()
    + "    value = _unsafe_run(value)" + python_newline()
    + "    if isinstance(value, dict):" + python_newline()
    + "        if 'value' in value:" + python_newline()
    + "            return int(value['value'])" + python_newline()
    + "        if '$0' in value:" + python_newline()
    + "            return int(value['$0'])" + python_newline()
    + "    return int(value)" + python_newline()
    + python_newline()
    + "def __capy_int_field(value, name):" + python_newline()
    + "    return __capy_int_value(__capy_raw_field(value, name))" + python_newline()
    + python_newline()
    + "def __capy_date(day, month, year):" + python_newline()
    + "    return __capy_data('Date', dict(day=int(day), month=int(month), year=int(year)))" + python_newline()
    + python_newline()
    + "def __capy_time(hour, minute, second, offset_minutes=None):" + python_newline()
    + "    if offset_minutes is None:" + python_newline()
    + "        offset_minutes = __capy_none()" + python_newline()
    + "    return __capy_data('Time', dict(hour=int(hour), minute=int(minute), second=int(second), offset_minutes=offset_minutes))" + python_newline()
    + python_newline()
    + "def __capy_date_duration(years, months, days, hours, minutes, seconds):" + python_newline()
    + "    return __capy_data('DateDuration', dict(years=int(years), months=int(months), days=int(days), hours=int(hours), minutes=int(minutes), seconds=int(seconds)))" + python_newline()
    + python_newline()
    + "def __capy_date_time(date, time):" + python_newline()
    + "    return __capy_data('DateTime', dict(date=date, time=time))" + python_newline()
    + python_newline()
    + "def __capy_date_unix_date():" + python_newline()
    + "    return __capy_date(1, 1, 1970)" + python_newline()
    + python_newline()
    + "def __capy_time_midnight():" + python_newline()
    + "    return __capy_time(0, 0, 0)" + python_newline()
    + python_newline()
    + "def __capy_date_time_unix_epoch():" + python_newline()
    + "    return __capy_date_time(__capy_date_unix_date(), __capy_time_midnight())" + python_newline()
    + python_newline()
    + "def __capy_duration_zero():" + python_newline()
    + "    return __capy_date_duration(0, 0, 0, 0, 0, 0)" + python_newline()
    + python_newline()

