private fun python_test_runtime_numeric_value_code(): String =
    "def __capy_str(value):" + python_newline()
    + "    if value is True:" + python_newline()
    + "        return 'true'" + python_newline()
    + "    if value is False:" + python_newline()
    + "        return 'false'" + python_newline()
    + "    if value is None:" + python_newline()
    + "        return 'null'" + python_newline()
    + "    if isinstance(value, dict) and '__type' in value:" + python_newline()
    + "        fields = [(key, field) for key, field in value.items() if key != '__type']" + python_newline()
    + "        rendered = ', '.join(str(key) + ': ' + __capy_str(field) for key, field in fields)" + python_newline()
    + "        return str(value.get('__type')) + ' ' + chr(123) + rendered + chr(125)" + python_newline()
    + "    return str(value)" + python_newline()
    + python_newline()
    + "def __capy_long(value):" + python_newline()
    + "    value = int(value)" + python_newline()
    + "    return ((value + 9223372036854775808) % 18446744073709551616) - 9223372036854775808" + python_newline()
    + python_newline()
    + "def __capy_to_int(value):" + python_newline()
    + "    if isinstance(value, float):" + python_newline()
    + "        if math.isnan(value):" + python_newline()
    + "            return 0" + python_newline()
    + "        if value > 2147483647.0:" + python_newline()
    + "            return 2147483647" + python_newline()
    + "        if value < -2147483648.0:" + python_newline()
    + "            return -2147483648" + python_newline()
    + "        return int(value)" + python_newline()
    + "    value = int(value)" + python_newline()
    + "    return ((value + 2147483648) % 4294967296) - 2147483648" + python_newline()
    + python_newline()
    + "def __capy_to_long(value):" + python_newline()
    + "    if isinstance(value, float):" + python_newline()
    + "        if math.isnan(value):" + python_newline()
    + "            return 0" + python_newline()
    + "        if value >= 9223372036854775808.0:" + python_newline()
    + "            return 9223372036854775807" + python_newline()
    + "        if value <= -9223372036854775808.0:" + python_newline()
    + "            return -9223372036854775808" + python_newline()
    + "        return int(value)" + python_newline()
    + "    return __capy_long(value)" + python_newline()
    + python_newline()
    + "def __capy_success(value):" + python_newline()
    + "    return __capy_data('Success', dict(value=value))" + python_newline()
    + python_newline()
    + "def __capy_error(message):" + python_newline()
    + "    return __capy_data('Error', dict(message=message))" + python_newline()
    + python_newline()

private fun python_test_runtime_numeric_parse_code(): String =
    "def __capy_parse_integral(value, label, minimum, maximum):" + python_newline()
    + "    text = str(value)" + python_newline()
    + "    digits = text[1:] if text.startswith(('+', '-')) else text" + python_newline()
    + "    try:" + python_newline()
    + "        if not digits or not all('0' <= char <= '9' for char in digits):" + python_newline()
    + "            raise ValueError()" + python_newline()
    + "        parsed = int(text)" + python_newline()
    + "        if parsed < minimum or parsed > maximum:" + python_newline()
    + "            raise ValueError()" + python_newline()
    + "        return __capy_success(parsed)" + python_newline()
    + "    except (TypeError, ValueError):" + python_newline()
    + "        return __capy_error('Cannot parse string to ' + label + ': ' + text)" + python_newline()
    + python_newline()
    + "def __capy_parse_int(value):" + python_newline()
    + "    return __capy_parse_integral(value, 'int', -2147483648, 2147483647)" + python_newline()
    + python_newline()
    + "def __capy_parse_long(value):" + python_newline()
    + "    return __capy_parse_integral(value, 'long', -9223372036854775808, 9223372036854775807)" + python_newline()
    + python_newline()
    + "def __capy_parse_decimal(value, label):" + python_newline()
    + "    text = str(value)" + python_newline()
    + "    try:" + python_newline()
    + "        return __capy_success(float(text))" + python_newline()
    + "    except (TypeError, ValueError):" + python_newline()
    + "        return __capy_error('Cannot parse string to ' + label + ': ' + text)" + python_newline()
    + python_newline()
    + "def __capy_parse_double(value):" + python_newline()
    + "    return __capy_parse_decimal(value, 'double')" + python_newline()
    + python_newline()
    + "def __capy_parse_float(value):" + python_newline()
    + "    return __capy_parse_decimal(value, 'float')" + python_newline()
    + python_newline()
    + "def __capy_parse_bool(value):" + python_newline()
    + "    text = str(value)" + python_newline()
    + "    if text == 'true':" + python_newline()
    + "        return __capy_success(True)" + python_newline()
    + "    if text == 'false':" + python_newline()
    + "        return __capy_success(False)" + python_newline()
    + "    return __capy_error('Cannot parse string to bool: ' + text)" + python_newline()
    + python_newline()
    + "def __capy_char(value):" + python_newline()
    + "    text = str(value)" + python_newline()
    + "    if len(text) == 1:" + python_newline()
    + "        return __capy_success(text)" + python_newline()
    + "    return __capy_error('char must contain exactly one character')" + python_newline()
    + python_newline()
    + "def __capy_to_string(value):" + python_newline()
    + "    if _capy_data_is(value, 'char'):" + python_newline()
    + "        return __capy_str(_capy_data_value(value))" + python_newline()
    + "    return __capy_str(value)" + python_newline()
    + python_newline()
    + "def digits(number):" + python_newline()
    + "    number = int(number)" + python_newline()
    + "    if number == -2147483648:" + python_newline()
    + "        return 10" + python_newline()
    + "    number = abs(number)" + python_newline()
    + "    result = 1" + python_newline()
    + "    while number >= 10:" + python_newline()
    + "        number = int(number / 10)" + python_newline()
    + "        result += 1" + python_newline()
    + "    return result" + python_newline()
    + python_newline()

private fun python_test_runtime_enum_code(): String =
    "def __capy_enum_parse(type_name, values, input_value):" + python_newline()
    + "    input_value = _unsafe_run(input_value)" + python_newline()
