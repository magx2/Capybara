        case None -> java_script_unknown_type()
    }
    case None -> java_script_unknown_type()

/// Collects imported function binding visible to the current module.
private fun java_script_imported_function_binding(declaration: CompiledImportDeclaration, function: CompiledFunction, functions: List[CompiledFunction], module: CompiledModule): String =
    java_script_import_alias(declaration, module) + "[" + java_script_string_literal(java_script_imported_function_export_name(function, functions)) + "]"

/// Creates one JavaScript name/type binding for module function.
private fun java_script_module_function_binding(targetModule: CompiledModule, function: CompiledFunction, module: CompiledModule): String =
    "require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), java_script_module_path(targetModule)))
        + ")["
        + java_script_string_literal(java_script_imported_function_export_name(function, targetModule.functions))
        + "]"

/// Collects imported function export name visible to the current module.
private fun java_script_imported_function_export_name(function: CompiledFunction, functions: List[CompiledFunction]): String =
    if java_script_exported_function_overloaded(function.name, functions)
    then function.name
    else java_script_export_name(function)

/// Checks whether qualified import matches the requested declaration, type, or name.
private fun java_script_qualified_import_matches(qualifier: String, declaration: CompiledImportDeclaration, module: CompiledModule): bool =
    let importPath = java_script_import_module_path(declaration.modulePath, module)
    qualifier == declaration.modulePath
        | qualifier == importPath
        | qualifier == java_script_module_leaf_name(importPath)

/// Computes the output or module path for qualified module.
private fun java_script_qualified_module_path(qualifier: String, module: CompiledModule): String =
    if java_script_string_has_prefix(qualifier, "/")
    then java_script_normalize_import_module_path(qualifier)
    else if qualifier ? "/"
    then java_script_normalize_import_module_path(qualifier)
    else if module.path.is_empty()
    then qualifier
    else module.path + "/" + qualifier

/// Finds a local constant in scope, imports, or compiled modules.
private fun java_script_find_local_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_emitted_constant(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_local_constant(name, functions[1:])

/// Finds an exported constant in scope, imports, or compiled modules.
private fun java_script_find_exported_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_exported_constant(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_exported_constant(name, functions[1:])

/// Finds a function in imports in scope, imports, or compiled modules.
private fun java_script_find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_find_function_in_imports(name, imports[1:], module, allModules)
        else if !java_script_import_includes_name(name, declaration)
        then java_script_find_function_in_imports(name, imports[1:], module, allModules)
        else java_script_find_function_in_import(name, declaration, imports[1:], module, allModules)

/// Finds a function in import in scope, imports, or compiled modules.
private fun java_script_find_function_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        java_script_find_function_in_imported_module(name, declaration, importedModule, rest, module, allModules)
    case None -> java_script_find_function_in_imports(name, rest, module, allModules)

/// Finds a function in imported module in scope, imports, or compiled modules.
private fun java_script_find_function_in_imported_module(name: String, declaration: CompiledImportDeclaration, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_function(name, importedModule.functions) with
    case Some { function } ->
        /capy/lang/Option.Some {
            java_script_imported_function_binding(declaration, function, importedModule.functions, module)
        }
    case None -> java_script_find_function_in_imports(name, rest, module, allModules)

/// Finds a function definition in imports in scope, imports, or compiled modules.
private fun java_script_find_function_definition_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_find_function_definition_in_imports(name, imports[1:], module, allModules)
        else if !java_script_import_includes_name(name, declaration)
        then java_script_find_function_definition_in_imports(name, imports[1:], module, allModules)
        else java_script_find_function_definition_in_import(name, declaration, imports[1:], module, allModules)

/// Finds a function definition in import in scope, imports, or compiled modules.
private fun java_script_find_function_definition_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        java_script_find_function_definition_in_imported_module(name, importedModule, rest, module, allModules)
    case None -> java_script_find_function_definition_in_imports(name, rest, module, allModules)

/// Finds a function definition in imported module in scope, imports, or compiled modules.
private fun java_script_find_function_definition_in_imported_module(name: String, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match java_script_find_function(name, importedModule.functions) with
    case Some { function } -> /capy/lang/Option.Some { function }
    case None -> java_script_find_function_definition_in_imports(name, rest, module, allModules)

/// Finds a local extension method in scope, imports, or compiled modules.
private fun java_script_find_local_extension_method(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
    java_script_find_local_extension_method_with_receiver_type(receiverType, call, module)

private fun java_script_find_local_extension_method_with_receiver_type(receiverType: String, call: CompiledMethodCallExpression, module: CompiledModule): /capy/lang/Option[CompiledFunction] =
    if receiverType == java_script_unknown_type()
    then /capy/lang/Option.None {}
    else java_script_find_local_method_function(receiverType, call.name, module.functions)

/// Finds an imported extension method in scope, imports, or compiled modules.
private fun java_script_find_imported_extension_method(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
    if receiverType == java_script_unknown_type()
    then /capy/lang/Option.None {}
    else java_script_find_imported_method_function(receiverType, call.name, module.imports, module, allModules)

/// Finds an imported extension method return type in scope, imports, or compiled modules.
private fun java_script_find_imported_extension_method_return_type(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
    java_script_find_imported_extension_method_return_type_with_receiver_type(receiverType, call, module, allModules)

private fun java_script_find_imported_extension_method_return_type_with_receiver_type(receiverType: String, call: CompiledMethodCallExpression, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if receiverType == java_script_unknown_type()
    then /capy/lang/Option.None {}
    else java_script_find_imported_method_function_return_type(receiverType, call.name, module.imports, module, allModules)

/// Finds an imported method function in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function(receiverType: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_option_string_identity(java_script_find_imported_method_function(receiverType, methodName, imports[1:], module, allModules))
        else if java_script_stdlib_import(declaration.modulePath)
        then java_script_option_string_identity(java_script_find_imported_method_function(receiverType, methodName, imports[1:], module, allModules))
        else java_script_find_imported_method_function_in_import(receiverType, methodName, declaration, imports[1:], module, allModules)

/// Finds an imported method function in import in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function_in_import(receiverType: String, methodName: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match java_script_find_imported_method_function_binding_in_functions(receiverType, methodName, declaration, importedModule.functions, importedModule.functions, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> java_script_option_string_identity(java_script_find_imported_method_function(receiverType, methodName, rest, module, allModules))
    }
    case None -> java_script_option_string_identity(java_script_find_imported_method_function(receiverType, methodName, rest, module, allModules))

/// Finds an imported method function return type in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function_return_type(receiverType: String, methodName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_option_string_identity(java_script_find_imported_method_function_return_type(receiverType, methodName, imports[1:], module, allModules))
        else if java_script_stdlib_import(declaration.modulePath)
        then java_script_option_string_identity(java_script_find_imported_method_function_return_type(receiverType, methodName, imports[1:], module, allModules))
        else java_script_find_imported_method_function_return_type_in_import(receiverType, methodName, declaration, imports[1:], module, allModules)

/// Finds an imported method function return type in import in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function_return_type_in_import(receiverType: String, methodName: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match java_script_find_imported_method_function_return_type_in_functions(receiverType, methodName, declaration, importedModule.functions) with
        case Some { returnType } -> /capy/lang/Option.Some { returnType }
        case None -> java_script_option_string_identity(java_script_find_imported_method_function_return_type(receiverType, methodName, rest, module, allModules))
    }
    case None -> java_script_option_string_identity(java_script_find_imported_method_function_return_type(receiverType, methodName, rest, module, allModules))

/// Finds an imported method function binding in functions in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function_binding_in_functions(receiverType: String, methodName: String, declaration: CompiledImportDeclaration, functions: List[CompiledFunction], allFunctions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[String] =
    let normalizedMethodName = java_script_method_member_name(methodName)
    java_script_find_imported_method_function_binding_in_functions_with_suffixes(receiverType, methodName, "." + normalizedMethodName, ".`" + normalizedMethodName + "`", declaration, functions, allFunctions, module)

private fun java_script_find_imported_method_function_binding_in_functions_with_suffixes(receiverType: String, methodName: String, directSuffix: String, quotedSuffix: String, declaration: CompiledImportDeclaration, functions: List[CompiledFunction], allFunctions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_method_member_candidate(directSuffix, quotedSuffix, function.name)
        then if java_script_imported_method_function_matches(receiverType, methodName, declaration, function)
            then /capy/lang/Option.Some { java_script_imported_function_binding(declaration, function, allFunctions, module) }
            else java_script_option_string_identity(java_script_find_imported_method_function_binding_in_functions_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, declaration, functions[1:], allFunctions, module))
        else java_script_option_string_identity(java_script_find_imported_method_function_binding_in_functions_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, declaration, functions[1:], allFunctions, module))

/// Finds an imported method function return type in functions in scope, imports, or compiled modules.
private fun java_script_find_imported_method_function_return_type_in_functions(receiverType: String, methodName: String, declaration: CompiledImportDeclaration, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    let normalizedMethodName = java_script_method_member_name(methodName)
    java_script_find_imported_method_function_return_type_in_functions_with_suffixes(receiverType, methodName, "." + normalizedMethodName, ".`" + normalizedMethodName + "`", declaration, functions)

private fun java_script_find_imported_method_function_return_type_in_functions_with_suffixes(receiverType: String, methodName: String, directSuffix: String, quotedSuffix: String, declaration: CompiledImportDeclaration, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_method_member_candidate(directSuffix, quotedSuffix, function.name)
        then if java_script_imported_method_function_matches(receiverType, methodName, declaration, function)
            then /capy/lang/Option.Some { function.returnType.name }
            else java_script_option_string_identity(java_script_find_imported_method_function_return_type_in_functions_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, declaration, functions[1:]))
        else java_script_option_string_identity(java_script_find_imported_method_function_return_type_in_functions_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, declaration, functions[1:]))

/// Collects imported method function matches visible to the current module.
private fun java_script_imported_method_function_matches(receiverType: String, methodName: String, declaration: CompiledImportDeclaration, function: CompiledFunction): bool =
    if !java_script_import_includes_method_function(methodName, declaration, function)
    then false
    else if !java_script_method_function_matches(receiverType, methodName, function)
    then false
    else function.visibility != "private" & function.visibility != "const:private"

/// Checks whether a function matches the import includes method function metadata.
private fun java_script_import_includes_method_function(methodName: String, declaration: CompiledImportDeclaration, function: CompiledFunction): bool =
    if java_script_import_includes_name(function.name, declaration)
    then true
    else java_script_import_includes_name(methodName, declaration)

/// Finds a local binary extension operator with left type in scope, imports, or compiled modules.
private fun java_script_find_local_binary_extension_operator_with_left_type(binary: CompiledBinaryExpression, leftType: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    if leftType == java_script_unknown_type()
    then /capy/lang/Option.None {}
    else java_script_find_local_method_function(leftType, binary.operator, functions)

/// Finds a local method function in scope, imports, or compiled modules.
private fun java_script_find_local_method_function(receiverType: String, methodName: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    let normalizedMethodName = java_script_method_member_name(methodName)
    java_script_find_local_method_function_with_suffixes(receiverType, methodName, "." + normalizedMethodName, ".`" + normalizedMethodName + "`", functions)

private fun java_script_find_local_method_function_with_suffixes(receiverType: String, methodName: String, directSuffix: String, quotedSuffix: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_method_member_candidate(directSuffix, quotedSuffix, function.name)
        then if java_script_method_function_matches(receiverType, methodName, function)
            then /capy/lang/Option.Some { function }
            else java_script_find_local_method_function_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, functions[1:])
        else java_script_find_local_method_function_with_suffixes(receiverType, methodName, directSuffix, quotedSuffix, functions[1:])

private fun java_script_method_member_candidate(directSuffix: String, quotedSuffix: String, functionName: String): bool =
    if java_script_string_has_suffix(functionName, directSuffix)
    then true
    else java_script_string_has_suffix(functionName, quotedSuffix)

/// Checks whether method function matches the requested declaration, type, or name.
private fun java_script_method_function_matches(ownerName: String, methodName: String, function: CompiledFunction): bool =
    let idx = java_script_last_dot_index(function.name)
    if idx < 0
    then false
    else if function.name ? "__local__"
    then false
    else
        let functionMethodName = java_script_method_member_name(function.name[idx + 1, function.name.size().value])
        if functionMethodName != java_script_method_member_name(methodName)
        then false
        else if java_script_method_owner_base_name(function.name[0, idx]) != java_script_method_owner_base_name(ownerName)
        then false
        else !java_script_skip_function(function)

/// Finds a constant in imports in scope, imports, or compiled modules.
private fun java_script_find_constant_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_find_constant_in_imports(name, imports[1:], module, allModules)
        else if !java_script_import_includes_name(name, declaration)
        then java_script_find_constant_in_imports(name, imports[1:], module, allModules)
        else java_script_find_constant_in_import(name, declaration, imports[1:], module, allModules)

/// Finds a constant in import in scope, imports, or compiled modules.
private fun java_script_find_constant_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        java_script_find_constant_in_imported_module(name, declaration, importedModule, rest, module, allModules)
    case None -> java_script_find_constant_in_imports(name, rest, module, allModules)

/// Finds a constant in imported module in scope, imports, or compiled modules.
private fun java_script_find_constant_in_imported_module(name: String, declaration: CompiledImportDeclaration, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_exported_constant(name, importedModule.functions) with
    case Some { function } ->
        /capy/lang/Option.Some {
            java_script_import_alias(declaration, module) + "[" + java_script_string_literal(java_script_export_name(function)) + "]"
        }
    case None -> java_script_find_constant_in_imports(name, rest, module, allModules)

/// Collects imported standard-library constant code visible to the current module.
private fun java_script_imported_stdlib_constant_code(name: String, imports: List[CompiledImportDeclaration]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !declaration.qualified & java_script_import_includes_name(name, declaration)
        then match java_script_stdlib_constant_code(name, declaration.modulePath) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> java_script_imported_stdlib_constant_code(name, imports[1:])
        else java_script_imported_stdlib_constant_code(name, imports[1:])

/// Emits JavaScript code for standard-library constant.
private fun java_script_stdlib_constant_code(name: String, modulePath: String): /capy/lang/Option[String] =
    let path = java_script_normalize_import_module_path(modulePath)
    if path == "capy/date_time/Date" & name == "UNIX_DATE"
    then /capy/lang/Option.Some { "__capy_date_unix_date()" }
    else if path == "capy/date_time/Time" & name == "MIDNIGHT"
    then /capy/lang/Option.Some { "__capy_time_midnight()" }
    else if path == "capy/date_time/DateTime" & name == "UNIX_EPOCH"
    then /capy/lang/Option.Some { "__capy_date_time_unix_epoch()" }
    else if path == "capy/date_time/Duration" & name == "ZERO"
    then /capy/lang/Option.Some { "__capy_duration_zero()" }
    else /capy/lang/Option.None {}

/// Collects imported standard-library constant type visible to the current module.
private fun java_script_imported_stdlib_constant_type(name: String, imports: List[CompiledImportDeclaration]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if !declaration.qualified & java_script_import_includes_name(name, declaration)
        then match java_script_stdlib_constant_type(name, declaration.modulePath) with
            case Some { typeName } -> /capy/lang/Option.Some { typeName }
            case None -> java_script_imported_stdlib_constant_type(name, imports[1:])
        else java_script_imported_stdlib_constant_type(name, imports[1:])

/// Computes the JavaScript type for standard-library constant.
private fun java_script_stdlib_constant_type(name: String, modulePath: String): /capy/lang/Option[String] =
    let path = java_script_normalize_import_module_path(modulePath)
    if path == "capy/date_time/Date" & name == "UNIX_DATE"
    then /capy/lang/Option.Some { "Date" }
    else if path == "capy/date_time/Time" & name == "MIDNIGHT"
    then /capy/lang/Option.Some { "Time" }
    else if path == "capy/date_time/DateTime" & name == "UNIX_EPOCH"
    then /capy/lang/Option.Some { "DateTime" }
    else if path == "capy/date_time/Duration" & name == "ZERO"
    then /capy/lang/Option.Some { "Duration" }
    else /capy/lang/Option.None {}

/// Finds an imported module in scope, imports, or compiled modules.
private fun java_script_find_imported_module(declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    java_script_find_module_by_path(java_script_import_module_path(declaration.modulePath, module), allModules)

/// Finds a module by path in scope, imports, or compiled modules.
private fun java_script_find_module_by_path(modulePath: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if java_script_module_matches_path(modulePath, module)
        then /capy/lang/Option.Some { module }
        else java_script_find_module_by_path(modulePath, modules[1:])

/// Checks whether a compiled module matches a slash-separated module path without building the full path.
private fun java_script_module_matches_path(modulePath: String, module: CompiledModule): bool =
    let nameSize = module.name.size().value
    if modulePath.size().value < nameSize
    then false
    else if !java_script_string_has_suffix(modulePath, module.name)
    then false
    else if module.path.is_empty()
    then module.name == modulePath
    else
        let pathSize = module.path.size().value
        if modulePath.size().value != pathSize + 1 + nameSize
        then false
        else if !java_script_string_has_prefix(modulePath, module.path)
        then false
        else modulePath[pathSize, pathSize + 1] == "/"

/// Checks whether an import matches the import includes name rule.
private fun java_script_import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !java_script_string_list_contains(name, declaration.excludedNames)
    else java_script_string_list_contains(name, declaration.importedNames)

/// Checks whether program member is imported into the current module scope.
private fun java_script_program_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/lang/Program", "capy/lang/Program")

private fun java_script_primitives_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/lang/Primitives", "capy/lang/Primitives")

/// Checks whether system member is imported into the current module scope.
private fun java_script_system_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/lang/System", "capy/lang/System")

/// Checks whether clock member is imported into the current module scope.
private fun java_script_clock_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/date_time/Clock", "capy/date_time/Clock")

/// Checks whether path member is imported into the current module scope.
private fun java_script_path_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/io/Path", "capy/io/Path")

/// Checks whether I/O member is imported into the current module scope.
private fun java_script_io_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/io/IO", "capy/io/IO")

/// Checks whether reflection member is imported into the current module scope.
private fun java_script_reflection_member_imported(member: String, imports: List[CompiledImportDeclaration]): bool =
    java_script_module_member_imported(member, imports, "/capy/meta_prog/Reflection", "capy/meta_prog/Reflection")

/// Checks whether module member is imported into the current module scope.
private fun java_script_module_member_imported(member: String, imports: List[CompiledImportDeclaration], absoluteModulePath: String, relativeModulePath: String): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if declaration.modulePath == absoluteModulePath | declaration.modulePath == relativeModulePath
        then if java_script_import_includes_name(member, declaration) then true else java_script_module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)
        else java_script_module_member_imported(member, imports[1:], absoluteModulePath, relativeModulePath)

/// Checks whether string list contains the requested value.
private fun java_script_string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> if item == value then true else java_script_string_list_contains(value, values[1:])

/// Formats JavaScript source text for exports.
private fun java_script_exports(functions: List[CompiledFunction]): String =
    let functionEntries = java_script_export_entries(functions, true)
    let dispatchEntries = java_script_export_dispatch_entries(functions, [], functionEntries.is_empty())
    let objectEntries = java_script_object_export_entries(functions, if dispatchEntries.is_empty() then functionEntries.is_empty() else false)
    "module.exports = {"
        + java_script_newline()
        + functionEntries
        + dispatchEntries
        + objectEntries
        + "};"
        + java_script_newline()

/// Formats JavaScript source text for export dispatch entries.
private fun java_script_export_dispatch_entries(functions: List[CompiledFunction], emittedNames: List[String], first: bool): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_exported_function(function)
        then if java_script_exported_function_overloaded(function.name, functions)
            then if !java_script_string_list_contains(function.name, emittedNames)
                then java_script_export_dispatch_entry(function.name, first)
                    + java_script_export_dispatch_entries(functions[1:], emittedNames + [function.name], false)
                else java_script_export_dispatch_entries(functions[1:], emittedNames, first)
            else java_script_export_dispatch_entries(functions[1:], emittedNames, first)
        else java_script_export_dispatch_entries(functions[1:], emittedNames, first)

/// Formats JavaScript source text for export dispatch entry.
private fun java_script_export_dispatch_entry(name: String, first: bool): String =
    let prefix = if first then "" else "," + java_script_newline()
    prefix
        + "    "
        + java_script_string_literal(name)
        + ": "
        + java_script_identifier(name)

/// Formats JavaScript source text for export entries.
private fun java_script_export_entries(functions: List[CompiledFunction], first: bool): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_exported_function(function)
        then java_script_export_entry(function, functions, first) + java_script_export_entries(functions[1:], false)
        else java_script_export_entries(functions[1:], first)

/// Formats JavaScript source text for export entry.
private fun java_script_export_entry(function: CompiledFunction, functions: List[CompiledFunction], first: bool): String =
    let prefix = if first then "" else "," + java_script_newline()
    prefix
        + "    "
        + java_script_string_literal(java_script_export_name(function))
        + ": "
        + java_script_export_value_name(function)
        + java_script_semantic_export_entry(function, functions)

/// Formats JavaScript source text for semantic export entry.
private fun java_script_semantic_export_entry(function: CompiledFunction, functions: List[CompiledFunction]): String =
    if java_script_exported_function_overloaded(function.name, functions)
    then ""
    else if function.name == java_script_export_name(function)
    then ""
    else ","
        + java_script_newline()
        + "    "
        + java_script_string_literal(function.name)
        + ": "
        + java_script_export_value_name(function)

/// Formats JavaScript source text for object export entries.
private fun java_script_object_export_entries(functions: List[CompiledFunction], first: bool): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_exported_object_class(function)
        then java_script_object_export_entry(java_script_object_class_schema_name(function), first)
            + java_script_object_export_entries(functions[1:], false)
        else if java_script_exported_object_interface(function)
        then java_script_object_export_entry(java_script_object_interface_schema_name(function), first)
            + java_script_object_export_entries(functions[1:], false)
        else java_script_object_export_entries(functions[1:], first)

/// Formats JavaScript source text for object export entry.
private fun java_script_object_export_entry(className: String, first: bool): String =
    let prefix = if first then "" else "," + java_script_newline()
    prefix
        + "    "
        + java_script_string_literal(className)
        + ": "
        + java_script_object_constructor_name(className)

/// Checks whether the current value satisfies the exported object class rule for JavaScript processing.
private fun java_script_exported_object_class(function: CompiledFunction): bool =
    if java_script_object_class_schema_function(function)
    then java_script_schema_value(function) != "private"
    else false

/// Checks whether the current value satisfies the exported object interface rule for JavaScript processing.
private fun java_script_exported_object_interface(function: CompiledFunction): bool =
    if java_script_object_interface_schema_function(function)
    then java_script_schema_value(function) != "private"
    else false

/// Checks whether a function matches the exported function metadata.
private fun java_script_exported_function(function: CompiledFunction): bool =
    if java_script_emitted_constant(function)
    then java_script_exported_constant(function)
    else if java_script_skip_function(function)
    then false
    else function.visibility != "private"

/// Checks whether the current value satisfies the exported constant rule for JavaScript processing.
private fun java_script_exported_constant(function: CompiledFunction): bool =
    if java_script_emitted_constant(function)
    then function.visibility != "const:private"
    else false

/// Checks whether a function matches the overloaded function name metadata.
private fun java_script_overloaded_function_name(name: String, functions: List[CompiledFunction]): bool =
    java_script_local_function_overloaded(name, functions)

/// Checks whether an exported function name has overloads.
private fun java_script_exported_function_overloaded(name: String, functions: List[CompiledFunction]): bool =
    java_script_exported_function_count_at_most(name, functions, 2) > 1

/// Counts exported functions up to the requested cap.
private fun java_script_exported_function_count_at_most(name: String, functions: List[CompiledFunction], limit: int): int =
    if limit <= 0
    then 0
    else match functions[0] with
    case None -> 0
    case Some { function } ->
        if java_script_exported_function(function) & function.name == name
        then 1 + java_script_exported_function_count_at_most(name, functions[1:], limit - 1)
        else java_script_exported_function_count_at_most(name, functions[1:], limit)

/// Computes the JavaScript name for export value.
private fun java_script_export_value_name(function: CompiledFunction): String =
    if java_script_emitted_constant(function)
    then java_script_constant_name(function)
    else java_script_function_name(function)

/// Computes the JavaScript name for export.
private fun java_script_export_name(function: CompiledFunction): String =
    java_script_function_name(function)

/// Creates JavaScript generated-module entries for test runtime.
private fun java_script_test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.js",
        code: java_script_test_runtime_code(modules)
    }]

/// Emits the JavaScript runtime support source for test.
private fun java_script_test_runtime_code(modules: List[CompiledModule]): String =
    "'use strict';" + java_script_newline()
    + java_script_newline()
    + java_script_effect_runtime_code()
    + java_script_io_runtime_code()
    + java_script_assert_runtime_code()
    + java_script_numeric_runtime_code()
    + java_script_error_runtime_code()
    + java_script_collection_runtime_code()
    + java_script_constructor_runtime_code()
    + java_script_module_export_runtime_code()
    + java_script_regex_runtime_code()
    + java_script_date_time_runtime_code()
    + java_script_deep_equal_code()
    + java_script_reflection_runtime_code(modules)
    + java_script_test_gather_runtime_code(modules)
    + java_script_runtime_exports_code()

/// Emits the JavaScript runtime support source for module export.
private fun java_script_module_export_runtime_code(): String =
    "function __capy_export(exports, name) {" + java_script_newline()
    + "    if (Object.prototype.hasOwnProperty.call(exports, name)) return exports[name];" + java_script_newline()
    + "    const snake = String(name).replace(/[A-Z]/g, char => '_' + char.toLowerCase());" + java_script_newline()
    + "    if (Object.prototype.hasOwnProperty.call(exports, snake)) return exports[snake];" + java_script_newline()
    + "    return exports[name];" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()

/// Emits the JavaScript runtime support source for effect.
private fun java_script_effect_runtime_code(): String =
    "class Effect {" + java_script_newline()
    + "    constructor(thunk) { this._thunk = thunk; }" + java_script_newline()
    + "    unsafe_run() { return this._thunk(); }" + java_script_newline()
    + "    unsafeRun() { return this.unsafe_run(); }" + java_script_newline()
    + "    map(fn) { return new Effect(() => fn(this.unsafe_run())); }" + java_script_newline()
    + "    flat_map(fn) { return new Effect(() => __capy_unsafe_run(fn(this.unsafe_run()))); }" + java_script_newline()
    + "    flatMap(fn) { return this.flat_map(fn); }" + java_script_newline()
    + "    start() { return __capy_async_start(this); }" + java_script_newline()
    + "    static pure(value) { return new Effect(() => value); }" + java_script_newline()
    + "    static delay(thunk) { return new Effect(thunk); }" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "class CapyAsyncResultFailure extends Error { constructor(result) { super('Async.flat_map returned Error'); this.result = result; } }" + java_script_newline()
    + java_script_newline()
    + "class Async {" + java_script_newline()
    + "    constructor(thunk) { this._thunk = thunk; this._done = false; this._result = undefined; }" + java_script_newline()
    + "    _evaluate() { if (!this._done) { try { this._result = __capy_success(__capy_unsafe_run(this._thunk())); } catch (error) { this._result = error instanceof CapyAsyncResultFailure ? error.result : __capy_async_error(error); } this._done = true; } return this._result; }" + java_script_newline()
    + "    join() { return __capy_async_join(this); }" + java_script_newline()
    + "    map(mapper) { return __capy_async_map(this, mapper); }" + java_script_newline()
    + "    flat_map(mapper) { return __capy_async_flat_map(this, mapper); }" + java_script_newline()
    + "    flatMap(mapper) { return this.flat_map(mapper); }" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function pure(value) { return Effect.pure(value); }" + java_script_newline()
    + "function delay(thunk) { return Effect.delay(thunk); }" + java_script_newline()
    + "function __capy_async_error(error) { const host = error instanceof Error ? error : new Error(String(error)); const rawStack = host.stack ? String(host.stack) : ''; const stackTrace = typeof __capy_stack_frames === 'function' ? __capy_stack_frames(rawStack) : []; return __capy_error_full('capy.lang.async.failed', host.message || String(error), __capy_none(), typeof __capy_source_location_from_stack === 'function' ? __capy_source_location_from_stack(stackTrace) : __capy_none(), stackTrace, rawStack ? __capy_some(rawStack) : __capy_none(), __capy_none(), []); }" + java_script_newline()
    + "function __capy_async_start(effect) { const handle = new Async(() => effect); const schedule = typeof setImmediate === 'function' ? setImmediate : (typeof queueMicrotask === 'function' ? queueMicrotask : task => setTimeout(task, 0)); schedule(() => handle._evaluate()); return handle; }" + java_script_newline()
    + "function __capy_async_join(asyncValue) { return Effect.delay(() => asyncValue._evaluate()); }" + java_script_newline()
    + "function __capy_async_all(asyncValues) { return Effect.delay(() => Array.from(asyncValues).map(value => value._evaluate())); }" + java_script_newline()
    + "function __capy_async_any(asyncValues) { return Effect.delay(() => { const values = Array.from(asyncValues); if (values.length === 0) return __capy_error_full('capy.lang.async.empty', 'Async.any requires at least one task', __capy_none(), __capy_none(), [], __capy_none(), __capy_none(), []); const done = values.find(value => value && value._done); return (done || values[0])._evaluate(); }); }" + java_script_newline()
    + "function __capy_async_value(asyncValue) { const result = asyncValue._evaluate(); if (__capy_data_is(result, 'Error')) throw new CapyAsyncResultFailure(result); if (__capy_data_is(result, 'Success')) return __capy_match_binding(result, 'value', 0); throw new CapyAsyncResultFailure(__capy_error_full('capy.lang.argument.invalid', 'Async expected Result value', __capy_none(), __capy_none(), [], __capy_none(), __capy_none(), [])); }" + java_script_newline()
    + "function __capy_async_map(asyncValue, mapper) { return new Async(() => __capy_unsafe_run(mapper(__capy_async_value(asyncValue)))); }" + java_script_newline()
    + "function __capy_async_flat_map(asyncValue, mapper) { return new Async(() => { const mapped = __capy_unsafe_run(mapper(__capy_async_value(asyncValue))); if (__capy_data_is(mapped, 'Error')) throw new CapyAsyncResultFailure(mapped); if (__capy_data_is(mapped, 'Success')) return __capy_match_binding(mapped, 'value', 0); throw new CapyAsyncResultFailure(__capy_error_full('capy.lang.argument.invalid', 'Async.flat_map expected Result value', __capy_none(), __capy_none(), [], __capy_none(), __capy_none(), [])); }); }" + java_script_newline()
    + "function __capy_current_millis() { return Effect.delay(() => __capy_long(BigInt(Date.now()))); }" + java_script_newline()
    + "function __capy_nano_time() { return Effect.delay(() => __capy_long(process.hrtime.bigint())); }" + java_script_newline()
    + "function __capy_clock_now() { return Effect.delay(() => { const current = new Date(); return __capy_date_time(__capy_date(current.getUTCDate(), current.getUTCMonth() + 1, current.getUTCFullYear()), __capy_time(current.getUTCHours(), current.getUTCMinutes(), current.getUTCSeconds(), __capy_data('Some', { value: 0 }))); }); }" + java_script_newline()
    + "function __capy_console_value(value) { if (Array.isArray(value)) return String.fromCharCode(...value); return __capy_str(value); }" + java_script_newline()
