from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledExpression import { CompiledBinaryExpression, CompiledBlockExpression, CompiledBoolLiteral, CompiledDataField, CompiledDataLiteral, CompiledDictEntry, CompiledDictLiteral, CompiledDoubleLiteral, CompiledExpression, CompiledFieldAccessExpression, CompiledFloatLiteral, CompiledFunctionCallExpression, CompiledFunctionReferenceExpression, CompiledIfExpression, CompiledIndexExpression, CompiledIntLiteral, CompiledLambdaExpression, CompiledLetBinding, CompiledListLiteral, CompiledLongLiteral, CompiledMatchCase, CompiledMatchExpression, CompiledMethodCallExpression, CompiledReduceExpression, CompiledSetLiteral, CompiledStringLiteral, CompiledTupleLiteral, CompiledUnaryExpression, CompiledUnsupportedExpression, CompiledVariableExpression, CompiledWithExpression }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledImportDeclaration import { CompiledImportDeclaration }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledSourceLocation import { CompiledSourceLocation }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from /dev/capylang/generator/GeneratedModule import { GeneratedModule }
from /dev/capylang/generator/GeneratedProgram import { GeneratedProgram }

data JavaScriptBinding { name: String, jsName: String, typeName: String }

fun java_script_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: java_script_modules(program.modules, program.modules) + java_script_test_runtime_modules(program.modules)
    }

private fun java_script_modules(modules: List[CompiledModule], allModules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: java_script_module_relative_path(module, ".js"),
        code: java_script_module_code(module, allModules)
    }] + java_script_modules(modules[1:], allModules)

private fun java_script_module_code(module: CompiledModule, allModules: List[CompiledModule]): String =
    "'use strict';" + java_script_newline()
    + java_script_newline()
    + java_script_runtime_import(module)
    + java_script_imports(module.imports, module)
    + java_script_newline()
    + java_script_constants(module.functions, module, allModules)
    + java_script_newline()
    + java_script_functions(module.functions, module, allModules)
    + java_script_exports(module.functions)

private fun java_script_runtime_import(module: CompiledModule): String =
    "const { Effect, pure, delay, assert_all, assert_that, test, test_file, digits, __capy_add, __capy_sub, __capy_mul, __capy_div, __capy_mod, __capy_pow, __capy_contains, __capy_size, __capy_index, __capy_get_field, __capy_reduce, __capy_type_matches, __capy_match_binding, __capy_no_match, __capy_unsupported, __capy_data } = require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), "capy/test/CapyTestRuntime"))
        + ");"
        + java_script_newline()

private fun java_script_imports(imports: List[CompiledImportDeclaration], module: CompiledModule): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        if java_script_stdlib_import(declaration.modulePath)
        then java_script_imports(imports[1:], module)
        else java_script_import(declaration, module) + java_script_imports(imports[1:], module)

private fun java_script_import(declaration: CompiledImportDeclaration, module: CompiledModule): String =
    "const "
        + java_script_import_alias(declaration, module)
        + " = require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), java_script_import_module_path(declaration.modulePath, module)))
        + ");"
        + java_script_newline()

private fun java_script_functions(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_skip_function(function)
        then java_script_functions(functions[1:], module, allModules)
        else java_script_function(function, module, allModules)
            + java_script_newline()
            + java_script_functions(functions[1:], module, allModules)

private fun java_script_skip_function(function: CompiledFunction): bool =
    java_script_compiled_constant(function)
        | java_script_imported_function(function)
        | java_script_compiled_object_helper_function(function)

private fun java_script_compiled_constant(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.visibility, "const:")

private fun java_script_compiled_schema(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.visibility, "const:schema")

private fun java_script_imported_function(function: CompiledFunction): bool =
    function.visibility == "imported"

private fun java_script_compiled_object_helper_function(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, "__capy_oo_method|")
        | java_script_string_has_prefix(function.name, "__capy_oo_interface_method|")
        | java_script_string_has_prefix(function.name, "__capy_oo_field_init|")
        | java_script_string_has_prefix(function.name, "__capy_oo_init|")

private fun java_script_constants(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_emitted_constant(function)
        then java_script_constant(function, module, allModules) + java_script_constants(functions[1:], module, allModules)
        else java_script_constants(functions[1:], module, allModules)

private fun java_script_emitted_constant(function: CompiledFunction): bool =
    java_script_compiled_constant(function) & !java_script_compiled_schema(function)

private fun java_script_constant(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    "const "
        + java_script_constant_name(function)
        + " = "
        + java_script_expression_code(function.body, [], module, allModules)
        + ";"
        + java_script_newline()

private fun java_script_constant_name(function: CompiledFunction): String =
    java_script_identifier(function.name)

private fun java_script_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    "function "
        + java_script_function_name(function)
        + "("
        + java_script_parameters(function.parameters)
        + ") {"
        + java_script_newline()
        + "    return "
        + java_script_expression_code(function.body, java_script_function_bindings(function), module, allModules)
        + ";"
        + java_script_newline()
        + "}"
        + java_script_newline()

private fun java_script_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_script_identifier(parameter.name) + java_script_parameter_tail(parameters[1:])

private fun java_script_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_script_identifier(parameter.name) + java_script_parameter_tail(parameters[1:])

private fun java_script_function_bindings(function: CompiledFunction): List[JavaScriptBinding] =
    java_script_parameter_bindings(function.parameters)

private fun java_script_parameter_bindings(parameters: List[CompiledFunctionParameter]): List[JavaScriptBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [JavaScriptBinding { name: parameter.name, jsName: java_script_identifier(parameter.name), typeName: parameter.typeReference.name }]
            + java_script_parameter_bindings(parameters[1:])

private fun java_script_expression_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledUnsupportedExpression unsupported -> "__capy_unsupported(" + java_script_string_literal(unsupported.source) + ")"
    case CompiledIntLiteral literal -> literal.source
    case CompiledLongLiteral literal -> java_script_integer_literal(literal.source)
    case CompiledFloatLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledDoubleLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> java_script_string_literal(literal.value)
    case CompiledVariableExpression variable -> java_script_variable_code(variable.name, env, module, allModules)
    case CompiledIfExpression ifExpression ->
        "("
            + java_script_expression_code(ifExpression.condition, env, module, allModules)
            + " ? "
            + java_script_expression_code(ifExpression.thenBranch, env, module, allModules)
            + " : "
            + java_script_expression_code(ifExpression.elseBranch, env, module, allModules)
            + ")"
    case CompiledBinaryExpression binary -> java_script_binary_expression_code(binary, env, module, allModules)
    case CompiledUnaryExpression unary -> java_script_unary_expression_code(unary, env, module, allModules)
    case CompiledFunctionCallExpression call -> java_script_function_call_code(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> java_script_function_call_name(reference.name, module, allModules)
    case CompiledMethodCallExpression call -> java_script_method_call_code(call, env, module, allModules)
    case CompiledWithExpression _ -> "__capy_unsupported('with')"
    case CompiledLambdaExpression lambda -> java_script_lambda_expression_code(lambda, env, module, allModules)
    case CompiledListLiteral literal -> "[" + java_script_expression_list_code(literal.values, env, module, allModules) + "]"
    case CompiledSetLiteral literal -> "new Set([" + java_script_expression_list_code(literal.values, env, module, allModules) + "])"
    case CompiledDictLiteral literal -> "new Map([" + java_script_dict_entries_code(literal.entries, env, module, allModules) + "])"
    case CompiledTupleLiteral literal -> "[" + java_script_expression_list_code(literal.values, env, module, allModules) + "]"
    case CompiledIndexExpression index -> java_script_index_expression_code(index, env, module, allModules)
    case CompiledDataLiteral literal -> "__capy_data(" + java_script_string_literal(literal.typeName) + ", {" + java_script_data_fields_code(literal.fields, env, module, allModules) + "})"
    case CompiledFieldAccessExpression access -> "__capy_get_field(" + java_script_expression_code(access.receiver, env, module, allModules) + ", " + java_script_string_literal(access.name) + ")"
    case CompiledReduceExpression reduce -> java_script_reduce_expression_code(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> java_script_match_expression_code(matchExpression, env, module, allModules)
    case CompiledBlockExpression block -> java_script_block_expression_code(block, env, module, allModules)

private fun java_script_variable_code(name: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_lookup_binding(name, env) with
    case Some { binding } -> binding.jsName
    case None ->
        match java_script_find_local_constant(name, module.functions) with
        case Some { function } -> java_script_constant_name(function)
        case None ->
            match java_script_find_constant_in_imports(name, module.imports, module, allModules) with
            case Some { binding } -> binding
            case None -> java_script_identifier(name)

private fun java_script_binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binary.operator == "+"
    then java_script_binary_runtime_call("__capy_add", binary, env, module, allModules)
    else if binary.operator == "-"
    then java_script_binary_runtime_call("__capy_sub", binary, env, module, allModules)
    else if binary.operator == "*"
    then java_script_binary_runtime_call("__capy_mul", binary, env, module, allModules)
    else if binary.operator == "/"
    then java_script_binary_runtime_call("__capy_div", binary, env, module, allModules)
    else if binary.operator == "%"
    then java_script_binary_runtime_call("__capy_mod", binary, env, module, allModules)
    else if binary.operator == "^"
    then java_script_binary_runtime_call("__capy_pow", binary, env, module, allModules)
    else if binary.operator == "?"
    then java_script_binary_runtime_call("__capy_contains", binary, env, module, allModules)
    else if binary.operator == ".nand."
    then "(~(" + java_script_expression_code(binary.left, env, module, allModules)
        + " & "
        + java_script_expression_code(binary.right, env, module, allModules)
        + "))"
    else if java_script_bitwise_binary_operator(binary.operator)
    then "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + " "
        + java_script_bitwise_operator(binary.operator)
        + " "
        + java_script_expression_code(binary.right, env, module, allModules)
        + ")"
    else if binary.operator == "&" | binary.operator == "|"
    then "("
        + java_script_truthy_expression_code(binary.left, env, module, allModules)
        + " "
        + java_script_boolean_operator(binary.operator)
        + " "
        + java_script_truthy_expression_code(binary.right, env, module, allModules)
        + ")"
    else "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + " "
        + java_script_binary_operator(binary.operator)
        + " "
        + java_script_expression_code(binary.right, env, module, allModules)
        + ")"

private fun java_script_binary_runtime_call(name: String, binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    name
        + "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + ", "
        + java_script_expression_code(binary.right, env, module, allModules)
        + ")"

private fun java_script_binary_operator(operator: String): String =
    if operator == "!="
    then "!=="
    else if operator == "=="
    then "==="
    else operator

private fun java_script_boolean_operator(operator: String): String =
    if operator == "&" then "&&" else "||"

private fun java_script_bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

private fun java_script_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

private fun java_script_unary_expression_code(unary: CompiledUnaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(!" + java_script_truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then "(~" + java_script_expression_code(unary.expression, env, module, allModules) + ")"
    else "(" + unary.operator + java_script_expression_code(unary.expression, env, module, allModules) + ")"

private fun java_script_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_function_call_name(call.name, module, allModules)
        + "("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

private fun java_script_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "size" & call.arguments.is_empty()
    then "__capy_size(" + java_script_expression_code(call.receiver, env, module, allModules) + ")"
    else java_script_expression_code(call.receiver, env, module, allModules)
        + "."
        + java_script_method_name(call.name)
        + "("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

private fun java_script_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = java_script_lambda_bindings(lambda.parameters) + env
    "(" + java_script_lambda_parameters(lambda.parameters) + ") => "
        + java_script_expression_code(lambda.body, lambdaEnv, module, allModules)

private fun java_script_lambda_parameters(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_script_identifier(parameter) + java_script_lambda_parameter_tail(parameters[1:])

private fun java_script_lambda_parameter_tail(parameters: List[String]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_script_identifier(parameter) + java_script_lambda_parameter_tail(parameters[1:])

private fun java_script_lambda_bindings(parameters: List[String]): List[JavaScriptBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [JavaScriptBinding { name: parameter, jsName: java_script_identifier(parameter), typeName: java_script_unknown_type() }]
            + java_script_lambda_bindings(parameters[1:])

private fun java_script_expression_list_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        java_script_expression_code(expression, env, module, allModules)
            + java_script_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun java_script_expression_list_tail_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + java_script_expression_code(expression, env, module, allModules)
            + java_script_expression_list_tail_code(expressions[1:], env, module, allModules)

private fun java_script_dict_entries_code(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        "[" + java_script_expression_code(entry.key, env, module, allModules) + ", " + java_script_expression_code(entry.value, env, module, allModules) + "]"
            + java_script_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun java_script_dict_entries_tail_code(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        ", [" + java_script_expression_code(entry.key, env, module, allModules) + ", " + java_script_expression_code(entry.value, env, module, allModules) + "]"
            + java_script_dict_entries_tail_code(entries[1:], env, module, allModules)

private fun java_script_data_fields_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        java_script_string_literal(field.name)
            + ": "
            + java_script_expression_code(field.value, env, module, allModules)
            + java_script_data_fields_tail_code(fields[1:], env, module, allModules)

private fun java_script_data_fields_tail_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
        + java_script_string_literal(field.name)
        + ": "
        + java_script_expression_code(field.value, env, module, allModules)
        + java_script_data_fields_tail_code(fields[1:], env, module, allModules)

private fun java_script_index_expression_code(index: CompiledIndexExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_index("
        + java_script_expression_code(index.receiver, env, module, allModules)
        + ", "
        + java_script_expression_code(index.index, env, module, allModules)
        + ")"

private fun java_script_reduce_expression_code(reduce: CompiledReduceExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = java_script_reduce_bindings(reduce, env)
    let keyed = if reduce.keyName.is_empty() then "false" else "true"
    "__capy_reduce("
        + java_script_expression_code(reduce.receiver, env, module, allModules)
        + ", "
        + java_script_expression_code(reduce.initial, env, module, allModules)
        + ", "
        + keyed
        + ", ("
        + java_script_reduce_parameters(reduce)
        + ") => "
        + java_script_expression_code(reduce.body, reduceEnv, module, allModules)
        + ")"

private fun java_script_reduce_parameters(reduce: CompiledReduceExpression): String =
    if reduce.keyName.is_empty()
    then java_script_identifier(reduce.accumulatorName) + ", " + java_script_identifier(reduce.valueName)
    else java_script_identifier(reduce.accumulatorName) + ", " + java_script_identifier(reduce.keyName) + ", " + java_script_identifier(reduce.valueName)

private fun java_script_reduce_bindings(reduce: CompiledReduceExpression, env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    if reduce.keyName.is_empty()
    then [
            JavaScriptBinding { name: reduce.accumulatorName, jsName: java_script_identifier(reduce.accumulatorName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.valueName, jsName: java_script_identifier(reduce.valueName), typeName: java_script_unknown_type() },
        ] + env
    else [
            JavaScriptBinding { name: reduce.accumulatorName, jsName: java_script_identifier(reduce.accumulatorName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.keyName, jsName: java_script_identifier(reduce.keyName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.valueName, jsName: java_script_identifier(reduce.valueName), typeName: java_script_unknown_type() },
        ] + env

private fun java_script_match_expression_code(matchExpression: CompiledMatchExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_match_supported(matchExpression)
    then "((__capy_match_value) => " + java_script_match_cases_code(matchExpression.cases, env, module, allModules) + ")("
        + java_script_expression_code(matchExpression.value, env, module, allModules) + ")"
    else "__capy_unsupported('match')"

private fun java_script_match_cases_code(cases: List[CompiledMatchCase], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match cases[0] with
    case None -> "__capy_no_match(__capy_match_value)"
    case Some { matchCase } ->
        "(" + java_script_match_case_condition_code(matchCase, env, module, allModules)
            + " ? "
            + java_script_match_case_body_code(matchCase, env, module, allModules)
            + " : "
            + java_script_match_cases_code(cases[1:], env, module, allModules)
            + ")"

private fun java_script_match_case_condition_code(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let base = if matchCase.wildcard
        then "true"
        else if matchCase.hasLiteral
        then "__capy_match_value === " + java_script_expression_code(matchCase.literal, env, module, allModules)
        else "__capy_type_matches(__capy_match_value, " + java_script_string_literal(matchCase.typeName) + ")"
    if matchCase.hasGuard
    then "(" + base + " && " + java_script_truthy_expression_code(matchCase.guard, java_script_match_case_env(matchCase, env), module, allModules) + ")"
    else base

private fun java_script_match_case_body_code(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let caseEnv = java_script_match_case_env(matchCase, env)
    if matchCase.bindings.is_empty()
    then java_script_expression_code(matchCase.body, caseEnv, module, allModules)
    else "((" + java_script_match_case_parameters(matchCase.bindings) + ") => "
        + java_script_expression_code(matchCase.body, caseEnv, module, allModules)
        + ")(" + java_script_match_case_arguments(matchCase.bindings, 0) + ")"

private fun java_script_match_case_parameters(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> java_script_identifier(binding) + java_script_match_case_parameter_tail(bindings[1:])

private fun java_script_match_case_parameter_tail(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> ", " + java_script_identifier(binding) + java_script_match_case_parameter_tail(bindings[1:])

private fun java_script_match_case_arguments(bindings: List[String], idx: int): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        "__capy_match_binding(__capy_match_value, " + java_script_string_literal(binding) + ", " + idx + ")"
            + java_script_match_case_argument_tail(bindings[1:], idx + 1)

private fun java_script_match_case_argument_tail(bindings: List[String], idx: int): String =
    match bindings[0] with
    case None -> ""
    case Some _ -> ", " + java_script_match_case_arguments(bindings, idx)

private fun java_script_match_case_env(matchCase: CompiledMatchCase, env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    java_script_match_case_bindings(matchCase.bindings) + env

private fun java_script_match_case_bindings(bindings: List[String]): List[JavaScriptBinding] =
    match bindings[0] with
    case None -> []
    case Some { binding } ->
        [JavaScriptBinding { name: binding, jsName: java_script_identifier(binding), typeName: java_script_unknown_type() }]
            + java_script_match_case_bindings(bindings[1:])

private fun java_script_block_expression_code(block: CompiledBlockExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "(() => { "
        + java_script_block_binding_statements(block.bindings, env, module, allModules)
        + "return "
        + java_script_expression_code(block.result, java_script_block_env(block.bindings, env), module, allModules)
        + "; })()"

private fun java_script_block_binding_statements(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        "const "
            + java_script_identifier(binding.name)
            + " = "
            + java_script_expression_code(binding.value, env, module, allModules)
            + "; "
            + java_script_block_binding_statements(bindings[1:], [java_script_let_binding(binding)] + env, module, allModules)

private fun java_script_block_env(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } -> java_script_block_env(bindings[1:], [java_script_let_binding(binding)] + env)

private fun java_script_let_binding(binding: CompiledLetBinding): JavaScriptBinding =
    JavaScriptBinding { name: binding.name, jsName: java_script_identifier(binding.name), typeName: binding.typeReference.name }

private fun java_script_truthy_expression_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "Boolean(" + java_script_expression_code(expression, env, module, allModules) + ")"

private fun java_script_function_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_runtime_function(name)
    then name
    else match java_script_find_local_function(name, module.functions) with
    case Some { function } -> java_script_function_name(function)
    case None ->
        match java_script_find_function_in_imports(name, module.imports, module, allModules) with
        case Some { binding } -> binding
        case None -> java_script_identifier(name)

private fun java_script_runtime_function(name: String): bool =
    name == "assert_all"
        | name == "assert_that"
        | name == "test"
        | name == "test_file"
        | name == "digits"
        | name == "pure"
        | name == "delay"

private fun java_script_find_local_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if !java_script_skip_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_local_function(name, functions[1:])

private fun java_script_find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_callable_function(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_function(name, functions[1:])

private fun java_script_callable_function(function: CompiledFunction): bool =
    !java_script_skip_function(function) & function.visibility != "private" & function.visibility != "const:private"

private fun java_script_find_local_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_emitted_constant(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_local_constant(name, functions[1:])

private fun java_script_find_exported_constant(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_exported_constant(function) & function.name == name
        then /capy/lang/Option.Some { function }
        else java_script_find_exported_constant(name, functions[1:])

private fun java_script_find_function_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified | !java_script_import_includes_name(name, declaration)
        then java_script_find_function_in_imports(name, imports[1:], module, allModules)
        else java_script_find_function_in_import(name, declaration, imports[1:], module, allModules)

private fun java_script_find_function_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        java_script_find_function_in_imported_module(name, declaration, importedModule, rest, module, allModules)
    case None -> java_script_find_function_in_imports(name, rest, module, allModules)

private fun java_script_find_function_in_imported_module(name: String, declaration: CompiledImportDeclaration, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_function(name, importedModule.functions) with
    case Some { function } ->
        /capy/lang/Option.Some {
            java_script_import_alias(declaration, module) + "[" + java_script_string_literal(java_script_export_name(function)) + "]"
        }
    case None -> java_script_find_function_in_imports(name, rest, module, allModules)

private fun java_script_find_constant_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified | !java_script_import_includes_name(name, declaration)
        then java_script_find_constant_in_imports(name, imports[1:], module, allModules)
        else java_script_find_constant_in_import(name, declaration, imports[1:], module, allModules)

private fun java_script_find_constant_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        java_script_find_constant_in_imported_module(name, declaration, importedModule, rest, module, allModules)
    case None -> java_script_find_constant_in_imports(name, rest, module, allModules)

private fun java_script_find_constant_in_imported_module(name: String, declaration: CompiledImportDeclaration, importedModule: CompiledModule, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_exported_constant(name, importedModule.functions) with
    case Some { function } ->
        /capy/lang/Option.Some {
            java_script_import_alias(declaration, module) + "[" + java_script_string_literal(java_script_export_name(function)) + "]"
        }
    case None -> java_script_find_constant_in_imports(name, rest, module, allModules)

private fun java_script_find_imported_module(declaration: CompiledImportDeclaration, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    java_script_find_module_by_path(java_script_import_module_path(declaration.modulePath, module), allModules)

private fun java_script_find_module_by_path(modulePath: String, modules: List[CompiledModule]): /capy/lang/Option[CompiledModule] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        if java_script_module_path(module) == modulePath
        then /capy/lang/Option.Some { module }
        else java_script_find_module_by_path(modulePath, modules[1:])

private fun java_script_import_includes_name(name: String, declaration: CompiledImportDeclaration): bool =
    if declaration.wildcard
    then !java_script_string_list_contains(name, declaration.excludedNames)
    else java_script_string_list_contains(name, declaration.importedNames)

private fun java_script_string_list_contains(value: String, values: List[String]): bool =
    match values[0] with
    case None -> false
    case Some { item } -> item == value | java_script_string_list_contains(value, values[1:])

private fun java_script_exports(functions: List[CompiledFunction]): String =
    "module.exports = {"
        + java_script_newline()
        + java_script_export_entries(functions, true)
        + "};"
        + java_script_newline()

private fun java_script_export_entries(functions: List[CompiledFunction], first: bool): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_exported_function(function)
        then java_script_export_entry(function, first) + java_script_export_entries(functions[1:], false)
        else java_script_export_entries(functions[1:], first)

private fun java_script_export_entry(function: CompiledFunction, first: bool): String =
    let prefix = if first then "" else "," + java_script_newline()
    prefix
        + "    "
        + java_script_string_literal(java_script_export_name(function))
        + ": "
        + java_script_export_value_name(function)

private fun java_script_exported_function(function: CompiledFunction): bool =
    if java_script_emitted_constant(function)
    then java_script_exported_constant(function)
    else !java_script_skip_function(function)
        & function.visibility != "private"

private fun java_script_exported_constant(function: CompiledFunction): bool =
    java_script_emitted_constant(function) & function.visibility != "const:private"

private fun java_script_export_value_name(function: CompiledFunction): String =
    if java_script_emitted_constant(function)
    then java_script_constant_name(function)
    else java_script_function_name(function)

private fun java_script_export_name(function: CompiledFunction): String =
    function.name

private fun java_script_test_runtime_modules(modules: List[CompiledModule]): List[GeneratedModule] =
    [GeneratedModule {
        relativePath: "capy/test/CapyTestRuntime.js",
        code: java_script_test_runtime_code(modules)
    }]

private fun java_script_test_runtime_code(modules: List[CompiledModule]): String =
    "'use strict';" + java_script_newline()
    + java_script_newline()
    + "class Effect {" + java_script_newline()
    + "    constructor(thunk) { this._thunk = thunk; }" + java_script_newline()
    + "    unsafe_run() { return this._thunk(); }" + java_script_newline()
    + "    unsafeRun() { return this.unsafe_run(); }" + java_script_newline()
    + "    map(fn) { return new Effect(() => fn(this.unsafe_run())); }" + java_script_newline()
    + "    flat_map(fn) { return new Effect(() => __capy_unsafe_run(fn(this.unsafe_run()))); }" + java_script_newline()
    + "    flatMap(fn) { return this.flat_map(fn); }" + java_script_newline()
    + "    static pure(value) { return new Effect(() => value); }" + java_script_newline()
    + "    static delay(thunk) { return new Effect(thunk); }" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function pure(value) { return Effect.pure(value); }" + java_script_newline()
    + "function delay(thunk) { return Effect.delay(thunk); }" + java_script_newline()
    + java_script_newline()
    + "class ValueAssert {" + java_script_newline()
    + "    constructor(value, assertions = []) { this.value = value; this.assertions = assertions; }" + java_script_newline()
    + "    _append(result, message, type) { return new ValueAssert(this.value, this.assertions.concat([() => ({ result: Boolean(result), message: String(message), type })])); }" + java_script_newline()
    + "    is_equal_to(other, tolerance = null) { const result = tolerance == null ? __capy_deep_equal(this.value, other) : Math.abs(Number(this.value) - Number(other)) <= Number(tolerance); return this._append(result, 'Expected ' + __capy_display(this.value) + ' to equal ' + __capy_display(other), 'Assert.is_equal_to'); }" + java_script_newline()
    + "    is_true() { return this._append(this.value === true, 'Expected ' + __capy_display(this.value) + ' to be true', 'Assert.is_true'); }" + java_script_newline()
    + "    is_false() { return this._append(this.value === false, 'Expected ' + __capy_display(this.value) + ' to be false', 'Assert.is_false'); }" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function assert_that(value) { return new ValueAssert(value); }" + java_script_newline()
    + "function assert_all(asserts) {" + java_script_newline()
    + "    const assertions = [];" + java_script_newline()
    + "    for (const item of asserts) {" + java_script_newline()
    + "        if (item && Array.isArray(item.assertions)) assertions.push(...item.assertions);" + java_script_newline()
    + "    }" + java_script_newline()
    + "    return { assertions };" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function test(name, body) { return { name, body, assert_supplier: body }; }" + java_script_newline()
    + "function test_file(file_name, test_cases) { return Effect.delay(() => ({ file_name, fileName: file_name, path: file_name, test_cases, testCases: test_cases, timestamp_millis: Date.now() })); }" + java_script_newline()
    + java_script_newline()
    + "function __capy_str(value) { if (value === true) return 'true'; if (value === false) return 'false'; if (value == null) return 'null'; return String(value); }" + java_script_newline()
    + "function __capy_add(left, right) { if (typeof left === 'string' || typeof right === 'string') return __capy_str(left) + __capy_str(right); if (Array.isArray(left)) return left.concat(Array.isArray(right) ? right : [right]); if (left instanceof Set) return new Set([...(left || []), ...((right instanceof Set) ? right : [right])]); if (left instanceof Map) { const result = new Map(left); if (right instanceof Map) for (const [key, value] of right) result.set(key, value); else if (Array.isArray(right) && right.length === 2) result.set(right[0], right[1]); return result; } return left + right; }" + java_script_newline()
    + "function __capy_sub(left, right) { return left - right; }" + java_script_newline()
    + "function __capy_mul(left, right) { return left * right; }" + java_script_newline()
    + "function __capy_div(left, right) { const value = left / right; return Number.isInteger(left) && Number.isInteger(right) ? Math.trunc(value) : value; }" + java_script_newline()
    + "function __capy_mod(left, right) { return left % right; }" + java_script_newline()
    + "function __capy_pow(left, right) { if (Number.isInteger(left) && Number.isInteger(right)) { if (right <= 0) return 1; let result = 1; for (let index = 0; index < right; index++) result *= left; return result; } return Math.pow(left, right); }" + java_script_newline()
    + "function __capy_contains(left, right) { if (typeof left === 'string') return left.includes(right); if (Array.isArray(left)) return left.includes(right); if (left instanceof Set) return left.has(right); if (left instanceof Map) return left.has(right); return right in left; }" + java_script_newline()
    + "function __capy_size(value) { return value == null ? 0 : value.size != null ? value.size : value.length; }" + java_script_newline()
    + "function __capy_index(value, index) { if (value instanceof Map) return value.get(index); return value[index]; }" + java_script_newline()
    + "function __capy_get_field(value, name) { return value == null ? undefined : value[name]; }" + java_script_newline()
    + "function __capy_reduce(value, initial, keyed, reducer) { let result = initial; if (value instanceof Map) { for (const [key, item] of value) result = keyed ? reducer(result, key, item) : reducer(result, item); return result; } if (value && typeof value[Symbol.iterator] === 'function') { for (const item of value) result = reducer(result, item); } return result; }" + java_script_newline()
    + "function __capy_type_matches(value, typeName) { if (typeName === 'String') return typeof value === 'string'; if (typeName === 'bool') return typeof value === 'boolean'; if (typeName === 'byte' || typeName === 'int' || typeName === 'long') return Number.isInteger(value); if (typeName === 'float' || typeName === 'double') return typeof value === 'number'; if (typeName === 'List') return Array.isArray(value); if (typeName === 'Set') return value instanceof Set; if (typeName === 'Dict') return value instanceof Map; if (value == null || typeof value !== 'object') return false; const actual = value.__type; return actual === typeName || actual === '__capy_raw|' + typeName; }" + java_script_newline()
    + "function __capy_match_binding(value, name, index) { if (value == null) return undefined; if (Object.prototype.hasOwnProperty.call(value, name)) return value[name]; const positional = '$' + index; if (Object.prototype.hasOwnProperty.call(value, positional)) return value[positional]; const fields = Object.keys(value).filter(key => key !== '__type'); if (index < fields.length) return value[fields[index]]; return value[name]; }" + java_script_newline()
    + "function __capy_no_match(value) { throw new Error('No Capybara match case for ' + __capy_display(value)); }" + java_script_newline()
    + "function __capy_data(typeName, fields) { return Object.assign({ __type: typeName }, fields); }" + java_script_newline()
    + "function __capy_unsupported(source) { throw new Error('Unsupported CFUN expression: ' + source); }" + java_script_newline()
    + "function digits(number) { number = Math.abs(Math.trunc(number)); let result = 1; while (number >= 10) { number = Math.trunc(number / 10); result++; } return result; }" + java_script_newline()
    + java_script_newline()
    + "function __capy_unsafe_run(value) { while (value && (typeof value.unsafe_run === 'function' || typeof value.unsafeRun === 'function')) value = typeof value.unsafe_run === 'function' ? value.unsafe_run() : value.unsafeRun(); return value; }" + java_script_newline()
    + "function __capy_as_list(value) { value = __capy_unsafe_run(value); if (value == null) return []; return Array.isArray(value) ? value : [value]; }" + java_script_newline()
    + "function __capy_gather_module(modulePath) { const module = require(modulePath); return typeof module.tests === 'function' ? __capy_as_list(module.tests()) : []; }" + java_script_newline()
    + java_script_newline()
    + java_script_deep_equal_code()
    + java_script_newline()
    + "function gatherTests() {" + java_script_newline()
    + "    const files = [];" + java_script_newline()
    + java_script_test_gather_calls(modules, modules)
    + "    return files;" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "module.exports = { Effect, pure, delay, assert_all, assert_that, test, test_file, digits, __capy_add, __capy_sub, __capy_mul, __capy_div, __capy_mod, __capy_pow, __capy_contains, __capy_size, __capy_index, __capy_get_field, __capy_reduce, __capy_type_matches, __capy_match_binding, __capy_no_match, __capy_unsupported, __capy_data, gatherTests };" + java_script_newline()

private fun java_script_deep_equal_code(): String =
    "function __capy_deep_equal(left, right) {" + java_script_newline()
    + "    if (Object.is(left, right)) return true;" + java_script_newline()
    + "    if (Array.isArray(left) && Array.isArray(right)) return left.length === right.length && left.every((item, index) => __capy_deep_equal(item, right[index]));" + java_script_newline()
    + "    if (left instanceof Set && right instanceof Set) {" + java_script_newline()
    + "        if (left.size !== right.size) return false;" + java_script_newline()
    + "        for (const item of left) if (![...right].some(other => __capy_deep_equal(item, other))) return false;" + java_script_newline()
    + "        return true;" + java_script_newline()
    + "    }" + java_script_newline()
    + "    if (left instanceof Map && right instanceof Map) {" + java_script_newline()
    + "        if (left.size !== right.size) return false;" + java_script_newline()
    + "        for (const [key, value] of left) if (!right.has(key) || !__capy_deep_equal(value, right.get(key))) return false;" + java_script_newline()
    + "        return true;" + java_script_newline()
    + "    }" + java_script_newline()
    + "    if (left && right && typeof left === 'object' && typeof right === 'object') {" + java_script_newline()
    + "        const leftKeys = Object.keys(left);" + java_script_newline()
    + "        const rightKeys = Object.keys(right);" + java_script_newline()
    + "        return leftKeys.length === rightKeys.length && leftKeys.every(key => Object.prototype.hasOwnProperty.call(right, key) && __capy_deep_equal(left[key], right[key]));" + java_script_newline()
    + "    }" + java_script_newline()
    + "    return false;" + java_script_newline()
    + "}" + java_script_newline()
    + "function __capy_display(value) {" + java_script_newline()
    + "    if (value instanceof Map) return JSON.stringify(Object.fromEntries(value));" + java_script_newline()
    + "    if (value instanceof Set) return JSON.stringify([...value]);" + java_script_newline()
    + "    return JSON.stringify(value);" + java_script_newline()
    + "}" + java_script_newline()

private fun java_script_test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        java_script_test_gather_calls_for_module(module.functions, module, allModules)
            + java_script_test_gather_calls(modules[1:], allModules)

private fun java_script_test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        java_script_test_gather_call_for_function(function, module, allModules)
            + java_script_test_gather_calls_for_module(functions[1:], module, allModules)

private fun java_script_test_gather_call_for_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function.name == "tests"
    then if java_script_test_function_gatherable(function)
        then if java_script_module_gatherable(module, allModules)
            then "    files.push(...__capy_gather_module("
                + java_script_string_literal(java_script_relative_require_path("capy/test/CapyTestRuntime", java_script_module_path(module)))
                + "));"
                + java_script_newline()
            else ""
        else ""
    else ""

private fun java_script_module_gatherable(module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_module_imports_gatherable(module.imports, module, allModules)
        & java_script_module_functions_gatherable(module.functions, module, allModules)

private fun java_script_module_imports_gatherable(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> true
    case Some { declaration } ->
        if java_script_stdlib_import(declaration.modulePath)
        then java_script_module_imports_gatherable(imports[1:], module, allModules)
        else match java_script_find_imported_module(declaration, module, allModules) with
            case Some { importedModule } ->
                java_script_module_functions_gatherable(importedModule.functions, importedModule, allModules)
                    & java_script_module_imports_gatherable(imports[1:], module, allModules)
            case None -> false

private fun java_script_module_functions_gatherable(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match functions[0] with
    case None -> true
    case Some { function } ->
        java_script_function_gatherable(function, module, allModules)
            & java_script_module_functions_gatherable(functions[1:], module, allModules)

private fun java_script_function_gatherable(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_imported_function(function)
    then true
    else if java_script_compiled_schema(function)
    then true
    else if java_script_compiled_object_helper_function(function)
    then true
    else if java_script_compiled_constant(function)
    then java_script_expression_gatherable(function.body, [], module, allModules)
    else java_script_expression_gatherable(function.body, java_script_function_bindings(function), module, allModules)

private fun java_script_expression_gatherable(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression _ -> false
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression _ -> true
    case CompiledIfExpression ifExpression ->
        java_script_expression_gatherable(ifExpression.condition, env, module, allModules)
            & java_script_expression_gatherable(ifExpression.thenBranch, env, module, allModules)
            & java_script_expression_gatherable(ifExpression.elseBranch, env, module, allModules)
    case CompiledBinaryExpression binary -> java_script_binary_expression_gatherable(binary, env, module, allModules)
    case CompiledUnaryExpression unary ->
        java_script_unary_operator_gatherable(unary.operator)
            & java_script_expression_gatherable(unary.expression, env, module, allModules)
    case CompiledFunctionCallExpression call -> java_script_function_call_gatherable(call, env, module, allModules)
    case CompiledFunctionReferenceExpression _ -> false
    case CompiledMethodCallExpression call -> java_script_method_call_gatherable(call, env, module, allModules)
    case CompiledWithExpression _ -> false
    case CompiledLambdaExpression lambda ->
        java_script_expression_gatherable(lambda.body, java_script_lambda_bindings(lambda.parameters) + env, module, allModules)
    case CompiledListLiteral literal -> java_script_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledSetLiteral literal -> java_script_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledDictLiteral literal -> java_script_dict_entries_gatherable(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> java_script_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledIndexExpression index ->
        java_script_expression_gatherable(index.receiver, env, module, allModules)
            & java_script_expression_gatherable(index.index, env, module, allModules)
    case CompiledDataLiteral literal -> java_script_data_fields_gatherable(literal.fields, env, module, allModules)
    case CompiledFieldAccessExpression access -> java_script_expression_gatherable(access.receiver, env, module, allModules)
    case CompiledReduceExpression reduce -> java_script_reduce_expression_gatherable(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> java_script_match_expression_gatherable(matchExpression, env, module, allModules)
    case CompiledBlockExpression block ->
        java_script_bindings_gatherable(block.bindings, env, module, allModules)
            & java_script_expression_gatherable(block.result, java_script_block_env(block.bindings, env), module, allModules)

private fun java_script_binary_expression_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_binary_operator_gatherable(binary.operator)
        & java_script_expression_gatherable(binary.left, env, module, allModules)
        & java_script_expression_gatherable(binary.right, env, module, allModules)

private fun java_script_binary_operator_gatherable(operator: String): bool =
    operator == "+"
        | operator == "-"
        | operator == "*"
        | operator == "/"
        | operator == "%"
        | operator == "^"
        | operator == "=="
        | operator == "!="
        | operator == ">"
        | operator == "<"
        | operator == ">="
        | operator == "<="
        | operator == "?"
        | operator == "&"
        | operator == "|"
        | java_script_bitwise_binary_operator(operator)
        | operator == ".nand."

private fun java_script_unary_operator_gatherable(operator: String): bool =
    operator == "-" | operator == "!" | operator == ".not."

private fun java_script_function_call_gatherable(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expressions_gatherable(call.arguments, env, module, allModules)
    then if java_script_runtime_function(call.name)
        then true
        else if java_script_local_function_unambiguous(call.name, module.functions)
        then true
        else java_script_imported_function_exists(call.name, module.imports, module, allModules)
    else false

private fun java_script_method_call_gatherable(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_equal_to" | call.name == "is_true" | call.name == "is_false"
    then java_script_expression_gatherable(call.receiver, env, module, allModules)
        & java_script_expressions_gatherable(call.arguments, env, module, allModules)
    else if call.name == "size"
    then call.arguments.is_empty() & java_script_expression_gatherable(call.receiver, env, module, allModules)
    else false

private fun java_script_local_function_unambiguous(name: String, functions: List[CompiledFunction]): bool =
    java_script_local_function_count(name, functions) == 1

private fun java_script_local_function_count(name: String, functions: List[CompiledFunction]): int =
    match functions[0] with
    case None -> 0
    case Some { function } ->
        let current = if !java_script_skip_function(function) & function.name == name then 1 else 0
        current + java_script_local_function_count(name, functions[1:])

private fun java_script_imported_function_exists(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match java_script_find_function_in_imports(name, imports, module, allModules) with
    case Some _ -> true
    case None -> false

private fun java_script_expressions_gatherable(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        java_script_expression_gatherable(expression, env, module, allModules)
            & java_script_expressions_gatherable(expressions[1:], env, module, allModules)

private fun java_script_dict_entries_gatherable(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } ->
        java_script_expression_gatherable(entry.key, env, module, allModules)
            & java_script_expression_gatherable(entry.value, env, module, allModules)
            & java_script_dict_entries_gatherable(entries[1:], env, module, allModules)

private fun java_script_data_fields_gatherable(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } ->
        !field.spread
            & java_script_expression_gatherable(field.value, env, module, allModules)
            & java_script_data_fields_gatherable(fields[1:], env, module, allModules)

private fun java_script_reduce_expression_gatherable(reduce: CompiledReduceExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    !reduce.accumulatorName.is_empty()
        & !reduce.valueName.is_empty()
        & java_script_expression_gatherable(reduce.receiver, env, module, allModules)
        & java_script_expression_gatherable(reduce.initial, env, module, allModules)
        & java_script_expression_gatherable(reduce.body, java_script_reduce_bindings(reduce, env), module, allModules)

private fun java_script_match_expression_gatherable(matchExpression: CompiledMatchExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_expression_gatherable(matchExpression.value, env, module, allModules)
        & java_script_match_cases_gatherable(matchExpression.cases, env, module, allModules)

private fun java_script_match_supported(matchExpression: CompiledMatchExpression): bool =
    java_script_match_cases_supported(matchExpression.cases)

private fun java_script_match_cases_gatherable(cases: List[CompiledMatchCase], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        java_script_match_case_gatherable(matchCase, env, module, allModules)
            & (cases[1:].is_empty() | java_script_match_cases_gatherable(cases[1:], env, module, allModules))

private fun java_script_match_case_gatherable(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_match_case_supported(matchCase)
        & (!matchCase.hasLiteral | java_script_expression_gatherable(matchCase.literal, env, module, allModules))
        & (!matchCase.hasGuard | java_script_expression_gatherable(matchCase.guard, java_script_match_case_env(matchCase, env), module, allModules))
        & java_script_expression_gatherable(matchCase.body, java_script_match_case_env(matchCase, env), module, allModules)

private fun java_script_match_cases_supported(cases: List[CompiledMatchCase]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        java_script_match_case_supported(matchCase)
            & (cases[1:].is_empty() | java_script_match_cases_supported(cases[1:]))

private fun java_script_match_case_supported(matchCase: CompiledMatchCase): bool =
    matchCase.wildcard | !matchCase.typeName.is_empty() | matchCase.hasLiteral

private fun java_script_bindings_gatherable(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        binding.operator == "="
            & java_script_expression_gatherable(binding.value, env, module, allModules)
            & java_script_bindings_gatherable(bindings[1:], [java_script_let_binding(binding)] + env, module, allModules)

private fun java_script_test_function_gatherable(function: CompiledFunction): bool =
    match function.body with
    case CompiledFunctionCallExpression call -> call.name == "test_file" & java_script_test_file_arguments_gatherable(call.arguments)
    case _ -> false

private fun java_script_test_file_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { fileName } ->
        match arguments[1] with
        case None -> false
        case Some { tests } ->
            arguments[2:].is_empty()
                & java_script_string_literal_expression(fileName)
                & java_script_test_case_list_gatherable(tests)

private fun java_script_test_case_list_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledListLiteral list -> java_script_test_case_expressions_gatherable(list.values)
    case _ -> false

private fun java_script_test_case_expressions_gatherable(expressions: List[CompiledExpression]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> java_script_test_case_expression_gatherable(expression) & java_script_test_case_expressions_gatherable(expressions[1:])

private fun java_script_test_case_expression_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "test" & java_script_test_call_arguments_gatherable(call.arguments)
    case _ -> false

private fun java_script_test_call_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { name } ->
        match arguments[1] with
        case None -> false
        case Some { body } ->
            arguments[2:].is_empty()
                & java_script_string_literal_expression(name)
                & java_script_zero_arg_lambda(body)

private fun java_script_string_literal_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledStringLiteral _ -> true
    case _ -> false

private fun java_script_zero_arg_lambda(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

private fun java_script_lookup_binding(name: String, env: List[JavaScriptBinding]): /capy/lang/Option[JavaScriptBinding] =
    match env[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding }
        else java_script_lookup_binding(name, env[1:])

private fun java_script_unknown_type(): String = "any"

private fun java_script_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else java_script_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

private fun java_script_method_name(name: String): String =
    java_script_identifier(name)

private fun java_script_import_alias(declaration: CompiledImportDeclaration, module: CompiledModule): String =
    "__capy_import_" + java_script_identifier(java_script_import_module_path(declaration.modulePath, module))

private fun java_script_import_module_path(modulePath: String, module: CompiledModule): String =
    if java_script_string_has_prefix(modulePath, "/")
    then java_script_normalize_module_path(modulePath)
    else if modulePath ? "/"
    then java_script_normalize_module_path(modulePath)
    else if module.path.is_empty()
    then modulePath
    else module.path + "/" + modulePath

private fun java_script_module_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

private fun java_script_module_relative_path(module: CompiledModule, extension: String): String =
    java_script_module_path(module) + extension

private fun java_script_stdlib_import(modulePath: String): bool =
    java_script_string_has_prefix(modulePath, "/capy/") | java_script_string_has_prefix(modulePath, "capy/")

private fun java_script_normalize_module_path(path: String): String =
    if java_script_string_has_prefix(path, "/")
    then java_script_normalize_module_path(path[1, path.size().value])
    else path

private fun java_script_relative_require_path(fromModulePath: String, toModulePath: String): String =
    java_script_parent_prefix(java_script_module_directory(fromModulePath)) + toModulePath

private fun java_script_module_directory(modulePath: String): String =
    let idx = java_script_last_index_of(modulePath, "/", 0, -1)
    if idx < 0 then "" else modulePath[0, idx]

private fun java_script_parent_prefix(path: String): String =
    if path.is_empty()
    then "./"
    else java_script_repeat_parent(java_script_path_component_count(path))

private fun java_script_repeat_parent(count: int): String =
    if count <= 0
    then "./"
    else "../" + java_script_repeat_parent_tail(count - 1)

private fun java_script_repeat_parent_tail(count: int): String =
    if count <= 0
    then ""
    else "../" + java_script_repeat_parent_tail(count - 1)

private fun java_script_path_component_count(path: String): int =
    if path.is_empty()
    then 0
    else 1 + java_script_char_count(path, "/", 0)

private fun java_script_char_count(value: String, expected: String, idx: int): int =
    if idx >= value.size().value
    then 0
    else match value[idx] with
        case None -> 0
        case Some { char } ->
            let current = if char == expected then 1 else 0
            current + java_script_char_count(value, expected, idx + 1)

private fun java_script_identifier(name: String): String =
    let sanitized = java_script_identifier_chars(name, 0, "")
    let nonEmpty = if sanitized.is_empty() then "_" else sanitized
    let prefixed = match nonEmpty[0] with
        case None -> "_"
        case Some { char } -> if java_script_identifier_start_char(char) then nonEmpty else "_" + nonEmpty
    if java_script_reserved_word(prefixed)
    then prefixed + "_"
    else prefixed

private fun java_script_identifier_chars(name: String, idx: int, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            let next = if java_script_identifier_part_char(char) then char else "_"
            java_script_identifier_chars(name, idx + 1, acc + next)

private fun java_script_identifier_start_char(char: String): bool =
    ("ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char) | ("abcdefghijklmnopqrstuvwxyz" ? char) | char == "_" | char == "$"

private fun java_script_identifier_part_char(char: String): bool =
    java_script_identifier_start_char(char) | ("0123456789" ? char)

private fun java_script_reserved_word(name: String): bool =
    "|break|case|catch|class|const|continue|debugger|default|delete|do|else|export|extends|finally|for|function|if|import|in|instanceof|new|return|super|switch|this|throw|try|typeof|var|void|while|with|yield|let|static|enum|await|implements|package|protected|interface|private|public|null|true|false|" ? ("|" + name + "|")

private fun java_script_string_literal(value: String): String =
    "\"" + java_script_escape_string(value) + "\""

private fun java_script_escape_string(value: String): String =
    value
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace('\n', '\\n')
        .replace('\r', '\\r')
        .replace('\t', '\\t')

private fun java_script_integer_literal(source: String): String =
    if java_script_string_has_suffix(source, "L") | java_script_string_has_suffix(source, "l")
    then source[0, source.size().value - 1]
    else source

private fun java_script_decimal_literal(source: String): String =
    if java_script_string_has_suffix(source, "f") | java_script_string_has_suffix(source, "F") | java_script_string_has_suffix(source, "d") | java_script_string_has_suffix(source, "D")
    then source[0, source.size().value - 1]
    else source

private fun java_script_string_has_prefix(value: String, prefix: String): bool =
    java_script_string_has_prefix_at(value, prefix, 0)

private fun java_script_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then java_script_string_has_prefix_at(value, prefix, idx + 1)
            else false

private fun java_script_string_has_suffix(value: String, suffix: String): bool =
    if suffix.size().value > value.size().value
    then false
    else value[value.size().value - suffix.size().value, value.size().value] == suffix

private fun java_script_last_index_of(value: String, needle: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { char } ->
            java_script_last_index_of(value, needle, idx + 1, if char == needle then idx else found)

private fun java_script_newline(): String = '\n'
