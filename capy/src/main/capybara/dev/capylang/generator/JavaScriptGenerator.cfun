/// Finds a qualified function return type in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_return_type_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
