/// JavaScript generator name binding from a Capybara symbol to its JavaScript identifier and type name.
data JavaScriptBinding { name: String, jsName: String, typeName: String }
/// JavaScript generator lookup entry for annotation metadata in a source module.
private data JavaScriptAnnotationBinding { name: String, moduleName: String, modulePath: String, fields: List[String] }
/// Decoded JavaScript annotation schema argument with field name, value kind, and encoded source value.
private data JavaScriptSchemaAnnotationArgument { name: String, kind: String, value: String }
/// Schema lookup result that distinguishes a type with no values from a missing type.
private data JavaScriptSchemaValues { typeExists: bool, values: List[String] }
/// Schema annotation values grouped under one object reflection metadata key.
private data JavaScriptObjectAnnotationValues { values: List[String] }
/// Object reflection annotation schema values collected for a class or interface.
private data JavaScriptObjectAnnotationSources { typeAnnotations: List[String], fieldAnnotations: Dict[JavaScriptObjectAnnotationValues], methodAnnotations: Dict[JavaScriptObjectAnnotationValues] }
/// Object reflection annotation schema values indexed by object owner name for one generated module.
private data JavaScriptObjectAnnotationIndex { sourcesByOwner: Dict[JavaScriptObjectAnnotationSources] }
/// JavaScript reflection table entries collected together to avoid duplicate schema scans.
private data JavaScriptReflectionEntries { typeEntries: List[String], enumValueEntries: List[String] }
/// JavaScript source sections collected in one pass over compiled functions.
private data JavaScriptFunctionSections { constants: String, functions: String, hasOverloadedFunctions: bool }
/// Native-provider declarations for a single JavaScript generated module, indexed by provider function name.
private data JavaScriptNativeProviderDeclarations { declarations: Dict[CompiledNativeProviderDeclaration] }
/// JavaScript native-provider declarations and JavaScript-capable bindings indexed for generator lookups.
private data JavaScriptNativeProviderIndex { declarationsByModule: Dict[JavaScriptNativeProviderDeclarations], bindings: Dict[CompiledNativeProviderBinding] }
/// JavaScript native-provider lookup scope for one generated module.
private data JavaScriptNativeProviderScope { declarations: Dict[CompiledNativeProviderDeclaration], bindings: Dict[CompiledNativeProviderBinding] }
/// Constructor statements collected in one scan over object helper functions.
private data JavaScriptObjectConstructorStatements { fieldStatements: String, initStatements: String }
/// Object class helper metadata collected in one scan over object helper functions.
private data JavaScriptObjectClassSources {
    openValue: String,
    fieldSchemas: List[String],
    parentSchemas: List[String],
    annotationSchemas: List[String],
    fieldStatements: String,
    initStatements: String
}
/// Object interface helper metadata collected in one scan over object helper functions.
private data JavaScriptObjectInterfaceSources { methodInfoStatements: String, parentSchemas: List[String], annotationSchemas: List[String] }
/// Decoded object field schema metadata used while emitting object reflection metadata.
private data JavaScriptObjectFieldSchema { name: String, typeName: String }

const JAVA_SCRIPT_RUNTIME_SYMBOLS = "Effect, pure, delay, print, println, print_error, println_error, assert_all, assert_that, test, test_file, reflection, digits, DEFAULT_FAILED_EXIT_CODE, __capy_current_millis, __capy_nano_time, __capy_clock_now, __capy_path_from_string, __capy_io_read_text, __capy_io_read_lines, __capy_io_read_bytes, __capy_io_write_text, __capy_io_write_lines, __capy_io_write_bytes, __capy_io_append_text, __capy_io_append_lines, __capy_io_append_bytes, __capy_io_exists, __capy_io_is_file, __capy_io_is_directory, __capy_io_size, __capy_io_create_file, __capy_io_create_directory, __capy_io_create_directories, __capy_io_list_entries, __capy_io_delete, __capy_io_copy, __capy_io_copy_replace, __capy_io_move, __capy_io_move_replace, __capy_add, __capy_sub, __capy_mul, __capy_div, __capy_mod, __capy_pow, __capy_truthy, __capy_contains, __capy_size, __capy_to_int, __capy_to_long, __capy_parse_int, __capy_parse_long, __capy_parse_double, __capy_parse_float, __capy_parse_bool, __capy_enum_parse, __capy_enum_name, __capy_char, __capy_to_string, __capy_string_trim, __capy_string_replace, __capy_string_starts_with, __capy_string_end_with, __capy_string_get, __capy_string_slice, __capy_regex_matches, __capy_regex_find, __capy_regex_find_all, __capy_regex_replace, __capy_regex_split, __capy_date_unix_date, __capy_time_midnight, __capy_date_time_unix_epoch, __capy_duration_zero, __capy_date_add_days, __capy_date_add_years_months, __capy_date_to_days_since_unix_epoch, __capy_date_to_iso_8601, __capy_time_add_seconds, __capy_time_to_seconds, __capy_time_to_iso_8601, __capy_date_time_plus, __capy_date_time_minus, __capy_date_time_timestamp, __capy_date_time_to_iso_8601, __capy_duration_to_iso_8601, __capy_duration_negate, __capy_duration_years, __capy_duration_months, __capy_duration_days, __capy_duration_hours, __capy_duration_minutes, __capy_duration_seconds, __capy_tuple, __capy_set, __capy_set_append, __capy_set_concat, __capy_set_remove, __capy_set_remove_all, __capy_set_subset, __capy_set_proper_subset, __capy_set_intersection, __capy_set_symmetric_difference, __capy_set_cartesian_product, __capy_set_power_set, __capy_index, __capy_slice, __capy_get_field, __capy_reduce, __capy_with, __capy_data_fields, __capy_as_list, to_seq, __capy_seq_map, __capy_seq_filter, __capy_seq_flat_map, __capy_option_map, __capy_option_filter, __capy_option_flat_map, __capy_result_map, __capy_result_flat_map, __capy_result_reduce, __capy_constructor_result, __capy_constructor_pipeline, __capy_any, __capy_all, __capy_type_matches, __capy_match_binding, __capy_no_match, __capy_throw, __capy_try, __capy_unsupported, __capy_not_implemented, __capy_data, __capy_export, __capy_unsafe_run, __capy_deep_equal, __capy_native_provider"

/// Passes an optional string through unchanged where JavaScript generator pipelines need a named adapter.
private fun java_script_option_string_identity(value: /capy/lang/Option[String]): /capy/lang/Option[String] = value
/// Passes a string through unchanged where JavaScript generator pipelines need a named adapter.
private fun java_script_string_identity(value: String): String = value
/// Passes a boolean through unchanged where JavaScript generator pipelines need a named adapter.
private fun java_script_bool_identity(value: bool): bool = value

/// Generates JavaScript source modules and test runtime modules from a compiled program.
fun java_script_generator(program: CompiledProgram): GeneratedProgram =
    let nativeProviderIndex = java_script_native_provider_index(program.nativeProviderCatalog)
    GeneratedProgram {
        modules: java_script_modules(program.modules, program.modules, nativeProviderIndex) + java_script_test_runtime_modules(program.modules)
    }

/// Creates JavaScript generated source modules for compiled modules.
private fun java_script_modules(modules: List[CompiledModule], allModules: List[CompiledModule], nativeProviderIndex: JavaScriptNativeProviderIndex): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: java_script_module_relative_path(module, ".js"),
        code: java_script_module_code(module, allModules, nativeProviderIndex)
    }] + java_script_modules(modules[1:], allModules, nativeProviderIndex)

/// Emits the complete CommonJS source for one compiled module.
private fun java_script_module_code(module: CompiledModule, allModules: List[CompiledModule], nativeProviderIndex: JavaScriptNativeProviderIndex): String =
    let nativeProviderScope = java_script_native_provider_scope_for_module(module, nativeProviderIndex)
    let objectAnnotationIndex = java_script_object_annotation_index(module.functions)
    let sections = java_script_function_sections(module.functions, module, allModules, nativeProviderScope, objectAnnotationIndex)
    "'use strict';" + java_script_newline()
    + java_script_newline()
    + java_script_runtime_import(module)
    + java_script_imports(module.imports, module)
    + java_script_newline()
    + sections.constants
    + java_script_newline()
    + sections.functions
    + java_script_overload_dispatchers_with_flag(module.functions, sections.hasOverloadedFunctions)
    + java_script_exports(module.functions)

/// Emits JavaScript runtime support source for runtime symbols.
private fun java_script_runtime_symbols(): String =
    JAVA_SCRIPT_RUNTIME_SYMBOLS

private fun java_script_runtime_import_symbols(module: CompiledModule): String =
    let excluded = java_script_runtime_excluded_symbols(module)
    if excluded.is_empty()
    then java_script_runtime_symbols()
    else java_script_code_list(java_script_runtime_symbol_names_excluding(java_script_runtime_symbol_names(), excluded))

private fun java_script_runtime_symbol_names_excluding(symbols: List[String], excluded: List[String]): List[String] =
    match symbols[0] with
    case None -> []
    case Some { symbol } ->
        if java_script_string_list_contains(symbol, excluded)
        then java_script_runtime_symbol_names_excluding(symbols[1:], excluded)
        else [symbol] + java_script_runtime_symbol_names_excluding(symbols[1:], excluded)

private fun java_script_runtime_excluded_symbols(module: CompiledModule): List[String] =
    let path = java_script_module_path(module)
    if path == "capy/lang/Effect"
    then ["pure", "delay"]
    else if path == "capy/io/Console"
    then ["print", "println", "print_error", "println_error"]
    else if path == "capy/test/Assert"
    then ["assert_all", "assert_that"]
    else if path == "capy/test/CapyTest"
    then ["test", "test_file"]
    else if path == "capy/meta_prog/Reflection"
    then ["reflection"]
    else if path == "capy/lang/Math"
    then ["digits"]
    else if path == "capy/lang/Program"
    then ["DEFAULT_FAILED_EXIT_CODE"]
    else if path == "capy/collection/Seq"
    then ["to_seq"]
    else []

