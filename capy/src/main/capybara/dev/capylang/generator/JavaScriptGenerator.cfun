            then java_script_find_qualified_function_result_payload_type_in_import(qualifier, member, declaration, imports[1:], module, allModules)
            else java_script_option_string_identity(java_script_find_qualified_function_result_payload_type_in_imports(qualifier, member, imports[1:], module, allModules))
