        case None -> java_script_option_string_identity(java_script_find_qualified_function_effect_payload_type_in_imports(qualifier, member, rest, module, allModules))
    }
    case _ -> java_script_option_string_identity(java_script_find_qualified_function_effect_payload_type_in_imports(qualifier, member, rest, module, allModules))

