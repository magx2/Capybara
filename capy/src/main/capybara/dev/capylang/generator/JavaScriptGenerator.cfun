    + "    typeName = __capy_normalize_type_name(typeName);" + java_script_newline()
    + "    return typeName.startsWith('__capy_raw|') ? typeName.slice('__capy_raw|'.length) : typeName;" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function __capy_reflection_unknown(typeName) {" + java_script_newline()
    + "    return __capy_data('DataValueInfo', { name: typeName, pkg: __capy_reflection_package(Object.create(null)), fields: [], annotations: [] });" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()
    + "function reflection(obj, declaredType = null) {" + java_script_newline()
    + "    const value = __capy_unsafe_run(obj);" + java_script_newline()
    + "    const typeName = declaredType == null ? __capy_reflection_type_name(value) : __capy_normalize_type_name(declaredType);" + java_script_newline()
    + "    const enumMetadata = __capy_reflection_enum_values[__capy_reflection_enum_value_name(typeName)];" + java_script_newline()
    + "    if (enumMetadata != null) {" + java_script_newline()
    + "        const name = value != null && typeof value === 'object' && Object.prototype.hasOwnProperty.call(value, 'name') ? __capy_get_field(value, 'name') : (enumMetadata.name || typeName);" + java_script_newline()
    + "        return __capy_data('DataValueInfo', { name, pkg: __capy_reflection_package(enumMetadata.pkg), fields: [], annotations: __capy_reflection_annotations(enumMetadata.annotations) });" + java_script_newline()
    + "    }" + java_script_newline()
    + "    const metadata = __capy_reflection_types[typeName];" + java_script_newline()
    + "    if (metadata == null) return __capy_reflection_unknown(typeName);" + java_script_newline()
    + "    const fields = (metadata.fields || []).map(field => __capy_reflection_field_value(value, field));" + java_script_newline()
    + "    return __capy_data('DataValueInfo', { name: metadata.name || typeName, pkg: __capy_reflection_package(metadata.pkg), fields, annotations: __capy_reflection_annotations(metadata.annotations) });" + java_script_newline()
    + "}" + java_script_newline()
    + java_script_newline()

/// Emits JavaScript expression text for test gather calls.
private fun java_script_test_gather_calls(modules: List[CompiledModule], allModules: List[CompiledModule]): String =
    match modules[0] with
    case None -> ""
    case Some { module } ->
        java_script_test_gather_calls_for_module(module.functions, module, allModules)
            + java_script_test_gather_calls(modules[1:], allModules)

/// Emits JavaScript expression text for test gather calls for a module.
private fun java_script_test_gather_calls_for_module(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        java_script_test_gather_call_for_function(function, module, allModules)
            + java_script_test_gather_calls_for_module(functions[1:], module, allModules)

/// Emits JavaScript expression text for test gather call for function.
private fun java_script_test_gather_call_for_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    if function.name == "tests"
    then if java_script_test_function_gatherable(function)
        then if java_script_module_gatherable(module, allModules)
            then "    files.push(...__capy_gather_module("
                + java_script_string_literal(java_script_relative_require_path("capy/test/CapyTestRuntime", java_script_module_path(module)))
                + "));"
                + java_script_newline()
            else ""
        else ""
    else ""

/// Checks whether module can be included in generated test gathering.
private fun java_script_module_gatherable(module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_module_imports_gatherable(module.imports, module, allModules)
    then java_script_module_functions_gatherable(module.functions, module, allModules)
    else false

/// Checks whether module imports can be included in generated test gathering.
private fun java_script_module_imports_gatherable(imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> true
    case Some { declaration } ->
        if java_script_stdlib_import(declaration.modulePath)
        then java_script_module_imports_gatherable(imports[1:], module, allModules)
        else match java_script_find_imported_module(declaration, module, allModules) with
            case Some { importedModule } ->
                if java_script_module_functions_gatherable(importedModule.functions, importedModule, allModules)
                then java_script_module_imports_gatherable(imports[1:], module, allModules)
                else false
            case None -> false

/// Checks whether module functions can be included in generated test gathering.
private fun java_script_module_functions_gatherable(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match functions[0] with
    case None -> true
    case Some { function } ->
        if java_script_function_gatherable(function, module, allModules)
        then java_script_module_functions_gatherable(functions[1:], module, allModules)
        else false

/// Checks whether function can be included in generated test gathering.
private fun java_script_function_gatherable(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_imported_function(function)
    then true
    else if java_script_compiled_schema(function)
    then true
    else if java_script_compiled_object_helper_function(function)
    then true
    else if java_script_compiled_constant(function)
    then java_script_expression_gatherable(function.body, [], module, allModules)
    else if java_script_placeholder_function_body(function)
    then true
    else if java_script_native_function_body(function)
    then true
    else java_script_expression_gatherable(function.body, java_script_function_bindings(function), module, allModules)

/// Checks whether a function matches the placeholder function body metadata.
private fun java_script_placeholder_function_body(function: CompiledFunction): bool =
    match function.body with
    case CompiledUnsupportedExpression unsupported -> java_script_compiled_placeholder_source(unsupported.source)
    case _ -> false

/// Checks whether a function matches the native function body metadata.
private fun java_script_native_function_body(function: CompiledFunction): bool =
    match function.body with
    case CompiledUnsupportedExpression unsupported -> unsupported.source == "<native>"
    case _ -> false

/// Checks whether expression can be included in generated test gathering.
private fun java_script_expression_gatherable(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledUnsupportedExpression _ -> false
    case CompiledThrowExpression throwExpression -> java_script_expression_gatherable(throwExpression.value, env, module, allModules)
    case CompiledTryCatchExpression tryCatch ->
        if java_script_expression_gatherable(tryCatch.body, env, module, allModules)
        then java_script_try_catch_branches_gatherable(tryCatch.branches, env, module, allModules)
        else false
    case CompiledIntLiteral _ -> true
    case CompiledLongLiteral _ -> true
    case CompiledFloatLiteral _ -> true
    case CompiledDoubleLiteral _ -> true
    case CompiledBoolLiteral _ -> true
    case CompiledStringLiteral _ -> true
    case CompiledVariableExpression _ -> true
    case CompiledIfExpression ifExpression ->
        if java_script_expression_gatherable(ifExpression.condition, env, module, allModules)
        then if java_script_expression_gatherable(ifExpression.thenBranch, env, module, allModules)
            then java_script_expression_gatherable(ifExpression.elseBranch, env, module, allModules)
            else false
        else false
    case CompiledBinaryExpression binary -> java_script_binary_expression_gatherable(binary, env, module, allModules)
    case CompiledUnaryExpression unary ->
        if java_script_unary_operator_gatherable(unary.operator)
        then java_script_expression_gatherable(unary.expression, env, module, allModules)
        else false
    case CompiledFunctionCallExpression call -> java_script_function_call_gatherable(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> java_script_function_reference_gatherable(reference, module, allModules)
    case CompiledMethodCallExpression call -> java_script_method_call_gatherable(call, env, module, allModules)
    case CompiledWithExpression withExpression ->
        if java_script_expression_gatherable(withExpression.receiver, env, module, allModules)
        then java_script_data_fields_gatherable(withExpression.fields, env, module, allModules)
        else false
    case CompiledLambdaExpression lambda ->
        java_script_expression_gatherable(lambda.body, java_script_lambda_bindings(lambda.parameters) + env, module, allModules)
    case CompiledListLiteral literal -> java_script_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledSetLiteral literal -> java_script_expressions_gatherable(literal.values, env, module, allModules)
    case CompiledDictLiteral literal -> java_script_dict_entries_gatherable(literal.entries, env, module, allModules)
    case CompiledTupleLiteral literal -> java_script_tuple_literal_gatherable(literal, env, module, allModules)
    case CompiledIndexExpression index -> java_script_index_expression_gatherable(index, env, module, allModules)
    case CompiledDataLiteral literal -> java_script_data_fields_gatherable(literal.fields, env, module, allModules)
    case CompiledFieldAccessExpression access -> java_script_expression_gatherable(access.receiver, env, module, allModules)
    case CompiledReduceExpression reduce -> java_script_reduce_expression_gatherable(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> java_script_match_expression_gatherable(matchExpression, env, module, allModules)
    case CompiledBlockExpression block ->
        if java_script_bindings_gatherable(block.bindings, env, module, allModules)
        then java_script_expression_gatherable(block.result, java_script_block_env(block.bindings, env, module, allModules), module, allModules)
        else false

/// Checks whether OO try/catch branches can be included in generated test gathering.
private fun java_script_try_catch_branches_gatherable(branches: List[CompiledTryCatchBranch], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match branches[0] with
    case None -> true
    case Some { branch } ->
        let catchEnv = [JavaScriptBinding { name: branch.catchName, jsName: java_script_identifier(branch.catchName), typeName: "Error" }] + env
        if java_script_expression_gatherable(branch.catchBody, catchEnv, module, allModules)
        then java_script_try_catch_branches_gatherable(branches[1:], env, module, allModules)
        else false

/// Checks whether binary expression can be included in generated test gathering.
private fun java_script_binary_expression_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let leftType = java_script_expression_type(binary.left, env, module, allModules)
    if java_script_result_reduce_operator_expression_with_left_type(binary, leftType)
    then java_script_result_reduce_operator_gatherable(binary, env, module, allModules)
    else if java_script_collection_reduce_operator_expression_with_left_type(binary, leftType)
    then java_script_collection_reduce_operator_gatherable(binary, env, module, allModules)
    else if java_script_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then java_script_method_call_gatherable(java_script_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if java_script_async_pipe_expression_with_left_type(binary, leftType)
    then java_script_async_pipe_gatherable(binary, env, module, allModules)
    else if java_script_result_pipe_expression_with_left_type(binary, leftType)
    then java_script_result_pipe_gatherable(binary, env, module, allModules)
    else if java_script_collection_or_unknown_pipe_expression_with_left_type(binary, leftType)
    then java_script_collection_pipe_gatherable(binary, env, module, allModules)
    else if java_script_option_pipe_expression_with_left_type(binary, leftType)
    then java_script_option_pipe_gatherable(binary, env, module, allModules)
    else if java_script_set_binary_expression_with_left_type(binary, leftType)
    then java_script_expression_gatherable(binary.left, env, module, allModules)
        & java_script_expression_gatherable(binary.right, env, module, allModules)
    else if java_script_regex_binary_expression_with_left_type(binary, leftType)
    then java_script_expression_gatherable(binary.left, env, module, allModules)
        & java_script_expression_gatherable(binary.right, env, module, allModules)
    else if java_script_binary_operator_gatherable(binary.operator)
    then java_script_expression_gatherable(binary.left, env, module, allModules)
        & java_script_expression_gatherable(binary.right, env, module, allModules)
    else
        match java_script_find_local_binary_extension_operator_with_left_type(binary, leftType, module.functions) with
        case Some _ ->
            java_script_expression_gatherable(binary.left, env, module, allModules)
                & java_script_expression_gatherable(binary.right, env, module, allModules)
        case None -> false

/// Checks whether collection pipe can be included in generated test gathering.
private fun java_script_collection_pipe_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_pipe_gatherable(binary, env, module, allModules)

/// Checks whether option pipe can be included in generated test gathering.
private fun java_script_option_pipe_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_pipe_gatherable(binary, env, module, allModules)

/// Checks whether pipe can be included in generated test gathering.
private fun java_script_pipe_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expression_gatherable(binary.left, env, module, allModules)
    then java_script_callable_expression_gatherable(binary.right, env, module, allModules)
    else false

/// Checks whether result pipe can be included in generated test gathering.
private fun java_script_result_pipe_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expression_gatherable(binary.left, env, module, allModules)
    then java_script_result_callable_expression_gatherable(binary.left, binary.right, env, module, allModules)
    else false

/// Checks whether async pipe can be included in generated test gathering.
private fun java_script_async_pipe_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_expression_gatherable(binary.left, env, module, allModules)
        & java_script_callable_expression_gatherable(binary.right, env, module, allModules)

/// Checks whether result reduce operator can be included in generated test gathering.
private fun java_script_result_reduce_operator_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match binary.right with
    case CompiledTupleLiteral literal ->
        if java_script_expression_gatherable(binary.left, env, module, allModules)
        then java_script_result_reduce_arguments_gatherable(binary.left, literal.values, env, module, allModules)
        else false
    case _ -> false

private fun java_script_collection_reduce_operator_gatherable(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match binary.right with
    case CompiledTupleLiteral literal -> {
        match literal.values[0] with
        case None -> false
        case Some { initial } ->
            match literal.values[1] with
            case None -> false
            case Some { reducer } ->
                if java_script_expression_gatherable(binary.left, env, module, allModules)
                then if java_script_expression_gatherable(initial, env, module, allModules)
                    then java_script_callable_expression_gatherable(reducer, env, module, allModules)
                    else false
                else false
    }
    case _ -> false

private fun java_script_tuple_literal_gatherable(literal: CompiledTupleLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match java_script_reduce_tuple_literal_call(literal.values) with
    case Some { call } ->
        if java_script_result_reduce_method_call(call, env, module, allModules)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else java_script_collection_reduce_method_gatherable(call, env, module, allModules)
    case None -> java_script_expressions_gatherable(literal.values, env, module, allModules)

/// Checks whether callable expression can be included in generated test gathering.
private fun java_script_callable_expression_gatherable(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expression with
    case CompiledLambdaExpression lambda -> java_script_expression_gatherable(lambda.body, java_script_lambda_bindings(lambda.parameters) + env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> java_script_function_reference_gatherable(reference, module, allModules)
    case _ -> false

/// Checks whether function reference can be included in generated test gathering.
private fun java_script_function_reference_gatherable(reference: CompiledFunctionReferenceExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_runtime_function(reference.name)
    then true
    else if java_script_local_function_unambiguous(reference.name, module.functions)
    then true
    else java_script_imported_function_exists(reference.name, module.imports, module, allModules)

/// Checks whether binary operator can be included in generated test gathering.
private fun java_script_binary_operator_gatherable(operator: String): bool =
    operator == "+"
        | operator == "-"
        | operator == "*"
        | operator == "/"
        | operator == "%"
        | operator == "^"
        | operator == "=="
        | operator == "!="
        | operator == ">"
        | operator == "<"
        | operator == ">="
        | operator == "<="
        | operator == "?"
        | operator == "&"
        | operator == "|"
        | java_script_bitwise_binary_operator(operator)
        | operator == ".nand."

/// Checks whether unary operator can be included in generated test gathering.
private fun java_script_unary_operator_gatherable(operator: String): bool =
    operator == "-" | operator == "!" | operator == ".not."

/// Checks whether index expression can be included in generated test gathering.
private fun java_script_index_expression_gatherable(index: CompiledIndexExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expression_gatherable(index.receiver, env, module, allModules)
    then if java_script_expression_gatherable(index.index, env, module, allModules)
        then if index.hasEndIndex
            then java_script_expression_gatherable(index.endIndex, env, module, allModules)
            else true
        else false
    else false

/// Checks whether function call can be included in generated test gathering.
private fun java_script_function_call_gatherable(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expressions_gatherable(call.arguments, env, module, allModules)
    then if java_script_binding_exists(call.name, env)
        then true
        else if java_script_runtime_function(call.name)
        then true
        else if java_script_object_type_call(call)
        then true
        else if java_script_oo_constructor_call(call.name, module, allModules)
        then true
        else if java_script_stdlib_effect_function_call(call, module)
        then true
        else if java_script_stdlib_path_function_call(call, module)
        then true
        else if java_script_stdlib_io_function_call(call, module)
        then true
        else if java_script_enum_parse_call(call, module, allModules)
        then true
        else if java_script_stdlib_math_sqrt_call(call, module)
        then true
        else if java_script_qualified_call_name(call.name)
        then match java_script_find_qualified_function_call(call.name, module, allModules) with
            case Some _ -> true
            case None ->
                match java_script_find_qualified_module_export_call(call.name, module, allModules) with
                case Some _ -> true
                case None -> false
        else if java_script_callable_binding_type(java_script_variable_type(call.name, env, module, allModules))
        then true
        else if java_script_local_function_exists(call.name, module.functions)
        then true
        else java_script_imported_function_exists(call.name, module.imports, module, allModules)
    else false

/// Checks whether binding exists in the relevant declarations or imports.
private fun java_script_binding_exists(name: String, env: List[JavaScriptBinding]): bool =
    match java_script_lookup_binding(name, env) with
    case Some _ -> true
    case None -> false

/// Checks whether method call can be included in generated test gathering.
private fun java_script_method_call_gatherable(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_equal_to" | call.name == "is_true" | call.name == "is_false"
        | call.name == "is_zero" | call.name == "is_one" | call.name == "is_empty"
        | call.name == "is_greater_than" | call.name == "is_less_than"
        | call.name == "is_greater_or_equals_than" | call.name == "is_less_or_equals_than"
        | call.name == "is_between" | call.name == "has_size" | call.name == "contains" | call.name == "starts_with" | call.name == "does_not_start_with" | call.name == "succeeds" | call.name == "fails"
        | call.name == "failed" | call.name == "succeeded"
    then java_script_expression_gatherable(call.receiver, env, module, allModules)
        & java_script_expressions_gatherable(call.arguments, env, module, allModules)
    else if call.name == "__capy_call"
    then java_script_expression_gatherable(call.receiver, env, module, allModules)
        & java_script_expressions_gatherable(call.arguments, env, module, allModules)
    else
        let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
        let receiverBaseType = java_script_type_unqualified_name(receiverType)
        let emptyArguments = call.arguments.is_empty()
        let oneArgument = java_script_one_method_argument(call.arguments)
        let twoArguments = java_script_two_method_arguments(call.arguments)
        if (call.name == "map" | call.name == "flat_map" | call.name == "flatMap") & java_script_single_callable_argument(call.arguments) & receiverType == "Effect"
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_single_callable_argument_gatherable(call.arguments, env, module, allModules)
        else if call.name == "start" & emptyArguments & receiverType == "Effect"
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "join" & emptyArguments & receiverBaseType == "Async"
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if java_script_async_map_method_name(call.name) & java_script_single_callable_argument(call.arguments) & receiverBaseType == "Async"
        then java_script_async_pipe_gatherable(java_script_async_map_method_binary(call), env, module, allModules)
        else if java_script_runtime_data_method_call(call)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_single_callable_argument_gatherable(call.arguments, env, module, allModules)
        else if call.name == "to_string" & emptyArguments & java_script_char_to_string_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "get" & (oneArgument | twoArguments) & receiverType == "String"
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_string_parse_method_name(call.name) & emptyArguments & java_script_string_parse_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if java_script_string_method_arity(call.name, call.arguments) & java_script_string_method_receiver_type(call.name, receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_regex_method_arity(call) & java_script_regex_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_date_time_method_candidate(call.name, emptyArguments, oneArgument, twoArguments)
            & java_script_date_time_method_call(receiverBaseType, call.name, emptyArguments, oneArgument, twoArguments)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_size_method_call(call)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "name" & emptyArguments & java_script_enum_name_receiver_type(receiverType, module, allModules)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "is_empty" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "get" & (oneArgument | twoArguments) & java_script_collection_get_receiver_type(receiverBaseType) & java_script_collection_get_arity(receiverBaseType, call.arguments)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if (call.name == "contains" | call.name == "contains_key") & oneArgument & ((call.name == "contains" & java_script_collection_contains_receiver_type(receiverBaseType)) | (call.name == "contains_key" & receiverBaseType == "Dict"))
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_set_method_arity(call) & receiverBaseType == "Set"
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_seq_as_list_call(call)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if call.name == "first" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if java_script_collection_method_name(call.name) & java_script_single_callable_argument(call.arguments) & java_script_collection_pipe_receiver_type(receiverType)
        then java_script_collection_method_gatherable(call, env, module, allModules)
        else if java_script_collection_reduce_method_call_with_receiver_type(call, receiverType)
        then java_script_collection_reduce_method_gatherable(call, env, module, allModules)
        else if (call.name == "any" | call.name == "all") & java_script_single_callable_argument(call.arguments) & java_script_collection_receiver_type(receiverType)
        then java_script_collection_predicate_gatherable(call, env, module, allModules)
        else if java_script_primitive_conversion_method(call.name) & emptyArguments & java_script_primitive_conversion_receiver(call.name, receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
        else if (call.name == "reduce" | call.name == "reduce_left") & twoArguments & java_script_result_pipe_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if (call.name == "or_else" | call.name == "or") & oneArgument & java_script_result_fallback_receiver_type(receiverType)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else if java_script_oo_method_call_with_receiver_type(call, receiverType, module, allModules)
        then java_script_expression_gatherable(call.receiver, env, module, allModules)
            & java_script_expressions_gatherable(call.arguments, env, module, allModules)
        else match java_script_find_local_extension_method_with_receiver_type(receiverType, call, module) with
            case Some _ ->
                java_script_expression_gatherable(call.receiver, env, module, allModules)
                    & java_script_expressions_gatherable(call.arguments, env, module, allModules)
            case None ->
                match java_script_find_imported_method_function(receiverType, call.name, module.imports, module, allModules) with
                case Some _ ->
                    java_script_expression_gatherable(call.receiver, env, module, allModules)
                        & java_script_expressions_gatherable(call.arguments, env, module, allModules)
                case None -> false

/// Checks whether method metadata matches the result fallback method call rule.
private fun java_script_result_fallback_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "or_else" | call.name == "or"
    then
        if java_script_one_method_argument(call.arguments)
        then java_script_result_fallback_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether a type reference matches the result fallback receiver type rule.
private fun java_script_result_fallback_receiver_type(typeName: String): bool =
    typeName == java_script_unknown_type() | java_script_result_pipe_receiver_type(typeName)

/// Checks whether method metadata matches the runtime data method call rule.
private fun java_script_runtime_data_method_call(call: CompiledMethodCallExpression): bool =
    call.name == "map" | call.name == "filter" | call.name == "flat_map" | call.name == "flatMap"

/// Checks whether collection method can be included in generated test gathering.
private fun java_script_collection_method_gatherable(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_expression_gatherable(call.receiver, env, module, allModules)
        & java_script_single_callable_argument_gatherable(call.arguments, env, module, allModules)

/// Checks whether collection reduce method can be included in generated test gathering.
private fun java_script_collection_reduce_method_gatherable(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match call.arguments[0] with
    case None -> false
    case Some { initial } ->
        match call.arguments[1] with
        case None -> false
        case Some { reducer } ->
            if call.arguments[2:].is_empty()
            then if java_script_expression_gatherable(call.receiver, env, module, allModules)
                then if java_script_expression_gatherable(initial, env, module, allModules)
                    then java_script_callable_expression_gatherable(reducer, env, module, allModules)
                    else false
                else false
            else false

/// Checks whether collection predicate can be included in generated test gathering.
private fun java_script_collection_predicate_gatherable(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expression_gatherable(call.receiver, env, module, allModules)
    then java_script_single_callable_argument_gatherable(call.arguments, env, module, allModules)
    else false

/// Checks whether single callable argument can be included in generated test gathering.
private fun java_script_single_callable_argument_gatherable(arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        if arguments[1:].is_empty()
        then java_script_callable_expression_gatherable(argument, env, module, allModules)
        else false

/// Checks whether result reduce arguments can be included in generated test gathering.
private fun java_script_result_reduce_arguments_gatherable(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match arguments[0] with
    case None -> false
    case Some { successMapper } ->
        match arguments[1] with
        case None -> false
        case Some { errorMapper } ->
            if arguments[2:].is_empty()
            then if java_script_result_callable_expression_gatherable(receiver, successMapper, env, module, allModules)
                then java_script_callable_expression_gatherable(errorMapper, env, module, allModules)
                else false
            else false

/// Checks whether result callable expression can be included in generated test gathering.
private fun java_script_result_callable_expression_gatherable(receiver: CompiledExpression, mapper: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match mapper with
    case CompiledLambdaExpression lambda ->
        java_script_expression_gatherable(
            lambda.body,
            java_script_lambda_bindings_with_single_type(lambda.parameters, java_script_result_payload_type(receiver, env, module, allModules)) + env,
            module,
            allModules
        )
    case CompiledFunctionReferenceExpression reference -> java_script_function_reference_gatherable(reference, module, allModules)
    case _ -> false

/// Checks whether a function matches the local function unambiguous metadata.
private fun java_script_local_function_unambiguous(name: String, functions: List[CompiledFunction]): bool =
    java_script_local_function_count_at_most(name, functions, 2) == 1

/// Checks whether a non-skipped local function exists.
private fun java_script_local_function_exists(name: String, functions: List[CompiledFunction]): bool =
    java_script_local_function_count_at_most(name, functions, 1) > 0

/// Checks whether a non-skipped local function name has overloads.
private fun java_script_local_function_overloaded(name: String, functions: List[CompiledFunction]): bool =
    java_script_local_function_count_at_most(name, functions, 2) > 1

/// Counts local functions up to the requested cap.
private fun java_script_local_function_count_at_most(name: String, functions: List[CompiledFunction], limit: int): int =
    if limit <= 0
    then 0
    else match functions[0] with
    case None -> 0
    case Some { function } ->
        if !java_script_skip_function(function) & function.name == name
        then 1 + java_script_local_function_count_at_most(name, functions[1:], limit - 1)
        else java_script_local_function_count_at_most(name, functions[1:], limit)

/// Collects imported function exists visible to the current module.
private fun java_script_imported_function_exists(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match java_script_find_function_in_imports(name, imports, module, allModules) with
    case Some _ -> true
    case None -> false

/// Checks whether expressions can be included in generated test gathering.
private fun java_script_expressions_gatherable(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } ->
        if java_script_expression_gatherable(expression, env, module, allModules)
        then java_script_expressions_gatherable(expressions[1:], env, module, allModules)
        else false

/// Checks whether dict entries can be included in generated test gathering.
private fun java_script_dict_entries_gatherable(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match entries[0] with
    case None -> true
    case Some { entry } ->
        if java_script_expression_gatherable(entry.key, env, module, allModules)
        then if java_script_expression_gatherable(entry.value, env, module, allModules)
            then java_script_dict_entries_gatherable(entries[1:], env, module, allModules)
            else false
        else false

/// Checks whether data fields can be included in generated test gathering.
private fun java_script_data_fields_gatherable(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match fields[0] with
    case None -> true
    case Some { field } ->
        if java_script_expression_gatherable(field.value, env, module, allModules)
        then java_script_data_fields_gatherable(fields[1:], env, module, allModules)
        else false

/// Checks whether reduce expression can be included in generated test gathering.
private fun java_script_reduce_expression_gatherable(reduce: CompiledReduceExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if reduce.accumulatorName.is_empty()
    then false
    else if reduce.valueName.is_empty()
    then false
    else if java_script_expression_gatherable(reduce.receiver, env, module, allModules)
    then if java_script_expression_gatherable(reduce.initial, env, module, allModules)
        then java_script_expression_gatherable(reduce.body, java_script_reduce_bindings(reduce, env), module, allModules)
        else false
    else false

/// Checks whether match expression can be included in generated test gathering.
private fun java_script_match_expression_gatherable(matchExpression: CompiledMatchExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_expression_gatherable(matchExpression.value, env, module, allModules)
    then java_script_match_cases_gatherable(matchExpression.cases, env, module, allModules)
    else false

/// Checks whether match is supported by the current backend.
private fun java_script_match_supported(matchExpression: CompiledMatchExpression): bool =
    java_script_match_cases_supported(matchExpression.cases)

/// Checks whether match cases can be included in generated test gathering.
private fun java_script_match_cases_gatherable(cases: List[CompiledMatchCase], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        if java_script_match_case_gatherable(matchCase, env, module, allModules)
        then if cases[1:].is_empty()
            then true
            else java_script_match_cases_gatherable(cases[1:], env, module, allModules)
        else false

/// Checks whether match case can be included in generated test gathering.
private fun java_script_match_case_gatherable(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_match_case_supported(matchCase)
    then java_script_match_case_literal_guard_body_gatherable(matchCase, env, module, allModules)
    else false

private fun java_script_match_case_literal_guard_body_gatherable(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if matchCase.hasLiteral
    then if java_script_expression_gatherable(matchCase.literal, env, module, allModules)
        then java_script_match_case_guard_body_gatherable(matchCase, env, module, allModules)
        else false
    else java_script_match_case_guard_body_gatherable(matchCase, env, module, allModules)

private fun java_script_match_case_guard_body_gatherable(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let caseEnv = java_script_match_case_env(matchCase, env)
    if matchCase.hasGuard
    then if java_script_expression_gatherable(matchCase.guard, caseEnv, module, allModules)
        then java_script_expression_gatherable(matchCase.body, caseEnv, module, allModules)
        else false
    else java_script_expression_gatherable(matchCase.body, caseEnv, module, allModules)

/// Checks whether match cases is supported by the current backend.
private fun java_script_match_cases_supported(cases: List[CompiledMatchCase]): bool =
    match cases[0] with
    case None -> false
    case Some { matchCase } ->
        if java_script_match_case_supported(matchCase)
        then if cases[1:].is_empty()
            then true
            else java_script_match_cases_supported(cases[1:])
        else false

/// Checks whether match case is supported by the current backend.
private fun java_script_match_case_supported(matchCase: CompiledMatchCase): bool =
    matchCase.wildcard | !matchCase.typeName.is_empty() | matchCase.hasLiteral

/// Checks whether bindings can be included in generated test gathering.
private fun java_script_bindings_gatherable(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> true
    case Some { binding } ->
        let jsBinding = java_script_let_binding(binding, env, module, allModules)
        if binding.operator == "=" | binding.operator == "<-"
        then if java_script_expression_gatherable(binding.value, env, module, allModules)
            then java_script_bindings_gatherable(bindings[1:], [jsBinding] + env, module, allModules)
            else false
        else false

/// Checks whether test function can be included in generated test gathering.
private fun java_script_test_function_gatherable(function: CompiledFunction): bool =
    match function.body with
    case CompiledFunctionCallExpression call -> call.name == "test_file" & java_script_test_file_arguments_gatherable(call.arguments)
    case _ -> false

/// Checks whether test file arguments can be included in generated test gathering.
private fun java_script_test_file_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { fileName } ->
        match arguments[1] with
        case None -> false
        case Some { tests } ->
            arguments[2:].is_empty()
                & java_script_string_literal_expression(fileName)
                & java_script_test_case_list_gatherable(tests)

/// Checks whether test case list can be included in generated test gathering.
private fun java_script_test_case_list_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledListLiteral list -> java_script_test_case_expressions_gatherable(list.values)
    case _ -> false

/// Checks whether test case expressions can be included in generated test gathering.
private fun java_script_test_case_expressions_gatherable(expressions: List[CompiledExpression]): bool =
    match expressions[0] with
    case None -> true
    case Some { expression } -> java_script_test_case_expression_gatherable(expression) & java_script_test_case_expressions_gatherable(expressions[1:])

/// Checks whether test case expression can be included in generated test gathering.
private fun java_script_test_case_expression_gatherable(expression: CompiledExpression): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == "test" & java_script_test_call_arguments_gatherable(call.arguments)
    case CompiledMethodCallExpression call -> java_script_effect_test_case_expression_gatherable(call)
    case _ -> false

/// Checks whether effect test case expression can be included in generated test gathering.
private fun java_script_effect_test_case_expression_gatherable(call: CompiledMethodCallExpression): bool =
    call.name == "map" & java_script_effect_test_case_map_arguments_gatherable(call.arguments)

/// Checks whether effect test case map arguments can be included in generated test gathering.
private fun java_script_effect_test_case_map_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } ->
        arguments[1:].is_empty()
            & match argument with
                case CompiledLambdaExpression lambda -> java_script_effect_test_case_lambda_gatherable(lambda)
                case _ -> false

/// Checks whether effect test case lambda can be included in generated test gathering.
private fun java_script_effect_test_case_lambda_gatherable(lambda: CompiledLambdaExpression): bool =
    match lambda.body with
    case CompiledFunctionCallExpression call -> call.name == "test" & java_script_test_call_arguments_gatherable(call.arguments)
    case _ -> false

/// Checks whether test call arguments can be included in generated test gathering.
private fun java_script_test_call_arguments_gatherable(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { name } ->
        match arguments[1] with
        case None -> false
        case Some { body } ->
            arguments[2:].is_empty()
                & java_script_string_literal_expression(name)
                & java_script_zero_arg_lambda(body)

/// Checks whether an expression has the string literal expression shape.
private fun java_script_string_literal_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledStringLiteral _ -> true
    case _ -> false

/// Checks whether the current value satisfies the zero argument lambda rule for JavaScript processing.
private fun java_script_zero_arg_lambda(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression lambda -> lambda.parameters.is_empty()
    case _ -> false

/// Collects reflection type and enum metadata entries in one module pass.
private fun java_script_reflection_entries(modules: List[CompiledModule], allModules: List[CompiledModule]): JavaScriptReflectionEntries =
    match modules[0] with
    case None -> JavaScriptReflectionEntries { typeEntries: [], enumValueEntries: [] }
    case Some { module } ->
        let current = java_script_reflection_entries_in_module(java_script_schema_values("__capy_schema_type|", module.functions), module, allModules)
        let rest = java_script_reflection_entries(modules[1:], allModules)
        JavaScriptReflectionEntries {
            typeEntries: current.typeEntries + rest.typeEntries,
            enumValueEntries: current.enumValueEntries + rest.enumValueEntries
        }

/// Collects reflection entries for one module from its schema type list.
private fun java_script_reflection_entries_in_module(typeNames: List[String], module: CompiledModule, allModules: List[CompiledModule]): JavaScriptReflectionEntries =
    match typeNames[0] with
    case None -> JavaScriptReflectionEntries { typeEntries: [], enumValueEntries: [] }
    case Some { typeName } ->
        let enumValues = java_script_enum_values_in_functions(typeName, module.functions)
        let rest = java_script_reflection_entries_in_module(typeNames[1:], module, allModules)
        if !enumValues.is_empty()
        then JavaScriptReflectionEntries {
            typeEntries: rest.typeEntries,
            enumValueEntries: java_script_reflection_enum_value_entries_for_type(typeName, enumValues, module, allModules) + rest.enumValueEntries
        }
        else JavaScriptReflectionEntries {
            typeEntries: [java_script_code_object_entry(typeName, java_script_reflection_type_metadata_literal(typeName, module, allModules))] + rest.typeEntries,
            enumValueEntries: rest.enumValueEntries
        }

/// Formats reflection type metadata as a JavaScript literal.
private fun java_script_reflection_type_metadata_literal(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(typeName)),
        java_script_code_object_entry("pkg", java_script_reflection_data_package_metadata_literal(module)),
        java_script_code_object_entry("fields", java_script_code_list_literal(java_script_reflection_field_metadata_literals(
            typeName,
            java_script_reflection_data_type_fields(typeName, module, allModules),
            0,
            module,
            allModules
        ))),
        java_script_code_object_entry("annotations", java_script_reflection_annotations_literal(
            java_script_schema_values("__capy_schema_annotation|data|" + typeName + "|", module.functions),
            module,
            allModules
        )),
    ])

/// Formats reflection field metadata as a JavaScript literal.
private fun java_script_reflection_field_metadata_literals(dataName: String, fields: List[String], idx: int, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [java_script_reflection_field_metadata_literal(dataName, field, idx, module, allModules)]
            + java_script_reflection_field_metadata_literals(dataName, fields[1:], idx + 1, module, allModules)

/// Formats reflection field metadata as a JavaScript literal.
private fun java_script_reflection_field_metadata_literal(dataName: String, field: String, idx: int, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(java_script_schema_field_name(field))),
        java_script_code_object_entry("type", java_script_string_literal(java_script_schema_field_type_name(field))),
        java_script_code_object_entry("annotations", java_script_reflection_annotations_literal(
            java_script_schema_values("__capy_schema_annotation|field|" + dataName + "|" + idx + "|", module.functions),
            module,
            allModules
        )),
    ])

/// Computes the JavaScript type for reflection enum value entries for a.
private fun java_script_reflection_enum_value_entries_for_type(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match values[0] with
    case None -> []
    case Some { value } ->
        [java_script_code_object_entry(value, java_script_reflection_enum_value_metadata_literal(typeName, value, module, allModules))]
            + java_script_reflection_enum_value_entries_for_type(typeName, values[1:], module, allModules)

/// Formats reflection enum value metadata as a JavaScript literal.
private fun java_script_reflection_enum_value_metadata_literal(typeName: String, value: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(value)),
        java_script_code_object_entry("type", java_script_string_literal(typeName)),
        java_script_code_object_entry("pkg", java_script_reflection_data_package_metadata_literal(module)),
        java_script_code_object_entry("annotations", java_script_reflection_annotations_literal(
            java_script_schema_values("__capy_schema_annotation|enum|" + typeName + "|", module.functions),
            module,
            allModules
        )),
    ])

/// Collects reflection metadata entries for reflection data type fields.
private fun java_script_reflection_data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    java_script_merge_schema_fields(
        java_script_reflection_data_type_parent_fields(java_script_data_type_parent_types(name, module, allModules), module, allModules),
        java_script_data_type_direct_fields(name, module, allModules)
    )

/// Collects reflection metadata entries for reflection data type parent fields.
private fun java_script_reflection_data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = java_script_schema_type_name(parent)
        java_script_merge_schema_fields(
            java_script_reflection_data_type_fields(parentName, module, allModules),
            java_script_reflection_data_type_parent_fields(parents[1:], module, allModules)
        )

/// Formats reflection annotations as a JavaScript literal.
private fun java_script_reflection_annotations_literal(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_list_literal(java_script_reflection_annotation_metadata_literals(values, usageModule, allModules))

/// Formats reflection annotation metadata as a JavaScript literal.
private fun java_script_reflection_annotation_metadata_literals(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match values[0] with
    case None -> []
    case Some { value } ->
        [java_script_reflection_annotation_metadata_literal(value, usageModule, allModules)]
            + java_script_reflection_annotation_metadata_literals(values[1:], usageModule, allModules)

/// Formats reflection annotation metadata as a JavaScript literal.
private fun java_script_reflection_annotation_metadata_literal(value: String, usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    let name = java_script_annotation_schema_name(value)
    let explicitArguments = java_script_annotation_schema_arguments(java_script_annotation_schema_arguments_source(value))
    match java_script_find_annotation_binding(name, usageModule, allModules) with
    case Some { binding } ->
        java_script_code_object([
            java_script_code_object_entry("name", java_script_string_literal(binding.name)),
            java_script_code_object_entry("pkg", java_script_reflection_package_metadata_literal(binding.moduleName, binding.modulePath)),
            java_script_code_object_entry("arguments", java_script_reflection_annotation_arguments_literal(explicitArguments, binding.fields)),
        ])
    case None ->
        java_script_code_object([
            java_script_code_object_entry("name", java_script_string_literal(java_script_annotation_display_name(name))),
            java_script_code_object_entry("pkg", java_script_reflection_module_package_metadata_literal(usageModule)),
            java_script_code_object_entry("arguments", java_script_code_list_literal(java_script_explicit_annotation_argument_metadata_literals(explicitArguments))),
        ])

/// Formats object annotations as a JavaScript literal.
private fun java_script_object_annotations_literal(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_list_literal(java_script_object_annotation_literals(values, usageModule, allModules))

/// Formats object annotation as a JavaScript literal.
private fun java_script_object_annotation_literals(values: List[String], usageModule: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match values[0] with
    case None -> []
    case Some { value } ->
        [java_script_object_annotation_literal(value, usageModule, allModules)]
            + java_script_object_annotation_literals(values[1:], usageModule, allModules)

/// Formats object annotation as a JavaScript literal.
private fun java_script_object_annotation_literal(value: String, usageModule: CompiledModule, allModules: List[CompiledModule]): String =
    let name = java_script_annotation_schema_name(value)
    let explicitArguments = java_script_annotation_schema_arguments(java_script_annotation_schema_arguments_source(value))
    match java_script_find_annotation_binding(name, usageModule, allModules) with
    case Some { binding } ->
        java_script_data_info_literal("AnnotationInfo", [
            java_script_code_object_entry("name", java_script_string_literal(binding.name)),
            java_script_code_object_entry("pkg", java_script_package_info_data_literal(binding.moduleName, binding.modulePath)),
            java_script_code_object_entry("arguments", java_script_object_annotation_arguments_literal(explicitArguments, binding.fields)),
        ])
    case None ->
        java_script_data_info_literal("AnnotationInfo", [
            java_script_code_object_entry("name", java_script_string_literal(java_script_annotation_display_name(name))),
            java_script_code_object_entry("pkg", java_script_package_info_data_literal(usageModule.name, usageModule.path)),
            java_script_code_object_entry("arguments", java_script_code_list_literal(java_script_object_explicit_annotation_argument_literals(explicitArguments))),
        ])

/// Formats object annotation arguments as a JavaScript literal.
private fun java_script_object_annotation_arguments_literal(arguments: List[JavaScriptSchemaAnnotationArgument], fields: List[String]): String =
    java_script_code_list_literal(java_script_object_explicit_annotation_argument_literals(arguments) + java_script_object_default_annotation_argument_literals(fields, arguments))

/// Formats object explicit annotation argument as a JavaScript literal.
private fun java_script_object_explicit_annotation_argument_literals(arguments: List[JavaScriptSchemaAnnotationArgument]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { argument } ->
        [java_script_object_annotation_argument_literal(argument.name, java_script_object_annotation_value_literal(argument.kind, argument.value))]
            + java_script_object_explicit_annotation_argument_literals(arguments[1:])

/// Formats object default annotation argument as a JavaScript literal.
private fun java_script_object_default_annotation_argument_literals(fields: List[String], explicitArguments: List[JavaScriptSchemaAnnotationArgument]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        let fieldName = java_script_annotation_field_schema_name(field)
        if java_script_annotation_field_schema_has_default(field) & !java_script_schema_annotation_argument_exists(fieldName, explicitArguments)
        then [java_script_object_annotation_argument_literal(fieldName, java_script_object_annotation_field_schema_default_value_literal(field))]
            + java_script_object_default_annotation_argument_literals(fields[1:], explicitArguments)
        else java_script_object_default_annotation_argument_literals(fields[1:], explicitArguments)

/// Formats object annotation argument as a JavaScript literal.
private fun java_script_object_annotation_argument_literal(name: String, valueCode: String): String =
    java_script_data_info_literal("AnnotationArgumentInfo", [
        java_script_code_object_entry("name", java_script_string_literal(name)),
        java_script_code_object_entry("value", valueCode),
    ])

/// Formats package info data as a JavaScript literal.
private fun java_script_package_info_data_literal(name: String, path: String): String =
    java_script_data_info_literal("PackageInfo", [
        java_script_code_object_entry("name", java_script_string_literal(name)),
        java_script_code_object_entry("path", java_script_string_literal(path)),
    ])

/// Formats data info as a JavaScript literal.
private fun java_script_data_info_literal(name: String, entries: List[String]): String =
    "__capy_data(" + java_script_string_literal(name) + ", " + java_script_code_object(entries) + ")"

/// Formats object annotation value as a JavaScript literal.
private fun java_script_object_annotation_value_literal(kind: String, value: String): String =
    if kind == "string"
    then java_script_data_info_literal("AnnotationString", [java_script_code_object_entry("value", java_script_string_literal(value))])
    else if kind == "int"
    then java_script_data_info_literal("AnnotationInt", [java_script_code_object_entry("value", java_script_numeric_annotation_value(value, "0"))])
    else if kind == "long"
    then java_script_data_info_literal("AnnotationLong", [java_script_code_object_entry("value", "__capy_long(BigInt(" + java_script_string_literal(if value.is_empty() then "0" else value) + "))")])
    else if kind == "double"
    then java_script_data_info_literal("AnnotationDouble", [java_script_code_object_entry("value", java_script_numeric_annotation_value(value, "0"))])
    else if kind == "float"
    then java_script_data_info_literal("AnnotationFloat", [java_script_code_object_entry("value", java_script_numeric_annotation_value(value, "0"))])
    else if kind == "bool"
    then java_script_data_info_literal("AnnotationBool", [java_script_code_object_entry("value", java_script_bool_code(value == "true"))])
    else if kind == "type"
    then java_script_data_info_literal("AnnotationTypeName", [java_script_code_object_entry("value", java_script_string_literal(value))])
    else java_script_data_info_literal("AnnotationNothing", [])

/// Computes value metadata for numeric annotation value.
private fun java_script_numeric_annotation_value(value: String, fallback: String): String =
    if value.is_empty() then fallback else value

/// Formats object annotation field schema default value as a JavaScript literal.
private fun java_script_object_annotation_field_schema_default_value_literal(value: String): String =
    let third = java_script_annotation_field_schema_third_separator(value)
    if third < 0
    then java_script_object_annotation_value_literal("nothing", "")
    else
        let payload = value[third + 1, value.size().value]
        let colon = java_script_first_index_of(payload, ":", 0)
        if colon < 0
        then java_script_object_annotation_value_literal("nothing", "")
        else java_script_object_annotation_value_literal(payload[0, colon], payload[colon + 1, payload.size().value])

/// Computes the JavaScript name for annotation display.
private fun java_script_annotation_display_name(name: String): String =
    if java_script_qualified_call_name(name) then java_script_qualified_call_member(name) else name

/// Formats reflection annotation arguments as a JavaScript literal.
private fun java_script_reflection_annotation_arguments_literal(arguments: List[JavaScriptSchemaAnnotationArgument], fields: List[String]): String =
    java_script_code_list_literal(java_script_explicit_annotation_argument_metadata_literals(arguments) + java_script_default_annotation_argument_metadata_literals(fields, arguments))

/// Formats explicit annotation argument metadata as a JavaScript literal.
private fun java_script_explicit_annotation_argument_metadata_literals(arguments: List[JavaScriptSchemaAnnotationArgument]): List[String] =
    match arguments[0] with
    case None -> []
    case Some { argument } ->
        [java_script_annotation_argument_metadata_literal(argument.name, java_script_annotation_value_metadata_literal(argument.kind, argument.value))]
            + java_script_explicit_annotation_argument_metadata_literals(arguments[1:])

/// Formats default annotation argument metadata as a JavaScript literal.
private fun java_script_default_annotation_argument_metadata_literals(fields: List[String], explicitArguments: List[JavaScriptSchemaAnnotationArgument]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        let fieldName = java_script_annotation_field_schema_name(field)
        if java_script_annotation_field_schema_has_default(field) & !java_script_schema_annotation_argument_exists(fieldName, explicitArguments)
        then [java_script_annotation_argument_metadata_literal(fieldName, java_script_annotation_field_schema_default_value_metadata_literal(field))]
            + java_script_default_annotation_argument_metadata_literals(fields[1:], explicitArguments)
        else java_script_default_annotation_argument_metadata_literals(fields[1:], explicitArguments)

/// Checks whether schema annotation argument exists in the relevant declarations or imports.
private fun java_script_schema_annotation_argument_exists(name: String, arguments: List[JavaScriptSchemaAnnotationArgument]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } -> argument.name == name | java_script_schema_annotation_argument_exists(name, arguments[1:])

/// Formats annotation argument metadata as a JavaScript literal.
private fun java_script_annotation_argument_metadata_literal(name: String, valueCode: String): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(name)),
        java_script_code_object_entry("value", valueCode),
    ])

/// Formats annotation value metadata as a JavaScript literal.
private fun java_script_annotation_value_metadata_literal(kind: String, value: String): String =
    java_script_code_object([
        java_script_code_object_entry("kind", java_script_string_literal(kind)),
        java_script_code_object_entry("value", java_script_string_literal(value)),
    ])

/// Computes the JavaScript name for annotation schema.
private fun java_script_annotation_schema_name(value: String): String =
    let separator = java_script_first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

/// Encodes schema metadata text for annotation schema arguments source.
private fun java_script_annotation_schema_arguments_source(value: String): String =
    let separator = java_script_first_index_of(value, "|", 0)
    if separator < 0
    then ""
    else value[separator + 1, value.size().value]

/// Formats annotation schema arguments for JavaScript emission.
private fun java_script_annotation_schema_arguments(value: String): List[JavaScriptSchemaAnnotationArgument] =
    if value.is_empty()
    then []
    else
        let separator = java_script_first_index_of(value, ";", 0)
        if separator < 0
        then [java_script_annotation_schema_argument(value)]
        else [java_script_annotation_schema_argument(value[0, separator])] + java_script_annotation_schema_arguments(value[separator + 1, value.size().value])

/// Formats one annotation schema argument for JavaScript emission.
private fun java_script_annotation_schema_argument(value: String): JavaScriptSchemaAnnotationArgument =
    let equals = java_script_first_index_of(value, "=", 0)
    if equals < 0
    then JavaScriptSchemaAnnotationArgument { name: value, kind: "nothing", value: "" }
    else
        let payload = value[equals + 1, value.size().value]
        let colon = java_script_first_index_of(payload, ":", 0)
        if colon < 0
        then JavaScriptSchemaAnnotationArgument { name: value[0, equals], kind: "nothing", value: "" }
        else JavaScriptSchemaAnnotationArgument {
            name: value[0, equals],
            kind: payload[0, colon],
            value: payload[colon + 1, payload.size().value]
        }

/// Computes the JavaScript name for annotation field schema.
private fun java_script_annotation_field_schema_name(value: String): String =
    java_script_schema_field_name(value)

/// Checks whether annotation metadata matches the annotation field schema has default rule.
private fun java_script_annotation_field_schema_has_default(value: String): bool =
    let second = java_script_annotation_field_schema_second_separator(value)
    let third = java_script_annotation_field_schema_third_separator(value)
    if second < 0 | third < 0
    then false
    else value[second + 1, third] == "true"

/// Formats annotation field schema default value metadata as a JavaScript literal.
private fun java_script_annotation_field_schema_default_value_metadata_literal(value: String): String =
    let third = java_script_annotation_field_schema_third_separator(value)
    if third < 0
    then java_script_annotation_value_metadata_literal("nothing", "")
    else
        let payload = value[third + 1, value.size().value]
        let colon = java_script_first_index_of(payload, ":", 0)
        if colon < 0
        then java_script_annotation_value_metadata_literal("nothing", "")
        else java_script_annotation_value_metadata_literal(payload[0, colon], payload[colon + 1, payload.size().value])

/// Computes a numeric value for annotation field schema second separator.
private fun java_script_annotation_field_schema_second_separator(value: String): int =
    let first = java_script_first_index_of(value, "|", 0)
    if first < 0 then -1 else java_script_first_index_of(value, "|", first + 1)

/// Computes a numeric value for annotation field schema third separator.
private fun java_script_annotation_field_schema_third_separator(value: String): int =
    let second = java_script_annotation_field_schema_second_separator(value)
    if second < 0 then -1 else java_script_first_index_of(value, "|", second + 1)

/// Finds an annotation binding in scope, imports, or compiled modules.
private fun java_script_find_annotation_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    if java_script_qualified_call_name(name)
    then java_script_find_qualified_annotation_binding(name, module, allModules)
    else
        match module.annotations.get(name) with
        case Some { declaration } -> /capy/lang/Option.Some { JavaScriptAnnotationBinding {
            name: declaration.name,
            moduleName: module.name,
            modulePath: module.path,
            fields: declaration.fields
        } }
        case None ->
            match java_script_find_annotation_binding_in_imports(name, module.imports, module, allModules) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> java_script_find_annotation_binding_in_modules(name, allModules)

/// Finds a qualified annotation binding in scope, imports, or compiled modules.
private fun java_script_find_qualified_annotation_binding(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    let idx = java_script_last_dot_index(name)
    let className = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    if java_script_stdlib_annotations_class(className)
    then java_script_stdlib_annotation_binding(member)
    else match java_script_find_qualified_annotation_binding_in_imports(className, member, module.imports, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding }
    case None -> java_script_find_qualified_annotation_binding_in_modules(className, member, module, allModules)

/// Finds a qualified annotation binding in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_annotation_binding_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & java_script_qualified_import_matches(qualifier, declaration, module)
        then java_script_find_qualified_annotation_binding_in_import(qualifier, member, declaration, imports[1:], module, allModules)
        else java_script_find_qualified_annotation_binding_in_imports(qualifier, member, imports[1:], module, allModules)

/// Finds a qualified annotation binding in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_annotation_binding_in_import(qualifier: String, member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    if java_script_stdlib_annotations_module_path(declaration.modulePath)
    then {
        match java_script_stdlib_annotation_binding(member) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> java_script_find_qualified_annotation_binding_in_imports(qualifier, member, rest, module, allModules)
    }
    else {
        match java_script_find_imported_module(declaration, module, allModules) with
        case Some { importedModule } -> {
            match java_script_annotation_binding_in_module(member, importedModule) with
            case Some { binding } -> /capy/lang/Option.Some { binding }
            case None -> java_script_find_qualified_annotation_binding_in_imports(qualifier, member, rest, module, allModules)
        }
        case None -> java_script_find_qualified_annotation_binding_in_imports(qualifier, member, rest, module, allModules)
    }

/// Finds a qualified annotation binding in a modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_annotation_binding_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } -> java_script_annotation_binding_in_module(member, targetModule)
    case None -> /capy/lang/Option.None {}

/// Finds an annotation binding in imports in scope, imports, or compiled modules.
private fun java_script_find_annotation_binding_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        match java_script_stdlib_annotation_binding_in_import(name, declaration) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None ->
            if java_script_annotation_import_matches(name, declaration)
            then java_script_find_annotation_binding_in_import(name, imports[1:], module, allModules, declaration)
            else java_script_find_annotation_binding_in_imports(name, imports[1:], module, allModules)

/// Finds an annotation binding in import in scope, imports, or compiled modules.
private fun java_script_find_annotation_binding_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case None -> java_script_find_annotation_binding_in_imports(name, rest, module, allModules)
    case Some { importedModule } ->
        match java_script_annotation_binding_in_module(name, importedModule) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> java_script_find_annotation_binding_in_imports(name, rest, module, allModules)

/// Finds an annotation binding in a modules in scope, imports, or compiled modules.
private fun java_script_find_annotation_binding_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match java_script_annotation_binding_in_module(name, module) with
        case Some { binding } -> /capy/lang/Option.Some { binding }
        case None -> java_script_find_annotation_binding_in_modules(name, modules[1:])

/// Resolves binding metadata for annotation binding in a module.
private fun java_script_annotation_binding_in_module(name: String, module: CompiledModule): /capy/lang/Option[JavaScriptAnnotationBinding] =
    match module.annotations.get(name) with
    case Some { declaration } -> /capy/lang/Option.Some { JavaScriptAnnotationBinding {
        name: declaration.name,
        moduleName: module.name,
        modulePath: module.path,
        fields: declaration.fields
    } }
    case None -> /capy/lang/Option.None {}

/// Checks whether annotation import matches the requested declaration, type, or name.
private fun java_script_annotation_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if java_script_stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else java_script_import_includes_name(name, declaration)

/// Emits one JavaScript import statement for standard-library annotation binding in.
private fun java_script_stdlib_annotation_binding_in_import(name: String, declaration: CompiledImportDeclaration): /capy/lang/Option[JavaScriptAnnotationBinding] =
    if !declaration.qualified
        & java_script_stdlib_annotations_module_path(declaration.modulePath)
        & java_script_import_includes_name(name, declaration)
    then java_script_stdlib_annotation_binding(name)
    else /capy/lang/Option.None {}

/// Creates one JavaScript name/type binding for standard-library annotation.
private fun java_script_stdlib_annotation_binding(name: String): /capy/lang/Option[JavaScriptAnnotationBinding] =
    if name == "Deprecated"
    then /capy/lang/Option.Some { JavaScriptAnnotationBinding {
        name: "Deprecated",
        moduleName: "Annotations",
        modulePath: "capy/meta_prog",
        fields: ["message|String|false|nothing:", "since|String|true|string:"]
    }}
    else /capy/lang/Option.None {}

/// Checks whether annotation metadata matches the standard-library annotations class rule.
private fun java_script_stdlib_annotations_class(className: String): bool =
    className == "capy.meta_prog.Annotations" | className == "capy/meta_prog/Annotations"

/// Checks whether annotation metadata matches the standard-library annotations module path rule.
private fun java_script_stdlib_annotations_module_path(path: String): bool =
    path == "/capy/meta_prog/Annotations" | path == "capy/meta_prog/Annotations"

/// Formats reflection module package metadata as a JavaScript literal.
private fun java_script_reflection_module_package_metadata_literal(module: CompiledModule): String =
    java_script_reflection_package_metadata_literal(module.name, module.path)

/// Formats reflection package metadata as a JavaScript literal.
private fun java_script_reflection_package_metadata_literal(moduleName: String, modulePath: String): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(moduleName)),
        java_script_code_object_entry("path", java_script_string_literal(modulePath)),
    ])

/// Formats reflection data package metadata as a JavaScript literal.
private fun java_script_reflection_data_package_metadata_literal(module: CompiledModule): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(module.name)),
        java_script_code_object_entry("path", java_script_string_literal(java_script_reflection_module_path(module))),
    ])

/// Computes the output or module path for reflection module.
private fun java_script_reflection_module_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

/// Emits JavaScript source code for code object.
private fun java_script_code_object(entries: List[String]): String =
    "{" + java_script_code_list(entries) + "}"

/// Emits JavaScript source code for code object entry.
private fun java_script_code_object_entry(name: String, valueCode: String): String =
    java_script_string_literal(name) + ": " + valueCode

/// Formats code list as a JavaScript literal.
private fun java_script_code_list_literal(values: List[String]): String =
    "[" + java_script_code_list(values) + "]"

/// Emits JavaScript source code for code list.
private fun java_script_code_list(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some { value } -> value + java_script_code_list_tail(values[1:])

/// Emits JavaScript source code for code list tail.
private fun java_script_code_list_tail(values: List[String]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + java_script_code_list(values)

/// Collects data type fields for JavaScript processing.
private fun java_script_data_type_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    java_script_merge_schema_fields(
        java_script_data_type_direct_fields(name, module, allModules),
        java_script_data_type_parent_fields(java_script_data_type_parent_types(name, module, allModules), module, allModules)
    )

/// Collects data type direct fields for JavaScript processing.
private fun java_script_data_type_direct_fields(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if java_script_stdlib_reflection_type(name)
    then java_script_stdlib_reflection_type_fields(name)
    else java_script_data_type_schema_values(name, "__capy_schema_field|", module, allModules)

/// Collects data type parent types for JavaScript processing.
private fun java_script_data_type_parent_types(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if java_script_stdlib_reflection_type(name)
    then java_script_stdlib_reflection_type_parents(name)
    else java_script_data_type_schema_values(name, "__capy_schema_parent|", module, allModules)

/// Checks whether a type reference matches the standard-library reflection type rule.
private fun java_script_stdlib_reflection_type(name: String): bool =
    name == "PackageInfo"
        | name == "AnyInfo"
        | name == "CFunInfo"
        | name == "CooInfo"
        | name == "AnnotationValue"
        | name == "AnnotationInfo"
        | name == "AnnotationArgumentInfo"
        | name == "DataValueInfo"
        | name == "FieldValueInfo"
        | name == "DataInfo"
        | name == "FunctionTypeInfo"
        | name == "FieldInfo"
        | name == "ListInfo"
        | name == "SetInfo"
        | name == "DictInfo"
        | name == "TupleInfo"
        | name == "InterfaceInfo"
        | name == "ObjectInfo"
        | name == "TraitInfo"
        | name == "MethodInfo"
        | name == "AnnotationString"
        | name == "AnnotationInt"
        | name == "AnnotationLong"
        | name == "AnnotationDouble"
        | name == "AnnotationFloat"
        | name == "AnnotationBool"
        | name == "AnnotationTypeName"
        | name == "AnnotationNothing"

/// Collects reflection metadata entries for standard-library reflection type parents.
private fun java_script_stdlib_reflection_type_parents(name: String): List[String] =
    if name == "CFunInfo" | name == "CooInfo"
    then ["AnyInfo"]
    else if name == "DataInfo" | name == "ListInfo" | name == "SetInfo" | name == "DictInfo" | name == "TupleInfo" | name == "FunctionTypeInfo"
    then ["CFunInfo"]
    else if name == "InterfaceInfo" | name == "ObjectInfo" | name == "TraitInfo" | name == "MethodInfo"
    then ["CooInfo"]
    else if name == "AnnotationString" | name == "AnnotationInt" | name == "AnnotationLong" | name == "AnnotationDouble" | name == "AnnotationFloat" | name == "AnnotationBool" | name == "AnnotationTypeName" | name == "AnnotationNothing"
    then ["AnnotationValue"]
    else []

/// Collects reflection metadata entries for standard-library reflection type fields.
private fun java_script_stdlib_reflection_type_fields(name: String): List[String] =
    if name == "PackageInfo"
    then ["name|String", "path|String"]
    else if name == "AnyInfo"
    then ["name|String", "pkg|PackageInfo"]
    else if name == "AnnotationInfo"
    then ["name|String", "pkg|PackageInfo", "arguments|List[AnnotationArgumentInfo]"]
    else if name == "AnnotationArgumentInfo"
    then ["name|String", "value|AnnotationValue"]
    else if name == "DataValueInfo"
    then ["name|String", "pkg|PackageInfo", "fields|List[FieldValueInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "FieldValueInfo"
    then ["name|String", "type|AnyInfo", "value|any", "annotations|List[AnnotationInfo]"]
    else if name == "DataInfo"
    then ["name|String", "pkg|PackageInfo", "annotations|List[AnnotationInfo]"]
    else if name == "FunctionTypeInfo"
    then ["name|String", "pkg|PackageInfo", "params|List[AnyInfo]", "return_type|AnyInfo"]
    else if name == "FieldInfo"
    then ["name|String", "type|AnyInfo", "annotations|List[AnnotationInfo]"]
    else if name == "ListInfo" | name == "SetInfo"
    then ["name|String", "pkg|PackageInfo", "element_type|AnyInfo"]
    else if name == "DictInfo"
    then ["name|String", "pkg|PackageInfo", "value_type|AnyInfo"]
    else if name == "TupleInfo"
    then ["name|String", "pkg|PackageInfo", "elements|List[AnyInfo]"]
    else if name == "InterfaceInfo" | name == "TraitInfo"
    then ["name|String", "pkg|PackageInfo", "methods|List[MethodInfo]", "parents|Set[AnyInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "ObjectInfo"
    then ["name|String", "pkg|PackageInfo", "open|bool", "fields|List[FieldInfo]", "methods|List[MethodInfo]", "parents|Set[AnyInfo]", "annotations|List[AnnotationInfo]"]
    else if name == "MethodInfo"
    then ["name|String", "pkg|PackageInfo", "params|List[FieldInfo]", "return_type|AnyInfo", "annotations|List[AnnotationInfo]"]
    else if name == "AnnotationString" | name == "AnnotationTypeName"
    then ["value|String"]
    else if name == "AnnotationInt"
    then ["value|int"]
    else if name == "AnnotationLong"
    then ["value|long"]
    else if name == "AnnotationDouble"
    then ["value|double"]
    else if name == "AnnotationFloat"
    then ["value|float"]
    else if name == "AnnotationBool"
    then ["value|bool"]
    else []

/// Collects data type parent fields for JavaScript processing.
private fun java_script_data_type_parent_fields(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        let parentName = java_script_schema_type_name(parent)
        java_script_merge_schema_fields(
            java_script_data_type_fields(parentName, module, allModules),
            java_script_data_type_parent_fields(parents[1:], module, allModules)
        )

/// Collects encoded schema constants for data type.
private fun java_script_data_type_schema_values(name: String, prefix: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localValues = java_script_schema_values_for_type(name, prefix, module.functions)
    if localValues.typeExists
    then localValues.values
    else match java_script_data_type_schema_values_in_imports(name, prefix, module.imports, module, allModules) with
        case Some { value } -> value
        case None -> java_script_data_type_schema_values_in_modules(name, prefix, allModules)

/// Creates JavaScript generated-module entries for data type schema values in a.
private fun java_script_data_type_schema_values_in_modules(name: String, prefix: String, modules: List[CompiledModule]): List[String] =
    match modules[0] with
    case None -> []
    case Some { module } ->
        let moduleValues = java_script_schema_values_for_type(name, prefix, module.functions)
        if moduleValues.typeExists
        then moduleValues.values
        else java_script_data_type_schema_values_in_modules(name, prefix, modules[1:])

/// Emits JavaScript import statements for data type schema values in.
private fun java_script_data_type_schema_values_in_imports(name: String, prefix: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if java_script_data_import_matches(name, declaration)
        then java_script_data_type_schema_values_in_import(name, prefix, imports[1:], module, allModules, declaration)
        else java_script_data_type_schema_values_in_imports(name, prefix, imports[1:], module, allModules)

/// Emits one JavaScript import statement for data type schema values in.
private fun java_script_data_type_schema_values_in_import(name: String, prefix: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[List[String]] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        let importedValues = java_script_schema_values_for_type(name, prefix, importedModule.functions)
        if importedValues.typeExists
        then /capy/lang/Option.Some { importedValues.values }
        else java_script_data_type_schema_values_in_imports(name, prefix, rest, module, allModules)
    case None -> java_script_data_type_schema_values_in_imports(name, prefix, rest, module, allModules)

/// Checks whether data import matches the requested declaration, type, or name.
private fun java_script_data_import_matches(name: String, declaration: CompiledImportDeclaration): bool =
    if java_script_stdlib_import(declaration.modulePath)
    then false
    else if declaration.qualified
    then false
    else java_script_import_includes_name(name, declaration)

/// Computes the JavaScript type for primitive backed backing.
private fun java_script_primitive_backed_backing_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if java_script_qualified_call_name(name)
    then java_script_primitive_backed_backing_type_in_qualified_name(name, module, allModules)
    else match java_script_primitive_backed_backing_type_in_functions(name, module.functions) with
    case Some { backingType } -> /capy/lang/Option.Some { backingType }
    case None ->
        match java_script_primitive_backed_backing_type_in_imports(name, module.imports, module, allModules) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> java_script_primitive_backed_backing_type_in_modules(name, allModules)

/// Computes the JavaScript name for primitive backed backing type in qualified.
private fun java_script_primitive_backed_backing_type_in_qualified_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(java_script_qualified_call_qualifier(name), module), allModules) with
    case Some { targetModule } -> java_script_primitive_backed_backing_type_in_functions(java_script_qualified_call_member(name), targetModule.functions)
    case None -> /capy/lang/Option.None {}

/// Resolves type metadata for primitive backed backing type in functions.
private fun java_script_primitive_backed_backing_type_in_functions(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match java_script_schema_value_named("__capy_schema_primitive|" + name, functions) with
    case Some { value } -> /capy/lang/Option.Some { java_script_schema_type_name(value) }
    case None -> /capy/lang/Option.None {}

/// Emits JavaScript import statements for primitive backed backing type in.
private fun java_script_primitive_backed_backing_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if java_script_data_import_matches(name, declaration)
        then java_script_primitive_backed_backing_type_in_import(name, imports[1:], module, allModules, declaration)
        else java_script_primitive_backed_backing_type_in_imports(name, imports[1:], module, allModules)

/// Emits one JavaScript import statement for primitive backed backing type in.
private fun java_script_primitive_backed_backing_type_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match java_script_primitive_backed_backing_type_in_functions(name, importedModule.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> java_script_primitive_backed_backing_type_in_imports(name, rest, module, allModules)
    }
    case None -> java_script_primitive_backed_backing_type_in_imports(name, rest, module, allModules)

/// Creates JavaScript generated-module entries for primitive backed backing type in a.
private fun java_script_primitive_backed_backing_type_in_modules(name: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match java_script_primitive_backed_backing_type_in_functions(name, module.functions) with
        case Some { backingType } -> /capy/lang/Option.Some { backingType }
        case None -> java_script_primitive_backed_backing_type_in_modules(name, modules[1:])

/// Merges schema fields while preserving compiler-visible metadata.
private fun java_script_merge_schema_fields(first: List[String], second: List[String]): List[String] =
    first + java_script_schema_fields_not_named(second, java_script_schema_field_name_index(first))

/// Collects schema metadata entries for schema fields not named.
private fun java_script_schema_fields_not_named(fields: List[String], existingNames: Dict[bool]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        let name = java_script_schema_field_name(field)
        if java_script_schema_field_name_exists(name, existingNames)
        then java_script_schema_fields_not_named(fields[1:], existingNames)
        else [field] + java_script_schema_fields_not_named(fields[1:], existingNames + (name, true))

/// Indexes schema field names already emitted by earlier fields.
private fun java_script_schema_field_name_index(fields: List[String]): Dict[bool] =
    java_script_schema_field_name_index_acc(fields, {:})

/// Accumulates schema field names already emitted by earlier fields.
private fun java_script_schema_field_name_index_acc(fields: List[String], names: Dict[bool]): Dict[bool] =
    match fields[0] with
    case None -> names
    case Some { field } -> java_script_schema_field_name_index_acc(fields[1:], names + (java_script_schema_field_name(field), true))

/// Checks whether schema field name exists in the relevant declarations or imports.
private fun java_script_schema_field_name_exists(name: String, fields: Dict[bool]): bool =
    match fields.get(name) with
    case Some _ -> true
    case None -> false

/// Checks whether schema type exists in the relevant declarations or imports.
private fun java_script_schema_type_exists(name: String, functions: List[CompiledFunction]): bool =
    java_script_schema_type_exists_named("__capy_schema_type|" + name, functions)

/// Checks whether schema type exists using a precomputed schema key.
private fun java_script_schema_type_exists_named(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_compiled_schema(function)
        then if function.name == name
            then true
            else java_script_schema_type_exists_named(name, functions[1:])
        else java_script_schema_type_exists_named(name, functions[1:])

/// Collects schema values while also checking whether the owning data type exists.
private fun java_script_schema_values_for_type(name: String, valuePrefix: String, functions: List[CompiledFunction]): JavaScriptSchemaValues =
    java_script_schema_values_for_type_named("__capy_schema_type|" + name, valuePrefix + name + "|", functions)

private fun java_script_schema_values_for_type_named(typeSchemaName: String, valuePrefix: String, functions: List[CompiledFunction]): JavaScriptSchemaValues =
    match functions[0] with
    case None -> JavaScriptSchemaValues { typeExists: false, values: [] }
    case Some { function } ->
        let rest = java_script_schema_values_for_type_named(typeSchemaName, valuePrefix, functions[1:])
        if java_script_compiled_schema(function)
        then JavaScriptSchemaValues {
            typeExists: if rest.typeExists then true else function.name == typeSchemaName,
            values: if java_script_string_has_prefix(function.name, valuePrefix) then [java_script_schema_value(function)] + rest.values else rest.values
        }
        else rest

/// Computes value metadata for schema values.
private fun java_script_schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    match functions[0] with
    case None -> []
    case Some { function } ->
        if java_script_compiled_schema(function)
        then if java_script_string_has_prefix(function.name, prefix)
            then [java_script_schema_value(function)] + java_script_schema_values(prefix, functions[1:])
            else java_script_schema_values(prefix, functions[1:])
        else java_script_schema_values(prefix, functions[1:])

/// Checks whether any schema helper has the requested key prefix without materializing values.
private fun java_script_schema_value_with_prefix_exists(prefix: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_compiled_schema(function)
        then if java_script_string_has_prefix(function.name, prefix)
            then true
            else java_script_schema_value_with_prefix_exists(prefix, functions[1:])
        else java_script_schema_value_with_prefix_exists(prefix, functions[1:])

/// Looks up optional metadata for schema value named.
private fun java_script_schema_value_named(name: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if java_script_compiled_schema(function)
        then if function.name == name
            then /capy/lang/Option.Some { java_script_schema_value(function) }
            else java_script_schema_value_named(name, functions[1:])
        else java_script_schema_value_named(name, functions[1:])

/// Computes value metadata for schema value.
private fun java_script_schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

/// Computes the JavaScript name for schema field.
private fun java_script_schema_field_name(value: String): String =
    let separator = java_script_first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

/// Computes the JavaScript type name for schema field.
private fun java_script_schema_field_type_name(value: String): String =
    let separator = java_script_first_index_of(value, "|", 0)
    if separator < 0
    then java_script_unknown_type()
    else java_script_schema_type_name(value[separator + 1, value.size().value])

/// Computes the JavaScript type for object field schema.
private fun java_script_object_field_schema_type(value: String): String =
    let second = java_script_object_field_schema_second_separator(value)
    let third = java_script_object_field_schema_third_separator(value)
    if second < 0
    then java_script_unknown_type()
    else if third < 0
    then java_script_schema_type_name(value[second + 1, value.size().value])
    else java_script_schema_type_name(value[second + 1, third])

/// Decodes object field schema separators once for generated object metadata.
private fun java_script_object_field_schema_metadata(value: String): JavaScriptObjectFieldSchema =
    let first = java_script_first_index_of(value, "|", 0)
    let second = if first < 0 then -1 else java_script_first_index_of(value, "|", first + 1)
    let third = if second < 0 then -1 else java_script_first_index_of(value, "|", second + 1)
    JavaScriptObjectFieldSchema {
        name: if first < 0 then value else value[0, first],
        typeName: if second < 0
            then java_script_unknown_type()
            else if third < 0
            then java_script_schema_type_name(value[second + 1, value.size().value])
            else java_script_schema_type_name(value[second + 1, third])
    }

/// Computes a numeric value for object field schema second separator.
private fun java_script_object_field_schema_second_separator(value: String): int =
    let first = java_script_first_index_of(value, "|", 0)
    if first < 0 then -1 else java_script_first_index_of(value, "|", first + 1)

/// Computes a numeric value for object field schema third separator.
private fun java_script_object_field_schema_third_separator(value: String): int =
    let second = java_script_object_field_schema_second_separator(value)
    if second < 0 then -1 else java_script_first_index_of(value, "|", second + 1)

/// Computes the JavaScript type name for schema.
private fun java_script_schema_type_name(value: String): String =
    let trimmed = value.trim()
    let bracket = java_script_first_index_of(trimmed, "[", 0)
    if bracket < 0
    then trimmed
    else trimmed[0, bracket]

/// Creates one JavaScript name/type binding for lookup.
private fun java_script_lookup_binding(name: String, env: List[JavaScriptBinding]): /capy/lang/Option[JavaScriptBinding] =
    match env[0] with
    case None -> /capy/lang/Option.None {}
    case Some { binding } ->
        if binding.name == name
        then /capy/lang/Option.Some { binding }
        else java_script_lookup_binding(name, env[1:])

/// Computes the JavaScript type for unknown.
private fun java_script_unknown_type(): String = "any"

/// Computes the JavaScript name for function.
private fun java_script_function_name(function: CompiledFunction): String =
    if function.name == "tests"
    then "tests"
    else if function.name == "main"
    then "main"
    else java_script_identifier(function.name) + "__" + function.location.line + "_" + function.location.column

/// Computes the JavaScript name for method.
private fun java_script_method_name(name: String): String =
    java_script_identifier(name)

/// Emits JavaScript import source for import alias.
private fun java_script_import_alias(declaration: CompiledImportDeclaration, module: CompiledModule): String =
    "__capy_import_" + java_script_identifier(java_script_import_module_path(declaration.modulePath, module))

/// Computes the output or module path for import module.
private fun java_script_import_module_path(modulePath: String, module: CompiledModule): String =
    if java_script_string_has_prefix(modulePath, "/")
    then java_script_normalize_import_module_path(modulePath)
    else if modulePath ? "/"
    then java_script_normalize_import_module_path(modulePath)
    else if module.path.is_empty()
    then modulePath
    else module.path + "/" + modulePath

/// Computes the output or module path for module.
private fun java_script_module_path(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else module.path + "/" + module.name

/// Computes the JavaScript name for type unqualified.
private fun java_script_type_unqualified_name(typeName: String): String =
    let rawName = java_script_schema_type_name(typeName)
    let idx = java_script_last_type_separator(rawName)
    if idx < 0 then rawName else rawName[idx + 1, rawName.size().value]

/// Computes the last separator for a qualified or path-qualified type name.
private fun java_script_last_type_separator(name: String): int =
    java_script_last_type_separator_from(name, 0, -1)

/// Computes the last separator for a qualified or path-qualified type name from an offset.
private fun java_script_last_type_separator_from(name: String, idx: int, found: int): int =
    if idx >= name.size().value
    then found
    else match name[idx] with
        case None -> found
        case Some { char } ->
            java_script_last_type_separator_from(name, idx + 1, if char == "." | char == "/" then idx else found)

/// Checks whether a call has the qualified call name shape.
private fun java_script_qualified_call_name(name: String): bool =
    let idx = java_script_last_dot_index(name)
    idx > 0 & idx < name.size().value - 1

/// Emits JavaScript expression text for qualified call qualifier.
private fun java_script_qualified_call_qualifier(name: String): String =
    java_script_qualified_call_qualifier_at(name, java_script_last_dot_index(name))

/// Emits JavaScript expression text for qualified call qualifier using a precomputed separator.
private fun java_script_qualified_call_qualifier_at(name: String, idx: int): String =
    name[0, idx]

/// Emits JavaScript expression text for qualified call member.
private fun java_script_qualified_call_member(name: String): String =
    java_script_qualified_call_member_at(name, java_script_last_dot_index(name))

/// Emits JavaScript expression text for qualified call member using a precomputed separator.
private fun java_script_qualified_call_member_at(name: String, idx: int): String =
    name[idx + 1, name.size().value]

/// Checks whether a function matches the extension method function metadata.
private fun java_script_extension_method_function(function: CompiledFunction): bool =
    if java_script_last_dot_index(function.name) < 0
    then false
    else !(function.name ? "__local__")

/// Computes the JavaScript name for method owner.
private fun java_script_method_owner_name(name: String): String =
    let idx = java_script_last_dot_index(name)
    if idx < 0 then "" else name[0, idx]

/// Computes the JavaScript name for method owner base.
private fun java_script_method_owner_base_name(name: String): String =
    let bracket = java_script_first_index_of(name, "[", 0)
    if bracket < 0 then name else name[0, bracket]

/// Computes the JavaScript name for method member.
private fun java_script_method_member_name(name: String): String =
    if name.size().value >= 2 & java_script_string_has_prefix(name, "`")
    then name[1, name.size().value - 1]
    else name

/// Computes the output or module path for module.
private fun java_script_module_relative_path(module: CompiledModule, extension: String): String =
    java_script_module_path(module) + extension

/// Checks whether an import matches the standard-library import rule.
private fun java_script_stdlib_import(modulePath: String): bool =
    if java_script_string_has_prefix(modulePath, "/capy/")
    then true
    else java_script_string_has_prefix(modulePath, "capy/")

/// Normalizes module path into the path or name form expected by later compiler stages.
private fun java_script_normalize_module_path(path: String): String =
    if java_script_string_has_prefix(path, "/")
    then java_script_normalize_module_path(path[1, path.size().value])
    else path

/// Normalizes import module path into the path or name form expected by later compiler stages.
private fun java_script_normalize_import_module_path(path: String): String =
    let normalized = java_script_normalize_module_path(path)
    if java_script_string_has_prefix(normalized, "dev/capylang/capybara/")
    then java_script_normalize_capybara_import_suffix(normalized["dev/capylang/capybara/".size(), normalized.size().value], "dev/capylang/")
    else if java_script_string_has_prefix(normalized, "capybara/")
    then java_script_normalize_capybara_import_suffix(normalized["capybara/".size(), normalized.size().value], "")
    else normalized

/// Normalizes Capybara import suffix into the path or name form expected by later compiler stages.
private fun java_script_normalize_capybara_import_suffix(suffix: String, prefix: String): String =
    if java_script_string_has_prefix(suffix, "test/")
    then prefix + suffix
    else prefix + "test/" + suffix

/// Computes the output or module path for relative require.
private fun java_script_relative_require_path(fromModulePath: String, toModulePath: String): String =
    java_script_parent_prefix(java_script_module_directory(fromModulePath)) + toModulePath

/// Formats JavaScript source text for module directory.
private fun java_script_module_directory(modulePath: String): String =
    let idx = java_script_last_index_of(modulePath, "/", 0, -1)
    if idx < 0 then "" else modulePath[0, idx]

/// Computes the JavaScript name for module leaf.
private fun java_script_module_leaf_name(modulePath: String): String =
    let idx = java_script_last_index_of(modulePath, "/", 0, -1)
    if idx < 0 then modulePath else modulePath[idx + 1, modulePath.size().value]

/// Computes the JavaScript prefix for parent.
private fun java_script_parent_prefix(path: String): String =
    if path.is_empty()
    then "./"
    else java_script_repeat_parent(java_script_path_component_count(path))

/// Formats JavaScript source text for repeat parent.
private fun java_script_repeat_parent(count: int): String =
    if count <= 0
    then "./"
    else "../" + java_script_repeat_parent_tail(count - 1)

/// Formats the recursive tail segment for repeat parent.
private fun java_script_repeat_parent_tail(count: int): String =
    if count <= 0
    then ""
    else "../" + java_script_repeat_parent_tail(count - 1)

/// Counts path component count for overload or test discovery logic.
private fun java_script_path_component_count(path: String): int =
    if path.is_empty()
    then 0
    else 1 + java_script_char_count(path, "/", 0)

/// Counts char count for overload or test discovery logic.
private fun java_script_char_count(value: String, expected: String, idx: int): int =
    if idx >= value.size().value
    then 0
    else match value[idx] with
        case None -> 0
        case Some { char } ->
            let current = if char == expected then 1 else 0
            current + java_script_char_count(value, expected, idx + 1)

/// Sanitizes a Capybara name into a JavaScript identifier.
private fun java_script_identifier(name: String): String =
    let sanitized = java_script_identifier_chars(name, 0, "")
    let nonEmpty = if sanitized.is_empty() then "_" else sanitized
    let prefixed = match nonEmpty[0] with
        case None -> "_"
        case Some { char } -> if java_script_identifier_start_char(char) then nonEmpty else "_" + nonEmpty
    if java_script_reserved_word(prefixed)
    then prefixed + "_"
    else prefixed

/// Sanitizes remaining Capybara name characters into JavaScript identifier text.
private fun java_script_identifier_chars(name: String, idx: int, acc: String): String =
    if idx >= name.size().value
    then acc
    else match name[idx] with
        case None -> acc
        case Some { char } ->
            let next = if java_script_identifier_part_char(char) then char else "_"
            java_script_identifier_chars(name, idx + 1, acc + next)

/// Checks whether a character can start a JavaScript identifier.
private fun java_script_identifier_start_char(char: String): bool =
    ("ABCDEFGHIJKLMNOPQRSTUVWXYZ" ? char) | ("abcdefghijklmnopqrstuvwxyz" ? char) | char == "_" | char == "$"

/// Checks whether a character can appear inside a JavaScript identifier.
private fun java_script_identifier_part_char(char: String): bool =
    java_script_identifier_start_char(char) | ("0123456789" ? char)

/// Checks whether a name is reserved in JavaScript source.
private fun java_script_reserved_word(name: String): bool =
    "|break|case|catch|class|const|continue|debugger|default|delete|do|else|export|extends|finally|for|function|if|import|in|instanceof|new|return|super|switch|this|throw|try|typeof|var|void|while|with|yield|let|static|enum|await|implements|package|protected|interface|private|public|null|true|false|" ? ("|" + name + "|")

/// Formats string as a JavaScript literal.
private fun java_script_string_literal(value: String): String =
    "\"" + java_script_escape_string(value) + "\""

/// Escapes string for safe insertion into JavaScript source.
private fun java_script_escape_string(value: String): String =
    value
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace('\n', '\\n')
        .replace('\r', '\\r')
        .replace('\t', '\\t')

/// Formats integer as a JavaScript literal.
private fun java_script_integer_literal(source: String): String =
    if java_script_string_has_suffix(source, "L") | java_script_string_has_suffix(source, "l")
    then source[0, source.size().value - 1] + "n"
    else source

/// Formats decimal as a JavaScript literal.
private fun java_script_decimal_literal(source: String): String =
    if java_script_string_has_suffix(source, "f") | java_script_string_has_suffix(source, "F") | java_script_string_has_suffix(source, "d") | java_script_string_has_suffix(source, "D")
    then source[0, source.size().value - 1]
    else source

/// Checks whether a string starts with the requested prefix.
private fun java_script_string_has_prefix(value: String, prefix: String): bool =
    java_script_string_has_prefix_at(value, prefix, 0)

/// Checks whether a string has the requested prefix at the given index.
private fun java_script_string_has_prefix_at(value: String, prefix: String, idx: int): bool =
    match prefix[idx] with
    case None -> true
    case Some { expected } ->
        match value[idx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then java_script_string_has_prefix_at(value, prefix, idx + 1)
            else false

/// Checks whether a string ends with the requested suffix.
private fun java_script_string_has_suffix(value: String, suffix: String): bool =
    if suffix.size().value > value.size().value
    then false
    else value[value.size().value - suffix.size().value, value.size().value] == suffix

/// Computes the index used to split or rank first index of.
private fun java_script_first_index_of(value: String, expected: String, idx: int): int =
    if expected.is_empty()
    then 0
    else if idx + expected.size().value > value.size().value
    then -1
    else
        let actual = value[idx, idx + expected.size().value]
        if actual == expected
        then idx
        else java_script_first_index_of(value, expected, idx + 1)

/// Computes the index used to split or rank last dot index.
private fun java_script_last_dot_index(value: String): int =
    java_script_last_index_of(value, ".", 0, -1)

/// Computes the index used to split or rank last index of.
private fun java_script_last_index_of(value: String, needle: String, idx: int, found: int): int =
    if idx >= value.size().value
    then found
    else match value[idx] with
        case None -> found
        case Some { char } ->
            java_script_last_index_of(value, needle, idx + 1, if char == needle then idx else found)

/// Returns the newline sequence used by JavaScript source emission.
private fun java_script_newline(): String = '\n'
