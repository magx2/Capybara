    + "function __capy_io_append_bytes(filePath, bytes) { return __capy_io_effect('append_bytes', () => { const values = __capy_io_byte_values(bytes); fs.appendFileSync(__capy_fs_path(filePath), Buffer.from(values)); return values; }); }" + java_script_newline()
