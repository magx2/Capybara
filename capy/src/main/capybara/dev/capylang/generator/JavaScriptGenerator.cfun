        case None -> java_script_option_string_identity(java_script_find_qualified_function_return_type_in_imports(qualifier, member, rest, module, allModules))
    }
    case _ -> java_script_option_string_identity(java_script_find_qualified_function_return_type_in_imports(qualifier, member, rest, module, allModules))

private fun java_script_find_qualified_function_return_type_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } -> {
        match java_script_find_function(member, targetModule.functions) with
        case Some { function } -> /capy/lang/Option.Some { function.returnType.name }
        case None -> /capy/lang/Option.None {}
    }
    case None -> /capy/lang/Option.None {}

