    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !java_script_stdlib_import(declaration.modulePath) & java_script_qualified_import_matches(qualifier, declaration, module)
        then java_script_find_qualified_function_result_payload_type_in_import(qualifier, member, declaration, imports[1:], module, allModules)
        else java_script_option_string_identity(java_script_find_qualified_function_result_payload_type_in_imports(qualifier, member, imports[1:], module, allModules))

private fun java_script_find_qualified_function_result_payload_type_in_import(qualifier: String, member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
