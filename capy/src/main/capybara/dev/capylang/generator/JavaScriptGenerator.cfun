    + "function __capy_io_read_bytes(filePath) { return __capy_io_effect('read_bytes', () => Array.from(fs.readFileSync(__capy_fs_path(filePath)))); }" + java_script_newline()
    + "function __capy_io_write_text(filePath, text) { return __capy_io_effect('write_text', () => { const value = String(__capy_unsafe_run(text)); fs.writeFileSync(__capy_fs_path(filePath), value, 'utf8'); return value; }); }" + java_script_newline()
    + "function __capy_io_write_lines(filePath, lines) { return __capy_io_effect('write_lines', () => { const values = __capy_as_list(lines).map(item => String(__capy_unsafe_run(item))); fs.writeFileSync(__capy_fs_path(filePath), __capy_io_lines_text(values), 'utf8'); return values; }); }" + java_script_newline()
