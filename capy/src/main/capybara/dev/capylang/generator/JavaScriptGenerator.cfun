/// Emits one JavaScript import statement for runtime.
private fun java_script_runtime_import(module: CompiledModule): String =
    "const { " + java_script_runtime_import_symbols(module) + " } = require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), "capy/test/CapyTestRuntime"))
        + ");"
        + java_script_newline()

/// Emits JavaScript import source for imports.
private fun java_script_imports(imports: List[CompiledImportDeclaration], module: CompiledModule): String =
    java_script_unique_imports(imports, module, {:})

/// Emits JavaScript import statements for unique.
private fun java_script_unique_imports(imports: List[CompiledImportDeclaration], module: CompiledModule, emittedAliases: Dict[bool]): String =
    match imports[0] with
    case None -> ""
    case Some { declaration } ->
        let alias = java_script_import_alias(declaration, module)
        match emittedAliases.get(alias) with
        case Some _ -> java_script_unique_imports(imports[1:], module, emittedAliases)
        case None -> java_script_import(declaration, module) + java_script_unique_imports(imports[1:], module, emittedAliases + (alias, true))

/// Emits JavaScript import source for import.
private fun java_script_import(declaration: CompiledImportDeclaration, module: CompiledModule): String =
    "const "
        + java_script_import_alias(declaration, module)
        + " = require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), java_script_import_module_path(declaration.modulePath, module)))
        + ");"
        + java_script_newline()

/// Checks whether a function matches the object helper function metadata.
private fun java_script_object_helper_function(function: CompiledFunction): bool =
    if !java_script_string_has_prefix(function.name, "__capy_oo_")
    then false
    else if java_script_object_class_schema_function(function)
    then true
    else if java_script_object_interface_schema_function(function)
    then true
    else if java_script_object_method_function(function)
    then true
    else if java_script_object_field_init_function(function)
    then true
    else java_script_object_init_function(function)

/// Emits JavaScript code for object helper.
private fun java_script_object_helper_code(function: CompiledFunction, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], objectAnnotationIndex: JavaScriptObjectAnnotationIndex): String =
    if !java_script_string_has_prefix(function.name, "__capy_oo_")
    then ""
    else if java_script_object_class_schema_function(function)
    then java_script_object_class(function, functions, module, allModules, objectAnnotationIndex)
    else if java_script_object_interface_schema_function(function)
    then java_script_object_interface(function, functions, module, allModules, objectAnnotationIndex)
    else if java_script_object_method_function(function)
    then java_script_object_method(
        java_script_object_method_class_name(function),
        function,
        java_script_object_method_body(function, module, allModules),
        module,
        allModules,
        objectAnnotationIndex
    )
    else if java_script_object_field_init_function(function)
    then java_script_object_field_init(function, module, allModules)
    else if java_script_object_init_function(function)
    then java_script_object_init(function, module, allModules)
    else ""

/// Formats JavaScript source text for object class.
private fun java_script_object_class(function: CompiledFunction, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], objectAnnotationIndex: JavaScriptObjectAnnotationIndex): String =
    let className = java_script_object_class_schema_name(function)
    let sources = java_script_object_class_sources(className, functions)
    let annotationSources = java_script_object_annotation_sources_for(className, objectAnnotationIndex)
    "function "
        + java_script_object_runtime_class_name(className)
        + "(...__capy_args) {"
        + java_script_newline()
        + "    this.__type = "
        + java_script_string_literal(className)
        + ";"
        + java_script_newline()
        + sources.fieldStatements
        + sources.initStatements
        + "}"
        + java_script_newline()
        + java_script_newline()
        + "function "
        + java_script_object_constructor_name(className)
        + "(...__capy_args) {"
        + java_script_newline()
        + "    return delay(() => new "
        + java_script_object_runtime_class_name(className)
        + "(...__capy_args));"
        + java_script_newline()
        + "}"
        + java_script_newline()
        + java_script_newline()
        + java_script_object_type_function(className, sources, annotationSources, module, allModules)

/// Collects JavaScript object class helper metadata for one class once.
private fun java_script_object_class_sources(className: String, functions: List[CompiledFunction]): JavaScriptObjectClassSources =
    match functions[0] with
    case None -> JavaScriptObjectClassSources { openValue: "", fieldSchemas: [], parentSchemas: [], annotationSchemas: [], fieldStatements: "", initStatements: "" }
    case Some { function } ->
        let rest = java_script_object_class_sources(className, functions[1:])
        if java_script_compiled_schema(function) & function.name == java_script_object_class_open_schema_key(className)
        then rest.with(openValue: java_script_schema_value(function))
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, java_script_object_field_schema_prefix(className))
        then rest.with(fieldSchemas: [java_script_schema_value(function)] + rest.fieldSchemas)
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, java_script_object_class_parent_schema_prefix(className))
        then rest.with(parentSchemas: [java_script_schema_value(function)] + rest.parentSchemas)
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, java_script_object_type_annotation_schema_prefix(className))
        then rest.with(annotationSchemas: [java_script_schema_value(function)] + rest.annotationSchemas)
        else if java_script_object_field_init_function_for_class(className, function)
        then rest.with(fieldStatements: "    this["
            + java_script_string_literal(java_script_object_field_init_name(function))
            + "] = "
            + java_script_function_name(function)
            + ".call(this, ...__capy_args);"
            + java_script_newline()
            + rest.fieldStatements)
        else if java_script_object_init_function_for_class(className, function)
        then rest.with(initStatements: "    __capy_unsafe_run("
            + java_script_function_name(function)
            + ".call(this, ...__capy_args));"
            + java_script_newline()
            + rest.initStatements)
        else rest

/// Formats JavaScript source text for object interface.
private fun java_script_object_interface(function: CompiledFunction, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], objectAnnotationIndex: JavaScriptObjectAnnotationIndex): String =
    let interfaceName = java_script_object_interface_schema_name(function)
    let annotationSources = java_script_object_annotation_sources_for(interfaceName, objectAnnotationIndex)
    let sources = java_script_object_interface_sources(interfaceName, functions, module, allModules, annotationSources)
    "const "
        + java_script_object_constructor_name(interfaceName)
        + " = Object.create(null);"
        + java_script_newline()
        + java_script_object_interface_type_function(interfaceName, sources, annotationSources, module, allModules)

/// Collects JavaScript object interface helper metadata for one interface once.
private fun java_script_object_interface_sources(interfaceName: String, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], annotationSources: JavaScriptObjectAnnotationSources): JavaScriptObjectInterfaceSources =
    match functions[0] with
    case None -> JavaScriptObjectInterfaceSources { methodInfoStatements: "", parentSchemas: [], annotationSchemas: [] }
    case Some { function } ->
        let rest = java_script_object_interface_sources(interfaceName, functions[1:], module, allModules, annotationSources)
        if java_script_object_interface_method_function_for_interface(interfaceName, function)
        then rest.with(methodInfoStatements: java_script_object_constructor_name(interfaceName)
            + ".__capy_methods.push("
            + java_script_object_interface_method_info_literal(interfaceName, function, annotationSources, module, allModules)
            + ");"
            + java_script_newline()
            + rest.methodInfoStatements)
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, java_script_object_interface_parent_schema_prefix(interfaceName))
        then rest.with(parentSchemas: [java_script_schema_value(function)] + rest.parentSchemas)
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, java_script_object_type_annotation_schema_prefix(interfaceName))
        then rest.with(annotationSchemas: [java_script_schema_value(function)] + rest.annotationSchemas)
        else rest

/// Formats type metadata text for object interface type function.
private fun java_script_object_interface_type_function(interfaceName: String, sources: JavaScriptObjectInterfaceSources, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_object_constructor_name(interfaceName)
        + ".__capy_methods = "
        + java_script_object_constructor_name(interfaceName)
        + ".__capy_methods || [];"
        + java_script_newline()
        + sources.methodInfoStatements
        + java_script_object_constructor_name(interfaceName)
        + ".type = function() {"
        + java_script_newline()
        + "    return {"
        + "\"name\": " + java_script_string_literal(interfaceName)
        + ", \"pkg\": " + java_script_reflection_module_package_metadata_literal(module)
        + ", \"methods\": " + java_script_object_constructor_name(interfaceName) + ".__capy_methods"
        + ", \"parents\": " + java_script_object_parent_infos_literal(sources.parentSchemas, module, allModules)
        + ", \"annotations\": " + java_script_object_annotations_literal(annotationSources.typeAnnotations, module, allModules)
        + "};"
        + java_script_newline()
        + "};"
        + java_script_newline()
        + java_script_newline()

/// Builds object reflection annotation schema values for one generated module.
private fun java_script_object_annotation_index(functions: List[CompiledFunction]): JavaScriptObjectAnnotationIndex =
    match functions[0] with
    case None -> JavaScriptObjectAnnotationIndex { sourcesByOwner: {:} }
    case Some { function } ->
        let rest = java_script_object_annotation_index(functions[1:])
        if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, "__capy_oo_annotation|type|")
        then java_script_object_annotation_index_add_type(rest, java_script_object_annotation_owner_name(function.name, "__capy_oo_annotation|type|"), java_script_schema_value(function))
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, "__capy_oo_annotation|field|")
        then java_script_object_annotation_index_add_field(rest, java_script_object_annotation_owner_name(function.name, "__capy_oo_annotation|field|"), java_script_object_annotation_member_name(function.name, "__capy_oo_annotation|field|"), java_script_schema_value(function))
        else if java_script_compiled_schema(function) & java_script_string_has_prefix(function.name, "__capy_oo_annotation|method|")
        then java_script_object_annotation_index_add_method(rest, java_script_object_annotation_owner_name(function.name, "__capy_oo_annotation|method|"), java_script_object_annotation_member_name(function.name, "__capy_oo_annotation|method|"), java_script_schema_value(function))
        else rest

/// Adds a type-level object annotation schema value.
private fun java_script_object_annotation_index_add_type(index: JavaScriptObjectAnnotationIndex, ownerName: String, value: String): JavaScriptObjectAnnotationIndex =
    let sources = java_script_object_annotation_sources_for(ownerName, index)
    JavaScriptObjectAnnotationIndex {
        sourcesByOwner: index.sourcesByOwner + (ownerName, sources.with(typeAnnotations: [value] + sources.typeAnnotations))
    }

/// Adds a field-level object annotation schema value.
private fun java_script_object_annotation_index_add_field(index: JavaScriptObjectAnnotationIndex, ownerName: String, fieldName: String, value: String): JavaScriptObjectAnnotationIndex =
    let sources = java_script_object_annotation_sources_for(ownerName, index)
    JavaScriptObjectAnnotationIndex {
        sourcesByOwner: index.sourcesByOwner + (ownerName, sources.with(fieldAnnotations: java_script_object_annotation_values_add(sources.fieldAnnotations, fieldName, value)))
    }

/// Adds a method-level object annotation schema value.
private fun java_script_object_annotation_index_add_method(index: JavaScriptObjectAnnotationIndex, ownerName: String, methodName: String, value: String): JavaScriptObjectAnnotationIndex =
    let sources = java_script_object_annotation_sources_for(ownerName, index)
    JavaScriptObjectAnnotationIndex {
        sourcesByOwner: index.sourcesByOwner + (ownerName, sources.with(methodAnnotations: java_script_object_annotation_values_add(sources.methodAnnotations, methodName, value)))
    }

/// Returns object annotation schema sources for an owner, or an empty source bundle.
private fun java_script_object_annotation_sources_for(ownerName: String, index: JavaScriptObjectAnnotationIndex): JavaScriptObjectAnnotationSources =
    match index.sourcesByOwner.get(ownerName) with
    case Some { sources } -> sources
    case None -> java_script_empty_object_annotation_sources()

/// Returns an empty object annotation source bundle.
private fun java_script_empty_object_annotation_sources(): JavaScriptObjectAnnotationSources =
    JavaScriptObjectAnnotationSources { typeAnnotations: [], fieldAnnotations: {:}, methodAnnotations: {:} }

/// Adds one object annotation schema value while preserving source order.
private fun java_script_object_annotation_values_add(index: Dict[JavaScriptObjectAnnotationValues], key: String, value: String): Dict[JavaScriptObjectAnnotationValues] =
    match index.get(key) with
    case Some { existing } -> index + (key, JavaScriptObjectAnnotationValues { values: [value] + existing.values })
    case None -> index + (key, JavaScriptObjectAnnotationValues { values: [value] })

/// Returns object annotation schema values for a member key.
private fun java_script_object_annotation_values(key: String, index: Dict[JavaScriptObjectAnnotationValues]): List[String] =
    match index.get(key) with
    case Some { values } -> values.values
    case None -> []

/// Extracts the owner name after an object annotation prefix.
private fun java_script_object_annotation_owner_name(name: String, prefix: String): String =
    let rest = name[prefix.size().value, name.size().value]
    let separator = java_script_first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Extracts the member name after an object annotation owner segment.
private fun java_script_object_annotation_member_name(name: String, prefix: String): String =
    let rest = name[prefix.size().value, name.size().value]
    let ownerSeparator = java_script_first_index_of(rest, "|", 0)
    if ownerSeparator < 0
    then ""
    else
        let memberRest = rest[ownerSeparator + 1, rest.size().value]
        let memberSeparator = java_script_first_index_of(memberRest, "|", 0)
        if memberSeparator < 0 then memberRest else memberRest[0, memberSeparator]

/// Emits JavaScript statements for object interface method info.
private fun java_script_object_interface_method_info_statements(interfaceName: String, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule]): String =
    let annotationSources = java_script_object_annotation_sources_for(interfaceName, java_script_object_annotation_index(functions))
    java_script_object_interface_method_info_statements_with_sources(interfaceName, functions, module, allModules, annotationSources)

/// Emits JavaScript statements for object interface method info with precomputed annotations.
private fun java_script_object_interface_method_info_statements_with_sources(interfaceName: String, functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], annotationSources: JavaScriptObjectAnnotationSources): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_object_interface_method_function_for_interface(interfaceName, function)
        then java_script_object_constructor_name(interfaceName)
            + ".__capy_methods.push("
            + java_script_object_interface_method_info_literal(interfaceName, function, annotationSources, module, allModules)
            + ");"
            + java_script_newline()
            + java_script_string_identity(java_script_object_interface_method_info_statements_with_sources(interfaceName, functions[1:], module, allModules, annotationSources))
        else java_script_string_identity(java_script_object_interface_method_info_statements_with_sources(interfaceName, functions[1:], module, allModules, annotationSources))

/// Formats type metadata text for object type function.
private fun java_script_object_type_function(className: String, sources: JavaScriptObjectClassSources, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_object_constructor_name(className)
        + ".__capy_methods = "
        + java_script_object_constructor_name(className)
        + ".__capy_methods || [];"
        + java_script_newline()
        + java_script_object_constructor_name(className)
        + ".type = function() {"
        + java_script_newline()
        + "    return {"
        + "\"name\": " + java_script_string_literal(className)
        + ", \"pkg\": " + java_script_reflection_module_package_metadata_literal(module)
        + ", \"open\": " + java_script_bool_code(sources.openValue == "true")
        + ", \"fields\": " + java_script_object_field_infos_literal(className, sources.fieldSchemas, 0, annotationSources, module, allModules)
        + ", \"methods\": " + java_script_object_constructor_name(className) + ".__capy_methods"
        + ", \"parents\": " + java_script_object_parent_infos_literal(sources.parentSchemas, module, allModules)
        + ", \"annotations\": " + java_script_object_annotations_literal(annotationSources.typeAnnotations, module, allModules)
        + "};"
        + java_script_newline()
        + "};"
        + java_script_newline()
        + java_script_newline()

/// Formats object method info as a JavaScript literal.
private fun java_script_object_method_info_literal(className: String, function: CompiledFunction, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    let methodName = java_script_object_method_name(className, function)
    java_script_object_method_info_literal_for(className, methodName, function, java_script_object_annotation_values(methodName, annotationSources.methodAnnotations), module, allModules)

/// Formats object interface method info as a JavaScript literal.
private fun java_script_object_interface_method_info_literal(interfaceName: String, function: CompiledFunction, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    let methodName = java_script_object_interface_method_name(interfaceName, function)
    java_script_object_method_info_literal_for(interfaceName, methodName, function, java_script_object_annotation_values(methodName, annotationSources.methodAnnotations), module, allModules)

/// Formats object method info literal for as a JavaScript literal.
private fun java_script_object_method_info_literal_for(ownerName: String, methodName: String, function: CompiledFunction, annotations: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(methodName)),
        java_script_code_object_entry("pkg", java_script_reflection_module_package_metadata_literal(module)),
        java_script_code_object_entry("params", java_script_object_method_param_infos_literal(function.parameters)),
        java_script_code_object_entry("return_type", java_script_object_type_info_literal(java_script_type_reference_name(function.returnType))),
        java_script_code_object_entry("annotations", java_script_object_annotations_literal(
            annotations,
            module,
            allModules
        )),
    ])

/// Formats object field infos as a JavaScript literal.
private fun java_script_object_field_infos_literal(className: String, fields: List[String], idx: int, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_code_list_literal(java_script_object_field_info_literals(className, fields, idx, annotationSources, module, allModules))

/// Formats object field info as a JavaScript literal.
private fun java_script_object_field_info_literals(className: String, fields: List[String], idx: int, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match fields[0] with
    case None -> []
    case Some { field } ->
        [java_script_object_field_info_literal(className, field, idx, annotationSources, module, allModules)]
            + java_script_object_field_info_literals(className, fields[1:], idx + 1, annotationSources, module, allModules)

/// Formats object field info as a JavaScript literal.
private fun java_script_object_field_info_literal(className: String, field: String, idx: int, annotationSources: JavaScriptObjectAnnotationSources, module: CompiledModule, allModules: List[CompiledModule]): String =
    let schema = java_script_object_field_schema_metadata(field)
    java_script_code_object([
        java_script_code_object_entry("name", java_script_string_literal(schema.name)),
        java_script_code_object_entry("type", java_script_object_type_info_literal(schema.typeName)),
        java_script_code_object_entry("annotations", java_script_object_annotations_literal(
            java_script_object_annotation_values("" + idx, annotationSources.fieldAnnotations),
            module,
            allModules
        )),
    ])

/// Formats object parent infos as a JavaScript literal.
private fun java_script_object_parent_infos_literal(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_set(" + java_script_code_list_literal(java_script_object_parent_info_literals(parents, module, allModules)) + ")"

/// Formats object parent info as a JavaScript literal.
private fun java_script_object_parent_info_literals(parents: List[String], module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    match parents[0] with
    case None -> []
    case Some { parent } ->
        [java_script_object_type_info_literal(java_script_schema_type_name(parent))]
            + java_script_object_parent_info_literals(parents[1:], module, allModules)

/// Formats object method param infos as a JavaScript literal.
private fun java_script_object_method_param_infos_literal(parameters: List[CompiledFunctionParameter]): String =
    java_script_code_list_literal(java_script_object_method_param_info_literals(parameters))

/// Formats object method param info as a JavaScript literal.
private fun java_script_object_method_param_info_literals(parameters: List[CompiledFunctionParameter]): List[String] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [java_script_object_method_param_info_literal(parameter)] + java_script_object_method_param_info_literals(parameters[1:])

/// Formats object method param info as a JavaScript literal.
private fun java_script_object_method_param_info_literal(parameter: CompiledFunctionParameter): String =
    "{"
        + "\"name\": " + java_script_string_literal(parameter.name)
        + ", \"type\": " + java_script_object_type_info_literal(java_script_type_reference_name(parameter.typeReference))
        + ", \"annotations\": []"
        + "}"

/// Formats object type info as a JavaScript literal.
private fun java_script_object_type_info_literal(typeName: String): String =
    "{"
        + "\"name\": " + java_script_string_literal(java_script_type_unqualified_name(typeName))
        + ", \"pkg\": {\"name\": \"\", \"path\": \"\"}"
        + ", \"annotations\": []"
        + "}"

/// Emits JavaScript statements for object constructor field.
private fun java_script_object_constructor_field_statements(className: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_object_field_init_function_for_class(className, function)
        then "    this["
            + java_script_string_literal(java_script_object_field_init_name(function))
            + "] = "
            + java_script_function_name(function)
            + ".call(this, ...__capy_args);"
            + java_script_newline()
            + java_script_object_constructor_field_statements(className, functions[1:])
        else java_script_object_constructor_field_statements(className, functions[1:])

/// Emits JavaScript constructor field and init statements in one function-list pass.
private fun java_script_object_constructor_statements(className: String, functions: List[CompiledFunction]): JavaScriptObjectConstructorStatements =
    match functions[0] with
    case None -> JavaScriptObjectConstructorStatements { fieldStatements: "", initStatements: "" }
    case Some { function } ->
        let rest = java_script_object_constructor_statements(className, functions[1:])
        if java_script_object_field_init_function_for_class(className, function)
        then JavaScriptObjectConstructorStatements {
            fieldStatements: "    this["
                + java_script_string_literal(java_script_object_field_init_name(function))
                + "] = "
                + java_script_function_name(function)
                + ".call(this, ...__capy_args);"
                + java_script_newline()
                + rest.fieldStatements,
            initStatements: rest.initStatements
        }
        else if java_script_object_init_function_for_class(className, function)
        then JavaScriptObjectConstructorStatements {
            fieldStatements: rest.fieldStatements,
            initStatements: "    __capy_unsafe_run("
                + java_script_function_name(function)
                + ".call(this, ...__capy_args));"
                + java_script_newline()
                + rest.initStatements
        }
        else rest

/// Emits JavaScript statements for object constructor initializer.
private fun java_script_object_constructor_init_statements(className: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_object_init_function_for_class(className, function)
        then "    __capy_unsafe_run("
            + java_script_function_name(function)
            + ".call(this, ...__capy_args));"
            + java_script_newline()
            + java_script_object_constructor_init_statements(className, functions[1:])
        else java_script_object_constructor_init_statements(className, functions[1:])

/// Formats JavaScript source text for object field initializer.
private fun java_script_object_field_init(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_object_value_function(function, java_script_object_field_init_class_name(function), module, allModules)

/// Formats JavaScript source text for object initializer.
private fun java_script_object_init(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_object_value_function(function, java_script_object_init_class_name(function), module, allModules)

/// Formats JavaScript source text for object value function.
private fun java_script_object_value_function(function: CompiledFunction, className: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    "function "
        + java_script_function_name(function)
        + "("
        + java_script_parameters(function.parameters)
        + ") {"
        + java_script_newline()
        + "    return "
        + java_script_expression_code(function.body, java_script_object_function_bindings(className, function.parameters), module, allModules)
        + ";"
        + java_script_newline()
        + "}"
        + java_script_newline()
        + java_script_newline()

/// Formats JavaScript source text for object method.
private fun java_script_object_method(className: String, function: CompiledFunction, bodyCode: String, module: CompiledModule, allModules: List[CompiledModule], objectAnnotationIndex: JavaScriptObjectAnnotationIndex): String =
    let annotationSources = java_script_object_annotation_sources_for(className, objectAnnotationIndex)
    java_script_object_runtime_class_name(className)
        + ".prototype."
        + java_script_method_name(java_script_object_method_name(className, function))
        + " = function("
        + java_script_parameters(function.parameters)
        + ") {"
        + java_script_newline()
        + "    return "
        + "pure("
        + "__capy_unsafe_run("
        + bodyCode
        + ")"
        + ")"
        + ";"
        + java_script_newline()
        + "};"
        + java_script_newline()
        + java_script_object_constructor_name(className)
        + ".__capy_methods = "
        + java_script_object_constructor_name(className)
        + ".__capy_methods || [];"
        + java_script_newline()
        + java_script_object_constructor_name(className)
        + ".__capy_methods.push("
        + java_script_object_method_info_literal(className, function, annotationSources, module, allModules)
        + ");"
        + java_script_newline()
        + java_script_newline()

/// Emits JavaScript expression text for object method body.
private fun java_script_object_method_body(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_expression_code(
        function.body,
        java_script_object_method_bindings(java_script_object_method_class_name(function), function.parameters),
        module,
        allModules
    )

/// Emits JavaScript code for object-oriented method expression.
private fun java_script_oo_method_expression_code(expression: CompiledExpression, env: List[JavaScriptBinding]): String =
    match expression with
    case CompiledIntLiteral literal -> literal.source
    case CompiledLongLiteral literal -> java_script_integer_literal(literal.source)
    case CompiledFloatLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledDoubleLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> java_script_string_literal(literal.value)
    case CompiledVariableExpression variable -> java_script_oo_method_variable_code(variable.name, env)
    case CompiledIfExpression ifExpression ->
        "("
            + java_script_truthy_code(java_script_oo_method_expression_code(ifExpression.condition, env))
            + " ? "
            + java_script_oo_method_expression_code(ifExpression.thenBranch, env)
            + " : "
            + java_script_oo_method_expression_code(ifExpression.elseBranch, env)
            + ")"
    case CompiledBinaryExpression binary -> java_script_oo_method_binary_expression_code(binary, env)
    case CompiledFieldAccessExpression access ->
        "__capy_get_field("
            + java_script_oo_method_expression_code(access.receiver, env)
            + ", "
            + java_script_string_literal(access.name)
            + ")"
    case CompiledMethodCallExpression call -> "__capy_unsafe_run(" + java_script_oo_method_raw_method_call_code(call, env) + ")"
    case _ -> "__capy_unsupported(" + java_script_string_literal("unsupported object method expression") + ")"

/// Emits JavaScript code for object-oriented method raw method call.
private fun java_script_oo_method_raw_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding]): String =
    java_script_oo_method_expression_code(call.receiver, env)
        + "."
        + java_script_method_name(call.name)
        + "("
        + java_script_oo_method_expression_list_code(call.arguments, env)
        + ")"

/// Emits JavaScript code for object-oriented method expression list.
private fun java_script_oo_method_expression_list_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        java_script_oo_method_expression_code(expression, env)
            + java_script_oo_method_expression_tail_code(expressions[1:], env)

/// Emits JavaScript code for object-oriented method expression tail.
private fun java_script_oo_method_expression_tail_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding]): String =
    match expressions[0] with
    case None -> ""
    case Some _ -> ", " + java_script_oo_method_expression_list_code(expressions, env)

/// Emits JavaScript code for object-oriented method binary expression.
private fun java_script_oo_method_binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding]): String =
    if binary.operator == "+"
    then java_script_oo_method_binary_runtime_call("__capy_add", binary, env)
    else if binary.operator == "-"
    then java_script_oo_method_binary_runtime_call("__capy_sub", binary, env)
    else if binary.operator == "*"
    then java_script_oo_method_binary_runtime_call("__capy_mul", binary, env)
    else if binary.operator == "/"
    then java_script_oo_method_binary_runtime_call("__capy_div", binary, env)
    else if binary.operator == "%"
    then java_script_oo_method_binary_runtime_call("__capy_mod", binary, env)
    else if binary.operator == "^"
    then java_script_oo_method_binary_runtime_call("__capy_pow", binary, env)
    else if binary.operator == "=="
    then java_script_oo_method_binary_runtime_call("__capy_deep_equal", binary, env)
    else if binary.operator == "!="
    then "(!" + java_script_oo_method_binary_runtime_call("__capy_deep_equal", binary, env) + ")"
    else if binary.operator == "&" | binary.operator == "|"
    then "("
        + java_script_truthy_code(java_script_oo_method_expression_code(binary.left, env))
        + " "
        + java_script_boolean_operator(binary.operator)
        + " "
        + java_script_truthy_code(java_script_oo_method_expression_code(binary.right, env))
        + ")"
    else "("
        + java_script_oo_method_expression_code(binary.left, env)
        + " "
        + java_script_binary_operator(binary.operator)
        + " "
        + java_script_oo_method_expression_code(binary.right, env)
        + ")"

/// Emits JavaScript runtime support source for object-oriented method binary runtime call.
private fun java_script_oo_method_binary_runtime_call(name: String, binary: CompiledBinaryExpression, env: List[JavaScriptBinding]): String =
    name
        + "("
        + java_script_oo_method_expression_code(binary.left, env)
        + ", "
        + java_script_oo_method_expression_code(binary.right, env)
        + ")"

/// Emits JavaScript code for object-oriented method variable.
private fun java_script_oo_method_variable_code(name: String, env: List[JavaScriptBinding]): String =
    match java_script_lookup_binding(name, env) with
    case Some { binding } -> binding.jsName
    case None -> java_script_identifier(name)

/// Creates JavaScript name/type bindings for object method.
private fun java_script_object_method_bindings(className: String, parameters: List[CompiledFunctionParameter]): List[JavaScriptBinding] =
    java_script_object_function_bindings(className, parameters)

/// Creates JavaScript name/type bindings for object function.
private fun java_script_object_function_bindings(className: String, parameters: List[CompiledFunctionParameter]): List[JavaScriptBinding] =
    [
        JavaScriptBinding { name: "this", jsName: "this", typeName: className },
        JavaScriptBinding { name: "receiver", jsName: "this", typeName: className },
    ] + java_script_parameter_bindings(parameters)

/// Checks whether a function matches the object class schema function metadata.
private fun java_script_object_class_schema_function(function: CompiledFunction): bool =
    if java_script_compiled_schema(function)
    then java_script_string_has_prefix(function.name, java_script_object_class_schema_prefix())
    else false

/// Computes the JavaScript name for object class schema.
private fun java_script_object_class_schema_name(function: CompiledFunction): String =
    function.name[java_script_object_class_schema_prefix().size().value, function.name.size().value]

/// Checks whether object class exists in the relevant declarations or imports.
private fun java_script_object_class_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_class_schema_function(function)
        then if java_script_object_class_schema_name(function) == name
            then true
            else java_script_object_class_exists(name, functions[1:])
        else java_script_object_class_exists(name, functions[1:])

/// Checks whether the current value satisfies the object class exported rule for JavaScript processing.
private fun java_script_object_class_exported(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_class_schema_function(function)
        then if java_script_object_class_schema_name(function) == name
            then java_script_schema_value(function) != "private"
            else java_script_object_class_exported(name, functions[1:])
        else java_script_object_class_exported(name, functions[1:])

/// Returns the encoded schema-key prefix for object class metadata.
private fun java_script_object_class_schema_prefix(): String =
    "__capy_oo_class|"

/// Checks whether the current value satisfies the object class open rule for JavaScript processing.
private fun java_script_object_class_open(className: String, functions: List[CompiledFunction]): bool =
    match java_script_schema_value_named(java_script_object_class_open_schema_key(className), functions) with
    case Some { value } -> value == "true"
    case None -> false

/// Formats the encoded schema key for object class open metadata.
private fun java_script_object_class_open_schema_key(className: String): String =
    java_script_object_class_open_schema_prefix() + className

/// Returns the encoded schema-key prefix for object class open metadata.
private fun java_script_object_class_open_schema_prefix(): String =
    "__capy_oo_class_open|"

/// Checks whether a function matches the object interface schema function metadata.
private fun java_script_object_interface_schema_function(function: CompiledFunction): bool =
    if java_script_compiled_schema(function)
    then java_script_string_has_prefix(function.name, java_script_object_interface_schema_prefix())
    else false

/// Computes the JavaScript name for object interface schema.
private fun java_script_object_interface_schema_name(function: CompiledFunction): String =
    function.name[java_script_object_interface_schema_prefix().size().value, function.name.size().value]

/// Checks whether object interface exists in the relevant declarations or imports.
private fun java_script_object_interface_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_interface_schema_function(function)
        then if java_script_object_interface_schema_name(function) == name
            then true
            else java_script_bool_identity(java_script_object_interface_exists(name, functions[1:]))
        else java_script_bool_identity(java_script_object_interface_exists(name, functions[1:]))

/// Checks whether object type exists in the relevant declarations or imports.
private fun java_script_object_type_exists(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_type_schema_matches(name, function)
        then true
        else java_script_object_type_exists(name, functions[1:])

/// Checks whether the current value satisfies the object interface exported rule for JavaScript processing.
private fun java_script_object_interface_exported(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_interface_schema_function(function)
        then if java_script_object_interface_schema_name(function) == name
            then java_script_schema_value(function) != "private"
            else java_script_bool_identity(java_script_object_interface_exported(name, functions[1:]))
        else java_script_bool_identity(java_script_object_interface_exported(name, functions[1:]))

/// Checks whether a type reference matches the object type exported rule.
private fun java_script_object_type_exported(name: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_type_schema_matches(name, function)
        then java_script_schema_value(function) != "private"
        else java_script_object_type_exported(name, functions[1:])

/// Checks whether a schema helper declares the requested object class or interface.
private fun java_script_object_type_schema_matches(name: String, function: CompiledFunction): bool =
    if java_script_object_class_schema_function(function)
    then java_script_object_class_schema_name(function) == name
    else if java_script_object_interface_schema_function(function)
    then java_script_object_interface_schema_name(function) == name
    else false

/// Returns the encoded schema-key prefix for object interface metadata.
private fun java_script_object_interface_schema_prefix(): String =
    "__capy_oo_interface|"

/// Returns the encoded schema-key prefix for object class parent metadata.
private fun java_script_object_class_parent_schema_prefix(className: String): String =
    "__capy_oo_parent|" + className + "|"

/// Returns the encoded schema-key prefix for object interface parent metadata.
private fun java_script_object_interface_parent_schema_prefix(interfaceName: String): String =
    "__capy_oo_interface_parent|" + interfaceName + "|"

/// Returns the encoded schema-key prefix for object field metadata.
private fun java_script_object_field_schema_prefix(className: String): String =
    "__capy_oo_field|" + className + "|"

/// Returns the encoded schema-key prefix for object type annotation metadata.
private fun java_script_object_type_annotation_schema_prefix(ownerName: String): String =
    java_script_object_annotation_schema_prefix("type", ownerName, "")

/// Returns the encoded schema-key prefix for object method annotation metadata.
private fun java_script_object_method_annotation_schema_prefix(ownerName: String, methodName: String): String =
    java_script_object_annotation_schema_prefix("method", ownerName, methodName)

/// Returns the encoded schema-key prefix for object field annotation metadata.
private fun java_script_object_field_annotation_schema_prefix(ownerName: String, idx: int): String =
    java_script_object_annotation_schema_prefix("field", ownerName, "" + idx)

/// Returns the encoded schema-key prefix for object annotation metadata.
private fun java_script_object_annotation_schema_prefix(target: String, ownerName: String, memberName: String): String =
    if memberName.is_empty()
    then "__capy_oo_annotation|" + target + "|" + ownerName + "|"
    else "__capy_oo_annotation|" + target + "|" + ownerName + "|" + memberName + "|"

/// Checks whether a function matches the object field initializer function metadata.
private fun java_script_object_field_init_function(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_field_init_prefix())

/// Computes the JavaScript prefix for object field initializer.
private fun java_script_object_field_init_prefix(): String =
    "__capy_oo_field_init|"

/// Checks whether a function matches the object field initializer function for class metadata.
private fun java_script_object_field_init_function_for_class(className: String, function: CompiledFunction): bool =
    if java_script_object_field_init_function(function)
    then java_script_object_field_init_class_name(function) == className
    else false

/// Computes the JavaScript name for object field initializer class.
private fun java_script_object_field_init_class_name(function: CompiledFunction): String =
    java_script_object_class_name_from_prefixed_function(function, java_script_object_field_init_prefix())

/// Computes the JavaScript name for object field initializer.
private fun java_script_object_field_init_name(function: CompiledFunction): String =
    java_script_object_member_name_from_prefixed_function(function, java_script_object_field_init_prefix())

/// Checks whether a function matches the object initializer function metadata.
private fun java_script_object_init_function(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_init_prefix())

/// Computes the JavaScript prefix for object initializer.
private fun java_script_object_init_prefix(): String =
    "__capy_oo_init|"

/// Checks whether a function matches the object initializer function for class metadata.
private fun java_script_object_init_function_for_class(className: String, function: CompiledFunction): bool =
    if java_script_object_init_function(function)
    then java_script_object_init_class_name(function) == className
    else false

/// Computes the JavaScript name for object initializer class.
private fun java_script_object_init_class_name(function: CompiledFunction): String =
    java_script_object_class_name_from_prefixed_function(function, java_script_object_init_prefix())

/// Computes the JavaScript name for object class name from prefixed function.
private fun java_script_object_class_name_from_prefixed_function(function: CompiledFunction, prefix: String): String =
    let start = prefix.size().value
    let separator = java_script_first_index_of(function.name, "|", start)
    if separator < 0
    then ""
    else function.name[start, separator]

/// Computes the JavaScript name for object member name from prefixed function.
private fun java_script_object_member_name_from_prefixed_function(function: CompiledFunction, prefix: String): String =
    let start = prefix.size().value
    let separator = java_script_first_index_of(function.name, "|", start)
    if separator < 0
    then ""
    else function.name[separator + 1, function.name.size().value]

/// Checks whether a function matches the object method function metadata.
private fun java_script_object_method_function(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_method_any_prefix())

/// Computes the JavaScript prefix for object method any.
private fun java_script_object_method_any_prefix(): String =
    "__capy_oo_method|"

/// Computes the JavaScript prefix for object method.
private fun java_script_object_method_prefix(className: String): String =
    java_script_object_method_any_prefix() + className + "|"

/// Computes the JavaScript name for object method class.
private fun java_script_object_method_class_name(function: CompiledFunction): String =
    let start = java_script_object_method_any_prefix().size().value
    let separator = java_script_first_index_of(function.name, "|", start)
    if separator < 0
    then ""
    else function.name[start, separator]

/// Checks whether a function matches the object method function for class metadata.
private fun java_script_object_method_function_for_class(className: String, function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_method_prefix(className))

/// Computes the JavaScript name for object method.
private fun java_script_object_method_name(className: String, function: CompiledFunction): String =
    function.name[java_script_object_method_prefix(className).size().value, function.name.size().value]

/// Checks whether object method exists in the relevant declarations or imports.
private fun java_script_object_method_exists(className: String, methodName: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_method_function_for_class(className, function)
        then if java_script_object_method_name(className, function) == methodName
            then true
            else java_script_object_method_exists(className, methodName, functions[1:])
        else java_script_object_method_exists(className, methodName, functions[1:])

/// Checks whether a function matches the object interface method function metadata.
private fun java_script_object_interface_method_function(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_interface_method_any_prefix())

/// Computes the JavaScript prefix for object interface method any.
private fun java_script_object_interface_method_any_prefix(): String =
    "__capy_oo_interface_method|"

/// Computes the JavaScript prefix for object interface method.
private fun java_script_object_interface_method_prefix(interfaceName: String): String =
    java_script_object_interface_method_any_prefix() + interfaceName + "|"

/// Checks whether a function matches the object interface method function for interface metadata.
private fun java_script_object_interface_method_function_for_interface(interfaceName: String, function: CompiledFunction): bool =
    java_script_string_has_prefix(function.name, java_script_object_interface_method_prefix(interfaceName))

/// Computes the JavaScript name for object interface method.
private fun java_script_object_interface_method_name(interfaceName: String, function: CompiledFunction): String =
    function.name[java_script_object_interface_method_prefix(interfaceName).size().value, function.name.size().value]

/// Checks whether object interface method exists in the relevant declarations or imports.
private fun java_script_object_interface_method_exists(interfaceName: String, methodName: String, functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_object_interface_method_function_for_interface(interfaceName, function)
        then if java_script_object_interface_method_name(interfaceName, function) == methodName
            then true
            else java_script_object_interface_method_exists(interfaceName, methodName, functions[1:])
        else java_script_object_interface_method_exists(interfaceName, methodName, functions[1:])

/// Checks whether object method exists in a modules exists in the relevant declarations or imports.
private fun java_script_object_method_exists_in_modules(typeName: String, methodName: String, modules: List[CompiledModule]): bool =
    match modules[0] with
    case None -> false
    case Some { module } ->
        java_script_object_method_exists_in_module(typeName, methodName, module)
            | java_script_object_method_exists_in_modules(typeName, methodName, modules[1:])

/// Checks whether object method exists in one module.
private fun java_script_object_method_exists_in_module(typeName: String, methodName: String, module: CompiledModule): bool =
    java_script_object_method_exists(typeName, methodName, module.functions)
        | java_script_object_interface_method_exists(typeName, methodName, module.functions)

/// Checks whether object method exists in modules other than the already-checked current module.
private fun java_script_object_method_exists_in_other_modules(typeName: String, methodName: String, current: CompiledModule, modules: List[CompiledModule]): bool =
    match modules[0] with
    case None -> false
    case Some { module } ->
        if java_script_same_module(module, current)
        then java_script_object_method_exists_in_other_modules(typeName, methodName, current, modules[1:])
        else java_script_object_method_exists_in_module(typeName, methodName, module)
            | java_script_object_method_exists_in_other_modules(typeName, methodName, current, modules[1:])

/// Checks whether two module values identify the same compiled module.
private fun java_script_same_module(first: CompiledModule, second: CompiledModule): bool =
    first.name == second.name & first.path == second.path

/// Computes the JavaScript name for object runtime class.
private fun java_script_object_runtime_class_name(className: String): String =
    "__capy_oo_class_" + java_script_identifier(className)

/// Computes the JavaScript name for object constructor.
private fun java_script_object_constructor_name(className: String): String =
    java_script_identifier(className)

/// Computes the encoded JavaScript type name for an object class.
private fun java_script_object_type_name(module: CompiledModule, className: String): String =
    "__capy_oo|" + java_script_module_path(module).replace("/", ".") + "." + className

/// Formats JavaScript constants and functions in one pass over compiled functions.
private fun java_script_function_sections(functions: List[CompiledFunction], module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaScriptNativeProviderScope, objectAnnotationIndex: JavaScriptObjectAnnotationIndex): JavaScriptFunctionSections =
    match functions[0] with
    case None -> JavaScriptFunctionSections { constants: "", functions: "", hasOverloadedFunctions: false }
    case Some { function } ->
        let rest = java_script_function_sections(functions[1:], module, allModules, nativeProviderScope, objectAnnotationIndex)
        if java_script_compiled_constant(function)
            & !java_script_compiled_schema(function)
        then JavaScriptFunctionSections {
                constants: java_script_constant(function, module, allModules) + rest.constants,
                functions: rest.functions,
                hasOverloadedFunctions: rest.hasOverloadedFunctions
            }
        else
            let objectHelperCode = java_script_object_helper_code(function, functions, module, allModules, objectAnnotationIndex)
            if !objectHelperCode.is_empty()
            then JavaScriptFunctionSections {
                constants: rest.constants,
                functions: objectHelperCode + rest.functions,
                hasOverloadedFunctions: rest.hasOverloadedFunctions
            }
            else if java_script_compiled_constant(function)
            then rest
            else if java_script_imported_function(function)
            then rest
            else if java_script_compiled_object_helper_function(function)
            then rest
            else JavaScriptFunctionSections {
                constants: rest.constants,
                functions: java_script_function(function, module, allModules, nativeProviderScope)
                    + java_script_newline()
                    + rest.functions,
                hasOverloadedFunctions: rest.hasOverloadedFunctions | java_script_overloaded_function_name(function.name, functions)
            }

/// Formats JavaScript source text for overload dispatchers.
private fun java_script_overload_dispatchers(functions: List[CompiledFunction]): String =
    java_script_overload_dispatchers_with_flag(functions, java_script_has_overloaded_functions(functions))

/// Formats JavaScript source text for overload dispatchers with a precomputed overload flag.
private fun java_script_overload_dispatchers_with_flag(functions: List[CompiledFunction], hasOverloadedFunctions: bool): String =
    if !hasOverloadedFunctions
    then ""
    else
        let dispatchers = java_script_overload_dispatcher_functions(functions, [])
        java_script_dispatch_parent_metadata(functions)
            + java_script_dispatch_runtime_code()
            + dispatchers

/// Checks whether overloaded functions is present.
private fun java_script_has_overloaded_functions(functions: List[CompiledFunction]): bool =
    match functions[0] with
    case None -> false
    case Some { function } ->
        if java_script_skip_function(function)
        then java_script_has_overloaded_functions(functions[1:])
        else if java_script_overloaded_function_name(function.name, functions)
        then true
        else java_script_has_overloaded_functions(functions[1:])

/// Formats JavaScript source text for dispatch parent metadata.
private fun java_script_dispatch_parent_metadata(functions: List[CompiledFunction]): String =
    "const __capy_type_parents = Object.create(null);" + java_script_newline()
        + java_script_dispatch_parent_assignments(functions)

/// Formats JavaScript source text for dispatch parent assignments.
private fun java_script_dispatch_parent_assignments(functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_schema_parent_function(function)
        then java_script_dispatch_parent_assignment(function) + java_script_dispatch_parent_assignments(functions[1:])
        else java_script_dispatch_parent_assignments(functions[1:])

/// Checks whether a function matches the schema parent function metadata.
private fun java_script_schema_parent_function(function: CompiledFunction): bool =
    if java_script_compiled_schema(function)
    then java_script_string_has_prefix(function.name, "__capy_schema_parent|")
    else false

/// Formats JavaScript source text for dispatch parent assignment.
private fun java_script_dispatch_parent_assignment(function: CompiledFunction): String =
    let owner = java_script_schema_parent_owner_name(function.name)
    let parent = java_script_schema_value(function)
    "if (!__capy_type_parents[" + java_script_string_literal(owner) + "]) __capy_type_parents[" + java_script_string_literal(owner) + "] = [];" + java_script_newline()
        + "__capy_type_parents[" + java_script_string_literal(owner) + "].push(" + java_script_string_literal(parent) + ");" + java_script_newline()

/// Computes the JavaScript name for schema parent owner.
private fun java_script_schema_parent_owner_name(name: String): String =
    let prefix = "__capy_schema_parent|"
    let rest = name[prefix.size().value, name.size().value]
    let separator = java_script_first_index_of(rest, "|", 0)
    if separator < 0 then rest else rest[0, separator]

/// Emits the JavaScript runtime support source for dispatch.
private fun java_script_dispatch_runtime_code(): String =
    "function __capy_dispatch_normalize(typeName) { typeName = String(typeName || ''); if (typeName.startsWith('__capy_raw|')) return __capy_dispatch_normalize(typeName.slice('__capy_raw|'.length)); if (typeName.includes('/')) typeName = typeName.slice(typeName.lastIndexOf('/') + 1); if (typeName.includes('.')) typeName = typeName.slice(typeName.lastIndexOf('.') + 1); return typeName; }" + java_script_newline()
    + "function __capy_dispatch_split_type_args(text) { const result = []; let depth = 0; let start = 0; for (let i = 0; i < text.length; i++) { const char = text[i]; if (char === '[') depth++; else if (char === ']') depth--; else if (char === ',' && depth === 0) { const part = text.slice(start, i).trim(); if (part) result.push(part); start = i + 1; } } const tail = text.slice(start).trim(); if (tail) result.push(tail); return result; }" + java_script_newline()
    + "function __capy_dispatch_parse_type(typeName) { typeName = String(typeName || ''); const start = typeName.indexOf('['); if (start < 0 || !typeName.endsWith(']')) return { name: __capy_dispatch_normalize(typeName), args: [] }; return { name: __capy_dispatch_normalize(typeName.slice(0, start)), args: __capy_dispatch_split_type_args(typeName.slice(start + 1, -1)).map(__capy_dispatch_parse_type) }; }" + java_script_newline()
    + "function __capy_dispatch_parent_distance(actual, expected, distance, seen) { actual = __capy_dispatch_normalize(actual); expected = __capy_dispatch_normalize(expected); if (actual === expected) return distance; if (!actual || seen.includes(actual)) return -1; const parents = __capy_type_parents[actual] || []; let best = -1; for (const parent of parents) { const next = __capy_dispatch_parent_distance(parent, expected, distance + 1, seen.concat([actual])); if (next >= 0 && (best < 0 || next < best)) best = next; } return best; }" + java_script_newline()
    + "function __capy_dispatch_values_score(values, expected) { if (expected.args.length === 0) return 0; let score = 0; for (const item of values) { const part = __capy_dispatch_type_score_parsed(item, expected.args[0]); if (part >= 1000000) return 1000000; score += part; } return score; }" + java_script_newline()
    + "function __capy_dispatch_dict_score(value, expected) { if (expected.args.length === 0) return 0; let score = 0; for (const entry of value.entries()) { if (expected.args.length > 1) { const keyScore = __capy_dispatch_type_score_parsed(entry[0], expected.args[0]); if (keyScore >= 1000000) return 1000000; score += keyScore; const valueScore = __capy_dispatch_type_score_parsed(entry[1], expected.args[1]); if (valueScore >= 1000000) return 1000000; score += valueScore; } else { const valueScore = __capy_dispatch_type_score_parsed(entry[1], expected.args[0]); if (valueScore >= 1000000) return 1000000; score += valueScore; } } return score; }" + java_script_newline()
    + "function __capy_dispatch_type_score(value, expected) { return __capy_dispatch_type_score_parsed(value, __capy_dispatch_parse_type(expected)); }" + java_script_newline()
    + "function __capy_dispatch_type_score_parsed(value, expected) { if (expected.name === 'any' || expected.name === '') return 1000; if (expected.name === 'String') return typeof value === 'string' ? 0 : 1000000; if (expected.name === 'char') return typeof value === 'string' && Array.from(value).length === 1 ? 0 : 1000000; if (expected.name === 'bool') return typeof value === 'boolean' ? 0 : 1000000; if (expected.name === 'int' || expected.name === 'byte') return Number.isInteger(value) ? 0 : 1000000; if (expected.name === 'long') { if (typeof value === 'bigint') return 0; return Number.isInteger(value) ? 1 : 1000000; } if (expected.name === 'float' || expected.name === 'double') return (typeof value === 'number' || typeof value === 'bigint') ? 0 : 1000000; if (expected.name === 'List') return Array.isArray(value) ? __capy_dispatch_values_score(value, expected) : 1000000; if (expected.name === 'Set') return value instanceof Set ? __capy_dispatch_values_score(value.values(), expected) : 1000000; if (expected.name === 'Dict') return value instanceof Map ? __capy_dispatch_dict_score(value, expected) : 1000000; if (value == null || typeof value !== 'object') return 1000000; const distance = __capy_dispatch_parent_distance(value.__type, expected.name, 0, []); return distance >= 0 ? distance : 1000000; }" + java_script_newline()
    + "function __capy_dispatch(name, args, candidates) { let best = null; let bestScore = 1000000; for (const candidate of candidates) { const types = candidate[0]; if (types.length !== args.length) continue; let score = 0; let ok = true; for (let i = 0; i < types.length; i++) { const part = __capy_dispatch_type_score(args[i], types[i]); if (part >= 1000000) { ok = false; break; } score += part; } if (ok && score < bestScore) { best = candidate[1]; bestScore = score; } } if (best) return best(...args); throw new Error('No overload matched ' + name + '/' + args.length); }" + java_script_newline()

/// Formats JavaScript source text for overload dispatcher functions.
private fun java_script_overload_dispatcher_functions(functions: List[CompiledFunction], emittedNames: List[String]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_skip_function(function)
        then java_script_overload_dispatcher_functions(functions[1:], emittedNames)
        else if java_script_overloaded_function_name(function.name, functions)
        then if !java_script_string_list_contains(function.name, emittedNames)
            then java_script_overload_dispatcher_function(function.name, functions)
                + java_script_newline()
                + java_script_overload_dispatcher_functions(functions[1:], emittedNames + [function.name])
            else java_script_overload_dispatcher_functions(functions[1:], emittedNames)
        else java_script_overload_dispatcher_functions(functions[1:], emittedNames)

/// Formats JavaScript source text for overload dispatcher function.
private fun java_script_overload_dispatcher_function(name: String, functions: List[CompiledFunction]): String =
    "function "
        + java_script_identifier(name)
        + "(...__capy_args) {"
        + java_script_newline()
        + "    return __capy_dispatch("
        + java_script_string_literal(name)
        + ", __capy_args, ["
        + java_script_dispatch_candidates(name, functions)
        + "]);"
        + java_script_newline()
        + "}"
        + java_script_newline()

/// Formats JavaScript source text for dispatch candidates.
private fun java_script_dispatch_candidates(name: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if java_script_skip_function(function)
        then java_script_dispatch_candidates(name, functions[1:])
        else if function.name == name
        then java_script_dispatch_candidate(function) + java_script_dispatch_candidate_tail(name, functions[1:])
        else java_script_dispatch_candidates(name, functions[1:])

/// Formats the recursive tail segment for dispatch candidate.
private fun java_script_dispatch_candidate_tail(name: String, functions: List[CompiledFunction]): String =
    let tail = java_script_dispatch_candidates(name, functions)
    if tail.is_empty() then "" else ", " + tail

/// Formats JavaScript source text for dispatch candidate.
private fun java_script_dispatch_candidate(function: CompiledFunction): String =
    "[["
        + java_script_dispatch_parameter_types(function.parameters)
        + "], "
        + java_script_function_name(function)
        + "]"

/// Formats type metadata text for dispatch parameter types.
private fun java_script_dispatch_parameter_types(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        java_script_string_literal(java_script_type_reference_name(parameter.typeReference)) + java_script_dispatch_parameter_type_tail(parameters[1:])

/// Formats the recursive tail segment for dispatch parameter type.
private fun java_script_dispatch_parameter_type_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", " + java_script_string_literal(java_script_type_reference_name(parameter.typeReference)) + java_script_dispatch_parameter_type_tail(parameters[1:])

/// Computes the JavaScript name for type reference.
private fun java_script_type_reference_name(typeReference: CompiledTypeReference): String =
    if typeReference.arguments.is_empty()
    then typeReference.name
    else typeReference.name + "[" + java_script_type_reference_arguments(typeReference.arguments) + "]"

/// Formats type reference arguments for JavaScript emission.
private fun java_script_type_reference_arguments(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> java_script_type_reference_name(argument) + java_script_type_reference_argument_tail(arguments[1:])

/// Formats the recursive tail segment for type reference argument.
private fun java_script_type_reference_argument_tail(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some _ -> ", " + java_script_type_reference_arguments(arguments)

/// Checks whether a function matches the skip function metadata.
private fun java_script_skip_function(function: CompiledFunction): bool =
    if java_script_compiled_constant(function)
    then true
    else if java_script_imported_function(function)
    then true
    else java_script_compiled_object_helper_function(function)

/// Extracts compiled metadata for constant.
private fun java_script_compiled_constant(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.visibility, "const:")

/// Extracts compiled metadata for schema.
private fun java_script_compiled_schema(function: CompiledFunction): bool =
    java_script_string_has_prefix(function.visibility, "const:schema")

/// Collects imported function visible to the current module.
private fun java_script_imported_function(function: CompiledFunction): bool =
    function.visibility == "imported"

/// Extracts compiled metadata for object helper function.
private fun java_script_compiled_object_helper_function(function: CompiledFunction): bool =
    if !java_script_string_has_prefix(function.name, "__capy_oo_")
    then false
    else if java_script_object_method_function(function)
    then true
    else if java_script_object_interface_method_function(function)
    then true
    else if java_script_object_field_init_function(function)
    then true
    else java_script_object_init_function(function)

/// Checks whether the current value satisfies the emitted constant rule for JavaScript processing.
private fun java_script_emitted_constant(function: CompiledFunction): bool =
    if java_script_compiled_constant(function)
    then !java_script_compiled_schema(function)
    else false

/// Formats JavaScript source text for constant.
private fun java_script_constant(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    "const "
        + java_script_constant_name(function)
        + " = "
        + java_script_expression_code(function.body, [], module, allModules)
        + ";"
        + java_script_newline()

/// Computes constant metadata for name.
private fun java_script_constant_name(function: CompiledFunction): String =
    java_script_identifier(function.name)

/// Formats JavaScript source text for function.
private fun java_script_function(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaScriptNativeProviderScope): String =
    if java_script_tail_recursive_function(function, module)
    then java_script_tail_recursive_function_code(function, module, allModules)
    else "function "
            + java_script_function_name(function)
            + "("
            + java_script_function_parameters(function)
            + ") {"
            + java_script_newline()
            + "    return "
            + java_script_function_body_expression(function, module, allModules, nativeProviderScope)
            + ";"
            + java_script_newline()
            + "}"
            + java_script_newline()

/// Emits JavaScript expression text for function body expression.
private fun java_script_function_body_expression(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], nativeProviderScope: JavaScriptNativeProviderScope): String =
    match nativeProviderScope.declarations.get(function.name) with
    case Some { declaration } -> java_script_native_provider_function_body(declaration, function.returnType, nativeProviderScope)
    case None ->
        if java_script_async_native_function(function, module)
        then java_script_async_native_function_body(function)
        else java_script_expression_code(function.body, java_script_function_bindings(function), module, allModules)

/// Checks whether a function is an Async native runtime wrapper.
private fun java_script_async_native_function(function: CompiledFunction, module: CompiledModule): bool =
    module.path == "capy/lang"
        & module.name == "Async"
        & (function.name == "all" | function.name == "any")
        & java_script_native_function_body(function)

/// Emits the Async native runtime wrapper body.
private fun java_script_async_native_function_body(function: CompiledFunction): String =
    "__capy_async_" + function.name + "(" + java_script_identifier(first_function_parameter_name(function)) + ")"

/// Returns the first function parameter name.
private fun first_function_parameter_name(function: CompiledFunction): String =
    match function.parameters[0] with
    case Some { parameter } -> parameter.name
    case None -> "value"

private fun java_script_native_provider_index(catalog: NativeProviderCatalog): JavaScriptNativeProviderIndex =
    JavaScriptNativeProviderIndex {
        declarationsByModule: java_script_native_provider_declarations_by_module(catalog.declarations),
        bindings: java_script_native_provider_binding_dict(catalog.bindings)
    }

private fun java_script_native_provider_scope_for_module(module: CompiledModule, index: JavaScriptNativeProviderIndex): JavaScriptNativeProviderScope =
    match index.declarationsByModule.get(java_script_native_provider_module_key(module.name, module.path)) with
    case Some { declarations } -> JavaScriptNativeProviderScope {
        declarations: declarations.declarations,
        bindings: index.bindings
    }
    case None -> JavaScriptNativeProviderScope {
        declarations: java_script_empty_native_provider_declaration_dict(),
        bindings: index.bindings
    }

private fun java_script_empty_native_provider_declaration_dict(): Dict[CompiledNativeProviderDeclaration] =
    {:}

private fun java_script_native_provider_declarations_by_module(declarations: List[CompiledNativeProviderDeclaration]): Dict[JavaScriptNativeProviderDeclarations] =
    java_script_native_provider_declarations_by_module_with_acc(declarations, {:})

private fun java_script_native_provider_declarations_by_module_with_acc(declarations: List[CompiledNativeProviderDeclaration], declarationsByModule: Dict[JavaScriptNativeProviderDeclarations]): Dict[JavaScriptNativeProviderDeclarations] =
    match declarations[0] with
    case None -> declarationsByModule
    case Some { declaration } ->
        java_script_native_provider_declarations_by_module_with_acc(declarations[1:], java_script_native_provider_add_declaration(declarationsByModule, declaration))

private fun java_script_native_provider_add_declaration(declarationsByModule: Dict[JavaScriptNativeProviderDeclarations], declaration: CompiledNativeProviderDeclaration): Dict[JavaScriptNativeProviderDeclarations] =
    let moduleKey = java_script_native_provider_module_key(declaration.sourceModuleName, declaration.sourceModulePath)
    let declarations = match declarationsByModule.get(moduleKey) with
        case Some { moduleDeclarations } -> moduleDeclarations.declarations
        case None -> java_script_empty_native_provider_declaration_dict()
    match declarations.get(declaration.providerName) with
    case Some _ -> declarationsByModule
    case None -> declarationsByModule + (moduleKey, JavaScriptNativeProviderDeclarations {
        declarations: declarations + (declaration.providerName, declaration)
    })

private fun java_script_native_provider_binding_dict(bindings: List[CompiledNativeProviderBinding]): Dict[CompiledNativeProviderBinding] =
    java_script_native_provider_binding_dict_with_acc(bindings, {:})

private fun java_script_native_provider_binding_dict_with_acc(bindings: List[CompiledNativeProviderBinding], bindingIndex: Dict[CompiledNativeProviderBinding]): Dict[CompiledNativeProviderBinding] =
    match bindings[0] with
    case None -> bindingIndex
    case Some { binding } ->
        if java_script_native_provider_binding_has_javascript(binding)
        then java_script_native_provider_binding_dict_with_acc(bindings[1:], java_script_native_provider_binding_dict_add(bindingIndex, binding))
        else java_script_native_provider_binding_dict_with_acc(bindings[1:], bindingIndex)

private fun java_script_native_provider_binding_dict_add(bindingIndex: Dict[CompiledNativeProviderBinding], binding: CompiledNativeProviderBinding): Dict[CompiledNativeProviderBinding] =
    let key = java_script_native_provider_binding_key(binding.interfaceId, binding.qualifier)
    match bindingIndex.get(key) with
    case Some _ -> bindingIndex
    case None -> bindingIndex + (key, binding)

private fun java_script_native_provider_module_key(name: String, path: String): String =
    if path.is_empty()
    then name
    else path + "/" + name

private fun java_script_native_provider_binding_key(interfaceId: String, qualifier: String): String =
    interfaceId.size().value + "|" + interfaceId + "|" + qualifier

/// Emits JavaScript expression text for native provider function body.
private fun java_script_native_provider_function_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, nativeProviderScope: JavaScriptNativeProviderScope): String =
    match nativeProviderScope.bindings.get(java_script_native_provider_binding_key(declaration.interfaceId, declaration.qualifier)) with
    case Some { binding } -> java_script_native_provider_binding_body(declaration, returnType, binding)
    case None -> java_script_native_provider_not_wired_body(declaration, returnType)

/// Emits JavaScript expression text for native provider binding body.
private fun java_script_native_provider_binding_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, binding: CompiledNativeProviderBinding): String =
    match binding.javascriptBinding with
    case Some { backend } -> java_script_native_provider_bound_body(declaration, returnType, backend)
    case None -> java_script_native_provider_not_wired_body(declaration, returnType)

/// Checks whether the current value satisfies the native provider binding has JavaScript rule for JavaScript processing.
private fun java_script_native_provider_binding_has_javascript(binding: CompiledNativeProviderBinding): bool =
    match binding.javascriptBinding with
    case Some _ -> true
    case None -> false

/// Emits JavaScript expression text for native provider bound body.
private fun java_script_native_provider_bound_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference, backend: NativeProviderBackendBinding): String =
    let valueCode = java_script_native_provider_backend_value_code(declaration, backend)
    if valueCode.is_empty()
    then java_script_native_provider_not_wired_body(declaration, returnType)
    else if returnType.name == "Effect"
    then "delay(() => " + valueCode + ")"
    else valueCode

/// Emits JavaScript code for native provider backend value.
private fun java_script_native_provider_backend_value_code(declaration: CompiledNativeProviderDeclaration, backend: NativeProviderBackendBinding): String =
    match backend.factory with
    case Some { factory } -> factory + "()"
    case None -> java_script_native_provider_backend_module_value_code(declaration, backend)

/// Emits JavaScript code for native provider backend module value.
private fun java_script_native_provider_backend_module_value_code(declaration: CompiledNativeProviderDeclaration, backend: NativeProviderBackendBinding): String =
    match backend.moduleName with
    case Some { moduleName } -> {
        match backend.exportName with
        case Some { exportName } ->
            "__capy_native_provider("
                + java_script_string_literal(moduleName)
                + ", "
                + java_script_string_literal(exportName)
                + ", "
                + java_script_string_literal(declaration.interfaceId)
                + ")"
        case None -> ""
    }
    case None -> java_script_native_provider_backend_class_value_code(backend)

/// Emits JavaScript code for native provider backend class value.
private fun java_script_native_provider_backend_class_value_code(backend: NativeProviderBackendBinding): String =
    match backend.className with
    case Some { className } -> "new " + className + "()"
    case None -> ""

/// Emits JavaScript expression text for native provider not wired body.
private fun java_script_native_provider_not_wired_body(declaration: CompiledNativeProviderDeclaration, returnType: CompiledTypeReference): String =
    let message = "NotWired: No native provider registered for interface `" + declaration.interfaceId + "` with qualifier `" + declaration.qualifier + "`."
    if returnType.name == "Effect"
    then "delay(() => __capy_unsupported(" + java_script_string_literal(message) + "))"
    else "__capy_unsupported(" + java_script_string_literal(message) + ")"

/// Checks whether a function matches the tail recursive function metadata.
private fun java_script_tail_recursive_function(function: CompiledFunction, module: CompiledModule): bool =
    if java_script_extension_method_function(function)
    then false
    else if java_script_local_function_unambiguous(function.name, module.functions)
    then java_script_tail_position_has_self_call(function.body, function.name)
    else false

/// Checks whether a call has the tail position has self call shape.
private fun java_script_tail_position_has_self_call(expression: CompiledExpression, functionName: String): bool =
    match expression with
    case CompiledFunctionCallExpression call -> call.name == functionName
    case CompiledIfExpression ifExpression ->
        if java_script_tail_position_has_self_call(ifExpression.thenBranch, functionName)
        then true
        else java_script_tail_position_has_self_call(ifExpression.elseBranch, functionName)
    case CompiledBlockExpression block -> java_script_tail_position_has_self_call(block.result, functionName)
    case _ -> false

/// Emits JavaScript code for tail recursive function.
private fun java_script_tail_recursive_function_code(function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule]): String =
    "function "
        + java_script_function_name(function)
        + "("
        + java_script_function_parameters(function)
        + ") {"
        + java_script_newline()
        + "    while (true) {"
        + java_script_newline()
        + java_script_tail_position_statements(function.body, java_script_function_bindings(function), function, module, allModules, "        ")
        + "    }"
        + java_script_newline()
        + "}"
        + java_script_newline()

/// Emits JavaScript statements for tail position.
private fun java_script_tail_position_statements(expression: CompiledExpression, env: List[JavaScriptBinding], function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match expression with
    case CompiledFunctionCallExpression call ->
        if call.name == function.name
        then java_script_tail_call_statements(call, function, env, module, allModules, indent)
        else java_script_tail_return_statement(expression, env, module, allModules, indent)
    case CompiledIfExpression ifExpression -> java_script_tail_if_statements(ifExpression, env, function, module, allModules, indent)
    case CompiledBlockExpression block -> java_script_tail_block_statements(block, env, function, module, allModules, indent)
    case _ -> java_script_tail_return_statement(expression, env, module, allModules, indent)

/// Emits one JavaScript statement for tail return.
private fun java_script_tail_return_statement(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    indent
        + "return "
        + java_script_expression_code(expression, env, module, allModules)
        + ";"
        + java_script_newline()

/// Emits JavaScript statements for tail call.
private fun java_script_tail_call_statements(call: CompiledFunctionCallExpression, function: CompiledFunction, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    java_script_tail_call_temp_statements(function.parameters, call.arguments, function, env, module, allModules, 0, indent)
        + java_script_tail_call_assignment_statements(function.parameters, call.arguments, function, 0, indent)
        + indent
        + "continue;"
        + java_script_newline()

/// Emits JavaScript statements for tail call temp.
private fun java_script_tail_call_temp_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], function: CompiledFunction, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule], idx: int, indent: String): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } ->
        indent
            + "const "
            + java_script_tail_call_temp_name(function, idx)
            + " = "
            + java_script_tail_call_argument_code(parameters, argument, env, module, allModules)
            + ";"
            + java_script_newline()
            + java_script_tail_call_temp_statements(java_script_parameter_rest(parameters), arguments[1:], function, env, module, allModules, idx + 1, indent)

/// Emits JavaScript code for tail call argument.
private fun java_script_tail_call_argument_code(parameters: List[CompiledFunctionParameter], argument: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> java_script_expression_code(argument, env, module, allModules)
    case Some { parameter } -> java_script_argument_code(parameter, argument, env, module, allModules)

/// Emits JavaScript statements for tail call assignment.
private fun java_script_tail_call_assignment_statements(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], function: CompiledFunction, idx: int, indent: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        indent
            + java_script_identifier(parameter.name)
            + " = "
            + java_script_tail_call_assignment_value(arguments, function, idx)
            + ";"
            + java_script_newline()
            + java_script_tail_call_assignment_statements(parameters[1:], java_script_expression_rest(arguments), function, idx + 1, indent)

/// Computes value metadata for tail call assignment value.
private fun java_script_tail_call_assignment_value(arguments: List[CompiledExpression], function: CompiledFunction, idx: int): String =
    match arguments[0] with
    case None -> "undefined"
    case Some _ -> java_script_tail_call_temp_name(function, idx)

/// Computes the JavaScript name for tail call temp.
private fun java_script_tail_call_temp_name(function: CompiledFunction, idx: int): String =
    "__capy_tail_"
        + function.location.line
        + "_"
        + function.location.column
        + "_"
        + idx

/// Collects parameter rest for JavaScript processing.
private fun java_script_parameter_rest(parameters: List[CompiledFunctionParameter]): List[CompiledFunctionParameter] =
    match parameters[0] with
    case None -> []
    case Some _ -> parameters[1:]

/// Collects expression rest for JavaScript processing.
private fun java_script_expression_rest(expressions: List[CompiledExpression]): List[CompiledExpression] =
    match expressions[0] with
    case None -> []
    case Some _ -> expressions[1:]

/// Emits JavaScript statements for tail if.
private fun java_script_tail_if_statements(ifExpression: CompiledIfExpression, env: List[JavaScriptBinding], function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    indent
        + "if ("
        + java_script_truthy_expression_code(ifExpression.condition, env, module, allModules)
        + ") {"
        + java_script_newline()
        + java_script_tail_position_statements(ifExpression.thenBranch, env, function, module, allModules, indent + "    ")
        + indent
        + "} else {"
        + java_script_newline()
        + java_script_tail_position_statements(ifExpression.elseBranch, env, function, module, allModules, indent + "    ")
        + indent
        + "}"
        + java_script_newline()

/// Emits JavaScript statements for tail block.
private fun java_script_tail_block_statements(block: CompiledBlockExpression, env: List[JavaScriptBinding], function: CompiledFunction, module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    if java_script_block_has_result_binding(block.bindings, env, module, allModules) | java_script_block_has_effect_binding(block.bindings)
    then indent
        + "return "
        + java_script_block_expression_code(block, env, module, allModules)
        + ";"
        + java_script_newline()
    else java_script_tail_block_binding_statements(block.bindings, env, module, allModules, indent)
        + java_script_tail_position_statements(block.result, java_script_block_env(block.bindings, env, module, allModules), function, module, allModules, indent)

/// Emits JavaScript statements for tail block binding.
private fun java_script_tail_block_binding_statements(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule], indent: String): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let jsBinding = java_script_let_binding(binding, env, module, allModules)
        indent
            + "const "
            + jsBinding.jsName
            + " = "
            + java_script_expression_code(binding.value, env, module, allModules)
            + ";"
            + java_script_newline()
            + java_script_tail_block_binding_statements(bindings[1:], [jsBinding] + env, module, allModules, indent)

/// Formats function parameters for JavaScript emission.
private fun java_script_function_parameters(function: CompiledFunction): String =
    if java_script_extension_method_function(function)
    then java_script_identifier("this") + java_script_method_parameter_tail(function.parameters)
    else java_script_parameters(function.parameters)

/// Formats the recursive tail segment for method parameter.
private fun java_script_method_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    if parameters.is_empty()
    then ""
    else ", " + java_script_parameters(parameters)

/// Formats JavaScript source text for parameters.
private fun java_script_parameters(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_script_identifier(parameter.name) + java_script_parameter_tail(parameters[1:])

/// Formats the recursive tail segment for parameter.
private fun java_script_parameter_tail(parameters: List[CompiledFunctionParameter]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> ", " + java_script_identifier(parameter.name) + java_script_parameter_tail(parameters[1:])

/// Creates JavaScript name/type bindings for function.
private fun java_script_function_bindings(function: CompiledFunction): List[JavaScriptBinding] =
    if java_script_extension_method_function(function)
    then
        let receiverType = java_script_method_owner_name(function.name)
        [JavaScriptBinding {
            name: "this",
            jsName: java_script_identifier("this"),
            typeName: receiverType
        }] + java_script_parameter_bindings(function.parameters)
            + [JavaScriptBinding {
                name: "receiver",
                jsName: java_script_identifier("this"),
                typeName: receiverType
            }]
    else java_script_parameter_bindings(function.parameters)

/// Creates JavaScript name/type bindings for parameter.
private fun java_script_parameter_bindings(parameters: List[CompiledFunctionParameter]): List[JavaScriptBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [JavaScriptBinding { name: parameter.name, jsName: java_script_identifier(parameter.name), typeName: parameter.typeReference.name }]
            + java_script_parameter_bindings(parameters[1:])

/// Emits JavaScript code for expression.
private fun java_script_expression_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledUnsupportedExpression unsupported ->
        if java_script_compiled_placeholder_source(unsupported.source)
        then java_script_placeholder_code(unsupported, module)
        else "__capy_unsupported(" + java_script_string_literal(unsupported.source) + ")"
    case CompiledThrowExpression throwExpression -> java_script_throw_expression_code(throwExpression, env, module, allModules)
    case CompiledTryCatchExpression tryCatch -> java_script_try_catch_expression_code(tryCatch, env, module, allModules)
    case CompiledIntLiteral literal -> literal.source
    case CompiledLongLiteral literal -> java_script_integer_literal(literal.source)
    case CompiledFloatLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledDoubleLiteral literal -> java_script_decimal_literal(literal.source)
    case CompiledBoolLiteral literal -> if literal.value then "true" else "false"
    case CompiledStringLiteral literal -> java_script_string_literal(literal.value)
    case CompiledVariableExpression variable -> java_script_variable_code(variable.name, env, module, allModules)
    case CompiledIfExpression ifExpression ->
        "("
            + java_script_truthy_expression_code(ifExpression.condition, env, module, allModules)
            + " ? "
            + java_script_expression_code(ifExpression.thenBranch, env, module, allModules)
            + " : "
            + java_script_expression_code(ifExpression.elseBranch, env, module, allModules)
            + ")"
    case CompiledBinaryExpression binary -> java_script_binary_expression_code(binary, env, module, allModules)
    case CompiledUnaryExpression unary -> java_script_unary_expression_code(unary, env, module, allModules)
    case CompiledFunctionCallExpression call -> java_script_function_call_code(call, env, module, allModules)
    case CompiledFunctionReferenceExpression reference -> java_script_function_call_name(reference.name, [], module, allModules)
    case CompiledMethodCallExpression call -> java_script_method_call_code(call, env, module, allModules)
    case CompiledWithExpression withExpression -> java_script_with_expression_code(withExpression, env, module, allModules)
    case CompiledLambdaExpression lambda -> java_script_lambda_expression_code(lambda, env, module, allModules)
    case CompiledListLiteral literal -> "[" + java_script_expression_list_code(literal.values, env, module, allModules) + "]"
    case CompiledSetLiteral literal -> "__capy_set([" + java_script_expression_list_code(literal.values, env, module, allModules) + "])"
    case CompiledDictLiteral literal -> "new Map([" + java_script_dict_entries_code(literal.entries, env, module, allModules) + "])"
    case CompiledTupleLiteral literal -> java_script_tuple_literal_code(literal, env, module, allModules)
    case CompiledIndexExpression index -> java_script_index_expression_code(index, env, module, allModules)
    case CompiledDataLiteral literal -> java_script_data_literal_code(literal, env, module, allModules)
    case CompiledFieldAccessExpression access ->
        if java_script_enum_static_field_access(access, env, module, allModules)
        then java_script_enum_static_field_access_code(access, module, allModules)
        else "__capy_get_field(" + java_script_expression_code(access.receiver, env, module, allModules) + ", " + java_script_string_literal(access.name) + ")"
    case CompiledReduceExpression reduce -> java_script_reduce_expression_code(reduce, env, module, allModules)
    case CompiledMatchExpression matchExpression -> java_script_match_expression_code(matchExpression, env, module, allModules)
    case CompiledBlockExpression block -> java_script_block_expression_code(block, env, module, allModules)

/// Emits JavaScript code for OO throw expression.
private fun java_script_throw_expression_code(throwExpression: CompiledThrowExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_throw(" + java_script_expression_code(throwExpression.value, env, module, allModules) + ")"

/// Emits JavaScript code for OO try/catch expression.
private fun java_script_try_catch_expression_code(tryCatch: CompiledTryCatchExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_try(() => "
        + java_script_expression_code(tryCatch.body, env, module, allModules)
        + ", ["
        + java_script_try_catch_branch_codes(tryCatch.branches, env, module, allModules)
        + "])"

/// Emits JavaScript branch tuples for OO try/catch expression.
private fun java_script_try_catch_branch_codes(branches: List[CompiledTryCatchBranch], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match branches[0] with
    case None -> ""
    case Some { branch } ->
        let catchName = java_script_identifier(branch.catchName)
        let catchEnv = [JavaScriptBinding { name: branch.catchName, jsName: catchName, typeName: "Error" }] + env
        "["
            + (if branch.hasKind then java_script_string_literal(branch.kind) else "null")
            + ", ("
            + catchName
            + ") => "
            + java_script_expression_code(branch.catchBody, catchEnv, module, allModules)
            + "]"
            + java_script_try_catch_branch_tail_codes(branches[1:], env, module, allModules)

/// Emits JavaScript branch tuple tails for OO try/catch expression.
private fun java_script_try_catch_branch_tail_codes(branches: List[CompiledTryCatchBranch], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match branches[0] with
    case None -> ""
    case Some _ -> ", " + java_script_try_catch_branch_codes(branches, env, module, allModules)

/// Emits JavaScript code for placeholder.
private fun java_script_placeholder_code(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    "__capy_not_implemented(" + java_script_string_literal(java_script_placeholder_message(placeholder, module)) + ")"

/// Formats JavaScript source text for placeholder message.
private fun java_script_placeholder_message(placeholder: CompiledUnsupportedExpression, module: CompiledModule): String =
    let functionName = java_script_placeholder_function_name(placeholder.source)
    if functionName.is_empty()
    then "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + java_script_module_source_file(module) + ": placeholder expression is not yet implemented"
    else "line " + placeholder.location.line + ", column " + placeholder.location.column + ", file " + java_script_module_source_file(module) + ": the function `" + functionName + "` is not yet implemented"

/// Extracts compiled metadata for placeholder source.
private fun java_script_compiled_placeholder_source(source: String): bool =
    java_script_string_has_prefix(source, "__capy_placeholder__|")

/// Computes the JavaScript name for placeholder function.
private fun java_script_placeholder_function_name(source: String): String =
    if java_script_compiled_placeholder_source(source)
    then source["__capy_placeholder__|".size().value, source.size().value]
    else ""

/// Formats JavaScript source text for module source file.
private fun java_script_module_source_file(module: CompiledModule): String =
    if module.path.is_empty()
    then "/" + module.name + ".cfun"
    else "/" + module.path + "/" + module.name + ".cfun"

/// Emits JavaScript code for variable.
private fun java_script_variable_code(name: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_lookup_binding(name, env) with
    case Some { binding } -> binding.jsName
    case None ->
        if java_script_qualified_enum_value_name(name, module, allModules)
        then java_script_enum_qualified_value_code(name, module, allModules)
        else match java_script_find_local_constant(name, module.functions) with
        case Some { function } -> java_script_constant_name(function)
        case None ->
            match java_script_find_constant_in_imports(name, module.imports, module, allModules) with
            case Some { binding } -> binding
            case None ->
                match java_script_imported_stdlib_constant_code(name, module.imports) with
                case Some { binding } -> binding
                case None -> java_script_identifier(name)

/// Emits JavaScript code for binary expression.
private fun java_script_binary_expression_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = java_script_expression_type(binary.left, env, module, allModules)
    if java_script_result_reduce_operator_expression_with_left_type(binary, leftType)
    then java_script_result_reduce_operator_code(binary, env, module, allModules)
    else if java_script_collection_reduce_operator_expression_with_left_type(binary, leftType)
    then java_script_collection_reduce_operator_code(binary, env, module, allModules)
    else if java_script_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then java_script_method_call_code(java_script_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if java_script_async_pipe_expression_with_left_type(binary, leftType)
    then java_script_async_pipe_code(binary, env, module, allModules)
    else if java_script_result_pipe_expression_with_left_type(binary, leftType)
    then java_script_result_pipe_code(binary, env, module, allModules)
    else if java_script_option_pipe_expression_with_left_type(binary, leftType)
    then java_script_option_pipe_code(binary, env, module, allModules)
    else if java_script_collection_or_unknown_pipe_expression_with_left_type(binary, leftType)
    then java_script_collection_pipe_code(binary, env, module, allModules)
    else if java_script_set_binary_expression_with_left_type(binary, leftType)
    then java_script_set_binary_code(binary, env, module, allModules)
    else if java_script_regex_binary_expression_with_left_type(binary, leftType)
    then java_script_regex_binary_code(binary, env, module, allModules)
    else match java_script_find_local_binary_extension_operator_with_left_type(binary, leftType, module.functions) with
    case Some { function } -> java_script_binary_extension_operator_code(function, binary, env, module, allModules)
    case None ->
        if binary.operator == "+"
        then java_script_binary_runtime_call("__capy_add", binary, env, module, allModules)
        else if binary.operator == "-"
        then java_script_binary_runtime_call("__capy_sub", binary, env, module, allModules)
        else if binary.operator == "*"
        then java_script_binary_runtime_call("__capy_mul", binary, env, module, allModules)
        else if binary.operator == "/"
        then java_script_binary_runtime_call("__capy_div", binary, env, module, allModules)
        else if binary.operator == "%"
        then java_script_binary_runtime_call("__capy_mod", binary, env, module, allModules)
        else if binary.operator == "^"
        then java_script_binary_runtime_call("__capy_pow", binary, env, module, allModules)
        else if binary.operator == "?"
        then java_script_binary_runtime_call("__capy_contains", binary, env, module, allModules)
        else if binary.operator == "=="
        then java_script_binary_runtime_call("__capy_deep_equal", binary, env, module, allModules)
        else if binary.operator == "!="
        then "(!" + java_script_binary_runtime_call("__capy_deep_equal", binary, env, module, allModules) + ")"
        else if binary.operator == ".nand."
        then "(~(" + java_script_expression_code(binary.left, env, module, allModules)
            + " & "
            + java_script_expression_code(binary.right, env, module, allModules)
            + "))"
        else if java_script_bitwise_binary_operator(binary.operator)
        then "("
            + java_script_expression_code(binary.left, env, module, allModules)
            + " "
            + java_script_bitwise_operator(binary.operator)
            + " "
            + java_script_expression_code(binary.right, env, module, allModules)
            + ")"
        else if binary.operator == "&" | binary.operator == "|"
        then "("
            + java_script_truthy_expression_code(binary.left, env, module, allModules)
            + " "
            + java_script_boolean_operator(binary.operator)
            + " "
            + java_script_truthy_expression_code(binary.right, env, module, allModules)
            + ")"
        else "("
            + java_script_expression_code(binary.left, env, module, allModules)
            + " "
            + java_script_binary_operator(binary.operator)
            + " "
            + java_script_expression_code(binary.right, env, module, allModules)
            + ")"

/// Emits JavaScript code for collection pipe.
private fun java_script_collection_pipe_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_pipe_code(java_script_collection_pipe_helper(binary.operator), binary, env, module, allModules)

/// Checks whether a type reference matches the collection pipe chained method expression with left type rule.
private fun java_script_collection_pipe_chained_method_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_collection_pipe_operator(binary.operator)
        & (java_script_collection_pipe_receiver_type(leftType) | leftType == java_script_unknown_type())
        & match binary.right with
            case CompiledMethodCallExpression call -> java_script_callable_expression(call.receiver)
            case _ -> false

/// Resolves expression metadata for collection pipe chained method call.
private fun java_script_collection_pipe_chained_method_call(binary: CompiledBinaryExpression): CompiledMethodCallExpression =
    match binary.right with
    case CompiledMethodCallExpression call ->
        CompiledMethodCallExpression {
            receiver: CompiledBinaryExpression {
                operator: binary.operator,
                left: binary.left,
                right: call.receiver,
                location: binary.location
            },
            name: call.name,
            arguments: call.arguments,
            location: call.location
        }
    case _ ->
        CompiledMethodCallExpression {
            receiver: binary,
            name: "",
            arguments: [],
            location: binary.location
        }

/// Emits JavaScript runtime helper source for collection pipe helper.
private fun java_script_collection_pipe_helper(operator: String): String =
    if operator == "|-"
    then "__capy_seq_filter"
    else if operator == "|*"
    then "__capy_seq_flat_map"
    else "__capy_seq_map"

/// Emits JavaScript code for option pipe.
private fun java_script_option_pipe_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_pipe_code(java_script_option_pipe_helper(binary.operator), binary, env, module, allModules)

/// Emits JavaScript runtime helper source for option pipe helper.
private fun java_script_option_pipe_helper(operator: String): String =
    if operator == "|-"
    then "__capy_option_filter"
    else if operator == "|*"
    then "__capy_option_flat_map"
    else "__capy_option_map"

/// Emits JavaScript code for result pipe.
private fun java_script_result_pipe_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_result_pipe_helper(binary.operator)
        + "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + ", "
        + java_script_result_callable_code(binary.left, binary.right, env, module, allModules)
        + ")"

/// Emits JavaScript code for async pipe.
private fun java_script_async_pipe_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_async_pipe_helper(binary.operator)
        + "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + ", "
        + java_script_expression_code(binary.right, env, module, allModules)
        + ")"

/// Emits JavaScript runtime helper source for async pipe helper.
private fun java_script_async_pipe_helper(operator: String): String =
    if operator == "|*"
    then "__capy_async_flat_map"
    else "__capy_async_map"

/// Emits JavaScript code for result reduce operator.
private fun java_script_result_reduce_operator_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledTupleLiteral literal ->
        "__capy_result_reduce("
            + java_script_expression_code(binary.left, env, module, allModules)
            + ", "
            + java_script_result_reduce_success_callable_code(binary.left, literal.values, env, module, allModules)
            + ", "
            + java_script_result_reduce_error_callable_code(literal.values, env, module, allModules)
            + ")"
    case _ -> "__capy_unsupported('result reduce')"

private fun java_script_collection_reduce_operator_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledTupleLiteral literal ->
        java_script_collection_reduce_method_code(
            CompiledMethodCallExpression {
                receiver: binary.left,
                name: "reduce",
                arguments: literal.values,
                location: binary.location
            },
            env,
            module,
            allModules
        )
    case _ -> "__capy_unsupported('collection reduce')"

private fun java_script_tuple_literal_code(literal: CompiledTupleLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_reduce_tuple_literal_call(literal.values) with
    case Some { call } ->
        if java_script_result_reduce_method_call(call, env, module, allModules)
        then java_script_result_reduce_method_call_code(call, env, module, allModules)
        else java_script_collection_reduce_method_code(call, env, module, allModules)
    case None -> "__capy_tuple([" + java_script_expression_list_code(literal.values, env, module, allModules) + "])"

private fun java_script_reduce_tuple_literal_call(values: List[CompiledExpression]): /capy/lang/Option[CompiledMethodCallExpression] =
    match values[0] with
    case None -> /capy/lang/Option.None {}
    case Some { first } ->
        match values[1] with
        case None -> /capy/lang/Option.None {}
        case Some { reducer } ->
            if values[2:].is_empty() & java_script_callable_expression(reducer)
            then match first with
                case CompiledBinaryExpression binary ->
                    if binary.operator == "|>"
                    then /capy/lang/Option.Some {
                        CompiledMethodCallExpression {
                            receiver: binary.left,
                            name: "reduce",
                            arguments: [binary.right, reducer],
                            location: binary.location
                        }
                    }
                    else /capy/lang/Option.None {}
                case _ -> /capy/lang/Option.None {}
            else /capy/lang/Option.None {}

/// Emits JavaScript code for pipe.
private fun java_script_pipe_code(helper: String, binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_binary_runtime_call(helper, binary, env, module, allModules)

/// Emits JavaScript runtime helper source for result pipe helper.
private fun java_script_result_pipe_helper(operator: String): String =
    if operator == "|*"
    then "__capy_result_flat_map"
    else "__capy_result_map"

/// Emits JavaScript code for result callable.
private fun java_script_result_callable_code(receiver: CompiledExpression, mapper: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match mapper with
    case CompiledLambdaExpression lambda ->
        java_script_lambda_expression_code_with_bindings(
            lambda,
            java_script_lambda_bindings_with_single_type(lambda.parameters, java_script_result_payload_type(receiver, env, module, allModules)),
            env,
            module,
            allModules
        )
    case _ -> java_script_expression_code(mapper, env, module, allModules)

/// Emits JavaScript code for result reduce success callable.
private fun java_script_result_reduce_success_callable_code(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> "__capy_unsupported('result reduce success mapper')"
    case Some { argument } -> java_script_result_callable_code(receiver, argument, env, module, allModules)

/// Emits JavaScript code for result reduce error callable.
private fun java_script_result_reduce_error_callable_code(arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[1] with
    case None -> "__capy_unsupported('result reduce error mapper')"
    case Some { argument } -> java_script_expression_code(argument, env, module, allModules)

/// Checks whether a type reference matches the result pipe expression with left type rule.
private fun java_script_result_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_result_pipe_operator(binary.operator)
        & java_script_result_pipe_receiver_type(leftType)
        & java_script_callable_expression(binary.right)

/// Checks whether a type reference matches the async pipe expression with left type rule.
private fun java_script_async_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_result_pipe_operator(binary.operator)
        & java_script_type_unqualified_name(leftType) == "Async"
        & java_script_callable_expression(binary.right)

/// Checks whether an operator belongs to the result reduce operator expression with left type category.
private fun java_script_result_reduce_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    binary.operator == "|>"
        & java_script_result_pipe_receiver_type(leftType)
        & java_script_result_reduce_operator_arguments_shape(binary.right)

/// Checks whether an operator belongs to the result reduce operator arguments shape category.
private fun java_script_result_reduce_operator_arguments_shape(expression: CompiledExpression): bool =
    match expression with
    case CompiledTupleLiteral literal -> java_script_two_callable_arguments(literal.values)
    case _ -> false

private fun java_script_collection_reduce_operator_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    binary.operator == "|>"
        & (java_script_collection_pipe_receiver_type(leftType) | leftType == java_script_unknown_type())
        & java_script_collection_reduce_operator_arguments_shape(binary.right)

private fun java_script_collection_reduce_operator_arguments_shape(expression: CompiledExpression): bool =
    match expression with
    case CompiledTupleLiteral literal ->
        if java_script_two_method_arguments(literal.values)
        then match literal.values[1] with
            case Some { reducer } -> java_script_callable_expression(reducer)
            case None -> false
        else false
    case _ -> false

/// Checks whether an operator belongs to the result pipe operator category.
private fun java_script_result_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|*"

/// Checks whether a type reference matches the result pipe receiver type rule.
private fun java_script_result_pipe_receiver_type(typeName: String): bool =
    let baseType = java_script_type_unqualified_name(typeName)
    baseType == "Result"
        | java_script_result_constructor_type(baseType)

/// Checks whether a type reference matches the option pipe expression with left type rule.
private fun java_script_option_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_option_pipe_operator(binary.operator)
        & java_script_option_pipe_receiver_type(leftType)
        & java_script_callable_expression(binary.right)

/// Checks whether an operator belongs to the option pipe operator category.
private fun java_script_option_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*"

/// Checks whether a type reference matches the option pipe receiver type rule.
private fun java_script_option_pipe_receiver_type(typeName: String): bool =
    let baseType = java_script_type_unqualified_name(typeName)
    baseType == "Option"
        | java_script_option_constructor_type(baseType)

/// Checks whether a type reference matches the option constructor type rule.
private fun java_script_option_constructor_type(typeName: String): bool =
    java_script_stdlib_data_constructor_name(typeName, "Option", "Some")
        | java_script_stdlib_data_constructor_name(typeName, "Option", "None")

/// Checks whether a type reference matches the result constructor type rule.
private fun java_script_result_constructor_type(typeName: String): bool =
    java_script_stdlib_data_constructor_name(typeName, "Result", "Success")
        | java_script_stdlib_data_constructor_name(typeName, "Result", "Error")

/// Checks whether constructor metadata matches the standard-library data constructor name rule.
private fun java_script_stdlib_data_constructor_name(typeName: String, family: String, ctor: String): bool =
    typeName == ctor
        | typeName == family + "." + ctor
        | typeName == "/capy/lang/" + family + "." + ctor

/// Checks whether a type reference matches the collection or unknown pipe expression with left type rule.
private fun java_script_collection_or_unknown_pipe_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_collection_pipe_operator(binary.operator)
        & (java_script_collection_pipe_receiver_type(leftType) | leftType == java_script_unknown_type())
        & java_script_callable_expression(binary.right)

/// Checks whether an operator belongs to the collection pipe operator category.
private fun java_script_collection_pipe_operator(operator: String): bool =
    operator == "|" | operator == "|-" | operator == "|*"

/// Checks whether a type reference matches the collection pipe receiver type rule.
private fun java_script_collection_pipe_receiver_type(typeName: String): bool =
    java_script_collection_receiver_type(typeName)

/// Checks whether a type reference matches the set binary expression with left type rule.
private fun java_script_set_binary_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_type_unqualified_name(leftType) == "Set" & java_script_set_binary_operator(binary.operator)

/// Checks whether an operator belongs to the set binary operator category.
private fun java_script_set_binary_operator(operator: String): bool =
    java_script_set_predicate_operator(operator) | java_script_set_algebra_operator(operator)

/// Checks whether an operator belongs to the set predicate operator category.
private fun java_script_set_predicate_operator(operator: String): bool =
    operator == "⊆" | operator == "⊂" | operator == "⊇" | operator == "⊃"

/// Checks whether an operator belongs to the set algebra operator category.
private fun java_script_set_algebra_operator(operator: String): bool =
    operator == "∪" | operator == "∩" | operator == "△" | operator == "×"

/// Emits JavaScript code for set binary.
private fun java_script_set_binary_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = java_script_expression_code(binary.left, env, module, allModules)
    let rightCode = java_script_expression_code(binary.right, env, module, allModules)
    java_script_set_operation_code(binary.operator, leftCode, rightCode)

/// Emits JavaScript code for set operation.
private fun java_script_set_operation_code(operator: String, leftCode: String, rightCode: String): String =
    if operator == "?"
    then "__capy_contains(" + leftCode + ", " + rightCode + ")"
    else if operator == "⊆"
    then "__capy_set_subset(" + leftCode + ", " + rightCode + ")"
    else if operator == "⊂"
    then "__capy_set_proper_subset(" + leftCode + ", " + rightCode + ")"
    else if operator == "⊇"
    then "__capy_set_subset(" + rightCode + ", " + leftCode + ")"
    else if operator == "⊃"
    then "__capy_set_proper_subset(" + rightCode + ", " + leftCode + ")"
    else if operator == "∪"
    then "__capy_set_concat(" + leftCode + ", " + rightCode + ")"
    else if operator == "∩"
    then "__capy_set_intersection(" + leftCode + ", " + rightCode + ")"
    else if operator == "-"
    then "__capy_set_remove_all(" + leftCode + ", " + rightCode + ")"
    else if operator == "△"
    then "__capy_set_symmetric_difference(" + leftCode + ", " + rightCode + ")"
    else "__capy_set_cartesian_product(" + leftCode + ", " + rightCode + ")"

/// Checks whether a type reference matches the regex binary expression with left type rule.
private fun java_script_regex_binary_expression_with_left_type(binary: CompiledBinaryExpression, leftType: String): bool =
    java_script_regex_receiver_type(leftType) & java_script_regex_binary_operator(binary.operator)

/// Checks whether an operator belongs to the regex binary operator category.
private fun java_script_regex_binary_operator(operator: String): bool =
    operator == "?" | operator == "~" | operator == "~~" | operator == "~>" | operator == "/>"

/// Emits JavaScript code for regex binary.
private fun java_script_regex_binary_code(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftCode = java_script_expression_code(binary.left, env, module, allModules)
    let rightCode = java_script_expression_code(binary.right, env, module, allModules)
    java_script_regex_operation_code(binary.operator, leftCode, rightCode)

/// Emits JavaScript code for regex operation.
private fun java_script_regex_operation_code(operator: String, receiverCode: String, argumentCode: String): String =
    if operator == "?"
    then "__capy_regex_matches(" + receiverCode + ", " + argumentCode + ")"
    else if operator == "~"
    then "__capy_regex_find(" + receiverCode + ", " + argumentCode + ")"
    else if operator == "~~"
    then "__capy_regex_find_all(" + receiverCode + ", " + argumentCode + ")"
    else if operator == "~>"
    then "__capy_regex_replace(" + receiverCode + ", " + argumentCode + ")"
    else "__capy_regex_split(" + receiverCode + ", " + argumentCode + ")"

/// Checks whether an expression has the callable expression shape.
private fun java_script_callable_expression(expression: CompiledExpression): bool =
    match expression with
    case CompiledLambdaExpression _ -> true
    case CompiledFunctionReferenceExpression _ -> true
    case _ -> false

/// Checks whether a type reference matches the callable binding type rule.
private fun java_script_callable_binding_type(typeName: String): bool =
    java_script_first_index_of(typeName, "=>", 0) >= 0

/// Emits JavaScript runtime support source for binary runtime call.
private fun java_script_binary_runtime_call(name: String, binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    name
        + "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + ", "
        + java_script_expression_code(binary.right, env, module, allModules)
        + ")"

/// Emits JavaScript code for binary extension operator.
private fun java_script_binary_extension_operator_code(function: CompiledFunction, binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_function_name(function)
        + "("
        + java_script_expression_code(binary.left, env, module, allModules)
        + java_script_extension_method_argument_tail([binary.right], env, module, allModules)
        + ")"

/// Maps binary to the JavaScript operator category.
private fun java_script_binary_operator(operator: String): String =
    if operator == "!="
    then "!=="
    else if operator == "=="
    then "==="
    else operator

/// Maps boolean to the JavaScript operator category.
private fun java_script_boolean_operator(operator: String): String =
    if operator == "&" then "&&" else "||"

/// Checks whether an operator belongs to the binary operator category.
private fun java_script_bitwise_binary_operator(operator: String): bool =
    operator == ".and." | operator == ".or." | operator == ".xor."

/// Maps bitwise to the JavaScript operator category.
private fun java_script_bitwise_operator(operator: String): String =
    if operator == ".and."
    then "&"
    else if operator == ".or."
    then "|"
    else if operator == ".xor."
    then "^"
    else operator

/// Emits JavaScript code for unary expression.
private fun java_script_unary_expression_code(unary: CompiledUnaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if unary.operator == "!"
    then "(!" + java_script_truthy_expression_code(unary.expression, env, module, allModules) + ")"
    else if unary.operator == ".not."
    then "(~" + java_script_expression_code(unary.expression, env, module, allModules) + ")"
    else "(" + unary.operator + java_script_expression_code(unary.expression, env, module, allModules) + ")"

/// Emits JavaScript code for function call.
private fun java_script_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_object_type_call(call)
    then java_script_object_type_call_code(call.name, module, allModules)
    else if java_script_stdlib_parse_function_call(call, module)
    then java_script_stdlib_parse_function_call_code(call, env, module, allModules)
    else if java_script_stdlib_effect_function_call(call, module)
    then java_script_stdlib_effect_function_call_code(call.name)
    else if java_script_oo_constructor_call(call.name, module, allModules)
    then java_script_oo_constructor_call_code(call, env, module, allModules)
    else if java_script_stdlib_path_function_call(call, module)
    then java_script_stdlib_path_function_call_code(call, env, module, allModules)
    else if java_script_stdlib_io_function_call(call, module)
    then java_script_stdlib_io_function_call_code(call, env, module, allModules)
    else if java_script_stdlib_math_sqrt_call(call, module)
    then "Math.sqrt(" + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if java_script_enum_parse_call(call, module, allModules)
    then java_script_enum_parse_call_code(call, env, module, allModules)
    else if java_script_reflection_function_call(call, module)
    then java_script_reflection_call_code(call, env, module, allModules)
    else
        let functionName = java_script_function_call_name(call.name, env, module, allModules)
        match java_script_function_call_definition(call.name, env, module, allModules) with
        case Some { function } ->
            functionName
                + "("
                + java_script_function_call_arguments(function.parameters, call.arguments, env, module, allModules)
                + ")"
        case None ->
            functionName
                + "("
                + java_script_expression_list_code(call.arguments, env, module, allModules)
                + ")"

/// Checks whether a type reference matches the object type call rule.
private fun java_script_object_type_call(call: CompiledFunctionCallExpression): bool =
    if call.arguments.is_empty()
    then java_script_object_type_call_name(call.name)
    else false

/// Checks whether a type reference matches the object type call name rule.
private fun java_script_object_type_call_name(name: String): bool =
    if java_script_qualified_call_name(name)
    then java_script_qualified_call_member(name) == "type"
    else false

/// Emits JavaScript code for object type call.
private fun java_script_object_type_call_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverName = java_script_qualified_call_qualifier(name)
    if java_script_object_type_exists(receiverName, module.functions)
    then java_script_object_constructor_name(receiverName) + ".type()"
    else match java_script_find_object_type_in_imports(receiverName, module.imports, module, allModules) with
    case Some { binding } -> binding + ".type()"
    case None ->
        match java_script_find_qualified_object_type_call(receiverName, module, allModules) with
        case Some { binding } -> binding + ".type()"
        case None -> java_script_identifier(name) + "()"

/// Checks whether a function matches the reflection function call metadata.
private fun java_script_reflection_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "reflection"
    then !java_script_local_function_exists("reflection", module.functions)
        & java_script_reflection_member_imported("reflection", module.imports)
        & match call.arguments[0] with
            case None -> false
            case Some _ -> call.arguments[1:].is_empty()
    else false

/// Emits JavaScript code for reflection call.
private fun java_script_reflection_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None -> "reflection()"
    case Some { value } ->
        let valueType = java_script_expression_type(value, env, module, allModules)
        if valueType == "data"
            | valueType == "enum"
            | valueType == java_script_unknown_type()
            | java_script_enum_type_exists(java_script_type_unqualified_name(valueType), module, allModules)
        then "reflection(" + java_script_expression_code(value, env, module, allModules) + ")"
        else "reflection("
            + java_script_expression_code(value, env, module, allModules)
            + ", "
            + java_script_string_literal(java_script_type_unqualified_name(valueType))
            + ")"

/// Emits JavaScript code for method call.
private fun java_script_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "__capy_call"
    then java_script_callable_call_code(call, env, module, allModules)
    else if java_script_size_method_call(call)
    then "__capy_size(" + java_script_expression_code(call.receiver, env, module, allModules) + ")"
    else
        let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
        let receiverBaseType = java_script_type_unqualified_name(receiverType)
        let receiver = java_script_expression_code(call.receiver, env, module, allModules)
        let emptyArguments = call.arguments.is_empty()
        let oneArgument = java_script_one_method_argument(call.arguments)
        let twoArguments = java_script_two_method_arguments(call.arguments)
        if call.name == "name" & emptyArguments & java_script_enum_name_receiver_type(receiverType, module, allModules)
        then "__capy_enum_name(" + receiver + ")"
        else if call.name == "to_string" & emptyArguments & java_script_char_to_string_receiver_type(receiverType)
        then "__capy_to_string(" + receiver + ")"
        else if call.name == "get" & (oneArgument | twoArguments) & receiverType == "String"
        then java_script_string_get_method_code(call, env, module, allModules)
        else if java_script_string_parse_method_name(call.name) & emptyArguments & java_script_string_parse_receiver_type(receiverType)
        then java_script_string_parse_method_code(call, env, module, allModules)
        else if java_script_string_method_arity(call.name, call.arguments) & java_script_string_method_receiver_type(call.name, receiverType)
        then java_script_string_method_code(call, env, module, allModules)
        else if java_script_regex_method_arity(call) & java_script_regex_receiver_type(receiverType)
        then java_script_regex_method_call_code(call, env, module, allModules)
        else if java_script_date_time_method_candidate(call.name, emptyArguments, oneArgument, twoArguments)
            & java_script_date_time_method_call(receiverBaseType, call.name, emptyArguments, oneArgument, twoArguments)
        then java_script_date_time_method_call_code(
            receiverBaseType,
            call.name,
            receiver,
            java_script_first_method_argument_code(call.arguments, env, module, allModules),
            java_script_second_method_argument_code(call.arguments, env, module, allModules)
        )
        else if call.name == "is_empty" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then "(__capy_size(" + receiver + ") === 0)"
        else if call.name == "get" & (oneArgument | twoArguments) & java_script_collection_get_receiver_type(receiverBaseType) & java_script_collection_get_arity(receiverBaseType, call.arguments)
        then java_script_collection_get_call_code_with_receiver_type(call, receiverBaseType, receiver, env, module, allModules)
        else if (call.name == "contains" | call.name == "contains_key") & oneArgument & ((call.name == "contains" & java_script_collection_contains_receiver_type(receiverBaseType)) | (call.name == "contains_key" & receiverBaseType == "Dict"))
        then java_script_collection_contains_call_code(call, env, module, allModules)
        else if java_script_set_method_arity(call) & receiverBaseType == "Set"
        then java_script_set_method_call_code(call, env, module, allModules)
        else if java_script_seq_as_list_call(call)
        then "__capy_as_list(" + receiver + ")"
        else if call.name == "first" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then java_script_collection_first_call_code(call, env, module, allModules)
        else if call.name == "start" & emptyArguments & receiverType == "Effect"
        then "__capy_async_start(" + receiver + ")"
        else if call.name == "join" & emptyArguments & receiverBaseType == "Async"
        then "__capy_async_join(" + receiver + ")"
        else if java_script_async_map_method_name(call.name) & java_script_single_callable_argument(call.arguments) & receiverBaseType == "Async"
        then java_script_async_pipe_code(java_script_async_map_method_binary(call), env, module, allModules)
        else if java_script_collection_method_name(call.name) & java_script_single_callable_argument(call.arguments) & java_script_collection_pipe_receiver_type(receiverType)
        then java_script_collection_method_call_code(call, env, module, allModules)
        else if java_script_collection_reduce_method_call_with_receiver_type(call, receiverType)
        then java_script_collection_reduce_method_code_with_receiver_type(call, receiverBaseType, env, module, allModules)
        else if (call.name == "any" | call.name == "all") & java_script_single_callable_argument(call.arguments) & java_script_collection_receiver_type(receiverType)
        then java_script_collection_predicate_call_code(call, env, module, allModules)
        else if java_script_primitive_conversion_method(call.name) & emptyArguments & java_script_primitive_conversion_receiver(call.name, receiverType)
        then java_script_primitive_conversion_code(call, env, module, allModules)
        else if (call.name == "reduce" | call.name == "reduce_left") & twoArguments & java_script_result_pipe_receiver_type(receiverType)
        then java_script_result_reduce_method_call_code(call, env, module, allModules)
        else if java_script_oo_method_call_with_receiver_type(call, receiverType, module, allModules)
        then java_script_raw_method_call_code(call, env, module, allModules)
        else match java_script_find_local_extension_method_with_receiver_type(receiverType, call, module) with
            case Some { function } -> java_script_extension_method_call_code(function, call, env, module, allModules)
            case None ->
                match java_script_find_imported_method_function(receiverType, call.name, module.imports, module, allModules) with
                case Some { binding } -> java_script_extension_method_binding_call_code(binding, call, env, module, allModules)
                case None -> java_script_raw_method_call_code(call, env, module, allModules)

/// Emits JavaScript code for object-oriented constructor call.
private fun java_script_oo_constructor_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_oo_constructor_call_name(call.name, module, allModules) with
    case Some { constructorName } ->
        constructorName
            + "("
            + java_script_expression_list_code(call.arguments, env, module, allModules)
            + ")"
    case None ->
        java_script_object_constructor_name(call.name)
            + "("
            + java_script_expression_list_code(call.arguments, env, module, allModules)
            + ")"

/// Checks whether a call has the object-oriented constructor call shape.
private fun java_script_oo_constructor_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match java_script_oo_constructor_call_name(name, module, allModules) with
    case Some _ -> true
    case None -> false

/// Computes the JavaScript name for object-oriented constructor call.
private fun java_script_oo_constructor_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    if java_script_qualified_call_name(name)
    then java_script_find_qualified_object_constructor_call(name, module, allModules)
    else if java_script_object_class_exists(name, module.functions)
    then /capy/lang/Option.Some { java_script_object_constructor_name(name) }
    else java_script_find_object_constructor_in_imports(name, module.imports, module, allModules)

/// Computes the JavaScript type for object-oriented constructor call payload.
private fun java_script_oo_constructor_call_payload_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_qualified_call_name(name)
    then match java_script_find_qualified_object_constructor_payload_type(name, module, allModules) with
        case Some { typeName } -> typeName
        case None -> java_script_unknown_type()
    else if java_script_object_class_exists(name, module.functions)
    then java_script_object_type_name(module, name)
    else match java_script_find_object_constructor_payload_type_in_imports(name, module.imports, module, allModules) with
        case Some { typeName } -> typeName
        case None -> java_script_unknown_type()

/// Finds an object constructor payload type in imports in scope, imports, or compiled modules.
private fun java_script_find_object_constructor_payload_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_option_string_identity(java_script_find_object_constructor_payload_type_in_imports(name, imports[1:], module, allModules))
        else if !java_script_import_includes_name(name, declaration)
        then java_script_option_string_identity(java_script_find_object_constructor_payload_type_in_imports(name, imports[1:], module, allModules))
        else java_script_find_object_constructor_payload_type_in_import(name, declaration, imports[1:], module, allModules)

/// Finds an object constructor payload type in import in scope, imports, or compiled modules.
private fun java_script_find_object_constructor_payload_type_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_class_exported(name, importedModule.functions)
        then /capy/lang/Option.Some { java_script_object_type_name(importedModule, name) }
        else java_script_option_string_identity(java_script_find_object_constructor_payload_type_in_imports(name, rest, module, allModules))
    case None -> java_script_option_string_identity(java_script_find_object_constructor_payload_type_in_imports(name, rest, module, allModules))

/// Finds an object constructor in imports in scope, imports, or compiled modules.
private fun java_script_find_object_constructor_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_find_object_constructor_in_imports(name, imports[1:], module, allModules)
        else if !java_script_import_includes_name(name, declaration)
        then java_script_find_object_constructor_in_imports(name, imports[1:], module, allModules)
        else java_script_find_object_constructor_in_import(name, declaration, imports[1:], module, allModules)

/// Finds an object constructor in import in scope, imports, or compiled modules.
private fun java_script_find_object_constructor_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_class_exported(name, importedModule.functions)
        then /capy/lang/Option.Some { java_script_imported_object_constructor_binding(declaration, name, module) }
        else java_script_find_object_constructor_in_imports(name, rest, module, allModules)
    case None -> java_script_find_object_constructor_in_imports(name, rest, module, allModules)

/// Finds an object type in imports in scope, imports, or compiled modules.
private fun java_script_find_object_type_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then java_script_option_string_identity(java_script_find_object_type_in_imports(name, imports[1:], module, allModules))
        else if !java_script_import_includes_name(name, declaration)
        then java_script_option_string_identity(java_script_find_object_type_in_imports(name, imports[1:], module, allModules))
        else java_script_find_object_type_in_import(name, declaration, imports[1:], module, allModules)

/// Finds an object type in import in scope, imports, or compiled modules.
private fun java_script_find_object_type_in_import(name: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_type_exported(name, importedModule.functions)
        then /capy/lang/Option.Some { java_script_imported_object_constructor_binding(declaration, name, module) }
        else java_script_option_string_identity(java_script_find_object_type_in_imports(name, rest, module, allModules))
    case None -> java_script_option_string_identity(java_script_find_object_type_in_imports(name, rest, module, allModules))

/// Finds a qualified object constructor call in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let idx = java_script_last_dot_index(name)
    let qualifier = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    match java_script_find_qualified_object_constructor_in_imports(qualifier, member, module.imports, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding }
    case None -> java_script_find_qualified_object_constructor_in_modules(qualifier, member, module, allModules)

/// Finds a qualified object constructor in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !java_script_stdlib_import(declaration.modulePath) & java_script_qualified_import_matches(qualifier, declaration, module)
        then java_script_find_qualified_object_constructor_in_import(member, declaration, imports[1:], module, allModules)
        else java_script_find_qualified_object_constructor_in_imports(qualifier, member, imports[1:], module, allModules)

/// Finds a qualified object constructor in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_in_import(member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_class_exported(member, importedModule.functions)
        then /capy/lang/Option.Some { java_script_imported_object_constructor_binding(declaration, member, module) }
        else java_script_find_qualified_object_constructor_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules)
    case None -> java_script_find_qualified_object_constructor_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules)

/// Finds a qualified object constructor in a modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } ->
        if java_script_object_class_exported(member, targetModule.functions)
        then /capy/lang/Option.Some { java_script_module_object_constructor_binding(targetModule, member, module) }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

/// Finds a qualified object constructor payload type in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_payload_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let idx = java_script_last_dot_index(name)
    let qualifier = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    match java_script_find_qualified_object_constructor_payload_type_in_imports(qualifier, member, module.imports, module, allModules) with
    case Some { typeName } -> /capy/lang/Option.Some { typeName }
    case None -> java_script_find_qualified_object_constructor_payload_type_in_modules(qualifier, member, module, allModules)

/// Finds a qualified object constructor payload type in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_payload_type_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !java_script_stdlib_import(declaration.modulePath) & java_script_qualified_import_matches(qualifier, declaration, module)
        then java_script_find_qualified_object_constructor_payload_type_in_import(member, declaration, imports[1:], module, allModules)
        else java_script_option_string_identity(java_script_find_qualified_object_constructor_payload_type_in_imports(qualifier, member, imports[1:], module, allModules))

/// Finds a qualified object constructor payload type in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_payload_type_in_import(member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_class_exported(member, importedModule.functions)
        then /capy/lang/Option.Some { java_script_object_type_name(importedModule, member) }
        else java_script_option_string_identity(java_script_find_qualified_object_constructor_payload_type_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules))
    case None -> java_script_option_string_identity(java_script_find_qualified_object_constructor_payload_type_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules))

/// Finds a qualified object constructor payload type in modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_constructor_payload_type_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } ->
        if java_script_object_class_exported(member, targetModule.functions)
        then /capy/lang/Option.Some { java_script_object_type_name(targetModule, member) }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

/// Finds a qualified object type call in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_type_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let idx = java_script_last_dot_index(name)
    let qualifier = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    match java_script_find_qualified_object_type_in_imports(qualifier, member, module.imports, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding }
    case None -> java_script_find_qualified_object_type_in_modules(qualifier, member, module, allModules)

/// Finds a qualified object type in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_type_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified & !java_script_stdlib_import(declaration.modulePath) & java_script_qualified_import_matches(qualifier, declaration, module)
        then java_script_find_qualified_object_type_in_import(member, declaration, imports[1:], module, allModules)
        else java_script_option_string_identity(java_script_find_qualified_object_type_in_imports(qualifier, member, imports[1:], module, allModules))

/// Finds a qualified object type in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_type_in_import(member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_object_type_exported(member, importedModule.functions)
        then /capy/lang/Option.Some { java_script_imported_object_constructor_binding(declaration, member, module) }
        else java_script_option_string_identity(java_script_find_qualified_object_type_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules))
    case None -> java_script_option_string_identity(java_script_find_qualified_object_type_in_imports(java_script_module_leaf_name(java_script_import_module_path(declaration.modulePath, module)), member, rest, module, allModules))

/// Finds a qualified object type in a modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_object_type_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } ->
        if java_script_object_type_exported(member, targetModule.functions)
        then /capy/lang/Option.Some { java_script_module_object_constructor_binding(targetModule, member, module) }
        else /capy/lang/Option.None {}
    case None -> /capy/lang/Option.None {}

/// Collects imported object constructor binding visible to the current module.
private fun java_script_imported_object_constructor_binding(declaration: CompiledImportDeclaration, name: String, module: CompiledModule): String =
    java_script_import_alias(declaration, module) + "[" + java_script_string_literal(name) + "]"

/// Creates one JavaScript name/type binding for module object constructor.
private fun java_script_module_object_constructor_binding(targetModule: CompiledModule, name: String, module: CompiledModule): String =
    "require("
        + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), java_script_module_path(targetModule)))
        + ")["
        + java_script_string_literal(name)
        + "]"

/// Checks whether method metadata matches the object-oriented method call rule.
private fun java_script_oo_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
    java_script_oo_method_call_with_receiver_type(call, receiverType, module, allModules)

private fun java_script_oo_method_call_with_receiver_type(call: CompiledMethodCallExpression, receiverType: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if !java_script_object_receiver_type(receiverType)
    then false
    else
        let typeName = java_script_type_unqualified_name(receiverType)
        java_script_object_method_exists_in_module(typeName, call.name, module)
            | java_script_object_method_exists_in_other_modules(typeName, call.name, module, allModules)

/// Checks whether a compiled type name can resolve to object-oriented metadata.
private fun java_script_object_receiver_type(typeName: String): bool =
    java_script_string_has_prefix(typeName, "__capy_oo|")

/// Emits JavaScript code for callable call.
private fun java_script_callable_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "(" + java_script_expression_code(call.receiver, env, module, allModules) + ")("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

/// Emits JavaScript code for raw method call.
private fun java_script_raw_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_expression_code(call.receiver, env, module, allModules)
        + "."
        + java_script_method_name(call.name)
        + "("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

/// Checks whether a call has the seq as list call shape.
private fun java_script_seq_as_list_call(call: CompiledMethodCallExpression): bool =
    call.name == "as_list" & call.arguments.is_empty()

/// Checks whether a call has the collection first call shape.
private fun java_script_collection_first_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "first"
    then
        if call.arguments.is_empty()
        then java_script_collection_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Emits JavaScript code for collection first call.
private fun java_script_collection_first_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_index(__capy_as_list("
        + java_script_expression_code(call.receiver, env, module, allModules)
        + "), 0, "
        + java_script_string_literal("List")
        + ")"

/// Checks whether method metadata matches the size method call rule.
private fun java_script_size_method_call(call: CompiledMethodCallExpression): bool =
    call.name == "size" & call.arguments.is_empty()

/// Checks whether method metadata matches the enum name method call rule.
private fun java_script_enum_name_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "name"
    then
        if call.arguments.is_empty()
        then java_script_enum_name_receiver_type(java_script_expression_type(call.receiver, env, module, allModules), module, allModules)
        else false
    else false

/// Checks whether a type reference matches the enum name receiver type rule.
private fun java_script_enum_name_receiver_type(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    typeName == java_script_unknown_type()
        | typeName == "enum"
        | java_script_enum_type_exists(typeName, module, allModules)

/// Checks whether a call has the collection is empty call shape.
private fun java_script_collection_is_empty_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "is_empty"
    then
        if call.arguments.is_empty()
        then java_script_collection_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether method metadata matches the effect method call rule.
private fun java_script_effect_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "map" | call.name == "flat_map" | call.name == "flatMap"
    then
        if java_script_single_callable_argument(call.arguments)
        then java_script_expression_type(call.receiver, env, module, allModules) == "Effect"
        else false
    else false

private fun java_script_effect_start_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "start"
    then call.arguments.is_empty()
        & java_script_expression_type(call.receiver, env, module, allModules) == "Effect"
    else false

private fun java_script_async_join_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "join"
    then call.arguments.is_empty()
        & java_script_expression_type(call.receiver, env, module, allModules) == "Async"
    else false

private fun java_script_async_map_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_async_map_method_name(call.name)
    then
        if java_script_single_callable_argument(call.arguments)
        then java_script_expression_type(call.receiver, env, module, allModules) == "Async"
        else false
    else false

private fun java_script_async_map_method_name(name: String): bool =
    name == "map" | name == "flat_map" | name == "`|`" | name == "`|*`"

private fun java_script_async_map_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    CompiledBinaryExpression {
        operator: if call.name == "flat_map" | call.name == "`|*`" then "|*" else "|",
        left: call.receiver,
        right: java_script_first_method_argument(call.arguments),
        location: call.location
    }

/// Checks whether a call has the collection predicate call shape.
private fun java_script_collection_predicate_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "any" | call.name == "all"
    then
        if java_script_single_callable_argument(call.arguments)
        then java_script_collection_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether a type reference matches the collection receiver type rule.
private fun java_script_collection_receiver_type(typeName: String): bool =
    let baseType = java_script_type_unqualified_name(typeName)
    baseType == "List" | baseType == "Set" | baseType == "String" | baseType == "Seq" | baseType == "Dict"

/// Checks whether method metadata matches the collection method call rule.
private fun java_script_collection_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_collection_method_name(call.name)
    then
        if java_script_single_callable_argument(call.arguments)
        then java_script_collection_pipe_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether method metadata matches the collection method name rule.
private fun java_script_collection_method_name(name: String): bool =
    name == "map" | name == "filter" | name == "flat_map"

/// Emits JavaScript code for collection method call.
private fun java_script_collection_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_collection_pipe_code(java_script_collection_method_binary(call), env, module, allModules)

/// Resolves expression metadata for collection method binary.
private fun java_script_collection_method_binary(call: CompiledMethodCallExpression): CompiledBinaryExpression =
    match call.arguments[0] with
    case None ->
        CompiledBinaryExpression {
            operator: java_script_collection_method_operator(call.name),
            left: call.receiver,
            right: java_script_missing_argument(),
            location: call.location
        }
    case Some { argument } ->
        CompiledBinaryExpression {
            operator: java_script_collection_method_operator(call.name),
            left: call.receiver,
            right: argument,
            location: call.location
        }

/// Maps collection method to the JavaScript operator category.
private fun java_script_collection_method_operator(name: String): String =
    if name == "filter"
    then "|-"
    else if name == "flat_map"
    then "|*"
    else "|"

/// Formats one missing argument for JavaScript emission.
private fun java_script_missing_argument(): CompiledExpression =
    CompiledUnsupportedExpression {
        source: "__capy_missing_argument__",
        location: CompiledSourceLocation { line: 0, column: 0 }
    }

/// Checks whether method metadata matches the collection reduce method call rule.
private fun java_script_collection_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "reduce" | call.name == "reduce_left"
    then if java_script_two_method_arguments(call.arguments)
        then java_script_collection_reduce_method_call_with_receiver_type(call, java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

private fun java_script_collection_reduce_method_call_with_receiver_type(call: CompiledMethodCallExpression, receiverType: String): bool =
    if call.name == "reduce" | call.name == "reduce_left"
    then if java_script_two_method_arguments(call.arguments)
        then match call.arguments[1] with
            case Some { reducer } ->
                if java_script_callable_expression(reducer)
                then java_script_collection_pipe_receiver_type(receiverType)
                else false
            case None -> false
        else false
    else false

/// Emits JavaScript code for collection reduce method.
private fun java_script_collection_reduce_method_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules))
    java_script_collection_reduce_method_code_with_receiver_type(call, receiverType, env, module, allModules)

private fun java_script_collection_reduce_method_code_with_receiver_type(call: CompiledMethodCallExpression, receiverType: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None -> "__capy_unsupported('collection reduce')"
    case Some { initial } ->
        match call.arguments[1] with
        case None -> "__capy_unsupported('collection reduce')"
        case Some { reducer } ->
            match reducer with
            case CompiledLambdaExpression lambda ->
                let accumulatorName = java_script_lambda_parameter_at(lambda.parameters, 0)
                let keyName = java_script_reduce_key_parameter(lambda.parameters, receiverType)
                let valueName = java_script_reduce_value_parameter(lambda.parameters, receiverType)
                java_script_collection_reduce_method_lambda_code(call.receiver, initial, lambda.body, accumulatorName, keyName, valueName, env, module, allModules)
            case CompiledFunctionReferenceExpression reference ->
                java_script_collection_reduce_method_callable_code(call.receiver, initial, reference, receiverType, env, module, allModules)
            case _ -> "__capy_unsupported('collection reduce')"

/// Emits JavaScript code for collection reduce method lambda.
private fun java_script_collection_reduce_method_lambda_code(receiver: CompiledExpression, initial: CompiledExpression, body: CompiledExpression, accumulatorName: String, keyName: String, valueName: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = java_script_reduce_bindings_from_names(accumulatorName, keyName, valueName, env)
    let keyed = if keyName.is_empty() then "false" else "true"
    "__capy_reduce("
        + java_script_expression_code(receiver, env, module, allModules)
        + ", "
        + java_script_expression_code(initial, env, module, allModules)
        + ", "
        + keyed
        + ", ("
        + java_script_reduce_parameters_from_names(accumulatorName, keyName, valueName)
        + ") => "
        + java_script_expression_code(body, reduceEnv, module, allModules)
        + ")"

/// Emits JavaScript code for collection reduce method callable.
private fun java_script_collection_reduce_method_callable_code(receiver: CompiledExpression, initial: CompiledExpression, reducer: CompiledExpression, receiverType: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let keyed = if receiverType == "Dict" then "true" else "false"
    "__capy_reduce("
        + java_script_expression_code(receiver, env, module, allModules)
        + ", "
        + java_script_expression_code(initial, env, module, allModules)
        + ", "
        + keyed
        + ", "
        + java_script_expression_code(reducer, env, module, allModules)
        + ")"

/// Computes the JavaScript name for reduce parameters from names.
private fun java_script_reduce_parameters_from_names(accumulatorName: String, keyName: String, valueName: String): String =
    if keyName.is_empty()
    then java_script_lambda_parameter_name(accumulatorName, 0) + ", " + java_script_lambda_parameter_name(valueName, 1)
    else java_script_lambda_parameter_name(accumulatorName, 0) + ", " + java_script_lambda_parameter_name(keyName, 1) + ", " + java_script_lambda_parameter_name(valueName, 2)

/// Collects name/type bindings for reduce bindings from names.
private fun java_script_reduce_bindings_from_names(accumulatorName: String, keyName: String, valueName: String, env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    if keyName.is_empty()
    then [
            JavaScriptBinding { name: accumulatorName, jsName: java_script_lambda_parameter_name(accumulatorName, 0), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: valueName, jsName: java_script_lambda_parameter_name(valueName, 1), typeName: java_script_unknown_type() },
        ] + env
    else [
            JavaScriptBinding { name: accumulatorName, jsName: java_script_lambda_parameter_name(accumulatorName, 0), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: keyName, jsName: java_script_lambda_parameter_name(keyName, 1), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: valueName, jsName: java_script_lambda_parameter_name(valueName, 2), typeName: java_script_unknown_type() },
        ] + env

/// Formats one reduce key parameter for JavaScript emission.
private fun java_script_reduce_key_parameter(parameters: List[String], receiverType: String): String =
    if receiverType == "Dict" | !parameters[2:].is_empty()
    then java_script_lambda_parameter_at(parameters, 1)
    else ""

/// Formats one reduce value parameter for JavaScript emission.
private fun java_script_reduce_value_parameter(parameters: List[String], receiverType: String): String =
    if receiverType == "Dict" | !parameters[2:].is_empty()
    then java_script_lambda_parameter_at(parameters, 2)
    else java_script_lambda_parameter_at(parameters, 1)

/// Formats JavaScript source text for lambda parameter at.
private fun java_script_lambda_parameter_at(parameters: List[String], target: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        if target == 0
        then parameter
        else java_script_lambda_parameter_at(parameters[1:], target - 1)

/// Checks whether a call has the collection get call shape.
private fun java_script_collection_get_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "get"
    then if java_script_one_method_argument(call.arguments) | java_script_two_method_arguments(call.arguments)
        then
            let receiverType = java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules))
            if java_script_collection_get_receiver_type(receiverType)
            then java_script_collection_get_arity(receiverType, call.arguments)
            else false
        else false
    else false

/// Checks whether a type reference matches the collection get receiver type rule.
private fun java_script_collection_get_receiver_type(typeName: String): bool =
    typeName == "List" | typeName == "Dict" | typeName == "Tuple"

/// Checks whether the current value satisfies the collection get arity rule for JavaScript processing.
private fun java_script_collection_get_arity(typeName: String, arguments: List[CompiledExpression]): bool =
    if typeName == "List"
    then java_script_one_method_argument(arguments) | java_script_two_method_arguments(arguments)
    else java_script_one_method_argument(arguments)

/// Emits JavaScript code for collection get call.
private fun java_script_collection_get_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules))
    let receiver = java_script_expression_code(call.receiver, env, module, allModules)
    java_script_collection_get_call_code_with_receiver_type(call, receiverType, receiver, env, module, allModules)

private fun java_script_collection_get_call_code_with_receiver_type(call: CompiledMethodCallExpression, receiverType: String, receiver: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if receiverType == "List" & java_script_two_method_arguments(call.arguments)
    then "__capy_slice(" + receiver + ", "
        + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ", "
        + java_script_second_method_argument_code(call.arguments, env, module, allModules) + ", "
        + java_script_string_literal(receiverType)
        + ")"
    else "__capy_index(" + receiver + ", "
        + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ", "
        + java_script_string_literal(receiverType)
        + ")"

/// Checks whether collection contains call contains the requested value.
private fun java_script_collection_contains_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "contains" | call.name == "contains_key"
    then if java_script_one_method_argument(call.arguments)
        then
            let receiverType = java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules))
            if call.name == "contains"
            then java_script_collection_contains_receiver_type(receiverType)
            else receiverType == "Dict"
        else false
    else false

/// Checks whether collection contains receiver type contains the requested value.
private fun java_script_collection_contains_receiver_type(typeName: String): bool =
    typeName == "List" | typeName == "Set"

/// Emits JavaScript code for collection contains call.
private fun java_script_collection_contains_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_contains("
        + java_script_expression_code(call.receiver, env, module, allModules)
        + ", "
        + java_script_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"

/// Checks whether method metadata matches the set method call rule.
private fun java_script_set_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_set_method_arity(call)
    then java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules)) == "Set"
    else false

/// Checks whether method metadata matches the set method arity rule.
private fun java_script_set_method_arity(call: CompiledMethodCallExpression): bool =
    if java_script_set_no_argument_method(call.name)
    then call.arguments.is_empty()
    else if java_script_set_one_argument_method(call.name)
    then java_script_one_method_argument(call.arguments)
    else false

/// Checks whether method metadata matches the set no argument method rule.
private fun java_script_set_no_argument_method(name: String): bool =
    name == "power_set" | name == "℘"

/// Checks whether method metadata matches the set one argument method rule.
private fun java_script_set_one_argument_method(name: String): bool =
    name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"
        | name == "union" | name == "intersection" | name == "difference"
        | name == "symmetric_difference" | name == "cartesian_product"

/// Emits JavaScript code for set method call.
private fun java_script_set_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = java_script_expression_code(call.receiver, env, module, allModules)
    if call.name == "power_set" | call.name == "℘"
    then "__capy_set_power_set(" + receiverCode + ")"
    else
        let argumentCode = java_script_first_method_argument_code(call.arguments, env, module, allModules)
        java_script_set_operation_code(java_script_set_method_operator(call.name), receiverCode, argumentCode)

/// Maps set method to the JavaScript operator category.
private fun java_script_set_method_operator(name: String): String =
    if name == "contains"
    then "?"
    else if name == "is_subset_of"
    then "⊆"
    else if name == "is_proper_subset_of"
    then "⊂"
    else if name == "is_superset_of"
    then "⊇"
    else if name == "is_proper_superset_of"
    then "⊃"
    else if name == "union"
    then "∪"
    else if name == "intersection"
    then "∩"
    else if name == "difference"
    then "-"
    else if name == "symmetric_difference"
    then "△"
    else "×"

/// Checks whether a call has the single callable argument shape.
private fun java_script_single_callable_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { argument } -> arguments[1:].is_empty() & java_script_callable_expression(argument)

/// Checks whether a call has the two callable arguments shape.
private fun java_script_two_callable_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some { first } ->
        match arguments[1] with
        case None -> false
        case Some { second } -> arguments[2:].is_empty() & java_script_callable_expression(first) & java_script_callable_expression(second)

/// Emits JavaScript code for collection predicate call.
private fun java_script_collection_predicate_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None -> "__capy_unsupported('collection predicate')"
    case Some { predicate } ->
        java_script_collection_predicate_helper(call.name)
            + "("
            + java_script_expression_code(call.receiver, env, module, allModules)
            + ", "
            + java_script_expression_code(predicate, env, module, allModules)
            + ")"

/// Emits JavaScript runtime helper source for collection predicate helper.
private fun java_script_collection_predicate_helper(name: String): String =
    if name == "all" then "__capy_all" else "__capy_any"

/// Checks whether method metadata matches the character to string method call rule.
private fun java_script_char_to_string_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "to_string"
    then
        if call.arguments.is_empty()
        then java_script_char_to_string_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether a type reference matches the character to string receiver type rule.
private fun java_script_char_to_string_receiver_type(typeName: String): bool =
    let baseType = java_script_type_unqualified_name(typeName)
    baseType == "char" | baseType == java_script_unknown_type()

/// Checks whether method metadata matches the string method call rule.
private fun java_script_string_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_string_method_arity(call.name, call.arguments)
    then java_script_string_method_receiver_type(call.name, java_script_expression_type(call.receiver, env, module, allModules))
    else false

/// Checks whether a type reference matches the string method receiver type rule.
private fun java_script_string_method_receiver_type(name: String, typeName: String): bool =
    let baseType = java_script_type_unqualified_name(typeName)
    baseType == "String"
        | (baseType == java_script_unknown_type() & java_script_string_only_method(name))

/// Checks whether method metadata matches the string only method rule.
private fun java_script_string_only_method(name: String): bool =
    name == "trim" | name == "starts_with" | name == "end_with" | name == "replace"

/// Checks whether method metadata matches the string method arity rule.
private fun java_script_string_method_arity(name: String, arguments: List[CompiledExpression]): bool =
    if name == "trim" | name == "is_empty"
    then arguments.is_empty()
    else if name == "contains" | name == "starts_with" | name == "end_with"
    then java_script_one_method_argument(arguments)
    else if name == "replace"
    then java_script_two_method_arguments(arguments)
    else false

/// Emits JavaScript code for string method.
private fun java_script_string_method_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = java_script_expression_code(call.receiver, env, module, allModules)
    if call.name == "trim"
    then "__capy_string_trim(" + receiver + ")"
    else if call.name == "is_empty"
    then "(__capy_size(" + receiver + ") === 0)"
    else if call.name == "contains"
    then "__capy_contains(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "starts_with"
    then "__capy_string_starts_with(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "end_with"
    then "__capy_string_end_with(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ")"
    else if call.name == "replace"
    then "__capy_string_replace(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ", " + java_script_second_method_argument_code(call.arguments, env, module, allModules) + ")"
    else "__capy_unsupported('string method')"

/// Checks whether method metadata matches the regex method call rule.
private fun java_script_regex_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_regex_method_arity(call)
    then java_script_regex_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
    else false

/// Checks whether method metadata matches the regex method arity rule.
private fun java_script_regex_method_arity(call: CompiledMethodCallExpression): bool =
    java_script_regex_method_name(call.name) & java_script_one_method_argument(call.arguments)

/// Checks whether method metadata matches the regex method name rule.
private fun java_script_regex_method_name(name: String): bool =
    name == "matches" | name == "find" | name == "find_all" | name == "replace" | name == "split"

/// Emits JavaScript code for regex method call.
private fun java_script_regex_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverCode = java_script_expression_code(call.receiver, env, module, allModules)
    let argumentCode = java_script_first_method_argument_code(call.arguments, env, module, allModules)
    java_script_regex_operation_code(java_script_regex_method_operator(call.name), receiverCode, argumentCode)

/// Maps regex method to the JavaScript operator category.
private fun java_script_regex_method_operator(name: String): String =
    if name == "matches"
    then "?"
    else if name == "find"
    then "~"
    else if name == "find_all"
    then "~~"
    else if name == "replace"
    then "~>"
    else "/>"

/// Checks whether a type reference matches the regex receiver type rule.
private fun java_script_regex_receiver_type(typeName: String): bool =
    java_script_type_unqualified_name(typeName) == java_script_regex_type()

private fun java_script_date_time_method_call_expression(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    let emptyArguments = call.arguments.is_empty()
    let oneArgument = java_script_one_method_argument(call.arguments)
    let twoArguments = java_script_two_method_arguments(call.arguments)
    if java_script_date_time_method_candidate(call.name, emptyArguments, oneArgument, twoArguments)
    then java_script_date_time_method_call(
        java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules)),
        call.name,
        emptyArguments,
        oneArgument,
        twoArguments
    )
    else false

private fun java_script_date_time_method_candidate(methodName: String, emptyArguments: bool, oneArgument: bool, twoArguments: bool): bool =
    if methodName == "add_days" | methodName == "add_seconds" | methodName == "plus" | methodName == "minus"
    then oneArgument
    else if methodName == "add_years_months"
    then twoArguments
    else if methodName == "to_days_since_unix_epoch" | methodName == "to_seconds" | methodName == "to_iso_8601" | methodName == "timestamp"
    then emptyArguments
    else if java_script_duration_method_name(methodName)
    then emptyArguments
    else false

/// Checks whether method metadata matches the date/time method call rule.
private fun java_script_date_time_method_call(receiver: String, methodName: String, emptyArguments: bool, oneArgument: bool, twoArguments: bool): bool =
    java_script_stdlib_date_time_method(receiver, methodName, emptyArguments, oneArgument, twoArguments)
        | (receiver == java_script_unknown_type() & java_script_unknown_date_time_method(methodName, oneArgument, twoArguments))

/// Checks whether method metadata matches the unknown date/time method rule.
private fun java_script_unknown_date_time_method(methodName: String, oneArgument: bool, twoArguments: bool): bool =
    if methodName == "add_days" | methodName == "add_seconds" | methodName == "plus" | methodName == "minus"
    then oneArgument
    else methodName == "add_years_months" & twoArguments

/// Checks whether method metadata matches the standard-library date/time method rule.
private fun java_script_stdlib_date_time_method(receiver: String, methodName: String, emptyArguments: bool, oneArgument: bool, twoArguments: bool): bool =
    if receiver == "Date"
    then if methodName == "add_days"
        then oneArgument
        else if methodName == "add_years_months"
        then twoArguments
        else (methodName == "to_days_since_unix_epoch" | methodName == "to_iso_8601") & emptyArguments
    else if receiver == "Time"
    then if methodName == "add_seconds"
        then oneArgument
        else (methodName == "to_seconds" | methodName == "to_iso_8601") & emptyArguments
    else if receiver == "DateTime"
    then if methodName == "plus" | methodName == "minus"
        then oneArgument
        else (methodName == "to_iso_8601" | methodName == "timestamp") & emptyArguments
    else if receiver == "Duration" | receiver == "DateDuration" | receiver == "WeekDuration"
    then java_script_duration_method_name(methodName) & emptyArguments
    else false

/// Checks whether method metadata matches the duration method name rule.
private fun java_script_duration_method_name(methodName: String): bool =
    methodName == "to_iso_8601"
        | methodName == "negate"
        | methodName == "years"
        | methodName == "months"
        | methodName == "days"
        | methodName == "hours"
        | methodName == "minutes"
        | methodName == "seconds"

/// Emits JavaScript code for date time method call.
private fun java_script_date_time_method_call_code(receiverType: String, methodName: String, receiver: String, firstArgument: String, secondArgument: String): String =
    if receiverType == "Date"
    then java_script_date_method_call_code(methodName, receiver, firstArgument, secondArgument)
    else if receiverType == "Time"
    then java_script_time_method_call_code(methodName, receiver, firstArgument)
    else if receiverType == "DateTime"
    then java_script_date_time_value_method_call_code(methodName, receiver, firstArgument)
    else if receiverType == java_script_unknown_type()
    then java_script_unknown_date_time_method_call_code(methodName, receiver, firstArgument, secondArgument)
    else java_script_duration_method_call_code(methodName, receiver)

/// Emits JavaScript code for date method call.
private fun java_script_date_method_call_code(methodName: String, receiver: String, firstArgument: String, secondArgument: String): String =
    if methodName == "add_days"
    then "__capy_date_add_days(" + receiver + ", " + firstArgument + ")"
    else if methodName == "add_years_months"
    then "__capy_date_add_years_months(" + receiver + ", " + firstArgument + ", " + secondArgument + ")"
    else if methodName == "to_days_since_unix_epoch"
    then "__capy_date_to_days_since_unix_epoch(" + receiver + ")"
    else "__capy_date_to_iso_8601(" + receiver + ")"

/// Emits JavaScript code for time method call.
private fun java_script_time_method_call_code(methodName: String, receiver: String, firstArgument: String): String =
    if methodName == "add_seconds"
    then "__capy_time_add_seconds(" + receiver + ", " + firstArgument + ")"
    else if methodName == "to_seconds"
    then "__capy_time_to_seconds(" + receiver + ")"
    else "__capy_time_to_iso_8601(" + receiver + ")"

/// Emits JavaScript code for date time value method call.
private fun java_script_date_time_value_method_call_code(methodName: String, receiver: String, firstArgument: String): String =
    if methodName == "plus"
    then "__capy_date_time_plus(" + receiver + ", " + firstArgument + ")"
    else if methodName == "minus"
    then "__capy_date_time_minus(" + receiver + ", " + firstArgument + ")"
    else if methodName == "timestamp"
    then "__capy_date_time_timestamp(" + receiver + ")"
    else "__capy_date_time_to_iso_8601(" + receiver + ")"

/// Emits JavaScript code for unknown date time method call.
private fun java_script_unknown_date_time_method_call_code(methodName: String, receiver: String, firstArgument: String, secondArgument: String): String =
    if methodName == "add_days"
    then "__capy_date_add_days(" + receiver + ", " + firstArgument + ")"
    else if methodName == "add_years_months"
    then "__capy_date_add_years_months(" + receiver + ", " + firstArgument + ", " + secondArgument + ")"
    else if methodName == "add_seconds"
    then "__capy_time_add_seconds(" + receiver + ", " + firstArgument + ")"
    else if methodName == "plus"
    then "__capy_date_time_plus(" + receiver + ", " + firstArgument + ")"
    else "__capy_date_time_minus(" + receiver + ", " + firstArgument + ")"

/// Emits JavaScript code for duration method call.
private fun java_script_duration_method_call_code(methodName: String, receiver: String): String =
    if methodName == "to_iso_8601"
    then "__capy_duration_to_iso_8601(" + receiver + ")"
    else if methodName == "negate"
    then "__capy_duration_negate(" + receiver + ")"
    else "__capy_duration_" + methodName + "(" + receiver + ")"

/// Checks whether method metadata matches the string get method call rule.
private fun java_script_string_get_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "get"
    then
        if java_script_one_method_argument(call.arguments) | java_script_two_method_arguments(call.arguments)
        then java_script_expression_type(call.receiver, env, module, allModules) == "String"
        else false
    else false

/// Emits JavaScript code for string get method.
private fun java_script_string_get_method_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiver = java_script_expression_code(call.receiver, env, module, allModules)
    if java_script_two_method_arguments(call.arguments)
    then "__capy_string_slice(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ", " + java_script_second_method_argument_code(call.arguments, env, module, allModules) + ")"
    else "__capy_string_get(" + receiver + ", " + java_script_first_method_argument_code(call.arguments, env, module, allModules) + ")"

/// Checks whether method metadata matches the string parse method call rule.
private fun java_script_string_parse_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_string_parse_method_name(call.name)
    then
        if call.arguments.is_empty()
        then java_script_string_parse_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether a type reference matches the string parse receiver type rule.
private fun java_script_string_parse_receiver_type(receiverType: String): bool =
    let baseType = java_script_type_unqualified_name(receiverType)
    baseType == "String" | baseType == java_script_unknown_type()

/// Checks whether method metadata matches the string parse method name rule.
private fun java_script_string_parse_method_name(name: String): bool =
    name == "to_int" | name == "to_long" | name == "to_double" | name == "to_float" | name == "to_bool"

/// Emits JavaScript code for string parse method.
private fun java_script_string_parse_method_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_string_parse_helper(call.name) + "(" + java_script_expression_code(call.receiver, env, module, allModules) + ")"

/// Emits JavaScript runtime helper source for string parse helper.
private fun java_script_string_parse_helper(name: String): String =
    if name == "to_int"
    then "__capy_parse_int"
    else if name == "to_long"
    then "__capy_parse_long"
    else if name == "to_double"
    then "__capy_parse_double"
    else if name == "to_float"
    then "__capy_parse_float"
    else "__capy_parse_bool"

/// Checks whether method metadata matches the one method argument rule.
private fun java_script_one_method_argument(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ -> arguments[1:].is_empty()

/// Checks whether method metadata matches the two method arguments rule.
private fun java_script_two_method_arguments(arguments: List[CompiledExpression]): bool =
    match arguments[0] with
    case None -> false
    case Some _ ->
        match arguments[1] with
        case None -> false
        case Some _ -> arguments[2:].is_empty()

/// Emits JavaScript code for first method argument.
private fun java_script_first_method_argument_code(arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> "undefined"
    case Some { argument } -> java_script_expression_code(argument, env, module, allModules)

/// Resolves the first method argument expression.
private fun java_script_first_method_argument(arguments: List[CompiledExpression]): CompiledExpression =
    match arguments[0] with
    case None -> java_script_missing_argument()
    case Some { argument } -> argument

/// Emits JavaScript code for second method argument.
private fun java_script_second_method_argument_code(arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[1] with
    case None -> "undefined"
    case Some { argument } -> java_script_expression_code(argument, env, module, allModules)

/// Checks whether a call has the primitive conversion call shape.
private fun java_script_primitive_conversion_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_primitive_conversion_method(call.name)
    then
        if call.arguments.is_empty()
        then java_script_primitive_conversion_receiver(call.name, java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Checks whether method metadata matches the primitive conversion method rule.
private fun java_script_primitive_conversion_method(name: String): bool =
    name == "to_int" | name == "to_long"

/// Checks whether a receiver type matches the primitive conversion receiver rule.
private fun java_script_primitive_conversion_receiver(name: String, receiverType: String): bool =
    let baseType = java_script_type_unqualified_name(receiverType)
    if name == "to_int"
    then baseType == "long" | baseType == "float" | baseType == "double"
    else if name == "to_long"
    then baseType == "float" | baseType == "double"
    else false

/// Emits JavaScript code for primitive conversion.
private fun java_script_primitive_conversion_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "to_int"
    then "__capy_to_int(" + java_script_expression_code(call.receiver, env, module, allModules) + ")"
    else "__capy_to_long(" + java_script_expression_code(call.receiver, env, module, allModules) + ")"

/// Checks whether method metadata matches the result reduce method call rule.
private fun java_script_result_reduce_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    if call.name == "reduce" | call.name == "reduce_left"
    then
        if java_script_two_method_arguments(call.arguments)
        then java_script_result_pipe_receiver_type(java_script_expression_type(call.receiver, env, module, allModules))
        else false
    else false

/// Emits JavaScript code for result reduce method call.
private fun java_script_result_reduce_method_call_code(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_result_reduce("
        + java_script_expression_code(call.receiver, env, module, allModules)
        + ", "
        + java_script_first_method_argument_code(call.arguments, env, module, allModules)
        + ", "
        + java_script_second_method_argument_code(call.arguments, env, module, allModules)
        + ")"

/// Emits JavaScript code for extension method call.
private fun java_script_extension_method_call_code(function: CompiledFunction, call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_extension_method_binding_call_code(java_script_function_name(function), call, env, module, allModules)

/// Emits JavaScript code for extension method binding call.
private fun java_script_extension_method_binding_call_code(binding: String, call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    binding
        + "("
        + java_script_expression_code(call.receiver, env, module, allModules)
        + java_script_extension_method_argument_tail(call.arguments, env, module, allModules)
        + ")"

/// Formats the recursive tail segment for extension method argument.
private fun java_script_extension_method_argument_tail(arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if arguments.is_empty()
    then ""
    else ", " + java_script_expression_list_code(arguments, env, module, allModules)

/// Emits JavaScript code for lambda expression.
private fun java_script_lambda_expression_code(lambda: CompiledLambdaExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let lambdaEnv = java_script_lambda_bindings(lambda.parameters) + env
    "(" + java_script_lambda_parameters(lambda.parameters) + ") => "
        + java_script_expression_code(lambda.body, lambdaEnv, module, allModules)

/// Creates JavaScript name/type bindings for lambda expression code with.
private fun java_script_lambda_expression_code_with_bindings(lambda: CompiledLambdaExpression, bindings: List[JavaScriptBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "(" + java_script_lambda_parameters(lambda.parameters) + ") => "
        + java_script_expression_code(lambda.body, bindings + env, module, allModules)

/// Formats lambda parameters for JavaScript emission.
private fun java_script_lambda_parameters(parameters: List[String]): String =
    java_script_lambda_parameters_from(parameters, 0)

/// Formats JavaScript source text for lambda parameters from.
private fun java_script_lambda_parameters_from(parameters: List[String], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } -> java_script_lambda_parameter_name(parameter, idx) + java_script_lambda_parameter_tail(parameters[1:], idx + 1)

/// Formats the recursive tail segment for lambda parameter.
private fun java_script_lambda_parameter_tail(parameters: List[String], idx: int): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + java_script_lambda_parameters_from(parameters, idx)

/// Computes the JavaScript name for lambda parameter.
private fun java_script_lambda_parameter_name(parameter: String, idx: int): String =
    if parameter == "_"
    then "__capy_lambda_unused_" + idx
    else java_script_identifier(parameter)

/// Creates JavaScript name/type bindings for lambda.
private fun java_script_lambda_bindings(parameters: List[String]): List[JavaScriptBinding] =
    java_script_lambda_bindings_from(parameters, 0)

/// Collects name/type bindings for lambda bindings from.
private fun java_script_lambda_bindings_from(parameters: List[String], idx: int): List[JavaScriptBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [JavaScriptBinding { name: parameter, jsName: java_script_lambda_parameter_name(parameter, idx), typeName: java_script_unknown_type() }]
            + java_script_lambda_bindings_from(parameters[1:], idx + 1)

/// Computes the JavaScript type for lambda bindings with single.
private fun java_script_lambda_bindings_with_single_type(parameters: List[String], typeName: String): List[JavaScriptBinding] =
    java_script_lambda_bindings_with_single_type_from(parameters, typeName, 0)

/// Collects name/type bindings for lambda bindings with single type from.
private fun java_script_lambda_bindings_with_single_type_from(parameters: List[String], typeName: String, idx: int): List[JavaScriptBinding] =
    match parameters[0] with
    case None -> []
    case Some { parameter } ->
        [JavaScriptBinding { name: parameter, jsName: java_script_lambda_parameter_name(parameter, idx), typeName: typeName }]
            + java_script_lambda_bindings_with_single_type_from(parameters[1:], typeName, idx + 1)

/// Emits JavaScript code for with expression.
private fun java_script_with_expression_code(withExpression: CompiledWithExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = java_script_data_constructor_type_names(receiverType, module, allModules)
    let rawWithCode = java_script_raw_with_expression_code(withExpression, env, module, allModules)
    if constructorTypes.is_empty()
    then rawWithCode
    else "__capy_constructor_pipeline("
        + rawWithCode
        + ", ["
        + java_script_data_constructor_pipeline_steps(constructorTypes, receiverType, module)
        + "], "
        + java_script_bool_code(java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules))
        + ")"

/// Emits JavaScript code for raw with expression.
private fun java_script_raw_with_expression_code(withExpression: CompiledWithExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_with("
        + java_script_expression_code(withExpression.receiver, env, module, allModules)
        + ", "
        + java_script_with_fields_object_code(withExpression.fields, env, module, allModules)
        + ")"

/// Emits JavaScript code for with fields object.
private fun java_script_with_fields_object_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_data_fields_have_spread(fields)
    then "__capy_data_fields(" + java_script_data_field_parts_code(fields, "", false, env, module, allModules) + ")"
    else "{" + java_script_with_fields_code(fields, env, module, allModules) + "}"

/// Computes the JavaScript type for with expression receiver.
private fun java_script_with_expression_receiver_type(withExpression: CompiledWithExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_expression_type(withExpression.receiver, env, module, allModules)

/// Infers the expression type for with.
private fun java_script_with_expression_type(withExpression: CompiledWithExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = java_script_data_constructor_type_names(receiverType, module, allModules)
    if constructorTypes.is_empty()
    then receiverType
    else java_script_with_constructor_result_type(receiverType, constructorTypes, module, allModules)

/// Computes the JavaScript type for with constructor result.
private fun java_script_with_constructor_result_type(receiverType: String, constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then "Result"
    else receiverType

/// Emits JavaScript code for with fields.
private fun java_script_with_fields_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        java_script_string_literal(field.name)
            + ": "
            + java_script_expression_code(field.value, env, module, allModules)
            + java_script_with_fields_tail_code(fields[1:], env, module, allModules)

/// Emits JavaScript code for with fields tail.
private fun java_script_with_fields_tail_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
            + java_script_string_literal(field.name)
            + ": "
            + java_script_expression_code(field.value, env, module, allModules)
            + java_script_with_fields_tail_code(fields[1:], env, module, allModules)

/// Emits JavaScript code for expression list.
private fun java_script_expression_list_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        java_script_expression_code(expression, env, module, allModules)
            + java_script_expression_list_tail_code(expressions[1:], env, module, allModules)

/// Emits JavaScript code for expression list tail.
private fun java_script_expression_list_tail_code(expressions: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expressions[0] with
    case None -> ""
    case Some { expression } ->
        ", " + java_script_expression_code(expression, env, module, allModules)
            + java_script_expression_list_tail_code(expressions[1:], env, module, allModules)

/// Formats function call arguments for JavaScript emission.
private fun java_script_function_call_arguments(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } ->
        match parameters[0] with
        case None ->
            java_script_expression_code(argument, env, module, allModules)
                + java_script_function_call_arguments_tail(parameters, arguments[1:], env, module, allModules)
        case Some { parameter } ->
            java_script_argument_code(parameter, argument, env, module, allModules)
                + java_script_function_call_arguments_tail(parameters[1:], arguments[1:], env, module, allModules)

/// Formats the recursive tail segment for function call arguments.
private fun java_script_function_call_arguments_tail(parameters: List[CompiledFunctionParameter], arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> ""
    case Some _ -> ", " + java_script_function_call_arguments(parameters, arguments, env, module, allModules)

/// Emits JavaScript code for argument.
private fun java_script_argument_code(parameter: CompiledFunctionParameter, argument: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_value_conversion_code(
        java_script_expression_code(argument, env, module, allModules),
        java_script_expression_type(argument, env, module, allModules),
        parameter.typeReference.name,
        module,
        allModules
    )

/// Emits JavaScript code for value conversion.
private fun java_script_value_conversion_code(code: String, sourceType: String, expectedType: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_primitive_backed_backing_type(sourceType, module, allModules) with
    case Some { backingType } ->
        if expectedType == backingType
        then "__capy_get_field(" + code + ", " + java_script_string_literal("value") + ")"
        else code
    case None -> code

/// Emits JavaScript code for dict entries.
private fun java_script_dict_entries_code(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        "[" + java_script_expression_code(entry.key, env, module, allModules) + ", " + java_script_expression_code(entry.value, env, module, allModules) + "]"
            + java_script_dict_entries_tail_code(entries[1:], env, module, allModules)

/// Emits JavaScript code for dict entries tail.
private fun java_script_dict_entries_tail_code(entries: List[CompiledDictEntry], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match entries[0] with
    case None -> ""
    case Some { entry } ->
        ", [" + java_script_expression_code(entry.key, env, module, allModules) + ", " + java_script_expression_code(entry.value, env, module, allModules) + "]"
            + java_script_dict_entries_tail_code(entries[1:], env, module, allModules)

/// Emits JavaScript code for data fields.
private fun java_script_data_fields_code(fields: List[CompiledDataField], typeName: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        java_script_string_literal(java_script_data_field_name(field.name, typeName, module, allModules))
            + ": "
            + java_script_expression_code(field.value, env, module, allModules)
            + java_script_data_fields_tail_code(fields[1:], typeName, env, module, allModules)

/// Emits JavaScript code for data fields tail.
private fun java_script_data_fields_tail_code(fields: List[CompiledDataField], typeName: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        ", "
        + java_script_string_literal(java_script_data_field_name(field.name, typeName, module, allModules))
        + ": "
        + java_script_expression_code(field.value, env, module, allModules)
        + java_script_data_fields_tail_code(fields[1:], typeName, env, module, allModules)

/// Checks whether the current value satisfies the data fields have spread rule for JavaScript processing.
private fun java_script_data_fields_have_spread(fields: List[CompiledDataField]): bool =
    match fields[0] with
    case None -> false
    case Some { field } -> field.spread | java_script_data_fields_have_spread(fields[1:])

/// Emits JavaScript code for data field parts.
private fun java_script_data_field_parts_code(fields: List[CompiledDataField], typeName: String, mapNames: bool, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some { field } ->
        java_script_data_field_part_code(field, typeName, mapNames, env, module, allModules)
            + java_script_data_field_parts_tail_code(fields[1:], typeName, mapNames, env, module, allModules)

/// Emits JavaScript code for data field parts tail.
private fun java_script_data_field_parts_tail_code(fields: List[CompiledDataField], typeName: String, mapNames: bool, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> ", " + java_script_data_field_parts_code(fields, typeName, mapNames, env, module, allModules)

/// Emits JavaScript code for data field part.
private fun java_script_data_field_part_code(field: CompiledDataField, typeName: String, mapNames: bool, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if field.spread
    then java_script_expression_code(field.value, env, module, allModules)
    else "{"
        + java_script_string_literal(java_script_data_field_part_name(field.name, typeName, mapNames, module, allModules))
        + ": "
        + java_script_expression_code(field.value, env, module, allModules)
        + "}"

/// Computes the JavaScript name for data field part.
private fun java_script_data_field_part_name(name: String, typeName: String, mapNames: bool, module: CompiledModule, allModules: List[CompiledModule]): String =
    if mapNames
    then java_script_data_field_name(name, typeName, module, allModules)
    else name

/// Emits JavaScript code for data literal.
private fun java_script_data_literal_code(literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if literal.typeName == "char"
    then java_script_char_constructor_code(literal.fields, env, module, allModules)
    else if java_script_raw_data_literal(literal.typeName)
    then java_script_raw_data_literal_code(literal, env, module, allModules)
    else
        let declaredTypeName = java_script_data_literal_declared_type_name(literal.typeName)
        let parentConstructors = java_script_data_parent_constructor_type_names(declaredTypeName, module, allModules)
        let constructorTypes = java_script_data_constructor_type_names(declaredTypeName, module, allModules)
        if parentConstructors.is_empty()
        then match java_script_data_constructor_function(declaredTypeName, module) with
            case Some { function } -> java_script_data_constructor_call_code(function, literal, env, module, allModules)
            case None -> java_script_raw_data_literal_code(literal, env, module, allModules)
        else java_script_data_constructor_pipeline_code(constructorTypes, literal, env, module, allModules)

/// Checks whether the current value satisfies the raw data literal rule for JavaScript processing.
private fun java_script_raw_data_literal(typeName: String): bool =
    java_script_string_has_prefix(typeName, "__capy_raw|")

/// Computes the JavaScript type name for data literal declared.
private fun java_script_data_literal_declared_type_name(typeName: String): String =
    java_script_schema_type_name(java_script_raw_data_literal_type_name(typeName))

/// Looks up optional metadata for data constructor function.
private fun java_script_data_constructor_function(typeName: String, module: CompiledModule): /capy/lang/Option[CompiledFunction] =
    if java_script_raw_data_literal(typeName)
    then /capy/lang/Option.None {}
    else java_script_find_local_function("__capy_constructor|" + java_script_data_literal_declared_type_name(typeName), module.functions)

/// Emits JavaScript code for data constructor call.
private fun java_script_data_constructor_call_code(function: CompiledFunction, literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_constructor_result("
        + java_script_string_literal(java_script_data_literal_declared_type_name(literal.typeName))
        + ", "
        + java_script_function_name(function)
        + "("
        + java_script_data_constructor_call_arguments(function.parameters, literal.fields, 0, env, module, allModules)
        + "))"

/// Collects data own constructor type names for JavaScript processing.
private fun java_script_data_own_constructor_type_names(typeName: String, module: CompiledModule): List[String] =
    match java_script_data_constructor_function(typeName, module) with
    case Some _ -> [typeName]
    case None -> []

/// Collects data constructor type names for JavaScript processing.
private fun java_script_data_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    if java_script_raw_data_literal(typeName)
    then []
    else java_script_data_parent_constructor_type_names(typeName, module, allModules) + java_script_data_own_constructor_type_names(typeName, module)

/// Collects data parent constructor type names for JavaScript processing.
private fun java_script_data_parent_constructor_type_names(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    java_script_data_parent_constructor_type_names_from(java_script_data_type_parent_types(typeName, module, allModules), module)

/// Collects data parent constructor type names from for JavaScript processing.
private fun java_script_data_parent_constructor_type_names_from(typeNames: List[String], module: CompiledModule): List[String] =
    match typeNames[0] with
    case None -> []
    case Some { typeName } ->
        let constructorTypeName = java_script_schema_type_name(typeName)
        match java_script_data_constructor_function(constructorTypeName, module) with
        case Some _ -> [constructorTypeName] + java_script_data_parent_constructor_type_names_from(typeNames[1:], module)
        case None -> java_script_data_parent_constructor_type_names_from(typeNames[1:], module)

/// Emits JavaScript code for data constructor pipeline.
private fun java_script_data_constructor_pipeline_code(constructorTypes: List[String], literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let declaredTypeName = java_script_data_literal_declared_type_name(literal.typeName)
    "__capy_constructor_pipeline("
        + java_script_raw_data_literal_code(literal, env, module, allModules)
        + ", ["
        + java_script_data_constructor_pipeline_steps(constructorTypes, declaredTypeName, module)
        + "], "
        + java_script_bool_code(java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules))
        + ")"

/// Formats JavaScript source text for data constructor pipeline steps.
private fun java_script_data_constructor_pipeline_steps(constructorTypes: List[String], literalTypeName: String, module: CompiledModule): String =
    match constructorTypes[0] with
    case None -> ""
    case Some { constructorType } ->
        match java_script_data_constructor_function(constructorType, module) with
        case Some { function } ->
            java_script_data_constructor_pipeline_step(function, constructorType, constructorType != literalTypeName)
                + java_script_data_constructor_pipeline_step_tail(constructorTypes[1:], literalTypeName, module)
        case None -> java_script_data_constructor_pipeline_steps(constructorTypes[1:], literalTypeName, module)

/// Formats the recursive tail segment for data constructor pipeline step.
private fun java_script_data_constructor_pipeline_step_tail(constructorTypes: List[String], literalTypeName: String, module: CompiledModule): String =
    match constructorTypes[0] with
    case None -> ""
    case Some _ ->
        let tail = java_script_data_constructor_pipeline_steps(constructorTypes, literalTypeName, module)
        if tail.is_empty()
        then ""
        else ", " + tail

/// Formats JavaScript source text for data constructor pipeline step.
private fun java_script_data_constructor_pipeline_step(function: CompiledFunction, constructorType: String, parentConstructor: bool): String =
    "["
        + java_script_string_literal(constructorType)
        + ", "
        + java_script_bool_code(parentConstructor)
        + ", (__capy_constructor_data) => "
        + java_script_data_constructor_data_call_code(function, "__capy_constructor_data")
        + "]"

/// Emits JavaScript code for data constructor data call.
private fun java_script_data_constructor_data_call_code(function: CompiledFunction, dataName: String): String =
    java_script_function_name(function)
        + "("
        + java_script_data_constructor_data_call_arguments(function.parameters, dataName)
        + ")"

/// Formats data constructor data call arguments for JavaScript emission.
private fun java_script_data_constructor_data_call_arguments(parameters: List[CompiledFunctionParameter], dataName: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        "__capy_get_field(" + dataName + ", " + java_script_string_literal(parameter.name) + ")"
            + java_script_data_constructor_data_call_argument_tail(parameters[1:], dataName)

/// Formats the recursive tail segment for data constructor data call argument.
private fun java_script_data_constructor_data_call_argument_tail(parameters: List[CompiledFunctionParameter], dataName: String): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        ", __capy_get_field(" + dataName + ", " + java_script_string_literal(parameter.name) + ")"
            + java_script_data_constructor_data_call_argument_tail(parameters[1:], dataName)

/// Checks whether constructor metadata matches the data constructor pipeline returns result rule.
private fun java_script_data_constructor_pipeline_returns_result(constructorTypes: List[String], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match constructorTypes[0] with
    case None -> false
    case Some { constructorType } ->
        if java_script_data_constructor_type_returns_result(constructorType, module, allModules)
        then true
        else java_script_data_constructor_pipeline_returns_result(constructorTypes[1:], module, allModules)

/// Checks whether a type reference matches the data constructor type returns result rule.
private fun java_script_data_constructor_type_returns_result(typeName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    match java_script_data_constructor_function(typeName, module) with
    case Some { function } ->
        if java_script_result_pipe_receiver_type(function.returnType.name)
        then true
        else java_script_result_pipe_receiver_type(java_script_data_constructor_inferred_expression_type(function.body, java_script_function_bindings(function), module, allModules))
    case None -> false

/// Infers the expression type for data constructor inferred.
private fun java_script_data_constructor_inferred_expression_type(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIfExpression ifExpression ->
        java_script_preferred_constructor_type(
            java_script_data_constructor_inferred_expression_type(ifExpression.thenBranch, env, module, allModules),
            java_script_data_constructor_inferred_expression_type(ifExpression.elseBranch, env, module, allModules)
        )
    case CompiledBlockExpression block ->
        java_script_data_constructor_inferred_expression_type(block.result, java_script_block_env(block.bindings, env, module, allModules), module, allModules)
    case _ -> java_script_expression_type(expression, env, module, allModules)

/// Computes the JavaScript type for preferred constructor.
private fun java_script_preferred_constructor_type(first: String, second: String): String =
    if java_script_result_pipe_receiver_type(first)
    then "Result"
    else if java_script_result_pipe_receiver_type(second)
    then "Result"
    else first

/// Emits JavaScript code for boolean.
private fun java_script_bool_code(value: bool): String =
    if value then "true" else "false"

/// Infers the expression type for data literal.
private fun java_script_data_literal_expression_type(literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_result_pipe_receiver_type(literal.typeName)
    then "Result"
    else if java_script_option_pipe_receiver_type(literal.typeName)
    then "Option"
    else if java_script_raw_data_literal(literal.typeName)
    then java_script_data_literal_declared_type_name(literal.typeName)
    else
        let declaredTypeName = java_script_data_literal_declared_type_name(literal.typeName)
        let constructorTypes = java_script_data_constructor_type_names(declaredTypeName, module, allModules)
        if constructorTypes.is_empty()
        then declaredTypeName
        else if java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
        then "Result"
        else declaredTypeName

/// Emits JavaScript code for raw data literal.
private fun java_script_raw_data_literal_code(literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = java_script_data_literal_type_name(literal.typeName, module.imports)
        "__capy_data("
            + java_script_string_literal(typeName)
            + ", "
            + java_script_data_literal_fields_object_code(literal, env, module, allModules)
            + ")"

/// Emits JavaScript code for data literal fields object.
private fun java_script_data_literal_fields_object_code(literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_data_fields_have_spread(literal.fields)
    then "__capy_data_fields(" + java_script_data_field_parts_code(literal.fields, literal.typeName, true, env, module, allModules) + ")"
    else "{" + java_script_data_fields_code(literal.fields, literal.typeName, env, module, allModules) + "}"

/// Formats data constructor call arguments for JavaScript emission.
private fun java_script_data_constructor_call_arguments(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some { parameter } ->
        java_script_data_constructor_argument_code(fields, parameter.name, "$" + idx, env, module, allModules)
            + java_script_data_constructor_call_argument_tail(parameters[1:], fields, idx + 1, env, module, allModules)

/// Formats the recursive tail segment for data constructor call argument.
private fun java_script_data_constructor_call_argument_tail(parameters: List[CompiledFunctionParameter], fields: List[CompiledDataField], idx: int, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match parameters[0] with
    case None -> ""
    case Some _ -> ", " + java_script_data_constructor_call_arguments(parameters, fields, idx, env, module, allModules)

/// Emits JavaScript code for data constructor argument.
private fun java_script_data_constructor_argument_code(fields: List[CompiledDataField], name: String, positionalName: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> "undefined"
    case Some { field } ->
        if field.name == name | field.name == positionalName
        then java_script_expression_code(field.value, env, module, allModules)
        else java_script_data_constructor_argument_code(fields[1:], name, positionalName, env, module, allModules)

/// Emits JavaScript code for character constructor.
private fun java_script_char_constructor_code(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> "__capy_char(\"\")"
    case Some { field } -> "__capy_char(" + java_script_expression_code(field.value, env, module, allModules) + ")"

/// Computes the JavaScript type name for data literal.
private fun java_script_data_literal_type_name(typeName: String, imports: List[CompiledImportDeclaration]): String =
    if java_script_program_success_literal(typeName, imports)
    then "/capy/lang/Program.Success"
    else if java_script_program_failed_literal(typeName, imports)
    then "/capy/lang/Program.Failed"
    else typeName

/// Checks whether the current value satisfies the program success literal rule for JavaScript processing.
private fun java_script_program_success_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Success"
        | typeName == "Program.Success"
        | (typeName == "Success" & java_script_program_member_imported("Success", imports))

/// Checks whether the current value satisfies the program failed literal rule for JavaScript processing.
private fun java_script_program_failed_literal(typeName: String, imports: List[CompiledImportDeclaration]): bool =
    typeName == "/capy/lang/Program.Failed"
        | typeName == "Program.Failed"
        | (typeName == "Failed" & java_script_program_member_imported("Failed", imports))

/// Computes the JavaScript name for data field.
private fun java_script_data_field_name(name: String, typeName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_string_has_prefix(name, "$")
    then java_script_declared_positional_field_name(name, java_script_data_type_fields(java_script_raw_data_literal_type_name(typeName), module, allModules), 0)
    else name

/// Computes the JavaScript type name for raw data literal.
private fun java_script_raw_data_literal_type_name(typeName: String): String =
    if java_script_string_has_prefix(typeName, "__capy_raw|")
    then typeName["__capy_raw|".size().value, typeName.size().value]
    else typeName

/// Computes the JavaScript name for declared positional field.
private fun java_script_declared_positional_field_name(name: String, fields: List[String], idx: int): String =
    match fields[0] with
    case None -> name
    case Some { field } ->
        if name == "$" + idx
        then java_script_schema_field_name(field)
        else java_script_declared_positional_field_name(name, fields[1:], idx + 1)

/// Emits JavaScript code for index expression.
private fun java_script_index_expression_code(index: CompiledIndexExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_expression_type(index.receiver, env, module, allModules)
    let receiverCode = java_script_expression_code(index.receiver, env, module, allModules)
    if !java_script_built_in_index_expression(index, receiverType)
    then java_script_user_defined_index_code(index, receiverType, env, module, allModules)
    else if index.hasEndIndex
    then "__capy_slice("
        + receiverCode
        + ", "
        + java_script_slice_start_code(index.index, env, module, allModules)
        + ", "
        + java_script_slice_end_code(index.endIndex, env, module, allModules)
        + ", "
        + java_script_string_literal(receiverType)
        + ")"
    else "__capy_index("
        + receiverCode
        + ", "
        + java_script_expression_code(index.index, env, module, allModules)
        + ", "
        + java_script_string_literal(receiverType)
        + ")"

/// Checks whether an expression has the built in index expression shape.
private fun java_script_built_in_index_expression(index: CompiledIndexExpression, receiverType: String): bool =
    if index.hasEndIndex
    then java_script_built_in_slice_receiver_type(receiverType)
    else java_script_built_in_index_receiver_type(receiverType)

/// Checks whether a type reference matches the built in slice receiver type rule.
private fun java_script_built_in_slice_receiver_type(receiverType: String): bool =
    java_script_built_in_sequence_receiver_type(receiverType)

/// Checks whether a type reference matches the built in index receiver type rule.
private fun java_script_built_in_index_receiver_type(receiverType: String): bool =
    let baseType = java_script_type_unqualified_name(receiverType)
    java_script_built_in_sequence_receiver_type(baseType)
        | baseType == "Dict"

/// Checks whether a type reference matches the built in sequence receiver type rule.
private fun java_script_built_in_sequence_receiver_type(receiverType: String): bool =
    let baseType = java_script_type_unqualified_name(receiverType)
    baseType == java_script_unknown_type()
        | baseType == "String"
        | baseType == "Tuple"
        | baseType == "List"

/// Emits JavaScript code for user defined index.
private fun java_script_user_defined_index_code(index: CompiledIndexExpression, receiverType: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_find_local_method_function(receiverType, "get", module.functions) with
    case Some { function } ->
        java_script_function_name(function)
            + "("
            + java_script_expression_code(index.receiver, env, module, allModules)
            + java_script_index_argument_tail(index, env, module, allModules)
            + ")"
    case None -> "__capy_unsupported('index get')"

/// Formats the recursive tail segment for index argument.
private fun java_script_index_argument_tail(index: CompiledIndexExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if index.hasEndIndex
    then ", "
        + java_script_expression_code(index.index, env, module, allModules)
        + ", "
        + java_script_expression_code(index.endIndex, env, module, allModules)
    else ", " + java_script_expression_code(index.index, env, module, allModules)

/// Emits JavaScript code for slice start.
private fun java_script_slice_start_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if literal.source == "__capy_slice_start__"
        then "0"
        else java_script_expression_code(expression, env, module, allModules)
    case _ -> java_script_expression_code(expression, env, module, allModules)

/// Emits JavaScript code for slice end.
private fun java_script_slice_end_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral literal ->
        if literal.source == "__capy_slice_end__"
        then "undefined"
        else java_script_expression_code(expression, env, module, allModules)
    case _ -> java_script_expression_code(expression, env, module, allModules)

/// Emits JavaScript code for reduce expression.
private fun java_script_reduce_expression_code(reduce: CompiledReduceExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let reduceEnv = java_script_reduce_bindings(reduce, env)
    let keyed = if reduce.keyName.is_empty() then "false" else "true"
    "__capy_reduce("
        + java_script_expression_code(reduce.receiver, env, module, allModules)
        + ", "
        + java_script_expression_code(reduce.initial, env, module, allModules)
        + ", "
        + keyed
        + ", ("
        + java_script_reduce_parameters(reduce)
        + ") => "
        + java_script_expression_code(reduce.body, reduceEnv, module, allModules)
        + ")"

/// Formats reduce parameters for JavaScript emission.
private fun java_script_reduce_parameters(reduce: CompiledReduceExpression): String =
    if reduce.keyName.is_empty()
    then java_script_identifier(reduce.accumulatorName) + ", " + java_script_identifier(reduce.valueName)
    else java_script_identifier(reduce.accumulatorName) + ", " + java_script_identifier(reduce.keyName) + ", " + java_script_identifier(reduce.valueName)

/// Creates JavaScript name/type bindings for reduce.
private fun java_script_reduce_bindings(reduce: CompiledReduceExpression, env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    if reduce.keyName.is_empty()
    then [
            JavaScriptBinding { name: reduce.accumulatorName, jsName: java_script_identifier(reduce.accumulatorName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.valueName, jsName: java_script_identifier(reduce.valueName), typeName: java_script_unknown_type() },
        ] + env
    else [
            JavaScriptBinding { name: reduce.accumulatorName, jsName: java_script_identifier(reduce.accumulatorName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.keyName, jsName: java_script_identifier(reduce.keyName), typeName: java_script_unknown_type() },
            JavaScriptBinding { name: reduce.valueName, jsName: java_script_identifier(reduce.valueName), typeName: java_script_unknown_type() },
        ] + env

/// Emits JavaScript code for match expression.
private fun java_script_match_expression_code(matchExpression: CompiledMatchExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_match_supported(matchExpression)
    then "((__capy_match_value) => " + java_script_match_cases_code(java_script_ordered_match_cases(matchExpression.cases), env, module, allModules) + ")("
        + java_script_expression_code(matchExpression.value, env, module, allModules) + ")"
    else "__capy_unsupported('match')"

/// Collects ordered match cases for JavaScript processing.
private fun java_script_ordered_match_cases(cases: List[CompiledMatchCase]): List[CompiledMatchCase] =
    java_script_match_cases_with_guard(cases, true) + java_script_match_cases_with_guard(cases, false)

/// Collects match cases with guard for JavaScript processing.
private fun java_script_match_cases_with_guard(cases: List[CompiledMatchCase], guarded: bool): List[CompiledMatchCase] =
    match cases[0] with
    case None -> []
    case Some { matchCase } ->
        if matchCase.hasGuard == guarded
        then [matchCase] + java_script_match_cases_with_guard(cases[1:], guarded)
        else java_script_match_cases_with_guard(cases[1:], guarded)

/// Emits JavaScript code for match cases.
private fun java_script_match_cases_code(cases: List[CompiledMatchCase], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match cases[0] with
    case None -> "__capy_no_match(__capy_match_value)"
    case Some { matchCase } ->
        "(" + java_script_match_case_condition_code(matchCase, env, module, allModules)
            + " ? "
            + java_script_match_case_body_code(matchCase, env, module, allModules)
            + " : "
            + java_script_match_cases_code(cases[1:], env, module, allModules)
            + ")"

/// Emits JavaScript code for match case condition.
private fun java_script_match_case_condition_code(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let base = if matchCase.wildcard
        then "true"
        else if matchCase.hasLiteral
        then "__capy_match_value === " + java_script_expression_code(matchCase.literal, env, module, allModules)
        else "__capy_type_matches(__capy_match_value, " + java_script_string_literal(matchCase.typeName) + ")"
    if matchCase.hasGuard
    then "(" + base + " && " + java_script_match_case_guard_code(matchCase, env, module, allModules) + ")"
    else base

/// Emits JavaScript code for match case guard.
private fun java_script_match_case_guard_code(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let caseEnv = java_script_match_case_env(matchCase, env)
    let guard = java_script_truthy_expression_code(matchCase.guard, caseEnv, module, allModules)
    if matchCase.bindings.is_empty()
    then guard
    else "((" + java_script_match_case_parameters(matchCase.bindings) + ") => "
        + guard
        + ")(" + java_script_match_case_arguments(matchCase) + ")"

/// Emits JavaScript code for match case body.
private fun java_script_match_case_body_code(matchCase: CompiledMatchCase, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let caseEnv = java_script_match_case_env(matchCase, env)
    if matchCase.bindings.is_empty()
    then java_script_expression_code(matchCase.body, caseEnv, module, allModules)
    else "((" + java_script_match_case_parameters(matchCase.bindings) + ") => "
        + java_script_expression_code(matchCase.body, caseEnv, module, allModules)
        + ")(" + java_script_match_case_arguments(matchCase) + ")"

/// Formats match case parameters for JavaScript emission.
private fun java_script_match_case_parameters(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> java_script_identifier(binding) + java_script_match_case_parameter_tail(bindings[1:])

/// Formats the recursive tail segment for match case parameter.
private fun java_script_match_case_parameter_tail(bindings: List[String]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } -> ", " + java_script_identifier(binding) + java_script_match_case_parameter_tail(bindings[1:])

/// Formats match case arguments for JavaScript emission.
private fun java_script_match_case_arguments(matchCase: CompiledMatchCase): String =
    java_script_match_case_binding_arguments(matchCase.bindings, 0, matchCase.bindsWholeValue)

/// Formats match case binding arguments for JavaScript emission.
private fun java_script_match_case_binding_arguments(bindings: List[String], idx: int, bindsWholeValue: bool): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        if bindsWholeValue
        then "__capy_match_value" + java_script_match_case_argument_tail(bindings[1:], idx + 1, bindsWholeValue)
        else "__capy_match_binding(__capy_match_value, " + java_script_string_literal(binding) + ", " + idx + ")"
            + java_script_match_case_argument_tail(bindings[1:], idx + 1, bindsWholeValue)

/// Formats the recursive tail segment for match case argument.
private fun java_script_match_case_argument_tail(bindings: List[String], idx: int, bindsWholeValue: bool): String =
    match bindings[0] with
    case None -> ""
    case Some _ -> ", " + java_script_match_case_binding_arguments(bindings, idx, bindsWholeValue)

/// Collects match case environmentironment for JavaScript processing.
private fun java_script_match_case_env(matchCase: CompiledMatchCase, env: List[JavaScriptBinding]): List[JavaScriptBinding] =
    java_script_match_case_bindings(matchCase.bindings) + env

/// Creates JavaScript name/type bindings for match case.
private fun java_script_match_case_bindings(bindings: List[String]): List[JavaScriptBinding] =
    match bindings[0] with
    case None -> []
    case Some { binding } ->
        [JavaScriptBinding { name: binding, jsName: java_script_identifier(binding), typeName: java_script_unknown_type() }]
            + java_script_match_case_bindings(bindings[1:])

/// Emits JavaScript code for block expression.
private fun java_script_block_expression_code(block: CompiledBlockExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_block_has_result_binding(block.bindings, env, module, allModules)
    then java_script_result_block_expression_code(block.bindings, block.result, env, module, allModules)
    else if java_script_block_has_effect_binding(block.bindings)
    then java_script_effect_block_expression_code(block.bindings, block.result, env, module, allModules)
    else java_script_plain_block_expression_code(block.bindings, block.result, env, module, allModules)

/// Emits JavaScript code for plain block expression.
private fun java_script_plain_block_expression_code(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "(() => { "
        + java_script_block_binding_statements(bindings, env, module, allModules)
        + "return "
        + java_script_expression_code(result, java_script_block_env(bindings, env, module, allModules), module, allModules)
        + "; })()"

/// Emits JavaScript code for effect block expression.
private fun java_script_effect_block_expression_code(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> java_script_effect_block_result_code(result, env, module, allModules)
    case Some { binding } ->
        if binding.operator == "<-"
        then java_script_effect_binding_code(binding, bindings[1:], result, env, module, allModules)
        else
            let jsBinding = java_script_let_binding(binding, env, module, allModules)
            "(() => { const "
            + jsBinding.jsName
            + " = "
            + java_script_expression_code(binding.value, env, module, allModules)
            + "; return "
            + java_script_effect_block_expression_code(bindings[1:], result, [jsBinding] + env, module, allModules)
            + "; })()"

/// Emits JavaScript code for effect block result.
private fun java_script_effect_block_result_code(result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_expression_type(result, env, module, allModules) == "Effect"
    then java_script_expression_code(result, env, module, allModules)
    else "pure(" + java_script_expression_code(result, env, module, allModules) + ")"

/// Emits JavaScript code for effect binding.
private fun java_script_effect_binding_code(binding: CompiledLetBinding, rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let jsBinding = java_script_let_binding(binding, env, module, allModules)
    let nextEnv = [jsBinding] + env
    java_script_expression_code(binding.value, env, module, allModules)
        + "."
        + java_script_effect_binding_method(rest, result, nextEnv, module, allModules)
        + "(("
        + jsBinding.jsName
        + ") => "
        + java_script_effect_binding_body(rest, result, nextEnv, module, allModules)
        + ")"

/// Formats JavaScript source text for effect binding method.
private fun java_script_effect_binding_method(rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_block_has_effect_binding(rest) | java_script_effect_block_result_type(rest, result, env, module, allModules) == "Effect"
    then "flat_map"
    else "map"

/// Emits JavaScript expression text for effect binding body.
private fun java_script_effect_binding_body(rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_block_has_effect_binding(rest)
    then java_script_effect_block_expression_code(rest, result, env, module, allModules)
    else java_script_plain_block_expression_code(rest, result, env, module, allModules)

/// Computes the JavaScript type for effect block result.
private fun java_script_effect_block_result_type(rest: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_expression_type(result, java_script_block_env(rest, env, module, allModules), module, allModules)

/// Checks whether the current value satisfies the block has effect binding rule for JavaScript processing.
private fun java_script_block_has_effect_binding(bindings: List[CompiledLetBinding]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } -> binding.operator == "<-" | java_script_block_has_effect_binding(bindings[1:])

/// Checks whether the current value satisfies the block has result binding rule for JavaScript processing.
private fun java_script_block_has_result_binding(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match bindings[0] with
    case None -> false
    case Some { binding } ->
        let jsBinding = java_script_let_binding(binding, env, module, allModules)
        if binding.operator == "<-"
        then
            if java_script_result_pipe_receiver_type(java_script_expression_type(binding.value, env, module, allModules))
            then true
            else java_script_block_has_result_binding(bindings[1:], [jsBinding] + env, module, allModules)
        else java_script_block_has_result_binding(bindings[1:], [jsBinding] + env, module, allModules)

/// Emits JavaScript code for result block expression.
private fun java_script_result_block_expression_code(bindings: List[CompiledLetBinding], result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultEnv = java_script_block_env(bindings, env, module, allModules)
    "(() => { "
        + java_script_result_block_binding_statements(bindings, env, module, allModules)
        + "return "
        + java_script_result_block_result_code(result, resultEnv, module, allModules)
        + "; })()"

/// Emits JavaScript statements for result block binding.
private fun java_script_result_block_binding_statements(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let jsBinding = java_script_let_binding(binding, env, module, allModules)
        java_script_result_block_binding_statement(binding, jsBinding, env, module, allModules)
            + java_script_result_block_binding_statements(bindings[1:], [jsBinding] + env, module, allModules)

/// Emits one JavaScript statement for result block binding.
private fun java_script_result_block_binding_statement(binding: CompiledLetBinding, jsBinding: JavaScriptBinding, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding.operator == "<-"
    then
        if java_script_result_pipe_receiver_type(java_script_expression_type(binding.value, env, module, allModules))
        then java_script_result_bind_statement(binding, jsBinding, env, module, allModules)
        else java_script_plain_result_block_binding_statement(binding, jsBinding, env, module, allModules)
    else java_script_plain_result_block_binding_statement(binding, jsBinding, env, module, allModules)

/// Emits a regular JavaScript const statement inside a result-aware block.
private fun java_script_plain_result_block_binding_statement(binding: CompiledLetBinding, jsBinding: JavaScriptBinding, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "const "
        + jsBinding.jsName
        + " = "
        + java_script_expression_code(binding.value, env, module, allModules)
        + "; "

/// Emits one JavaScript statement for result bind.
private fun java_script_result_bind_statement(binding: CompiledLetBinding, jsBinding: JavaScriptBinding, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let bindName = "__capy_bind_" + jsBinding.jsName
    "const "
        + bindName
        + " = "
        + java_script_expression_code(binding.value, env, module, allModules)
        + "; if (!__capy_type_matches("
        + bindName
        + ", "
        + java_script_string_literal("Success")
        + ")) return "
        + bindName
        + "; const "
        + jsBinding.jsName
        + " = __capy_match_binding("
        + bindName
        + ", "
        + java_script_string_literal("value")
        + ", 0); "

/// Emits JavaScript code for result block result.
private fun java_script_result_block_result_code(result: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let resultType = java_script_expression_type(result, env, module, allModules)
    let resultCode = java_script_expression_code(result, env, module, allModules)
    if java_script_result_pipe_receiver_type(resultType)
    then resultCode
    else "__capy_data(" + java_script_string_literal("Success") + ", {" + java_script_string_literal("value") + ": " + resultCode + "})"

/// Emits JavaScript statements for block binding.
private fun java_script_block_binding_statements(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match bindings[0] with
    case None -> ""
    case Some { binding } ->
        let jsBinding = java_script_let_binding(binding, env, module, allModules)
        "const "
            + jsBinding.jsName
            + " = "
            + java_script_expression_code(binding.value, env, module, allModules)
            + "; "
            + java_script_block_binding_statements(bindings[1:], [jsBinding] + env, module, allModules)

/// Collects block environmentironment for JavaScript processing.
private fun java_script_block_env(bindings: List[CompiledLetBinding], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): List[JavaScriptBinding] =
    match bindings[0] with
    case None -> env
    case Some { binding } -> java_script_block_env(bindings[1:], [java_script_let_binding(binding, env, module, allModules)] + env, module, allModules)

/// Creates one JavaScript name/type binding for let.
private fun java_script_let_binding(binding: CompiledLetBinding, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): JavaScriptBinding =
    JavaScriptBinding { name: binding.name, jsName: java_script_let_binding_name(binding), typeName: java_script_let_binding_type(binding, env, module, allModules) }

/// Computes the JavaScript name for let binding.
private fun java_script_let_binding_name(binding: CompiledLetBinding): String =
    java_script_identifier(binding.name) + "__local__" + binding.location.line + "_" + binding.location.column

/// Computes the JavaScript type for let binding.
private fun java_script_let_binding_type(binding: CompiledLetBinding, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if binding.typeReference.name.is_empty()
    then if binding.operator == "<-"
        then java_script_effect_binding_payload_type(binding.value, env, module, allModules)
        else java_script_expression_type(binding.value, env, module, allModules)
    else binding.typeReference.name

/// Computes the JavaScript type for effect binding payload.
private fun java_script_effect_binding_payload_type(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledFunctionCallExpression call ->
        if java_script_oo_constructor_call(call.name, module, allModules)
        then java_script_oo_constructor_call_payload_type(call.name, module, allModules)
        else java_script_effect_payload_type_from_function_call(call.name, module, allModules)
    case CompiledMethodCallExpression call -> java_script_effect_payload_type_from_method_call(call, env, module, allModules)
    case _ -> java_script_unknown_type()

private fun java_script_effect_payload_type_from_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_async_join_method_call(call, env, module, allModules)
    then "Result"
    else java_script_unknown_type()

/// Emits JavaScript expression text for effect payload type from function call.
private fun java_script_effect_payload_type_from_function_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_qualified_call_name(name)
    then java_script_find_qualified_function_effect_payload_type(name, module, allModules)
    else match java_script_find_local_function(name, module.functions) with
    case Some { function } -> java_script_effect_payload_type_from_type_reference(function.returnType)
    case None ->
        match java_script_find_function_definition_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> java_script_effect_payload_type_from_type_reference(function.returnType)
        case None -> java_script_unknown_type()

/// Formats type metadata text for effect payload type from type reference.
private fun java_script_effect_payload_type_from_type_reference(typeReference: CompiledTypeReference): String =
    if typeReference.name == "Effect"
    then java_script_first_type_argument_name(typeReference.arguments)
    else java_script_unknown_type()

/// Emits JavaScript code for truthy expression.
private fun java_script_truthy_expression_code(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_truthy_code(java_script_expression_code(expression, env, module, allModules))

/// Emits JavaScript code for truthy.
private fun java_script_truthy_code(code: String): String =
    "__capy_truthy(" + code + ")"

/// Computes the JavaScript type for expression.
private fun java_script_expression_type(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledIntLiteral _ -> "int"
    case CompiledLongLiteral _ -> "long"
    case CompiledFloatLiteral _ -> "float"
    case CompiledDoubleLiteral _ -> "double"
    case CompiledBoolLiteral _ -> "bool"
    case CompiledStringLiteral _ -> "String"
    case CompiledVariableExpression variable -> java_script_variable_type(variable.name, env, module, allModules)
    case CompiledBinaryExpression binary -> java_script_binary_expression_type(binary, env, module, allModules)
    case CompiledFunctionCallExpression call ->
        if java_script_stdlib_math_sqrt_call(call, module)
        then "float"
        else java_script_function_call_expression_type(call.name, module, allModules)
    case CompiledMethodCallExpression call -> java_script_method_call_expression_type(call, env, module, allModules)
    case CompiledListLiteral _ -> "List"
    case CompiledSetLiteral _ -> "Set"
    case CompiledDictLiteral _ -> "Dict"
    case CompiledTupleLiteral _ -> "Tuple"
    case CompiledIndexExpression index -> java_script_index_expression_type(index, env, module, allModules)
    case CompiledDataLiteral literal -> java_script_data_literal_expression_type(literal, env, module, allModules)
    case CompiledFieldAccessExpression access -> java_script_field_access_type(access, env, module, allModules)
    case CompiledReduceExpression reduce -> java_script_expression_type(reduce.initial, env, module, allModules)
    case CompiledWithExpression withExpression -> java_script_with_expression_type(withExpression, env, module, allModules)
    case CompiledBlockExpression block -> java_script_expression_type(block.result, java_script_block_env(block.bindings, env, module, allModules), module, allModules)
    case CompiledIfExpression ifExpression ->
        let thenType = java_script_expression_type(ifExpression.thenBranch, env, module, allModules)
        let elseType = java_script_expression_type(ifExpression.elseBranch, env, module, allModules)
        if thenType == elseType then thenType else java_script_unknown_type()
    case _ -> java_script_unknown_type()

/// Infers the expression type for binary.
private fun java_script_binary_expression_type(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = java_script_expression_type(binary.left, env, module, allModules)
    if java_script_result_reduce_operator_expression_with_left_type(binary, leftType)
    then java_script_result_reduce_operator_type(binary, env, module, allModules)
    else if java_script_collection_pipe_chained_method_expression_with_left_type(binary, leftType)
    then java_script_method_call_expression_type(java_script_collection_pipe_chained_method_call(binary), env, module, allModules)
    else if java_script_async_pipe_expression_with_left_type(binary, leftType)
    then "Async"
    else if java_script_result_pipe_expression_with_left_type(binary, leftType)
    then "Result"
    else if java_script_option_pipe_expression_with_left_type(binary, leftType)
    then "Option"
    else if java_script_collection_or_unknown_pipe_expression_with_left_type(binary, leftType)
    then java_script_collection_pipe_result_type(binary.operator, leftType)
    else if java_script_set_binary_expression_with_left_type(binary, leftType)
    then java_script_set_binary_expression_type(binary.operator)
    else if java_script_regex_binary_expression_with_left_type(binary, leftType)
    then java_script_regex_binary_expression_type(binary.operator)
    else match java_script_find_local_binary_extension_operator_with_left_type(binary, leftType, module.functions) with
    case Some { function } -> function.returnType.name
    case None ->
        if binary.operator == "&" | binary.operator == "|"
            | binary.operator == "==" | binary.operator == "!="
            | binary.operator == ">" | binary.operator == "<"
            | binary.operator == ">=" | binary.operator == "<="
            | binary.operator == "?"
        then "bool"
        else java_script_unknown_type()

/// Infers the expression type for set binary.
private fun java_script_set_binary_expression_type(operator: String): String =
    if java_script_set_predicate_operator(operator)
    then "bool"
    else "Set"

/// Infers the expression type for regex binary.
private fun java_script_regex_binary_expression_type(operator: String): String =
    if operator == "?"
    then "bool"
    else if operator == "~"
    then "Option"
    else if operator == "~~"
    then "Seq"
    else if operator == "~>"
    then java_script_string_to_string_function_type()
    else "List"

/// Computes the JavaScript type for result reduce operator.
private fun java_script_result_reduce_operator_type(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledTupleLiteral literal -> java_script_result_reduce_success_type(binary.left, literal.values, env, module, allModules)
    case _ -> java_script_unknown_type()

/// Computes the JavaScript type for result reduce success.
private fun java_script_result_reduce_success_type(receiver: CompiledExpression, arguments: List[CompiledExpression], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match arguments[0] with
    case None -> java_script_unknown_type()
    case Some { argument } ->
        match argument with
        case CompiledLambdaExpression lambda ->
            java_script_expression_type(
                lambda.body,
                java_script_lambda_bindings_with_single_type(lambda.parameters, java_script_result_payload_type(receiver, env, module, allModules)) + env,
                module,
                allModules
            )
        case CompiledFunctionReferenceExpression reference -> java_script_function_call_expression_type(reference.name, module, allModules)
        case _ -> java_script_unknown_type()

/// Infers the expression type for index.
private fun java_script_index_expression_type(index: CompiledIndexExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_type_unqualified_name(java_script_expression_type(index.receiver, env, module, allModules))
    if !java_script_built_in_index_expression(index, receiverType)
    then match java_script_find_local_method_function(receiverType, "get", module.functions) with
        case Some { function } -> function.returnType.name
        case None -> java_script_unknown_type()
    else if index.hasEndIndex
    then receiverType
    else if receiverType == "Tuple"
    then java_script_unknown_type()
    else "Option"

/// Computes the JavaScript type for field access.
private fun java_script_field_access_type(access: CompiledFieldAccessExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_enum_static_field_access(access, env, module, allModules)
    then java_script_enum_static_field_access_type(access)
    else
        let receiverType = java_script_expression_type(access.receiver, env, module, allModules)
        if receiverType == java_script_unknown_type()
        then java_script_unknown_type()
        else match java_script_object_field_type(access.name, receiverType, module, allModules) with
        case Some { typeName } -> typeName
        case None -> java_script_data_field_type(access.name, java_script_data_type_fields(receiverType, module, allModules))

/// Computes the JavaScript type for object field.
private fun java_script_object_field_type(name: String, receiverType: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let className = java_script_type_unqualified_name(receiverType)
    match java_script_object_field_type_in_functions(name, className, module.functions) with
    case Some { typeName } -> /capy/lang/Option.Some { typeName }
    case None -> java_script_object_field_type_in_modules(name, className, allModules)

/// Creates JavaScript generated-module entries for object field type in a.
private fun java_script_object_field_type_in_modules(name: String, className: String, modules: List[CompiledModule]): /capy/lang/Option[String] =
    match modules[0] with
    case None -> /capy/lang/Option.None {}
    case Some { module } ->
        match java_script_object_field_type_in_functions(name, className, module.functions) with
        case Some { typeName } -> /capy/lang/Option.Some { typeName }
        case None -> java_script_object_field_type_in_modules(name, className, modules[1:])

/// Resolves type metadata for object field type in functions.
private fun java_script_object_field_type_in_functions(name: String, className: String, functions: List[CompiledFunction]): /capy/lang/Option[String] =
    java_script_object_field_type_in_fields(name, java_script_schema_values(java_script_object_field_schema_prefix(className), functions))

/// Resolves type metadata for object field type in fields.
private fun java_script_object_field_type_in_fields(name: String, fields: List[String]): /capy/lang/Option[String] =
    match fields[0] with
    case None -> /capy/lang/Option.None {}
    case Some { field } ->
        if java_script_schema_field_name(field) == name
        then /capy/lang/Option.Some { java_script_object_field_schema_type(field) }
        else java_script_object_field_type_in_fields(name, fields[1:])

/// Computes the JavaScript type for data field.
private fun java_script_data_field_type(name: String, fields: List[String]): String =
    match fields[0] with
    case None -> java_script_unknown_type()
    case Some { field } ->
        if java_script_schema_field_name(field) == name
        then java_script_schema_field_type_name(field)
        else java_script_data_field_type(name, fields[1:])

/// Infers the expression type for method call.
private fun java_script_method_call_expression_type(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if call.name == "__capy_call"
    then java_script_callable_call_expression_type(call, env, module, allModules)
    else if java_script_size_method_call(call)
    then "int"
    else
        let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
        let receiverBaseType = java_script_type_unqualified_name(receiverType)
        let emptyArguments = call.arguments.is_empty()
        let oneArgument = java_script_one_method_argument(call.arguments)
        let twoArguments = java_script_two_method_arguments(call.arguments)
        if call.name == "name" & emptyArguments & java_script_enum_name_receiver_type(receiverType, module, allModules)
        then "String"
        else if call.name == "to_string" & emptyArguments & java_script_char_to_string_receiver_type(receiverType)
        then "String"
        else if call.name == "get" & (oneArgument | twoArguments) & receiverType == "String"
        then java_script_string_get_method_return_type(call)
        else if java_script_string_parse_method_name(call.name) & emptyArguments & java_script_string_parse_receiver_type(receiverType)
        then "Result"
        else if java_script_string_method_arity(call.name, call.arguments) & java_script_string_method_receiver_type(call.name, receiverType)
        then java_script_string_method_return_type(call.name)
        else if java_script_regex_method_arity(call) & java_script_regex_receiver_type(receiverType)
        then java_script_regex_method_call_type(call.name)
        else if java_script_date_time_method_candidate(call.name, emptyArguments, oneArgument, twoArguments)
            & java_script_date_time_method_call(receiverBaseType, call.name, emptyArguments, oneArgument, twoArguments)
        then java_script_date_time_method_call_type(receiverBaseType, call.name)
        else if call.name == "start" & emptyArguments & receiverType == "Effect"
        then "Async"
        else if call.name == "join" & emptyArguments & receiverBaseType == "Async"
        then "Effect"
        else if java_script_async_map_method_name(call.name) & java_script_single_callable_argument(call.arguments) & receiverBaseType == "Async"
        then "Async"
        else if (call.name == "map" | call.name == "flat_map" | call.name == "flatMap") & java_script_single_callable_argument(call.arguments) & receiverType == "Effect"
        then "Effect"
        else if call.name == "is_empty" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then "bool"
        else if call.name == "get" & (oneArgument | twoArguments) & java_script_collection_get_receiver_type(receiverBaseType) & java_script_collection_get_arity(receiverBaseType, call.arguments)
        then if receiverBaseType == "List" & twoArguments
            then "List"
            else if receiverBaseType == "Tuple"
            then java_script_unknown_type()
            else "Option"
        else if (call.name == "contains" | call.name == "contains_key") & oneArgument & ((call.name == "contains" & java_script_collection_contains_receiver_type(receiverBaseType)) | (call.name == "contains_key" & receiverBaseType == "Dict"))
        then "bool"
        else if java_script_set_method_arity(call) & receiverBaseType == "Set"
        then java_script_set_method_return_type(call.name)
        else if java_script_seq_as_list_call(call)
        then "List"
        else if call.name == "first" & emptyArguments & java_script_collection_receiver_type(receiverType)
        then "Option"
        else if java_script_collection_method_name(call.name) & java_script_single_callable_argument(call.arguments) & java_script_collection_pipe_receiver_type(receiverType)
        then java_script_collection_pipe_result_type(java_script_collection_method_operator(call.name), receiverType)
        else if java_script_collection_reduce_method_call_with_receiver_type(call, receiverType)
        then java_script_collection_reduce_method_type(call, env, module, allModules)
        else if (call.name == "any" | call.name == "all") & java_script_single_callable_argument(call.arguments) & java_script_collection_receiver_type(receiverType)
        then "bool"
        else if java_script_primitive_conversion_method(call.name) & emptyArguments & java_script_primitive_conversion_receiver(call.name, receiverType)
        then java_script_primitive_conversion_result_type(call.name)
        else if (call.name == "reduce" | call.name == "reduce_left") & twoArguments & java_script_result_pipe_receiver_type(receiverType)
        then java_script_unknown_type()
        else match java_script_find_local_extension_method_with_receiver_type(receiverType, call, module) with
        case Some { function } -> function.returnType.name
        case None ->
            match java_script_find_imported_extension_method_return_type_with_receiver_type(receiverType, call, module, allModules) with
            case Some { returnType } -> returnType
            case None -> java_script_unknown_type()

/// Infers the expression type for callable call.
private fun java_script_callable_call_expression_type(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_expression_type(call.receiver, env, module, allModules)
    if java_script_callable_binding_type(receiverType)
    then java_script_callable_return_type(receiverType)
    else java_script_unknown_type()

/// Computes the JavaScript type for callable return.
private fun java_script_callable_return_type(typeName: String): String =
    let arrow = java_script_first_index_of(typeName, ">", 0)
    if arrow < 0 | arrow >= typeName.size().value - 1
    then java_script_unknown_type()
    else typeName[arrow + 1, typeName.size().value]

/// Computes the JavaScript type for result payload.
private fun java_script_result_payload_type(expression: CompiledExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match expression with
    case CompiledBinaryExpression binary -> java_script_result_payload_type_from_binary(binary, env, module, allModules)
    case CompiledFunctionCallExpression call -> java_script_result_payload_type_from_function_call(call.name, module, allModules)
    case CompiledMethodCallExpression call -> java_script_result_payload_type_from_method_call(call, env, module, allModules)
    case CompiledWithExpression withExpression -> java_script_result_payload_type_from_with_expression(withExpression, env, module, allModules)
    case CompiledDataLiteral literal -> java_script_result_payload_type_from_data_literal(literal, env, module, allModules)
    case CompiledIfExpression ifExpression -> java_script_result_payload_type(ifExpression.thenBranch, env, module, allModules)
    case CompiledBlockExpression block -> java_script_result_payload_type(block.result, java_script_block_env(block.bindings, env, module, allModules), module, allModules)
    case CompiledReduceExpression reduce -> java_script_result_payload_type(reduce.initial, env, module, allModules)
    case _ -> java_script_unknown_type()

/// Formats type metadata text for result payload type from binary.
private fun java_script_result_payload_type_from_binary(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let leftType = java_script_expression_type(binary.left, env, module, allModules)
    if java_script_result_pipe_expression_with_left_type(binary, leftType)
    then java_script_result_pipe_payload_type(binary, env, module, allModules)
    else java_script_unknown_type()

/// Computes the JavaScript type for result pipe payload.
private fun java_script_result_pipe_payload_type(binary: CompiledBinaryExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match binary.right with
    case CompiledLambdaExpression lambda ->
        let lambdaEnv = java_script_lambda_bindings_with_single_type(lambda.parameters, java_script_result_payload_type(binary.left, env, module, allModules)) + env
        let bodyType = java_script_expression_type(lambda.body, lambdaEnv, module, allModules)
        if java_script_result_pipe_receiver_type(bodyType)
        then java_script_result_payload_type(lambda.body, lambdaEnv, module, allModules)
        else bodyType
    case CompiledFunctionReferenceExpression reference -> java_script_result_payload_type_from_function_call(reference.name, module, allModules)
    case _ -> java_script_unknown_type()

/// Emits JavaScript expression text for result payload type from function call.
private fun java_script_result_payload_type_from_function_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_stdlib_parse_function_call_by_name(name, module)
    then java_script_parse_function_result_payload_type(name)
    else if java_script_enum_parse_call_name(name, module, allModules)
    then java_script_enum_qualified_type_name(name)
    else if java_script_qualified_call_name(name)
    then java_script_find_qualified_function_result_payload_type(name, module, allModules)
    else match java_script_find_local_function(name, module.functions) with
    case Some { function } -> java_script_result_payload_type_from_type_reference(function.returnType)
    case None ->
        match java_script_find_function_definition_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> java_script_result_payload_type_from_type_reference(function.returnType)
        case None -> java_script_unknown_type()

private fun java_script_parse_function_result_payload_type(name: String): String =
    if name == "to_int"
    then "int"
    else if name == "to_long"
    then "long"
    else if name == "to_double"
    then "double"
    else if name == "to_float"
    then "float"
    else "bool"

/// Emits JavaScript expression text for result payload type from method call.
private fun java_script_result_payload_type_from_method_call(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_string_parse_method_call(call, env, module, allModules)
    then java_script_string_parse_payload_type(call.name)
    else java_script_unknown_type()

/// Emits JavaScript expression text for result payload type from with expression.
private fun java_script_result_payload_type_from_with_expression(withExpression: CompiledWithExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_with_expression_receiver_type(withExpression, env, module, allModules)
    let constructorTypes = java_script_data_constructor_type_names(receiverType, module, allModules)
    if java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
    then receiverType
    else java_script_unknown_type()

/// Computes the JavaScript type for string parse payload.
private fun java_script_string_parse_payload_type(name: String): String =
    if name == "to_int"
    then "int"
    else if name == "to_long"
    then "long"
    else if name == "to_double"
    then "double"
    else if name == "to_float"
    then "float"
    else "bool"

/// Formats result payload type from data as a JavaScript literal.
private fun java_script_result_payload_type_from_data_literal(literal: CompiledDataLiteral, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_type_unqualified_name(literal.typeName) == "Success"
    then java_script_success_literal_payload_type(literal.fields, env, module, allModules)
    else
        let declaredTypeName = java_script_data_literal_declared_type_name(literal.typeName)
        let constructorTypes = java_script_data_constructor_type_names(declaredTypeName, module, allModules)
        if java_script_raw_data_literal(literal.typeName)
        then java_script_unknown_type()
        else if java_script_data_constructor_pipeline_returns_result(constructorTypes, module, allModules)
        then declaredTypeName
        else java_script_unknown_type()

/// Computes the JavaScript type for success literal payload.
private fun java_script_success_literal_payload_type(fields: List[CompiledDataField], env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match fields[0] with
    case None -> java_script_unknown_type()
    case Some { field } ->
        if field.name == "value" | field.name == "$0"
        then java_script_expression_type(field.value, env, module, allModules)
        else java_script_success_literal_payload_type(fields[1:], env, module, allModules)

/// Formats type metadata text for result payload type from type reference.
private fun java_script_result_payload_type_from_type_reference(typeReference: CompiledTypeReference): String =
    if java_script_result_pipe_receiver_type(typeReference.name)
    then java_script_first_type_argument_name(typeReference.arguments)
    else java_script_unknown_type()

/// Computes the JavaScript name for first type argument.
private fun java_script_first_type_argument_name(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> java_script_unknown_type()
    case Some { argument } -> argument.name

/// Computes the JavaScript type for string get method return.
private fun java_script_string_get_method_return_type(call: CompiledMethodCallExpression): String =
    if java_script_two_method_arguments(call.arguments)
    then "String"
    else "Option"

/// Computes the JavaScript type for set method return.
private fun java_script_set_method_return_type(name: String): String =
    if name == "contains"
        | name == "is_subset_of" | name == "is_proper_subset_of"
        | name == "is_superset_of" | name == "is_proper_superset_of"
    then "bool"
    else "Set"

/// Computes the JavaScript type for collection get return.
private fun java_script_collection_get_return_type(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let receiverType = java_script_type_unqualified_name(java_script_expression_type(call.receiver, env, module, allModules))
    if receiverType == "List" & java_script_two_method_arguments(call.arguments)
    then "List"
    else if receiverType == "Tuple"
    then java_script_unknown_type()
    else "Option"

/// Computes the JavaScript type for collection reduce method.
private fun java_script_collection_reduce_method_type(call: CompiledMethodCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match call.arguments[0] with
    case None -> java_script_unknown_type()
    case Some { initial } -> java_script_expression_type(initial, env, module, allModules)

/// Computes the JavaScript type for string method return.
private fun java_script_string_method_return_type(name: String): String =
    if name == "trim" | name == "replace"
    then "String"
    else "bool"

/// Computes the JavaScript type for regex method call.
private fun java_script_regex_method_call_type(name: String): String =
    if name == "matches"
    then "bool"
    else if name == "find"
    then "Option"
    else if name == "find_all"
    then "Seq"
    else if name == "replace"
    then java_script_string_to_string_function_type()
    else "List"

/// Computes the JavaScript type for date time method call.
private fun java_script_date_time_method_call_type(receiver: String, methodName: String): String =
    if receiver == java_script_unknown_type()
    then java_script_unknown_date_time_method_return_type(methodName)
    else java_script_stdlib_date_time_method_return_type(receiver, methodName)

/// Computes the JavaScript type for unknown date time method return.
private fun java_script_unknown_date_time_method_return_type(name: String): String =
    if name == "add_days" | name == "add_years_months"
    then "Date"
    else if name == "add_seconds"
    then "Time"
    else if name == "plus"
    then "DateTime"
    else if name == "minus"
    then "Duration"
    else java_script_unknown_type()

/// Computes the JavaScript type for standard-library date time method return.
private fun java_script_stdlib_date_time_method_return_type(receiver: String, name: String): String =
    if receiver == "Date"
    then if name == "to_days_since_unix_epoch" then "int" else if name == "to_iso_8601" then "String" else "Date"
    else if receiver == "Time"
    then if name == "to_seconds" then "int" else if name == "to_iso_8601" then "String" else "Time"
    else if receiver == "DateTime"
    then java_script_stdlib_date_time_value_method_return_type(name)
    else java_script_stdlib_duration_method_call_type(name)

/// Computes the JavaScript type for standard-library date time value method return.
private fun java_script_stdlib_date_time_value_method_return_type(name: String): String =
    if name == "to_iso_8601"
    then "String"
    else if name == "timestamp"
    then "long"
    else if name == "plus"
    then "DateTime"
    else if name == "minus"
    then "Duration"
    else "DateTime"

/// Computes the JavaScript type for standard-library duration method call.
private fun java_script_stdlib_duration_method_call_type(name: String): String =
    if name == "to_iso_8601"
    then "String"
    else if name == "negate"
    then "Duration"
    else "int"

/// Infers the expression type for function call.
private fun java_script_function_call_expression_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_runtime_function(name)
    then java_script_runtime_function_type(name)
    else if java_script_object_type_call_name(name)
    then "ObjectInfo"
    else if java_script_oo_constructor_call(name, module, allModules)
    then "Effect"
    else if java_script_stdlib_parse_function_call_by_name(name, module)
    then "Result"
    else if java_script_stdlib_effect_function_call_by_name(name, module)
    then java_script_stdlib_effect_function_call_type(name)
    else if java_script_stdlib_path_function_call_by_name(name, module)
    then "Path"
    else if java_script_stdlib_io_function_call_by_name(name, module)
    then "Effect"
    else if java_script_enum_parse_call_name(name, module, allModules)
    then "Result"
    else if java_script_qualified_call_name(name)
    then match java_script_find_qualified_function_return_type(name, module, allModules) with
        case Some { returnType } -> returnType
        case None -> java_script_unknown_type()
    else match java_script_find_local_function(name, module.functions) with
    case Some { function } -> function.returnType.name
    case None ->
        match java_script_find_function_definition_in_imports(name, module.imports, module, allModules) with
        case Some { function } -> function.returnType.name
        case None -> java_script_unknown_type()

/// Computes the JavaScript type for runtime function.
private fun java_script_runtime_function_type(name: String): String =
    if name == "assert_that" | name == "assert_all"
    then "Assert"
    else if name == "test"
    then "TestCase"
    else if name == "test_file"
    then "Effect"
    else if name == "reflection"
    then "DataValueInfo"
    else if name == "print" | name == "println" | name == "print_error" | name == "println_error"
    then "Effect"
    else if name == "pure" | name == "delay"
    then "Effect"
    else if name == "to_seq"
    then "Seq"
    else java_script_unknown_type()

/// Computes the JavaScript type for collection pipe result.
private fun java_script_collection_pipe_result_type(operator: String, leftType: String): String =
    if java_script_type_unqualified_name(leftType) == "Dict" & operator != "|*"
    then "Dict"
    else "Seq"

/// Computes the JavaScript type for primitive conversion result.
private fun java_script_primitive_conversion_result_type(name: String): String =
    if name == "to_int" then "int" else "long"

/// Computes the JavaScript type for regex.
private fun java_script_regex_type(): String = "Regex"
/// Computes the JavaScript type for string to string function.
private fun java_script_string_to_string_function_type(): String = "String=>String"

/// Computes the JavaScript type for variable.
private fun java_script_variable_type(name: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_lookup_binding(name, env) with
    case Some { binding } -> binding.typeName
    case None ->
        if java_script_qualified_enum_value_name(name, module, allModules)
        then java_script_enum_qualified_type_name(name)
        else match java_script_find_local_constant(name, module.functions) with
        case Some { function } -> function.returnType.name
        case None ->
            match java_script_imported_stdlib_constant_type(name, module.imports) with
            case Some { typeName } -> typeName
            case None -> java_script_unknown_type()

/// Computes the JavaScript name for function call.
private fun java_script_function_call_name(name: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    match java_script_lookup_binding(name, env) with
    case Some { binding } -> binding.jsName
    case None ->
        if java_script_runtime_function(name)
        then name
        else if java_script_qualified_call_name(name)
        then match java_script_find_qualified_function_call(name, module, allModules) with
            case Some { binding } -> binding
            case None ->
                match java_script_find_qualified_module_export_call(name, module, allModules) with
                case Some { binding } -> binding
                case None -> java_script_identifier(name)
        else match java_script_find_local_function(name, module.functions) with
        case Some { function } ->
            if java_script_overloaded_function_name(name, module.functions)
            then java_script_identifier(name)
            else java_script_function_name(function)
        case None ->
            match java_script_find_function_in_imports(name, module.imports, module, allModules) with
            case Some { binding } -> binding
            case None -> java_script_identifier(name)

/// Looks up optional metadata for function call definition.
private fun java_script_function_call_definition(name: String, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[CompiledFunction] =
    match java_script_lookup_binding(name, env) with
    case Some _ -> /capy/lang/Option.None {}
    case None ->
        if java_script_runtime_function(name)
        then /capy/lang/Option.None {}
        else if java_script_qualified_call_name(name)
        then /capy/lang/Option.None {}
        else match java_script_find_local_function(name, module.functions) with
        case Some { function } -> /capy/lang/Option.Some { function }
        case None -> java_script_find_function_definition_in_imports(name, module.imports, module, allModules)

/// Checks whether a function matches the runtime function metadata.
private fun java_script_runtime_function(name: String): bool =
    name == "assert_all"
        | name == "assert_that"
        | name == "test"
        | name == "test_file"
        | name == "reflection"
        | name == "digits"
        | name == "pure"
        | name == "delay"
        | name == "print"
        | name == "println"
        | name == "print_error"
        | name == "println_error"
        | name == "to_seq"

private fun java_script_stdlib_parse_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if java_script_one_method_argument(call.arguments)
    then java_script_stdlib_parse_function_call_by_name(call.name, module)
    else false

private fun java_script_stdlib_parse_function_call_by_name(name: String, module: CompiledModule): bool =
    if java_script_parse_function_name(name)
    then if !java_script_local_function_exists(name, module.functions)
        then java_script_primitives_member_imported(name, module.imports)
        else false
    else false

private fun java_script_parse_function_name(name: String): bool =
    name == "to_int"
        | name == "to_long"
        | name == "to_double"
        | name == "to_float"
        | name == "to_bool"

private fun java_script_stdlib_parse_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_parse_function_call_name(call.name)
        + "("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

private fun java_script_parse_function_call_name(name: String): String =
    if name == "to_int"
    then "__capy_parse_int"
    else if name == "to_long"
    then "__capy_parse_long"
    else if name == "to_double"
    then "__capy_parse_double"
    else if name == "to_float"
    then "__capy_parse_float"
    else "__capy_parse_bool"

/// Checks whether a function matches the standard-library effect function call metadata.
private fun java_script_stdlib_effect_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.arguments.is_empty()
    then java_script_stdlib_effect_function_call_by_name(call.name, module)
    else false

/// Checks whether a function matches the standard-library effect function call by name metadata.
private fun java_script_stdlib_effect_function_call_by_name(name: String, module: CompiledModule): bool =
    if name == "current_millis"
    then !java_script_local_function_exists(name, module.functions) & java_script_system_member_imported("current_millis", module.imports)
    else if name == "nano_time"
    then !java_script_local_function_exists(name, module.functions) & java_script_system_member_imported("nano_time", module.imports)
    else if name == "now"
    then !java_script_local_function_exists(name, module.functions) & java_script_clock_member_imported("now", module.imports)
    else false

/// Emits JavaScript code for standard-library effect function call.
private fun java_script_stdlib_effect_function_call_code(name: String): String =
    if name == "current_millis"
    then "__capy_current_millis()"
    else if name == "nano_time"
    then "__capy_nano_time()"
    else "__capy_clock_now()"

/// Computes the JavaScript type for standard-library effect function call.
private fun java_script_stdlib_effect_function_call_type(name: String): String =
    "Effect"

/// Checks whether a function matches the standard-library path function call metadata.
private fun java_script_stdlib_path_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if java_script_one_method_argument(call.arguments)
    then java_script_stdlib_path_function_call_by_name(call.name, module)
    else false

/// Checks whether a function matches the standard-library path function call by name metadata.
private fun java_script_stdlib_path_function_call_by_name(name: String, module: CompiledModule): bool =
    if name == "from_string"
    then !java_script_local_function_exists(name, module.functions) & java_script_path_member_imported("from_string", module.imports)
    else false

/// Emits JavaScript code for standard-library path function call.
private fun java_script_stdlib_path_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_path_from_string("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

/// Checks whether a function matches the standard-library I/O function call metadata.
private fun java_script_stdlib_io_function_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    java_script_stdlib_io_function_call_by_name(call.name, module)
        & java_script_stdlib_io_function_argument_count(call.name, call.arguments)

/// Checks whether a function matches the standard-library I/O function call by name metadata.
private fun java_script_stdlib_io_function_call_by_name(name: String, module: CompiledModule): bool =
    if java_script_io_function_name(name)
    then !java_script_local_function_exists(name, module.functions) & java_script_io_member_imported(name, module.imports)
    else false

/// Checks whether a function matches the standard-library I/O function argument count metadata.
private fun java_script_stdlib_io_function_argument_count(name: String, arguments: List[CompiledExpression]): bool =
    if java_script_io_unary_function_name(name)
    then java_script_one_method_argument(arguments)
    else if java_script_io_binary_function_name(name)
    then java_script_two_method_arguments(arguments)
    else false

/// Checks whether a function matches the I/O unary function name metadata.
private fun java_script_io_unary_function_name(name: String): bool =
    name == "read_text"
        | name == "read_lines"
        | name == "read_bytes"
        | name == "exists"
        | name == "is_file"
        | name == "is_directory"
        | name == "size"
        | name == "create_file"
        | name == "create_directory"
        | name == "create_directories"
        | name == "list_entries"
        | name == "delete"

/// Checks whether a function matches the I/O binary function name metadata.
private fun java_script_io_binary_function_name(name: String): bool =
    name == "write_text"
        | name == "write_lines"
        | name == "write_bytes"
        | name == "append_text"
        | name == "append_lines"
        | name == "append_bytes"
        | name == "copy"
        | name == "copy_replace"
        | name == "move"
        | name == "move_replace"

/// Checks whether a function matches the I/O function name metadata.
private fun java_script_io_function_name(name: String): bool =
    java_script_io_unary_function_name(name) | java_script_io_binary_function_name(name)

/// Emits JavaScript code for standard-library I/O function call.
private fun java_script_stdlib_io_function_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    "__capy_io_" + call.name
        + "("
        + java_script_expression_list_code(call.arguments, env, module, allModules)
        + ")"

/// Checks whether a call has the standard-library math sqrt call shape.
private fun java_script_stdlib_math_sqrt_call(call: CompiledFunctionCallExpression, module: CompiledModule): bool =
    if call.name == "sqrt"
    then if java_script_one_method_argument(call.arguments)
        then !java_script_local_function_exists(call.name, module.functions)
        else false
    else false

/// Checks whether a call has the enum parse call shape.
private fun java_script_enum_parse_call(call: CompiledFunctionCallExpression, module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_enum_parse_call_name(call.name, module, allModules)
        & java_script_one_method_argument(call.arguments)

/// Checks whether a call has the enum parse call name shape.
private fun java_script_enum_parse_call_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_qualified_call_name(name)
        & java_script_enum_qualified_member_name(name) == "parse"
        & java_script_enum_type_exists(java_script_enum_qualified_type_name(name), module, allModules)

/// Emits JavaScript code for enum parse call.
private fun java_script_enum_parse_call_code(call: CompiledFunctionCallExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = java_script_enum_qualified_type_name(call.name)
    "__capy_enum_parse("
        + java_script_string_literal(typeName)
        + ", ["
        + java_script_enum_value_references_code(typeName, java_script_enum_values(typeName, module, allModules), module, allModules)
        + "], "
        + java_script_first_method_argument_code(call.arguments, env, module, allModules)
        + ")"

/// Checks whether the current value satisfies the enum static field access rule for JavaScript processing.
private fun java_script_enum_static_field_access(access: CompiledFieldAccessExpression, env: List[JavaScriptBinding], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match access.receiver with
    case CompiledVariableExpression variable -> {
        match java_script_lookup_binding(variable.name, env) with
        case Some _ -> false
        case None ->
            java_script_enum_type_exists(variable.name, module, allModules)
                & (access.name == "values" | java_script_enum_value_exists(variable.name, access.name, module, allModules))
    }
    case _ -> false

/// Emits JavaScript code for enum static field access.
private fun java_script_enum_static_field_access_code(access: CompiledFieldAccessExpression, module: CompiledModule, allModules: List[CompiledModule]): String =
    let typeName = java_script_enum_static_field_access_type_name(access)
    if access.name == "values"
    then "__capy_set([" + java_script_enum_value_references_code(typeName, java_script_enum_values(typeName, module, allModules), module, allModules) + "])"
    else java_script_enum_value_reference_code(typeName, access.name, module, allModules)

/// Computes the JavaScript type for enum static field access.
private fun java_script_enum_static_field_access_type(access: CompiledFieldAccessExpression): String =
    if access.name == "values"
    then "Set"
    else java_script_enum_static_field_access_type_name(access)

/// Computes the JavaScript type name for enum static field access.
private fun java_script_enum_static_field_access_type_name(access: CompiledFieldAccessExpression): String =
    match access.receiver with
    case CompiledVariableExpression variable -> variable.name
    case _ -> ""

/// Checks whether the current value satisfies the qualified enum value name rule for JavaScript processing.
private fun java_script_qualified_enum_value_name(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_qualified_call_name(name)
        & java_script_enum_value_exists(java_script_enum_qualified_type_name(name), java_script_enum_qualified_member_name(name), module, allModules)

/// Computes the JavaScript type name for enum qualified.
private fun java_script_enum_qualified_type_name(name: String): String =
    java_script_qualified_call_qualifier(name)

/// Computes the JavaScript name for enum qualified member.
private fun java_script_enum_qualified_member_name(name: String): String =
    java_script_qualified_call_member(name)

/// Emits JavaScript code for enum qualified value.
private fun java_script_enum_qualified_value_code(name: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    java_script_enum_value_reference_code(java_script_enum_qualified_type_name(name), java_script_enum_qualified_member_name(name), module, allModules)

/// Checks whether enum type exists in the relevant declarations or imports.
private fun java_script_enum_type_exists(name: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    if java_script_enum_type_exists_in_functions(name, module.functions)
    then true
    else java_script_enum_type_exists_in_imports(name, module.imports, module, allModules)

/// Checks whether enum value exists in the relevant declarations or imports.
private fun java_script_enum_value_exists(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): bool =
    java_script_string_list_contains(valueName, java_script_enum_values(typeName, module, allModules))

/// Computes value metadata for enum values.
private fun java_script_enum_values(name: String, module: CompiledModule, allModules: List[CompiledModule]): List[String] =
    let localValues = java_script_enum_values_in_functions(name, module.functions)
    if !localValues.is_empty()
    then localValues
    else match java_script_enum_values_in_imports(name, module.imports, module, allModules) with
        case Some { values } -> values
        case None -> []

/// Checks whether enum type exists in functions exists in the relevant declarations or imports.
private fun java_script_enum_type_exists_in_functions(name: String, functions: List[CompiledFunction]): bool =
    java_script_schema_value_with_prefix_exists("__capy_schema_enum|" + name + "|", functions)

/// Collects enum metadata for enum values in functions.
private fun java_script_enum_values_in_functions(name: String, functions: List[CompiledFunction]): List[String] =
    java_script_schema_values("__capy_schema_enum|" + name + "|", functions)

/// Emits JavaScript import statements for enum values in.
private fun java_script_enum_values_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[List[String]] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if java_script_data_import_matches(name, declaration)
        then java_script_enum_values_in_import(name, imports[1:], module, allModules, declaration)
        else java_script_enum_values_in_imports(name, imports[1:], module, allModules)

/// Emits one JavaScript import statement for enum values in.
private fun java_script_enum_values_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[List[String]] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        let values = java_script_enum_values_in_functions(name, importedModule.functions)
        if !values.is_empty()
        then /capy/lang/Option.Some { values }
        else java_script_enum_values_in_imports(name, rest, module, allModules)
    case None -> java_script_enum_values_in_imports(name, rest, module, allModules)

/// Checks imported modules for enum type existence without materializing enum values.
private fun java_script_enum_type_exists_in_imports(name: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): bool =
    match imports[0] with
    case None -> false
    case Some { declaration } ->
        if java_script_data_import_matches(name, declaration)
        then java_script_enum_type_exists_in_import(name, imports[1:], module, allModules, declaration)
        else java_script_enum_type_exists_in_imports(name, imports[1:], module, allModules)

/// Checks one imported module for enum type existence without materializing enum values.
private fun java_script_enum_type_exists_in_import(name: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): bool =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_enum_type_exists_in_functions(name, importedModule.functions)
        then true
        else java_script_enum_type_exists_in_imports(name, rest, module, allModules)
    case None -> java_script_enum_type_exists_in_imports(name, rest, module, allModules)

/// Emits JavaScript code for enum value references.
private fun java_script_enum_value_references_code(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some { value } ->
        java_script_enum_value_reference_code(typeName, value, module, allModules)
            + java_script_enum_value_reference_tail(typeName, values[1:], module, allModules)

/// Formats the recursive tail segment for enum value reference.
private fun java_script_enum_value_reference_tail(typeName: String, values: List[String], module: CompiledModule, allModules: List[CompiledModule]): String =
    match values[0] with
    case None -> ""
    case Some _ -> ", " + java_script_enum_value_references_code(typeName, values, module, allModules)

/// Emits JavaScript code for enum value reference.
private fun java_script_enum_value_reference_code(typeName: String, valueName: String, module: CompiledModule, allModules: List[CompiledModule]): String =
    if java_script_enum_type_exists_in_functions(typeName, module.functions)
    then java_script_identifier(valueName)
    else match java_script_imported_enum_value_binding(typeName, valueName, module.imports, module, allModules) with
        case Some { binding } -> binding
        case None -> java_script_identifier(valueName)

/// Collects imported enum value binding visible to the current module.
private fun java_script_imported_enum_value_binding(typeName: String, valueName: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if java_script_data_import_matches(typeName, declaration)
        then java_script_imported_enum_value_binding_from(typeName, valueName, imports[1:], module, allModules, declaration)
        else java_script_option_string_identity(java_script_imported_enum_value_binding(typeName, valueName, imports[1:], module, allModules))

/// Collects imported enum value binding from visible to the current module.
private fun java_script_imported_enum_value_binding_from(typeName: String, valueName: String, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule], declaration: CompiledImportDeclaration): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } ->
        if java_script_enum_type_exists_in_functions(typeName, importedModule.functions)
        then java_script_imported_enum_value_binding_in_module(valueName, declaration, importedModule.functions, module)
        else java_script_option_string_identity(java_script_imported_enum_value_binding(typeName, valueName, rest, module, allModules))
    case None -> java_script_option_string_identity(java_script_imported_enum_value_binding(typeName, valueName, rest, module, allModules))

/// Collects imported enum value binding in a module visible to the current module.
private fun java_script_imported_enum_value_binding_in_module(valueName: String, declaration: CompiledImportDeclaration, functions: List[CompiledFunction], module: CompiledModule): /capy/lang/Option[String] =
    match java_script_find_exported_constant(valueName, functions) with
    case Some { function } ->
        /capy/lang/Option.Some {
            java_script_import_alias(declaration, module)
                + "["
                + java_script_string_literal(java_script_export_name(function))
                + "]"
        }
    case None -> /capy/lang/Option.Some { java_script_identifier(valueName) }

/// Finds a local function in scope, imports, or compiled modules.
private fun java_script_find_local_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name
        then if !java_script_skip_function(function)
            then /capy/lang/Option.Some { function }
            else java_script_find_local_function(name, functions[1:])
        else java_script_find_local_function(name, functions[1:])

/// Finds a function in scope, imports, or compiled modules.
private fun java_script_find_function(name: String, functions: List[CompiledFunction]): /capy/lang/Option[CompiledFunction] =
    match functions[0] with
    case None -> /capy/lang/Option.None {}
    case Some { function } ->
        if function.name == name
        then if java_script_callable_function(function)
            then /capy/lang/Option.Some { function }
            else java_script_find_function(name, functions[1:])
        else java_script_find_function(name, functions[1:])

/// Checks whether a function matches the callable function metadata.
private fun java_script_callable_function(function: CompiledFunction): bool =
    !java_script_skip_function(function) & function.visibility != "private" & function.visibility != "const:private"

/// Finds a qualified module export call in scope, imports, or compiled modules.
private fun java_script_find_qualified_module_export_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let idx = java_script_last_dot_index(name)
    let qualifier = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } ->
        /capy/lang/Option.Some {
            "__capy_export(require("
                + java_script_string_literal(java_script_relative_require_path(java_script_module_path(module), java_script_module_path(targetModule)))
                + "), "
                + java_script_string_literal(member)
                + ")"
        }
    case None -> /capy/lang/Option.None {}

/// Finds a qualified function call in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_call(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    let idx = java_script_last_dot_index(name)
    let qualifier = java_script_qualified_call_qualifier_at(name, idx)
    let member = java_script_qualified_call_member_at(name, idx)
    match java_script_find_qualified_function_call_in_imports(qualifier, member, module.imports, module, allModules) with
    case Some { binding } -> /capy/lang/Option.Some { binding }
    case None -> java_script_find_qualified_function_call_in_modules(qualifier, member, module, allModules)

/// Finds a qualified function call in imports in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_call_in_imports(qualifier: String, member: String, imports: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match imports[0] with
    case None -> /capy/lang/Option.None {}
    case Some { declaration } ->
        if declaration.qualified
        then if java_script_stdlib_import(declaration.modulePath)
            then java_script_option_string_identity(java_script_find_qualified_function_call_in_imports(qualifier, member, imports[1:], module, allModules))
            else if java_script_qualified_import_matches(qualifier, declaration, module)
            then java_script_find_qualified_function_call_in_import(qualifier, member, declaration, imports[1:], module, allModules)
            else java_script_option_string_identity(java_script_find_qualified_function_call_in_imports(qualifier, member, imports[1:], module, allModules))
        else java_script_option_string_identity(java_script_find_qualified_function_call_in_imports(qualifier, member, imports[1:], module, allModules))

/// Finds a qualified function call in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_call_in_import(qualifier: String, member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_imported_module(declaration, module, allModules) with
    case Some { importedModule } -> {
        match java_script_find_function(member, importedModule.functions) with
        case Some { function } ->
            /capy/lang/Option.Some { java_script_imported_function_binding(declaration, function, importedModule.functions, module) }
        case None -> java_script_option_string_identity(java_script_find_qualified_function_call_in_imports(qualifier, member, rest, module, allModules))
    }
    case _ -> java_script_option_string_identity(java_script_find_qualified_function_call_in_imports(qualifier, member, rest, module, allModules))

/// Finds a qualified function call in a modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_call_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
    match java_script_find_module_by_path(java_script_qualified_module_path(qualifier, module), allModules) with
    case Some { targetModule } -> {
        match java_script_find_function(member, targetModule.functions) with
        case Some { function } ->
            /capy/lang/Option.Some { java_script_module_function_binding(targetModule, function, module) }
        case None -> /capy/lang/Option.None {}
    }
    case None -> /capy/lang/Option.None {}

/// Finds a qualified function return type in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_return_type(name: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
