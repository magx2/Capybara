            else if java_script_qualified_import_matches(qualifier, declaration, module)
            then java_script_find_qualified_function_return_type_in_import(qualifier, member, declaration, imports[1:], module, allModules)
            else java_script_option_string_identity(java_script_find_qualified_function_return_type_in_imports(qualifier, member, imports[1:], module, allModules))
        else java_script_option_string_identity(java_script_find_qualified_function_return_type_in_imports(qualifier, member, imports[1:], module, allModules))

/// Finds a qualified function return type in import in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_return_type_in_import(qualifier: String, member: String, declaration: CompiledImportDeclaration, rest: List[CompiledImportDeclaration], module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
