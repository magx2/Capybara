    + "    }" + java_script_newline()
    + "    return value;" + java_script_newline()
    + "}" + java_script_newline()
    + "function __capy_native_provider(modulePath, exportName, interfaceId) {" + java_script_newline()
    + "    const exports = __capy_load_native_module(modulePath);" + java_script_newline()
