from /capy/collection/List import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledProgram import { CompiledModule, CompiledProgram }
from /dev/capylang/generator/GeneratedProgram import { GeneratedModule, GeneratedProgram }

fun java_script_generator(program: CompiledProgram): GeneratedProgram =
    GeneratedProgram {
        modules: javaScriptModules(program.modules)
    }

private fun javaScriptModules(modules: List[CompiledModule]): List[GeneratedModule] =
    match modules[0] with
    case None -> []
    case Some { module } -> [GeneratedModule {
        relativePath: moduleRelativePath(module, ".js"),
        code: javaScriptModuleCode(module)
    }] + javaScriptModules(modules[1:])

private fun javaScriptModuleCode(module: CompiledModule): String =
    "// Generated by Capybara.\n"
    + "module.exports = {};\n"

private fun moduleRelativePath(module: CompiledModule, extension: String): String =
    if module.path.is_empty()
    then module.name + extension
    else module.path + "/" + module.name + extension
