/// Finds a qualified function return type in a modules in scope, imports, or compiled modules.
private fun java_script_find_qualified_function_return_type_in_modules(qualifier: String, member: String, module: CompiledModule, allModules: List[CompiledModule]): /capy/lang/Option[String] =
