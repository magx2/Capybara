from /capy/collection/List import { * }
from /capy/lang/Effect import { Effect }
from /capy/lang/Option import { * }
from /dev/capylang/CapyBridge import { exit_on_failed, optional_path, path_is_null, path_string, print_error_and_fail, run_program }
import /dev/capylang/cli/Capy
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledObjectOrientedUnit import { CompiledObjectOrientedUnit }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/NativeProviderManifest import { NativeProviderManifest }
from /dev/capylang/compiler/OutputType import { OutputType }

fun main(args: List[String]): Effect[/capy/lang/Program] =
    exit_on_failed(/dev/capylang/cli/Capy.run(args))

fun read_linked_program(input_dir: /java/nio/file/Path, include_runtime: bool): CompiledProgram =
    CompiledProgram {
        modules: [],
        objectOrientedModules: [],
        nativeProviders: empty_native_provider_manifest(),
        nativeProviderCatalog: empty_native_provider_catalog()
    }

fun read_native_provider_manifest(native_wiring: /java/nio/file/Path): NativeProviderManifest =
    empty_native_provider_manifest()

fun compile(
    input_path: /java/nio/file/Path,
    linked_output_path: /java/nio/file/Path,
    libraries: /java/util/TreeSet,
    compile_tests: bool,
    errors: /java/io/PrintStream,
    compiler_version: String
): int =
    if path_is_null(linked_output_path)
    then print_error_and_fail(errors, "Linked output path is required.")
    else
        run_program(
            /dev/capylang/cli/Capy.run_compile(
                /dev/capylang/cli/Capy.compile_options(
                    path_string(input_path),
                    path_string(linked_output_path),
                    compile_tests
                )
            ),
            errors
        )

fun compile_generate(
    output_type: OutputType,
    input_path: /java/nio/file/Path,
    generated_output_path: /java/nio/file/Path,
    linked_output_path: /java/nio/file/Path,
    test_input_path: /java/nio/file/Path,
    test_generated_output_path: /java/nio/file/Path,
    libraries: /java/util/TreeSet,
    compile_tests: bool,
    include_java_lib_resources: bool,
    compiler_version: String,
    errors: /java/io/PrintStream
): int =
    if path_is_null(generated_output_path)
    then print_error_and_fail(errors, "Generated output path is required.")
    else
        run_program(
            /dev/capylang/cli/Capy.run_compile_generate(
                /dev/capylang/cli/Capy.compile_generate_options(
                    output_type,
                    path_string(input_path),
                    path_string(generated_output_path),
                    optional_path(linked_output_path),
                    optional_path(test_input_path),
                    optional_path(test_generated_output_path),
                    compile_tests,
                    include_java_lib_resources
                )
            ),
            errors
        )

fun compile_generate(
    output_type: OutputType,
    input_path: /java/nio/file/Path,
    generated_output_path: /java/nio/file/Path,
    linked_output_path: /java/nio/file/Path,
    test_input_path: /java/nio/file/Path,
    test_generated_output_path: /java/nio/file/Path,
    libraries: /java/util/TreeSet,
    compile_tests: bool,
    include_java_lib_resources: bool,
    native_providers: NativeProviderManifest,
    compiler_version: String,
    errors: /java/io/PrintStream
): int =
    compile_generate(
        output_type,
        input_path,
        generated_output_path,
        linked_output_path,
        test_input_path,
        test_generated_output_path,
        libraries,
        compile_tests,
        include_java_lib_resources,
        compiler_version,
        errors
    )
