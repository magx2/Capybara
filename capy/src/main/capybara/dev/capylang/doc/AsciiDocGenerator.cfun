from /capy/collection/List import { * }
from /capy/collection/Dict import { * }
from /capy/collection/Seq import { * }
from /capy/lang/String import { * }
from /dev/capylang/compiler/CompiledAnnotationDeclaration import { CompiledAnnotationDeclaration }
from /dev/capylang/compiler/CompiledExpression import { CompiledExpression, CompiledStringLiteral }
from /dev/capylang/compiler/CompiledFunction import { CompiledFunction }
from /dev/capylang/compiler/CompiledFunctionParameter import { CompiledFunctionParameter }
from /dev/capylang/compiler/CompiledModule import { CompiledModule }
from /dev/capylang/compiler/CompiledPrimitiveBackedType import { CompiledPrimitiveBackedType }
from /dev/capylang/compiler/CompiledProgram import { * }
from /dev/capylang/compiler/CompiledTypeReference import { CompiledTypeReference }
from Documentation import { Documentation }

fun generate_asciidoc_docs(program: CompiledProgram): List[Documentation] =
    [generate_asciidoc_index(program)]
    + program.modules
        .map(module => generate_asciidoc_docs_for_module(module))
        .reduce([], (docs, doc) => docs + doc)

private fun generate_asciidoc_index(program: CompiledProgram): Documentation =
    Documentation {
        path: "/index.adoc",
        content: "= Capybara Documentation\n\n"
        + "== Modules\n\n"
        + generate_module_index_entries(program.modules)
    }

private fun generate_module_index_entries(modules: List[CompiledModule]): String =
    modules
        .sort((a,b) => module_display_name(a).compare(module_display_name(b)))
        .map(module => "* xref:{module_doc_path(module)}[{module_display_name(module)}]\n")
        .reduce("", (content, entry) => content + entry)

private fun module_doc_path(module: CompiledModule): String =
    if module.path.is_empty()
    then "{module.name}.adoc"
    else "{module.path}/{module.name}.adoc"

private fun module_display_name(module: CompiledModule): String =
    if module.path.is_empty()
    then module.name
    else "{module.path}/{module.name}"

private fun generate_asciidoc_docs_for_module(module: CompiledModule): Documentation =
    let typeNames = asciidoc_schema_type_names(module.functions)
    Documentation {
        path: "/" + module_doc_path(module),
        content: "= Module {module.name}\n\n"
        + "== Functions\n\n"
        + generate_function_docs(asciidoc_top_level_functions(module.functions, typeNames), "===") + "\n\n"
        + "== Annotations\n\n"
        + generate_annotation_docs(module.annotations) + "\n\n"
        + "== Types\n\n"
        + generate_schema_type_docs(module.functions)
        + generate_backend_type_docs(module.visiblePrimitiveBackedTypes, module.functions)
    }

private fun generate_function_docs(functions: List[CompiledFunction], heading: String): String =
    functions
        .sort((a,b) => a.name.compare(b.name))
        .map(function => "{heading} {function.visibility} {function.name}({generate_parameters(function.parameters)}): {type_name(function.returnType)}\n\n{generate_documentation(function)}\n\n")
        .reduce("", (content, functionDoc) => content + functionDoc)

private fun asciidoc_top_level_functions(functions: List[CompiledFunction], typeNames: List[String]): List[CompiledFunction] =
    functions.reduce([], (acc, function) =>
        if asciidoc_top_level_function(function, functions, typeNames)
        then acc + function
        else acc
    )

private fun asciidoc_top_level_function(function: CompiledFunction, functions: List[CompiledFunction], typeNames: List[String]): bool =
    !asciidoc_schema_function(function)
    & !asciidoc_generated_local_function(function)
    & !function.name.starts_with("__capy_constructor|")
    & !asciidoc_function_belongs_to_type(function, typeNames)
    & !asciidoc_enum_value_function(function, functions)

private fun asciidoc_function_belongs_to_type(function: CompiledFunction, typeNames: List[String]): bool =
    let owner = asciidoc_function_owner(function)
    !owner.is_empty() & asciidoc_string_list_contains(typeNames, owner)

private fun asciidoc_function_owner(function: CompiledFunction): String =
    let dot = asciidoc_first_index_of(function.name, ".", 0)
    if dot < 0
    then ""
    else asciidoc_schema_base_type_name(function.name[0, dot])

private fun asciidoc_enum_value_function(function: CompiledFunction, functions: List[CompiledFunction]): bool =
    function.visibility.starts_with("const:")
    & asciidoc_string_list_contains(asciidoc_enum_value_names(functions), function.name)

private fun asciidoc_generated_local_function(function: CompiledFunction): bool =
    function.name.contains("__local__")

private fun generate_parameters(parameters: List[CompiledFunctionParameter]): String =
    parameters
        .map(parameter => generate_parameter(parameter))
        .reduce("", (content, parameter) =>
            if content.is_empty()
            then parameter
            else content + ", " + parameter
        )

private fun generate_documentation(function: CompiledFunction): String =
    function.documentation.reduce("", (content, docLine) => content + docLine + "\n")

private fun generate_documentation_for_annotation(annotation: CompiledAnnotationDeclaration): String =
    annotation.documentation.reduce("", (content, docLine) => content + docLine + "\n")

private fun generate_parameter(parameter: CompiledFunctionParameter): String =
    "{parameter.name}: {type_name(parameter.typeReference)}"

private fun type_name(type: CompiledTypeReference): String =
    type.name + type_arguments(type.arguments)

private fun type_arguments(arguments: List[CompiledTypeReference]): String =
    if arguments.is_empty()
    then ""
    else "[" + join_type_names(arguments) + "]"

private fun join_type_names(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> type_name(argument) + join_type_names_tail(arguments[1:])

private fun join_type_names_tail(arguments: List[CompiledTypeReference]): String =
    match arguments[0] with
    case None -> ""
    case Some { argument } -> ", " + type_name(argument) + join_type_names_tail(arguments[1:])

private fun generate_schema_type_docs(functions: List[CompiledFunction]): String =
    asciidoc_schema_type_names(functions)
        .sort((a,b) => a.compare(b))
        .reduce("", (content, typeName) =>
            if asciidoc_primitive_schema_type(typeName, functions)
            then content
            else content + generate_schema_type_doc(typeName, functions)
        )

private fun generate_schema_type_doc(typeName: String, functions: List[CompiledFunction]): String =
    "=== {asciidoc_type_kind(typeName, functions)} {asciidoc_type_display_name(typeName, functions)}\n\n"
    + asciidoc_schema_documentation_named("__capy_schema_type|" + typeName, functions)
    + "\n"
    + generate_type_field_docs(typeName, functions)
    + generate_union_variant_docs(typeName, functions)
    + generate_enum_value_docs(typeName, functions)
    + generate_type_function_docs(typeName, functions)

private fun asciidoc_type_kind(typeName: String, functions: List[CompiledFunction]): String =
    if !asciidoc_schema_values("__capy_schema_enum|" + typeName + "|", functions).is_empty()
    then "enum"
    else if !asciidoc_union_variant_names(typeName, functions).is_empty()
    then "union"
    else "data"

private fun asciidoc_type_display_name(typeName: String, functions: List[CompiledFunction]): String =
    let parameters = asciidoc_schema_values("__capy_schema_param|" + typeName + "|", functions)
    if parameters.is_empty()
    then typeName
    else typeName + "[" + join_strings(parameters, ", ") + "]"

private fun generate_type_field_docs(typeName: String, functions: List[CompiledFunction]): String =
    let fields = asciidoc_schema_functions("__capy_schema_field|" + typeName + "|", functions)
    if !asciidoc_schema_values("__capy_schema_enum|" + typeName + "|", functions).is_empty()
    then ""
    else if fields.is_empty()
    then ""
    else "==== Fields\n\n"
        + fields.reduce("", (content, field) => content + generate_type_field_doc(field))
        + "\n"

private fun generate_type_field_doc(function: CompiledFunction): String =
    let field = asciidoc_schema_value(function)
    "* `{asciidoc_schema_field_name(field)}`: `{asciidoc_schema_field_type(field)}`\n"
    + generate_type_field_documentation(function)

private fun generate_type_field_documentation(function: CompiledFunction): String =
    if function.documentation.is_empty()
    then ""
    else "+\n" + generate_documentation(function) + "\n"

private fun generate_union_variant_docs(typeName: String, functions: List[CompiledFunction]): String =
    let variants = asciidoc_union_variant_names(typeName, functions)
    if variants.is_empty()
    then ""
    else "==== Variants\n\n"
        + variants.reduce("", (content, variant) => content + "* `{asciidoc_type_display_name(variant, functions)}`\n")
        + "\n"

private fun generate_enum_value_docs(typeName: String, functions: List[CompiledFunction]): String =
    let values = asciidoc_schema_values("__capy_schema_enum|" + typeName + "|", functions)
    if values.is_empty()
    then ""
    else "==== Values\n\n"
        + values.reduce("", (content, value) => content + "* `{value}`\n")
        + "\n"

private fun generate_type_function_docs(typeName: String, functions: List[CompiledFunction]): String =
    let ownedFunctions = asciidoc_type_functions(typeName, functions)
    if ownedFunctions.is_empty()
    then ""
    else "==== Functions\n\n"
        + generate_function_docs(ownedFunctions, "=====")

private fun asciidoc_type_functions(typeName: String, functions: List[CompiledFunction]): List[CompiledFunction] =
    functions.reduce([], (acc, function) =>
        if !asciidoc_schema_function(function)
            & !asciidoc_generated_local_function(function)
            & !function.name.starts_with("__capy_constructor|")
            & asciidoc_function_owner(function) == typeName
        then acc + function
        else acc
    )

private fun asciidoc_schema_type_names(functions: List[CompiledFunction]): List[String] =
    functions.reduce([], (acc, function) =>
        if asciidoc_schema_function(function) & function.name.starts_with("__capy_schema_type|")
        then asciidoc_add_string_if_missing(acc, function.name["__capy_schema_type|".size().value, function.name.size().value])
        else acc
    )

private fun asciidoc_union_variant_names(typeName: String, functions: List[CompiledFunction]): List[String] =
    functions.reduce([], (acc, function) =>
        if asciidoc_schema_function(function)
            & function.name.starts_with("__capy_schema_parent|")
            & asciidoc_schema_base_type_name(asciidoc_schema_value(function)) == typeName
        then asciidoc_add_string_if_missing(acc, asciidoc_schema_parent_child_name(function.name))
        else acc
    )

private fun asciidoc_enum_value_names(functions: List[CompiledFunction]): List[String] =
    functions.reduce([], (acc, function) =>
        if asciidoc_schema_function(function) & function.name.starts_with("__capy_schema_enum|")
        then asciidoc_add_string_if_missing(acc, asciidoc_schema_value(function))
        else acc
    )

private fun asciidoc_schema_parent_child_name(name: String): String =
    let prefixSize = "__capy_schema_parent|".size().value
    let rest = name[prefixSize, name.size().value]
    let separator = asciidoc_first_index_of(rest, "|", 0)
    if separator < 0
    then rest
    else rest[0, separator]

private fun asciidoc_primitive_schema_type(typeName: String, functions: List[CompiledFunction]): bool =
    !asciidoc_schema_value_named("__capy_schema_primitive|" + typeName, functions).is_empty()

private fun asciidoc_schema_function(function: CompiledFunction): bool =
    function.visibility.starts_with("const:schema")

private fun asciidoc_schema_functions(prefix: String, functions: List[CompiledFunction]): List[CompiledFunction] =
    functions.reduce([], (acc, function) =>
        if asciidoc_schema_function(function) & function.name.starts_with(prefix)
        then acc + function
        else acc
    )

private fun asciidoc_schema_values(prefix: String, functions: List[CompiledFunction]): List[String] =
    functions.reduce([], (acc, function) =>
        if asciidoc_schema_function(function) & function.name.starts_with(prefix)
        then acc + asciidoc_schema_value(function)
        else acc
    )

private fun asciidoc_schema_value_named(name: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if asciidoc_schema_function(function) & function.name == name
        then asciidoc_schema_value(function)
        else asciidoc_schema_value_named(name, functions[1:])

private fun asciidoc_schema_documentation_named(name: String, functions: List[CompiledFunction]): String =
    match functions[0] with
    case None -> ""
    case Some { function } ->
        if asciidoc_schema_function(function) & function.name == name
        then generate_documentation(function)
        else asciidoc_schema_documentation_named(name, functions[1:])

private fun asciidoc_schema_value(function: CompiledFunction): String =
    match function.body with
    case CompiledStringLiteral literal -> literal.value
    case _ -> ""

private fun asciidoc_schema_field_name(value: String): String =
    let separator = asciidoc_first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

private fun asciidoc_schema_field_type(value: String): String =
    let separator = asciidoc_first_index_of(value, "|", 0)
    if separator < 0
    then "any"
    else value[separator + 1, value.size().value]

private fun asciidoc_schema_base_type_name(value: String): String =
    let trimmed = value.trim()
    let bracket = asciidoc_first_index_of(trimmed, "[", 0)
    if bracket < 0
    then trimmed
    else trimmed[0, bracket]

private fun asciidoc_add_string_if_missing(values: List[String], value: String): List[String] =
    if asciidoc_string_list_contains(values, value)
    then values
    else values + value

private fun asciidoc_string_list_contains(values: List[String], expected: String): bool =
    match values[0] with
    case None -> false
    case Some { value } -> value == expected | asciidoc_string_list_contains(values[1:], expected)

private fun generate_backend_type_docs(types: Dict[CompiledPrimitiveBackedType], functions: List[CompiledFunction]): String =
    types
        .reduce("", (content, name, type) =>
            content
            + "=== {type.visibility} {type.name}: {type_name(type.backingType)}\n\n{generate_documentation_for_backend_type(type)}\n"
            + generate_type_function_docs(type.name, functions)
            + "\n"
        )

private fun generate_documentation_for_backend_type(type: CompiledPrimitiveBackedType): String =
    type.documentation.reduce("", (content, docLine) => content + docLine + "\n")

private fun generate_annotation_docs(annotations: Dict[CompiledAnnotationDeclaration]): String =
    annotations
        .reduce("", (content, name, annotation) => content + generate_annotation_doc(annotation))

private fun generate_annotation_doc(annotation: CompiledAnnotationDeclaration): String =
    "=== {annotation.visibility} @{annotation.name}\n\n"
    + generate_documentation_for_annotation(annotation)
    + "\n"
    + "* Repeatable: {annotation_repeatable_value(annotation)}\n"
    + "* Targets: " + join_strings(annotation.targets, ", ") + "\n"
    + generate_annotation_fields(annotation.fields)
    + "\n"

private fun annotation_repeatable_value(annotation: CompiledAnnotationDeclaration): String =
    if annotation.repeatable then "yes" else "no"

private fun generate_annotation_fields(fields: List[String]): String =
    match fields[0] with
    case None -> ""
    case Some _ -> "\n==== Fields\n\n" + fields.reduce("", (content, field) => content + annotation_field_doc(field)) + "\n"

private fun annotation_field_doc(field: String): String =
    "* `{annotation_field_name(field)}`: `{annotation_field_type(field)}` ({annotation_field_presence(field)})\n"

private fun annotation_field_presence(field: String): String =
    if annotation_field_has_default(field)
    then "optional, default " + annotation_field_default_value(field)
    else "required"

private fun annotation_field_name(value: String): String =
    let separator = asciidoc_first_index_of(value, "|", 0)
    if separator < 0
    then value
    else value[0, separator]

private fun annotation_field_type(value: String): String =
    let first = asciidoc_first_index_of(value, "|", 0)
    let second = if first < 0 then -1 else asciidoc_first_index_of(value, "|", first + 1)
    if first < 0
    then "any"
    else if second < 0
    then value[first + 1, value.size().value]
    else value[first + 1, second]

private fun annotation_field_has_default(value: String): bool =
    let second = annotation_field_second_separator(value)
    let third = annotation_field_third_separator(value)
    if second < 0 | third < 0
    then false
    else value[second + 1, third] == "true"

private fun annotation_field_default_value(value: String): String =
    let third = annotation_field_third_separator(value)
    if third < 0
    then "`nothing`"
    else
        let payload = value[third + 1, value.size().value]
        let colon = asciidoc_first_index_of(payload, ":", 0)
        if colon < 0
        then "`nothing`"
        else if payload[0, colon] == "nothing"
        then "`nothing`"
        else "`" + payload[colon + 1, payload.size().value] + "`"

private fun annotation_field_second_separator(value: String): int =
    let first = asciidoc_first_index_of(value, "|", 0)
    if first < 0 then -1 else asciidoc_first_index_of(value, "|", first + 1)

private fun annotation_field_third_separator(value: String): int =
    let second = annotation_field_second_separator(value)
    if second < 0 then -1 else asciidoc_first_index_of(value, "|", second + 1)

private fun join_strings(values: List[String], separator: String): String =
    match values[0] with
    case None -> ""
    case Some { value } -> value + join_strings_tail(values[1:], separator)

private fun join_strings_tail(values: List[String], separator: String): String =
    match values[0] with
    case None -> ""
    case Some { value } -> separator + value + join_strings_tail(values[1:], separator)

private fun asciidoc_first_index_of(value: String, needle: String, idx: int): int =
    match value[idx] with
    case None -> -1
    case Some { char } ->
        if char == needle
        then idx
        else asciidoc_first_index_of(value, needle, idx + 1)
