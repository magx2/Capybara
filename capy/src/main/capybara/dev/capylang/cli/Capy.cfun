    let documentation <- linked_list_field(node, "documentation", value => linked_string_value(value))
    let backingTypeData <- linked_data_field(node, "backingType")
    let backingType <- linked_decode_type_reference(backingTypeData)
    let locationData <- linked_data_field(node, "location")
    let location <- linked_decode_source_location(locationData)
    CompiledPrimitiveBackedType {
