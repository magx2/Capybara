// This is set during build
const COMPILER_VERSION = "x.y.z"

fun main(args: List[String]): Effect[/capy/lang/Program] =
    match args[0] with
    case None -> usage_error("No command passed!")
    case Some { "-h" } | Some { "--help" } -> print_help()
    case Some { "-v" } | Some { "--version" } -> print_version()
    case Some { "compile" } -> execute_compile(args[1:])
    case Some { "generate" } -> execute_generate(args[1:])
    case Some { "compile-generate" } -> execute_compile_generate(args[1:])
    case Some { "package" } -> execute_package(args[1:])
    case Some { command } -> usage_error("Unknown command `" + command + "`.")

fun execute_compile(args: List[String]): Effect[/capy/lang/Program] =
    match parse_compile_options(args) with
    case UsageError { message } -> usage_error(message)
    case ParsedArgs { options } -> run_compile(options)

fun execute_generate(args: List[String]): Effect[/capy/lang/Program] =
    match parse_generate_options(args) with
    case UsageError { message } -> usage_error(message)
    case ParsedArgs { options } -> run_generate(options)

fun execute_compile_generate(args: List[String]): Effect[/capy/lang/Program] =
    match parse_compile_generate_options(args) with
    case UsageError { message } -> usage_error(message)
    case ParsedArgs { options } -> run_compile_generate(options)

fun execute_package(args: List[String]): Effect[/capy/lang/Program] =
    match parse_package_options(args) with
    case UsageError { message } -> usage_error(message)
    case ParsedArgs { options } -> run_package(options)

data CompileOptions {
    input: String,
    output: String,
    libs: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    log_level: LogLevel
}

data GenerateOptions {
    output_type: String,
    input: String,
    output: String,
    include_java_lib_resources: bool,
    log_level: LogLevel
}

data CompileGenerateOptions {
    output_type: String,
    input: String,
    output: String,
    linked_output: Option[String],
    test_input: Option[String],
    test_output: Option[String],
    libs: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    include_java_lib_resources: bool,
    log_level: LogLevel
}

fun compile_options(input: String, output: String, compile_tests: bool): CompileOptions =
    CompileOptions {
        input: input,
        output: output,
        libs: None {},
        native_wiring: None {},
        compile_tests: compile_tests,
        log_level: WARN
    }

fun compile_generate_options(
    output_type: String,
    input: String,
    output: String,
    linked_output: Option[String],
    test_input: Option[String],
    test_output: Option[String],
    compile_tests: bool,
    include_java_lib_resources: bool
): CompileGenerateOptions =
    CompileGenerateOptions {
        output_type: output_type,
        input: input,
        output: output,
        linked_output: linked_output,
        test_input: test_input,
        test_output: test_output,
        libs: None {},
        native_wiring: None {},
        compile_tests: compile_tests,
        include_java_lib_resources: include_java_lib_resources,
        log_level: WARN
    }

data PackageOptions {
    compiled_input: Option[String],
    input: Option[String],
    module: String,
    capy_overrides: List[CapyOverride],
    log_level: LogLevel
}

data CapyOverride {
    field: String,
    value: String
}

data PackageArchive {
    format: String,
    module: String,
    files: List[PackageFile]
}

data PackageFile {
    path: String,
    content: String
}

enum LogLevel {
    DEBUG,
    INFO,
    WARN,
    ERROR
}

union CliArgs[T] = ParsedArgs[T] | UsageError
data ParsedArgs[T] { value: T }
data UsageError { message: String }

data NamedOptions {
    input: Option[String],
    output: Option[String],
    libs: Option[String],
    linked_output: Option[String],
    test_input: Option[String],
    test_output: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    skip_java_lib: bool,
    log_level: LogLevel
}

data NamedOptionRules {
    allow_libs: bool,
    allow_skip_java_lib: bool,
    allow_linked_output: bool,
    allow_test_outputs: bool
}

data PartialPackageOptions {
    compiled_input: Option[String],
    input: Option[String],
    module: Option[String],
    capy_overrides: List[CapyOverride],
    log_level: LogLevel
}

fun CliArgs[T].`|`(map: T => CliArgs[Y]): CliArgs[Y] =
    match this with
    case UsageError e -> e
    case ParsedArgs { value } -> map(value)

private fun parse_compile_options(args: List[String]): CliArgs[CompileOptions] =
    match parse_named_options(args, 0, empty_named_options(), NamedOptionRules {
        allow_libs: true,
        allow_skip_java_lib: false,
        allow_linked_output: false,
        allow_test_outputs: false
    }) with
    case UsageError e -> e
    case ParsedArgs { options } -> compile_options_from_named(options)

private fun parse_generate_options(args: List[String]): CliArgs[GenerateOptions] =
    match args[0] with
    case None -> UsageError { message: "Missing output type for `generate`." }
    case Some { output_type_name } ->
        match parse_output_type(output_type_name) with
        case UsageError e -> e
        case ParsedArgs { output_type } ->
            match parse_named_options(args[1:], 0, empty_named_options(), NamedOptionRules {
                allow_libs: false,
                allow_skip_java_lib: true,
                allow_linked_output: false,
                allow_test_outputs: false
            }) with
            case UsageError e -> e
            case ParsedArgs { options } -> generate_options_from_named(output_type, options)

private fun parse_compile_generate_options(args: List[String]): CliArgs[CompileGenerateOptions] =
    match args[0] with
    case None -> UsageError { message: "Missing output type for `compile-generate`." }
    case Some { output_type_name } ->
        match parse_output_type(output_type_name) with
        case UsageError e -> e
        case ParsedArgs { output_type } ->
            match parse_named_options(args[1:], 0, empty_named_options(), NamedOptionRules {
                allow_libs: true,
                allow_skip_java_lib: true,
                allow_linked_output: true,
                allow_test_outputs: true
            }) with
            case UsageError e -> e
            case ParsedArgs { options } ->
                match validate_test_outputs(options) with
                case UsageError e -> e
                case ParsedArgs { validated_options } -> compile_generate_options_from_named(output_type, validated_options)

private fun parse_package_options(args: List[String]): CliArgs[PackageOptions] =
    match parse_package_options(args, 0, PartialPackageOptions {
        compiled_input: None {},
        input: None {},
        module: None {},
        capy_overrides: [],
        log_level: INFO
    }) with
    case UsageError e -> e
    case ParsedArgs { options } ->
        match validate_package_inputs(options) with
        case UsageError e -> e
        case ParsedArgs { validated_options } -> package_options_from_partial(validated_options)

private fun compile_options_from_named(options: NamedOptions): CliArgs[CompileOptions] =
    match required_option(options.input, "input", "compile") with
    case UsageError e -> e
    case ParsedArgs { input } ->
        match required_option(options.output, "output", "compile") with
        case UsageError e -> e
        case ParsedArgs { output } -> ParsedArgs { CompileOptions {
            input: input,
            output: output,
            libs: options.libs,
            native_wiring: options.native_wiring,
            compile_tests: options.compile_tests,
            log_level: options.log_level
        }}

private fun generate_options_from_named(output_type: String, options: NamedOptions): CliArgs[GenerateOptions] =
    match required_option(options.output, "output", "generate") with
    case UsageError e -> e
    case ParsedArgs { output } -> ParsedArgs { GenerateOptions {
        output_type: output_type,
        input: option_or(options.input, "."),
        output: output,
        include_java_lib_resources: !options.skip_java_lib,
        log_level: options.log_level
    }}

private fun compile_generate_options_from_named(output_type: String, options: NamedOptions): CliArgs[CompileGenerateOptions] =
    match required_option(options.input, "input", "compile-generate") with
    case UsageError e -> e
    case ParsedArgs { input } ->
        match required_option(options.output, "output", "compile-generate") with
        case UsageError e -> e
        case ParsedArgs { output } -> ParsedArgs { CompileGenerateOptions {
            output_type: output_type,
            input: input,
            output: output,
            linked_output: options.linked_output,
            test_input: options.test_input,
            test_output: options.test_output,
            libs: options.libs,
            native_wiring: options.native_wiring,
            compile_tests: options.compile_tests,
            include_java_lib_resources: !options.skip_java_lib,
            log_level: options.log_level
        }}

private fun package_options_from_partial(options: PartialPackageOptions): CliArgs[PackageOptions] =
    match required_option(options.module, "module", "package") with
    case UsageError e -> e
    case ParsedArgs { module } -> ParsedArgs { PackageOptions {
        compiled_input: options.compiled_input,
        input: options.input,
        module: module,
        capy_overrides: options.capy_overrides,
        log_level: options.log_level
    }}

private fun parse_named_options(args: List[String], idx: int, options: NamedOptions, rules: NamedOptionRules): CliArgs[NamedOptions] =
    match args[idx] with
    case None -> ParsedArgs { options }
    case Some { "--log" } ->
        next_value(args, idx, "--log")
        | value => parse_log_level(value)
        | log_level => parse_named_options(args, idx + 2, options.with(log_level: log_level), rules)
    case Some { "-i" } | Some { "--input" } ->
        next_value(args, idx, "input")
        | value => parse_named_options(args, idx + 2, options.with(input: Some { value }), rules)
    case Some { "-o" } | Some { "--output" } ->
        next_value(args, idx, "output")
        | value => parse_named_options(args, idx + 2, options.with(output: Some { value }), rules)
    case Some { "--linked-output" } ->
        if !rules.allow_linked_output
        then UsageError { message: "Option `--linked-output` is supported only for `compile-generate`." }
        else next_value(args, idx, "--linked-output")
            | value => parse_named_options(args, idx + 2, options.with(linked_output: Some { value }), rules)
    case Some { "--test-input" } ->
        if !rules.allow_test_outputs
        then UsageError { message: "Option `--test-input` is supported only for `compile-generate`." }
        else next_value(args, idx, "--test-input")
            | value => parse_named_options(args, idx + 2, options.with(test_input: Some { value }), rules)
    case Some { "--test-output" } ->
        if !rules.allow_test_outputs
        then UsageError { message: "Option `--test-output` is supported only for `compile-generate`." }
        else next_value(args, idx, "--test-output")
            | value => parse_named_options(args, idx + 2, options.with(test_output: Some { value }), rules)
    case Some { "-l" } | Some { "--libs" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--libs` is supported only for `compile` and `compile-generate`." }
        else next_value(args, idx, "--libs")
            | value => parse_named_options(args, idx + 2, options.with(libs: Some { value }), rules)
    case Some { "--native-wiring" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--native-wiring` is supported only for `compile` and `compile-generate`." }
        else next_value(args, idx, "--native-wiring")
            | value => parse_named_options(args, idx + 2, options.with(native_wiring: Some { value }), rules)
    case Some { "--compile-tests" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--compile-tests` is supported only for `compile` and `compile-generate`." }
        else parse_named_options(args, idx + 1, options.with(compile_tests: true), rules)
    case Some { "--skip-java-lib" } ->
        if !rules.allow_skip_java_lib
        then UsageError { message: "Option `--skip-java-lib` is supported only for `generate` and `compile-generate`." }
        else parse_named_options(args, idx + 1, options.with(skip_java_lib: true), rules)
    case Some { arg } -> UsageError { message: "Unknown option `" + arg + "`." }

private fun parse_package_options(args: List[String], idx: int, options: PartialPackageOptions): CliArgs[PartialPackageOptions] =
    match args[idx] with
    case None -> ParsedArgs { options }
    case Some { "--log" } ->
        next_value(args, idx, "--log")
        | value => parse_log_level(value)
        | log_level => parse_package_options(args, idx + 2, options.with(log_level: log_level))
    case Some { "-ci" } | Some { "--compiled-input" } ->
        next_value(args, idx, "--compiled-input")
        | value => parse_package_options(args, idx + 2, options.with(compiled_input: Some { value }))
    case Some { "-i" } | Some { "--input" } ->
        next_value(args, idx, "--input")
        | value => parse_package_options(args, idx + 2, options.with(input: Some { value }))
    case Some { "-m" } | Some { "--module" } ->
        next_value(args, idx, "--module")
        | value => parse_package_options(args, idx + 2, options.with(module: Some { value }))
    case Some { arg } when arg.starts_with("--capy.") ->
        next_value(args, idx, arg)
        | value => parse_package_options(args, idx + 2, options.with(capy_overrides: options.capy_overrides + CapyOverride {
            field: capy_override_field(arg),
            value: value
        }))
    case Some { arg } -> UsageError { message: "Unknown option `" + arg + "`." }

private fun empty_named_options(): NamedOptions =
    NamedOptions {
        input: None {},
        output: None {},
        libs: None {},
        linked_output: None {},
        test_input: None {},
        test_output: None {},
        native_wiring: None {},
        compile_tests: false,
        skip_java_lib: false,
        log_level: INFO
    }

private fun next_value(args: List[String], idx: int, option: String): CliArgs[String] =
    match args[idx + 1] with
    case Some { value } -> ParsedArgs { value }
    case None -> UsageError { message: "Missing value for `" + option + "`." }

private fun required_option(option: Option[String], name: String, command: String): CliArgs[String] =
    match option with
    case Some { value } -> ParsedArgs { value }
    case None -> UsageError { message: "Missing required option `--" + name + "` for `" + command + "`." }

private fun option_or(option: Option[String], default_value: String): String =
    match option with
    case Some { value } -> value
    case None -> default_value

private fun option_present(option: Option[String]): bool =
    match option with
    case Some _ -> true
    case None -> false

private fun validate_test_outputs(options: NamedOptions): CliArgs[NamedOptions] =
    if option_present(options.test_input) == option_present(options.test_output)
    then ParsedArgs { options }
    else UsageError { message: "`compile-generate` requires both `--test-input` and `--test-output` when either is provided." }

private fun validate_package_inputs(options: PartialPackageOptions): CliArgs[PartialPackageOptions] =
    if option_present(options.compiled_input) & option_present(options.input)
    then UsageError { message: "Package accepts only one of `--compiled-input` or `--input`." }
    else if option_present(options.compiled_input) | option_present(options.input)
    then ParsedArgs { options }
    else UsageError { message: "Package requires either `--compiled-input` or `--input`." }

private fun parse_output_type(value: String): CliArgs[String] =
    match value with
    case "java" | "JAVA" -> ParsedArgs { "java" }
    case "javascript" | "JAVASCRIPT" | "js" | "JS" -> ParsedArgs { "javascript" }
    case "python" | "PYTHON" | "py" | "PY" -> ParsedArgs { "python" }
    case _ -> UsageError { message: "Unknown output type `" + value + "`. Use java, python, py, javascript, or js." }

private fun parse_log_level(value: String): CliArgs[LogLevel] =
    match value with
    case "DEBUG" | "debug" -> ParsedArgs { DEBUG }
    case "INFO" | "info" -> ParsedArgs { INFO }
    case "WARN" | "warn" | "WARNING" | "warning" -> ParsedArgs { WARN }
    case "ERROR" | "error" -> ParsedArgs { ERROR }
    case _ -> UsageError { message: "Unknown log level `" + value + "`. Use DEBUG, INFO, WARN, or ERROR." }

private fun print_version(): Effect[/capy/lang/Program] =
    println(version_text())
        .map(_ => /capy/lang/Program.Success {})

private fun print_help(): Effect[/capy/lang/Program] =
    println(version_text() + "\n\n" + help_text())
        .map(_ => /capy/lang/Program.Success {})

private fun usage_error(message: String): Effect[/capy/lang/Program] =
    println_error(message + "\n\n" + help_text())
        .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })

private fun command_not_ready(command: String): Effect[/capy/lang/Program] =
    println_error("Command `" + command + "` parsed successfully, but execution is not implemented yet.")
        .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })

private fun version_text(): String =
    "Capybara compiler version: " + COMPILER_VERSION

private fun help_text(): String =
    "Usage:\n"
    + "  capy -v | --version\n"
    + "  capy -h | --help\n"
    + "  capy compile [-l|--libs <dir1,dir2,...>] [--compile-tests] [--native-wiring <file>] -i|--input <dir> -o|--output <dir> [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy compile-generate <java|python|javascript|js> [-l|--libs <dir1,dir2,...>] [--compile-tests] [--native-wiring <file>] -i|--input <dir> -o|--output <dir> [--linked-output <dir>] [--test-input <dir> --test-output <dir>] [--skip-java-lib] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy generate <java|python|javascript|js> [-i|--input <dir>] -o|--output <dir> [--skip-java-lib] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy package (-ci|--compiled-input <dir> | -i|--input <dir>) -m|--module <capy.yml> [--capy.<field> <value>] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "\n"
    + "Notes:\n"
    + "  compile output directory may be reused; stale generated files are pruned automatically.\n"
    + "  compile-generate compiles Capybara sources directly to generated output without writing linked intermediates unless --linked-output is provided.\n"
    + "  --native-wiring <file> is supported by compile and compile-generate; it reads native provider bindings from a JSON manifest and stores them in linked program output.\n"
    + "  compile-generate --test-input/--test-output also compiles test Capybara sources against the freshly compiled main program in the same invocation.\n"
    + "  compile --compile-tests writes bundled stdlib modules and injects discovered TestFile/List[TestFile] producers into capy/test/CapyTestRuntime.gather_tests.\n"
    + "  generate input directory defaults to the current directory.\n"
    + "  generate --skip-java-lib omits bundled Java runtime sources when the caller already has them on the compile classpath.\n"
    + "  package writes `capy.cbin` next to the provided `capy.yml`."

private fun capy_override_field(arg: String): String =
    @Recursive
    fun copy_suffix(value: String, idx: int, acc: String): String =
        if idx >= value.size().value
        then acc
        else match value[idx] with
            case None -> acc
            case Some { char } -> copy_suffix(value, idx + 1, acc + char)
    ---
    copy_suffix(arg, 7, "")

fun run_compile(options: CompileOptions): Effect[/capy/lang/Program] =
    compile_configuration(options).flat_map(configuration_result =>
        match configuration_result with
        case Error { message } -> runtime_error(message)
        case Success { configuration } ->
            let input_path = from_string(options.input)
            let output_path = from_string(options.output)
            validate_input_directory(input_path, options.input).flat_map(input_result =>
                match input_result with
                case Error { message } -> runtime_error(message)
                case Success _ ->
                    validate_output_directory(output_path, options.output).flat_map(output_result =>
                        match output_result with
                        case Error { message } -> runtime_error(message)
                        case Success _ ->
                            read_source_modules(input_path, options.input).flat_map(modules_result =>
                                match modules_result with
                                case Error { message } -> runtime_error(message)
                                case Success { raw_modules } ->
                                    /dev/capylang/compiler/CapybaraCompiler.compile(
                                        raw_modules,
                                        configuration.libraries,
                                        configuration.native_providers,
                                        empty_native_provider_manifest()
                                    ).flat_map(compilation =>
                                        match compilation with
                                        case Left { program } ->
                                            write_compilation_output(output_path, program).flat_map(write_result =>
                                                match write_result with
                                                case Error { message } -> runtime_error(message)
                                                case Success _ -> pure(/capy/lang/Program.Success {})
                                            )
                                        case Right { errors } ->
                                            print_compiler_errors(errors)
                                                .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })
                                    )
                            )
                    )
            )
    )

private fun compile_configuration(options: CompileOptions): Effect[Result[CompileConfiguration]] =
    compiler_configuration(options.libs, options.native_wiring)

private fun compile_generate_configuration(options: CompileGenerateOptions): Effect[Result[CompileConfiguration]] =
    compiler_configuration(options.libs, options.native_wiring)

private fun compiler_configuration(libs: Option[String], nativeWiring: Option[String]): Effect[Result[CompileConfiguration]] =
    read_library_modules(libs).flat_map(libraries_result =>
        match libraries_result with
        case Error e -> pure(e)
        case Success { libraries } ->
            read_native_provider_manifest_option(nativeWiring).map(native_result =>
                match native_result with
                case Error e -> e
                case Success { native_providers } -> Success { CompileConfiguration {
                    libraries: libraries,
                    native_providers: native_providers
                }}
            )
    )

private fun read_library_modules(libs: Option[String]): Effect[Result[Set[CompiledModule]]] =
    match libs with
    case None -> pure(Success { {} })
    case Some { value } ->
        if value.trim().is_empty()
        then pure(Success { {} })
        else read_linked_libraries(value)

private fun read_native_provider_manifest_option(nativeWiring: Option[String]): Effect[Result[NativeProviderManifest]] =
    match nativeWiring with
    case None -> pure(Success { empty_native_provider_manifest() })
    case Some { rawPath } ->
        let manifestPath = from_string(rawPath)
        validate_module_file(manifestPath, rawPath).flat_map(fileResult =>
            match fileResult with
            case Error { message } -> pure(Error { message: "Native wiring manifest is not a file: " + rawPath + ": " + message })
            case Success _ ->
                read_text(manifestPath).map(readResult =>
                    match readResult with
                    case Error { message } -> Error { message: "Unable to read native wiring manifest `" + rawPath + "`: " + message }
                    case Success { source } -> parse_native_provider_manifest(rawPath, source)
                )
        )

private fun parse_native_provider_manifest(rawPath: String, source: String): Result[NativeProviderManifest] =
    match deserialize(source) with
    case Error { message } -> Error { message: "Unable to parse native wiring manifest `" + rawPath + "`: " + message }
    case Success { value } ->
        match value.get("providers") with
        case None -> Success { empty_native_provider_manifest() }
        case Some { providersJson } ->
            match native_provider_bindings_from_json(providersJson) with
            case Error e -> e
            case Success { providers } -> Success { NativeProviderManifest { providers } }

private fun native_provider_bindings_from_json(json: Json): Result[List[NativeProviderBinding]] =
    match json with
    case JsonArray { value } -> native_provider_bindings_from_json_values(value)
    case JsonValueArray { value } -> native_provider_bindings_from_json(value)
    case _ -> Error { message: "Native wiring field `providers` must be an array." }

private fun native_provider_bindings_from_json_values(values: List[Json]): Result[List[NativeProviderBinding]] =
    match values[0] with
    case None -> Success { [] }
    case Some { value } ->
        let binding <- native_provider_binding_from_json(value)
        let rest <- native_provider_bindings_from_json_values(values[1:])
        [binding] + rest

private fun native_provider_binding_from_json(json: Json): Result[NativeProviderBinding] =
    let object <- json_object(json, "Native provider binding")
    let interfaceId <- json_required_string(object, "interfaceId")
    let qualifier <- json_optional_string(object, "qualifier", "")
    let javaBinding <- json_optional_backend_binding(object, "javaBinding")
    let javascriptBinding <- json_optional_backend_binding(object, "javascriptBinding")
    let pythonBinding <- json_optional_backend_binding(object, "pythonBinding")
    NativeProviderBinding {
        interfaceId: interfaceId,
        qualifier: qualifier,
        javaBinding: javaBinding,
        javascriptBinding: javascriptBinding,
        pythonBinding: pythonBinding
    }

private fun json_optional_backend_binding(object: JsonObject, field: String): Result[Option[NativeProviderBackendBinding]] =
    match object.get(field) with
    case None -> Success { None {} }
    case Some { value } ->
        match value with
        case JsonNull -> Success { None {} }
        case _ ->
            let backendObject <- json_object(value, "Native provider backend binding `" + field + "`")
            let className <- json_optional_string_option(backendObject, "className")
            let moduleName <- json_optional_string_option(backendObject, "moduleName")
            let exportName <- json_optional_string_option(backendObject, "exportName")
            let factory <- json_optional_string_option(backendObject, "factory")
            Some { NativeProviderBackendBinding {
                className: className,
                moduleName: moduleName,
                exportName: exportName,
                factory: factory
            }}

private fun json_object(json: Json, description: String): Result[JsonObject] =
    match json with
    case JsonObject object -> Success { object }
    case JsonValueObject { value } -> Success { value }
    case _ -> Error { message: description + " must be a JSON object." }

private fun json_required_string(object: JsonObject, field: String): Result[String] =
    match object.get(field) with
    case None -> Error { message: "Missing native wiring field `" + field + "`." }
    case Some { value } -> json_string(value, "Native wiring field `" + field + "`")

private fun json_optional_string(object: JsonObject, field: String, defaultValue: String): Result[String] =
    match object.get(field) with
    case None -> Success { defaultValue }
    case Some { value } ->
        match value with
        case JsonNull -> Success { defaultValue }
        case _ -> json_string(value, "Native wiring field `" + field + "`")

private fun json_optional_string_option(object: JsonObject, field: String): Result[Option[String]] =
    match object.get(field) with
    case None -> Success { None {} }
    case Some { value } ->
        match value with
        case JsonNull -> Success { None {} }
        case _ ->
            let text <- json_string(value, "Native wiring field `" + field + "`")
            Some { text }

private fun json_string(json: Json, description: String): Result[String] =
    match json with
    case JsonString { value } -> Success { value }
    case _ -> Error { message: description + " must be a string." }

private fun validate_input_directory(path: Path, raw_path: String): Effect[Result[Path]] =
    exists(path).flat_map(present =>
        if !present
        then pure(Error { message: "Input path does not exist: " + raw_path })
        else is_directory(path).map(directory =>
            if directory
            then Success { path }
            else Error { message: "Input path is not a directory: " + raw_path }
        )
    )

private fun validate_output_directory(path: Path, raw_path: String): Effect[Result[Path]] =
    exists(path).flat_map(present =>
        if !present
        then create_directories(path)
        else is_directory(path).map(directory =>
            if directory
            then Success { path }
            else Error { message: "Compile output path is not a directory: " + raw_path }
        )
    )

private fun compile_source_directory(inputPath: Path, rawInput: String, configuration: CompileConfiguration): Effect[Either[CompiledProgram, List[CompilerError]]] =
    validate_input_directory(inputPath, rawInput).flat_map(inputResult =>
        match inputResult with
        case Error { message } -> pure(Right { [CompilerError {
            message: message,
            moduleName: "",
            line: 0,
            column: 0
        }] })
        case Success _ ->
            read_source_modules(inputPath, rawInput).flat_map(modulesResult =>
                match modulesResult with
                case Error { message } -> pure(Right { [CompilerError {
                    message: message,
                    moduleName: "",
                    line: 0,
                    column: 0
                }] })
                case Success { raw_modules } ->
                    read_native_implementation_manifest(inputPath).flat_map(nativeImplementationProviders =>
                        /dev/capylang/compiler/CapybaraCompiler.compile(
                            raw_modules,
                            configuration.libraries,
                            configuration.native_providers,
                            nativeImplementationProviders
                        )
                    )
            )
    )

private fun read_native_implementation_manifest(inputPath: Path): Effect[NativeProviderManifest] =
    read_native_implementation_manifest_at(inputPath).flat_map(providers =>
        if !providers.providers.is_empty()
        then pure(providers)
        else match inputPath.parent() with
            case None -> pure(providers)
            case Some { parent } ->
                match last_segment(inputPath.normalize().segments) with
                case Some { segment } ->
                    if segment == "capybara"
                    then read_native_implementation_manifest_at(parent)
                    else pure(providers)
                case None -> pure(providers)
    )

private fun read_native_implementation_manifest_at(inputPath: Path): Effect[NativeProviderManifest] =
    read_native_java_implementation_manifest(inputPath).flat_map(javaProviders =>
        read_native_python_implementation_manifest(inputPath).flat_map(pythonProviders =>
            read_native_javascript_implementation_manifest(inputPath).map(javascriptProviders =>
                NativeProviderManifest {
                    providers: javaProviders.providers + pythonProviders.providers + javascriptProviders.providers
                }
            )
        )
    )

private fun read_native_java_implementation_manifest(inputPath: Path): Effect[NativeProviderManifest] =
    read_native_java_implementation_root(inputPath / "native" / "java").flat_map(inRootProviders =>
        read_native_java_implementation_manifest_near_capybara_root(inputPath).map(nearRootProviders =>
            NativeProviderManifest {
                providers: inRootProviders.providers + nearRootProviders.providers
            }
        )
    )

private fun read_native_java_implementation_manifest_near_capybara_root(inputPath: Path): Effect[NativeProviderManifest] =
    match inputPath.parent() with
    case None -> pure(empty_native_provider_manifest())
    case Some { parent } ->
        match last_segment(inputPath.normalize().segments) with
        case Some { segment } ->
            if segment == "capybara"
            then read_native_java_implementation_root(parent / "native" / "java")
            else pure(empty_native_provider_manifest())
        case None -> pure(empty_native_provider_manifest())

private fun read_native_java_implementation_root(nativeJavaPath: Path): Effect[NativeProviderManifest] =
    exists(nativeJavaPath).flat_map(present =>
        if !present
        then pure(empty_native_provider_manifest())
        else is_directory(nativeJavaPath).flat_map(directory =>
            if !directory
            then pure(empty_native_provider_manifest())
            else cli_list_regular_files(nativeJavaPath).flat_map(filesResult =>
                match filesResult with
                case Error _ -> pure(empty_native_provider_manifest())
                case Success { files } -> read_native_java_provider_bindings(java_source_files(files))
            )
        )
    )

private fun read_native_python_implementation_manifest(inputPath: Path): Effect[NativeProviderManifest] =
    read_native_python_implementation_root(inputPath / "native" / "py").flat_map(providers =>
        if !providers.providers.is_empty()
        then pure(providers)
        else match inputPath.parent() with
            case None -> pure(providers)
            case Some { parent } ->
                match last_segment(inputPath.normalize().segments) with
                case Some { segment } ->
                    if segment == "capybara"
                    then read_native_python_implementation_root(parent / "native" / "py")
                    else pure(providers)
                case None -> pure(providers)
    )

private fun read_native_python_implementation_root(nativePythonPath: Path): Effect[NativeProviderManifest] =
    exists(nativePythonPath).flat_map(present =>
        if !present
        then pure(empty_native_provider_manifest())
        else is_directory(nativePythonPath).flat_map(directory =>
            if !directory
            then pure(empty_native_provider_manifest())
            else cli_list_regular_files(nativePythonPath).flat_map(filesResult =>
                match filesResult with
                case Error _ -> pure(empty_native_provider_manifest())
                case Success { files } -> read_native_python_provider_bindings(nativePythonPath, python_source_files(files))
            )
        )
    )

private fun read_native_javascript_implementation_manifest(inputPath: Path): Effect[NativeProviderManifest] =
    match inputPath.parent() with
    case None -> read_native_javascript_implementation_root(inputPath / "native" / "js")
    case Some { parent } -> read_native_javascript_implementation_root(parent / "native" / "js")

private fun read_native_javascript_implementation_root(root: Path): Effect[NativeProviderManifest] =
    exists(root).flat_map(present =>
        if !present
        then pure(empty_native_provider_manifest())
        else is_directory(root).flat_map(directory =>
            if !directory
            then pure(empty_native_provider_manifest())
            else cli_list_regular_files(root).flat_map(filesResult =>
                match filesResult with
                case Error _ -> pure(empty_native_provider_manifest())
                case Success { files } -> read_native_javascript_provider_bindings(root, javascript_source_files(files))
            )
        )
    )

private fun java_source_files(files: List[Path]): List[Path] =
    match files[0] with
    case None -> []
    case Some { file } ->
        if cli_path_to_string(file).end_with(".java")
        then [file] + java_source_files(files[1:])
        else java_source_files(files[1:])

private fun python_source_files(files: List[Path]): List[Path] =
    match files[0] with
    case None -> []
    case Some { file } ->
        if cli_path_to_string(file).end_with(".py")
        then [file] + python_source_files(files[1:])
        else python_source_files(files[1:])

private fun javascript_source_files(files: List[Path]): List[Path] =
    match files[0] with
    case None -> []
    case Some { file } ->
        if cli_path_to_string(file).end_with(".js")
        then [file] + javascript_source_files(files[1:])
        else javascript_source_files(files[1:])

private fun read_native_java_provider_bindings(files: List[Path]): Effect[NativeProviderManifest] =
    match files[0] with
    case None -> pure(empty_native_provider_manifest())
    case Some { file } ->
        read_text(file).flat_map(readResult =>
            match readResult with
            case Error _ -> read_native_java_provider_bindings(files[1:])
            case Success { content } ->
                read_native_java_provider_bindings(files[1:]).map(rest =>
                    NativeProviderManifest {
                        providers: native_java_provider_bindings(content) + rest.providers
                    }
                )
        )

private fun read_native_python_provider_bindings(root: Path, files: List[Path]): Effect[NativeProviderManifest] =
    match files[0] with
    case None -> pure(empty_native_provider_manifest())
    case Some { file } ->
        read_text(file).flat_map(readResult =>
            match readResult with
            case Error _ -> read_native_python_provider_bindings(root, files[1:])
            case Success { content } ->
                read_native_python_provider_bindings(root, files[1:]).map(rest =>
                    NativeProviderManifest {
                        providers: native_python_provider_bindings(content, native_python_module_name(cli_relative_to(root, file))) + rest.providers
                    }
                )
        )

private fun read_native_javascript_provider_bindings(root: Path, files: List[Path]): Effect[NativeProviderManifest] =
    match files[0] with
    case None -> pure(empty_native_provider_manifest())
    case Some { file } ->
        read_text(file).flat_map(readResult =>
            match readResult with
            case Error _ -> read_native_javascript_provider_bindings(root, files[1:])
            case Success { content } ->
                read_native_javascript_provider_bindings(root, files[1:]).map(rest =>
                    NativeProviderManifest {
                        providers: native_javascript_provider_bindings(
                            content,
                            native_javascript_module_name(cli_relative_to(root, file)),
                            cli_path_to_string(file.normalize())
                        ) + rest.providers
                    }
                )
        )

private fun native_java_provider_bindings(source: String): List[NativeProviderBinding] =
    if !(source ? "@NativeImplementation")
    then []
    else
        let className = native_java_class_name(source)
        let interfaceId = native_java_interface_id(source)
        if className.is_empty() | interfaceId.is_empty()
        then []
        else [NativeProviderBinding {
            interfaceId: interfaceId,
            qualifier: native_java_qualifier(source),
            javaBinding: Some { NativeProviderBackendBinding {
                className: Some { className },
                moduleName: None {},
                exportName: None {},
                factory: None {}
            }},
            javascriptBinding: None {},
            pythonBinding: None {}
        }]

private fun native_python_provider_bindings(source: String, moduleName: String): List[NativeProviderBinding] =
    if !(source ? "@NativeImplementation")
    then []
    else
        let className = native_python_class_name(source)
        let interfaceId = native_python_interface_id(source)
        if className.is_empty() | interfaceId.is_empty() | moduleName.is_empty()
        then []
        else [NativeProviderBinding {
            interfaceId: interfaceId,
            qualifier: native_python_qualifier(source),
            javaBinding: None {},
            javascriptBinding: None {},
            pythonBinding: Some { NativeProviderBackendBinding {
                className: None {},
                moduleName: Some { moduleName },
                exportName: Some { className },
                factory: None {}
            }}
        }]

private fun native_javascript_provider_bindings(source: String, moduleName: String, sourceFilePath: String): List[NativeProviderBinding] =
    if !(source ? "@NativeImplementation")
    then []
    else
        let className = native_javascript_class_name(source)
        let interfaceId = native_javascript_interface_id(source, moduleName)
        if className.is_empty() | interfaceId.is_empty() | sourceFilePath.is_empty()
        then []
        else [NativeProviderBinding {
            interfaceId: interfaceId,
            qualifier: native_javascript_qualifier(source),
            javaBinding: None {},
            javascriptBinding: Some { NativeProviderBackendBinding {
                className: None {},
                moduleName: Some { sourceFilePath },
                exportName: Some { className },
                factory: None {}
            }},
            pythonBinding: None {}
        }]

private fun native_java_class_name(source: String): String =
    let packageName = native_java_package_name(source)
    let className = native_java_token_after(source, " class ")
    if className.is_empty()
    then ""
    else if packageName.is_empty()
    then className
    else packageName + "." + className

private fun native_java_interface_id(source: String): String =
    let implemented = native_java_token_after(source, " implements ")
    if implemented.is_empty()
    then ""
    else if implemented ? "."
    then implemented
    else native_java_imported_name(source, implemented, native_java_package_name(source))

private fun native_java_package_name(source: String): String =
    native_java_between(source, "package ", ";").trim()

private fun native_java_qualifier(source: String): String =
    if source ? "qualifier = \""
    then native_java_between(source, "qualifier = \"", "\"")
    else if source ? "qualifier=\""
    then native_java_between(source, "qualifier=\"", "\"")
    else if source ? "@NativeImplementation(\""
    then native_java_between(source, "@NativeImplementation(\"", "\"")
    else ""

private fun native_python_module_name(relativePath: Path): String =
    let path = cli_path_to_string(relativePath.normalize())
    let withoutExtension =
        if path.end_with(".py")
        then path[0, path.size().value - ".py".size().value]
        else path
    withoutExtension.replace("/", ".")

private fun native_python_class_name(source: String): String =
    let annotationIndex = native_java_index_of(source, "@NativeImplementation", 0)
    if annotationIndex < 0
    then ""
    else native_java_token_after(source[annotationIndex, source.size().value], "class ")

private fun native_python_interface_id(source: String): String =
    let className = native_python_class_name(source)
    if source ? "interface_id = \""
    then native_java_between(source, "interface_id = \"", "\"")
    else if source ? "interface_id=\""
    then native_java_between(source, "interface_id=\"", "\"")
    else native_python_base_interface_id(source, className)

private fun native_python_base_interface_id(source: String, className: String): String =
    if className.is_empty()
    then ""
    else
        let bases = native_java_between(source, "class " + className + "(", ")")
        let baseName = native_python_first_base(bases)
        if baseName.is_empty()
        then ""
        else if baseName ? "."
        then baseName
        else native_python_imported_name(source, baseName)

private fun native_python_first_base(bases: String): String =
    native_python_base_token(bases.trim(), 0, "")

private fun native_python_base_token(source: String, idx: int, acc: String): String =
    if idx >= source.size().value
    then acc
    else match source[idx] with
        case None -> acc
        case Some { char } ->
            if native_java_token_char(char)
            then native_python_base_token(source, idx + 1, acc + char)
            else acc

private fun native_python_qualifier(source: String): String =
    if source ? "qualifier = \""
    then native_java_between(source, "qualifier = \"", "\"")
    else if source ? "qualifier=\""
    then native_java_between(source, "qualifier=\"", "\"")
    else if source ? "@NativeImplementation(\""
    then native_java_between(source, "@NativeImplementation(\"", "\"")
    else ""

private fun native_javascript_module_name(relativePath: Path): String =
    let path = cli_path_to_string(relativePath.normalize())
    let withoutExtension =
        if path.end_with(".js")
        then path[0, path.size().value - ".js".size().value]
        else path
    withoutExtension.replace("/", ".")

private fun native_javascript_class_name(source: String): String =
    native_java_token_after(source, "class ")

private fun native_javascript_interface_id(source: String, moduleName: String): String =
    let className = native_javascript_class_name(source)
    if className.is_empty()
    then ""
    else
        let classStart = native_java_index_of(source, "class " + className, 0)
        if classStart < 0
        then ""
        else
            let extendsName = native_javascript_extends_name(source, classStart)
            if extendsName.is_empty()
            then ""
            else native_javascript_imported_name(source, extendsName, moduleName)

private fun native_javascript_extends_name(source: String, classStart: int): String =
    let extendsStart = native_java_index_of(source, " extends ", classStart)
    if extendsStart < 0
    then ""
    else native_java_token_from(source, extendsStart + " extends ".size().value, "")

private fun native_javascript_qualifier(source: String): String =
    if source ? "qualifier = \""
    then native_java_between(source, "qualifier = \"", "\"")
    else if source ? "qualifier=\""
    then native_java_between(source, "qualifier=\"", "\"")
    else if source ? "@NativeImplementation(\""
    then native_java_between(source, "@NativeImplementation(\"", "\"")
    else ""

private fun native_javascript_imported_name(source: String, simpleName: String, moduleName: String): String =
    if simpleName ? "."
    then simpleName
    else
        let requiredModule = native_javascript_required_module(source)
        if requiredModule.is_empty()
        then native_javascript_module_relative_name(moduleName, simpleName)
        else native_javascript_required_interface_id(moduleName, requiredModule, simpleName)

private fun native_javascript_required_module(source: String): String =
    if source ? "require('"
    then native_java_between(source, "require('", "'")
    else if source ? "require(\""
    then native_java_between(source, "require(\"", "\"")
    else ""

private fun native_javascript_required_interface_id(moduleName: String, requiredModule: String, simpleName: String): String =
    let parentModule = native_javascript_parent_module_name(moduleName)
    let normalized = native_javascript_required_module_name(parentModule, requiredModule)
    let withoutExtension =
        if normalized.end_with(".js")
        then normalized[0, normalized.size().value - ".js".size().value]
        else normalized
    if withoutExtension.end_with("." + simpleName)
    then withoutExtension
    else withoutExtension + "." + simpleName

private fun native_javascript_required_module_name(baseModule: String, requiredModule: String): String =
    if requiredModule.starts_with("../")
    then native_javascript_join_module(native_javascript_parent_module_name(baseModule), requiredModule[3, requiredModule.size().value])
    else if requiredModule.starts_with("./")
    then native_javascript_join_module(baseModule, requiredModule[2, requiredModule.size().value])
    else requiredModule.replace("/", ".")

private fun native_javascript_join_module(baseModule: String, relativeModule: String): String =
    let moduleName = relativeModule.replace("/", ".")
    if baseModule.is_empty()
    then moduleName
    else if moduleName.is_empty()
    then baseModule
    else baseModule + "." + moduleName

private fun native_javascript_parent_module_name(moduleName: String): String =
    let separator = native_java_last_index_of(moduleName, ".", 0, -1, moduleName.size().value)
    if separator < 0
    then ""
    else moduleName[0, separator]

private fun native_javascript_module_relative_name(moduleName: String, simpleName: String): String =
    let parentModule = native_javascript_parent_module_name(moduleName)
    if parentModule.is_empty()
    then simpleName
    else parentModule + "." + simpleName

private fun native_python_imported_name(source: String, simpleName: String): String =
    if simpleName ? "."
    then simpleName
    else
        let importSuffix = " import " + simpleName
        let suffixIndex = native_java_index_of(source, importSuffix, 0)
        if suffixIndex >= 0
        then
            let importStart = native_java_last_index_of(source, "from ", 0, -1, suffixIndex)
            if importStart >= 0
            then native_python_imported_module_name(source[importStart + "from ".size().value, suffixIndex].trim(), simpleName)
            else simpleName
        else simpleName

private fun native_python_imported_module_name(moduleName: String, simpleName: String): String =
    if moduleName.end_with("." + simpleName)
    then moduleName
    else moduleName + "." + simpleName

private fun native_java_imported_name(source: String, simpleName: String, packageName: String): String =
    let importSuffix = "." + simpleName + ";"
    let suffixIndex = native_java_index_of(source, importSuffix, 0)
    if suffixIndex >= 0
    then
        let importStart = native_java_last_index_of(source, "import ", 0, -1, suffixIndex)
        let semicolon = native_java_index_of(source, ";", suffixIndex)
        if importStart >= 0 & semicolon >= 0
        then source[importStart + "import ".size().value, semicolon].trim()
        else native_java_package_relative_name(packageName, simpleName)
    else native_java_package_relative_name(packageName, simpleName)

private fun native_java_package_relative_name(packageName: String, simpleName: String): String =
    if packageName.is_empty()
    then simpleName
    else packageName + "." + simpleName

private fun native_java_token_after(source: String, marker: String): String =
    let start = native_java_index_of(source, marker, 0)
    if start < 0
    then ""
    else native_java_token_from(source, start + marker.size().value, "")

private fun native_java_token_from(source: String, idx: int, acc: String): String =
    if idx >= source.size().value
    then acc
    else match source[idx] with
        case None -> acc
        case Some { char } ->
            if native_java_token_char(char)
            then native_java_token_from(source, idx + 1, acc + char)
            else acc

private fun native_java_token_char(char: String): bool =
    "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789.$" ? char

private fun native_java_between(source: String, prefix: String, suffix: String): String =
    let start = native_java_index_of(source, prefix, 0)
    if start < 0
    then ""
    else
        let bodyStart = start + prefix.size().value
        let end = native_java_index_of(source, suffix, bodyStart)
        if end < 0
        then ""
        else source[bodyStart, end]

private fun native_java_index_of(source: String, needle: String, idx: int): int =
    if idx > source.size().value - needle.size().value
    then -1
    else if native_java_has_prefix_at(source, needle, idx, 0)
    then idx
    else native_java_index_of(source, needle, idx + 1)

private fun native_java_last_index_of(source: String, needle: String, idx: int, found: int, before: int): int =
    if idx >= before
    then found
    else if native_java_has_prefix_at(source, needle, idx, 0)
    then native_java_last_index_of(source, needle, idx + 1, idx, before)
    else native_java_last_index_of(source, needle, idx + 1, found, before)

private fun native_java_has_prefix_at(source: String, needle: String, sourceIdx: int, needleIdx: int): bool =
    match needle[needleIdx] with
    case None -> true
    case Some { expected } ->
        match source[sourceIdx + needleIdx] with
        case None -> false
        case Some { actual } ->
            if actual == expected
            then native_java_has_prefix_at(source, needle, sourceIdx, needleIdx + 1)
            else false

private fun write_compile_generate_linked_output(linkedOutput: Option[String], program: CompiledProgram): Effect[Result[String]] =
    match linkedOutput with
    case None -> pure(Success { "linked output skipped" })
    case Some { rawLinkedOutput } ->
        let linkedOutputPath = from_string(rawLinkedOutput)
        validate_output_directory(linkedOutputPath, rawLinkedOutput).flat_map(outputResult =>
            match outputResult with
            case Error e -> pure(e)
            case Success _ -> write_compilation_output(linkedOutputPath, program)
        )

private fun compile_generate_tests(
    options: CompileGenerateOptions,
    configuration: CompileConfiguration,
    mainProgram: CompiledProgram
): Effect[Result[Option[CompiledProgram]]] =
    if !option_present(options.test_input) & !option_present(options.test_output)
    then pure(Success { None {} })
    else if !option_present(options.test_input) | !option_present(options.test_output)
    then pure(Error { message: "`compile-generate` requires both `--test-input` and `--test-output` when either is provided." })
    else
        let rawTestInput = option_or(options.test_input, "")
        let rawTestOutput = option_or(options.test_output, "")
        let testInputPath = from_string(rawTestInput)
        let testOutputPath = from_string(rawTestOutput)
        validate_output_directory(testOutputPath, rawTestOutput).flat_map(outputResult =>
            match outputResult with
            case Error e -> pure(e)
            case Success _ ->
                compile_source_directory(testInputPath, rawTestInput, configuration.with(libraries: merge_libraries(configuration.libraries, mainProgram))).flat_map(compilation =>
                    match compilation with
                    case Right { errors } -> pure(Error { message: compiler_errors_text(errors) })
                    case Left { program } ->
                        let testProgram = test_generation_program(options.output_type, mainProgram, program)
                        pure(Success { Some { testProgram } })
                )
        )

private fun write_compile_generate_test_output(options: CompileGenerateOptions, testProgram: Option[CompiledProgram]): Effect[Result[String]] =
    match testProgram with
    case None -> pure(Success { "test output skipped" })
    case Some { program } ->
        match options.test_output with
        case None -> pure(Error { message: "`compile-generate` requires both `--test-input` and `--test-output` when either is provided." })
        case Some { rawTestOutput } -> write_generated_program(from_string(rawTestOutput), generate(program, options.output_type))

private fun write_compile_generate_outputs(options: CompileGenerateOptions, mainProgram: CompiledProgram, testProgram: Option[CompiledProgram]): Effect[Result[String]] =
    match testProgram with
    case Some { test } -> {
        match options.test_output with
        case Some { rawTestOutput } when rawTestOutput == options.output ->
            write_generated_program(
                from_string(options.output),
                merge_generated_programs(generate(mainProgram, options.output_type), generate(test, options.output_type))
            )
        case _ ->
            write_generated_program(from_string(options.output), generate(mainProgram, options.output_type)).flat_map(writeResult =>
                match writeResult with
                case Error e -> pure(e)
                case Success _ -> write_compile_generate_test_output(options, testProgram)
            )
    }
    case None -> write_generated_program(from_string(options.output), generate(mainProgram, options.output_type))

private fun merge_generated_programs(first: GeneratedProgram, second: GeneratedProgram): GeneratedProgram =
    GeneratedProgram { modules: first.modules + second.modules }

private fun merge_libraries(libraries: Set[CompiledModule], program: CompiledProgram): Set[CompiledModule] =
    add_modules_to_libraries(libraries, program.modules)

private fun add_modules_to_libraries(libraries: Set[CompiledModule], modules: List[CompiledModule]): Set[CompiledModule] =
    match modules[0] with
    case None -> libraries
    case Some { module } -> add_modules_to_libraries(libraries + module, modules[1:])

private fun test_generation_program(outputType: String, mainProgram: CompiledProgram, testProgram: CompiledProgram): CompiledProgram =
    match outputType with
    case "javascript" | "python" -> merge_programs(mainProgram, testProgram)
    case "java" -> testProgram
    case _ -> testProgram

private fun merge_programs(first: CompiledProgram, second: CompiledProgram): CompiledProgram =
    CompiledProgram {
        modules: first.modules + second.modules,
        objectOrientedModules: first.objectOrientedModules + second.objectOrientedModules,
        nativeProviders: merge_native_providers(first.nativeProviders, second.nativeProviders),
        nativeProviderCatalog: merge_native_provider_catalog(first.nativeProviderCatalog, second.nativeProviderCatalog)
    }

private fun merge_native_providers(first: NativeProviderManifest, second: NativeProviderManifest): NativeProviderManifest =
    if first.providers.is_empty()
    then second
    else
        first

private fun merge_native_provider_catalog(first: NativeProviderCatalog, second: NativeProviderCatalog): NativeProviderCatalog =
    NativeProviderCatalog {
        declarations: first.declarations + second.declarations,
        bindings: first.bindings + second.bindings
    }

private fun read_source_modules(root: Path, raw_root: String): Effect[Result[List[RawModule]]] =
    list_source_files(root).flat_map(files_result =>
        match files_result with
        case Error e -> pure(e)
        case Success { files } ->
            if files.is_empty()
            then pure(Error { message: "No Capybara source files found under: " + raw_root })
            else read_source_modules(root, files)
    )

private fun read_source_modules(root: Path, files: List[Path]): Effect[Result[List[RawModule]]] =
    match files[0] with
    case None -> pure(Success { [] })
    case Some { file } ->
        read_text(file).flat_map(read_result =>
            match read_result with
            case Error e -> pure(e)
            case Success { source } ->
                match build_raw_module(cli_relative_to(root, file), source) with
                case Error e -> pure(e)
                case Success { raw_module } ->
                    read_source_modules(root, files[1:]).map(rest_result =>
                        match rest_result with
                        case Error e -> e
                        case Success { rest } -> Success { [raw_module] + rest }
                    )
        )

private fun build_raw_module(relative_path: Path, source: String): Result[RawModule] =
    match last_segment(relative_path.normalize().segments) with
    case None -> Error { message: "Unable to infer module name for source path: " + cli_path_to_string(relative_path) }
    case Some { file_name } ->
        if file_name.end_with(functional_extension())
        then Success { functional_raw_module(strip_source_extension(file_name), module_path(relative_path), source) }
        else if file_name.end_with(object_oriented_extension())
        then Success { object_oriented_raw_module(strip_source_extension(file_name), module_path(relative_path), source) }
        else Error { message: "Unsupported source file extension: " + file_name }

private fun list_source_files(path: Path): Effect[Result[List[Path]]] =
    list_entries(path).flat_map(entries_result =>
        match entries_result with
        case Error e -> pure(e)
        case Success { entries } -> list_source_files_from_entries(entries)
    )

private fun list_source_files_from_entries(entries: List[Path]): Effect[Result[List[Path]]] =
    match entries[0] with
    case None -> pure(Success { [] })
    case Some { entry } ->
        is_file(entry).flat_map(file =>
            if file
            then list_source_files_from_entries(entries[1:]).map(rest_result =>
                match rest_result with
                case Error e -> e
                case Success { rest } ->
                    if source_file(entry)
                    then Success { [entry] + rest }
                    else Success { rest }
            )
            else is_directory(entry).flat_map(directory =>
                if directory
                then list_source_files(entry).flat_map(children_result =>
                    match children_result with
                    case Error e -> pure(e)
                    case Success { children } ->
                        list_source_files_from_entries(entries[1:]).map(rest_result =>
                            match rest_result with
                            case Error e -> e
                            case Success { rest } -> Success { children + rest }
                        )
                )
                else list_source_files_from_entries(entries[1:])
            )
        )

private fun source_file(path: Path): bool =
    match last_segment(path.normalize().segments) with
    case None -> false
    case Some { file_name } ->
        file_name.end_with(functional_extension()) | file_name.end_with(object_oriented_extension())

private fun strip_source_extension(file_name: String): String =
    if file_name.end_with(functional_extension())
    then file_name[0, file_name.size().value - functional_extension().size().value]
    else if file_name.end_with(object_oriented_extension())
    then file_name[0, file_name.size().value - object_oriented_extension().size().value]
    else file_name

private fun functional_extension(): String = ".cfun"

private fun object_oriented_extension(): String = ".coo"

private fun module_path(relative_path: Path): String =
    match relative_path.parent() with
    case None -> ""
    case Some { parent } -> cli_path_segments_to_string(parent.normalize().segments)

private fun last_segment(segments: List[String]): Option[String] =
    match segments[0] with
    case None -> None {}
    case Some { segment } ->
        match segments[1] with
        case None -> Some { segment }
        case Some _ -> last_segment(segments[1:])

private fun relative_to(base: Path, path: Path): Path =
    cli_relative_to(base, path)

private fun cli_relative_to(base: Path, path: Path): Path =
    from_string(cli_path_segments_to_string(cli_drop_prefix_segments(base.normalize().segments, path.normalize().segments)))

private fun cli_drop_prefix_segments(prefix: List[String], segments: List[String]): List[String] =
    if cli_segments_have_prefix(prefix, segments)
    then cli_drop_exact_prefix_segments(prefix, segments)
    else
        match prefix[1] with
        case None -> segments
        case Some _ -> cli_drop_prefix_segments(prefix[1:], segments)

private fun cli_segments_have_prefix(prefix: List[String], segments: List[String]): bool =
    if prefix.is_empty()
    then true
    else if segments.is_empty()
    then false
    else prefix[0] == segments[0] & cli_segments_have_prefix(prefix[1:], segments[1:])

private fun cli_drop_exact_prefix_segments(prefix: List[String], segments: List[String]): List[String] =
    if prefix.is_empty()
    then segments
    else if segments.is_empty()
    then []
    else cli_drop_exact_prefix_segments(prefix[1:], segments[1:])

private fun cli_path_segments_to_string(segments: List[String]): String =
    @Recursive
    fun cli_path_segments_to_string(segments: List[String], acc: String): String =
        match segments[0] with
        case None -> acc
        case Some { segment } ->
            let next = if acc.is_empty() then segment else acc + "/" + segment
            cli_path_segments_to_string(segments[1:], next)
    ---
    cli_path_segments_to_string(segments, "")

private fun cli_path_to_string(path: Path): String =
    let normalized = path.normalize()
    let body = cli_path_segments_to_string(normalized.segments)
    match normalized.root with
    case RELATIVE -> if body.is_empty() then "." else body
    case ABSOLUTE -> "/" + body
    case HOME -> if body.is_empty() then "~" else "~/" + body

private fun write_compilation_output(output_dir: Path, program: CompiledProgram): Effect[Result[String]] =
    create_directories(output_dir).flat_map(directory_result =>
        match directory_result with
        case Error e -> pure(e)
        case Success _ ->
            let program_data: data = program
            write_linked_json_file(output_dir / "program.json", program_data).flat_map(program_result =>
                match program_result with
                case Error e -> pure(e)
                case Success _ -> write_linked_modules(output_dir, program.modules)
            )
    )

private fun write_linked_modules(output_dir: Path, modules: List[CompiledModule]): Effect[Result[String]] =
    match modules[0] with
    case None -> pure(Success { "linked modules written" })
    case Some { module } ->
        write_linked_module(output_dir, module).flat_map(module_result =>
            match module_result with
            case Error e -> pure(e)
            case Success _ -> write_linked_modules(output_dir, modules[1:])
        )

private fun write_linked_module(output_dir: Path, module: CompiledModule): Effect[Result[String]] =
    let module_file = linked_module_file(output_dir, module)
    let module_data: data = module
    create_parent_directories(module_file).flat_map(parent_result =>
        match parent_result with
        case Error e -> pure(e)
        case Success _ -> write_linked_json_file(module_file, module_data)
    )

private fun linked_module_file(output_dir: Path, module: CompiledModule): Path =
    let base =
        if module.path.is_empty()
        then output_dir
        else output_dir / from_string(module.path)
    base / (module.name + ".json")

private fun create_parent_directories(path: Path): Effect[Result[Path]] =
    match path.parent() with
    case None -> pure(Success { path })
    case Some { parent } -> create_directories(parent)

private fun write_json_file(path: Path, value: data): Effect[Result[String]] =
    match to_json(value) with
    case Error { message } -> pure(Error { message: "Unable to serialize linked JSON for `" + cli_path_to_string(path) + "`: " + message })
    case Success { json } -> write_text(path, serialize(json))

private fun write_linked_json_file(path: Path, value: data): Effect[Result[String]] =
    match to_typed_json(value) with
    case Error { message } -> pure(Error { message: "Unable to serialize linked JSON for `" + cli_path_to_string(path) + "`: " + message })
    case Success { json } -> write_text(path, linked_serialize_typed_json(json))

private fun linked_serialize_typed_json(json: TypedJson): String =
    match json with
    case TypedJsonData { name, pkg, fields } ->
        "{"
        + linked_json_entry("$capybaraTypedJson", linked_json_string("data")) + ","
        + linked_json_entry("name", linked_json_string(name)) + ","
        + linked_json_entry("pkg", linked_serialize_typed_package(pkg)) + ","
        + linked_json_entry("fields", linked_serialize_typed_fields(fields))
        + "}"
    case TypedJsonObject { value } ->
        "{"
        + linked_json_entry("$capybaraTypedJson", linked_json_string("object")) + ","
        + linked_json_entry("value", linked_serialize_typed_fields(value))
        + "}"
    case TypedJsonArray { kind, value } ->
        "{"
        + linked_json_entry("$capybaraTypedJson", linked_json_string("array")) + ","
        + linked_json_entry("kind", linked_json_string(kind)) + ","
        + linked_json_entry("value", linked_serialize_typed_list(value))
        + "}"
    case TypedJsonString { value } -> linked_serialize_typed_value("String", linked_json_string(value))
    case TypedJsonByte { value } -> linked_serialize_typed_value("byte", linked_json_long(value))
    case TypedJsonInt { value } -> linked_serialize_typed_value("int", linked_json_long(value))
    case TypedJsonLong { value } -> linked_serialize_typed_value("long", linked_json_long(value))
    case TypedJsonFloat { value } -> linked_serialize_typed_value("float", linked_json_double(value))
    case TypedJsonDouble { value } -> linked_serialize_typed_value("double", linked_json_double(value))
    case TypedJsonBool { value } -> linked_serialize_typed_value("bool", if value then "true" else "false")
    case TypedJsonNull -> linked_serialize_typed_value("null", "null")

private fun linked_serialize_typed_package(pkg: TypedJsonPackage): String =
    "{"
    + linked_json_entry("name", linked_json_string(pkg.name)) + ","
    + linked_json_entry("path", linked_json_string(pkg.path))
    + "}"

private fun linked_serialize_typed_fields(fields: Dict[TypedJson]): String =
    "{"
    + (fields |> "", (acc, key, value) =>
        linked_join_json(acc, linked_json_entry(key, linked_serialize_typed_json(value))))
    + "}"

private fun linked_serialize_typed_list(values: List[TypedJson]): String =
    "["
    + (values |> "", (acc, value) => linked_join_json(acc, linked_serialize_typed_json(value)))
    + "]"

private fun linked_serialize_typed_value(kind: String, value: String): String =
    "{"
    + linked_json_entry("$capybaraTypedJson", linked_json_string("value")) + ","
    + linked_json_entry("kind", linked_json_string(kind)) + ","
    + linked_json_entry("value", value)
    + "}"

private fun linked_json_entry(key: String, value: String): String =
    linked_json_string(key) + ":" + value

private fun linked_json_string(value: String): String =
    stringify(JsonString { value })

private fun linked_json_long(value: long): String =
    stringify(JsonNumberLong { value })

private fun linked_json_double(value: double): String =
    stringify(JsonNumberDouble { value })

private fun linked_join_json(acc: String, value: String): String =
    if acc.is_empty() then value else acc + "," + value

private fun read_linked_libraries(libs: String): Effect[Result[Set[CompiledModule]]] =
    read_linked_libraries(linked_library_paths(libs))

private fun linked_library_paths(libs: String): List[String] =
    @Recursive
    fun split(value: String, idx: int, current: String, acc: List[String]): List[String] =
        if idx >= value.size().value
        then
            let item = current.trim()
            if item.is_empty() then acc else acc + item
        else match value[idx] with
            case Some { "," } ->
                let item = current.trim()
                split(value, idx + 1, "", if item.is_empty() then acc else acc + item)
            case Some { char } -> split(value, idx + 1, current + char, acc)
            case None ->
                let item = current.trim()
                if item.is_empty() then acc else acc + item
    ---
    split(libs, 0, "", [])

private fun read_linked_libraries(libraries: List[String]): Effect[Result[Set[CompiledModule]]] =
    match libraries[0] with
    case None -> pure(Success { {} })
    case Some { library } ->
        read_linked_program(from_string(library), false).flat_map(program_result =>
            match program_result with
            case Error e -> pure(e)
            case Success { program } ->
                read_linked_libraries(libraries[1:]).map(rest_result =>
                    match rest_result with
                    case Error e -> e
                    case Success { rest } -> Success { add_modules_to_libraries(rest, program.modules) }
                )
        )

private fun read_linked_program(inputDir: Path, requireModules: bool): Effect[Result[CompiledProgram]] =
    let program_file = inputDir / "program.json"
    is_file(program_file).flat_map(has_program =>
        if has_program
        then read_linked_program_file(program_file).map(program_result =>
            match program_result with
            case Error e -> e
            case Success { program } ->
                if requireModules & program.modules.is_empty()
                then Error { message: "Missing linked module files in directory: " + cli_path_to_string(inputDir) }
                else Success { program }
        )
        else read_linked_program_from_module_files(inputDir, requireModules)
    )

private fun read_linked_program_file(file: Path): Effect[Result[CompiledProgram]] =
    read_text(file).map(read_result =>
        match read_result with
        case Error e -> e
        case Success { content } ->
            match deserialize_typed(content) with
            case Error { message } -> Error { message: "Unable to deserialize linked JSON `" + cli_path_to_string(file) + "`: " + message }
            case Success { json } -> linked_decode_program(json)
    )

private fun read_linked_module_file(file: Path): Effect[Result[CompiledModule]] =
    read_text(file).map(read_result =>
        match read_result with
        case Error e -> e
        case Success { content } ->
            match deserialize_typed(content) with
            case Error { message } -> Error { message: "Unable to deserialize linked JSON `" + cli_path_to_string(file) + "`: " + message }
            case Success { json } -> linked_decode_module(json)
    )

private fun read_linked_program_from_module_files(inputDir: Path, requireModules: bool): Effect[Result[CompiledProgram]] =
    cli_list_regular_files(inputDir).flat_map(files_result =>
        match files_result with
        case Error e -> pure(e)
        case Success { files } ->
            read_linked_module_files(linked_module_json_files(files)).map(modules_result =>
                match modules_result with
                case Error e -> e
                case Success { modules } ->
                    if requireModules & modules.is_empty()
                    then Error { message: "Missing linked module files in directory: " + cli_path_to_string(inputDir) }
                    else Success { CompiledProgram {
                        modules: modules,
                        objectOrientedModules: [],
                        nativeProviders: empty_native_provider_manifest(),
                        nativeProviderCatalog: empty_native_provider_catalog()
                    }}
            )
    )

private fun linked_module_json_files(files: List[Path]): List[Path] =
    match files[0] with
    case None -> []
    case Some { file } ->
        match last_segment(file.normalize().segments) with
        case Some { name } ->
            if name.end_with(".json") & name != "build-info.json" & name != "program.json"
            then [file] + linked_module_json_files(files[1:])
            else linked_module_json_files(files[1:])
        case None -> linked_module_json_files(files[1:])

private fun read_linked_module_files(files: List[Path]): Effect[Result[List[CompiledModule]]] =
    match files[0] with
    case None -> pure(Success { [] })
    case Some { file } ->
        read_linked_module_file(file).flat_map(module_result =>
            match module_result with
            case Error e -> pure(e)
            case Success { module } ->
                read_linked_module_files(files[1:]).map(rest_result =>
                    match rest_result with
                    case Error e -> e
                    case Success { rest } -> Success { [module] + rest }
                )
        )

private fun linked_expect_data(node: any, expected: String): Result[any] =
    match node with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData typed_node ->
            if typed_node.name == expected
            then Success { typed_node }
            else Error { message: "Expected typed JSON node `" + expected + "`, got `" + typed_node.name + "`" }
        case _ -> Error { message: "Expected typed JSON node `" + expected + "`" }
    }
    case _ -> Error { message: "Expected typed JSON node `" + expected + "`" }

private fun linked_field(node: any, name: String): Result[any] =
    match node with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData typed_node -> {
            match typed_node.fields.get(name) with
            case Some { value } -> Success { value }
            case None -> Error { message: "Expected typed JSON field `" + typed_node.name + "." + name + "`" }
        }
        case _ -> Error { message: "Expected typed JSON field `" + name + "`" }
    }
    case _ -> Error { message: "Expected typed JSON field `" + name + "`" }

private fun linked_string_value(value: any): Result[String] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonString { text } -> Success { text }
        case _ -> Error { message: "Expected typed JSON string" }
    }
    case _ -> Error { message: "Expected typed JSON string" }

private fun linked_bool_value(value: any): Result[bool] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonBool { bool_value } -> Success { bool_value }
        case _ -> Error { message: "Expected typed JSON bool" }
    }
    case _ -> Error { message: "Expected typed JSON bool" }

private fun linked_int_value(value: any): Result[int] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonInt { int_value } -> Success { int_value }
        case TypedJsonByte { byte_value } -> Success { byte_value }
        case _ -> Error { message: "Expected typed JSON int" }
    }
    case _ -> Error { message: "Expected typed JSON int" }

private fun linked_long_value(value: any): Result[long] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonLong { long_value } -> Success { long_value }
        case TypedJsonInt { int_value } -> Success { int_value }
        case TypedJsonByte { byte_value } -> Success { byte_value + 0L }
        case _ -> Error { message: "Expected typed JSON long" }
    }
    case _ -> Error { message: "Expected typed JSON long" }

private fun linked_float_value(value: any): Result[float] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonFloat { float_value } -> Success { float_value }
        case _ -> Error { message: "Expected typed JSON float" }
    }
    case _ -> Error { message: "Expected typed JSON float" }

private fun linked_double_value(value: any): Result[double] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonDouble { double_value } -> Success { double_value }
        case TypedJsonFloat { float_value } -> Success { float_value }
        case TypedJsonLong { long_value } -> Success { long_value }
        case TypedJsonInt { int_value } -> Success { int_value }
        case TypedJsonByte { byte_value } -> Success { byte_value + 0L }
        case _ -> Error { message: "Expected typed JSON double" }
    }
    case _ -> Error { message: "Expected typed JSON double" }

private fun linked_string_field(node: any, name: String): Result[String] =
    let value <- linked_field(node, name)
    linked_string_value(value)

private fun linked_bool_field(node: any, name: String): Result[bool] =
    let value <- linked_field(node, name)
    linked_bool_value(value)

