from /capy/collection/List import { * }
from /capy/collection/Set import { Set }
from /capy/io/Console import { println, println_error }
from /capy/io/IO import { create_directories, exists, is_directory, is_file, list_entries, read_text, write_text }
from /capy/io/Path import { Path, PathRoot, RELATIVE, ABSOLUTE, HOME, from_string }
from /capy/lang/Effect import { * }
from /capy/lang/Either import { * }
from /capy/lang/Option import { * }
from /capy/lang/Program import { DEFAULT_FAILED_EXIT_CODE }
from /capy/lang/Result import { * }
from /capy/lang/String import { * }
from /capy/meta_prog/Recursive import { Recursive }
from /capy/serialization/Json import { * }
from /dev/capylang/compiler/CapybaraCompiler import { compile }
from /dev/capylang/compiler/CompiledProgram import { CompiledModule, CompiledProgram, CompilerError, NativeProviderManifest, empty_native_provider_catalog, empty_native_provider_manifest }
from /dev/capylang/compiler/OutputType import { OutputType, JAVA, JAVASCRIPT, PYTHON }
from /dev/capylang/compiler/parser/RawModule import { FUNCTIONAL, OBJECT_ORIENTED, RawModule, SourceKind }
from /dev/capylang/generator/GeneratedProgram import { GeneratedModule, GeneratedProgram }
from /dev/capylang/generator/Generator import { generate }

const COMPILER_VERSION = "0.4.0-SNAPSHOT"

fun main(args: List[String]): Effect[/capy/lang/Program] =
    match args[0] with
    case None -> usageError("No command passed!")
    case Some { "-h" } | Some { "--help" } -> printHelp()
    case Some { "-v" } | Some { "--version" } -> printVersion()
    case Some { "compile" } -> execute_compile(args[1:])
    case Some { "generate" } -> execute_generate(args[1:])
    case Some { "compile-generate" } -> execute_compile_generate(args[1:])
    case Some { "package" } -> execute_package(args[1:])
    case Some { command } -> usageError("Unknown command `" + command + "`.")

fun execute_compile(args: List[String]): Effect[/capy/lang/Program] =
    match parseCompileOptions(args) with
    case UsageError { message } -> usageError(message)
    case ParsedArgs { options } -> run_compile(options)

fun execute_generate(args: List[String]): Effect[/capy/lang/Program] =
    match parseGenerateOptions(args) with
    case UsageError { message } -> usageError(message)
    case ParsedArgs { options } -> run_generate(options)

fun execute_compile_generate(args: List[String]): Effect[/capy/lang/Program] =
    match parseCompileGenerateOptions(args) with
    case UsageError { message } -> usageError(message)
    case ParsedArgs { options } -> runCompileGenerate(options)

fun execute_package(args: List[String]): Effect[/capy/lang/Program] =
    match parsePackageOptions(args) with
    case UsageError { message } -> usageError(message)
    case ParsedArgs { options } -> runPackage(options)

data CompileOptions {
    input: String,
    output: String,
    libs: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    log_level: LogLevel
}

data GenerateOptions {
    output_type: OutputType,
    input: String,
    output: String,
    include_java_lib_resources: bool,
    log_level: LogLevel
}

data CompileGenerateOptions {
    output_type: OutputType,
    input: String,
    output: String,
    linked_output: Option[String],
    test_input: Option[String],
    test_output: Option[String],
    libs: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    include_java_lib_resources: bool,
    log_level: LogLevel
}

data PackageOptions {
    compiled_input: Option[String],
    input: Option[String],
    module: String,
    capy_overrides: List[CapyOverride],
    log_level: LogLevel
}

data CapyOverride {
    field: String,
    value: String
}

enum LogLevel {
    DEBUG,
    INFO,
    WARN,
    ERROR
}

union CliArgs[T] = ParsedArgs[T] | UsageError
data ParsedArgs[T] { value: T }
data UsageError { message: String }

data NamedOptions {
    input: Option[String],
    output: Option[String],
    libs: Option[String],
    linked_output: Option[String],
    test_input: Option[String],
    test_output: Option[String],
    native_wiring: Option[String],
    compile_tests: bool,
    skip_java_lib: bool,
    log_level: LogLevel
}

data NamedOptionRules {
    allow_libs: bool,
    allow_skip_java_lib: bool,
    allow_linked_output: bool,
    allow_test_outputs: bool
}

data PartialPackageOptions {
    compiled_input: Option[String],
    input: Option[String],
    module: Option[String],
    capy_overrides: List[CapyOverride],
    log_level: LogLevel
}

fun CliArgs[T].`|`(map: T => CliArgs[Y]): CliArgs[Y] =
    match this with
    case UsageError e -> e
    case ParsedArgs { value } -> map(value)

private fun parseCompileOptions(args: List[String]): CliArgs[CompileOptions] =
    match parseNamedOptions(args, 0, emptyNamedOptions(), NamedOptionRules {
        allow_libs: true,
        allow_skip_java_lib: false,
        allow_linked_output: false,
        allow_test_outputs: false
    }) with
    case UsageError e -> e
    case ParsedArgs { options } -> compileOptionsFromNamed(options)

private fun parseGenerateOptions(args: List[String]): CliArgs[GenerateOptions] =
    match args[0] with
    case None -> UsageError { message: "Missing output type for `generate`." }
    case Some { output_type_name } ->
        match parseOutputType(output_type_name) with
        case UsageError e -> e
        case ParsedArgs { output_type } ->
            match parseNamedOptions(args[1:], 0, emptyNamedOptions(), NamedOptionRules {
                allow_libs: false,
                allow_skip_java_lib: true,
                allow_linked_output: false,
                allow_test_outputs: false
            }) with
            case UsageError e -> e
            case ParsedArgs { options } -> generateOptionsFromNamed(output_type, options)

private fun parseCompileGenerateOptions(args: List[String]): CliArgs[CompileGenerateOptions] =
    match args[0] with
    case None -> UsageError { message: "Missing output type for `compile-generate`." }
    case Some { output_type_name } ->
        match parseOutputType(output_type_name) with
        case UsageError e -> e
        case ParsedArgs { output_type } ->
            match parseNamedOptions(args[1:], 0, emptyNamedOptions(), NamedOptionRules {
                allow_libs: true,
                allow_skip_java_lib: true,
                allow_linked_output: true,
                allow_test_outputs: true
            }) with
            case UsageError e -> e
            case ParsedArgs { options } ->
                match validateTestOutputs(options) with
                case UsageError e -> e
                case ParsedArgs { validated_options } -> compileGenerateOptionsFromNamed(output_type, validated_options)

private fun parsePackageOptions(args: List[String]): CliArgs[PackageOptions] =
    match parsePackageOptions(args, 0, PartialPackageOptions {
        compiled_input: None {},
        input: None {},
        module: None {},
        capy_overrides: [],
        log_level: INFO
    }) with
    case UsageError e -> e
    case ParsedArgs { options } ->
        match validatePackageInputs(options) with
        case UsageError e -> e
        case ParsedArgs { validated_options } -> packageOptionsFromPartial(validated_options)

private fun compileOptionsFromNamed(options: NamedOptions): CliArgs[CompileOptions] =
    match requiredOption(options.input, "input", "compile") with
    case UsageError e -> e
    case ParsedArgs { input } ->
        match requiredOption(options.output, "output", "compile") with
        case UsageError e -> e
        case ParsedArgs { output } -> ParsedArgs { CompileOptions {
            input: input,
            output: output,
            libs: options.libs,
            native_wiring: options.native_wiring,
            compile_tests: options.compile_tests,
            log_level: options.log_level
        }}

private fun generateOptionsFromNamed(output_type: OutputType, options: NamedOptions): CliArgs[GenerateOptions] =
    match requiredOption(options.output, "output", "generate") with
    case UsageError e -> e
    case ParsedArgs { output } -> ParsedArgs { GenerateOptions {
        output_type: output_type,
        input: optionOr(options.input, "."),
        output: output,
        include_java_lib_resources: !options.skip_java_lib,
        log_level: options.log_level
    }}

private fun compileGenerateOptionsFromNamed(output_type: OutputType, options: NamedOptions): CliArgs[CompileGenerateOptions] =
    match requiredOption(options.input, "input", "compile-generate") with
    case UsageError e -> e
    case ParsedArgs { input } ->
        match requiredOption(options.output, "output", "compile-generate") with
        case UsageError e -> e
        case ParsedArgs { output } -> ParsedArgs { CompileGenerateOptions {
            output_type: output_type,
            input: input,
            output: output,
            linked_output: options.linked_output,
            test_input: options.test_input,
            test_output: options.test_output,
            libs: options.libs,
            native_wiring: options.native_wiring,
            compile_tests: options.compile_tests,
            include_java_lib_resources: !options.skip_java_lib,
            log_level: options.log_level
        }}

private fun packageOptionsFromPartial(options: PartialPackageOptions): CliArgs[PackageOptions] =
    match requiredOption(options.module, "module", "package") with
    case UsageError e -> e
    case ParsedArgs { module } -> ParsedArgs { PackageOptions {
        compiled_input: options.compiled_input,
        input: options.input,
        module: module,
        capy_overrides: options.capy_overrides,
        log_level: options.log_level
    }}

private fun parseNamedOptions(args: List[String], idx: int, options: NamedOptions, rules: NamedOptionRules): CliArgs[NamedOptions] =
    match args[idx] with
    case None -> ParsedArgs { options }
    case Some { "--log" } ->
        nextValue(args, idx, "--log")
        | value => parseLogLevel(value)
        | log_level => parseNamedOptions(args, idx + 2, options.with(log_level: log_level), rules)
    case Some { "-i" } | Some { "--input" } ->
        nextValue(args, idx, "input")
        | value => parseNamedOptions(args, idx + 2, options.with(input: Some { value }), rules)
    case Some { "-o" } | Some { "--output" } ->
        nextValue(args, idx, "output")
        | value => parseNamedOptions(args, idx + 2, options.with(output: Some { value }), rules)
    case Some { "--linked-output" } ->
        if !rules.allow_linked_output
        then UsageError { message: "Option `--linked-output` is supported only for `compile-generate`." }
        else nextValue(args, idx, "--linked-output")
            | value => parseNamedOptions(args, idx + 2, options.with(linked_output: Some { value }), rules)
    case Some { "--test-input" } ->
        if !rules.allow_test_outputs
        then UsageError { message: "Option `--test-input` is supported only for `compile-generate`." }
        else nextValue(args, idx, "--test-input")
            | value => parseNamedOptions(args, idx + 2, options.with(test_input: Some { value }), rules)
    case Some { "--test-output" } ->
        if !rules.allow_test_outputs
        then UsageError { message: "Option `--test-output` is supported only for `compile-generate`." }
        else nextValue(args, idx, "--test-output")
            | value => parseNamedOptions(args, idx + 2, options.with(test_output: Some { value }), rules)
    case Some { "-l" } | Some { "--libs" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--libs` is supported only for `compile` and `compile-generate`." }
        else nextValue(args, idx, "--libs")
            | value => parseNamedOptions(args, idx + 2, options.with(libs: Some { value }), rules)
    case Some { "--native-wiring" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--native-wiring` is supported only for `compile` and `compile-generate`." }
        else nextValue(args, idx, "--native-wiring")
            | value => parseNamedOptions(args, idx + 2, options.with(native_wiring: Some { value }), rules)
    case Some { "--compile-tests" } ->
        if !rules.allow_libs
        then UsageError { message: "Option `--compile-tests` is supported only for `compile` and `compile-generate`." }
        else parseNamedOptions(args, idx + 1, options.with(compile_tests: true), rules)
    case Some { "--skip-java-lib" } ->
        if !rules.allow_skip_java_lib
        then UsageError { message: "Option `--skip-java-lib` is supported only for `generate` and `compile-generate`." }
        else parseNamedOptions(args, idx + 1, options.with(skip_java_lib: true), rules)
    case Some { arg } -> UsageError { message: "Unknown option `" + arg + "`." }

private fun parsePackageOptions(args: List[String], idx: int, options: PartialPackageOptions): CliArgs[PartialPackageOptions] =
    match args[idx] with
    case None -> ParsedArgs { options }
    case Some { "--log" } ->
        nextValue(args, idx, "--log")
        | value => parseLogLevel(value)
        | log_level => parsePackageOptions(args, idx + 2, options.with(log_level: log_level))
    case Some { "-ci" } | Some { "--compiled-input" } ->
        nextValue(args, idx, "--compiled-input")
        | value => parsePackageOptions(args, idx + 2, options.with(compiled_input: Some { value }))
    case Some { "-i" } | Some { "--input" } ->
        nextValue(args, idx, "--input")
        | value => parsePackageOptions(args, idx + 2, options.with(input: Some { value }))
    case Some { "-m" } | Some { "--module" } ->
        nextValue(args, idx, "--module")
        | value => parsePackageOptions(args, idx + 2, options.with(module: Some { value }))
    case Some { arg } when arg.starts_with("--capy.") ->
        nextValue(args, idx, arg)
        | value => parsePackageOptions(args, idx + 2, options.with(capy_overrides: options.capy_overrides + CapyOverride {
            field: capyOverrideField(arg),
            value: value
        }))
    case Some { arg } -> UsageError { message: "Unknown option `" + arg + "`." }

private fun emptyNamedOptions(): NamedOptions =
    NamedOptions {
        input: None {},
        output: None {},
        libs: None {},
        linked_output: None {},
        test_input: None {},
        test_output: None {},
        native_wiring: None {},
        compile_tests: false,
        skip_java_lib: false,
        log_level: INFO
    }

private fun nextValue(args: List[String], idx: int, option: String): CliArgs[String] =
    match args[idx + 1] with
    case Some { value } -> ParsedArgs { value }
    case None -> UsageError { message: "Missing value for `" + option + "`." }

private fun requiredOption(option: Option[String], name: String, command: String): CliArgs[String] =
    match option with
    case Some { value } -> ParsedArgs { value }
    case None -> UsageError { message: "Missing required option `--" + name + "` for `" + command + "`." }

private fun optionOr(option: Option[String], default_value: String): String =
    match option with
    case Some { value } -> value
    case None -> default_value

private fun validateTestOutputs(options: NamedOptions): CliArgs[NamedOptions] =
    match options.test_input with
    case Some { _ } ->
        match options.test_output with
        case Some { _ } -> ParsedArgs { options }
        case None -> UsageError { message: "`compile-generate` requires both `--test-input` and `--test-output` when either is provided." }
    case None ->
        match options.test_output with
        case Some { _ } -> UsageError { message: "`compile-generate` requires both `--test-input` and `--test-output` when either is provided." }
        case None -> ParsedArgs { options }

private fun validatePackageInputs(options: PartialPackageOptions): CliArgs[PartialPackageOptions] =
    match options.compiled_input with
    case Some { _ } ->
        match options.input with
        case Some { _ } -> UsageError { message: "Package accepts only one of `--compiled-input` or `--input`." }
        case None -> ParsedArgs { options }
    case None ->
        match options.input with
        case Some { _ } -> ParsedArgs { options }
        case None -> UsageError { message: "Package requires either `--compiled-input` or `--input`." }

private fun parseOutputType(value: String): CliArgs[OutputType] =
    match value with
    case "java" | "JAVA" -> ParsedArgs { JAVA }
    case "javascript" | "JAVASCRIPT" | "js" | "JS" -> ParsedArgs { JAVASCRIPT }
    case "python" | "PYTHON" | "py" | "PY" -> ParsedArgs { PYTHON }
    case _ -> UsageError { message: "Unknown output type `" + value + "`. Use java, python, py, javascript, or js." }

private fun parseLogLevel(value: String): CliArgs[LogLevel] =
    match value with
    case "DEBUG" | "debug" -> ParsedArgs { DEBUG }
    case "INFO" | "info" -> ParsedArgs { INFO }
    case "WARN" | "warn" | "WARNING" | "warning" -> ParsedArgs { WARN }
    case "ERROR" | "error" -> ParsedArgs { ERROR }
    case _ -> UsageError { message: "Unknown log level `" + value + "`. Use DEBUG, INFO, WARN, or ERROR." }

private fun printVersion(): Effect[/capy/lang/Program] =
    println(versionText())
        .map(_ => /capy/lang/Program.Success {})

private fun printHelp(): Effect[/capy/lang/Program] =
    println(versionText() + "\n\n" + helpText())
        .map(_ => /capy/lang/Program.Success {})

private fun usageError(message: String): Effect[/capy/lang/Program] =
    println_error(message + "\n\n" + helpText())
        .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })

private fun commandNotReady(command: String): Effect[/capy/lang/Program] =
    println_error("Command `" + command + "` parsed successfully, but execution is not implemented yet.")
        .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })

private fun versionText(): String =
    "Capybara compiler version: " + COMPILER_VERSION

private fun helpText(): String =
    "Usage:\n"
    + "  capy -v | --version\n"
    + "  capy -h | --help\n"
    + "  capy compile [-l|--libs <dir1,dir2,...>] [--compile-tests] [--native-wiring <file>] -i|--input <dir> -o|--output <dir> [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy compile-generate <java|python|javascript|js> [-l|--libs <dir1,dir2,...>] [--compile-tests] [--native-wiring <file>] -i|--input <dir> -o|--output <dir> [--linked-output <dir>] [--test-input <dir> --test-output <dir>] [--skip-java-lib] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy generate <java|python|javascript|js> [-i|--input <dir>] -o|--output <dir> [--skip-java-lib] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "  capy package (-ci|--compiled-input <dir> | -i|--input <dir>) -m|--module <capy.yml> [--capy.<field> <value>] [--log <DEBUG|INFO|WARN|ERROR>]\n"
    + "\n"
    + "Notes:\n"
    + "  compile output directory may be reused; stale generated files are pruned automatically.\n"
    + "  compile-generate compiles Capybara sources directly to generated output without writing linked intermediates unless --linked-output is provided.\n"
    + "  --native-wiring <file> is supported by compile and compile-generate; it reads native provider bindings from a JSON manifest and stores them in linked program output.\n"
    + "  compile-generate --test-input/--test-output also compiles test Capybara sources against the freshly compiled main program in the same invocation.\n"
    + "  compile --compile-tests writes bundled stdlib modules and injects discovered TestFile/List[TestFile] producers into capy/test/CapyTestRuntime.gather_tests.\n"
    + "  generate input directory defaults to the current directory.\n"
    + "  generate --skip-java-lib omits bundled Java runtime sources when the caller already has them on the compile classpath.\n"
    + "  package writes `capy.cbin` next to the provided `capy.yml`."

private fun capyOverrideField(arg: String): String =
    @Recursive
    fun copy_suffix(value: String, idx: int, acc: String): String =
        if idx >= value.size().value
        then acc
        else match value[idx] with
            case None -> acc
            case Some { char } -> copy_suffix(value, idx + 1, acc + char)
    ---
    copy_suffix(arg, 7, "")

data CompileConfiguration {
    libraries: Set[CompiledModule],
    native_providers: NativeProviderManifest
}

fun run_compile(options: CompileOptions): Effect[/capy/lang/Program] =
    match compileConfiguration(options) with
    case Error { message } -> runtimeError(message)
    case Success { configuration } ->
        let input_path = from_string(options.input)
        let output_path = from_string(options.output)
        validateInputDirectory(input_path, options.input).flat_map(input_result =>
            match input_result with
            case Error { message } -> runtimeError(message)
            case Success _ ->
                validateOutputDirectory(output_path, options.output).flat_map(output_result =>
                    match output_result with
                    case Error { message } -> runtimeError(message)
                    case Success _ ->
                        readSourceModules(input_path, options.input).flat_map(modules_result =>
                            match modules_result with
                            case Error { message } -> runtimeError(message)
                            case Success { raw_modules } ->
                                compile(
                                    raw_modules,
                                    configuration.libraries,
                                    configuration.native_providers,
                                    empty_native_provider_manifest()
                                ).flat_map(compilation =>
                                    match compilation with
                                    case Left { program } ->
                                        writeCompilationOutput(output_path, program).flat_map(write_result =>
                                            match write_result with
                                            case Error { message } -> runtimeError(message)
                                            case Success _ -> pure(/capy/lang/Program.Success {})
                                        )
                                    case Right { errors } ->
                                        printCompilerErrors(errors)
                                            .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })
                                )
                        )
                )
        )

private fun compileConfiguration(options: CompileOptions): Result[CompileConfiguration] =
    if options.compile_tests
    then Error { message: "`compile --compile-tests` is not available until test augmentation is translated to CFUN." }
    else
        match readLibraryModules(options.libs) with
        case Error e -> e
        case Success { libraries } ->
            match readNativeProviderManifest(options.native_wiring) with
            case Error e -> e
            case Success { native_providers } -> Success { CompileConfiguration {
                libraries: libraries,
                native_providers: native_providers
            }}

private fun readLibraryModules(libs: Option[String]): Result[Set[CompiledModule]] =
    match libs with
    case None -> Success { {} }
    case Some { value } ->
        if value.trim().is_empty()
        then Success { {} }
        else Error { message: "`compile --libs` is not available until linked program deserialization is translated to CFUN." }

private fun readNativeProviderManifest(native_wiring: Option[String]): Result[NativeProviderManifest] =
    match native_wiring with
    case None -> Success { empty_native_provider_manifest() }
    case Some { _ } -> Error { message: "`compile --native-wiring` is not available until native provider manifest deserialization is translated to CFUN." }

private fun validateInputDirectory(path: Path, raw_path: String): Effect[Result[Path]] =
    exists(path).flat_map(present =>
        if !present
        then pure(Error { message: "Input path does not exist: " + raw_path })
        else is_directory(path).map(directory =>
            if directory
            then Success { path }
            else Error { message: "Input path is not a directory: " + raw_path }
        )
    )

private fun validateOutputDirectory(path: Path, raw_path: String): Effect[Result[Path]] =
    exists(path).flat_map(present =>
        if !present
        then create_directories(path)
        else is_directory(path).map(directory =>
            if directory
            then Success { path }
            else Error { message: "Compile output path is not a directory: " + raw_path }
        )
    )

private fun readSourceModules(root: Path, raw_root: String): Effect[Result[List[RawModule]]] =
    listSourceFiles(root).flat_map(files_result =>
        match files_result with
        case Error e -> pure(e)
        case Success { files } ->
            if files.is_empty()
            then pure(Error { message: "No Capybara source files found under: " + raw_root })
            else readSourceModules(root, files)
    )

private fun readSourceModules(root: Path, files: List[Path]): Effect[Result[List[RawModule]]] =
    match files[0] with
    case None -> pure(Success { [] })
    case Some { file } ->
        read_text(file).flat_map(read_result =>
            match read_result with
            case Error e -> pure(e)
            case Success { source } ->
                match buildRawModule(relativeTo(root, file), source) with
                case Error e -> pure(e)
                case Success { raw_module } ->
                    readSourceModules(root, files[1:]).map(rest_result =>
                        match rest_result with
                        case Error e -> e
                        case Success { rest } -> Success { [raw_module] + rest }
                    )
        )

private fun buildRawModule(relative_path: Path, source: String): Result[RawModule] =
    match lastSegment(relative_path.normalize().segments) with
    case None -> Error { message: "Unable to infer module name for source path: " + pathToString(relative_path) }
    case Some { file_name } ->
        match sourceKind(file_name) with
        case None -> Error { message: "Unsupported source file extension: " + file_name }
        case Some { kind } -> Success { RawModule {
            name: stripSourceExtension(file_name),
            path: modulePath(relative_path),
            input: source,
            sourceKind: kind
        }}

private fun listSourceFiles(path: Path): Effect[Result[List[Path]]] =
    list_entries(path).flat_map(entries_result =>
        match entries_result with
        case Error e -> pure(e)
        case Success { entries } -> listSourceFilesFromEntries(entries)
    )

private fun listSourceFilesFromEntries(entries: List[Path]): Effect[Result[List[Path]]] =
    match entries[0] with
    case None -> pure(Success { [] })
    case Some { entry } ->
        is_file(entry).flat_map(file =>
            if file
            then listSourceFilesFromEntries(entries[1:]).map(rest_result =>
                match rest_result with
                case Error e -> e
                case Success { rest } ->
                    if sourceFile(entry)
                    then Success { [entry] + rest }
                    else Success { rest }
            )
            else is_directory(entry).flat_map(directory =>
                if directory
                then listSourceFiles(entry).flat_map(children_result =>
                    match children_result with
                    case Error e -> pure(e)
                    case Success { children } ->
                        listSourceFilesFromEntries(entries[1:]).map(rest_result =>
                            match rest_result with
                            case Error e -> e
                            case Success { rest } -> Success { children + rest }
                        )
                )
                else listSourceFilesFromEntries(entries[1:])
            )
        )

private fun sourceFile(path: Path): bool =
    match lastSegment(path.normalize().segments) with
    case None -> false
    case Some { file_name } ->
        match sourceKind(file_name) with
        case None -> false
        case Some _ -> true

private fun sourceKind(file_name: String): Option[SourceKind] =
    if file_name.end_with(FUNCTIONAL.extension())
    then Some { FUNCTIONAL }
    else if file_name.end_with(OBJECT_ORIENTED.extension())
    then Some { OBJECT_ORIENTED }
    else None {}

private fun stripSourceExtension(file_name: String): String =
    if file_name.end_with(FUNCTIONAL.extension())
    then file_name[0, file_name.size().value - FUNCTIONAL.extension().size().value]
    else if file_name.end_with(OBJECT_ORIENTED.extension())
    then file_name[0, file_name.size().value - OBJECT_ORIENTED.extension().size().value]
    else file_name

private fun modulePath(relative_path: Path): String =
    match relative_path.parent() with
    case None -> ""
    case Some { parent } -> pathSegmentsToString(parent.normalize().segments)

private fun lastSegment(segments: List[String]): Option[String] =
    match segments[0] with
    case None -> None {}
    case Some { segment } ->
        match segments[1] with
        case None -> Some { segment }
        case Some _ -> lastSegment(segments[1:])

private fun relativeTo(base: Path, path: Path): Path =
    from_string(pathSegmentsToString(dropPrefixSegments(base.normalize().segments, path.normalize().segments)))

@Recursive
private fun dropPrefixSegments(prefix: List[String], segments: List[String]): List[String] =
    match prefix[0] with
    case None -> segments
    case Some { expected } ->
        match segments[0] with
        case None -> []
        case Some { actual } ->
            if expected == actual
            then dropPrefixSegments(prefix[1:], segments[1:])
            else segments

private fun pathSegmentsToString(segments: List[String]): String =
    @Recursive
    fun pathSegmentsToString(segments: List[String], acc: String): String =
        match segments[0] with
        case None -> acc
        case Some { segment } ->
            let next = if acc.is_empty() then segment else acc + "/" + segment
            pathSegmentsToString(segments[1:], next)
    ---
    pathSegmentsToString(segments, "")

private fun pathToString(path: Path): String =
    let normalized = path.normalize()
    let body = pathSegmentsToString(normalized.segments)
    match normalized.root with
    case RELATIVE -> if body.is_empty() then "." else body
    case ABSOLUTE -> "/" + body
    case HOME -> if body.is_empty() then "~" else "~/" + body

private fun writeCompilationOutput(output_dir: Path, program: CompiledProgram): Effect[Result[String]] =
    create_directories(output_dir).flat_map(directory_result =>
        match directory_result with
        case Error e -> pure(e)
        case Success _ ->
            writeJsonFile(output_dir / "program.json", program).flat_map(program_result =>
                match program_result with
                case Error e -> pure(e)
                case Success _ -> writeLinkedModules(output_dir, program.modules)
            )
    )

private fun writeLinkedModules(output_dir: Path, modules: List[CompiledModule]): Effect[Result[String]] =
    match modules[0] with
    case None -> pure(Success { "linked modules written" })
    case Some { module } ->
        writeLinkedModule(output_dir, module).flat_map(module_result =>
            match module_result with
            case Error e -> pure(e)
            case Success _ -> writeLinkedModules(output_dir, modules[1:])
        )

private fun writeLinkedModule(output_dir: Path, module: CompiledModule): Effect[Result[String]] =
    let module_file = linkedModuleFile(output_dir, module)
    createParentDirectories(module_file).flat_map(parent_result =>
        match parent_result with
        case Error e -> pure(e)
        case Success _ -> writeJsonFile(module_file, module)
    )

private fun linkedModuleFile(output_dir: Path, module: CompiledModule): Path =
    let base =
        if module.path.is_empty()
        then output_dir
        else output_dir / from_string(module.path)
    base / (module.name + ".json")

private fun createParentDirectories(path: Path): Effect[Result[Path]] =
    match path.parent() with
    case None -> pure(Success { path })
    case Some { parent } -> create_directories(parent)

private fun writeJsonFile(path: Path, value: data): Effect[Result[String]] =
    match to_json(value) with
    case Error { message } -> pure(Error { message: "Unable to serialize linked JSON for `" + pathToString(path) + "`: " + message })
    case Success { json } -> write_text(path, serialize(json))

private fun printCompilerErrors(errors: List[CompilerError]): Effect[String] =
    println_error(compilerErrorsText(errors))

private fun compilerErrorsText(errors: List[CompilerError]): String =
    "Compilation failed with " + errors.size().value + " error(s):"
    + (errors |> "", (acc, error) => acc + "\n" + compilerErrorText(error))

private fun compilerErrorText(error: CompilerError): String =
    let location =
        if error.moduleName.is_empty()
        then ""
        else error.moduleName + ":" + error.line + ":" + error.column + ": "
    location + error.message

private fun runtimeError(message: String): Effect[/capy/lang/Program] =
    println_error(message)
        .map(_ => /capy/lang/Program.Failed { exit_code: DEFAULT_FAILED_EXIT_CODE })

fun run_generate(options: GenerateOptions): Effect[/capy/lang/Program] =
    let inputPath = from_string(options.input)
    let outputPath = from_string(options.output)
    validateInputDirectory(inputPath, options.input).flat_map(inputResult =>
        match inputResult with
        case Error { message } -> runtimeError(message)
        case Success _ ->
            validateOutputDirectory(outputPath, options.output).flat_map(outputResult =>
                match outputResult with
                case Error { message } -> runtimeError(message)
                case Success _ ->
                    readLinkedProgram(inputPath).flat_map(programResult =>
                        match programResult with
                        case Error { message } -> runtimeError(message)
                        case Success { program } ->
                            writeGeneratedProgram(outputPath, generate(program, options.output_type)).flat_map(writeResult =>
                                match writeResult with
                                case Error { message } -> runtimeError(message)
                                case Success _ -> pure(/capy/lang/Program.Success {})
                            )
                    )
            )
    )

private fun readLinkedProgram(inputDir: Path): Effect[Result[CompiledProgram]] =
    let programFile = inputDir / "program.json"
    read_text(programFile).map(readResult =>
        match readResult with
        case Error { message } -> Error { message: "Unable to read linked program `" + pathToString(programFile) + "`: " + message }
        case Success { content } ->
            match deserialize(content) with
            case Error { message } -> Error { message: "Unable to parse linked program `" + pathToString(programFile) + "`: " + message }
            case Success { json } -> parseLinkedProgram(json)
    )

private fun parseLinkedProgram(json: JsonObject): Result[CompiledProgram] =
    match requiredJsonArray(json, "modules") with
    case Error e -> e
    case Success { modulesJson } ->
        match parseLinkedModules(modulesJson.value) with
        case Error e -> e
        case Success { modules } -> Success { CompiledProgram {
            modules: modules,
            objectOrientedModules: [],
            nativeProviders: empty_native_provider_manifest(),
            nativeProviderCatalog: empty_native_provider_catalog()
        }}

private fun parseLinkedModules(modules: List[Json]): Result[List[CompiledModule]] =
    match modules[0] with
    case None -> Success { [] }
    case Some { json } ->
        match parseLinkedModule(json) with
        case Error e -> e
        case Success { module } ->
            match parseLinkedModules(modules[1:]) with
            case Error e -> e
            case Success { rest } -> Success { [module] + rest }

private fun parseLinkedModule(json: Json): Result[CompiledModule] =
    match json with
    case JsonObject { moduleFields } ->
        match requiredJsonString(JsonObject { moduleFields }, "name") with
        case Error e -> e
        case Success { name } ->
            match requiredJsonString(JsonObject { moduleFields }, "path") with
            case Error e -> e
            case Success { path } -> Success { CompiledModule {
                name: name,
                path: path,
                types: {:},
                visiblePrimitiveBackedTypes: {:},
                functions: [],
                derivers: {:},
                annotations: {:},
                staticImports: []
            }}
    case _ -> Error { message: "Linked program `modules` must contain objects." }

private fun requiredJsonArray(json: JsonObject, fieldName: String): Result[JsonArray] =
    match json.get(fieldName) with
    case None -> Error { message: "Linked program is missing required field `" + fieldName + "`." }
    case Some { value } ->
        match value with
        case JsonArray { values } -> Success { JsonArray { values } }
        case _ -> Error { message: "Linked program field `" + fieldName + "` must be an array." }

private fun requiredJsonString(json: JsonObject, fieldName: String): Result[String] =
    match json.get(fieldName) with
    case None -> Error { message: "Linked module is missing required field `" + fieldName + "`." }
    case Some { value } ->
        match value with
        case JsonString { text } -> Success { text }
        case _ -> Error { message: "Linked module field `" + fieldName + "` must be a string." }

private fun writeGeneratedProgram(outputDir: Path, program: GeneratedProgram): Effect[Result[String]] =
    writeGeneratedModules(outputDir, program.modules)

private fun writeGeneratedModules(outputDir: Path, modules: List[GeneratedModule]): Effect[Result[String]] =
    match modules[0] with
    case None -> pure(Success { "generated modules written" })
    case Some { module } ->
        writeGeneratedModule(outputDir, module).flat_map(moduleResult =>
            match moduleResult with
            case Error e -> pure(e)
            case Success _ -> writeGeneratedModules(outputDir, modules[1:])
        )

private fun writeGeneratedModule(outputDir: Path, module: GeneratedModule): Effect[Result[String]] =
    let outputFile = outputDir / from_string(module.relativePath)
    createParentDirectories(outputFile).flat_map(parentResult =>
        match parentResult with
        case Error e -> pure(e)
        case Success _ -> write_text(outputFile, module.code)
    )

private fun runCompileGenerate(options: CompileGenerateOptions): Effect[/capy/lang/Program] =
    commandNotReady("compile-generate")

private fun runPackage(options: PackageOptions): Effect[/capy/lang/Program] =
    commandNotReady("package")
