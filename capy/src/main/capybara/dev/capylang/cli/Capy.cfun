    linked_double_value(value)

private fun linked_data_field(node: any, name: String): Result[any] =
    let value <- linked_field(node, name)
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData data_value -> Success { data_value }
        case _ -> Error { message: "Expected typed JSON node field `" + name + "`" }
    }
    case _ -> Error { message: "Expected typed JSON node field `" + name + "`" }

private fun linked_list_value(value: any, decode: any => Result[T]): Result[any] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonArray { _, items } -> {
            let initial: List[any] = []
            linked_list_items(items, 0, initial, decode)
        }
        case _ -> Error { message: "Expected typed JSON array" }
    }
    case _ -> Error { message: "Expected typed JSON array" }

private fun linked_list_items(items: List[TypedJson], idx: int, acc: List[any], decode: any => Result[T]): Result[any] =
    match items[idx] with
    case None -> Success { acc }
    case Some { item } ->
        let decoded <- decode(item)
        let next: List[any] = acc + decoded
        linked_list_items(items, idx + 1, next, decode) | (result => result)

private fun linked_list_field(node: any, name: String, decode: any => Result[T]): Result[List[T]] =
    let value <- linked_field(node, name)
    let items <- linked_list_value(value, decode)
    Success { items }

private fun linked_dict_value(value: any, decode: any => Result[T]): Result[any] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonObject { entries } -> {
            let initial: Result[Dict[any]] = Success { {:} }
            let decoded_entries <- entries |> initial, (acc_result, key, item) => {
                let acc <- acc_result
                let decoded <- decode(item)
                Success { acc + { key : decoded } }
            }
            Success { decoded_entries }
        }
        case _ -> Error { message: "Expected typed JSON object" }
    }
    case _ -> Error { message: "Expected typed JSON object" }

private fun linked_dict_field(node: any, name: String, decode: any => Result[T]): Result[Dict[T]] =
    let value <- linked_field(node, name)
    let entries <- linked_dict_value(value, decode)
    Success { entries }

private fun linked_option_field(node: any, name: String, decode: any => Result[T]): Result[Option[T]] =
    let value <- linked_field(node, name)
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData option_data -> {
            match option_data.name with
            case "None" -> Success { None {} }
            case "Some" ->
                let item <- linked_field(option_data, "value")
                let decoded <- decode(item)
                Some { decoded }
            case _ -> Error { message: "Expected Option typed JSON, got `" + option_data.name + "`" }
        }
        case _ -> Error { message: "Expected Option typed JSON" }
    }
    case _ -> Error { message: "Expected Option typed JSON" }

private fun linked_decode_data_value(value: any, expected: String, decode: any => Result[T]): Result[T] =
    match value with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData node -> decode(node)
        case _ -> Error { message: "Expected " + expected + " typed JSON" }
    }
    case _ -> Error { message: "Expected " + expected + " typed JSON" }

private fun linked_decode_program(node: any): Result[CompiledProgram] =
    let checked <- linked_expect_data(node, "CompiledProgram")
    let modules <- linked_list_field(node, "modules", value => linked_decode_module_value(value))
    let objectOrientedModules <- linked_list_field(node, "objectOrientedModules", value => linked_decode_object_oriented_unit_value(value))
    let nativeProvidersData <- linked_data_field(node, "nativeProviders")
    let nativeProviders <- linked_decode_native_provider_manifest(nativeProvidersData)
    let nativeProviderCatalogData <- linked_data_field(node, "nativeProviderCatalog")
    let nativeProviderCatalog <- linked_decode_native_provider_catalog(nativeProviderCatalogData)
    CompiledProgram {
        modules: modules,
        objectOrientedModules: objectOrientedModules,
        nativeProviders: nativeProviders,
        nativeProviderCatalog: nativeProviderCatalog
    }

