    linked_decode_data_value(value, "CompiledModule", node => linked_decode_module(node))

private fun linked_decode_module(node: any): Result[CompiledModule] =
    let checked <- linked_expect_data(node, "CompiledModule")
    let name <- linked_string_field(node, "name")
    let path <- linked_string_field(node, "path")
    let types <- linked_dict_field(node, "types", value => linked_decode_generic_data_type_value(value))
    let visiblePrimitiveBackedTypes <- linked_dict_field(node, "visiblePrimitiveBackedTypes", value => linked_decode_primitive_backed_type_value(value))
    let functions <- linked_list_field(node, "functions", value => linked_decode_function_value(value))
    let imports <- linked_list_field(node, "imports", value => linked_decode_import_value(value))
    let derivers <- linked_dict_field(node, "derivers", value => linked_decode_deriver_value(value))
    let annotations <- linked_dict_field(node, "annotations", value => linked_decode_annotation_value(value))
    let staticImports <- linked_list_field(node, "staticImports", value => linked_decode_static_import_value(value))
    CompiledModule {
        name: name,
        path: path,
        types: types,
        visiblePrimitiveBackedTypes: visiblePrimitiveBackedTypes,
        functions: functions,
        imports: imports,
        derivers: derivers,
        annotations: annotations,
        staticImports: staticImports
    }

