private fun linked_decode_expression(node: any): Result[CompiledExpression] =
    match node with
    case TypedJson typed -> {
        match typed with
        case TypedJsonData expression_node -> {
        match expression_node.name with
    case "CompiledUnsupportedExpression" ->
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledUnsupportedExpression { source: source, location: location }
    case "CompiledIntLiteral" ->
        let value <- linked_int_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledIntLiteral { value: value, source: source, location: location }
    case "CompiledLongLiteral" ->
        let value <- linked_long_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledLongLiteral { value: value, source: source, location: location }
    case "CompiledFloatLiteral" ->
        let value <- linked_float_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledFloatLiteral { value: value, source: source, location: location }
    case "CompiledDoubleLiteral" ->
        let value <- linked_double_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledDoubleLiteral { value: value, source: source, location: location }
    case "CompiledBoolLiteral" ->
        let value <- linked_bool_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledBoolLiteral { value: value, source: source, location: location }
    case "CompiledStringLiteral" ->
        let value <- linked_string_field(node, "value")
        let source <- linked_string_field(node, "source")
        let location <- linked_decode_source_location_field(node)
        CompiledStringLiteral { value: value, source: source, location: location }
    case "CompiledVariableExpression" ->
        let name <- linked_string_field(node, "name")
        let location <- linked_decode_source_location_field(node)
        CompiledVariableExpression { name: name, location: location }
    case "CompiledIfExpression" ->
        let condition <- linked_decode_expression_field(node, "condition")
        let thenBranch <- linked_decode_expression_field(node, "thenBranch")
        let elseBranch <- linked_decode_expression_field(node, "elseBranch")
        let location <- linked_decode_source_location_field(node)
        CompiledIfExpression { condition: condition, thenBranch: thenBranch, elseBranch: elseBranch, location: location }
    case "CompiledBinaryExpression" ->
        let operator <- linked_string_field(node, "operator")
        let left <- linked_decode_expression_field(node, "left")
        let right <- linked_decode_expression_field(node, "right")
        let location <- linked_decode_source_location_field(node)
        CompiledBinaryExpression { operator: operator, left: left, right: right, location: location }
    case "CompiledUnaryExpression" ->
        let operator <- linked_string_field(node, "operator")
        let expression <- linked_decode_expression_field(node, "expression")
        let location <- linked_decode_source_location_field(node)
        CompiledUnaryExpression { operator: operator, expression: expression, location: location }
    case "CompiledFunctionCallExpression" ->
        let name <- linked_string_field(node, "name")
        let arguments <- linked_list_field(node, "arguments", value => linked_decode_expression_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledFunctionCallExpression { name: name, arguments: arguments, location: location }
    case "CompiledFunctionReferenceExpression" ->
        let name <- linked_string_field(node, "name")
        let location <- linked_decode_source_location_field(node)
        CompiledFunctionReferenceExpression { name: name, location: location }
    case "CompiledMethodCallExpression" ->
        let receiver <- linked_decode_expression_field(node, "receiver")
        let name <- linked_string_field(node, "name")
        let arguments <- linked_list_field(node, "arguments", value => linked_decode_expression_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledMethodCallExpression { receiver: receiver, name: name, arguments: arguments, location: location }
    case "CompiledWithExpression" ->
        let receiver <- linked_decode_expression_field(node, "receiver")
        let fields <- linked_list_field(node, "fields", value => linked_decode_data_field_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledWithExpression { receiver: receiver, fields: fields, location: location }
    case "CompiledLambdaExpression" ->
        let parameters <- linked_list_field(node, "parameters", value => linked_string_value(value))
        let body <- linked_decode_expression_field(node, "body")
        let location <- linked_decode_source_location_field(node)
        CompiledLambdaExpression { parameters: parameters, body: body, location: location }
    case "CompiledListLiteral" ->
        let values <- linked_list_field(node, "values", value => linked_decode_expression_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledListLiteral { values: values, location: location }
    case "CompiledSetLiteral" ->
        let values <- linked_list_field(node, "values", value => linked_decode_expression_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledSetLiteral { values: values, location: location }
    case "CompiledDictLiteral" ->
        let entries <- linked_list_field(node, "entries", value => linked_decode_dict_entry_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledDictLiteral { entries: entries, location: location }
    case "CompiledTupleLiteral" ->
        let values <- linked_list_field(node, "values", value => linked_decode_expression_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledTupleLiteral { values: values, location: location }
    case "CompiledIndexExpression" ->
        let receiver <- linked_decode_expression_field(node, "receiver")
        let index <- linked_decode_expression_field(node, "index")
        let endIndex <- linked_decode_expression_field(node, "endIndex")
        let hasEndIndex <- linked_bool_field(node, "hasEndIndex")
        let location <- linked_decode_source_location_field(node)
        CompiledIndexExpression { receiver: receiver, index: index, endIndex: endIndex, hasEndIndex: hasEndIndex, location: location }
    case "CompiledDataLiteral" ->
        let typeName <- linked_string_field(node, "typeName")
        let fields <- linked_list_field(node, "fields", value => linked_decode_data_field_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledDataLiteral { typeName: typeName, fields: fields, location: location }
    case "CompiledFieldAccessExpression" ->
        let receiver <- linked_decode_expression_field(node, "receiver")
        let name <- linked_string_field(node, "name")
        let location <- linked_decode_source_location_field(node)
        CompiledFieldAccessExpression { receiver: receiver, name: name, location: location }
    case "CompiledReduceExpression" ->
        let receiver <- linked_decode_expression_field(node, "receiver")
        let initial <- linked_decode_expression_field(node, "initial")
        let accumulatorName <- linked_string_field(node, "accumulatorName")
        let keyName <- linked_string_field(node, "keyName")
        let valueName <- linked_string_field(node, "valueName")
        let body <- linked_decode_expression_field(node, "body")
        let location <- linked_decode_source_location_field(node)
        CompiledReduceExpression { receiver: receiver, initial: initial, accumulatorName: accumulatorName, keyName: keyName, valueName: valueName, body: body, location: location }
    case "CompiledMatchExpression" ->
        let value <- linked_decode_expression_field(node, "value")
        let cases <- linked_list_field(node, "cases", value => linked_decode_match_case_value(value))
        let location <- linked_decode_source_location_field(node)
        CompiledMatchExpression { value: value, cases: cases, location: location }
    case "CompiledBlockExpression" ->
        let bindings <- linked_list_field(node, "bindings", value => linked_decode_let_binding_value(value))
        let result <- linked_decode_expression_field(node, "result")
        let location <- linked_decode_source_location_field(node)
        CompiledBlockExpression { bindings: bindings, result: result, location: location }
        case _ -> Error { message: "Unknown linked expression type `" + expression_node.name + "`" }
        }
        case _ -> Error { message: "Expected CompiledExpression typed JSON" }
    }
    case _ -> Error { message: "Expected CompiledExpression typed JSON" }

private fun linked_decode_expression_value(value: any): Result[CompiledExpression] =
    linked_decode_data_value(value, "CompiledExpression", node => linked_decode_expression(node))

