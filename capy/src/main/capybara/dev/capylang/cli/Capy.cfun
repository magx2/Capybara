fun execute_compile(args: List[String]): Effect[Program] = ???
fun execute_generate(args: List[String]): Effect[Program] = ???
fun execute_compile_generate(args: List[String]): Effect[Program] = ???
fun execute_package(args: List[String]): Effect[Program] = ???
