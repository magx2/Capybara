{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Capybara",
  "scopeName": "source.capybara",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#indexing"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.capybara",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.documentation.capybara",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.capybara",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.capybara",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.capybara",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.capybara",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.capybara",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.byte.capybara",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.long.capybara",
          "match": "\\b\\d+[lL]\\b"
        },
        {
          "name": "constant.numeric.float.capybara",
          "match": "\\b(?:\\d+\\.\\d*(?:[eE][+\\-]?\\d+)?|\\d+[eE][+\\-]?\\d+)[fF]\\b"
        },
        {
          "name": "constant.numeric.double.capybara",
          "match": "\\b(?:\\d+\\.\\d*(?:[eE][+\\-]?\\d+)?|\\d+[eE][+\\-]?\\d+)(?:[dD])?\\b"
        },
        {
          "name": "constant.numeric.int.capybara",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.capybara",
          "match": "\\b(fun|type|data|single|match|with|if|then|else|let|from|import|except)\\b"
        },
        {
          "name": "keyword.other.capybara",
          "match": "\\b(this|is_empty|size)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.capybara",
          "match": "\\b(byte|int|long|float|double|bool|string|any|data|nothing|list|set|dict|tuple)\\b"
        },
        {
          "name": "entity.name.type.capybara",
          "match": "\\b_*[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.qualified.capybara",
          "match": "/[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z_][A-Za-z0-9_]*)+"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.private.capybara",
          "match": "\\b(fun)\\s+(__[A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.control.capybara"
            },
            "2": {
              "name": "entity.name.function.private.capybara"
            }
          }
        },
        {
          "name": "meta.function.capybara",
          "match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.capybara"
            },
            "2": {
              "name": "entity.name.function.capybara"
            }
          }
        },
        {
          "name": "meta.function.reference.private.capybara",
          "match": ":(__[A-Za-z0-9_]+)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.private.capybara"
            }
          }
        },
        {
          "name": "meta.function.reference.capybara",
          "match": ":([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.capybara"
            }
          }
        },
        {
          "name": "meta.function.call.private.capybara",
          "match": "\\b(__[A-Za-z0-9_]+)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.private.capybara"
            }
          }
        },
        {
          "name": "meta.function.call.capybara",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.capybara"
            }
          }
        },
        {
          "name": "meta.type.private.capybara",
          "match": "\\b(type|data|single)\\s+(__[A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.capybara"
            },
            "2": {
              "name": "entity.name.type.private.capybara"
            }
          }
        },
        {
          "name": "meta.type.capybara",
          "match": "\\b(type|data|single)\\s+(_*[A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.capybara"
            },
            "2": {
              "name": "entity.name.type.capybara"
            }
          }
        },
        {
          "name": "meta.match.typed-pattern.capybara",
          "match": "(\\|)\\s*(_*[A-Z][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=>)",
          "captures": {
            "1": {
              "name": "keyword.operator.capybara"
            },
            "2": {
              "name": "entity.name.type.capybara"
            },
            "3": {
              "name": "variable.parameter.capybara"
            },
            "4": {
              "name": "keyword.operator.capybara"
            }
          }
        },
        {
          "name": "meta.function.owner-generic.capybara",
          "match": "\\b(fun)\\s+(_*[A-Z][A-Za-z0-9_]*\\[[^\\]]+\\])\\.(?:`[^`]+`|[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.capybara"
            },
            "2": {
              "name": "entity.name.type.capybara"
            }
          }
        },
        {
          "name": "meta.match.wildcard-binding.capybara",
          "match": "(\\|)\\s*(_)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=>)",
          "captures": {
            "1": {
              "name": "keyword.operator.capybara"
            },
            "2": {
              "name": "keyword.operator.capybara"
            },
            "3": {
              "name": "variable.parameter.capybara"
            },
            "4": {
              "name": "keyword.operator.capybara"
            }
          }
        },
        {
          "name": "meta.match.constructor-pattern.capybara",
          "match": "(\\|)\\s*(_*[A-Z][A-Za-z0-9_]*)\\s*(\\{)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.capybara"
            },
            "2": {
              "name": "entity.name.type.capybara"
            },
            "3": {
              "name": "punctuation.section.block.begin.capybara"
            },
            "4": {
              "name": "variable.parameter.capybara"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.capybara",
          "match": "\\|all\\?|\\|any\\?|\\|>|\\|\\*|\\|-|\\|"
        },
        {
          "name": "keyword.operator.capybara",
          "match": "\\.and\\.|\\.nand\\.|\\.or\\.|\\.xor\\.|\\.not\\."
        },
        {
          "name": "keyword.operator.capybara",
          "match": "==|!=|<=|>=|=>|->|\\+|\\-|\\*|/|%|\\^|<|>|=|&|\\?|:"
        }
      ]
    },
    "indexing": {
      "patterns": [
        {
          "name": "meta.index.capybara",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "keyword.operator.capybara",
              "match": ":"
            },
            {
              "name": "constant.numeric.int.capybara",
              "match": "-?\\d+"
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.capybara",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.unimplemented.capybara",
          "match": "\\?\\?\\?"
        }
      ]
    }
  }
}



