from Pck1 import { * }
from Pck2 import { * } except { add }
from /dev/capylang/capybara/imports2/Pck5 import { lvl_multiplier }

from Types1 import { * }
from Types2 import { * } except { T1 }

fun calculator(a: int, b: int, op: string) =
    if op == "+"
    then add(a,b)
    else if op == "-"
    then subtract(a,b)
    else if op == "*"
    then multiply(a,b)
    else if op == "/"
    then divide(a,b)
    else if op == "p3"
    then Pck3.foo_boo(a>10, a<20)
    else empty(a+b)

fun what_to_do(x: int) = Pck3.foo_boo(x>10, x<20)

fun x(a: int, b: int, op: string) = /dev/capylang/capybara/imports2/Pck4.awesome(calculator(a,b,op))

fun y(a: int, b: int, op: string) = /dev/capylang/capybara/imports2/Pck4.awesome(lvl_multiplier(calculator(a,b,op)))

fun t1(x: int): T1 = D1 { foo: x }

fun t1(x: int): Types2.T1 = TD1 { x: "x: " + x }

fun xyz(x: int, y: int, z: int): Types2.DataX = Types2.DataX { xyz: "" + x + y + z }

fun type5(x: int, y: int): /dev/capylang/capybara/imports2/Types3.T5 =
    if x > 0
    then /dev/capylang/capybara/imports2/Types3.D5_1 { x: x }
    else /dev/capylang/capybara/imports2/Types3.D5_2 { y: y }
