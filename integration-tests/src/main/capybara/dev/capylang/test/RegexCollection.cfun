from /capy/lang/Regex import { * }

fun has_foo(input: string): bool = regex/foo/ ~ input

fun has_foo_with_flag(input: string): bool = regex/Foo/i ~ input

fun all_foo(input: string): list[string] = regex/foo/ ~~ input

fun redact_ones(input: string): string = (regex/1/ ~> "#")(input)

fun split_csv(input: string): list[string] = regex/,/ /> input

fun escaped_slash_match(): bool = regex/a\/b/ ~ "--a/b--"
