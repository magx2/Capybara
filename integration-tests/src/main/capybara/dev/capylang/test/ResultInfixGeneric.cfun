type MyResult[T] = Ok[T] | Fail
data Ok[T] { value: T }
data Fail { message: string }

fun MyResult[T].`|`(map: T => MyResult[Y]): MyResult[Y] =
    match this with
    | Fail f -> f
    | Ok o -> map(o.value)

fun MyResult[T].`|*`(flatmap: T => MyResult[MyResult[Y]]): MyResult[Y] =
    match this with
    | Fail f -> f
    | Ok o ->
        match flatmap(o.value) with
        | Fail f -> f
        | Ok { top_result } -> top_result

fun MyResult[T].or_else(v: T): T =
    match this with
    | Fail _ -> v
    | Ok { v } -> v

fun map_to_string(v: int): MyResult[string] = Ok { value: "v=" + v }

fun map_to_fail(v: int): MyResult[string] = Fail { message: "bad:" + v }

fun map_to_nested_ok(v: int): MyResult[MyResult[string]] = Ok { value: Ok { value: "mapped_" + v } }

fun map_to_nested_fail(v: int): MyResult[MyResult[string]] = Ok { value: Fail { message: "nested_bad:" + v } }

fun wrap_nested_ok(v: int): MyResult[MyResult[string]] = Ok { value: Ok { value: "wrapped_" + v } }

fun wrap_nested_fail(v: int): MyResult[MyResult[string]] = Ok { value: Fail { message: "wrapped_bad:" + v } }

fun apply_mapper(r: MyResult[T], map: T => MyResult[Y]): MyResult[Y] = r | map

fun propagate_fail(r: MyResult[T], map: T => MyResult[Y]): MyResult[Y] = r | map

fun apply_flat_mapper(r: MyResult[T], map: T => MyResult[MyResult[Y]]): MyResult[Y] = r |* map

fun nested_identity(r: MyResult[MyResult[string]]): MyResult[MyResult[string]] = r

fun flatten_nested_result(r: MyResult[MyResult[string]]): MyResult[string] =
    r |* nested => Ok { value: nested }
