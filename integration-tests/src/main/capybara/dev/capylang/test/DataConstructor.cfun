from /capy/lang/Result import { * }

data OddInt { number: int } with constructor {
    if number % 2 == 1 then
        * { number: number }
    else
        * { number: number + 1 }
}

data User { age: int } with constructor {
    if age <= 0 then
        Error { "Age has to be greater than 0. Was " + age + "." }
    else
        Success { * { age: age } }
}

fun odd_number(x: int): int =
    (OddInt { number: x }).number

fun validated_user_age(age: int): string =
    match User { age: age } with
    case Success { value } -> "ok:" + value.age
    case Error { message } -> "err:" + message

type ValidatedName { name: string } = NamedUser | NamedGuest with constructor {
    if name.size == 0 then
        Error { "Name was empty" }
    else
        Success { * { name: name } }
}

data NamedUser { name: string, role: string } with constructor {
    if role.size == 0 then
        Error { "Role was empty" }
    else
        Success { * { name: name, role: role } }
}

data NamedGuest { name: string, badge: string }

type ValidatedProfileName { name: string } = Profile with constructor {
    if name.size == 0 then
        Error { "Profile name was empty" }
    else
        Success { * { name: name } }
}

type ValidatedProfileRole { role: string } = Profile with constructor {
    if role.size == 0 then
        Error { "Profile role was empty" }
    else
        Success { * { role: role } }
}

data Profile { name: string, role: string }

fun validated_named_user(name: string, role: string): string =
    match NamedUser { name: name, role: role } with
    case Success { value } -> "ok:" + value.name + ":" + value.role
    case Error { message } -> "err:" + message

fun validated_named_guest(name: string, badge: string): string =
    match NamedGuest { name: name, badge: badge } with
    case Success { value } -> "ok:" + value.name + ":" + value.badge
    case Error { message } -> "err:" + message

fun validated_profile(name: string, role: string): string =
    match Profile { name: name, role: role } with
    case Success { value } -> "ok:" + value.name + ":" + value.role
    case Error { message } -> "err:" + message
