from /capy/lang/Option import { * }
from /capy/lang/Result import { * }
from /capy/lang/Seq import { * }

fun sum_int(acc: int, value: int): int = acc + value
fun double_int(value: int): int = value * 2
fun is_positive(value: int): bool = value > 0
fun expand_list(value: int): list[int] = [value, value + 1]
fun expand_set(value: int): set[int] = {value, value + 10}
fun expand_seq(value: int): Seq[int] = to_seq([value, value + 1])
fun nested_success(value: int): Result[Result[string]] = Success { value: Success { value: "v=" + value } }

fun list_map_named(values: list[int]): list[int] = values.map(x => x * 2)
fun list_map_operator(values: list[int]): list[int] = values | x => x * 2

fun list_filter_named(values: list[int]): list[int] = values.filter(x => x > 0)
fun list_filter_operator(values: list[int]): list[int] = values |- x => x > 0

fun list_flat_map_named(values: list[int]): list[int] = values.flat_map(x => expand_list(x))
fun list_flat_map_operator(values: list[int]): list[int] = values |* x => expand_list(x)

fun list_reduce_named(values: list[int]): int = values.reduce(0, (acc, value) => acc + value)
fun list_reduce_operator(values: list[int]): int = values |> 0, (acc, value) => acc + value
fun list_reduce_left_named(values: list[int]): int = values.reduce_left(0, (acc, value) => acc + value)
fun list_reduce_left_symbolic(values: list[int]): int = values.`|l>`(0, (acc, value) => acc + value)

fun set_map_named(values: set[int]): set[int] = values.map(x => x * 2)
fun set_map_operator(values: set[int]): set[int] = values | x => x * 2

fun set_filter_named(values: set[int]): set[int] = values.filter(x => x > 0)
fun set_filter_operator(values: set[int]): set[int] = values |- x => x > 0

fun set_flat_map_named(values: set[int]): set[int] = values.flat_map(x => expand_set(x))
fun set_flat_map_operator(values: set[int]): set[int] = values |* x => expand_set(x)

fun set_reduce_named(values: set[int]): int = values.reduce(0, (acc, value) => acc + value)
fun set_reduce_operator(values: set[int]): int = values |> 0, (acc, value) => acc + value
fun set_reduce_left_named(values: set[int]): int = values.reduce_left(0, (acc, value) => acc + value)
fun set_reduce_left_symbolic(values: set[int]): int = values.`|l>`(0, (acc, value) => acc + value)

fun dict_map_named(values: dict[int]): dict[string] = values.map((key, value) => key + ":" + value)
fun dict_map_operator(values: dict[int]): dict[string] = values | (key, value) => key + ":" + value

fun dict_filter_named(values: dict[int]): dict[int] = values.filter(value => value > 10)
fun dict_filter_operator(values: dict[int]): dict[int] = values |- value => value > 10

fun dict_flat_map_named(values: dict[int]): list[int] = values.flat_map(value => [value, value + 10])
fun dict_flat_map_operator(values: dict[int]): list[int] = values |* value => [value, value + 10]

fun dict_reduce_named(values: dict[int]): string = values.reduce("", (acc, key, value) => acc + key + ":" + value + ",")
fun dict_reduce_operator(values: dict[int]): string = values |> "", (acc, key, value) => acc + key + ":" + value + ","
fun dict_reduce_left_named(values: dict[int]): string = values.reduce_left("", (acc, key, value) => acc + key + ":" + value + ",")
fun dict_reduce_left_symbolic(values: dict[int]): string = values.`|l>`("", (acc, key, value) => acc + key + ":" + value + ",")

fun seq_map_named(values: list[int]): list[int] = to_seq(values).map(x => x * 3).as_list()
fun seq_map_operator(values: list[int]): list[int] = (to_seq(values) | x => x * 3).as_list()

fun seq_flat_map_named(values: list[int]): list[int] = to_seq(values).flat_map(x => expand_seq(x)).as_list()
fun seq_flat_map_operator(values: list[int]): list[int] = (to_seq(values) |* x => expand_seq(x)).as_list()

fun seq_reduce_named(values: list[int]): int = to_seq(values).reduce(0, :sum_int)
fun seq_reduce_left_named(values: list[int]): int = to_seq(values).reduce_left(0, :sum_int)

fun string_filter_named(value: string): list[string] = value.filter(ch => ch == "b")
fun string_filter_symbolic(value: string): list[string] = value.`|-`(ch => ch == "b")

fun option_map_named(value: Option[string]): Option[string] = value.map(text => text + "!")
fun option_map_operator(value: Option[string]): Option[string] = value | text => text + "!"

fun option_filter_named(value: Option[string]): Option[string] = value.filter(text => text == "drop")
fun option_filter_operator(value: Option[string]): Option[string] = value |- text => text == "drop"

fun option_flat_map_named(value: Option[string]): Option[string] =
    value.flat_map(text => Some { value: text + "!" })

fun option_reduce_named(value: Option[string]): string =
    value.reduce("start:", (acc, inner) => acc + inner)
fun option_reduce_left_named(value: Option[string]): string =
    value.reduce_left("start:", (acc, inner) => acc + inner)

fun result_map_named(value: Result[int]): Result[string] =
    value.map(x => Success { value: "v=" + x })

fun result_map_operator(value: Result[int]): Result[string] =
    value | x => Success { value: "v=" + x }

fun result_flat_map_named(value: Result[int]): Result[string] =
    value.flat_map(:nested_success)

fun result_flat_map_operator(value: Result[int]): Result[string] =
    value |* :nested_success

fun result_reduce_named(value: Result[int]): string =
    value.reduce(x => "ok:" + x, err => "err:" + err)

fun result_reduce_operator(value: Result[int]): string =
    value |> (x => "ok:" + x, err => "err:" + err)

fun result_reduce_left_named(value: Result[int]): string =
    value.reduce_left(x => "ok:" + x, err => "err:" + err)
