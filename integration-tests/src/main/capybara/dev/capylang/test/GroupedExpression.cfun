from /capy/lang/Result import { *}

fun nested_pipe_in_match_branch(value: int): Result[int] =
    Success { value }
    | parsed => {
        match parsed with
        case int v when v > 0 -> {
            Success { v + 1 }
            | next => Success { next + 1 }
        }
        case _ -> Error { "invalid" }
    }
