fun static_dict(): dict[int] = {
    "one": 1,
    "two": 2,
    "three": 3,
}

fun empty_static_dict(): dict[int] = {:}

fun empty_static_dict_with_spaces(): dict[int] = { : }

fun static_dict_with_trailing_comma(): dict[int] = {
    "one": 1,
    "two": 2,
    "three": 3,
}

fun append(d: dict[int]): dict[int] = d + {
    "four": 4,
}

fun append_dict(left: dict[int], right: dict[int]): dict[int] = left + right

fun append_tuple(d: dict[int]): dict[int] = d + ("leet", 1337)

fun append_tuple_override(d: dict[int]): dict[int] = d + ("two", 200)

fun remove(d: dict[int]): dict[int] = d - "two"

fun remove_dict(left: dict[int], right: dict[int]): dict[int] = left - right

fun contains(d: dict[int], key: string): bool = d ? key

fun is_empty(d: dict[int]): bool = d.is_empty

fun size(d: dict[int]): int = d.size

data Entry {k: string, v: int}
fun dict_to_list(d: dict[int]): list[Entry] =
    d |> [], (acc, k, v) => acc + Entry {k:k, v:v}

fun dict_to_string(d: dict[int]): string =
    d
        |> "", (acc, k, v) =>
            if acc == ""
            then k + " " + v
            else acc + "," + k + " " + v
