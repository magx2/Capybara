type Seq[T] = Cons[T] | End
data Cons[T] { value: T, rest: Seq[T] }
single End

fun one_two_three(): Seq[int] =
    Cons { 1, Cons { 2, Cons { 3, End } } }

fun head_or_default(s: Seq[int], d: int): int =
    match s with
    case Cons { value, rest } -> value
    case End -> d

fun head_or_default_wildcard(s: Seq[int], d: int): int =
    match s with
    case Cons { value, _ } -> value
    case End -> d

fun first_fq_singleton(s: Seq[int]): /capy/lang/Option[int] =
    match s with
    case End -> /capy/lang/Option.None {}
    case Cons { value, _ } -> /capy/lang/Option.Some { value }

fun first_short_singleton(s: Seq[int]): /capy/lang/Option[int] =
    match s with
    case End -> None {}
    case Cons { value, _ } -> /capy/lang/Option.Some { value }

fun tail(s: Seq[int]): Seq[int] =
    match s with
    case Cons { value, rest } -> rest
    case End -> End

fun sum_first_two(s: Seq[int]): int =
    match s with
    case Cons { value, rest } -> value + head_or_default(rest, 0)
    case End -> 0

fun drop_local(s: Seq[int], n: int): Seq[int] =
    fun __drop(seq: Seq[int], left: int) =
        if left <= 0
        then seq
        else
            match seq with
            case End -> End
            case Cons { value, rest } -> __drop(rest, left - 1)
    __drop(s, n)

fun until_local(s: Seq[int], stop: int): Seq[int] =
    fun __until(seq: Seq[int], x: int) =
        match seq with
        case End -> End
        case Cons { value, rest } ->
            if value == x
            then End
            else Cons { value, __until(rest, x) }
    __until(s, stop)
