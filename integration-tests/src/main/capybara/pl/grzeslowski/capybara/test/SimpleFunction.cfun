fun classify(x: int): string =
    if (x > 0) then "positive" else "non-positive"

fun always_true(): bool = true

fun add(a: int, b: int): int = a + b

fun subtract(a: int, b: int): int = a - b

fun multiply(a: int, b: int): int = a * b

fun divide(a: int, b: int): int =
    a / {
        let x = if (b != 0) then b else 1
        x
    }

fun is_positive(x: int): bool = x > 0

fun greet(name: string): string = "Hello, " + name

fun double_then_classify(x: int): string =
    if (x * 2 > 0) then "positive" else "non-positive"

fun order_of_expression(a: int, b: int): int =
    {
        let x = (a-1) * b
        x + 1
    } * {
        let x = a + 1 * b
        x - 1
    }

fun power(x: int, y: int): int = x ** y
