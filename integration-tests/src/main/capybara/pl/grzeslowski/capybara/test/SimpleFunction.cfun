

fun divide(a: int, b: int): int =
    {
        let x = a * 2
        x
    } / {
        let x = if(b!=0) b else 1
        x
    }

fun some_if(x: int): int =
    if ({
        let a = x * 2
        a > 2
    }) {
        let a = x * x
        "I'm happy " + a + " " + a
       } else {
        let a = x / 2
        "I'm not happy " + a
        }

