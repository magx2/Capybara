from /pl/grzeslowski/capybara/test/local_visibility/PackageLocalSupport import { add_local_offset, make_local, identity_local, unwrap_number, LocalValue, LocalNumber }

fun child_can_use_local_members(x: int): int =
    let value: LocalValue = identity_local(make_local(x))
    unwrap_number(LocalNumber { value: add_local_offset(x) })
