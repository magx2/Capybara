from Pck1 import { * }
from Pck2 import { * } except { add }
from /pl/grzeslowski/capybara/imports2/Pck5 import { lvl_multiplier }

fun calculator(a: int, b: int, op: string) =
    if op == "+"
    then add(a,b)
    else if op == "-"
    then subtract(a,b)
    else if op == "*"
    then multiply(a,b)
    else if op == "/"
    then divide(a,b)
    else if op == "p3"
    then Pck3.foo_boo(a>10, a<20)
    else empty(a+b)

fun what_to_do(x: int) = Pck3.foo_boo(x>10, x<20)

fun x(a: int, b: int, op: string) = /pl/grzeslowski/capybara/imports2/Pck4.awesome(calculator(a,b,op))

fun y(a: int, b: int, op: string) = /pl/grzeslowski/capybara/imports2/Pck4.awesome(lvl_multiplier(calculator(a,b,op)))
