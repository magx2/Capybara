type MyResult[T] = Ok[T] | Fail
data Ok[T] { value: T }
data Fail { message: string }

fun MyResult[T].`|`(map: T -> MyResult[Y]): MyResult[Y] =
    match this with
    | Fail f => f
    | Ok o => map(o.value)

fun map_to_string(v: int): MyResult[string] = Ok { value: "v=" + v }

fun map_to_fail(v: int): MyResult[string] = Fail { message: "bad:" + v }

fun apply_mapper(r: MyResult[T], map: T -> MyResult[Y]): MyResult[Y] = r | map

fun propagate_fail(r: MyResult[T], map: T -> MyResult[Y]): MyResult[Y] = r | map
