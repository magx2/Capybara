fun map1(l: list[int]): list[int] =
    l | x => x * 2

fun map2(l: list[int]): list[int] =
    l
        | x => x * 2
        | x => x - 1

fun map3(l: list[int]): list[string] = l | x => "Hello " + x

fun filter1(l: list[int]): list[int] = l |- x => x > 0

fun filter2(l: list[int]): list[int] =
    l
        |- x => x > 2
        |- x => x == 1

fun reduce1(l: list[int]): int = l |> 0, (a,b) => a+b

fun reduce2(l: list[int]): int =
    l
        | x => x * 2
        |- x => x < 0
        |> 0, (a,b) => a+b

fun flatMap1(l: list[int]): list[int] = l |* x => [x, x+1, x+2]

fun flatMap2(l: list[int]): list[int] =
    l
        | x => x * 2
        |- x => x > 0
        |* x => [x, x+1, x+2]

fun setMap1(s: set[int]): set[int] = s | x => x * 2

fun setFilter1(s: set[int]): set[int] = s |- x => x > 0

fun setReduce1(s: set[int]): int = s |> 0, (a,b) => a+b

fun setFlatMap1(s: set[int]): set[int] = s |* x => {x, x+10}
