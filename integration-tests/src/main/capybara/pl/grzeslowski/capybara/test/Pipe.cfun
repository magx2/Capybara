fun map1(l: list[int]): list[int] =
    l | x => x * 2

fun map2(l: list[int]): list[int] =
    l
        | x => x * 2
        | x => x - 1

fun map3(l: list[int]): list[string] = l | x => "Hello " + x

fun filter1(l: list[int]): list[int] = l |- x => x > 0

fun filter2(l: list[int]): list[int] =
    l
        |- x => x > 2
        |- x => x == 1

fun reduce1(l: list[int]): int = l |> 0, (a,b) => a+b

fun reduce2(l: list[int]): int =
    l
        | x => x * 2
        |- x => x < 0
        |> 0, (a,b) => a+b

fun flatMap1(l: list[int]): list[int] = l |* x => [x, x+1, x+2]

fun flatMap2(l: list[int]): list[int] =
    l
        | x => x * 2
        |- x => x > 0
        |* x => [x, x+1, x+2]

fun setMap1(s: set[int]): set[int] = s | x => x * 2

fun setFilter1(s: set[int]): set[int] = s |- x => x > 0

fun setReduce1(s: set[int]): int = s |> 0, (a,b) => a+b

fun setFlatMap1(s: set[int]): set[int] = s |* x => {x, x+10}

data Value { x: int }

fun add(v: Value, x: int): Value = Value { x: v.x + x }

fun data_pipe(a: int, b: int, c: int): Value =
    Value { x: a }
        | v => add(v, b)
        | v => add(v, c)

type Boxed = IntBox | LongBox
data IntBox { value: int }
data LongBox { value: long }

fun keep_boxed(boxed: Boxed): Boxed = boxed

fun add_to_boxed(boxed: Boxed): Boxed =
    match boxed with
    | IntBox { value } => IntBox { value: value + 1 }
    | LongBox { value } => LongBox { value: value + 1L }

fun type_pipe_lambda(x: int): Boxed =
    IntBox { value: x }
        | b => keep_boxed(b)
        | b => add_to_boxed(b)

fun type_pipe_ref(x: int): Boxed =
    IntBox { value: x }
        | :keep_boxed
        | :add_to_boxed
