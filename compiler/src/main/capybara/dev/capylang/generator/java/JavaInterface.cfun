from /dev/capylang/generator/java/JavaInterfaceMethod import { JavaInterfaceMethod }
from /dev/capylang/generator/java/JavaMethod import { JavaMethod }
from /dev/capylang/generator/java/JavaType import { JavaType }

union JavaInterface =
    JavaNormalInterface
    | JavaSealedInterface

data JavaNormalInterface {
    name: JavaType,
    extendInterfaces: List[JavaType],
    comments: List[String],
    methods: List[JavaInterfaceMethod],
    defaultMethods: List[JavaMethod]
}

data JavaSealedInterface {
    name: JavaType,
    extendInterfaces: List[JavaType],
    comments: List[String],
    methods: List[JavaInterfaceMethod],
    permits: List[String],
    typeParameters: List[String],
    defaultMethods: List[JavaMethod]
}

fun JavaInterface.name(): JavaType =
    match this with
    case JavaNormalInterface { name, extendInterfaces, comments, methods, defaultMethods } -> name
    case JavaSealedInterface { name, extendInterfaces, comments, methods, permits, typeParameters, defaultMethods } -> name

fun JavaInterface.extend_interfaces(): List[JavaType] =
    match this with
    case JavaNormalInterface { name, extendInterfaces, comments, methods, defaultMethods } -> extendInterfaces
    case JavaSealedInterface { name, extendInterfaces, comments, methods, permits, typeParameters, defaultMethods } -> extendInterfaces

fun JavaInterface.methods(): List[JavaInterfaceMethod] =
    match this with
    case JavaNormalInterface { name, extendInterfaces, comments, methods, defaultMethods } -> methods
    case JavaSealedInterface { name, extendInterfaces, comments, methods, permits, typeParameters, defaultMethods } -> methods

fun JavaInterface.default_methods(): List[JavaMethod] =
    match this with
    case JavaNormalInterface { name, extendInterfaces, comments, methods, defaultMethods } -> defaultMethods
    case JavaSealedInterface { name, extendInterfaces, comments, methods, permits, typeParameters, defaultMethods } -> defaultMethods
