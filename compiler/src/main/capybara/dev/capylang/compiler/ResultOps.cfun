from /capy/collection/List import { * }
from /capy/lang/Result import { * }
from /dev/capylang/compiler/Results import { * }

fun error(result: Result[T]): Result[Y] =
    result.reduce(_ => error(""), message => error(message))

fun map(result: Result[T], mapper: T => Y): Result[Y] =
    map_success(result, mapper)

fun flat_map(result: Result[T], mapper: T => Result[Y]): Result[Y] =
    flat_map_success(result, mapper)

fun join(function: (A, B) => C, a: Result[A], b: Result[B]): Result[C] =
    a.reduce(
        left => map(b, right => function(left, right)),
        left_error => b.reduce(
            _ => error(left_error),
            right_error => error([left_error, right_error])
        )
    )
