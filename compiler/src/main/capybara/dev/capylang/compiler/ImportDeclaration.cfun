from /capy/collection/List import { * }
from /capy/collection/Set import { * }

data ImportDeclaration {
    moduleName: String,
    symbols: List[String],
    excludedSymbols: List[String],
    qualifiedOnly: bool
}

fun ImportDeclaration.isStarImport(): bool =
    this.symbols.contains("*")

fun ImportDeclaration.selectedSymbols(availableSymbols: Set[String]): Set[String] =
    let selected =
        if this.isStarImport()
        then availableSymbols
        else import_declaration_set_from_list(this.symbols, 0, {})
    selected - import_declaration_set_from_list(this.excludedSymbols, 0, {})

private fun import_declaration_set_from_list(values: List[String], idx: int, acc: Set[String]): Set[String] =
    match values[idx] with
    case Some { value } -> import_declaration_set_from_list(values, idx + 1, acc + value)
    case _ -> acc
