from /capy/lang/Option import { * }
from /capy/lang/String import { * }
from /capy/collection/List import { * }
from /dev/capylang/compiler/CompiledAnnotation import { CompiledAnnotation }
from /dev/capylang/compiler/CompiledAnnotationArgument import { CompiledAnnotationArgument }
from /dev/capylang/compiler/CompiledAnnotationValue import { CompiledAnnotationValue, StringValue }

const NATIVE_PROVIDER_ANNOTATION_NAME = "NativeProvider"
const NATIVE_PROVIDER_ANNOTATION_MODULE_NAME = "NativeProvider"
const NATIVE_PROVIDER_ANNOTATION_MODULE_PATH = "capy/meta_prog"

fun is_native_provider_annotation(annotation: CompiledAnnotation): bool =
    is_annotation(
        annotation,
        NATIVE_PROVIDER_ANNOTATION_NAME,
        NATIVE_PROVIDER_ANNOTATION_MODULE_NAME,
        NATIVE_PROVIDER_ANNOTATION_MODULE_PATH
    )

fun string_argument(annotation: CompiledAnnotation, name: String): Option[String] =
    string_argument_scan(annotation.arguments, name, 0)

private fun string_argument_scan(arguments: List[CompiledAnnotationArgument], name: String, idx: int): Option[String] =
    match arguments[idx] with
    case Some { argument } ->
        if argument.name == name
        then match argument.value with
            case StringValue { value } -> Some { annotation_string_literal_value(value) }
            case _ -> string_argument_scan(arguments, name, idx + 1)
        else string_argument_scan(arguments, name, idx + 1)
    case _ -> None {}

private fun is_annotation(annotation: CompiledAnnotation, name: String, module_name: String, module_path: String): bool =
    name == annotation.name
    & module_name == annotation.packageName
    & module_path == native_annotations_normalized_module_path(annotation.packagePath)

private fun native_annotations_normalized_module_path(path: String): String =
    native_annotations_strip_slashes(path.replace("\\", "/"))

private fun native_annotations_strip_slashes(path: String): String =
    native_annotations_strip_trailing_slashes(native_annotations_strip_leading_slashes(path))

private fun native_annotations_strip_leading_slashes(path: String): String =
    match path[0] with
    case Some { char } ->
        if char == "/"
        then native_annotations_strip_leading_slashes(path[1, path.size()])
        else path
    case _ -> path

private fun native_annotations_strip_trailing_slashes(path: String): String =
    if path.size().value > 0 & path[path.size().value - 1] == Some { "/" }
    then native_annotations_strip_trailing_slashes(path[0, path.size().value - 1])
    else path

private fun annotation_string_literal_value(value: String): String =
    if value.size().value >= 2 & value[0] == Some { "\"" } & value[value.size().value - 1] == Some { "\"" }
    then value[1, value.size().value - 1]
    else value
