from /capy/collection/List import { * }
from /capy/lang/Option import { * }
from /dev/capylang/compiler/CompiledAnnotation import { CompiledAnnotation }
from /dev/capylang/compiler/parser/InfixOperator import { InfixOperator }
from /dev/capylang/compiler/parser/SourcePosition import { SourcePosition }

data CompiledExpressionIr { marker: String }

union CompiledType =
    PrimitiveLinkedType
    | CompiledDataParentType
    | CompiledFunctionType
    | CompiledObjectType
    | CompiledTupleType

data PrimitiveLinkedType { name: String }
data CompiledDataParentType {}
data CompiledFunctionType {}
data CompiledObjectType {}
data CompiledTupleType {}

const BYTE: PrimitiveLinkedType = PrimitiveLinkedType { name: "BYTE" }
const INT: PrimitiveLinkedType = PrimitiveLinkedType { name: "INT" }
const LONG: PrimitiveLinkedType = PrimitiveLinkedType { name: "LONG" }
const FLOAT: PrimitiveLinkedType = PrimitiveLinkedType { name: "FLOAT" }
const DOUBLE: PrimitiveLinkedType = PrimitiveLinkedType { name: "DOUBLE" }
const STRING: PrimitiveLinkedType = PrimitiveLinkedType { name: "STRING" }
const BOOL: PrimitiveLinkedType = PrimitiveLinkedType { name: "BOOL" }
const NOTHING: PrimitiveLinkedType = PrimitiveLinkedType { name: "NOTHING" }
const ANY: PrimitiveLinkedType = PrimitiveLinkedType { name: "ANY" }

union CompiledExpression =
    CompiledBooleanValue
    | CompiledByteValue
    | CompiledDoubleValue
    | CompiledEffectBindExpression
    | CompiledEffectExpression
    | CompiledFieldAccess
    | CompiledFloatValue
    | CompiledFunctionCall
    | CompiledFunctionInvoke
    | CompiledIfExpression
    | CompiledIndexExpression
    | CompiledInfixExpression
    | CompiledIntValue
    | CompiledLambdaExpression
    | CompiledLetExpression
    | CompiledLongValue
    | CompiledMatchExpression
    | CompiledNothingValue
    | CompiledNumericWidening
    | CompiledObjectConstruction
    | CompiledPipeFlatMapExpression
    | CompiledPipeFilterOutExpression
    | CompiledPipeExpression
    | CompiledPipeReduceExpression
    | CompiledReflectionValue
    | CompiledSliceExpression
    | CompiledTupleExpression
    | CompiledUnwrapExpression
    | CompiledNewDict
    | CompiledNewList
    | CompiledNewSet
    | CompiledNewData
    | CompiledStringValue
    | CompiledVariable

union CompiledPattern =
    CompiledIntPattern
    | CompiledLongPattern
    | CompiledStringPattern
    | CompiledBoolPattern
    | CompiledFloatPattern
    | CompiledTypedPattern
    | CompiledVariablePattern
    | CompiledWildcardPattern
    | CompiledWildcardBindingPattern
    | CompiledConstructorPattern

data CompiledBooleanValue { value: bool }
data CompiledByteValue { byteValue: String }
data CompiledDoubleValue { doubleValue: String }
data CompiledEffectBindExpression {
    name: String,
    source: CompiledExpression,
    payloadType: CompiledType,
    letType: CompiledType,
    declaredType: Option[CompiledType],
    rest: CompiledExpression,
    effectType: CompiledDataParentType
}
data CompiledEffectExpression {
    body: CompiledExpression,
    effectType: CompiledDataParentType
}
data CompiledFieldAccess {
    source: CompiledExpression,
    field: String,
    type: CompiledType
}
data CompiledFloatValue { floatValue: String }
data CompiledFunctionCall {
    name: String,
    arguments: List[CompiledExpression],
    returnType: CompiledType
}
data CompiledFunctionInvoke {
    function: CompiledExpression,
    arguments: List[CompiledExpression],
    returnType: CompiledType
}
data CompiledIfExpression {
    condition: CompiledExpression,
    thenBranch: CompiledExpression,
    elseBranch: CompiledExpression,
    type: CompiledType
}
data CompiledIndexExpression {
    source: CompiledExpression,
    index: CompiledExpression,
    elementType: CompiledType,
    type: CompiledType
}
data CompiledInfixExpression {
    left: CompiledExpression,
    operator: InfixOperator,
    right: CompiledExpression,
    type: CompiledType
}
data CompiledIntValue { intValue: String }
data CompiledLambdaExpression {
    argumentName: String,
    expression: CompiledExpression,
    functionType: CompiledFunctionType
}
data CompiledLetExpression {
    name: String,
    value: CompiledExpression,
    declaredType: Option[CompiledType],
    rest: CompiledExpression
}
data CompiledLongValue { longValue: String }
data CompiledMatchExpression {
    matchWith: CompiledExpression,
    cases: List[CompiledMatchCase],
    type: CompiledType
}
data CompiledNothingValue {
    position: Option[SourcePosition],
    message: String
}
data CompiledNumericWidening {
    expression: CompiledExpression,
    type: CompiledType
}
data CompiledObjectConstruction {
    objectType: CompiledObjectType,
    arguments: List[CompiledExpression],
    effectType: CompiledDataParentType
}
data CompiledPipeFlatMapExpression {
    source: CompiledExpression,
    argumentName: String,
    mapper: CompiledExpression,
    type: CompiledType
}
data CompiledPipeFilterOutExpression {
    source: CompiledExpression,
    argumentName: String,
    predicate: CompiledExpression,
    type: CompiledType
}
data CompiledPipeExpression {
    source: CompiledExpression,
    argumentName: String,
    mapper: CompiledExpression,
    type: CompiledType
}
data CompiledPipeReduceExpression {
    source: CompiledExpression,
    initialValue: CompiledExpression,
    accumulatorName: String,
    keyName: Option[String],
    valueName: String,
    reducerExpression: CompiledExpression,
    type: CompiledType
}
data CompiledReflectionField {
    name: String,
    type: CompiledType,
    annotations: List[CompiledAnnotation]
}
data CompiledReflectionValue {
    target: CompiledExpression,
    name: String,
    packageName: String,
    packagePath: String,
    fields: List[CompiledReflectionField],
    annotations: List[CompiledAnnotation],
    type: CompiledType
}
data CompiledSliceExpression {
    source: CompiledExpression,
    start: Option[CompiledExpression],
    end: Option[CompiledExpression],
    type: CompiledType
}
data CompiledTupleExpression {
    values: List[CompiledExpression],
    type: CompiledType
}
data CompiledUnwrapExpression {
    expression: CompiledExpression,
    type: CompiledType
}
data CompiledNewDictEntry {
    key: CompiledExpression,
    value: CompiledExpression
}
data CompiledNewDict {
    entries: List[CompiledNewDictEntry],
    type: CompiledType
}
data CompiledNewList {
    values: List[CompiledExpression],
    type: CompiledType
}
data CompiledNewSet {
    values: List[CompiledExpression],
    type: CompiledType
}
data CompiledNewDataFieldAssignment {
    name: String,
    value: CompiledExpression
}
data CompiledNewData {
    type: CompiledType,
    assignments: List[CompiledNewDataFieldAssignment]
}
data CompiledStringValue { stringValue: String }
data CompiledVariable {
    name: String,
    type: CompiledType,
    emptyShapeCompatible: bool
}

data CompiledMatchCase {
    pattern: CompiledPattern,
    guard: Option[CompiledExpression],
    expression: CompiledExpression
}
data CompiledIntPattern { value: String }
data CompiledLongPattern { value: String }
data CompiledStringPattern { value: String }
data CompiledBoolPattern { value: String }
data CompiledFloatPattern { value: String }
data CompiledTypedPattern {
    type: CompiledType,
    name: String
}
data CompiledVariablePattern { name: String }
data CompiledWildcardPattern {}
data CompiledWildcardBindingPattern { name: String }
data CompiledConstructorPattern {
    constructorName: String,
    fieldPatterns: List[CompiledPattern]
}

fun CompiledExpression.type(): CompiledType =
    compiledExpressionType(this)

fun compiledExpressionType(expression: CompiledExpression): CompiledType =
    match expression with
    case CompiledBooleanValue { value } -> BOOL
    case CompiledByteValue { byteValue } -> BYTE
    case CompiledDoubleValue { doubleValue } -> DOUBLE
    case CompiledEffectBindExpression { name, source, payloadType, letType, declaredType, rest, effectType } -> effectType
    case CompiledEffectExpression { body, effectType } -> effectType
    case CompiledFieldAccess { source, field, type } -> type
    case CompiledFloatValue { floatValue } -> FLOAT
    case CompiledFunctionCall { name, arguments, returnType } -> returnType
    case CompiledFunctionInvoke { function, arguments, returnType } -> returnType
    case CompiledIfExpression { condition, thenBranch, elseBranch, type } -> type
    case CompiledIndexExpression { source, index, elementType, type } -> type
    case CompiledInfixExpression { left, operator, right, type } -> type
    case CompiledIntValue { intValue } -> INT
    case CompiledLambdaExpression { argumentName, expression, functionType } -> functionType
    case CompiledLetExpression { name, value, declaredType, rest } -> compiledExpressionType(rest)
    case CompiledLongValue { longValue } -> LONG
    case CompiledMatchExpression { matchWith, cases, type } -> type
    case CompiledNothingValue { position, message } -> NOTHING
    case CompiledNumericWidening { expression, type } -> type
    case CompiledObjectConstruction { objectType, arguments, effectType } -> effectType
    case CompiledPipeFlatMapExpression { source, argumentName, mapper, type } -> type
    case CompiledPipeFilterOutExpression { source, argumentName, predicate, type } -> type
    case CompiledPipeExpression { source, argumentName, mapper, type } -> type
    case CompiledPipeReduceExpression { source, initialValue, accumulatorName, keyName, valueName, reducerExpression, type } -> type
    case CompiledReflectionValue { target, name, packageName, packagePath, fields, annotations, type } -> type
    case CompiledSliceExpression { source, start, end, type } -> type
    case CompiledTupleExpression { values, type } -> type
    case CompiledUnwrapExpression { expression, type } -> type
    case CompiledNewDict { entries, type } -> type
    case CompiledNewList { values, type } -> type
    case CompiledNewSet { values, type } -> type
    case CompiledNewData { type, assignments } -> type
    case CompiledStringValue { stringValue } -> STRING
    case CompiledVariable { name, type, emptyShapeCompatible } -> type

fun compiledExpressionSourcePosition(expression: CompiledExpression): Option[SourcePosition] =
    match expression with
    case CompiledNothingValue { position, message } -> position
    case _ -> None {}

fun compiledExpressionLiteralString(expression: CompiledExpression): String =
    match expression with
    case CompiledBooleanValue { value } -> if value then "true" else "false"
    case CompiledByteValue { byteValue } -> byteValue
    case CompiledDoubleValue { doubleValue } -> doubleValue
    case CompiledFloatValue { floatValue } -> floatValue
    case CompiledIntValue { intValue } -> intValue
    case CompiledLongValue { longValue } -> longValue
    case CompiledStringValue { stringValue } -> stringValue
    case _ -> "" + expression

fun compiledMatchCasesAreNonEmpty(cases: List[CompiledMatchCase]): bool =
    !cases.is_empty()

fun compiledVariable(name: String, type: CompiledType): CompiledVariable =
    CompiledVariable { name, type, emptyShapeCompatible: false }

fun compiledBooleanValue(value: bool): CompiledBooleanValue =
    CompiledBooleanValue { value }

fun compiledMatchExpression(matchWith: CompiledExpression, cases: List[CompiledMatchCase]): CompiledMatchExpression =
    CompiledMatchExpression { matchWith, cases, type: ANY }

fun compiledMatchExpression(matchWith: CompiledExpression, cases: List[CompiledMatchCase], type: CompiledType): CompiledMatchExpression =
    CompiledMatchExpression { matchWith, cases, type }

fun CompiledBooleanValue.name(): String =
    if this.value then "TRUE" else "FALSE"

fun CompiledBooleanValue.to_string(): String =
    compiledExpressionLiteralString(this)

fun CompiledByteValue.to_string(): String =
    this.byteValue

fun CompiledDoubleValue.to_string(): String =
    this.doubleValue

fun CompiledFloatValue.to_string(): String =
    this.floatValue

fun CompiledIntValue.to_string(): String =
    this.intValue

fun CompiledLongValue.to_string(): String =
    this.longValue

fun CompiledStringValue.to_string(): String =
    this.stringValue
