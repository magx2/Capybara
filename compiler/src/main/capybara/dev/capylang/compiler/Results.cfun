from /capy/collection/List import { * }
from /capy/lang/Result import { * }

fun success(value: T): Result[T] = Success { value }

fun error(message: String): Result[T] = Error { message }

fun error(messages: List[String]): Result[T] = Error { combine_error_messages(messages) }

private fun combine_error_messages(messages: List[String]): String =
    messages.reduce("", (acc, message) =>
        if acc == "" then message else acc + "\n" + message)

fun error_message(result: Result[T]): String =
    result.reduce(_ => "", message => message)

fun map_success(result: Result[T], mapper: T => Y): Result[Y] =
    result.reduce(value => success(mapper(value)), message => error(message))

fun flat_map_success(result: Result[T], mapper: T => Result[Y]): Result[Y] =
    result.reduce(value => mapper(value), message => error(message))
