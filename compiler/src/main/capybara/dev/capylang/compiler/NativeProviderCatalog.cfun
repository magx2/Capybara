from /capy/collection/List import { * }
from /dev/capylang/compiler/CompiledNativeProviderBinding import { CompiledNativeProviderBinding }
from /dev/capylang/compiler/CompiledNativeProviderDeclaration import { CompiledNativeProviderDeclaration }

data NativeProviderCatalog {
    declarations: List[CompiledNativeProviderDeclaration],
    bindings: List[CompiledNativeProviderBinding]
}

fun nativeProviderCatalogEmpty(catalog: NativeProviderCatalog): bool =
    catalog.declarations.is_empty() & catalog.bindings.is_empty()
