union CompiledAnnotationValue =
    StringValue
    | IntValue
    | LongValue
    | FloatValue
    | DoubleValue
    | BoolValue
    | NothingValue
    | TypeNameValue

data StringValue { value: String }
data IntValue { value: String }
data LongValue { value: String }
data FloatValue { value: String }
data DoubleValue { value: String }
data BoolValue { value: bool }
data NothingValue {}
data TypeNameValue { name: String }
