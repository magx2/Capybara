/// Tuple DTOs keep this generated compiler-main pass independent of the Capybara stdlib runtime.
data String { <native> }
data List[T] { <native> }

fun String.`+`(value: any): String = <native>
fun List[T].`+`(value: T): List[T] = <native>

fun List[T].contains(value: T): bool =
    this.any(item => item == value)

fun List[T].any(predicate: T => bool): bool =
    fun scan(values: List[T], idx: int, predicate: T => bool): bool =
        match values[idx] with
        case Some { value } ->
            if predicate(value)
            then true
            else scan(values, idx + 1, predicate)
        case _ -> false
    ---
    scan(this, 0, predicate)

fun List[T].reduce(initial: R, reducer: (R, T) => R): R =
    fun scan(values: List[T], idx: int, acc: R, reducer: (R, T) => R): R =
        match values[idx] with
        case Some { value } -> scan(values, idx + 1, reducer(acc, value), reducer)
        case _ -> acc
    ---
    scan(this, 0, initial, reducer)

fun normalize_module_path(module_path: String): String =
    fun scan(value: String, idx: int, output: String, current: String): String =
        match value[idx] with
        case Some { char } ->
            if is_path_separator(char)
            then scan(value, idx + 1, append_module_path_part(output, current), "")
            else scan(value, idx + 1, output, current + char)
        case _ -> append_module_path_part(output, current)
    ---
    scan(module_path, 0, "", "")

fun canonical_module_identity(path: String, name: String): String =
    let normalized_path = normalize_module_path(path)
    if string_is_empty(normalized_path)
    then name
    else normalized_path + "/" + name

fun module_key(path: String, name: String): String =
    let normalized_path = normalize_module_path(path)
    if string_is_empty(normalized_path) | normalized_path == "."
    then name
    else normalized_path + "/" + name

fun source_kind_from_file_name(file_name: String): Tuple[bool, String, String] =
    if string_ends_with(file_name, ".cfun")
    then success("FUNCTIONAL")
    else if string_ends_with(file_name, ".coo")
        then success("OBJECT_ORIENTED")
        else failure("Unknown source kind for file `" + file_name + "`")

fun strip_known_extension(file_name: String): String =
    if string_ends_with(file_name, ".cfun")
    then file_name[0, string_size(file_name) - string_size(".cfun")]
    else if string_ends_with(file_name, ".coo")
        then file_name[0, string_size(file_name) - string_size(".coo")]
        else file_name

fun source_kind_extension(source_kind: String): String =
    if source_kind == "FUNCTIONAL"
    then ".cfun"
    else ".coo"

fun source_kind_file_name(source_kind: String, module_name: String): String =
    module_name + source_kind_extension(source_kind)

fun module_file(source_kind: String, path: String, module_name: String): String =
    let normalized_path = replace_path_separators(path)
    let absolute_path = if string_starts_with(normalized_path, "/") then normalized_path else "/" + normalized_path
    absolute_path + "/" + source_kind_file_name(source_kind, module_name)

fun module_ref(name: String, path: String): Tuple[String, String] =
    (name, path)

fun import_declaration(
    module_name: String,
    symbols: List[String],
    excluded_symbols: List[String],
    qualified_only: bool
): Tuple[String, List[String], List[String], bool] =
    (module_name, symbols, excluded_symbols, qualified_only)

fun module_member(name: String, visibility: String, kind: String): Tuple[String, String, String] =
    (name, visibility, kind)

fun module_descriptor(
    module: Tuple[String, String],
    members: List[Tuple[String, String, String]],
    linked_type_names: List[String],
    owner_type_shape: String,
    helper_class_required: bool,
    imports: List[Tuple[String, List[String], List[String], bool]]
): Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]] =
    (module, members, linked_type_names, owner_type_shape, helper_class_required, imports)

fun build_module_link_index(
    modules: List[Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]]
): Tuple[
    bool,
    Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ],
    String
] =
    (true, build_module_link_index_unchecked(modules), "")

fun build_module_link_index_unchecked(
    modules: List[Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]]
): Tuple[
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[String],
    List[Tuple[String, List[String]]],
    List[Tuple[String, String]]
] =
    build_module_link_index_scan(modules, 0, empty_module_link_index())

fun resolve_imported_module(
    raw_imported_module_name: String,
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): Tuple[bool, Tuple[String, String]] =
    match get_entry(index_modules_by_exact_name(index), raw_imported_module_name) with
    case Some { direct } -> (true, direct)
    case _ ->
        let normalized = replace_path_separators(raw_imported_module_name)
        let normalized_qualified = normalize_module_path(normalized)
        match get_entry(index_modules_by_qualified_name(index), normalized_qualified) with
        case Some { qualified } -> (true, qualified)
        case _ ->
            let slash_tail = tail_after_last_or_empty(normalized, "/")
            if string_is_empty(slash_tail)
            then resolve_imported_module_by_dot_tail(normalized, index)
            else
                match get_entry(index_modules_by_tail_name(index), slash_tail) with
                case Some { by_tail } -> (true, by_tail)
                case _ -> resolve_imported_module_by_dot_tail(normalized, index)

fun build_declaration_index(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): Tuple[
    bool,
    Tuple[
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]]
    ],
    String
] =
    (true, build_declaration_index_scan(module_descriptor_members(descriptor), 0, empty_declaration_index()), "")

fun validate_import_selection(
    module_name: String,
    import_declaration: Tuple[String, List[String], List[String], bool],
    available_symbols: List[String]
): Tuple[bool, List[String], String] =
    match first_unknown(import_declaration_excluded_symbols(import_declaration), available_symbols) with
    case Some { excluded_symbol } ->
        (false, [], "Module `" + module_name + "` excludes unknown symbol `" + excluded_symbol
            + "` from module `" + import_declaration_module_name(import_declaration) + "`")
    case _ ->
        if is_star_import(import_declaration)
        then (true, selected_symbols(import_declaration, available_symbols), "")
        else
            match first_unknown(import_declaration_symbols(import_declaration), available_symbols) with
            case Some { symbol } ->
                (false, [], "Module `" + module_name + "` imports unknown symbol `" + symbol
                    + "` from module `" + import_declaration_module_name(import_declaration) + "`")
            case _ -> (true, selected_symbols(import_declaration, available_symbols), "")

fun selected_symbols(import_declaration: Tuple[String, List[String], List[String], bool], available_symbols: List[String]): List[String] =
    let source_symbols = if is_star_import(import_declaration) then available_symbols else import_declaration_symbols(import_declaration)
    source_symbols.reduce([], (selected, symbol) =>
        if import_declaration_excluded_symbols(import_declaration).contains(symbol) | selected.contains(symbol)
        then selected
        else selected + symbol)

fun visible_members(
    current_module_path: String,
    owner_module: Tuple[String, String],
    members: List[Tuple[String, String, String]]
): List[Tuple[String, String, String]] =
    members.reduce([], (visible, member) =>
        if is_visible_from_module(current_module_path, module_path(owner_module), module_member_visibility(member))
        then visible + member
        else visible)

fun is_visible_from_module(current_module_path: String, owner_module_path: String, visibility: String): bool =
    let current = normalize_module_path(current_module_path)
    let owner = normalize_module_path(owner_module_path)
    match visibility with
    case "PUBLIC" -> true
    case "LOCAL" -> current == owner | string_starts_with(current, owner + "/")
    case _ -> current == owner

private fun success(value: T): Tuple[bool, T, String] =
    (true, value, "")

private fun failure(message: String): Tuple[bool, String, String] =
    (false, "", message)

private fun module_name(module: Tuple[String, String]): String =
    module[0]

private fun module_path(module: Tuple[String, String]): String =
    module[1]

private fun module_descriptor_module(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): Tuple[String, String] =
    descriptor[0]

private fun module_descriptor_members(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): List[Tuple[String, String, String]] =
    descriptor[1]

private fun module_descriptor_linked_type_names(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): List[String] =
    descriptor[2]

private fun module_descriptor_owner_type_shape(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): String =
    descriptor[3]

private fun module_descriptor_helper_class_required(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): bool =
    descriptor[4]

private fun import_declaration_module_name(import_declaration: Tuple[String, List[String], List[String], bool]): String =
    import_declaration[0]

private fun import_declaration_symbols(import_declaration: Tuple[String, List[String], List[String], bool]): List[String] =
    import_declaration[1]

private fun import_declaration_excluded_symbols(import_declaration: Tuple[String, List[String], List[String], bool]): List[String] =
    import_declaration[2]

private fun module_member_name(member: Tuple[String, String, String]): String =
    member[0]

private fun module_member_visibility(member: Tuple[String, String, String]): String =
    member[1]

private fun module_member_kind(member: Tuple[String, String, String]): String =
    member[2]

private fun entry_key(entry: Tuple[String, T]): String =
    entry[0]

private fun entry_value(entry: Tuple[String, T]): T =
    entry[1]

private fun index_modules_by_exact_name(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[Tuple[String, Tuple[String, String]]] =
    index[0]

private fun index_modules_by_qualified_name(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[Tuple[String, Tuple[String, String]]] =
    index[1]

private fun index_modules_by_tail_name(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[Tuple[String, Tuple[String, String]]] =
    index[2]

private fun index_ambiguous_tail_names(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[String] =
    index[3]

private fun index_linked_types_by_module_name(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[Tuple[String, List[String]]] =
    index[4]

private fun index_module_java_class_name_by_module_name(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): List[Tuple[String, String]] =
    index[5]

private fun append_module_path_part(output: String, current: String): String =
    if string_is_blank(current) | current == "."
    then output
    else if string_is_empty(output)
        then current
        else output + "/" + current

private fun is_path_separator(char: String): bool =
    char == "/" | char == '\\'

private fun replace_path_separators(path: String): String =
    fun scan(value: String, idx: int, output: String): String =
        match value[idx] with
        case Some { char } ->
            if char == '\\'
            then scan(value, idx + 1, output + "/")
            else scan(value, idx + 1, output + char)
        case _ -> output
    ---
    scan(path, 0, "")

private fun empty_module_link_index(): Tuple[
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[String],
    List[Tuple[String, List[String]]],
    List[Tuple[String, String]]
] =
    ([], [], [], [], [], [])

private fun build_module_link_index_scan(
    modules: List[Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]],
    idx: int,
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): Tuple[
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[String],
    List[Tuple[String, List[String]]],
    List[Tuple[String, String]]
] =
    match modules[idx] with
    case Some { descriptor } -> build_module_link_index_scan(modules, idx + 1, add_module_to_link_index(index, descriptor))
    case _ -> index

private fun add_module_to_link_index(
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ],
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): Tuple[
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[Tuple[String, Tuple[String, String]]],
    List[String],
    List[Tuple[String, List[String]]],
    List[Tuple[String, String]]
] =
    let module = module_descriptor_module(descriptor)
    let exact = put_entry_if_absent(index_modules_by_exact_name(index), module_name(module), module)
    let qualified_name = qualified_module_name(module)
    let qualified = put_entry_if_absent(index_modules_by_qualified_name(index), qualified_name, module)
    let tail_update = add_tail_module(index_modules_by_tail_name(index), index_ambiguous_tail_names(index), module)
    let linked_types_by_module_name = put_imported_entry(index_linked_types_by_module_name(index), module, module_descriptor_linked_type_names(descriptor))
    let module_java_class_name_by_module_name = put_imported_entry(index_module_java_class_name_by_module_name(index), module, module_java_class_name(descriptor))
    (exact, qualified, tail_update[0], tail_update[1], linked_types_by_module_name, module_java_class_name_by_module_name)

private fun add_tail_module(
    modules_by_tail_name: List[Tuple[String, Tuple[String, String]]],
    ambiguous_tail_names: List[String],
    module: Tuple[String, String]
): Tuple[List[Tuple[String, Tuple[String, String]]], List[String]] =
    let tail_name = module_tail_name(module)
    if string_is_empty(tail_name)
    then (modules_by_tail_name, ambiguous_tail_names)
    else if ambiguous_tail_names.contains(tail_name)
        then (modules_by_tail_name, ambiguous_tail_names)
        else
            match get_entry(modules_by_tail_name, tail_name) with
            case Some { existing } ->
                if existing == module
                then (modules_by_tail_name, ambiguous_tail_names)
                else (remove_entry(modules_by_tail_name, tail_name), append_distinct(ambiguous_tail_names, tail_name))
            case _ -> (put_entry_if_absent(modules_by_tail_name, tail_name, module), ambiguous_tail_names)

private fun qualified_module_name(module: Tuple[String, String]): String =
    let normalized_path = normalize_module_path(module_path(module))
    if normalized_path == "." | string_is_empty(normalized_path)
    then module_name(module)
    else normalized_path + "/" + module_name(module)

private fun module_tail_name(module: Tuple[String, String]): String =
    tail_after_last_or_empty(qualified_module_name(module), "/")

private fun module_java_class_name(
    descriptor: Tuple[Tuple[String, String], List[Tuple[String, String, String]], List[String], String, bool, List[Tuple[String, List[String], List[String], bool]]]
): String =
    let module = module_descriptor_module(descriptor)
    let base_class_name = replace_char(replace_char(module_path(module), "/", "."), "\\", ".") + "." + module_name(module)
    let owner_type_shape = module_descriptor_owner_type_shape(descriptor)
    if owner_type_shape == "NONE" | owner_type_shape == "PARENT_NON_ENUM" | owner_type_shape == "DATA_NATIVE"
    then base_class_name
    else if module_descriptor_helper_class_required(descriptor)
        then base_class_name + "Module"
        else base_class_name

private fun resolve_imported_module_by_dot_tail(
    normalized: String,
    index: Tuple[
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[Tuple[String, Tuple[String, String]]],
        List[String],
        List[Tuple[String, List[String]]],
        List[Tuple[String, String]]
    ]
): Tuple[bool, Tuple[String, String]] =
    let dot_tail = tail_after_last_or_empty(normalized, ".")
    if string_is_empty(dot_tail)
    then (false, ("", ""))
    else
        match get_entry(index_modules_by_tail_name(index), dot_tail) with
        case Some { by_dot_tail } -> (true, by_dot_tail)
        case _ -> (false, ("", ""))

private fun tail_after_last_or_empty(value: String, separator: String): String =
    fun scan(value: String, separator: String, idx: int, last_separator_idx: int): String =
        match value[idx] with
        case Some { char } ->
            if char == separator
            then scan(value, separator, idx + 1, idx)
            else scan(value, separator, idx + 1, last_separator_idx)
        case _ ->
            if last_separator_idx < 0 | last_separator_idx >= string_size(value) - 1
            then ""
            else value[last_separator_idx + 1, string_size(value)]
    ---
    scan(value, separator, 0, -1)

private fun is_star_import(import_declaration: Tuple[String, List[String], List[String], bool]): bool =
    import_declaration_symbols(import_declaration).contains("*")

private fun first_unknown(symbols: List[String], available_symbols: List[String]): Option[String] =
    fun scan(symbols: List[String], available_symbols: List[String], idx: int): Option[String] =
        match symbols[idx] with
        case Some { symbol } ->
            if available_symbols.contains(symbol)
            then scan(symbols, available_symbols, idx + 1)
            else Some { symbol }
        case _ -> None {}
    ---
    scan(symbols, available_symbols, 0)

private fun empty_declaration_index(): Tuple[
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]]
] =
    ([], [], [], [])

private fun build_declaration_index_scan(
    members: List[Tuple[String, String, String]],
    idx: int,
    index: Tuple[
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]]
    ]
): Tuple[
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]]
] =
    match members[idx] with
    case Some { member } -> build_declaration_index_scan(members, idx + 1, add_member_to_declaration_index(index, member))
    case _ -> index

private fun add_member_to_declaration_index(
    index: Tuple[
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]],
        List[Tuple[String, List[Tuple[String, String, String]]]]
    ],
    member: Tuple[String, String, String]
): Tuple[
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]],
    List[Tuple[String, List[Tuple[String, String, String]]]]
] =
    let kind = module_member_kind(member)
    match kind with
    case "FUNCTION" -> (append_member(index[0], member), index[1], index[2], index[3])
    case "TYPE" -> (index[0], append_member(index[1], member), index[2], index[3])
    case "DERIVER" -> (index[0], index[1], append_member(index[2], member), index[3])
    case _ -> (index[0], index[1], index[2], append_member(index[3], member))

private fun append_member(
    entries: List[Tuple[String, List[Tuple[String, String, String]]]],
    member: Tuple[String, String, String]
): List[Tuple[String, List[Tuple[String, String, String]]]] =
    match get_entry(entries, module_member_name(member)) with
    case Some { current } -> put_entry(entries, module_member_name(member), current + member)
    case _ -> put_entry(entries, module_member_name(member), [member])

private fun append_distinct(values: List[String], value: String): List[String] =
    if values.contains(value)
    then values
    else values + value

private fun put_imported_entry(entries: List[Tuple[String, T]], module: Tuple[String, String], value: T): List[Tuple[String, T]] =
    put_entry(put_entry_if_absent(entries, module_name(module), value), qualified_module_name(module), value)

private fun put_entry_if_absent(entries: List[Tuple[String, T]], key: String, value: T): List[Tuple[String, T]] =
    if has_entry(entries, key)
    then entries
    else entries + (key, value)

private fun put_entry(entries: List[Tuple[String, T]], key: String, value: T): List[Tuple[String, T]] =
    if has_entry(entries, key)
    then entries.reduce([], (updated, entry) =>
        if entry_key(entry) == key
        then updated + (key, value)
        else updated + entry)
    else entries + (key, value)

private fun remove_entry(entries: List[Tuple[String, T]], key: String): List[Tuple[String, T]] =
    entries.reduce([], (updated, entry) =>
        if entry_key(entry) == key
        then updated
        else updated + entry)

private fun get_entry(entries: List[Tuple[String, T]], key: String): Option[T] =
    fun scan(entries: List[Tuple[String, T]], key: String, idx: int): Option[T] =
        match entries[idx] with
        case Some { entry } ->
            if entry_key(entry) == key
            then Some { entry_value(entry) }
            else scan(entries, key, idx + 1)
        case _ -> None {}
    ---
    scan(entries, key, 0)

private fun has_entry(entries: List[Tuple[String, T]], key: String): bool =
    entries.any(entry => entry_key(entry) == key)

private fun string_size(value: String): int =
    fun scan(value: String, idx: int): int =
        match value[idx] with
        case Some _ -> scan(value, idx + 1)
        case _ -> idx
    ---
    scan(value, 0)

private fun string_is_empty(value: String): bool =
    string_size(value) == 0

private fun string_is_blank(value: String): bool =
    fun scan(value: String, idx: int): bool =
        match value[idx] with
        case Some { char } ->
            if char == " " | char == '\t' | char == '\n' | char == '\r' | char == '\f'
            then scan(value, idx + 1)
            else false
        case _ -> true
    ---
    scan(value, 0)

private fun string_starts_with(value: String, prefix: String): bool =
    let prefix_size = string_size(prefix)
    if string_size(value) < prefix_size
    then false
    else value[0, prefix_size] == prefix

private fun string_ends_with(value: String, suffix: String): bool =
    let value_size = string_size(value)
    let suffix_size = string_size(suffix)
    if value_size < suffix_size
    then false
    else value[value_size - suffix_size, value_size] == suffix

private fun replace_char(value: String, old: String, new: String): String =
    fun scan(value: String, old: String, new: String, idx: int, output: String): String =
        match value[idx] with
        case Some { char } ->
            if char == old
            then scan(value, old, new, idx + 1, output + new)
            else scan(value, old, new, idx + 1, output + char)
        case _ -> output
    ---
    scan(value, old, new, 0, "")
