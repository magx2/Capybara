private fun definition_parents(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): List[String] =
    definition[3]

private fun definition_modifiers(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): List[String] =
    definition[4]

private fun member_owner(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
    member[0]

private fun member_kind(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
    member[1]

private fun member_name(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
    member[2]

private fun member_type(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
