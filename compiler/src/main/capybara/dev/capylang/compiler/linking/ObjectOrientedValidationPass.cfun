from /capy/lang/Option import { * }
from /dev/capylang/compiler/parser/ObjectOriented import { * }
from /dev/capylang/compiler/parser/ObjectOrientedModule import { * }

/// Pure validation for object-oriented source.
/// Parser-model inputs are normalized to compact tuple DTOs for the rule checks below.
data String { <native> }
data List[T] { <native> }

fun String.`+`(value: any): String = <native>
fun List[T].`+`(value: T): List[T] = <native>

data OoValidationBuildState {
    nextBlockId: int,
    nextStatementId: int,
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
}

fun validate_object_oriented_modules(modules: List[ObjectOrientedModule]): List[Tuple[int, int, String, String]] =
    validate_modules(oo_model_modules(modules, 0, []))

private fun oo_model_modules(
    modules: List[ObjectOrientedModule],
    idx: int,
    output: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ]
): List[
    Tuple[
        String,
        List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
        List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
        List[Tuple[int, List[int]]],
        List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
    ]
] =
    match modules[idx] with
    case Some { module } -> oo_model_modules(modules, idx + 1, output + oo_model_module(module))
    case _ -> output

private fun oo_model_module(
    module: ObjectOrientedModule
): Tuple[
    String,
    List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
    List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    List[Tuple[int, List[int]]],
    List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
] =
    let definitions = oo_model_definitions(module.objectOriented().definitions(), 0, [])
    let members = oo_model_definition_members(module.objectOriented().definitions(), oo_model_empty_state(), 0, [])
    let state = members[0]
    (module.moduleFile(), definitions, members[1], state.blocks, state.statements)

private fun oo_model_empty_state(): OoValidationBuildState =
    OoValidationBuildState { nextBlockId: 0, nextStatementId: 0, blocks: [], statements: [] }

private fun oo_model_definitions(
    definitions: List[TypeDeclaration],
    idx: int,
    output: List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]]
): List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    match definitions[idx] with
    case Some { definition } ->
        oo_model_definitions(definitions, idx + 1, output + oo_model_definition(definition))
    case _ -> output

private fun oo_model_definition(
    definition: TypeDeclaration
): Tuple[String, String, List[Tuple[String, String]], List[String], List[String]] =
    match definition with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } ->
        ("class", name, oo_model_parameters(constructorParameters), oo_model_parents(parents), modifiers)
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } ->
        ("trait", name, [], oo_model_parents(parents), [])
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } ->
        ("interface", name, [], oo_model_parents(parents), [])

private fun oo_model_definition_name(definition: TypeDeclaration): String =
    match definition with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } -> name
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> name
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> name

private fun oo_model_definition_members(
    definitions: List[TypeDeclaration],
    state: OoValidationBuildState,
    idx: int,
    output: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
): Tuple[
    OoValidationBuildState,
    List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
] =
    match definitions[idx] with
    case Some { definition } ->
        let members = oo_model_members(oo_model_definition_name(definition), definition.members(), state, 0, output)
        oo_model_definition_members(definitions, members[0], idx + 1, members[1])
    case _ -> (state, output)

private fun oo_model_members(
    owner: String,
    members: List[MemberDeclaration],
    state: OoValidationBuildState,
    idx: int,
    output: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
): Tuple[
    OoValidationBuildState,
    List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
] =
    match members[idx] with
    case Some { member } ->
        let built = oo_model_member(owner, member, state)
        oo_model_members(owner, members, built[0], idx + 1, output + built[1])
    case _ -> (state, output)

private fun oo_model_member(
    owner: String,
    member: MemberDeclaration,
    state: OoValidationBuildState
): Tuple[
    OoValidationBuildState,
    Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]
] =
    match member with
    case FieldDeclaration { name, type, visibility, initializer, comments, annotations, linkedAnnotations } ->
        let init = oo_model_optional_string(initializer)
        (state, (owner, "field", name, type, visibility, [], false, oo_model_empty_body(), init[0], init[1], []))
    case MethodDeclaration { name, parameters, returnType, visibility, modifiers, body, comments, annotations, linkedAnnotations } ->
        let built_body = oo_model_optional_body(body, state)
        let body_info = built_body[1]
        (built_body[0], (owner, "method", name, returnType, visibility, modifiers, body_info[0], body_info[1], false, "", oo_model_parameters(parameters)))
    case InitBlock { body, comments, annotations, linkedAnnotations } ->
        let built_body = oo_model_block_body(body, state)
        (built_body[0], (owner, "init", "init", "void", "public", [], true, built_body[1], false, "", []))

private fun oo_model_optional_body(
    body: Option[MethodBody],
    state: OoValidationBuildState
): Tuple[OoValidationBuildState, Tuple[bool, Tuple[String, String, int]]] =
    match body with
    case Some { value } ->
        let built = oo_model_body(value, state)
        (built[0], (true, built[1]))
    case _ -> (state, (false, oo_model_empty_body()))

private fun oo_model_body(body: MethodBody, state: OoValidationBuildState): Tuple[OoValidationBuildState, Tuple[String, String, int]] =
    match body with
    case ExpressionBody { expression } -> (state, ("expression", expression, -1))
    case StatementBlock { statements } -> oo_model_block_body(StatementBlock { statements: statements }, state)

private fun oo_model_block_body(block: StatementBlock, state: OoValidationBuildState): Tuple[OoValidationBuildState, Tuple[String, String, int]] =
    let built = oo_model_block(block, state)
    (built[0], ("block", "", built[1]))

private fun oo_model_empty_body(): Tuple[String, String, int] =
    ("none", "", -1)

private fun oo_model_block(block: StatementBlock, state: OoValidationBuildState): Tuple[OoValidationBuildState, int] =
    let id = state.nextBlockId
    let start_state = OoValidationBuildState { nextBlockId: id + 1, nextStatementId: state.nextStatementId, blocks: state.blocks, statements: state.statements }
    let built = oo_model_statements(block.statements, start_state, 0, [])
    let built_state = built[0]
    (OoValidationBuildState {
        nextBlockId: built_state.nextBlockId,
        nextStatementId: built_state.nextStatementId,
        blocks: built_state.blocks + (id, built[1]),
        statements: built_state.statements
    }, id)

private fun oo_model_statements(
    statements: List[Statement],
    state: OoValidationBuildState,
    idx: int,
    output: List[int]
): Tuple[OoValidationBuildState, List[int]] =
    match statements[idx] with
    case Some { statement } ->
        let built = oo_model_statement(statement, state)
        oo_model_statements(statements, built[0], idx + 1, output + built[1])
    case _ -> (state, output)

private fun oo_model_statement(statement: Statement, state: OoValidationBuildState): Tuple[OoValidationBuildState, int] =
    let id = state.nextStatementId
    let start_state = OoValidationBuildState { nextBlockId: state.nextBlockId, nextStatementId: id + 1, blocks: state.blocks, statements: state.statements }
    let built = oo_model_statement_row(id, statement, start_state)
    let built_state = built[0]
    (OoValidationBuildState {
        nextBlockId: built_state.nextBlockId,
        nextStatementId: built_state.nextStatementId,
        blocks: built_state.blocks,
        statements: built_state.statements + built[1]
    }, id)

private fun oo_model_statement_row(
    id: int,
    statement: Statement,
    state: OoValidationBuildState
): Tuple[
    OoValidationBuildState,
    Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]
] =
    match statement with
    case LetStatement { name, type, expression } ->
        let declared_type = oo_model_optional_string(type)
        (state, oo_model_statement_dto(id, "let", name, declared_type[1], expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case LocalMethodStatement { name, parameters, returnType, body, comments } ->
        let built_body = oo_model_body(body, state)
        (built_body[0], oo_model_statement_dto(id, "local_method", name, "", "", oo_model_parameters(parameters), built_body[1], -1, -1, [], returnType))
    case MutableVariableStatement { name, type, expression } ->
        let declared_type = oo_model_optional_string(type)
        (state, oo_model_statement_dto(id, "mutable", name, declared_type[1], expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case AssignmentStatement { name, expression } ->
        (state, oo_model_statement_dto(id, "assignment", name, "", expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case ExpressionStatement { expression } ->
        (state, oo_model_statement_dto(id, "expression", "", "", expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case ThrowStatement { expression } ->
        (state, oo_model_statement_dto(id, "throw", "", "", expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case ReturnStatement { expression } ->
        (state, oo_model_statement_dto(id, "return", "", "", expression, [], oo_model_empty_body(), -1, -1, [], ""))
    case IfStatement { condition, thenBranch, elseBranch } ->
        let then_block = oo_model_block(thenBranch, state)
        let else_statement = oo_model_optional_statement(elseBranch, then_block[0])
        (else_statement[0], oo_model_statement_dto(id, "if", "", "", condition, [], oo_model_empty_body(), then_block[1], else_statement[1], [], ""))
    case TryCatchStatement { tryBlock, catches } ->
        let try_block = oo_model_block(tryBlock, state)
        let built_catches = oo_model_catches(catches, try_block[0], 0, [])
        (built_catches[0], oo_model_statement_dto(id, "try", "", "", "", [], oo_model_empty_body(), try_block[1], -1, built_catches[1], ""))
    case WhileStatement { condition, body } ->
        let built_body = oo_model_block(body, state)
        (built_body[0], oo_model_statement_dto(id, "while", "", "", condition, [], oo_model_empty_body(), built_body[1], -1, [], ""))
    case DoWhileStatement { body, condition } ->
        let built_body = oo_model_block(body, state)
        (built_body[0], oo_model_statement_dto(id, "do_while", "", "", condition, [], oo_model_empty_body(), built_body[1], -1, [], ""))
    case ForEachStatement { name, type, iterable, body } ->
        let declared_type = oo_model_optional_string(type)
        let built_body = oo_model_block(body, state)
        (built_body[0], oo_model_statement_dto(id, "foreach", name, declared_type[1], iterable, [], oo_model_empty_body(), built_body[1], -1, [], ""))
    case StatementBlock { statements } ->
        let built_body = oo_model_block(StatementBlock { statements: statements }, state)
        (built_body[0], oo_model_statement_dto(id, "block", "", "", "", [], oo_model_empty_body(), built_body[1], -1, [], ""))

private fun oo_model_optional_statement(body: Option[Statement], state: OoValidationBuildState): Tuple[OoValidationBuildState, int] =
    match body with
    case Some { value } -> oo_model_statement(value, state)
    case _ -> (state, -1)

private fun oo_model_catches(
    catches: List[CatchClause],
    state: OoValidationBuildState,
    idx: int,
    output: List[Tuple[String, int]]
): Tuple[OoValidationBuildState, List[Tuple[String, int]]] =
    match catches[idx] with
    case Some { catch_clause } ->
        let built = oo_model_catch(catch_clause, state)
        oo_model_catches(catches, built[0], idx + 1, output + built[1])
    case _ -> (state, output)

private fun oo_model_catch(catch_clause: CatchClause, state: OoValidationBuildState): Tuple[OoValidationBuildState, Tuple[String, int]] =
    match catch_clause with
    case CatchClause { name, body } ->
        let built = oo_model_block(body, state)
        (built[0], (name, built[1]))

private fun oo_model_statement_dto(
    id: int,
    kind: String,
    name: String,
    declared_type: String,
    raw_expression: String,
    parameters: List[Tuple[String, String]],
    body: Tuple[String, String, int],
    body_id: int,
    else_statement_id: int,
    catches: List[Tuple[String, int]],
    return_type: String
): Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String] =
    (id, kind, name, declared_type, raw_expression, parameters, body, body_id, else_statement_id, catches, return_type)

private fun oo_model_parameters(parameters: List[Parameter]): List[Tuple[String, String]] =
    oo_model_parameters_scan(parameters, 0, [])

private fun oo_model_parameters_scan(parameters: List[Parameter], idx: int, output: List[Tuple[String, String]]): List[Tuple[String, String]] =
    match parameters[idx] with
    case Some { parameter } -> oo_model_parameters_scan(parameters, idx + 1, output + (parameter.name, parameter.type))
    case _ -> output

private fun oo_model_parents(parents: List[TypeReference]): List[String] =
    oo_model_parents_scan(parents, 0, [])

private fun oo_model_parents_scan(parents: List[TypeReference], idx: int, output: List[String]): List[String] =
    match parents[idx] with
    case Some { parent } -> oo_model_parents_scan(parents, idx + 1, output + parent.name)
    case _ -> output

private fun oo_model_optional_string(value: Option[String]): Tuple[bool, String] =
    match value with
    case Some { text } -> (true, text)
    case _ -> (false, "")

fun validate_modules(
    modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ]
): List[Tuple[int, int, String, String]] =
    validate_modules_scan(modules, modules, 0, [])

private fun validate_modules_scan(
    modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match modules[idx] with
    case Some { module } -> validate_modules_scan(modules, all_modules, idx + 1, validate_module(module, all_modules, errors))
    case _ -> errors

private fun validate_module(
    module: Tuple[
        String,
        List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
        List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
        List[Tuple[int, List[int]]],
        List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
    ],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_definitions(module, all_modules, module_definitions(module), 0, [], errors)

private fun validate_definitions(
    module: Tuple[
        String,
        List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
        List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
        List[Tuple[int, List[int]]],
        List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
    ],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    definitions: List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
    idx: int,
    seen_names: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match definitions[idx] with
    case Some { definition } ->
        let name = definition_name(definition)
        let duplicate_errors =
            if oo_list_contains(seen_names, name)
            then errors + error(module_file(module), "Duplicate object-oriented type `" + name + "`")
            else errors
        let next_errors = validate_definition(module, all_modules, definition, duplicate_errors)
        validate_definitions(module, all_modules, definitions, idx + 1, seen_names + name, next_errors)
    case _ -> errors

private fun validate_definition(
    module: Tuple[
        String,
        List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
        List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
        List[Tuple[int, List[int]]],
        List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
    ],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let file = module_file(module)
    let name = definition_name(definition)
    let members = module_members(module)
    let blocks = module_blocks(module)
    let statements = module_statements(module)
    match definition_kind(definition) with
    case "class" ->
        let modifier_errors = validate_duplicate_modifiers(file, "Class `" + name + "`", definition_modifiers(definition), errors)
        let class_errors = validate_class_modifiers(file, name, definition_modifiers(definition), modifier_errors)
        let parameter_errors = validate_duplicate_parameters(file, "Constructor `" + name + "`", definition_constructor_parameters(definition), class_errors)
        let parent_errors = validate_class_parents(file, name, definition_parents(definition), all_modules, parameter_errors)
        let member_errors = validate_class_members(file, name, definition_constructor_parameters(definition), members, blocks, statements, all_modules, definition, 0, [], parent_errors)
        validate_concrete_class_abstract_methods(file, name, members, definition_modifiers(definition), all_modules, definition, member_errors)
    case "trait" ->
        let parent_errors = validate_non_class_parents(file, "Trait `" + name + "`", definition_parents(definition), all_modules, errors)
        validate_trait_members(file, name, members, blocks, statements, all_modules, definition, 0, [], parent_errors)
    case _ ->
        let parent_errors = validate_interface_parents(file, name, definition_parents(definition), all_modules, errors)
        validate_interface_members(file, name, members, 0, [], parent_errors)

private fun validate_class_modifiers(file: String, name: String, modifiers: List[String], errors: List[Tuple[int, int, String, String]]): List[Tuple[int, int, String, String]] =
    if oo_list_contains(modifiers, "open") & oo_list_contains(modifiers, "abstract")
    then errors + error(file, "Class `" + name + "` cannot be both `open` and `abstract`")
    else errors

private fun validate_duplicate_modifiers(
    file: String,
    owner: String,
    modifiers: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_duplicate_modifiers_scan(file, owner, modifiers, 0, [], errors)

private fun validate_duplicate_modifiers_scan(
    file: String,
    owner: String,
    modifiers: List[String],
    idx: int,
    seen: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match modifiers[idx] with
    case Some { modifier } ->
        let next_errors =
            if oo_list_contains(seen, modifier)
            then errors + error(file, owner + " declares duplicate modifier `" + modifier + "`")
            else errors
        validate_duplicate_modifiers_scan(file, owner, modifiers, idx + 1, seen + modifier, next_errors)
    case _ -> errors

private fun validate_duplicate_parameters(
    file: String,
    owner: String,
    parameters: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_duplicate_parameters_scan(file, owner, parameters, 0, [], errors)

private fun validate_duplicate_parameters_scan(
    file: String,
    owner: String,
    parameters: List[Tuple[String, String]],
    idx: int,
    seen: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match parameters[idx] with
    case Some { parameter } ->
        let name = parameter_name(parameter)
        let next_errors =
            if oo_list_contains(seen, name)
            then errors + error(file, owner + " declares duplicate parameter `" + name + "`")
            else errors
        validate_duplicate_parameters_scan(file, owner, parameters, idx + 1, seen + name, next_errors)
    case _ -> errors

private fun validate_class_parents(
    file: String,
    class_name: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_class_parents_scan(file, class_name, parents, all_modules, 0, false, errors)

private fun validate_class_parents_scan(
    file: String,
    class_name: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    idx: int,
    has_class_parent: bool,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match parents[idx] with
    case Some { parent } ->
        let parent_definition = find_definition(all_modules, parent)
        let parent_is_class = option_definition_is_class(parent_definition)
        let class_parent_errors =
            if has_class_parent & parent_is_class
            then errors + error(file, "Class `" + class_name + "` can extend only one class")
            else errors
        let final_parent_errors =
            match parent_definition with
            case Some { resolved } ->
                if definition_is_class(resolved) & !definition_is_open_class(resolved) & !definition_is_abstract_class(resolved)
                then class_parent_errors + error(file, "Class `" + class_name + "` cannot extend final class `" + definition_name(resolved) + "`")
                else class_parent_errors
            case _ -> class_parent_errors
        validate_class_parents_scan(file, class_name, parents, all_modules, idx + 1, has_class_parent | parent_is_class, final_parent_errors)
    case _ -> errors

private fun validate_interface_parents(
    file: String,
    interface_name: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_interface_parents_scan(file, interface_name, parents, all_modules, 0, errors)

private fun validate_interface_parents_scan(
    file: String,
    interface_name: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match parents[idx] with
    case Some { parent } ->
        let next_errors =
            match find_definition(all_modules, parent) with
            case Some { resolved } ->
                if definition_is_interface(resolved)
                then errors
                else errors + error(file, "Interface `" + interface_name + "` can only extend interfaces; `" + parent + "` is a " + definition_kind_display(resolved))
            case _ -> errors
        validate_interface_parents_scan(file, interface_name, parents, all_modules, idx + 1, next_errors)
    case _ -> errors

private fun validate_non_class_parents(
    file: String,
    owner: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_non_class_parents_scan(file, owner, parents, all_modules, 0, errors)

private fun validate_non_class_parents_scan(
    file: String,
    owner: String,
    parents: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match parents[idx] with
    case Some { parent } ->
        let next_errors =
            match find_definition(all_modules, parent) with
            case Some { resolved } ->
                if definition_is_class(resolved)
                then errors + error(file, owner + " cannot inherit class `" + parent + "`")
                else errors
            case _ -> errors
        validate_non_class_parents_scan(file, owner, parents, all_modules, idx + 1, next_errors)
    case _ -> errors

private fun validate_class_members(
    file: String,
    class_name: String,
    constructor_parameters: List[Tuple[String, String]],
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    idx: int,
    seen_member_keys: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match members[idx] with
    case Some { member } ->
        if member_owner(member) == class_name
        then
            let member_key = member_signature_key(member)
            let duplicate_errors =
                if !oo_string_is_empty(member_key) & oo_list_contains(seen_member_keys, member_key)
                then errors + error(file, "Duplicate member signature `" + member_display_name(member) + "` in class `" + class_name + "`")
                else errors
            let next_seen = if oo_string_is_empty(member_key) then seen_member_keys else seen_member_keys + member_key
            let next_errors = validate_class_member(file, class_name, constructor_parameters, member, blocks, statements, all_modules, owner_definition, duplicate_errors)
            validate_class_members(file, class_name, constructor_parameters, members, blocks, statements, all_modules, owner_definition, idx + 1, next_seen, next_errors)
        else validate_class_members(file, class_name, constructor_parameters, members, blocks, statements, all_modules, owner_definition, idx + 1, seen_member_keys, errors)
    case _ -> errors

private fun validate_class_member(
    file: String,
    class_name: String,
    constructor_parameters: List[Tuple[String, String]],
    member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match member_kind(member) with
    case "field" ->
        if !member_has_initializer(member) & !parameters_contain_name(constructor_parameters, member_name(member))
        then errors + error(file, "Field `" + class_name + "." + member_name(member) + "` must be initialized or backed by a constructor parameter")
        else errors
    case "method" ->
        let owner = class_name + "." + member_name(member)
        let parameter_errors = validate_duplicate_parameters(file, "Method `" + owner + "`", member_parameters(member), errors)
        let shape_errors = validate_class_method_shape(file, class_name, member_name(member), member_visibility(member), member_modifiers(member), member_has_body(member), definition_is_abstract_class(owner_definition), parameter_errors)
        let override_errors = validate_class_method_override(file, class_name, member, all_modules, owner_definition, shape_errors)
        let unsafe_errors = validate_member_body_unsafe_run(file, owner, member_has_body(member), member_body(member), blocks, statements, override_errors)
        let local_errors =
            if member_has_body(member) & body_kind(member_body(member)) == "block"
            then validate_block(file, owner, blocks, statements, body_block_id(member_body(member)), scope_from_parameters(member_parameters(member)), unsafe_errors)
            else unsafe_errors
        validate_method_return(file, owner, member_type(member), member_has_body(member), member_body(member), blocks, statements, local_errors)
    case _ ->
        let owner = class_name + ".init"
        let unsafe_errors = validate_block_unsafe_run(file, owner, blocks, statements, member_body_block_id(member), errors)
        let return_errors = validate_no_return_in_block(file, owner, blocks, statements, member_body_block_id(member), unsafe_errors)
        validate_block(file, owner, blocks, statements, member_body_block_id(member), scope_from_parameters(constructor_parameters), return_errors)

private fun validate_class_method_shape(
    file: String,
    class_name: String,
    method_name: String,
    visibility: String,
    modifiers: List[String],
    has_body: bool,
    owner_is_abstract: bool,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let owner = "Method `" + class_name + "." + method_name + "`"
    let abstract_method = oo_list_contains(modifiers, "abstract") | !has_body
    let abstract_body_errors =
        if oo_list_contains(modifiers, "abstract") & has_body
        then errors + error(file, owner + " is `abstract` and cannot declare a body")
        else errors
    let abstract_final_errors =
        if abstract_method & oo_list_contains(modifiers, "final")
        then abstract_body_errors + error(file, owner + " cannot be both `abstract` and `final`")
        else abstract_body_errors
    let abstract_private_errors =
        if abstract_method & visibility == "private"
        then abstract_final_errors + error(file, owner + " cannot be both `abstract` and `private`")
        else abstract_final_errors
    let open_final_errors =
        if oo_list_contains(modifiers, "open") & oo_list_contains(modifiers, "final")
        then abstract_private_errors + error(file, owner + " cannot be both `open` and `final`")
        else abstract_private_errors
    let open_private_errors =
        if oo_list_contains(modifiers, "open") & visibility == "private"
        then open_final_errors + error(file, owner + " cannot be both `open` and `private`")
        else open_final_errors
    if !has_body & !owner_is_abstract
    then open_private_errors + error(file, "Concrete class `" + class_name + "` cannot declare body-less method `" + method_name + "`")
    else open_private_errors

private fun validate_class_method_override(
    file: String,
    class_name: String,
    method: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let parent_method = find_parent_method(all_modules, owner_definition, member_name(method), list_size(member_parameters(method)))
    let has_parent_method = parent_method != None {}
    let missing_override_errors =
        if has_parent_method & !oo_list_contains(member_modifiers(method), "override")
        then errors + error(file, "Method `" + class_name + "." + member_name(method) + "` overrides a parent method and must declare `override`")
        else errors
    let unknown_override_errors =
        if !has_parent_method & oo_list_contains(member_modifiers(method), "override")
        then missing_override_errors + error(file, "Method `" + class_name + "." + member_name(method) + "` declares `override` but no matching parent method exists")
        else missing_override_errors
    validate_parent_override_details(file, class_name, method, parent_method, unknown_override_errors)

private fun validate_parent_override_details(
    file: String,
    class_name: String,
    method: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]],
    parent_method: Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match parent_method with
    case Some { parent } ->
        let final_errors =
            if method_is_final_in_owner(parent[0], parent[1])
            then errors + error(file, "Method `" + class_name + "." + member_name(method) + "` cannot override final method `" + definition_name(parent[0]) + "." + member_name(parent[1]) + "`")
            else errors
        if !visibility_can_override(member_visibility(parent[1]), member_visibility(method))
        then final_errors + error(file, "Method `" + class_name + "." + member_name(method) + "` cannot reduce visibility from `" + member_visibility(parent[1]) + "` to `" + member_visibility(method) + "`")
        else final_errors
    case _ -> errors

private fun validate_trait_members(
    file: String,
    trait_name: String,
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    idx: int,
    seen_member_keys: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match members[idx] with
    case Some { member } ->
        if member_owner(member) == trait_name
        then
            let member_key = member_signature_key(member)
            let duplicate_errors =
                if !oo_string_is_empty(member_key) & oo_list_contains(seen_member_keys, member_key)
                then errors + error(file, "Duplicate member signature `" + member_display_name(member) + "` in trait `" + trait_name + "`")
                else errors
            let next_seen = if oo_string_is_empty(member_key) then seen_member_keys else seen_member_keys + member_key
            let next_errors = validate_trait_member(file, trait_name, member, blocks, statements, all_modules, owner_definition, duplicate_errors)
            validate_trait_members(file, trait_name, members, blocks, statements, all_modules, owner_definition, idx + 1, next_seen, next_errors)
        else validate_trait_members(file, trait_name, members, blocks, statements, all_modules, owner_definition, idx + 1, seen_member_keys, errors)
    case _ -> errors

private fun validate_trait_member(
    file: String,
    trait_name: String,
    member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match member_kind(member) with
    case "field" -> errors
    case "init" -> errors + error(file, "Trait `" + trait_name + "` cannot declare init blocks")
    case _ ->
        let owner = trait_name + "." + member_name(member)
        let parameter_errors = validate_duplicate_parameters(file, "Method `" + owner + "`", member_parameters(member), errors)
        let private_body_errors =
            if member_visibility(member) == "private" & !member_has_body(member)
            then parameter_errors + error(file, "Trait method `" + owner + "` cannot be private without a body")
            else parameter_errors
        let override_errors =
            if oo_list_contains(member_modifiers(member), "override")
            then private_body_errors + error(file, "Trait method `" + owner + "` cannot declare `override`")
            else private_body_errors
        let final_errors =
            if oo_list_contains(member_modifiers(member), "final")
            then override_errors + error(file, "Trait method `" + owner + "` cannot declare `final`")
            else override_errors
        let local_errors =
            if member_visibility(member) != "public" & member_visibility(member) != "private"
            then final_errors + error(file, "Trait method `" + owner + "` must be public or private")
            else final_errors
        let unsafe_errors = validate_member_body_unsafe_run(file, owner, member_has_body(member), member_body(member), blocks, statements, local_errors)
        let block_errors =
            if member_has_body(member) & body_kind(member_body(member)) == "block"
            then validate_block(file, owner, blocks, statements, body_block_id(member_body(member)), scope_from_parameters(member_parameters(member)), unsafe_errors)
            else unsafe_errors
        validate_method_return(file, owner, member_type(member), member_has_body(member), member_body(member), blocks, statements, block_errors)

private fun validate_interface_members(
    file: String,
    interface_name: String,
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    idx: int,
    seen_member_keys: List[String],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match members[idx] with
    case Some { member } ->
        if member_owner(member) == interface_name
        then
            let member_key = member_signature_key(member)
            let duplicate_errors =
                if !oo_string_is_empty(member_key) & oo_list_contains(seen_member_keys, member_key)
                then errors + error(file, "Duplicate member signature `" + member_display_name(member) + "` in interface `" + interface_name + "`")
                else errors
            let next_seen = if oo_string_is_empty(member_key) then seen_member_keys else seen_member_keys + member_key
            let next_errors = validate_interface_member(file, interface_name, member, duplicate_errors)
            validate_interface_members(file, interface_name, members, idx + 1, next_seen, next_errors)
        else validate_interface_members(file, interface_name, members, idx + 1, seen_member_keys, errors)
    case _ -> errors

private fun validate_interface_member(
    file: String,
    interface_name: String,
    member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if member_kind(member) != "method"
    then errors + error(file, "Interface `" + interface_name + "` can only contain methods")
    else
        let owner = interface_name + "." + member_name(member)
        let parameter_errors = validate_duplicate_parameters(file, "Method `" + owner + "`", member_parameters(member), errors)
        let visibility_errors =
            if member_visibility(member) != "public"
            then parameter_errors + error(file, "Interface method `" + owner + "` must be public")
            else parameter_errors
        let modifier_errors =
            if !list_is_empty(member_modifiers(member))
            then visibility_errors + error(file, "Interface method `" + owner + "` cannot declare modifiers")
            else visibility_errors
        if member_has_body(member)
        then modifier_errors + error(file, "Interface method `" + owner + "` cannot declare a body")
        else modifier_errors

private fun validate_concrete_class_abstract_methods(
    file: String,
    class_name: String,
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    modifiers: List[String],
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if oo_list_contains(modifiers, "abstract")
    then errors
    else
        let own_methods = concrete_method_keys(members, class_name, 0, [])
        let required_methods = abstract_parent_method_keys(all_modules, owner_definition, [])
        validate_required_methods(file, class_name, required_methods, own_methods, 0, errors)

private fun validate_required_methods(
    file: String,
    class_name: String,
    required_methods: List[String],
    own_methods: List[String],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match required_methods[idx] with
    case Some { required } ->
        validate_required_methods(
            file,
            class_name,
            required_methods,
            own_methods,
            idx + 1,
            if oo_list_contains(own_methods, required)
            then errors
            else errors + error(file, "Concrete class `" + class_name + "` must implement method `" + required + "`")
        )
    case _ -> errors

private fun concrete_method_keys(
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    owner: String,
    idx: int,
    keys: List[String]
): List[String] =
    match members[idx] with
    case Some { member } ->
        let next_keys =
            if member_owner(member) == owner & member_kind(member) == "method" & member_has_body(member)
            then oo_append_distinct(keys, method_key(member_name(member), list_size(member_parameters(member))))
            else keys
        concrete_method_keys(members, owner, idx + 1, next_keys)
    case _ -> keys

private fun abstract_parent_method_keys(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    keys: List[String]
): List[String] =
    abstract_parent_method_keys_scan(all_modules, definition_parents(owner_definition), 0, keys)

private fun abstract_parent_method_keys_scan(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    parents: List[String],
    idx: int,
    keys: List[String]
): List[String] =
    match parents[idx] with
    case Some { parent } ->
        let next_keys =
            match find_definition(all_modules, parent) with
            case Some { resolved } ->
                let inherited = abstract_parent_method_keys(all_modules, resolved, keys)
                collect_abstract_method_keys(all_modules, resolved, 0, inherited)
            case _ -> keys
        abstract_parent_method_keys_scan(all_modules, parents, idx + 1, next_keys)
    case _ -> keys

private fun collect_abstract_method_keys(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    idx: int,
    keys: List[String]
): List[String] =
    let members = definition_members(all_modules, definition)
    match members[idx] with
    case Some { member } ->
        let next_keys =
            if member_kind(member) == "method" & member_visibility(member) != "private" & (!member_has_body(member) | definition_is_interface(definition))
            then oo_append_distinct(keys, method_key(member_name(member), list_size(member_parameters(member))))
            else keys
        collect_abstract_method_keys(all_modules, definition, idx + 1, next_keys)
    case _ -> keys

private fun validate_member_body_unsafe_run(
    file: String,
    owner: String,
    has_body: bool,
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if has_body
    then validate_body_unsafe_run(file, owner, body, blocks, statements, errors)
    else errors

private fun validate_body_unsafe_run(
    file: String,
    owner: String,
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if body_kind(body) == "expression"
    then validate_expression_unsafe_run(file, owner, body_expression(body), errors)
    else validate_block_unsafe_run(file, owner, blocks, statements, body_block_id(body), errors)

private fun validate_block_unsafe_run(
    file: String,
    owner: String,
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    block_id: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_statement_list_unsafe_run(file, owner, block_statement_ids(blocks, block_id), blocks, statements, 0, errors)

private fun validate_statement_list_unsafe_run(
    file: String,
    owner: String,
    ids: List[int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match ids[idx] with
    case Some { id } ->
        let next_errors =
            match find_statement(statements, id) with
            case Some { statement } -> validate_statement_unsafe_run(file, owner, statement, blocks, statements, errors)
            case _ -> errors
        validate_statement_list_unsafe_run(file, owner, ids, blocks, statements, idx + 1, next_errors)
    case _ -> errors

private fun validate_statement_unsafe_run(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match statement_kind(statement) with
    case "let" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "local_method" -> validate_body_unsafe_run(file, owner + "." + statement_name(statement), statement_body(statement), blocks, statements, errors)
    case "mutable" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "assignment" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "expression" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "throw" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "return" -> validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors)
    case "if" -> validate_if_unsafe_run(file, owner, statement, blocks, statements, validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors))
    case "try" -> validate_catches_unsafe_run(file, owner, statement_catches(statement), blocks, statements, 0, validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), errors))
    case "while" -> validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors))
    case "do_while" -> validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors))
    case "foreach" -> validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), validate_expression_unsafe_run(file, owner, statement_raw_expression(statement), errors))
    case _ -> validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), errors)

private fun validate_if_unsafe_run(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let then_errors = validate_block_unsafe_run(file, owner, blocks, statements, statement_body_id(statement), errors)
    if statement_else_id(statement) < 0
    then then_errors
    else
        match find_statement(statements, statement_else_id(statement)) with
        case Some { else_statement } -> validate_statement_unsafe_run(file, owner, else_statement, blocks, statements, then_errors)
        case _ -> then_errors

private fun validate_catches_unsafe_run(
    file: String,
    owner: String,
    catches: List[Tuple[String, int]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match catches[idx] with
    case Some { catch_clause } ->
        validate_catches_unsafe_run(file, owner, catches, blocks, statements, idx + 1, validate_block_unsafe_run(file, owner, blocks, statements, catch_body_id(catch_clause), errors))
    case _ -> errors

private fun validate_expression_unsafe_run(file: String, owner: String, raw_expression: String, errors: List[Tuple[int, int, String, String]]): List[Tuple[int, int, String, String]] =
    if contains_unsafe_run_call(raw_expression)
    then errors + unsafe_run_error(file, owner)
    else errors

private fun validate_method_return(
    file: String,
    owner: String,
    return_type: String,
    has_body: bool,
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if !has_body
    then errors
    else
        let validation = method_body_return_validation(body, blocks, statements)
        let has_value_return = rv_has_value_return(validation) & !(return_type == "void" & body_kind(body) == "expression")
        let void_errors =
            if return_type == "void" & has_value_return
            then errors + error(file, "Method `" + owner + "` returns a value but declares return type `void`")
            else errors
        if return_type != "void" & !rv_definitely_returns(validation)
        then void_errors + error(file, "Method `" + owner + "` must return `" + return_type + "` on every path")
        else void_errors

private fun method_body_return_validation(
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
): Tuple[bool, bool] =
    if body_kind(body) == "expression"
    then rv(true, true)
    else statement_block_return_validation(blocks, statements, body_block_id(body))

private fun statement_block_return_validation(
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    block_id: int
): Tuple[bool, bool] =
    statement_list_return_validation(block_statement_ids(blocks, block_id), blocks, statements, 0, rv(false, false))

private fun statement_list_return_validation(
    ids: List[int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    idx: int,
    acc: Tuple[bool, bool]
): Tuple[bool, bool] =
    if rv_definitely_returns(acc)
    then acc
    else
        match ids[idx] with
        case Some { id } ->
            let statement_validation =
                match find_statement(statements, id) with
                case Some { statement } -> statement_return_validation(statement, blocks, statements)
                case _ -> rv(false, false)
            statement_list_return_validation(ids, blocks, statements, idx + 1, merge_return_validation(acc, statement_validation))
        case _ -> acc

private fun statement_return_validation(
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
): Tuple[bool, bool] =
    match statement_kind(statement) with
    case "return" -> rv(true, true)
    case "throw" -> rv(true, false)
    case "if" -> if_return_validation(statement, blocks, statements)
    case "try" -> try_return_validation(statement, blocks, statements)
    case "do_while" -> statement_block_return_validation(blocks, statements, statement_body_id(statement))
    case "block" -> statement_block_return_validation(blocks, statements, statement_body_id(statement))
    case _ -> rv(false, false)

private fun if_return_validation(
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
): Tuple[bool, bool] =
    if statement_else_id(statement) < 0
    then rv(false, false)
    else
        let then_validation = statement_block_return_validation(blocks, statements, statement_body_id(statement))
        let else_validation =
            match find_statement(statements, statement_else_id(statement)) with
            case Some { else_statement } -> statement_return_validation(else_statement, blocks, statements)
            case _ -> rv(false, false)
        rv(rv_definitely_returns(then_validation) & rv_definitely_returns(else_validation), rv_has_value_return(then_validation) | rv_has_value_return(else_validation))

private fun try_return_validation(
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
): Tuple[bool, bool] =
    catch_return_validation(statement_catches(statement), blocks, statements, 0, statement_block_return_validation(blocks, statements, statement_body_id(statement)))

private fun catch_return_validation(
    catches: List[Tuple[String, int]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    idx: int,
    acc: Tuple[bool, bool]
): Tuple[bool, bool] =
    match catches[idx] with
    case Some { catch_clause } ->
        let catch_validation = statement_block_return_validation(blocks, statements, catch_body_id(catch_clause))
        catch_return_validation(catches, blocks, statements, idx + 1, rv(rv_definitely_returns(acc) & rv_definitely_returns(catch_validation), rv_has_value_return(acc) | rv_has_value_return(catch_validation)))
    case _ -> acc

private fun merge_return_validation(left: Tuple[bool, bool], right: Tuple[bool, bool]): Tuple[bool, bool] =
    rv(rv_definitely_returns(left) | rv_definitely_returns(right), rv_has_value_return(left) | rv_has_value_return(right))

private fun validate_no_return_in_block(
    file: String,
    owner: String,
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    block_id: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    if rv_has_value_return(statement_block_return_validation(blocks, statements, block_id))
    then errors + error(file, "Init block `" + owner + "` cannot return a value")
    else errors

private fun validate_block(
    file: String,
    owner: String,
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    block_id: int,
    parent_scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_block_scan(file, owner, block_statement_ids(blocks, block_id), blocks, statements, 0, parent_scope, errors)[1]

private fun validate_block_scan(
    file: String,
    owner: String,
    ids: List[int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    idx: int,
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): Tuple[List[Tuple[String, String]], List[Tuple[int, int, String, String]]] =
    match ids[idx] with
    case Some { id } ->
        let step =
            match find_statement(statements, id) with
            case Some { statement } -> validate_statement(file, owner, statement, blocks, statements, scope, errors)
            case _ -> (scope, errors)
        validate_block_scan(file, owner, ids, blocks, statements, idx + 1, step[0], step[1])
    case _ -> (scope, errors)

private fun validate_statement(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): Tuple[List[Tuple[String, String]], List[Tuple[int, int, String, String]]] =
    match statement_kind(statement) with
    case "let" -> (declare_scope(scope, statement_name(statement), "IMMUTABLE"), errors)
    case "local_method" -> validate_local_method_statement(file, owner, statement, blocks, statements, scope, errors)
    case "mutable" -> (declare_scope(scope, statement_name(statement), "MUTABLE"), errors)
    case "assignment" -> (scope, validate_assignment(file, owner, statement_name(statement), scope, errors))
    case "expression" -> (scope, validate_expression_statement(file, owner, statement_raw_expression(statement), errors))
    case "if" -> (scope, validate_if_statement(file, owner, statement, blocks, statements, scope, errors))
    case "try" -> (scope, validate_try_statement(file, owner, statement, blocks, statements, scope, errors))
    case "while" -> (scope, validate_block(file, owner, blocks, statements, statement_body_id(statement), scope, errors))
    case "do_while" -> (scope, validate_block(file, owner, blocks, statements, statement_body_id(statement), scope, errors))
    case "foreach" -> (scope, validate_block(file, owner, blocks, statements, statement_body_id(statement), declare_scope(scope, statement_name(statement), "IMMUTABLE"), errors))
    case "block" -> (scope, validate_block(file, owner, blocks, statements, statement_body_id(statement), scope, errors))
    case _ -> (scope, errors)

private fun validate_local_method_statement(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): Tuple[List[Tuple[String, String]], List[Tuple[int, int, String, String]]] =
    let local_scope = declare_scope(scope_from_parameters_with_parent(scope, statement_parameters(statement)), statement_name(statement), "IMMUTABLE")
    let capture_errors = validate_local_method_captures(file, owner, statement_name(statement), statement_body(statement), blocks, statements, local_scope, errors)
    let body_errors =
        if body_kind(statement_body(statement)) == "block"
        then validate_block(file, owner + "." + statement_name(statement), blocks, statements, body_block_id(statement_body(statement)), local_scope, capture_errors)
        else capture_errors
    (declare_scope(scope, statement_name(statement), "IMMUTABLE"), validate_method_return(file, owner + "." + statement_name(statement), statement_return_type(statement), true, statement_body(statement), blocks, statements, body_errors))

private fun validate_if_statement(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let then_errors = validate_block(file, owner, blocks, statements, statement_body_id(statement), scope, errors)
    if statement_else_id(statement) < 0
    then then_errors
    else
        match find_statement(statements, statement_else_id(statement)) with
        case Some { else_statement } -> validate_nested_statement(file, owner, else_statement, blocks, statements, scope, then_errors)
        case _ -> then_errors

private fun validate_try_statement(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_catches(file, owner, statement_catches(statement), blocks, statements, scope, 0, validate_block(file, owner, blocks, statements, statement_body_id(statement), scope, errors))

private fun validate_nested_statement(
    file: String,
    owner: String,
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    validate_statement(file, owner, statement, blocks, statements, scope, errors)[1]

private fun validate_catches(
    file: String,
    owner: String,
    catches: List[Tuple[String, int]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    idx: int,
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    match catches[idx] with
    case Some { catch_clause } ->
        let catch_scope = declare_scope(scope, catch_name(catch_clause), "IMMUTABLE")
        validate_catches(file, owner, catches, blocks, statements, scope, idx + 1, validate_block(file, owner, blocks, statements, catch_body_id(catch_clause), catch_scope, errors))
    case _ -> errors

private fun validate_assignment(
    file: String,
    owner: String,
    name: String,
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let resolution = resolve_scope(scope, name)
    if resolution == "MUTABLE"
    then errors
    else
        let message =
            if resolution == "IMMUTABLE"
            then "Cannot assign to immutable local `" + name + "` in `" + owner + "`; use `def` for mutable locals"
            else "Assignment target `" + name + "` in `" + owner + "` is not a mutable local variable"
        errors + error(file, message)

private fun validate_expression_statement(file: String, owner: String, raw_expression: String, errors: List[Tuple[int, int, String, String]]): List[Tuple[int, int, String, String]] =
    if is_call_expression(raw_expression)
    then errors
    else errors + error(file, "Only call expressions can be used as stand-alone statements in `" + owner + "`")

private fun validate_local_method_captures(
    file: String,
    owner: String,
    name: String,
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    errors: List[Tuple[int, int, String, String]]
): List[Tuple[int, int, String, String]] =
    let mutable_captures = collect_mutable_captures_body(body, blocks, statements, scope, [])
    if list_is_empty(mutable_captures)
    then errors
    else errors + error(file, "Local method `" + owner + "." + name + "` cannot capture mutable locals: " + join_strings(mutable_captures, ", "))

private fun collect_mutable_captures_body(
    body: Tuple[String, String, int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    captures: List[String]
): List[String] =
    if body_kind(body) == "expression"
    then collect_mutable_captures_expression(body_expression(body), scope, captures)
    else collect_mutable_captures_block(blocks, statements, body_block_id(body), scope, captures)

private fun collect_mutable_captures_block(
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    block_id: int,
    scope: List[Tuple[String, String]],
    captures: List[String]
): List[String] =
    collect_mutable_captures_statements(block_statement_ids(blocks, block_id), blocks, statements, scope, 0, captures)

private fun collect_mutable_captures_statements(
    ids: List[int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    idx: int,
    captures: List[String]
): List[String] =
    match ids[idx] with
    case Some { id } -> collect_mutable_captures_statement_by_id(ids, blocks, statements, scope, idx, captures, id)
    case _ -> captures

private fun collect_mutable_captures_statement_by_id(
    ids: List[int],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    idx: int,
    captures: List[String],
    id: int
): List[String] =
    match find_statement(statements, id) with
    case Some { statement } ->
        let step = collect_mutable_captures_statement(statement, blocks, statements, scope, captures)
        collect_mutable_captures_statements(ids, blocks, statements, step[0], idx + 1, step[1])
    case _ -> collect_mutable_captures_statements(ids, blocks, statements, scope, idx + 1, captures)

private fun collect_mutable_captures_statement(
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    captures: List[String]
): Tuple[List[Tuple[String, String]], List[String]] =
    match statement_kind(statement) with
    case "let" -> (declare_scope(scope, statement_name(statement), "IMMUTABLE"), collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "local_method" -> (declare_scope(scope, statement_name(statement), "IMMUTABLE"), captures)
    case "mutable" -> (declare_scope(scope, statement_name(statement), "MUTABLE"), collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "assignment" -> (scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "expression" -> (scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "throw" -> (scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "return" -> (scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures))
    case "if" -> collect_mutable_captures_if(statement, blocks, statements, scope, captures)
    case "try" -> (scope, collect_mutable_captures_catches(statement_catches(statement), blocks, statements, scope, 0, collect_mutable_captures_block(blocks, statements, statement_body_id(statement), scope, captures)))
    case "while" -> (scope, collect_mutable_captures_block(blocks, statements, statement_body_id(statement), scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures)))
    case "do_while" -> (scope, collect_mutable_captures_block(blocks, statements, statement_body_id(statement), scope, collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures)))
    case "foreach" -> (scope, collect_mutable_captures_block(blocks, statements, statement_body_id(statement), declare_scope(scope, statement_name(statement), "IMMUTABLE"), collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures)))
    case "block" -> (scope, collect_mutable_captures_block(blocks, statements, statement_body_id(statement), scope, captures))
    case _ -> (scope, captures)

private fun collect_mutable_captures_if(
    statement: Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    captures: List[String]
): Tuple[List[Tuple[String, String]], List[String]] =
    let condition_captures = collect_mutable_captures_expression(statement_raw_expression(statement), scope, captures)
    let then_captures = collect_mutable_captures_block(blocks, statements, statement_body_id(statement), scope, condition_captures)
    let else_captures =
        if statement_else_id(statement) < 0
        then then_captures
        else
            match find_statement(statements, statement_else_id(statement)) with
            case Some { else_statement } -> collect_mutable_captures_statement(else_statement, blocks, statements, scope, then_captures)[1]
            case _ -> then_captures
    (scope, else_captures)

private fun collect_mutable_captures_catches(
    catches: List[Tuple[String, int]],
    blocks: List[Tuple[int, List[int]]],
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    scope: List[Tuple[String, String]],
    idx: int,
    captures: List[String]
): List[String] =
    match catches[idx] with
    case Some { catch_clause } ->
        let catch_scope = declare_scope(scope, catch_name(catch_clause), "IMMUTABLE")
        collect_mutable_captures_catches(catches, blocks, statements, scope, idx + 1, collect_mutable_captures_block(blocks, statements, catch_body_id(catch_clause), catch_scope, captures))
    case _ -> captures

private fun collect_mutable_captures_expression(raw_expression: String, scope: List[Tuple[String, String]], captures: List[String]): List[String] =
    collect_mutable_captures_identifier_scan(strip_string_literals(raw_expression), scope, 0, captures)

private fun collect_mutable_captures_identifier_scan(expression: String, scope: List[Tuple[String, String]], idx: int, captures: List[String]): List[String] =
    match expression[idx] with
    case Some { char } ->
        if is_identifier_start(char)
        then
            let end = identifier_end(expression, idx + 1)
            let name = expression[idx, end]
            let resolution = resolve_scope(scope, name)
            let next_captures =
                if resolution == "MUTABLE" & !oo_list_contains(captures, name)
                then oo_append_distinct(captures, name)
                else captures
            collect_mutable_captures_identifier_scan(expression, scope, end, next_captures)
        else collect_mutable_captures_identifier_scan(expression, scope, idx + 1, captures)
    case _ -> captures

private fun scope_from_parameters(parameters: List[Tuple[String, String]]): List[Tuple[String, String]] =
    scope_from_parameters_scan(parameters, 0, [])

private fun scope_from_parameters_with_parent(scope: List[Tuple[String, String]], parameters: List[Tuple[String, String]]): List[Tuple[String, String]] =
    append_scope(scope, scope_from_parameters(parameters))

private fun scope_from_parameters_scan(parameters: List[Tuple[String, String]], idx: int, scope: List[Tuple[String, String]]): List[Tuple[String, String]] =
    match parameters[idx] with
    case Some { parameter } -> scope_from_parameters_scan(parameters, idx + 1, declare_scope(scope, parameter_name(parameter), "IMMUTABLE"))
    case _ -> scope

private fun append_scope(scope: List[Tuple[String, String]], entries: List[Tuple[String, String]]): List[Tuple[String, String]] =
    append_scope_scan(scope, entries, 0)

private fun append_scope_scan(scope: List[Tuple[String, String]], entries: List[Tuple[String, String]], idx: int): List[Tuple[String, String]] =
    match entries[idx] with
    case Some { entry } -> append_scope_scan(scope + entry, entries, idx + 1)
    case _ -> scope

private fun declare_scope(scope: List[Tuple[String, String]], name: String, resolution: String): List[Tuple[String, String]] =
    scope + (name, resolution)

private fun resolve_scope(scope: List[Tuple[String, String]], name: String): String =
    resolve_scope_from(scope, name, list_size(scope) - 1)

private fun resolve_scope_from(scope: List[Tuple[String, String]], name: String, idx: int): String =
    if idx < 0
    then "UNDECLARED"
    else
        match scope[idx] with
        case Some { entry } ->
            if scope_entry_name(entry) == name
            then scope_entry_resolution(entry)
            else resolve_scope_from(scope, name, idx - 1)
        case _ -> "UNDECLARED"

private fun find_parent_method(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner_definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    name: String,
    arity: int
): Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]] =
    find_parent_method_scan(all_modules, definition_parents(owner_definition), 0, name, arity)

private fun find_parent_method_scan(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    parents: List[String],
    idx: int,
    name: String,
    arity: int
): Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]] =
    match parents[idx] with
    case Some { parent } -> find_parent_method_scan_found(all_modules, parents, idx, parent, name, arity)
    case _ -> None {}

private fun find_parent_method_scan_found(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    parents: List[String],
    idx: int,
    parent: String,
    name: String,
    arity: int
): Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]] =
    match find_parent_method_for_parent(all_modules, parent, name, arity) with
    case Some { found } -> Some { found }
    case _ -> find_parent_method_scan(all_modules, parents, idx + 1, name, arity)

private fun find_parent_method_for_parent(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    parent: String,
    name: String,
    arity: int
): Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]] =
    match find_definition(all_modules, parent) with
    case Some { resolved } -> find_method_or_inherited_parent_method(all_modules, resolved, name, arity)
    case _ -> None {}

private fun find_method_or_inherited_parent_method(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    resolved: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    name: String,
    arity: int
): Option[Tuple[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]], Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]] =
    match find_method_in_definition(all_modules, resolved, name, arity) with
    case Some { method } -> Some { (resolved, method) }
    case _ -> find_parent_method(all_modules, resolved, name, arity)

private fun find_method_in_definition(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    target_name: String,
    arity: int
): Option[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    find_method_in_members(definition_members(all_modules, definition), target_name, arity, 0)

private fun find_method_in_members(
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    target_name: String,
    arity: int,
    idx: int
): Option[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    match members[idx] with
    case Some { member } ->
        if member_kind(member) == "method" & member_name(member) == target_name & list_size(member_parameters(member)) == arity
        then Some { member }
        else find_method_in_members(members, target_name, arity, idx + 1)
    case _ -> None {}

private fun definition_members(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]
): List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    definition_members_in_modules(all_modules, definition_name(definition), 0, [])

private fun definition_members_in_modules(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    owner: String,
    idx: int,
    output: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
): List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    match all_modules[idx] with
    case Some { module } -> definition_members_in_modules(all_modules, owner, idx + 1, definition_members_in_list(module_members(module), owner, 0, output))
    case _ -> output

private fun definition_members_in_list(
    members: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
    owner: String,
    idx: int,
    output: List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]]
): List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    match members[idx] with
    case Some { member } ->
        definition_members_in_list(
            members,
            owner,
            idx + 1,
            if member_owner(member) == owner then output + member else output
        )
    case _ -> output

private fun find_definition(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    name: String
): Option[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    find_definition_in_modules(all_modules, name, 0)

private fun find_definition_in_modules(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    name: String,
    idx: int
): Option[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    match all_modules[idx] with
    case Some { module } -> find_definition_in_module_entry(all_modules, name, idx, module)
    case _ -> None {}

private fun find_definition_in_module_entry(
    all_modules: List[
        Tuple[
            String,
            List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
            List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
            List[Tuple[int, List[int]]],
            List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
        ]
    ],
    name: String,
    idx: int,
    module: Tuple[
        String,
        List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]],
        List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]],
        List[Tuple[int, List[int]]],
        List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]
    ]
): Option[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    match find_definition_in_list(module_definitions(module), name, 0) with
    case Some { definition } -> Some { definition }
    case _ -> find_definition_in_modules(all_modules, name, idx + 1)

private fun find_definition_in_list(definitions: List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], name: String, idx: int): Option[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    match definitions[idx] with
    case Some { definition } ->
        if definition_name(definition) == name | simple_type_name(definition_name(definition)) == name
        then Some { definition }
        else find_definition_in_list(definitions, name, idx + 1)
    case _ -> None {}

private fun find_statement(
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    id: int
): Option[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]] =
    find_statement_scan(statements, id, 0)

private fun find_statement_scan(
    statements: List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]],
    id: int,
    idx: int
): Option[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]] =
    match statements[idx] with
    case Some { statement } ->
        if statement_id(statement) == id
        then Some { statement }
        else find_statement_scan(statements, id, idx + 1)
    case _ -> None {}

private fun find_block(blocks: List[Tuple[int, List[int]]], id: int): Option[Tuple[int, List[int]]] =
    find_block_scan(blocks, id, 0)

private fun find_block_scan(blocks: List[Tuple[int, List[int]]], id: int, idx: int): Option[Tuple[int, List[int]]] =
    match blocks[idx] with
    case Some { block } ->
        if block_id(block) == id
        then Some { block }
        else find_block_scan(blocks, id, idx + 1)
    case _ -> None {}

private fun block_statement_ids(blocks: List[Tuple[int, List[int]]], id: int): List[int] =
    match find_block(blocks, id) with
    case Some { block } -> block_ids(block)
    case _ -> []

private fun method_is_final_in_owner(
    owner: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]],
    method: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]
): bool =
    if oo_list_contains(member_modifiers(method), "final")
    then true
    else
        definition_is_class(owner)
        & (definition_is_open_class(owner) | definition_is_abstract_class(owner))
        & member_has_body(method)
        & !oo_list_contains(member_modifiers(method), "open")
        & !oo_list_contains(member_modifiers(method), "override")
        & member_visibility(method) != "private"

private fun parameters_contain_name(parameters: List[Tuple[String, String]], name: String): bool =
    parameters_contain_name_scan(parameters, name, 0)

private fun parameters_contain_name_scan(parameters: List[Tuple[String, String]], name: String, idx: int): bool =
    match parameters[idx] with
    case Some { parameter } ->
        if parameter_name(parameter) == name
        then true
        else parameters_contain_name_scan(parameters, name, idx + 1)
    case _ -> false

private fun oo_append_distinct(values: List[String], value: String): List[String] =
    if oo_list_contains(values, value)
    then values
    else values + value

private fun method_key(name: String, arity: int): String =
    name + "/" + int_to_string(arity)

private fun member_signature_key(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
    match member_kind(member) with
    case "field" -> "field/" + member_name(member)
    case "method" -> "method/" + method_key(member_name(member), list_size(member_parameters(member)))
    case _ -> ""

private fun member_display_name(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): String =
    match member_kind(member) with
    case "field" -> member_name(member)
    case "method" -> member_name(member) + "/" + int_to_string(list_size(member_parameters(member)))
    case _ -> "init"

private fun definition_is_class(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): bool =
    definition_kind(definition) == "class"

private fun definition_is_interface(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): bool =
    definition_kind(definition) == "interface"

private fun definition_is_open_class(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): bool =
    definition_is_class(definition) & oo_list_contains(definition_modifiers(definition), "open")

private fun definition_is_abstract_class(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): bool =
    definition_is_class(definition) & oo_list_contains(definition_modifiers(definition), "abstract")

private fun option_definition_is_class(definition: Option[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]]): bool =
    match definition with
    case Some { resolved } -> definition_is_class(resolved)
    case _ -> false

private fun definition_kind_display(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): String =
    if definition_is_class(definition)
    then if definition_is_abstract_class(definition) then "abstract class" else "class"
    else if definition_is_interface(definition) then "interface" else "trait"

private fun visibility_can_override(parent_visibility: String, child_visibility: String): bool =
    visibility_rank(child_visibility) >= visibility_rank(parent_visibility)

private fun visibility_rank(visibility: String): int =
    match visibility with
    case "private" -> 0
    case "protected" -> 1
    case _ -> 2

private fun rv(definitely_returns: bool, has_value_return: bool): Tuple[bool, bool] =
    (definitely_returns, has_value_return)

private fun rv_definitely_returns(value: Tuple[bool, bool]): bool =
    value[0]

private fun rv_has_value_return(value: Tuple[bool, bool]): bool =
    value[1]

private fun error(file: String, message: String): Tuple[int, int, String, String] =
    (0, 0, file, message)

private fun unsafe_run_error(file: String, owner: String): Tuple[int, int, String, String] =
    error(file, "`unsafe_run` cannot be called from Capybara OO source: object-oriented method `" + owner + "`; keep effects at functional entrypoints")

private fun contains_unsafe_run_call(raw_expression: String): bool =
    contains_unsafe_run_call_scan(strip_string_literals(raw_expression), 0)

private fun contains_unsafe_run_call_scan(expression: String, idx: int): bool =
    match expression[idx] with
    case Some { char } ->
        if unsafe_run_call_at(expression, idx, "unsafe_run") | unsafe_run_call_at(expression, idx, "unsafeRun")
        then true
        else contains_unsafe_run_call_scan(expression, idx + 1)
    case _ -> false

private fun unsafe_run_call_at(expression: String, idx: int, name: String): bool =
    let end = idx + oo_string_size(name)
    if end > oo_string_size(expression)
    then false
    else if expression[idx, end] != name
    then false
    else unsafe_run_prefix_ok(expression, idx) & call_open_paren_after(expression, idx + oo_string_size(name))

private fun unsafe_run_prefix_ok(expression: String, idx: int): bool =
    if idx == 0
    then true
    else
        let previous_idx = previous_non_space_index(expression, idx - 1)
        if previous_idx < 0
        then true
        else
            match expression[previous_idx] with
            case Some { previous } -> previous == "." | !is_identifier_part(previous)
            case _ -> true

private fun call_open_paren_after(expression: String, idx: int): bool =
    let next_idx = next_non_space_index(expression, idx)
    match expression[next_idx] with
    case Some { next } -> next == "("
    case _ -> false

private fun is_call_expression(raw_expression: String): bool =
    let expression = trim(raw_expression)
    if oo_string_is_empty(expression) | !oo_string_ends_with(expression, ")")
    then false
    else
        let result = call_expression_scan(expression, 0, 0, "", -1)
        let balanced = result[0]
        let outer_open_paren = result[1]
        balanced & outer_open_paren > 0 & callee_looks_callable(trim(expression[0, outer_open_paren]))

private fun call_expression_scan(expression: String, idx: int, depth: int, string_delimiter: String, outer_open_paren: int): Tuple[bool, int] =
    match expression[idx] with
    case Some { char } ->
        if !oo_string_is_empty(string_delimiter)
        then
            if char == "\\"
            then call_expression_scan(expression, idx + 2, depth, string_delimiter, outer_open_paren)
            else if char == string_delimiter
                then call_expression_scan(expression, idx + 1, depth, "", outer_open_paren)
                else call_expression_scan(expression, idx + 1, depth, string_delimiter, outer_open_paren)
        else if char == "\"" | char == "'"
            then call_expression_scan(expression, idx + 1, depth, char, outer_open_paren)
            else if char == "("
                then call_expression_scan(expression, idx + 1, depth + 1, "", if depth == 0 then idx else outer_open_paren)
                else if char == ")"
                    then
                        if depth <= 0
                        then (false, outer_open_paren)
                        else call_expression_scan(expression, idx + 1, depth - 1, "", outer_open_paren)
                    else call_expression_scan(expression, idx + 1, depth, "", outer_open_paren)
    case _ -> (depth == 0, outer_open_paren)

private fun callee_looks_callable(callee: String): bool =
    dotted_identifier_reference(callee)

private fun dotted_identifier_reference(value: String): bool =
    if oo_string_is_empty(value)
    then false
    else dotted_identifier_reference_scan(value, 0, true)

private fun dotted_identifier_reference_scan(value: String, idx: int, expect_start: bool): bool =
    match value[idx] with
    case Some { char } ->
        if char == "."
        then
            if expect_start
            then false
            else dotted_identifier_reference_scan(value, idx + 1, true)
        else if expect_start
            then
                if is_identifier_start(char)
                then dotted_identifier_reference_scan(value, idx + 1, false)
                else false
            else
                if is_identifier_part(char)
                then dotted_identifier_reference_scan(value, idx + 1, false)
                else false
    case _ -> !expect_start

private fun strip_string_literals(value: String): String =
    strip_string_literals_scan(value, 0, "", "")

private fun strip_string_literals_scan(value: String, idx: int, delimiter: String, output: String): String =
    match value[idx] with
    case Some { char } ->
        if !oo_string_is_empty(delimiter)
        then
            if char == "\\"
            then strip_string_literals_scan(value, idx + 2, delimiter, output + "  ")
            else if char == delimiter
                then strip_string_literals_scan(value, idx + 1, "", output + " ")
                else strip_string_literals_scan(value, idx + 1, delimiter, output + " ")
        else if char == "\"" | char == "'"
            then strip_string_literals_scan(value, idx + 1, char, output + " ")
            else strip_string_literals_scan(value, idx + 1, "", output + char)
    case _ -> output

private fun join_strings(values: List[String], separator: String): String =
    join_strings_scan(values, separator, 0, "")

private fun join_strings_scan(values: List[String], separator: String, idx: int, output: String): String =
    match values[idx] with
    case Some { value } ->
        let next_output =
            if oo_string_is_empty(output)
            then value
            else output + separator + value
        join_strings_scan(values, separator, idx + 1, next_output)
    case _ -> output

private fun list_size(values: List[T]): int =
    list_size_scan(values, 0)

private fun list_size_scan(values: List[T], idx: int): int =
    match values[idx] with
    case Some { value } -> list_size_scan(values, idx + 1)
    case _ -> idx

private fun list_is_empty(values: List[T]): bool =
    list_size(values) == 0

private fun oo_list_contains(values: List[T], value: T): bool =
    oo_list_contains_scan(values, value, 0)

private fun oo_list_contains_scan(values: List[T], value: T, idx: int): bool =
    match values[idx] with
    case Some { current } ->
        if current == value
        then true
        else oo_list_contains_scan(values, value, idx + 1)
    case _ -> false

private fun oo_string_size(value: String): int =
    string_size_scan(value, 0)

private fun string_size_scan(value: String, idx: int): int =
    match value[idx] with
    case Some { char } -> string_size_scan(value, idx + 1)
    case _ -> idx

private fun oo_string_is_empty(value: String): bool =
    value == ""

private fun oo_string_ends_with(value: String, suffix: String): bool =
    let value_size = oo_string_size(value)
    let suffix_size = oo_string_size(suffix)
    value_size >= suffix_size & value[value_size - suffix_size, value_size] == suffix

private fun trim(value: String): String =
    let left = trim_left_index(value, 0)
    trim_right(value, left, oo_string_size(value) - 1)

private fun trim_left_index(value: String, idx: int): int =
    match value[idx] with
    case Some { char } ->
        if is_space(char)
        then trim_left_index(value, idx + 1)
        else idx
    case _ -> idx

private fun trim_right(value: String, left_idx: int, right_idx: int): String =
    if right_idx < left_idx
    then ""
    else
        match value[right_idx] with
        case Some { char } ->
            if is_space(char)
            then trim_right(value, left_idx, right_idx - 1)
            else value[left_idx, right_idx + 1]
        case _ -> ""

private fun next_non_space_index(value: String, idx: int): int =
    match value[idx] with
    case Some { char } ->
        if is_space(char)
        then next_non_space_index(value, idx + 1)
        else idx
    case _ -> idx

private fun previous_non_space_index(value: String, idx: int): int =
    if idx < 0
    then -1
    else
        match value[idx] with
        case Some { char } ->
            if is_space(char)
            then previous_non_space_index(value, idx - 1)
            else idx
        case _ -> -1

private fun identifier_end(value: String, idx: int): int =
    match value[idx] with
    case Some { char } ->
        if is_identifier_part(char)
        then identifier_end(value, idx + 1)
        else idx
    case _ -> idx

private fun is_identifier_start(char: String): bool =
    char == "_" | is_lowercase_char(char) | is_uppercase_char(char)

private fun is_identifier_part(char: String): bool =
    is_identifier_start(char) | is_digit_char(char)

private fun is_lowercase_char(char: String): bool =
    char_in(char, "abcdefghijklmnopqrstuvwxyz")

private fun is_uppercase_char(char: String): bool =
    char_in(char, "ABCDEFGHIJKLMNOPQRSTUVWXYZ")

private fun is_digit_char(char: String): bool =
    char_in(char, "0123456789")

private fun is_space(char: String): bool =
    char == " " | char == "\n" | char == "\r" | char == "\t"

private fun char_in(char: String, chars: String): bool =
    char_in_scan(char, chars, 0)

private fun char_in_scan(char: String, chars: String, idx: int): bool =
    match chars[idx] with
    case Some { current } ->
        if current == char
        then true
        else char_in_scan(char, chars, idx + 1)
    case _ -> false

private fun int_to_string(value: int): String =
    "" + value

private fun simple_type_name(name: String): String =
    simple_type_name_scan(name, 0, 0)

private fun simple_type_name_scan(name: String, idx: int, start_idx: int): String =
    match name[idx] with
    case Some { char } ->
        if char == "/" | char == "."
        then simple_type_name_scan(name, idx + 1, idx + 1)
        else simple_type_name_scan(name, idx + 1, start_idx)
    case _ -> name[start_idx, oo_string_size(name)]

private fun module_file(module: Tuple[String, List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]], List[Tuple[int, List[int]]], List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]]): String =
    module[0]

private fun module_definitions(module: Tuple[String, List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]], List[Tuple[int, List[int]]], List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]]): List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]] =
    module[1]

private fun module_members(module: Tuple[String, List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]], List[Tuple[int, List[int]]], List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]]): List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]] =
    module[2]

private fun module_blocks(module: Tuple[String, List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]], List[Tuple[int, List[int]]], List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]]): List[Tuple[int, List[int]]] =
    module[3]

private fun module_statements(module: Tuple[String, List[Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]], List[Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]], List[Tuple[int, List[int]]], List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]]]): List[Tuple[int, String, String, String, String, List[Tuple[String, String]], Tuple[String, String, int], int, int, List[Tuple[String, int]], String]] =
    module[4]

