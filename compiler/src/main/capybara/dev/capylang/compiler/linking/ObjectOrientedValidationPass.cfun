private fun member_modifiers(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): List[String] =
    member[5]

private fun member_has_body(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): bool =
    member[6]

private fun member_body(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): Tuple[String, String, int] =
    member[7]

private fun member_has_initializer(member: Tuple[String, String, String, String, String, List[String], bool, Tuple[String, String, int], bool, String, List[Tuple[String, String]]]): bool =
