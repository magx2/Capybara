    definition[0]

private fun definition_name(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): String =
    definition[1]

private fun definition_constructor_parameters(definition: Tuple[String, String, List[Tuple[String, String]], List[String], List[String]]): List[Tuple[String, String]] =
