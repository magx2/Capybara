from /capy/lang/Option import { Option }

enum InfixOperator {
    PLUS,
    MINUS,
    MUL,
    DIV,
    MOD,
    POWER,
    BITWISE_AND,
    BITWISE_NAND,
    BITWISE_OR,
    BITWISE_XOR,
    BITWISE_NOT,
    GT,
    LT,
    EQUAL,
    NOTEQUAL,
    LE,
    GE,
    AND,
    QUESTION,
    TILDE,
    TILDE_TILDE,
    TILDE_GT,
    DIV_GT,
    PIPE,
    PIPE_MINUS,
    PIPE_FLATMAP,
    PIPE_REDUCE
}

fun fromSymbol(value: String): Option[InfixOperator] =
    match value with
    case "+" -> Some { InfixOperator.PLUS }
    case "-" -> Some { InfixOperator.MINUS }
    case "*" -> Some { InfixOperator.MUL }
    case "/" -> Some { InfixOperator.DIV }
    case "%" -> Some { InfixOperator.MOD }
    case "^" -> Some { InfixOperator.POWER }
    case ".and." -> Some { InfixOperator.BITWISE_AND }
    case ".nand." -> Some { InfixOperator.BITWISE_NAND }
    case ".or." -> Some { InfixOperator.BITWISE_OR }
    case ".xor." -> Some { InfixOperator.BITWISE_XOR }
    case ".not." -> Some { InfixOperator.BITWISE_NOT }
    case ">" -> Some { InfixOperator.GT }
    case "<" -> Some { InfixOperator.LT }
    case "==" -> Some { InfixOperator.EQUAL }
    case "!=" -> Some { InfixOperator.NOTEQUAL }
    case "<=" -> Some { InfixOperator.LE }
    case ">=" -> Some { InfixOperator.GE }
    case "&" -> Some { InfixOperator.AND }
    case "?" -> Some { InfixOperator.QUESTION }
    case "~" -> Some { InfixOperator.TILDE }
    case "~~" -> Some { InfixOperator.TILDE_TILDE }
    case "~>" -> Some { InfixOperator.TILDE_GT }
    case "/>" -> Some { InfixOperator.DIV_GT }
    case "|" -> Some { InfixOperator.PIPE }
    case "|-" -> Some { InfixOperator.PIPE_MINUS }
    case "|*" -> Some { InfixOperator.PIPE_FLATMAP }
    case "|>" -> Some { InfixOperator.PIPE_REDUCE }
    case _ -> None {}

fun symbol(operator: InfixOperator): String =
    match operator with
    case PLUS -> "+"
    case MINUS -> "-"
    case MUL -> "*"
    case DIV -> "/"
    case MOD -> "%"
    case POWER -> "^"
    case BITWISE_AND -> ".and."
    case BITWISE_NAND -> ".nand."
    case BITWISE_OR -> ".or."
    case BITWISE_XOR -> ".xor."
    case BITWISE_NOT -> ".not."
    case GT -> ">"
    case LT -> "<"
    case EQUAL -> "=="
    case NOTEQUAL -> "!="
    case LE -> "<="
    case GE -> ">="
    case AND -> "&"
    case QUESTION -> "?"
    case TILDE -> "~"
    case TILDE_TILDE -> "~~"
    case TILDE_GT -> "~>"
    case DIV_GT -> "/>"
    case PIPE -> "|"
    case PIPE_MINUS -> "|-"
    case PIPE_FLATMAP -> "|*"
    case PIPE_REDUCE -> "|>"

fun quotedSymbol(operator: InfixOperator): String =
    "\"" + symbol(operator) + "\""

fun javaSymbol(operator: InfixOperator): String =
    match operator with
    case BITWISE_NOT -> "~"
    case BITWISE_AND -> "&"
    case BITWISE_NAND -> "&"
    case BITWISE_OR -> "|"
    case BITWISE_XOR -> "^"
    case _ -> symbol(operator)

fun precedence(operator: InfixOperator): int =
    match operator with
    case BITWISE_NOT -> 8
    case POWER -> 7
    case MUL -> 6
    case DIV -> 6
    case MOD -> 6
    case PLUS -> 5
    case MINUS -> 5
    case BITWISE_AND -> 5
    case BITWISE_NAND -> 5
    case BITWISE_OR -> 5
    case BITWISE_XOR -> 5
    case GT -> 4
    case LT -> 4
    case LE -> 4
    case GE -> 4
    case EQUAL -> 3
    case NOTEQUAL -> 3
    case AND -> 2
    case QUESTION -> 2
    case TILDE -> 2
    case TILDE_TILDE -> 2
    case TILDE_GT -> 2
    case DIV_GT -> 2
    case PIPE -> 1
    case PIPE_MINUS -> 1
    case PIPE_FLATMAP -> 1
    case PIPE_REDUCE -> 1
