from /capy/lang/Option import { * }
from /dev/capylang/compiler/CompiledAnnotation import { CompiledAnnotation }
from /dev/capylang/compiler/parser/SourcePosition import { SourcePosition }

union ObjectOriented =
    ObjectOrientedSource

data ObjectOrientedSource {
    definitions: List[TypeDeclaration],
    nativeProviders: List[NativeProviderDeclaration]
}

union AnnotationValue =
    AnnotationStringValue
    | AnnotationIntValue
    | AnnotationLongValue
    | AnnotationFloatValue
    | AnnotationDoubleValue
    | AnnotationBoolValue
    | AnnotationNothingValue
    | AnnotationTypeNameValue

data AnnotationStringValue { value: String, position: Option[SourcePosition] }
data AnnotationIntValue { value: String, position: Option[SourcePosition] }
data AnnotationLongValue { value: String, position: Option[SourcePosition] }
data AnnotationFloatValue { value: String, position: Option[SourcePosition] }
data AnnotationDoubleValue { value: String, position: Option[SourcePosition] }
data AnnotationBoolValue { value: bool, position: Option[SourcePosition] }
data AnnotationNothingValue { position: Option[SourcePosition] }
data AnnotationTypeNameValue { name: String, position: Option[SourcePosition] }

data AnnotationArgument {
    name: String,
    value: AnnotationValue,
    position: Option[SourcePosition]
}

data AnnotationUsage {
    name: String,
    arguments: List[AnnotationArgument],
    position: Option[SourcePosition]
}

fun ObjectOriented.definitions(): List[TypeDeclaration] =
    match this with
    case ObjectOrientedSource { definitions, nativeProviders } -> definitions

fun ObjectOriented.nativeProviders(): List[NativeProviderDeclaration] =
    match this with
    case ObjectOrientedSource { definitions, nativeProviders } -> nativeProviders

union TypeDeclaration =
    ClassDeclaration
    | TraitDeclaration
    | InterfaceDeclaration

fun TypeDeclaration.name(): String =
    match this with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } -> name
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> name
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> name

fun TypeDeclaration.parents(): List[TypeReference] =
    match this with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } -> parents
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> parents
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> parents

fun TypeDeclaration.members(): List[MemberDeclaration] =
    match this with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } -> members
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> members
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> members

fun TypeDeclaration.linkedAnnotations(): List[CompiledAnnotation] =
    match this with
    case ClassDeclaration { name, constructorParameters, parents, members, modifiers, comments, annotations, linkedAnnotations } -> linkedAnnotations
    case TraitDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> linkedAnnotations
    case InterfaceDeclaration { name, parents, members, comments, annotations, linkedAnnotations } -> linkedAnnotations

union MemberDeclaration =
    FieldDeclaration
    | MethodDeclaration
    | InitBlock

fun MemberDeclaration.linkedAnnotations(): List[CompiledAnnotation] =
    match this with
    case FieldDeclaration { name, type, visibility, initializer, comments, annotations, linkedAnnotations } -> linkedAnnotations
    case MethodDeclaration { name, parameters, returnType, visibility, modifiers, body, comments, annotations, linkedAnnotations } -> linkedAnnotations
    case InitBlock { body, comments, annotations, linkedAnnotations } -> linkedAnnotations

union MethodBody =
    ExpressionBody
    | StatementBlock

union Statement =
    LetStatement
    | LocalMethodStatement
    | MutableVariableStatement
    | AssignmentStatement
    | ExpressionStatement
    | ThrowStatement
    | ReturnStatement
    | IfStatement
    | TryCatchStatement
    | WhileStatement
    | DoWhileStatement
    | ForEachStatement
    | StatementBlock

data ClassDeclaration {
    name: String,
    constructorParameters: List[Parameter],
    parents: List[TypeReference],
    members: List[MemberDeclaration],
    modifiers: List[String],
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data TraitDeclaration {
    name: String,
    parents: List[TypeReference],
    members: List[MemberDeclaration],
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data InterfaceDeclaration {
    name: String,
    parents: List[TypeReference],
    members: List[MemberDeclaration],
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data NativeProviderDeclaration {
    name: String,
    targetType: String,
    qualifier: String,
    comments: List[String]
}

data FieldDeclaration {
    name: String,
    type: String,
    visibility: String,
    initializer: Option[String],
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data MethodDeclaration {
    name: String,
    parameters: List[Parameter],
    returnType: String,
    visibility: String,
    modifiers: List[String],
    body: Option[MethodBody],
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data InitBlock {
    body: StatementBlock,
    comments: List[String],
    annotations: List[AnnotationUsage],
    linkedAnnotations: List[CompiledAnnotation]
}

data ExpressionBody { expression: String }
data StatementBlock { statements: List[Statement] }
data LetStatement { name: String, type: Option[String], expression: String }
data LocalMethodStatement { name: String, parameters: List[Parameter], returnType: String, body: MethodBody, comments: List[String] }
data MutableVariableStatement { name: String, type: Option[String], expression: String }
data AssignmentStatement { name: String, expression: String }
data ExpressionStatement { expression: String }
data ThrowStatement { expression: String }
data ReturnStatement { expression: String }
data IfStatement { condition: String, thenBranch: StatementBlock, elseBranch: Option[Statement] }
data TryCatchStatement { tryBlock: StatementBlock, catches: List[CatchClause] }
data CatchClause { name: String, body: StatementBlock }
data WhileStatement { condition: String, body: StatementBlock }
data DoWhileStatement { body: StatementBlock, condition: String }
data ForEachStatement { name: String, type: Option[String], iterable: String, body: StatementBlock }
data Parameter { name: String, type: String }
data TypeReference { name: String }
