/// Capybara-owned Python backend output planning.
///
/// Java still renders the transition modules while this pass owns file
/// ordering and native-provider bootstrap output.
data String { <native> }
data List[T] { <native> }

fun String.`+`(value: any): String = <native>
fun List[T].`+`(value: T): List[T] = <native>
fun List[T].`+`(other: List[T]): List[T] = <native>

fun generated_python_file(relative_path: String, code: String): Tuple[String, String] =
    (relative_path, code)

fun generated_python_file_relative_path(file: Tuple[String, String]): String =
    file[0]

fun generated_python_file_code(file: Tuple[String, String]): String =
    file[1]

fun python_native_provider_method_info(name: String, arity: int): Tuple[String, int] =
    (name, arity)

fun python_native_provider_info(
    provider_symbol_name: String,
    bootstrap_function_name: String,
    interface_id: String,
    qualifier: String,
    lifetime: String,
    source_file: String,
    module_name: String,
    class_name: String,
    factory: String,
    methods: List[Tuple[String, int]]
): Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]] =
    (
        provider_symbol_name,
        bootstrap_function_name,
        interface_id,
        qualifier,
        lifetime,
        source_file,
        module_name,
        class_name,
        factory,
        methods
    )

fun plan_python_generation(
    rendered_files: List[Tuple[String, String]],
    native_providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]]
): List[Tuple[String, String]] =
    python_generated_file_order(rendered_files + python_native_provider_bootstrap_files(native_providers))

private fun python_generated_file_order(files: List[Tuple[String, String]]): List[Tuple[String, String]] =
    files

private fun python_native_provider_bootstrap_files(
    providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]]
): List[Tuple[String, String]] =
    match providers[0] with
    case Some _ -> [generated_python_file("dev/capylang/native_providers.py", render_python_native_provider_bootstrap(providers))]
    case _ -> []

private fun render_python_native_provider_bootstrap(
    providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]]
): String =
    "# Generated by Capybara. Do not edit." + py_nl()
    + "import dev.capylang.capybara as capy" + py_nl()
    + render_python_native_provider_imports(providers, 0)
    + py_nl()
    + "_providers = capy.define_native_providers({" + py_nl()
    + render_python_native_provider_entries(providers, 0)
    + "})" + py_nl() + py_nl()
    + render_python_native_provider_functions(providers, 0)

private fun render_python_native_provider_imports(
    providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]],
    idx: int
): String =
    match providers[idx] with
    case Some { provider } ->
        render_python_native_provider_import(provider)
        + render_python_native_provider_imports(providers, idx + 1)
    case _ -> ""

private fun render_python_native_provider_import(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    python_native_provider_class_variable(provider)
    + " = capy.require_native_provider_class("
    + "module_name=" + py_string(python_native_provider_module_name(provider))
    + ", class_name=" + py_string(python_native_provider_class_name(provider))
    + ", metadata=" + render_python_native_provider_load_metadata(provider)
    + ")" + py_nl()

private fun render_python_native_provider_load_metadata(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    py_lbrace()
    + py_string("interfaceId") + ": " + py_string(python_native_provider_interface_id(provider))
    + ", " + py_string("qualifier") + ": " + py_string(python_native_provider_qualifier(provider))
    + ", " + py_string("providerSymbol") + ": " + py_string(python_native_provider_symbol_name(provider))
    + ", " + py_string("backend") + ": " + py_string("python")
    + ", " + py_string("sourceFile") + ": " + py_string(python_native_provider_source_file(provider))
    + ", " + py_string("moduleName") + ": " + py_string(python_native_provider_module_name(provider))
    + ", " + py_string("className") + ": " + py_string(python_native_provider_class_name(provider))
    + py_rbrace()

private fun render_python_native_provider_entries(
    providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]],
    idx: int
): String =
    match providers[idx] with
    case Some { provider } ->
        render_python_native_provider_entry(provider)
        + render_python_native_provider_entries(providers, idx + 1)
    case _ -> ""

private fun render_python_native_provider_entry(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    "    " + py_string(python_native_provider_bootstrap_key(provider)) + ": capy.native_factory(" + py_nl()
    + "        interface_id=" + py_string(python_native_provider_interface_id(provider)) + "," + py_nl()
    + "        qualifier=" + py_string(python_native_provider_qualifier(provider)) + "," + py_nl()
    + "        provider_symbol=" + py_string(python_native_provider_symbol_name(provider)) + "," + py_nl()
    + "        backend='python'," + py_nl()
    + "        source_file=" + py_string(python_native_provider_source_file(provider)) + "," + py_nl()
    + "        module_name=" + py_string(python_native_provider_module_name(provider)) + "," + py_nl()
    + "        class_name=" + py_string(python_native_provider_class_name(provider)) + "," + py_nl()
    + "        factory=" + py_string(python_native_provider_factory(provider)) + "," + py_nl()
    + "        lifetime=" + py_string(python_native_provider_lifetime(provider)) + "," + py_nl()
    + "        metadata=" + py_lbrace() + py_string("methods") + ": " + render_python_native_provider_methods(python_native_provider_methods(provider), 0) + py_rbrace() + "," + py_nl()
    + "        create=lambda: " + render_python_native_provider_factory(provider) + "," + py_nl()
    + "    )," + py_nl()

private fun render_python_native_provider_methods(methods: List[Tuple[String, int]], idx: int): String =
    match methods[idx] with
    case Some { method } ->
        let separator = match methods[idx + 1] with
            case Some _ -> ", "
            case _ -> ""
        if idx == 0
        then "[" + render_python_native_provider_method(method) + separator + render_python_native_provider_methods(methods, idx + 1)
        else render_python_native_provider_method(method) + separator + render_python_native_provider_methods(methods, idx + 1)
    case _ ->
        if idx == 0
        then "[]"
        else "]"

private fun render_python_native_provider_method(method: Tuple[String, int]): String =
    py_lbrace()
    + py_string("name") + ": " + py_string(python_native_provider_method_name(method))
    + ", " + py_string("arity") + ": " + python_native_provider_method_arity(method)
    + py_rbrace()

private fun render_python_native_provider_functions(
    providers: List[Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]],
    idx: int
): String =
    match providers[idx] with
    case Some { provider } ->
        render_python_native_provider_function(provider) + py_nl()
        + render_python_native_provider_functions(providers, idx + 1)
    case _ -> ""

private fun render_python_native_provider_function(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    "def " + python_native_provider_bootstrap_function_name(provider) + "():" + py_nl()
    + "    return _providers.resolve(" + py_string(python_native_provider_interface_id(provider))
    + ", " + py_string(python_native_provider_qualifier(provider))
    + ", " + py_string(python_native_provider_symbol_name(provider))
    + ", 'python', " + py_string(python_native_provider_source_file(provider)) + ")" + py_nl()

private fun render_python_native_provider_factory(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    python_native_provider_class_variable(provider) + "()"

private fun python_native_provider_class_variable(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    "__capy_provider_" + python_native_provider_bootstrap_function_name(provider) + "_class"

private fun python_native_provider_bootstrap_key(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    python_native_provider_interface_id(provider) + "#" + python_native_provider_qualifier(provider)

private fun python_native_provider_symbol_name(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[0]

private fun python_native_provider_bootstrap_function_name(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[1]

private fun python_native_provider_interface_id(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[2]

private fun python_native_provider_qualifier(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[3]

private fun python_native_provider_lifetime(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[4]

private fun python_native_provider_source_file(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[5]

private fun python_native_provider_module_name(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[6]

private fun python_native_provider_class_name(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[7]

private fun python_native_provider_factory(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): String =
    provider[8]

private fun python_native_provider_methods(
    provider: Tuple[String, String, String, String, String, String, String, String, String, List[Tuple[String, int]]]
): List[Tuple[String, int]] =
    provider[9]

private fun python_native_provider_method_name(method: Tuple[String, int]): String =
    method[0]

private fun python_native_provider_method_arity(method: Tuple[String, int]): int =
    method[1]

private fun py_nl(): String = '\n'

private fun py_lbrace(): String = "{"

private fun py_rbrace(): String = "}"

private fun py_string(value: String): String =
    "'" + py_string_body(value, 0, "") + "'"

private fun py_string_body(value: String, idx: int, output: String): String =
    match value[idx] with
    case Some { char } -> py_string_body(value, idx + 1, output + py_string_char(char))
    case _ -> output

private fun py_string_char(char: String): String =
    if char == "\\"
    then "\\\\"
    else if char == "'"
        then "\\'"
        else if char == '\r'
            then "\\r"
            else if char == '\n'
                then "\\n"
                else char
