from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Option import { * }
from /capy/lang/Result import { * }
from /capy/test/CapyTest import { * }
from /capy/serialization/Json import { * }

data JsonPrimitiveSample {
    name: string,
    age: int,
    external_id: long,
    score: double,
    ratio: float,
    active: bool
}
data JsonCollectionSample { numbers: list[int], flags: dict[bool] }
data JsonSetSample { tags: set[string] }
data JsonInnerSample { label: string, count: int }
enum JsonSampleStatus { PENDING, COMPLETE }
data JsonLambdaSample { callback: () => string }
data JsonWrapperSample {
    present: Option[string],
    absent: Option[string],
    success: Result[int],
    error: Result[int],
    inner: JsonInnerSample,
    status: JsonSampleStatus,
    raw: Json
}
data JsonablePrimitiveSample { name: string, age: int, active: bool } derive Jsonable
data JsonableNestedSample {
    user: JsonablePrimitiveSample,
    labels: list[string],
    metadata: dict[int],
    raw: Json
} derive Jsonable

fun tests(): Effect[TestFile] =
    test_file("/capy/lang/Json.cfun", [
        test("should convert data with primitive fields to json object", () => should_convert_data_with_primitive_fields_to_json_object()),
        test("should convert data with collection fields to json object", () => should_convert_data_with_collection_fields_to_json_object()),
        test("should convert data with set field to json array", () => should_convert_data_with_set_field_to_json_array()),
        test("should convert data with wrapper and nested fields to json object", () => should_convert_data_with_wrapper_and_nested_fields_to_json_object()),
        test("should convert enum to json string", () => should_convert_enum_to_json_string()),
        test("should fail converting lambda field", () => should_fail_converting_lambda_field()),
        test("should derive Jsonable to_json for primitive fields", () => should_derive_jsonable_to_json_for_primitive_fields()),
        test("should derive Jsonable to_json for nested and collection fields", () => should_derive_jsonable_to_json_for_nested_and_collection_fields()),
        test("should index json object and array containers", () => should_index_json_object_and_array_containers()),
        test("should index json value container wrappers", () => should_index_json_value_container_wrappers()),
        test("should serialize simple object", () => test_serialize_simple_object()),
        test("should serialize empty object", () => test_empty()),
        test("should serialize object with primitive types", () => test_serialize_object_with_primitive_types()),
        test("should serialize object with list", () => test_serialize_object_with_list()),
        test("should stringify top-level json values", () => should_stringify_top_level_json_values()),
        test("should deserialize simple object", () => should_deserialize_simple_object()),
        test("should deserialize object with number as long types", () => should_deserialize_object_with_number_as_long_types()),
        test("should deserialize object with number as double types", () => should_deserialize_object_with_number_as_double_types()),
        test("should deserialize object with number as double types in exponential notation", () => should_deserialize_object_with_number_as_double_types_in_exponential_notation()),
        test("should deserialize object as bool types", () => should_deserialize_object_as_bool_types()),
        test("should fail deserialize object as bool types", () => should_fail_deserialize_object_as_bool_types()),
        test("should deserialize object as null", () => should_deserialize_object_as_null()),
        test("should fail deserialize object as null", () => should_fail_deserialize_object_as_null()),
        test("should deserialize empty array", () => should_deserialize_empty_array()),
        test("should deserialize array with values", () => should_deserialize_array_with_values()),
        test("should deserialize array with objects", () => should_deserialize_array_with_objects()),
        test("should deserialize array with arrays", () => should_deserialize_array_with_arrays()),
        test("should deserialize JSON with whitespaces", () => should_deserialize_json_with_white_spaces()),
    ])

fun should_convert_data_with_primitive_fields_to_json_object(): Assert =
    let sample = JsonPrimitiveSample {
        name: "Ada",
        age: 42,
        external_id: 9876543210L,
        score: 99.5,
        ratio: 0.75f,
        active: true
    }
    assert_that(to_json(sample)).succeeds(JsonObject {
        value: {
            "name": JsonString { value: "Ada" },
            "age": JsonNumberLong { value: 42 },
            "external_id": JsonNumberLong { value: 9876543210L },
            "score": JsonNumberDouble { value: 99.5 },
            "ratio": JsonNumberDouble { value: 0.75 },
            "active": JsonBool { value: true },
        }
    })

fun should_convert_data_with_collection_fields_to_json_object(): Assert =
    let sample = JsonCollectionSample {
        numbers: [1, 2, 3],
        flags: {
            "debug": true,
            "stable": false,
        }
    }
    assert_that(to_json(sample)).succeeds(JsonObject {
        value: {
            "numbers": JsonArray {
                value: [
                    JsonNumberLong { value: 1 },
                    JsonNumberLong { value: 2 },
                    JsonNumberLong { value: 3 },
                ]
            },
            "flags": JsonObject {
                value: {
                    "debug": JsonBool { value: true },
                    "stable": JsonBool { value: false },
                }
            },
        }
    })

fun should_convert_data_with_set_field_to_json_array(): Assert =
    assert_that(to_json(JsonSetSample { tags: {"red", "blue"} })).succeeds(obj =>
        match _json_field(obj, "tags") with
        case Some { tags } -> {
            match tags with
            case JsonArray { values } ->
                assert_that(values)
                    .has_size(2)
                    .contains(JsonString { value: "red" })
                    .contains(JsonString { value: "blue" })
            case _ -> assert_that(false).is_true()
        }
        case None -> assert_that(false).is_true()
    )

fun should_convert_data_with_wrapper_and_nested_fields_to_json_object(): Assert =
    let sample = JsonWrapperSample {
        present: Some { value: "value" },
        absent: None {},
        success: Success { value: 7 },
        error: Error { message: "bad" },
        inner: JsonInnerSample { label: "child", count: 2 },
        status: COMPLETE {},
        raw: JsonArray { value: [JsonString { value: "kept" }] }
    }
    assert_that(to_json(sample)).succeeds(JsonObject {
        value: {
            "present": JsonString { value: "value" },
            "absent": JsonNull {},
            "success": JsonNumberLong { value: 7 },
            "error": JsonString { value: "bad" },
            "inner": JsonObject {
                value: {
                    "label": JsonString { value: "child" },
                    "count": JsonNumberLong { value: 2 },
                }
            },
            "status": JsonString { value: "COMPLETE" },
            "raw": JsonArray {
                value: [JsonString { value: "kept" }]
            },
        }
    })

fun should_convert_enum_to_json_string(): Assert =
    assert_that(to_json(JsonWrapperSample {
        present: None {},
        absent: None {},
        success: Success { value: 1 },
        error: Error { message: "ignored" },
        inner: JsonInnerSample { label: "enum", count: 1 },
        status: PENDING {},
        raw: JsonNull {}
    })).succeeds(obj =>
        match _json_field(obj, "status") with
        case Some { json } -> {
            match json with
            case JsonString { value } -> assert_that(value).is_equal_to("PENDING")
            case _ -> assert_that(false).is_true()
        }
        case _ -> assert_that(false).is_true()
    )

fun should_fail_converting_lambda_field(): Assert =
    let sample = JsonLambdaSample {
        callback: () => "ignored"
    }
    assert_that(to_json(sample)).fails("Cannot convert field `callback` to JSON: unsupported value")

fun should_derive_jsonable_to_json_for_primitive_fields(): Assert =
    assert_that(JsonablePrimitiveSample {
        name: "Ada",
        age: 42,
        active: true
    }.to_json()).succeeds(JsonObject {
        value: {
            "name": JsonString { value: "Ada" },
            "age": JsonNumberLong { value: 42 },
            "active": JsonBool { value: true },
        }
    })

fun should_derive_jsonable_to_json_for_nested_and_collection_fields(): Assert =
    assert_that(JsonableNestedSample {
        user: JsonablePrimitiveSample { name: "Grace", age: 36, active: false },
        labels: ["compiler", "json"],
        metadata: { "stars": 5 },
        raw: JsonArray { value: [JsonString { value: "kept" }] }
    }.to_json()).succeeds(JsonObject {
        value: {
            "user": JsonObject {
                value: {
                    "name": JsonString { value: "Grace" },
                    "age": JsonNumberLong { value: 36 },
                    "active": JsonBool { value: false },
                }
            },
            "labels": JsonArray {
                value: [
                    JsonString { value: "compiler" },
                    JsonString { value: "json" },
                ]
            },
            "metadata": JsonObject {
                value: {
                    "stars": JsonNumberLong { value: 5 },
                }
            },
            "raw": JsonArray {
                value: [JsonString { value: "kept" }]
            },
        }
    })

fun _json_field(json: JsonObject, name: string): Option[Json] =
    json.value |> None {}, (acc, key, value) =>
        if key == name then Some { value } else acc

fun should_index_json_object_and_array_containers(): Assert =
    let object = JsonObject {
        value: {
            "name": JsonString { value: "Ada" },
            "numbers": JsonArray {
                value: [
                    JsonNumberLong { value: 1 },
                    JsonNumberLong { value: 2 },
                ]
            },
        }
    }
    let array = JsonArray {
        value: [
            JsonString { value: "first" },
            JsonBool { value: true },
        ]
    }
    assert_all([
        assert_that(object["name"]).contains(JsonString { value: "Ada" }),
        assert_that(object["missing"]).is_empty(),
        assert_that(array[1]).contains(JsonBool { value: true }),
        assert_that(array[3]).is_empty(),
    ])

fun should_index_json_value_container_wrappers(): Assert =
    let object = JsonValueObject {
        value: JsonObject {
            value: { "enabled": JsonBool { value: true } }
        }
    }
    let array = JsonValueArray {
        value: JsonArray {
            value: [JsonNumberLong { value: 7 }]
        }
    }
    assert_all([
        assert_that(object["enabled"]).contains(JsonBool { value: true }),
        assert_that(array[0]).contains(JsonNumberLong { value: 7 }),
    ])

fun test_serialize_simple_object(): Assert =
    let json = JsonObject { value: { "foo": JsonString { value: "boo" } } }
    let ser = serialize(json)
    assert_that(ser).is_equal_to("{\"foo\":\"boo\"}")

fun test_empty(): Assert =
    let json = JsonObject { value: { : } }
    let ser = serialize(json)
    assert_that(ser).is_equal_to('{}')

fun test_serialize_object_with_primitive_types(): Assert =
    let json = JsonObject { value: {
        "name": JsonString { value: "Tom" },
        "age" : JsonNumberLong { value: 50 },
        "ageLong" : JsonNumberLong { value: 50L },
        "ageDouble" : JsonNumberDouble { value: 50.5 },
        "ageFloat" : JsonNumberDouble { value: 60.5f },
        "married" : JsonBool { value: true },
        "car" : JsonNull {},
    }};
    let ser = serialize(json)
    assert_that(ser)
        .starts_with("{")
        .does_not_start_with("{,")
        .contains('"name":"Tom"')
        .contains('"age":50')
        .contains('"ageLong":50')
        .contains('"ageDouble":50.5')
        .contains('"ageFloat":60.5')
        .contains('"married":true')
        .contains('"car":null')

fun test_serialize_object_with_list(): Assert =
    let json = JsonObject { value: {
        "cars": JsonArray { value: [
            JsonString { value: "name" },
            JsonNumberLong { value: 2010L },
        ] },
    }}
    let ser = serialize(json)
    assert_that(ser)
        .contains('"cars":["name",2010]')

fun should_stringify_top_level_json_values(): Assert =
    assert_all([
        assert_that(stringify(JsonObject { value: { "name": JsonString { value: "Ada" } } })).is_equal_to('{"name":"Ada"}'),
        assert_that(stringify(JsonArray { value: [JsonString { value: "Ada" }] })).is_equal_to('["Ada"]'),
        assert_that(stringify(JsonString { value: "Ada" })).is_equal_to('"Ada"'),
        assert_that(stringify(JsonNumberLong { value: 7L })).is_equal_to("7"),
        assert_that(stringify(JsonNumberDouble { value: 1.5 })).is_equal_to("1.5"),
        assert_that(stringify(JsonBool { value: true })).is_equal_to("true"),
        assert_that(stringify(JsonNull {})).is_equal_to("null"),
    ])

fun should_deserialize_simple_object(): Assert =
    assert_that(deserialize('{"foo":"boo"}'))
        .succeeds(
            JsonObject {
                value: { "foo": JsonString { value: "boo" } }
            })

fun should_deserialize_object_with_number_as_long_types(): Assert =
    assert_that(deserialize('{"int":5,"int_minus":-5,"long":97387717187,"long_minus":-973877177}'))
        .succeeds(
                JsonObject {
                    value: {
                        "int": JsonNumberLong { value: 5 },
                        "int_minus": JsonNumberLong { value: -5 },
                        "long": JsonNumberLong { value: 97387717187L },
                        "long_minus": JsonNumberLong { value: -973877177L },
                    }
            })

fun should_deserialize_object_with_number_as_double_types(): Assert =
    assert_that(deserialize('{"int":5.5,"int_minus":-5.5,"long":97387716608.0,"long_minus":-97387720.0}'))
        .succeeds(
                JsonObject {
                    value: {
                        "int": JsonNumberDouble { value: 5.5 },
                        "int_minus": JsonNumberDouble { value: -5.5 },
                        "long": JsonNumberDouble { value: 97387716608.0 },
                        "long_minus": JsonNumberDouble { value: -97387720.0 },
                    }
            })

fun should_deserialize_object_with_number_as_double_types_in_exponential_notation(): Assert =
    assert_that(deserialize('{'+
        '"negative1":-9.731200516096E12,'+
        '"negative2":-9.731200516096e12,'+
        '"negative3":-9.731199668294721E-8,'+
        '"positive1":1.2345E7,'+
        '"positive2":1.2345e7,'+
        '"positive3":1.2345e+7,'+
        '"positive4":1.234499968916225E-8'+
        '}'))
        .succeeds(
                JsonObject {
                    value: {
                        "negative1": JsonNumberDouble { value: -9.731200516096E12 },
                        "negative2": JsonNumberDouble { value: -9.731200516096E12 },
                        "negative3": JsonNumberDouble { value: -9.731199668294721E-8 },
                        "positive1": JsonNumberDouble { value: 1.2345E7 },
                        "positive2": JsonNumberDouble { value: 1.2345E7 },
                        "positive3": JsonNumberDouble { value: 1.2345E7 },
                        "positive4": JsonNumberDouble { value: 1.234499968916225E-8 },
                    }
            })

fun should_deserialize_object_as_bool_types(): Assert =
    assert_that(deserialize('{"t":true,"f":false}'))
        .succeeds(
                JsonObject {
                    value: {
                        "t": JsonBool { value: true },
                        "f": JsonBool { value: false },
                    }
            })

fun should_fail_deserialize_object_as_bool_types(): Assert =
    assert_that(deserialize('{"t":tr}')).fails('Expected `true` or `false`, but got `tr`!')

fun should_deserialize_object_as_null(): Assert =
    assert_that(deserialize('{"foo":null}'))
        .succeeds(JsonObject { value: { "foo": JsonNull {} } })

fun should_fail_deserialize_object_as_null(): Assert =
    assert_that(deserialize('{"foo":nul}')).fails('Expected `null`, but got `nul`!')

fun should_deserialize_empty_array(): Assert =
    assert_that(deserialize('{"foo":[]}'))
        .succeeds(JsonObject { value: { "foo": JsonArray { value: [] } } })

fun should_deserialize_array_with_values(): Assert =
    assert_that(deserialize('{"foo":[1,"x",false,null]}'))
        .succeeds(JsonObject {
            value: {
                "foo": JsonArray {
                    value: [
                        JsonNumberLong { value: 1 },
                        JsonString { value: "x" },
                        JsonBool { value: false },
                        JsonNull {}
                    ]
                }
            }
        })

fun should_deserialize_array_with_objects(): Assert =
    assert_that(deserialize('{"foo":[{"name":"Tom","age":18},{"name":"Bob","age":19},{"name":"Marty","age":21}]}'))
        .succeeds(JsonObject {
            value: {
                "foo": JsonArray {
                    value: [
                        JsonObject { value: { "name": JsonString { value: "Tom" }, "age": JsonNumberLong { value: 18 } } },
                        JsonObject { value: { "name": JsonString { value: "Bob" }, "age": JsonNumberLong { value: 19 } } },
                        JsonObject { value: { "name": JsonString { value: "Marty" }, "age": JsonNumberLong { value: 21 } } },
                    ]
                }
            }
        })
fun should_deserialize_array_with_arrays(): Assert =
    assert_that(deserialize('{"foo":[[1,2,3],[4,5,6],[7,8,9]]}'))
        .succeeds(JsonObject {
            value: {
                "foo": JsonArray {
                    value: [
                        JsonArray { value: [JsonNumberLong { value: 1 }, JsonNumberLong { value: 2 }, JsonNumberLong { value: 3 }] },
                        JsonArray { value: [JsonNumberLong { value: 4 }, JsonNumberLong { value: 5 }, JsonNumberLong { value: 6 }] },
                        JsonArray { value: [JsonNumberLong { value: 7 }, JsonNumberLong { value: 8 }, JsonNumberLong { value: 9 }] },
                    ]
                }
            }
        })

fun should_deserialize_json_with_white_spaces(): Assert =
    //assert_that(deserialize('{  "foo"  :  [  { "name" :   \n " Tom "} , \t \n \r\n "y o u"  ,  2  ,  3  ]  }'))
    assert_that(deserialize('{  "foo"  :  [  { "name" :    " Tom "} ,  "y o u"  ,  2  ,  3  ]  }'))
        .succeeds(JsonObject {
            value: {
                "foo": JsonArray {
                    value: [
                        JsonObject { value: { "name": JsonString { value: " Tom " } } },
                        JsonString { value: "y o u" },
                        JsonNumberLong { value: 2 },
                        JsonNumberLong { value: 3 },
                    ]
                }
            }
        })
