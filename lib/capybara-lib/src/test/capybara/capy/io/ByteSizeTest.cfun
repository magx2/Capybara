from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Primitives import { * }
from /capy/lang/Result import { * }
from /capy/io/ByteSize import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    test_file("/capy/io/ByteSize.cfun", [
        test("byte_count accepts zero", () => should_construct_byte_count(0L, 0L)),
        test("byte_count rejects negative values", () => assert_that(byte_count { -1L }).fails("byte_count must be greater than or equal to 0")),
        test("byte_count addition returns byte_count", () => should_add_byte_count(1024L, 512L, 1536L)),
        test("byte_count addition rejects overflow", () => should_reject_byte_count_addition(MAX_LONG_VALUE, 1L)),
        test("byte_count subtraction validates result", () => should_subtract_byte_count(1024L, 512L, 512L)),
        test("byte_count subtraction rejects negative result", () => should_reject_byte_count_subtraction(512L, 1024L)),
        test("ZERO_BYTES is zero", () => assert_that(ZERO_BYTES.value).is_equal_to(0L)),
        test("ONE_KIB is 1024 bytes", () => assert_that(ONE_KIB.value).is_equal_to(1024L)),
        test("ONE_MIB is 1048576 bytes", () => assert_that(ONE_MIB.value).is_equal_to(1048576L)),
        test("ONE_GIB is 1073741824 bytes", () => assert_that(ONE_GIB.value).is_equal_to(1073741824L)),
        test("byte_count converts to kib", () => should_convert_to_kib(2048L, 2.0)),
        test("byte_count converts to mib", () => should_convert_to_mib(1048576L, 1.0)),
        test("byte_count converts to gib", () => should_convert_to_gib(1073741824L, 1.0)),
        test("byte_count comparison operators compare byte counts", () => should_compare_byte_counts()),
    ])

private fun should_construct_byte_count(value: long, expected: long): Assert =
    assert_that((byte_count { value }).reduce(actual => actual.value, _ => -1L)).is_equal_to(expected)

private fun should_add_byte_count(left: long, right: long, expected: long): Assert =
    assert_that(
        (byte_count { left }).reduce(
            left_value => (byte_count { right }).reduce(
                right_value => left_value.plus(right_value).reduce(actual => actual.value, _ => -1L),
                _ => -1L
            ),
            _ => -1L
        )
    ).is_equal_to(expected)

private fun should_reject_byte_count_addition(left: long, right: long): Assert =
    let message: String =
        (byte_count { left }).reduce(
            left_value => (byte_count { right }).reduce(
                right_value => left_value.plus(right_value).reduce(_ => "unexpected success", message => message),
                _ => "unexpected constructor failure"
            ),
            _ => "unexpected constructor failure"
        )
    assert_that(message).is_equal_to("byte_count addition overflow")

private fun should_subtract_byte_count(left: long, right: long, expected: long): Assert =
    assert_that(
        (byte_count { left }).reduce(
            left_value => (byte_count { right }).reduce(
                right_value => left_value.minus(right_value).reduce(actual => actual.value, _ => -1L),
                _ => -1L
            ),
            _ => -1L
        )
    ).is_equal_to(expected)

private fun should_reject_byte_count_subtraction(left: long, right: long): Assert =
    let message: String =
        (byte_count { left }).reduce(
            left_value => (byte_count { right }).reduce(
                right_value => left_value.minus(right_value).reduce(_ => "unexpected success", message => message),
                _ => "unexpected constructor failure"
            ),
            _ => "unexpected constructor failure"
        )
    assert_that(message).is_equal_to("byte_count must be greater than or equal to 0")

private fun should_convert_to_kib(value: long, expected: double): Assert =
    assert_that((byte_count { value }).reduce(actual => actual.to_kib(), _ => -1.0)).is_equal_to(expected)

private fun should_convert_to_mib(value: long, expected: double): Assert =
    assert_that((byte_count { value }).reduce(actual => actual.to_mib(), _ => -1.0)).is_equal_to(expected)

private fun should_convert_to_gib(value: long, expected: double): Assert =
    assert_that((byte_count { value }).reduce(actual => actual.to_gib(), _ => -1.0)).is_equal_to(expected)

private fun should_compare_byte_counts(): Assert =
    let zero = ZERO_BYTES
    let kib = ONE_KIB
    assert_all([
        assert_that(kib > zero).is_true(),
        assert_that(kib >= zero).is_true(),
        assert_that(zero < kib).is_true(),
        assert_that(zero <= kib).is_true(),
        assert_that(zero == ZERO_BYTES).is_true(),
    ])
