from /capy/collection/List import { * }
from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Validation import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    test_file("/capy/lang/Validation.cfun", [
        test("should create and map non-empty list", () => should_create_and_map_non_empty_list()),
        test("should map valid value", () => should_map_valid_value()),
        test("should keep invalid when mapping valid value", () => should_keep_invalid_when_mapping_valid_value()),
        test("should map errors", () => should_map_errors()),
        test("should flat map valid value", () => should_flat_map_valid_value()),
        test("should zip valid values", () => should_zip_valid_values()),
        test("should accumulate zip errors", () => should_accumulate_zip_errors()),
        test("should map two valid values", () => should_map_two_valid_values()),
        test("should convert to result", () => validation_should_convert_to_result()),
    ])

fun should_create_and_map_non_empty_list(): Assert =
    let errors = non_empty_list_with_tail("a", ["b"]).append("c").map(value => value + "!")
    assert_that(errors.as_list()).is_equal_to(["a!", "b!", "c!"])

fun _valid_int(value: int): Validation[String, int] = Valid { value }

fun _valid_string(value: String): Validation[String, String] = Valid { value }

fun _invalid_int(error: String): Validation[String, int] = Invalid { non_empty_list(error) }

fun _invalid_int(error: String, more_errors: List[String]): Validation[String, int] =
    Invalid { non_empty_list_with_tail(error, more_errors) }

fun _invalid_string(error: String, more_errors: List[String]): Validation[String, String] =
    Invalid { non_empty_list_with_tail(error, more_errors) }

fun _validation_plus_5(value: int): int = value + 5

fun should_map_valid_value(): Assert =
    let validation = _valid_int(10)
    assert_that(validation.map(:_validation_plus_5)).is_equal_to(Valid { 15 })

fun should_keep_invalid_when_mapping_valid_value(): Assert =
    let validation = _invalid_int("missing")
    assert_that(validation.map(:_validation_plus_5)).is_equal_to(Invalid { non_empty_list("missing") })

fun _validation_prefix_error(message: String): String = "error: " + message

fun should_map_errors(): Assert =
    let validation = _invalid_int("missing", ["bad"])
    assert_that(validation.map_error(:_validation_prefix_error)).is_equal_to(Invalid {
        non_empty_list_with_tail("error: missing", ["error: bad"])
    })

fun _valid_plus_5(value: int): Validation[String, int] = Valid { value + 5 }

fun _invalid_bad(value: int): Validation[String, int] = Invalid { non_empty_list("bad " + value) }

fun should_flat_map_valid_value(): Assert =
    let validation = _valid_int(10)
    assert_all([
        assert_that(validation.flat_map(:_valid_plus_5)).is_equal_to(Valid { 15 }),
        assert_that(validation.flat_map(:_invalid_bad)).is_equal_to(Invalid {
            non_empty_list("bad 10")
        }),
    ])

fun should_zip_valid_values(): Assert =
    let left = _valid_int(2)
    let right = _valid_string("ok")
    assert_that(left.zip(right)).is_equal_to(Valid { (2, "ok") })

fun should_accumulate_zip_errors(): Assert =
    let left = _invalid_int("name missing")
    let right = _invalid_string("age invalid", ["email invalid"])
    assert_that(left.zip(right)).is_equal_to(Invalid {
        non_empty_list_with_tail("name missing", ["age invalid", "email invalid"])
    })

fun _add(left: int, right: int): int = left + right

fun should_map_two_valid_values(): Assert =
    let left = _valid_int(2)
    let right = _valid_int(3)
    assert_that(left.map2(right, :_add)).is_equal_to(Valid { 5 })

fun _join_errors(errors: NonEmptyList[String]): String =
    errors.as_list().reduce("", (acc, error) =>
        if acc == "" then error else acc + ", " + error)

fun validation_should_convert_to_result(): Assert =
    let invalid = _invalid_int("name missing", ["age invalid"])
    let valid = _valid_int(42)
    assert_all([
        assert_that(invalid.to_result(:_join_errors)).fails("name missing, age invalid"),
        assert_that(valid.to_result(errors => "unused")).succeeds(42),
    ])
