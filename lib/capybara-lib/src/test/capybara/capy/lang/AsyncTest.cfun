from /capy/test/Assert import { * }
from /capy/lang/Async import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Result import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    test_file("/capy/lang/Async.cfun", [
        should_join_started_effect().map(assertion => test("should join started effect", () => assertion)),
        should_join_all_started_effects().map(assertion => test("should join all started effects", () => assertion)),
        should_join_all_started_effects_with_failures().map(assertion => test("should join all started effects with failures", () => assertion)),
        should_join_first_completed_effect().map(assertion => test("should join first completed effect", () => assertion)),
        should_return_error_for_empty_any().map(assertion => test("should return error for empty any", () => assertion)),
        should_capture_async_failure().map(assertion => test("should capture async failure", () => assertion)),
        should_map_async_value().map(assertion => test("should map async value", () => assertion)),
        should_pipe_async_value().map(assertion => test("should pipe async value", () => assertion)),
        should_flat_map_async_success().map(assertion => test("should flat map async success", () => assertion)),
        should_flat_pipe_async_success().map(assertion => test("should flat pipe async success", () => assertion)),
        should_flat_map_async_error().map(assertion => test("should flat map async error", () => assertion)),
    ])

fun should_join_started_effect(): Effect[Assert] =
    let task = pure(42).start()
    let result <- task.join()
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_join_all_started_effects(): Effect[Assert] =
    let first = pure(1).start()
    let second = pure(2).start()
    let results <- all([first, second])
    assert_that(success_values(results)).is_equal_to([1, 2])

fun should_join_all_started_effects_with_failures(): Effect[Assert] =
    let first = pure(1).start()
    let second = delay(() => portable_failure()).start()
    let results <- all([first, second])
    assert_that(result_kinds(results)).is_equal_to(["success", "capy.lang.async.failed"])

fun should_join_first_completed_effect(): Effect[Assert] =
    let task = pure(42).start()
    let result <- any([task])
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_return_error_for_empty_any(): Effect[Assert] =
    let result <- any([])
    match result with
    case Success _ -> assert_that(false).is_true()
    case Error error -> assert_that(error.kind).is_equal_to("capy.lang.async.empty")

fun should_capture_async_failure(): Effect[Assert] =
    let task = delay(() => portable_failure()).start()
    let result <- task.join()
    match result with
    case Success _ -> assert_that(false).is_true()
    case Error error -> assert_that(error.kind).is_equal_to("capy.lang.async.failed")

fun should_map_async_value(): Effect[Assert] =
    let task = pure(20).start()
    let result <- task.map(value => value + 22).join()
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_pipe_async_value(): Effect[Assert] =
    let task = pure(40).start()
    let result <- (task | value => value + 2).join()
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_flat_map_async_success(): Effect[Assert] =
    let task = pure(20).start()
    let result <- task.flat_map(value => Success { value + 22 }).join()
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_flat_pipe_async_success(): Effect[Assert] =
    let task = pure(41).start()
    let result <- (task |* value => Success { value + 1 }).join()
    match result with
    case Success { value } -> assert_that(value).is_equal_to(42)
    case Error _ -> assert_that(false).is_true()

fun should_flat_map_async_error(): Effect[Assert] =
    let task = pure(20).start()
    let result <- task.flat_map(value => fail_kind("capy.test.async.mapper", "bad value")).join()
    match result with
    case Success _ -> assert_that(false).is_true()
    case Error error -> assert_that(error.kind).is_equal_to("capy.test.async.mapper")

private fun success_values(results: List[Result[int]]): List[int] =
    match results[0] with
    case None -> []
    case Some { value } ->
        match value with
        case Success { value } -> [value] + success_values(results[1:])
        case Error _ -> [-1] + success_values(results[1:])

private fun result_kinds(results: List[Result[int]]): List[String] =
    match results[0] with
    case None -> []
    case Some { value } ->
        match value with
        case Success _ -> ["success"] + result_kinds(results[1:])
        case Error error -> [error.kind] + result_kinds(results[1:])

private fun portable_failure(): int = (1L / 0L).to_int()
