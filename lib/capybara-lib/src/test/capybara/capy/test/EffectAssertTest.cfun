from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }
from /capy/lang/Effect import { * }

fun tests(): Effect[TestFile] =
    test_file("/capy/test/EffectAssert.cfun", [
        effect_test("effect assertion compares result", () => effect_assertion_compares_result()),
        effect_test("effect assertion delegates to nested assertion", () => effect_assertion_delegates_to_nested_assertion()),
    ])

fun effect_assertion_compares_result(): Effect[Assert] =
    assert_that(sequence_two("Capy", "Bara")).is_equal_to("Capy:Bara")

fun effect_assertion_delegates_to_nested_assertion(): Effect[Assert] =
    assert_that(pure("Capybara")).satisfies(value => assert_that(value).starts_with("Capy"))

private fun sequence_two(left: String, right: String): Effect[String] =
    let first <- pure(left)
    let second <- pure(right)
    first + ":" + second
