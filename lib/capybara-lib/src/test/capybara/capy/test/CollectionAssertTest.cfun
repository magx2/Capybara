from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }

fun tests(): TestFile =
    test_file("/capy/test/CollectionAssertTest.cfun", [
        test("should assert list", should_assert_list()),
        test("should assert empty list", should_assert_empty_list()),
        test("should assert set", should_assert_set()),
        test("should assert empty set", should_assert_empty_set()),
        test("should assert dict", should_assert_dict()),
        test("should assert empty dict", should_assert_empty_dict()),
    ])

fun should_assert_list(): Assert =
    let l = [1, 2, 3]
    assert_that(l.size).is_equal_to(3)

fun should_assert_empty_list(): Assert =
    assert_that([].size).is_equal_to(0)

fun should_assert_set(): Assert =
    let s = {1, 2, 3}
    assert_that(s.size).is_equal_to(3)

fun should_assert_empty_set(): Assert =
    let empty_set: set[int] = {1, 2} - 1 - 2
    assert_that(empty_set.size).is_equal_to(0)

fun should_assert_dict(): Assert =
    let d: dict[int] = {"one": 1, "two": 2}
    assert_that(d.size).is_equal_to(2)

fun should_assert_empty_dict(): Assert =
    let d: dict[int] = {:}
    assert_that(d.size).is_equal_to(0)


