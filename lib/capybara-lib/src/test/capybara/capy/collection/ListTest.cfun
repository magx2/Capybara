from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Seq import { * }
from /capy/collection/List import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    test_file("/capy/collection/List.cfun", [
        test("should report size and emptiness", () => list_should_report_size_and_emptiness()),
        test("should append values and lists", () => list_should_append_values_and_lists()),
        test("should remove values and lists", () => list_should_remove_values_and_lists()),
        test("should test any and all values", () => list_should_test_any_and_all_values()),
        test("should detect contained values", () => list_should_detect_contained_values()),
        test("should reduce values", () => list_should_reduce_values()),
        test("should map values", () => list_should_map_values()),
        test("should filter and reject values", () => list_should_filter_and_reject_values()),
        test("should flat map values", () => list_should_flat_map_values()),
        test("should get values by index", () => list_should_get_values_by_index()),
        test("should get values by range", () => list_should_get_values_by_range()),
    ])

fun list_should_report_size_and_emptiness(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that([1, 2, 3].size()).is_equal_to(3),
        assert_that(empty.is_empty()).is_equal_to(true),
        assert_that([1].is_empty()).is_equal_to(false),
    ])

fun list_should_append_values_and_lists(): Assert =
    let base: List[int] = [1, 2]
    let other: List[int] = [3, 4]
    assert_all([
        assert_that([1, 2] + 3).is_equal_to([1, 2, 3]),
        assert_that([1, 2].plus(3)).is_equal_to([1, 2, 3]),
        assert_that([1, 2] + [3, 4]).is_equal_to([1, 2, 3, 4]),
        assert_that(base.plus(other)).is_equal_to([1, 2, 3, 4]),
    ])

fun list_should_remove_values_and_lists(): Assert =
    let base: List[int] = [1, 2, 3, 4]
    let other: List[int] = [2, 4]
    assert_all([
        assert_that([1, 2, 1, 3] - 1).is_equal_to([2, 3]),
        assert_that([1, 2, 1, 3].minus(1)).is_equal_to([2, 3]),
        assert_that([1, 2, 3, 4] - [2, 4]).is_equal_to([1, 3]),
        assert_that(base.minus(other)).is_equal_to([1, 3]),
    ])

fun list_should_test_any_and_all_values(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that([1, 2, 3].any(value => value > 2)).is_equal_to(true),
        assert_that([1, 2, 3].any(value => value > 5)).is_equal_to(false),
        assert_that([2, 4, 6].all(value => value % 2 == 0)).is_equal_to(true),
        assert_that([2, 3, 6].all(value => value % 2 == 0)).is_equal_to(false),
        assert_that(empty.all(value => value > 0)).is_equal_to(true),
    ])

fun list_should_detect_contained_values(): Assert =
    assert_all([
        assert_that([1, 2, 3].contains(2)).is_equal_to(true),
        assert_that([1, 2, 3] ? 4).is_equal_to(false),
    ])

fun list_should_reduce_values(): Assert =
    let empty: List[int] = []
    assert_all([
        assert_that([1, 2, 3] |> 0, (acc, value) => acc + value).is_equal_to(6),
        assert_that(empty.reduce(10, (acc, value) => acc + value)).is_equal_to(10),
    ])

fun list_should_map_values(): Assert =
    assert_all([
        assert_that(([1, 2, 3] | value => value * 2).as_list()).is_equal_to([2, 4, 6]),
        assert_that([1, 2].map(value => "v" + value).as_list()).is_equal_to(["v1", "v2"]),
    ])

fun list_should_filter_and_reject_values(): Assert =
    assert_all([
        assert_that(([1, 2, 3, 4] |- value => value % 2 == 0).as_list()).is_equal_to([1, 3]),
        assert_that([1, 2, 3].filter(value => value < 3).as_list()).is_equal_to([1, 2]),
        assert_that([1, 2, 3].reject(value => value < 3).as_list()).is_equal_to([3]),
    ])

fun list_should_flat_map_values(): Assert =
    assert_all([
        assert_that(([1, 2] |* value => [value, value + 10]).as_list()).is_equal_to([1, 11, 2, 12]),
        assert_that([3].flat_map(value => [value, value * 2]).as_list()).is_equal_to([3, 6]),
    ])

fun list_should_get_values_by_index(): Assert =
    let values = [10, 20, 30, 40]
    assert_all([
        assert_that(values[0]).contains(10),
        assert_that(values.get(2)).contains(30),
        assert_that(values[-1]).contains(40),
        assert_that(values[10]).is_empty(),
        assert_that(values[-10]).is_empty(),
    ])

fun list_should_get_values_by_range(): Assert =
    let values = [10, 20, 30, 40]
    assert_all([
        assert_that(values[1, 3]).is_equal_to([20, 30]),
        assert_that(values.get(0, 2)).is_equal_to([10, 20]),
        assert_that(values[-3, -1]).is_equal_to([20, 30]),
    ])
