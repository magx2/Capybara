from /capy/date_time/Time import { * }
from /capy/test/Assert import { * }
from /capy/lang/Math import { * }
from /capy/lang/Result import { * }
from /capy/test/CapyTest import { * }

fun tests(): TestFile =
    let test_cases = [
        // valid times
        (0, 0, 0, true),
        (23, 59, 59, true),
        (12, 30, 45, true),
        // invalid times - too high
        (24, 0, 0, false),
        (0, 60, 0, false),
        (0, 0, 60, false),
        // invalid times - negative
        (-1, 0, 0, false),
        (0, -1, 0, false),
        (0, 0, -1, false),
    ] | (hour, minute, second, is_valid) => _test_time(hour, minute, second, is_valid)
    test_file('/capy/date_time/Time.cfun',
        test_cases
        + _test_to_seconds()
        + _test_to_minutes()
        + _test_to_hours()
        + _test_round_to_minutes()
        + _test_round_to_hours()
        + _test_add_seconds()
        + _test_add_minutes()
        + _test_add_hours())

fun _test_time(hour: int, minute: int, second: int, is_valid: bool): TestCase =
    let assert: Assert =
        if is_valid
        then assert_that(Time { hour, minute, second })
            .succeeds(time =>
                assert_all([
                    assert_that(time.hour).is_equal_to(hour),
                    assert_that(time.minute).is_equal_to(minute),
                    assert_that(time.second).is_equal_to(second),
                ]))
        else assert_that(Time { hour, minute, second }).fails()
    test("Time \{ hour: {hour}, minute: {minute}, second: {second} } should " + (if is_valid then "succeed" else "fail"), assert)

fun _test_to_seconds(): list[TestCase] =
    [
        (4, 23, 59, 15839),
        (2, 30, 0, 9000),
        (3, 0, 0, 10800),
    ] | (hour, minute, second, expected) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.to_seconds() should return the {expected} seconds",
        assert_that(Time { hour, minute, second } | t => Success { t.to_seconds() }).succeeds(expected))

fun _test_to_minutes(): list[TestCase] =
    [
        (4, 23, 59, 263),
        (2, 30, 0, 150),
        (3, 0, 0, 180),
    ] | (hour, minute, second, expected) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.to_minutes() should return the {expected} minutes",
        assert_that(Time { hour, minute, second } | t => Success { t.to_minutes() }).succeeds(expected))

fun _test_to_hours(): list[TestCase] =
    [
        (4, 23, 59, 4),
        (2, 30, 0, 2),
        (3, 0, 0, 3),
    ] | (hour, minute, second, expected) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.to_hours() should return the {expected} hours",
        assert_that(Time { hour, minute, second } | t => Success { t.to_hours() }).succeeds(expected))

fun _test_round_to_minutes(): TestCase =
    test(
        "Time \{hour: 23, minute: 59, seconds: 59}.round_to_minutes() should return Time \{hour: 23, minute: 59, seconds: 0}",
        assert_that(Time { hour: 23, minute: 59, second: 59 })
            .succeeds(time =>
                assert_all([
                    assert_that(time.round_to_minutes().hour).is_equal_to(23),
                    assert_that(time.round_to_minutes().minute).is_equal_to(59),
                    assert_that(time.round_to_minutes().second).is_equal_to(0),
                ])))

fun _test_round_to_hours(): TestCase =
    test(
        "Time \{hour: 23, minute: 59, seconds: 59}.round_to_hours() should return Time \{hour: 23, minute: 0, seconds: 0}",
        assert_that(Time { hour: 23, minute: 59, second: 59 })
            .succeeds(time =>
                assert_all([
                    assert_that(time.round_to_hours().hour).is_equal_to(23),
                    assert_that(time.round_to_hours().minute).is_equal_to(0),
                    assert_that(time.round_to_hours().second).is_equal_to(0),
                ])))

fun _test_add_seconds(): list[TestCase] =
    [
        // plus
        (23, 59, 59, 1, 0, 0, 0),
        (23, 59, 59, 60, 0, 0, 59),
        (23, 59, 59, 3600, 0, 59, 59),
        (23, 59, 59, 3661, 1, 1, 0),
        // minus
        (23, 59, 59, -1, 23, 59, 58),
        (0, 0, 0, -1, 23, 59, 59),
        (0, 0, 0, -60, 23, 59, 0),
        (0, 0, 0, -3600, 23, 0, 0),
        (0, 0, 0, -3661, 22, 58, 59),
    ] | (hour, minute, second, seconds_to_add, expected_hour, expected_minute, expected_second) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.add_seconds({seconds_to_add}) should return expected time",
        assert_that(Time { hour, minute, second })
            .succeeds(time =>
                assert_all([
                    assert_that(time.add_seconds(seconds_to_add).hour).is_equal_to(expected_hour),
                    assert_that(time.add_seconds(seconds_to_add).minute).is_equal_to(expected_minute),
                    assert_that(time.add_seconds(seconds_to_add).second).is_equal_to(expected_second),
                ])))

fun _test_add_minutes(): list[TestCase] =
    [
        // plus
        (23, 59, 59, 1, 0, 0, 59),
        (23, 59, 59, 60, 0, 59, 59),
        (23, 59, 59, 61, 1, 0, 59),
        // minus
        (23, 59, 59, -1, 23, 58, 59),
        (0, 0, 0, -1, 23, 59, 0),
        (0, 0, 0, -60, 23, 0, 0),
        (0, 0, 0, -61, 22, 59, 0),
    ] | (hour, minute, second, minutes_to_add, expected_hour, expected_minute, expected_second) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.add_minutes({minutes_to_add}) should return expected time",
        assert_that(Time { hour, minute, second })
            .succeeds(time =>
                assert_all([
                    assert_that(time.add_minutes(minutes_to_add).hour).is_equal_to(expected_hour),
                    assert_that(time.add_minutes(minutes_to_add).minute).is_equal_to(expected_minute),
                    assert_that(time.add_minutes(minutes_to_add).second).is_equal_to(expected_second),
                ])))

fun _test_add_hours(): list[TestCase] =
    [
        // plus
        (23, 59, 59, 1, 0, 59, 59),
        // minus
        (23, 59, 59, -1, 22, 59, 59),
        (0, 0, 0, -1, 23, 0, 0),
    ] | (hour, minute, second, hours_to_add, expected_hour, expected_minute, expected_second) => test(
        "Time \{ hour: {hour}, minute: {minute}, second: {second} }.add_hours({hours_to_add}) should return expected time",
        assert_that(Time { hour, minute, second })
            .succeeds(time =>
                assert_all([
                    assert_that(time.add_hours(hours_to_add).hour).is_equal_to(expected_hour),
                    assert_that(time.add_hours(hours_to_add).minute).is_equal_to(expected_minute),
                    assert_that(time.add_hours(hours_to_add).second).is_equal_to(expected_second),
                ])))
