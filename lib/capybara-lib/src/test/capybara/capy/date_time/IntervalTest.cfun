from /capy/date_time/Interval import { * }
from /capy/date_time/Date import { * }
from /capy/date_time/DateTime import { * }
from /capy/date_time/Duration import { * }
from /capy/date_time/Time import { * }
from /capy/lang/Result import { * }
from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    let success_test_cases = [
        _should_parse_interval(
            "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z",
            "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2008, 5, 11, 15, 30, 0),
            DateDuration { years: 0, months: 0, days: 437, hours: 2, minutes: 30, seconds: 0 }
        ),
        _should_parse_interval(
            "20070301T130000Z/20080511T153000Z",
            "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2008, 5, 11, 15, 30, 0),
            DateDuration { years: 0, months: 0, days: 437, hours: 2, minutes: 30, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T13:00:00Z/P1Y2M10DT2H30M",
            "2007-03-01T13:00:00Z/P1Y2M10DT2H30M",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2008, 5, 11, 15, 30, 0),
            DateDuration { years: 1, months: 2, days: 10, hours: 2, minutes: 30, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T14:00:00+01:00/P1D",
            "2007-03-01T13:00:00Z/P1D",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2007, 3, 2, 13, 0, 0),
            DateDuration { years: 0, months: 0, days: 1, hours: 0, minutes: 0, seconds: 0 }
        ),
        _should_parse_interval(
            "P1Y2M10DT2H30M/2008-05-11T15:30:00Z",
            "P1Y2M10DT2H30M/2008-05-11T15:30:00Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2008, 5, 11, 15, 30, 0),
            DateDuration { years: 1, months: 2, days: 10, hours: 2, minutes: 30, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T13:00:00Z--2008-05-11T15:30:00Z",
            "2007-03-01T13:00:00Z/2008-05-11T15:30:00Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2008, 5, 11, 15, 30, 0),
            DateDuration { years: 0, months: 0, days: 437, hours: 2, minutes: 30, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T13:00:00Z--P10D",
            "2007-03-01T13:00:00Z/P10D",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2007, 3, 11, 13, 0, 0),
            DateDuration { years: 0, months: 0, days: 10, hours: 0, minutes: 0, seconds: 0 }
        ),
        _should_parse_interval(
            "P10D--2007-03-11T13:00:00Z",
            "P10D/2007-03-11T13:00:00Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2007, 3, 11, 13, 0, 0),
            DateDuration { years: 0, months: 0, days: 10, hours: 0, minutes: 0, seconds: 0 }
        ),
        _should_parse_interval(
            "P1D/2007-03-03T15:30:10Z",
            "P1D/2007-03-03T15:30:10Z",
            _interval_datetime(2007, 3, 2, 15, 30, 10),
            _interval_datetime(2007, 3, 3, 15, 30, 10),
            DateDuration { years: 0, months: 0, days: 1, hours: 0, minutes: 0, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T13:00:00Z/P1D",
            "2007-03-01T13:00:00Z/P1D",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2007, 3, 2, 13, 0, 0),
            DateDuration { years: 0, months: 0, days: 1, hours: 0, minutes: 0, seconds: 0 }
        ),
        _should_parse_interval(
            "2007-03-01T13:00:00Z/2007-03-03T15:30:10Z",
            "2007-03-01T13:00:00Z/2007-03-03T15:30:10Z",
            _interval_datetime(2007, 3, 1, 13, 0, 0),
            _interval_datetime(2007, 3, 3, 15, 30, 10),
            DateDuration { years: 0, months: 0, days: 2, hours: 2, minutes: 30, seconds: 10 }
        ),
    ]
    let failed_test_cases = {
        "P1D/P2D" : "Invalid ISO 8601 interval format: interval cannot contain a duration on both sides",
        "2007-03-01/2008-05-11" : "Invalid ISO 8601 interval format: interval endpoints must be UTC date-times",
        "2007-03-01/P2W" : "Invalid ISO 8601 interval format: interval endpoints must be UTC date-times",
        "P2W/2007-03-15" : "Invalid ISO 8601 interval format: interval endpoints must be UTC date-times",
        "2007-03-01/2007-03-01T13:00:00Z" : "Invalid ISO 8601 interval format: interval endpoints must be UTC date-times",
        "2007-03-01/P1DT2H" : "Invalid ISO 8601 interval format: interval endpoints must be UTC date-times",
        "2008-05-11T15:30:00Z/2007-03-01T13:00:00Z" : "Invalid ISO 8601 interval format: interval start must not be after interval end",
        "2007-03-01--2007-03-02--P1D" : "Invalid ISO 8601 interval format: expected exactly one interval separator",
    } |> [], (acc, iso, expected_message) =>
        acc + test("should fail parsing {iso}",
            () => assert_that(/capy/date_time/Interval.from_iso_8601(iso)).fails(expected_message))

    test_file("/capy/date_time/Interval.cfun", success_test_cases + failed_test_cases)

fun _should_parse_interval(
    iso: String,
    canonical: String,
    start: DateTime,
    end: DateTime,
    duration: Duration
): Effect[TestCase] =
    test("should parse {iso}",
        () => assert_that(/capy/date_time/Interval.from_iso_8601(iso))
            .succeeds(interval =>
                assert_all([
                    assert_that(interval.to_iso_8601()).is_equal_to(canonical),
                    assert_that(interval)
                        .has_start(start)
                        .has_end(end)
                        .has_duration(duration),
                ])))

fun _interval_date(year: int, month: int, day: int): Date =
    match Date { day: day, month: month, year: year } with
    case Success { value } -> value
    case Error -> UNIX_DATE

fun _interval_time(hour: int, minute: int, second: int): Time =
    match Time { hour: hour, minute: minute, second: second, offset_minutes: None {} } with
    case Success { value } -> value
    case Error -> MIDNIGHT

fun _interval_datetime(year: int, month: int, day: int, hour: int, minute: int, second: int): DateTime =
    DateTime {
        date: _interval_date(year, month, day),
        time: _interval_time(hour, minute, second)
    }
