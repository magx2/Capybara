from /capy/date_time/Date import { * }
from /capy/test/Assert import { * }
from /capy/lang/Effect import { * }
from /capy/lang/Math import { * }
from /capy/lang/Result import { * }
from /capy/lang/Collections import { * }
from /capy/test/CapyTest import { * }

fun tests(): Effect[TestFile] =
    let test_cases = [
        // valid dates - first day
        (1, JANUARY, 2020, true),
        (1, FEBRUARY, 2020, true),
        (1, MARCH, 2020, true),
        (1, APRIL, 2020, true),
        (1, MAY, 2020, true),
        (1, JUNE, 2020, true),
        (1, JULY, 2020, true),
        (1, AUGUST, 2020, true),
        (1, SEPTEMBER, 2020, true),
        (1, OCTOBER, 2020, true),
        (1, NOVEMBER, 2020, true),
        (1, DECEMBER, 2020, true),
        // valid dates - last day
        (31, JANUARY, 2020, true),
        (28, FEBRUARY, 2020, true),
        (29, FEBRUARY, 2020, true),
        (28, FEBRUARY, 2019, true),
        (31, MARCH, 2020, true),
        (30, APRIL, 2020, true),
        (31, MAY, 2020, true),
        (30, JUNE, 2020, true),
        (31, JULY, 2020, true),
        (31, AUGUST, 2020, true),
        (30, SEPTEMBER, 2020, true),
        (31, OCTOBER, 2020, true),
        (30, NOVEMBER, 2020, true),
        (31, DECEMBER, 2020, true),
        // invalid dates - too high day
        (31 + 1, JANUARY, 2020, false),
        (29 + 1, FEBRUARY, 2020, false),
        (28 + 1, FEBRUARY, 2019, false),
        (31 + 1, MARCH, 2020, false),
        (30 + 1, APRIL, 2020, false),
        (31 + 1, MAY, 2020, false),
        (30 + 1, JUNE, 2020, false),
        (31 + 1, JULY, 2020, false),
        (31 + 1, AUGUST, 2020, false),
        (30 + 1, SEPTEMBER, 2020, false),
        (31 + 1, OCTOBER, 2020, false),
        (30 + 1, NOVEMBER, 2020, false),
        (31 + 1, DECEMBER, 2020, false),
        // invalid dates
        (-1, JANUARY, 2020, false),
        (0, FEBRUARY, 2020, false),
        (1, JANUARY - 1, 2020, false),
        (1, DECEMBER + 1, 2020, false),
    ] | (day, month, year, is_valid) => _test_date(day, month, year, is_valid)
    test_file('/capy/date_time/Date.cfun',
        test_cases
        + _test_leap_year()
        + _date_test_to_iso_8601()
        + _date_test_from_iso_8601_success()
        + _date_test_from_iso_8601_failure())

fun _test_date(day: int, month: int, year: int, is_valid: bool): Effect[TestCase] =
    let assert: Assert =
        if is_valid
        then assert_that(Date { day, month, year })
            .succeeds(date =>
                assert_that(date)
                    .has_day(day)
                    .has_month(month)
                    .has_year(year))
        else assert_that(Date { day, month, year }).fails()
    test(
        "Date \{ day: {day}, month: {month}, year: {year} } should be " + (if is_valid then 'valid' else 'invalid'),
        () => assert)

fun _test_leap_year(): List[Effect[TestCase]] =
    let leap_year = Date { day: 1, month: JANUARY, year: 2020 } | d => Success { d.leap_year() }
    let not_leap_year = Date { day: 1, month: JANUARY, year: 2019 } | d => Success { d.leap_year() }
    [
        test('1/1/2020 should be a leap year', () => assert_that(leap_year).succeeds(true)),
        test('1/1/2019 should not be a leap year', () => assert_that(not_leap_year).succeeds(false)) ]

fun _date_test_to_iso_8601(): List[Effect[TestCase]] =
    [
        (7, JANUARY, 2000, "2000-01-07"),
        (7, JANUARY, -1, "-0001-01-07"),
        (7, JANUARY, 10000, "+10000-01-07"),
    ] | (day, month, year, expected) => test(
        "Date.to_iso_8601() should format {day}/{month}/{year}",
        () => assert_that(Date { day, month, year } | d => Success { d.to_iso_8601() }).succeeds(expected))

fun _date_test_from_iso_8601_success(): List[Effect[TestCase]] =
    [
        ("2000-01-07", 7, JANUARY, 2000),
        ("20000107", 7, JANUARY, 2000),
        ("-0001-01-07", 7, JANUARY, -1),
        ("+10000-01-07", 7, JANUARY, 10000),
    ] | (iso, day, month, year) => test(
        "Date.from_iso_8601 should parse {iso}",
        () => assert_that(/capy/date_time/Date.from_iso_8601(iso)).succeeds(date =>
            assert_that(date)
                .has_day(day)
                .has_month(month)
                .has_year(year)))

fun _date_test_from_iso_8601_failure(): List[Effect[TestCase]] =
    [
        "2000-02-30",
        "2000-01",
        "2000-W01-1",
        "2000-01-07Z",
        "2000/01/07",
    ] | iso => test(
        "Date.from_iso_8601 should fail for {iso}",
        () => assert_that(/capy/date_time/Date.from_iso_8601(iso)).fails())

fun _date_test_value(day: int, month: int, year: int): Date =
    match Date { day: day, month: month, year: year } with
    case Success { value } -> value
    case Error -> UNIX_DATE
