from /capy/date_time/Duration import { * }
from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }

fun tests(): TestFile =
    let round_trip_test_cases = {
        "PT0S" : ZERO,
        "P3Y6M4DT12H30M5S" : DateDuration { years: 3, months: 6, days: 4, hours: 12, minutes: 30, seconds: 5L },
        "P123Y4M5DT6H7M8S" : DateDuration { years: 123, months: 4, days: 5, hours: 6, minutes: 7, seconds: 8L },
        "P4Y" : DateDuration { years: 4, months: 0, days: 0, hours: 0, minutes: 0, seconds: 0L },
        "P23DT23H" : DateDuration { years: 0, months: 0, days: 23, hours: 23, minutes: 0, seconds: 0L },
        "P2W" : WeekDuration { weeks: 2 },
        "PT2147483648S" : DateDuration { years: 0, months: 0, days: 0, hours: 0, minutes: 0, seconds: 2147483648L },
    } |> [], (acc, iso, expected) => acc + test("should round-trip {iso}",
        assert_all([
            assert_that(from_iso_8601(iso)).succeeds(expected),
            assert_that(expected.to_iso_8601()).is_equal_to(iso),
        ]))
    let parse_only_test_cases = [
        ("PT36H", DateDuration { years: 0, months: 0, days: 0, hours: 36, minutes: 0, seconds: 0L }),
        ("P00030604T123005", DateDuration { years: 3, months: 6, days: 4, hours: 12, minutes: 30, seconds: 5L }),
        ("P0003-06-04T12:30:05", DateDuration { years: 3, months: 6, days: 4, hours: 12, minutes: 30, seconds: 5L }),
    ] | (iso, expected) => test("should parse {iso}", assert_that(from_iso_8601(iso)).succeeds(expected))
    let failed_test_cases = [
        "P",
        "PT",
        "1DT2H",
        "P1H",
        "P1S",
        "P1W2D",
        "P1WT2H",
        "P1D2Y",
        "P0003-13-04T12:30:05",
    ] | iso => test("should fail parsing {iso}", assert_that(from_iso_8601(iso)).fails())
    test_file("/capy/date_time/Duration.cfun", round_trip_test_cases + parse_only_test_cases + failed_test_cases)
