from /capy/date_time/DateTime import { * }
from /capy/date_time/Time import { * }
from /capy/date_time/Date import { * }
from /capy/date_time/Duration import { * }
from /capy/test/Assert import { * }
from /capy/test/CapyTest import { * }

fun _at(days_since_epoch: int, seconds_since_midnight: int): DateTime =
    let epoch_date = UNIX_DATE
    let midnight = MIDNIGHT
    DateTime {
        date: epoch_date.add_days(days_since_epoch),
        time: midnight.add_seconds(seconds_since_midnight)
    }

fun tests(): TestFile =
    test_file('/capy/date_time/DateTime.cfun',
        [_test_unix_epoch()]
        + _test_timestamp()
        + _test_plus()
        + _test_minus()
        + _test_comparisons())

fun _test_unix_epoch(): TestCase =
    test("unix_epoch() should return the correct DateTime for 1 January 1970 at 00:00:00",
        let epoch = unix_epoch()
        assert_all([
            assert_that(epoch.date.year).is_equal_to(1970),
            assert_that(epoch.date.month).is_equal_to(1),
            assert_that(epoch.date.day).is_equal_to(1),
            assert_that(epoch.time.hour).is_equal_to(0),
            assert_that(epoch.time.minute).is_equal_to(0),
            assert_that(epoch.time.second).is_equal_to(0),
        ]))

fun _test_timestamp(): list[TestCase] =
    [
        (_at(0, 0), 0L),
        (_at(1, 0), 86400L),
        (_at(0, 3600), 3600L),
        (_at(0, 60), 60L),
        (_at(0, 1), 1L),
        (_at(-1, 86399), -1L),
        (_at(1, 3600), 90000L),
    ] | (datetime, expected) => test(
        "{datetime}.timestamp() should return the correct Unix timestamp",
        assert_that(datetime.timestamp()).is_equal_to(expected))

fun _test_plus(): list[TestCase] =
    let base = _at(0, 0)
    let epoch_date = UNIX_DATE
    let jan_31_2024 = epoch_date.add_years_months(54, 0).add_days(30)
    [
        ("plus with week duration", base.plus(WeekDuration { weeks: 2 }), _at(14, 0)),
        ("plus with date duration and carry", base.plus(DateDuration { years: 0, months: 0, days: 1, hours: 1, minutes: 30, seconds: 0L }), _at(1, 5400)),
        ("plus should clamp month day", DateTime { date: jan_31_2024, time: MIDNIGHT }.plus(DateDuration { years: 0, months: 1, days: 0, hours: 0, minutes: 0, seconds: 0L }), DateTime { date: jan_31_2024.add_years_months(0, 1), time: MIDNIGHT }),
                ("plus should handle very large hour component without overflow", base.plus(DateDuration { years: 0, months: 0, days: 0, hours: 600000, minutes: 0, seconds: 0L }), _at(25000, 0)),
    ] | (name, actual, expected) =>
        test(name, _assert_datetime(actual, expected))

fun _test_minus(): list[TestCase] =
    let base = _at(1, 0)
    let epoch_date = UNIX_DATE
    let mar_31_2024 = epoch_date.add_years_months(54, 2).add_days(30)
    let duration_minus_test_cases = [
        ("minus with week duration", base.minus(WeekDuration { weeks: 1 }), _at(-6, 0)),
        ("minus with date duration and borrow", base.minus(DateDuration { years: 0, months: 0, days: 0, hours: 1, minutes: 0, seconds: 1L }), _at(0, 82799)),
            ] | (name, actual, expected) =>
        test(name, _assert_datetime(actual, expected))
    duration_minus_test_cases + [
        test("minus with DateTime should return elapsed duration",
            _assert_minus_duration(_at(2, 9010), _at(0, 0), 181810L)),
        test("minus with same DateTime should return zero duration",
            _assert_minus_duration(_at(2, 9010), _at(2, 9010), 0L)),
        test("minus with earlier receiver should return negative seconds duration",
            _assert_minus_duration(_at(0, 0), _at(2, 9010), -181810L)),
        test("minus with cross day boundary should keep full elapsed seconds in seconds field",
            _assert_minus_duration(_at(1, 10), _at(0, 86390), 20L)),
        test("minus with DateTime should keep long-range elapsed seconds",
            _assert_minus_duration(_at(30000, 0), _at(0, 0), 2592000000L)),
    ]

fun _test_comparisons(): list[TestCase] =
    let first = _at(0, 0)
    let second = _at(0, 1)
    let third = _at(1, 0)
    [
        test("greater_than should return true when this DateTime is later",
            assert_all([
                assert_that(second.greater_than(first)).is_true(),
                assert_that(first.greater_than(second)).is_false(),
            ])),
        test("less_than should return true when this DateTime is earlier",
            assert_all([
                assert_that(first.less_than(second)).is_true(),
                assert_that(second.less_than(first)).is_false(),
            ])),
        test("operator > should compare DateTime values",
            assert_all([
                assert_that(second > first).is_true(),
                assert_that(first > second).is_false(),
            ])),
        test("operator < should compare DateTime values",
            assert_all([
                assert_that(second < third).is_true(),
                assert_that(third < second).is_false(),
            ])),
    ]

fun _assert_duration_components(
    duration: Duration,
    years: int,
    months: int,
    days: int,
    hours: int,
    minutes: int,
    seconds: long
): Assert =
    assert_all([
        assert_that(duration.years()).is_equal_to(years),
        assert_that(duration.months()).is_equal_to(months),
        assert_that(duration.days()).is_equal_to(days),
        assert_that(duration.hours()).is_equal_to(hours),
        assert_that(duration.minutes()).is_equal_to(minutes),
        assert_that(duration.seconds()).is_equal_to(seconds),
    ])

fun _assert_minus_duration(
    left: DateTime,
    right: DateTime,
    seconds: long
): Assert =
    _assert_duration_components(left.minus(right), 0, 0, 0, 0, 0, seconds)

fun _assert_datetime(actual: DateTime, expected: DateTime): Assert =
    assert_all([
        assert_that(actual.date.year).is_equal_to(expected.date.year),
        assert_that(actual.date.month).is_equal_to(expected.date.month),
        assert_that(actual.date.day).is_equal_to(expected.date.day),
        assert_that(actual.time.hour).is_equal_to(expected.time.hour),
        assert_that(actual.time.minute).is_equal_to(expected.time.minute),
        assert_that(actual.time.second).is_equal_to(expected.time.second),
    ])
