    DictAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun SeqAssertion[T].is_equal_to(other: Seq[T]): SeqAssertion[T] =
    let assertion = Assertion {
        result: this.value.as_list() == other.as_list(),
        message: "Expected sequence:\n" + this.value.as_list() + "\nto be equal to:\n" + other.as_list()
    }
    SeqAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun SeqAssertion[T].has_size(other: int): SeqAssertion[T] =
    let assertion = Assertion {
        result: this.value.as_list().size == other,
        message: "Expected sequence size:\n" + this.value.as_list().size + "\nto be equal to:\n" + other
    }
    SeqAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun SeqAssertion[T].is_empty(): SeqAssertion[T] =
    let assertion = Assertion {
        result: this.value.as_list().size == 0,
        message: "Expected sequence:\n" + this.value.as_list() + "\nto be empty"
    }
    SeqAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun SeqAssertion[T].contains(other: T): SeqAssertion[T] =
    let assertion = Assertion {
        result: this.value.as_list() |any? v => v == other,
        message: "Expected sequence:\n" + this.value.as_list() + "\nto contain:\n" + other
    }
    SeqAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun SeqAssertion[T].does_not_contain(other: T): SeqAssertion[T] =
    let assertion = Assertion {
        result: (this.value.as_list() |any? v => v == other) == false,
        message: "Expected sequence:\n" + this.value.as_list() + "\nnot to contain:\n" + other
    }
    SeqAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun assert_that(value: string) = StringAssertion { value: value, assertions: [] }
fun assert_that(value: int) = IntAssertion { value: value, assertions: [] }
fun assert_that(value: long) = LongAssertion { value: value, assertions: [] }
fun assert_that(value: double) = DoubleAssertion { value: value, assertions: [] }
fun assert_that(value: float) = FloatAssertion { value: value, assertions: [] }
fun assert_that(value: bool) = BoolAssertion { value: value, assertions: [] }
fun assert_that(value: list[T]): ListAssertion[T] = ListAssertion { value: value, assertions: [] }
fun assert_that(value: set[T]): SetAssertion[T] = SetAssertion { value: value, assertions: [] }
fun assert_that(value: dict[T]): DictAssertion[T] = DictAssertion { value: value, assertions: [] }
fun assert_that(value: Seq[T]): SeqAssertion[T] = SeqAssertion { value: value, assertions: [] }
fun assert_that(value: Option[T]) = OptionAssertion { value: value, assertions: [] }
fun assert_that(value: Result[T]) = ResultAssertion { value: value, assertions: [] }
fun assert_that(value: data) = DataAssertion { value: value, assertions: [] }

fun Assert.check(): list[string] =
    this.assertions
        |- a =>  a.result
        | a => a.message
        | m => "❌ " + m

fun run_tests(asserts: list[Assert]) =
    let errors = asserts |* a => a.check()
    if errors.size == 0
    then /capy/lang/Program.Success { results: ["✅ All tests (" + asserts.size + ") passed"] }
    else /capy/lang/Program.Failed { exitCode: 2, errors: ["❌ Some test failed " + errors.size * 100.0 / asserts.size + "% (" + errors.size + "/" + asserts.size + ")"] + errors }
