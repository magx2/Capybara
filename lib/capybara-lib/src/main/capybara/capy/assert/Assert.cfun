    ListAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun ListAssertion[T].has_size(other: int): ListAssertion[T] =
    let assertion = Assertion {
        result: this.value.size == other,
        message: "Expected list size:\n" + this.value.size + "\nto be equal to:\n" + other
    }
    ListAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun ListAssertion[T].is_empty(): ListAssertion[T] =
    let assertion = Assertion {
        result: this.value.size == 0,
        message: "Expected list:\n" + this.value + "\nto be empty"
    }
    ListAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun ListAssertion[T].contains(other: T): ListAssertion[T] =
    let assertion = Assertion {
        result: this.value |any? v => v == other,
        message: "Expected list:\n" + this.value + "\nto contain:\n" + other
    }
    ListAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

fun ListAssertion[T].does_not_contain(other: T): ListAssertion[T] =
    let assertion = Assertion {
        result: (this.value |any? v => v == other) == false,
        message: "Expected list:\n" + this.value + "\nnot to contain:\n" + other
    }
    ListAssertion {
        value: this.value,
        assertions: this.assertions + assertion
    }

