    let assertion = Assertion {
        result: this.value.as_list() |any? v => v == other,
        message: "Expected sequence:\n" + this.value.as_list() + "\nto contain:\n" + other,
        type: 'SeqAssert[T].contains'
    }
    SeqAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

