        assertions: this.assertions + () => assertion
    }

fun DataAssert.is_equal_to(other: data): DataAssert =
    let assertion = Assertion {
        result: this.value == other,
        message: "Expected data:\n" + this.value + "\nto be equal to:\n" + other,
        type: 'DataAssert.is_equal_to'
    }
    DataAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun DataAssert.contains(other: any): DataAssert =
    let assertion = Assertion {
        result: ('' + this.value) ? ('' + other),
        message: "Expected data:\n" + this.value + "\nto contain:\n" + other,
        type: 'DataAssert.contains'
    }
    DataAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun OptionAssert[T].is_equal_to(other: /capy/lang/Option[T]): OptionAssert[T] =
    let assertion = Assertion {
        result: this.value == other,
        message: "Expected data:\n" + this.value + "\nto be equal to:\n" + other,
        type: 'OptionAssert[T].is_equal_to'
    }
    OptionAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun OptionAssert[T].contains(other: T): OptionAssert[T] =
    let assertion = Assertion {
        result: match this.value with
            | Some s -> s == other
            | _ -> false,
        message: "Expected option:\n" + this.value + "\nto contains:\n" + other,
        type: 'OptionAssert[T].contains'
    }
    OptionAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun OptionAssert[T].is_empty(): OptionAssert[T] =
    let assertion = Assertion {
        result: match this.value with
            | None -> true
            | _ -> false,
        message: "Expected option:\n" + this.value + "\nto be empty",
        type: 'OptionAssert[T].is_empty'
    }
    OptionAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ResultAssert[T].is_equal_to(other: /capy/lang/Result[T]): ResultAssert[T] =
    let assertion = Assertion {
        result: this.value == other,
        message: "Expected result:\n" + this.value + "\nto contains:\n" + other,
        type: 'ResultAssert[T].is_equal_to'
    }
    ResultAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ResultAssert[T].succeeds(): ResultAssert[T] =
    let assertion = Assertion {
        result:
            match this.value with
            | Error e  -> false
            | Success s -> true,
        message: "Expected result:\n" + this.value + "\nto succeed",
        type: 'ResultAssert[T].succeeds'
    }
    ResultAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ResultAssert[T].succeeds(other: T): ResultAssert[T] =
    let assertion = Assertion {
        result:
            match this.value with
            | Error e  -> false
            | Success { v } -> v == other,
        message: "Expected result:\n" + this.value + "\nto succeed with value:\n" + other,
        type: 'ResultAssert[T].succeeds'
    }
    ResultAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ResultAssert[T].fails(): ResultAssert[T] =
    let assertion = Assertion {
        result: {
            match this.value with
            | Error e -> true
            | Success s -> false
        },
        message: "Expected result:\n" + this.value + "\nto fail",
        type: 'ResultAssert[T].fails'
    }
    ResultAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ResultAssert[T].fails(message: string): ResultAssert[T] =
    let assertion = Assertion {
        result: {
            match this.value with
            | Error e -> e.message == message
            | Success s -> false
        },
        message: "Expected result:\n" + this.value + "\nto failed with message:\n" + message,
        type: 'ResultAssert[T].fails'
    }
    ResultAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun ListAssert[T].is_equal_to(other: list[T]): ListAssert[T] =
    let assertion = Assertion {
        result: this.value == other,
        message: "Expected list:\n" + this.value + "\nto be equal to:\n" + other,
        type: 'ListAssert[T].is_equal_to'
    }
    ListAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

