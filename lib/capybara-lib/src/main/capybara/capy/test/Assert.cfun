    let assertion = Assertion {
        result: this.value == other,
        message: "Expected int:\n" + this.value + "\nto be equal to:\n" + other,
        type: 'IntAssert.is_equal_to'
    }
    IntAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

