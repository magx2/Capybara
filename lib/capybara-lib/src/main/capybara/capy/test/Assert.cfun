    }

fun SeqAssert[T].is_equal_to(other: Seq[T]): SeqAssert[T] =
    let assertion = Assertion {
        result: this.value.as_list() == other.as_list(),
        message: "Expected sequence:\n" + this.value.as_list() + "\nto be equal to:\n" + other.as_list(),
        type: 'SeqAssert[T].is_equal_to'
    }
    SeqAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun SeqAssert[T].has_size(other: int): SeqAssert[T] =
    let assertion = Assertion {
        result: this.value.as_list().size == other,
        message: "Expected sequence size:\n" + this.value.as_list().size + "\nto be equal to:\n" + other,
        type: 'SeqAssert[T].has_size'
    }
    SeqAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

