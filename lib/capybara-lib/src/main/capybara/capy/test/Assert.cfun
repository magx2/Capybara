fun DurationAssert.has_weeks(other: int): DurationAssert =
    let assertion = Assertion {
        result: match this.value with
            case WeekDuration { weeks } -> weeks == other
            case _ -> false,
        message: "Expected duration weeks:\n" + this.value.to_iso_8601() + "\nto have weeks:\n" + other,
        type: 'DurationAssert.has_weeks'
    }
    DurationAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

