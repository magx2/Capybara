        result: this.value |any? (k, v) => k == other,
        message: "Expected dict:\n" + this.value + "\nto contain key:\n" + other,
        type: 'DictAssert[T].contains_key'
    }
    DictAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

