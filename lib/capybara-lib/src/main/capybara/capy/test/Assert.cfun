from /capy/lang/Option import { * }
from /capy/lang/Result import { * }
from /capy/lang/Seq import { * }
from /capy/date_time/Date import { * }
from /capy/date_time/Time import { * }
from /capy/date_time/DateTime import { * }
from /capy/date_time/Duration import { * }
from /capy/date_time/Interval import { * }

data Assertion { result: bool, message: string, type: string }

type Assert { assertions: list[() => Assertion] } =
    _TechnicalAssert
    | StringAssert | IntAssert | LongAssert | DoubleAssert | FloatAssert | BoolAssert
    | DataAssert | OptionAssert | ResultAssert
    | DateAssert | TimeAssert | DateTimeAssert | DurationAssert | IntervalAssert
    | ListAssert | SetAssert | DictAssert | SeqAssert

fun Assert.failed(): bool = this.assertions | supplier => supplier().result |any? r => !r

fun Assert.succeeded(): bool = !this.failed()

data _TechnicalAssert { assertions: list[() => Assertion] }
data StringAssert { value: string }
data IntAssert { value: int }
data LongAssert { value: long }
data DoubleAssert { value: double }
data FloatAssert { value: float }
data BoolAssert { value: bool }
data DataAssert { value: data }
data OptionAssert[T] { value: /capy/lang/Option[T] }
data ResultAssert[T] { value: /capy/lang/Result[T] }
data DateAssert { value: Date }
data TimeAssert { value: Time }
data DateTimeAssert { value: DateTime }
data DurationAssert { value: Duration }
data IntervalAssert { value: Interval }
data ListAssert[T] { value: list[T] }
data SetAssert[T] { value: set[T] }
data DictAssert[T] { value: dict[T] }
data SeqAssert[T] { value: Seq[T] }

fun assert_all(asserts: list[Assert]): Assert =
    let assertions: list[() => Assertion] = asserts | assert => assert.assertions |> [], (acc, assertions) => acc + assertions
    _TechnicalAssert { assertions: assertions }

fun StringAssert.is_equal_to(other: string): StringAssert =
    let assertion = Assertion {
        result: this.value == other,
        message: "Expected string:\n" + this.value + "\nto be equal to:\n" + other,
        type: 'StringAssert.is_equal_to'
    }
    StringAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

fun StringAssert.starts_with(other: string): StringAssert =
    let assertion = Assertion {
       result: this.value.starts_with(other),
       message: "Expected string:\n" + this.value + "\nto start with:\n" + other,
        type: 'StringAssert.starts_with'
    }
    StringAssert {
       value: this.value,
       assertions: this.assertions + () => assertion
    }

fun StringAssert.does_not_start_with(other: string): StringAssert =
    let assertion = Assertion {
       result: this.value.starts_with(other) != true,
       message: "Expected string:\n" + this.value + "\nnot to start with:\n" + other,
        type: 'StringAssert.does_not_start_with'
    }
    StringAssert {
       value: this.value,
       assertions: this.assertions + () => assertion
    }

fun StringAssert.contains(other: string): StringAssert =
    let assertion = Assertion {
       result: this.value ? other,
       message: "Expected string:\n" + this.value + "\nto contain:\n" + other,
        type: 'StringAssert.contains'
    }
    StringAssert {
       value: this.value,
       assertions: this.assertions + () => assertion
    }

