    let assertion = Assertion {
        result: this.value.as_list().size == 0,
        message: "Expected sequence:\n" + this.value.as_list() + "\nto be empty",
        type: 'SeqAssert[T].is_empty'
    }
    SeqAssert {
        value: this.value,
        assertions: this.assertions + () => assertion
    }

